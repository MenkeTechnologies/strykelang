#!/usr/bin/env stryke

# Pinning batch Native-D (2026-05-10): Namespaces & Atomics (from NAMESPACE_FUNCTIONS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Namespaced Functions ────────────────────────────────────────────────────

fn Math::Utils::add_three = _0 + _1 + _2
Math::Utils::add_three(1, 2, 3) |> aeq 6, "call namespaced function"

fn MyProject::sum(@list) {
    sum(@list) + 100
}

MyProject::sum(1, 2, 3) |> aeq 106, "namespaced function calling builtin"
sum(1, 2, 3) |> aeq 6, "builtin sum still works"

# ── Atomics (Oursync) ───────────────────────────────────────────────────────

package Counter
oursync $val = 0

fn bump = $Counter::val++

package main
fan 100 { Counter::bump() }
$Counter::val |> aeq 100, "oursync shared across workers"

test_run
