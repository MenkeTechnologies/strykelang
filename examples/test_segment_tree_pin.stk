#!/usr/bin/env stryke

package SegTree

fn new($arr) {
    val $n = len @$arr
    val @tree = (0) x (4 * $n)
    val $st = { n => $n, tree => \@tree }
    _build $st, $arr, 1, 0, $n - 1; $st
}
fn _build($st, $arr, $node, $start, $end) {
    if ($start == $end) { $st->{tree}->[$node] = $arr->[$start]; return }
    val $mid = int(($start + $end) / 2)
    _build $st, $arr, 2 * $node, $start, $mid
    _build $st, $arr, 2 * $node + 1, $mid + 1, $end
    $st->{tree}->[$node] = $st->{tree}->[2 * $node] + $st->{tree}->[2 * $node + 1]
}
fn update($st, $idx, $val) { _update $st, 1, 0, $st->{n} - 1, $idx, $val }
fn _update($st, $node, $start, $end, $idx, $val) {
    if ($start == $end) { $st->{tree}->[$node] = $val; return }
    val $mid = int(($start + $end) / 2)
    if ($idx <= $mid) { _update $st, 2 * $node, $start, $mid, $idx, $val }
    else { _update $st, 2 * $node + 1, $mid + 1, $end, $idx, $val }
    $st->{tree}->[$node] = $st->{tree}->[2 * $node] + $st->{tree}->[2 * $node + 1]
}
fn query($st, $l, $r) { _query $st, 1, 0, $st->{n} - 1, $l, $r }
fn _query($st, $node, $start, $end, $l, $r) {
    return 0 if $r < $start || $end < $l
    return $st->{tree}->[$node] if $l <= $start && $end <= $r
    val $mid = int(($start + $end) / 2)
    _query($st, 2 * $node, $start, $mid, $l, $r) + _query($st, 2 * $node + 1, $mid + 1, $end, $l, $r)
}

package main

# --- Basic E2E ---
val @d1 = (1, 2, 3, 4, 5)
val $st1 = SegTree::new \@d1
SegTree::query($st1, 0, 2) |> aeq 6, "sum [0:2]"
SegTree::query($st1, 0, 4) |> aeq 15, "sum [0:4]"

SegTree::update($st1, 2, 10)
SegTree::query($st1, 0, 2) |> aeq 13, "sum [0:2] after update (1+2+10)"
SegTree::query($st1, 2, 4) |> aeq 19, "sum [2:4] after update (10+4+5)"

# --- Stress: 100 random ops ---
var @d2
for (1:50) { push @d2, int(rand 100) }
val $st2 = SegTree::new \@d2
var $ok = 1
for (1:100) {
    if (rand() < 0.5) {
        val $idx = int(rand 50); val $val = int(rand 100)
        @d2[$idx] = $val
        SegTree::update $st2, $idx, $val
    } else {
        var $l = int(rand 50); var $r = int(rand 50)
        if ($l > $r) { val $tmp = $l; $l = $r; $r = $tmp }
        var $sum = 0; for val $i ($l : $r) { $sum = $sum + $d2[$i] }
        $ok = 0 if SegTree::query($st2, $l, $r) != $sum
    }
}
$ok |> aeq 1, "stress tests match naive sum"

test_run
