#!/usr/bin/env stryke

fn Seg::build($values) {
    my $n = len @$values
    my @tree = ()
    for my $i (0:4*$n) { push @tree, 0 }
    if ($n > 0) {
        Seg::_build(\@tree, $values, 1, 0, $n - 1)
    }
    +{ n => $n, tree => \@tree }
}

fn Seg::_build($tree, $values, $node, $l, $r) {
    if ($l == $r) {
        $tree->[$node] = $values->[$l]
        return
    }
    my $m = int(($l + $r) / 2)
    Seg::_build($tree, $values, 2*$node,   $l,   $m)
    Seg::_build($tree, $values, 2*$node+1, $m+1, $r)
    $tree->[$node] = $tree->[2*$node] + $tree->[2*$node+1]
}

fn Seg::sum($seg, $ql, $qr) {
    return 0 if $seg->{n} == 0
    Seg::_sum($seg->{tree}, 1, 0, $seg->{n} - 1, $ql, $qr)
}

fn Seg::_sum($tree, $node, $l, $r, $ql, $qr) {
    return 0 if $qr < $l || $r < $ql
    return $tree->[$node] if $ql <= $l && $r <= $qr
    my $m = int(($l + $r) / 2)
    Seg::_sum($tree, 2*$node,   $l,   $m, $ql, $qr) +
    Seg::_sum($tree, 2*$node+1, $m+1, $r, $ql, $qr)
}

fn Seg::update($seg, $idx, $val) {
    Seg::_update($seg->{tree}, 1, 0, $seg->{n} - 1, $idx, $val)
}

fn Seg::_update($tree, $node, $l, $r, $idx, $val) {
    if ($l == $r) {
        $tree->[$node] = $val
        return
    }
    my $m = int(($l + $r) / 2)
    if ($idx <= $m) {
        Seg::_update($tree, 2*$node,   $l,   $m, $idx, $val)
    } else {
        Seg::_update($tree, 2*$node+1, $m+1, $r, $idx, $val)
    }
    $tree->[$node] = $tree->[2*$node] + $tree->[2*$node+1]
}

my @vals = (1, 3, 5, 7, 9, 11)
my $seg = Seg::build(\@vals)

Seg::sum($seg, 0, 5)   |> aeq 36, "full sum"
Seg::sum($seg, 0, 0)   |> aeq 1,  "single elem"
Seg::sum($seg, 5, 5)   |> aeq 11, "last elem"
Seg::sum($seg, 1, 3)   |> aeq 15, "middle range 3+5+7"
Seg::sum($seg, 2, 4)   |> aeq 21, "5+7+9"
Seg::sum($seg, 0, 2)   |> aeq 9,  "1+3+5"

Seg::update($seg, 2, 100)
Seg::sum($seg, 1, 3)   |> aeq 110, "after update 3+100+7"
Seg::sum($seg, 0, 5)   |> aeq 131, "full sum after update"
Seg::sum($seg, 2, 2)   |> aeq 100, "single updated"

Seg::update($seg, 0, 0)
Seg::sum($seg, 0, 5)   |> aeq 130, "after zero update"

# All zeros
my @z = (0, 0, 0, 0)
my $sz = Seg::build(\@z)
Seg::sum($sz, 0, 3)    |> aeq 0, "all zeros"

# Single element tree
my @s = (42)
my $ss = Seg::build(\@s)
Seg::sum($ss, 0, 0)    |> aeq 42, "single tree"
Seg::update($ss, 0, 7)
Seg::sum($ss, 0, 0)    |> aeq 7, "single after update"

# Negative numbers
my @n = (-1, -2, 5, -3, 10)
my $sn = Seg::build(\@n)
Seg::sum($sn, 0, 4)    |> aeq 9, "with negatives"
Seg::sum($sn, 0, 1)    |> aeq -3, "two negatives"

# Larger
my @big = ()
for my $i (1:100) { push @big, $i }
my $sb = Seg::build(\@big)
Seg::sum($sb, 0, 99)   |> aeq 5050, "1..100 sum"
Seg::sum($sb, 0, 9)    |> aeq 55,   "1..10 sum"
Seg::sum($sb, 50, 50)  |> aeq 51,   "point 50"

test_run
