#!/usr/bin/env stryke

package HopcroftKarp

fn bfs($u_size, $adj, $pair_u, $pair_v, $dist) {
    var @queue
    for (var $u = 1; $u <= $u_size; $u++) {
        if ($pair_u->[$u] == 0) { $dist->[$u] = 0; push @queue, $u }
        else { $dist->[$u] = 1000000000 }
    }
    $dist->[0] = 1000000000; var $head = 0
    while ($head < len @queue) {
        val $u = $queue[$head++]
        if ($dist->[$u] < $dist->[0]) {
            val $u_adj = $adj->[$u] // []
            for val $v (@$u_adj) {
                val $u_next = $pair_v->[$v]
                if ($dist->[$u_next] == 1000000000) {
                    $dist->[$u_next] = $dist->[$u] + 1; push @queue, $u_next
                }
            }
        }
    }
    return $dist->[0] != 1000000000
}

fn dfs($u, $adj, $pair_u, $pair_v, $dist) {
    if ($u != 0) {
        val $u_adj = $adj->[$u] // []
        for val $v (@$u_adj) {
            val $u_next = $pair_v->[$v]
            if ($dist->[$u_next] == $dist->[$u] + 1) {
                if (HopcroftKarp::dfs($u_next, $adj, $pair_u, $pair_v, $dist)) {
                    $pair_v->[$v] = $u; $pair_u->[$u] = $v; return 1
                }
            }
        }
        $dist->[$u] = 1000000000; return 0
    }
    1
}

fn solve($u_size, $v_size, $adj) {
    val @pair_u = (0) x ($u_size + 1); val @pair_v = (0) x ($v_size + 1); val @dist = (0) x ($u_size + 1)
    var $matching = 0
    while (HopcroftKarp::bfs($u_size, $adj, \@pair_u, \@pair_v, \@dist)) {
        for (var $u = 1; $u <= $u_size; $u++) {
            if ($pair_u[$u] == 0) {
                if (HopcroftKarp::dfs($u, $adj, \@pair_u, \@pair_v, \@dist)) { $matching++ }
            }
        }
    }
    { count => $matching, pair_u => \@pair_u, pair_v => \@pair_v }
}

package main

# --- Basic E2E ---
val $adj1 = [ [], [2, 3], [1], [2], [2, 4] ]
val $res1 = HopcroftKarp::solve(4, 4, $adj1)
$res1->{count} |> aeq 4, "max matching is 4"

# --- Disconnected ---
val $adj2 = [ [], [], [] ]
val $res2 = HopcroftKarp::solve(2, 2, $adj2)
$res2->{count} |> aeq 0, "max matching is 0"

# --- Complete Bipartite K_3_3 ---
val $adj3 = [ [], [1, 2, 3], [1, 2, 3], [1, 2, 3] ]
val $res3 = HopcroftKarp::solve(3, 3, $adj3)
$res3->{count} |> aeq 3, "max matching K_3_3 is 3"

test_run
