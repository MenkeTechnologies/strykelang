#!/usr/bin/env stryke

# rpn.stk — Reverse Polish Notation calculator.
#
# Demonstrates:
#   * Stack-based evaluation
#   * String tokenization
#   * Multi-branch dispatch
#
# Run: stryke --no-interop examples/rpn.stk

fn RPN::eval($expr) {
    var @stack = ()
    for val $tok (split / +/, $expr) {
        next if len($tok) == 0
        if ($tok eq "+") {
            val $y = pop @stack
            val $x = pop @stack
            push @stack, $x + $y
        } elsif ($tok eq "-") {
            val $y = pop @stack
            val $x = pop @stack
            push @stack, $x - $y
        } elsif ($tok eq "*") {
            val $y = pop @stack
            val $x = pop @stack
            push @stack, $x * $y
        } elsif ($tok eq "/") {
            val $y = pop @stack
            val $x = pop @stack
            push @stack, $x / $y
        } elsif ($tok eq "neg") {
            val $x = pop @stack
            push @stack, 0 - $x
        } elsif ($tok eq "dup") {
            val $x = $stack[-1]
            push @stack, $x
        } elsif ($tok eq "swap") {
            val $y = pop @stack
            val $x = pop @stack
            push @stack, $y
            push @stack, $x
        } else {
            push @stack, $tok + 0
        }
    }
    $stack[-1]
}

p "═══════════════════════════════════════════════"
p " Stryke RPN Calculator Demo"
p "═══════════════════════════════════════════════"
p ""

var @progs = (
    "3 4 +",
    "10 2 -",
    "6 7 *",
    "20 4 /",
    "2 3 4 * +",
    "5 1 2 + 4 * + 3 -",
    "5 dup *",
    "8 3 swap -",
    "10 neg",
)

p "── Program → Result ──────────────────────────"
for val $p (@progs) {
    p "  #{$p}  =  #{RPN::eval($p)}"
}

p ""
p "── Polynomial: ((3·5+2)·4-7) ─────────────────"
p "  3 5 * 2 + 4 * 7 -  =  #{RPN::eval('3 5 * 2 + 4 * 7 -')}"

p ""
p "── Distance via Pythagoras: √(3² + 4²) ──────"
val $d2 = RPN::eval("3 dup * 4 dup * +")
p "  3² + 4² = $d2  →  distance = 5"
