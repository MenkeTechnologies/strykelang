#!/usr/bin/env stryke

package Fenwick2D

fn new($rows, $cols) {
    val $tree = []
    for (0 : $rows) {
        val $row = []
        for (0 : $cols) { push @$row, 0 }
        push @$tree, $row
    }
    { tree => $tree, rows => $rows, cols => $cols }
}

fn update($bit, $r, $c, $val) {
    val $tree = $bit->{tree}; val $rows = $bit->{rows}; val $cols = $bit->{cols}
    for (var $i = $r + 1; $i <= $rows; $i += ($i & -$i)) {
        var $row = $tree->[$i]
        for (var $j = $c + 1; $j <= $cols; $j += ($j & -$j)) { $row->[$j] += $val }
    }
}

fn query($bit, $r, $c) {
    val $tree = $bit->{tree}; var $sum = 0
    for (var $i = $r + 1; $i > 0; $i -= ($i & -$i)) {
        val $row = $tree->[$i]
        for (var $j = $c + 1; $j > 0; $j -= ($j & -$j)) { $sum += $row->[$j] }
    }
    $sum
}

fn query_range($bit, $r1, $c1, $r2, $c2) {
    var $res = query($bit, $r2, $c2)
    $res -= query($bit, $r1 - 1, $c2) if $r1 > 0
    $res -= query($bit, $r2, $c1 - 1) if $c1 > 0
    $res += query($bit, $r1 - 1, $c1 - 1) if $r1 > 0 && $c1 > 0
    $res
}

package main

# --- Basic E2E ---
val $bit = Fenwick2D::new(10, 10)
Fenwick2D::update($bit, 2, 2, 5)
Fenwick2D::update($bit, 5, 5, 10)
Fenwick2D::query_range($bit, 0, 0, 9, 9) |> aeq 15, "full range sum"
Fenwick2D::query_range($bit, 2, 2, 2, 2) |> aeq 5, "point query"
Fenwick2D::query_range($bit, 3, 3, 4, 4) |> aeq 0, "empty subgrid"
Fenwick2D::query_range($bit, 0, 0, 5, 5) |> aeq 15, "partial overlap sum"

# --- Overlap test ---
Fenwick2D::update($bit, 2, 5, 3)
Fenwick2D::query_range($bit, 2, 2, 5, 5) |> aeq 18, "subgrid with 3 points"

test_run
