#!/usr/bin/env stryke

fn Topo::sort($edges, $nodes) {
    var %indeg = ()
    var %adj   = ()
    for val $n (@$nodes) {
        $indeg{$n} = 0
        $adj{$n}   = []
    }
    for val $e (@$edges) {
        val ($u, $v) = @$e
        push @{$adj{$u}}, $v
        $indeg{$v} = $indeg{$v} + 1
    }
    var @queue = ()
    for val $n (sort @$nodes) {
        push @queue, $n if $indeg{$n} == 0
    }
    var @order = ()
    while (len(@queue) > 0) {
        val $n = shift @queue
        push @order, $n
        val @nexts = sort @{$adj{$n}}
        for val $m (@nexts) {
            $indeg{$m} = $indeg{$m} - 1
            push @queue, $m if $indeg{$m} == 0
        }
    }
    if (len(@order) == len(@$nodes)) {
        return \@order
    }
    return undef
}

val @nodes = ("a","b","c","d")
val @edges = (["a","b"], ["a","c"], ["b","d"], ["c","d"])
val $order = Topo::sort(\@edges, \@nodes)

len(@$order)   |> aeq 4, "4 nodes ordered"
$order->[0]    |> aeq "a", "a first"
$order->[3]    |> aeq "d", "d last"

var %pos = ()
var $i = 0
for val $n (@$order) {
    $pos{$n} = $i
    $i = $i + 1
}

(($pos{"a"} < $pos{"b"}) ? 1 : 0) |> aeq 1, "a before b"
(($pos{"a"} < $pos{"c"}) ? 1 : 0) |> aeq 1, "a before c"
(($pos{"b"} < $pos{"d"}) ? 1 : 0) |> aeq 1, "b before d"
(($pos{"c"} < $pos{"d"}) ? 1 : 0) |> aeq 1, "c before d"

val @cn = ("x","y","z")
val @ce = (["x","y"], ["y","z"], ["z","x"])
val $r = Topo::sort(\@ce, \@cn)

(defined($r) ? 1 : 0) |> aeq 0, "cycle returns undef"

val @s = ("only")
val @se = ()
val $sr = Topo::sort(\@se, \@s)

len(@$sr)   |> aeq 1, "single node"
$sr->[0]    |> aeq "only", "only node"

val @dn = ("a","b","c","d")
val @de = (["a","b"], ["c","d"])
val $dr = Topo::sort(\@de, \@dn)

len(@$dr)   |> aeq 4, "disconnected 4 nodes"

val @ln = ("1","2","3","4","5")
val @le = (["1","2"], ["2","3"], ["3","4"], ["4","5"])
val $lr = Topo::sort(\@le, \@ln)

join(",", @$lr) |> aeq "1,2,3,4,5", "linear chain order"

val @en = ()
val @ee = ()
val $er = Topo::sort(\@ee, \@en)

len(@$er)   |> aeq 0, "empty"

test_run
