#!/usr/bin/env stryke

# Pinning tests for signal processing bugs from BUGS.md

# Pinning test for BUG-127: iota_range ignores arguments after the first
val @iota1 = iota_range(5, 99);
val @iota2 = iota_range(5);
aeq(join("", @iota1), join("", @iota2), "BUG-127: iota_range should ignore arguments after the first");


# BUG-129 (FIXED): convolve_full now returns the actual convolution values
# (m + n − 1 samples). @a and @b above flatten through the pipe; pass as
# arrayrefs so the builtin sees two operands.
val @conv_full = convolve_full([1, 2, 3], [4, 5]);
aeq(join(",", @conv_full), "4,13,22,15", "BUG-129 (FIXED): convolve_full([1,2,3], [4,5]) = [4, 13, 22, 15]");


# Pinning test for BUG-130: detrend_linear returns slope, not samples
val @data = (1, 2, 3, 4, 5);
val $detrended = detrend_linear(@data);
aeq($detrended, 0, "BUG-130: detrend_linear should return 0");


test_run
