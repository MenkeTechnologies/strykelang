#!/usr/bin/env stryke

fn Earley::state_hash($s) {
    my $rhs_str = ~> @{$s->{rhs}} join(" ")
    "#{$s->{lhs}}|#{$rhs_str}|#{$s->{dot}}|#{$s->{start}}"
}

fn Earley::add_state($chart, $idx, $state) {
    my $hash = Earley::state_hash($state)
    return 0 if $chart->[$idx]->{seen}->{$hash}
    $chart->[$idx]->{seen}->{$hash} = 1
    push @{$chart->[$idx]->{states}}, $state
    1
}

fn Earley::parse($words, $grammar, $start) {
    my $n = len @$words
    my @chart
    for (0 : $n) { push @chart, +{ states => [], seen => {} } }
    Earley::add_state(\@chart, 0, +{ lhs => "gamma", rhs => [$start], dot => 0, start => 0 })

    for my $i (0 : $n) {
        my $k = 0
        while ($k < len(@{$chart[$i]->{states}})) {
            my $state = $chart[$i]->{states}->[$k]
            my $rhs = $state->{rhs}
            my $dot = $state->{dot}
            if ($dot < len(@$rhs)) {
                my $next_sym = $rhs->[$dot]
                if (exists $grammar->{$next_sym}) {
                    for my $rule_rhs (@{$grammar->{$next_sym}}) {
                        Earley::add_state(\@chart, $i, +{
                            lhs => $next_sym, rhs => $rule_rhs,
                            dot => 0, start => $i,
                        })
                    }
                } else {
                    if ($i < $n && $words->[$i] eq $next_sym) {
                        Earley::add_state(\@chart, $i + 1, +{
                            lhs => $state->{lhs}, rhs => $rhs,
                            dot => $dot + 1, start => $state->{start},
                        })
                    }
                }
            } else {
                my $start_idx = $state->{start}
                for my $prev (@{$chart[$start_idx]->{states}}) {
                    my $p_rhs = $prev->{rhs}
                    my $p_dot = $prev->{dot}
                    next if $p_dot >= len(@$p_rhs)
                    next if $p_rhs->[$p_dot] ne $state->{lhs}
                    Earley::add_state(\@chart, $i, +{
                        lhs => $prev->{lhs}, rhs => $p_rhs,
                        dot => $p_dot + 1, start => $prev->{start},
                    })
                }
            }
            $k++
        }
    }

    for my $state (@{$chart[$n]->{states}}) {
        return 1 if $state->{lhs} eq "gamma"
                 && $state->{dot} == 1
                 && $state->{start} == 0
    }
    0
}

my %g1 = (
    "S"   => [ ["NP", "VP"] ],
    "VP"  => [ ["V", "NP"], ["eats"] ],
    "NP"  => [ ["Det", "N"], ["she"] ],
    "V"   => [ ["eats"] ],
    "Det" => [ ["a"] ],
    "N"   => [ ["fish"], ["fork"] ],
)

my @w1 = ("she", "eats", "a", "fish")
~> Earley::parse(\@w1, \%g1, "S") aeq(1, "valid CFG parse")

my @w2 = ("she", "a", "fish")
~> Earley::parse(\@w2, \%g1, "S") aeq(0, "invalid CFG parse")

test_run
