#!/usr/bin/env stryke
# Run: stryke --no-interop examples/statistical_sketches.stk

p "--- Stats ---"
val $t = tdigest_new()
tdigest_add $t, _ for 1:1000
val $q = tdigest_quantile $t, 0.5
val @s = reservoir_sample 5, 1:1e4

abs($q - 500) < 10 |> aok "td"
len(@s)            |> aeq 5, "resv"
test_run
