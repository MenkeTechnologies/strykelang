#!/usr/bin/env stryke

# Pinning batch: Numerical methods — Newton, bisection, integration, derivatives.
# Compliance: docs/STYLE_GUIDE.md

fn Nm::near = abs(_ - _1) < _2

# ── Bisection ──────────────────────────────────────────────────────────────

fn Nm::bisect($f, $lo, $hi) {
    for (1:100) {
        my $m = ($lo + $hi) / 2
        return $m if abs($hi - $lo) < 1e-9
        if ($f($lo) * $f($m) < 0) { $hi = $m } else { $lo = $m }
    }
    ($lo + $hi) / 2
}

Nm::near(Nm::bisect(fn { _ * _ - 2 }, 0, 2),       1.41421356, 1e-6) |> aok "bisect √2"
Nm::near(Nm::bisect(fn { _ * _ * _ - 9 }, 0, 4),   9 ** (1/3), 1e-6) |> aok "bisect ∛9"

# ── Newton's method ────────────────────────────────────────────────────────

fn Nm::newton($f, $df, $x0) {
    my $x = $x0
    for (1:50) {
        my $fx = $f($x)
        last if abs($fx) < 1e-12
        $x -= $fx / $df($x)
    }
    $x
}

Nm::near(Nm::newton(fn { _ * _ - 2 },      fn { 2 * _ },     1), sqrt(2), 1e-9) |> aok "newton √2"
Nm::near(Nm::newton(fn { _ * _ * _ - 27 }, fn { 3 * _ * _ }, 3), 3,       1e-9) |> aok "newton ∛27"

# ── Numerical derivative ───────────────────────────────────────────────────

fn Nm::deriv($f, $x) = ($f($x + 1e-6) - $f($x - 1e-6)) / 2e-6

Nm::near(Nm::deriv(fn { _ * _ },  3), 6,      1e-4) |> aok "d/dx x² at 3"
Nm::near(Nm::deriv(fn { _ ** 3 }, 2), 12,     1e-4) |> aok "d/dx x³ at 2"
Nm::near(Nm::deriv(fn { sin(_) }, 0), 1,      1e-4) |> aok "d/dx sin(0)"
Nm::near(Nm::deriv(fn { exp(_) }, 1), exp(1), 1e-4) |> aok "d/dx exp(1)"

# ── Trapezoidal integration ────────────────────────────────────────────────

fn Nm::trap($f, $lo, $hi, $n) {
    my $h = ($hi - $lo) / $n
    my $s = ($f($lo) + $f($hi)) / 2
    $s += $f($lo + $_ * $h) for (1:$n - 1)
    $s * $h
}

Nm::near(Nm::trap(fn { _ * _ }, 0, 1, 1000), 1/3, 1e-4) |> aok "∫ x² [0,1]"
Nm::near(Nm::trap(fn { _ },     0, 10, 100), 50,  1e-9) |> aok "∫ x [0,10]"
Nm::near(Nm::trap(fn { 1 },     0, 5,  10),  5,   1e-9) |> aok "∫ 1 [0,5]"

# ── Simpson's rule ─────────────────────────────────────────────────────────

fn Nm::simpson($f, $lo, $hi, $n) {
    $n += 1 if $n % 2
    my $h = ($hi - $lo) / $n
    my $s = $f($lo) + $f($hi)
    for my $i (1:$n - 1) {
        $s += ($i % 2 ? 4 : 2) * $f($lo + $i * $h)
    }
    $s * $h / 3
}

Nm::near(Nm::simpson(fn { _ ** 3 }, 0, 2, 100),    4, 1e-6) |> aok "Simpson ∫ x³"
Nm::near(Nm::simpson(fn { sin(_) }, 0, 3.141592653589793, 1000), 2, 1e-4) |> aok "Simpson ∫ sin"

# ── Fixed-point iteration ──────────────────────────────────────────────────

fn Nm::fixpt($g, $x0) {
    my $x = $x0
    for (1:1000) {
        my $nx = $g($x)
        return $nx if abs($nx - $x) < 1e-12
        $x = $nx
    }
    $x
}

Nm::near(Nm::fixpt(fn { 1 + 1 / _ }, 1), (1 + sqrt(5)) / 2, 1e-6) |> aok "fixpt φ"

# ── Secant method ──────────────────────────────────────────────────────────

fn Nm::secant($f, $x0, $x1) {
    for (1:100) {
        my $f0 = $f($x0)
        my $f1 = $f($x1)
        last if abs($f1 - $f0) < 1e-15
        my $nx = $x1 - $f1 * ($x1 - $x0) / ($f1 - $f0)
        return $nx if abs($nx - $x1) < 1e-12
        ($x0, $x1) = ($x1, $nx)
    }
    $x1
}

Nm::near(Nm::secant(fn { _ * _ - 5 }, 0, 5), sqrt(5), 1e-9) |> aok "secant √5"

# ── Cramer's rule 2x2 ──────────────────────────────────────────────────────

fn Nm::cramer2($a1, $b1, $c1, $d1, $e1, $f1) {
    my $det = $a1 * $d1 - $b1 * $c1
    return undef if abs($det) < 1e-15
    [($e1 * $d1 - $b1 * $f1) / $det, ($a1 * $f1 - $e1 * $c1) / $det]
}

# 2x + 3y = 8 ; x + 4y = 9  => x=1, y=2
my $sol = Nm::cramer2(2, 3, 1, 4, 8, 9)
Nm::near($sol->[0], 1, 1e-9) |> aok "cramer x"
Nm::near($sol->[1], 2, 1e-9) |> aok "cramer y"

# ── Polynomial eval (Horner) ───────────────────────────────────────────────

fn Nm::horner($coeffs, $x) {
    my $r = 0
    $r = $r * $x + $_ for @$coeffs
    $r
}

Nm::horner([2, 3, 4, 5], 2) |> aeq 41,  "horner 2x³+3x²+4x+5 @ 2"
Nm::horner([1, 0, -1],   3) |> aeq 8,   "x²−1 @ 3"
Nm::horner([1, 1, 1, 1], 1) |> aeq 4,   "ones @ 1"
Nm::horner([1, 0, 0, 0], 5) |> aeq 125, "x³ @ 5"

# ── GCD/LCM via Euclid ─────────────────────────────────────────────────────

fn Nm::gcd($u, $v) {
    while ($v) { ($u, $v) = ($v, $u % $v) }
    $u
}
fn Nm::lcm($u, $v) = $u / Nm::gcd($u, $v) * $v

Nm::gcd(12, 18)    |> aeq 6,   "gcd 12,18"
Nm::gcd(100, 75)   |> aeq 25,  "gcd 100,75"
Nm::lcm(4, 6)      |> aeq 12,  "lcm 4,6"
Nm::lcm(21, 6)     |> aeq 42,  "lcm 21,6"

test_run
