#!/usr/bin/env stryke

# sparse_table.stk — Sparse Table for O(1) range-min queries on
# immutable arrays, with O(n log n) preprocessing.
#
# st[k][i] = min of arr[i .. i + 2^k - 1].
# Recurrence: st[k][i] = min(st[k-1][i], st[k-1][i + 2^(k-1)]).
# Query(l,r): k = floor(log2(r-l+1)); ans = min(st[k][l], st[k][r-2^k+1]).
#
# Run: stryke --no-interop examples/sparse_table.stk

package ST;

fn ilog2($n) {
    my $k = 0
    my $v = $n
    while ($v > 1) {
        $v = $v >> 1
        $k = $k + 1
    }
    $k
}

fn build_min($arr) {
    my $n = len(@$arr)
    my $logn = ilog2($n) + 1
    my @table = ()
    my @row0 = ()
    for my $i (0:$n-1) { push @row0, $arr->[$i] }
    push @table, \@row0
    for my $k (1:$logn-1) {
        my $half = 1 << ($k - 1)
        my $span = 1 << $k
        my @row = ()
        my $last = $n - $span
        if ($last < 0) {
            for my $i (0:$n-1) { push @row, $table[$k-1]->[$i] }
        } else {
            for my $i (0:$last) {
                my $va = $table[$k-1]->[$i]
                my $vb = $table[$k-1]->[$i + $half]
                push @row, ($va <= $vb ? $va : $vb)
            }
        }
        push @table, \@row
    }
    { table => \@table, n => $n, logn => $logn }
}

fn build_max($arr) {
    my $n = len(@$arr)
    my $logn = ilog2($n) + 1
    my @table = ()
    my @row0 = ()
    for my $i (0:$n-1) { push @row0, $arr->[$i] }
    push @table, \@row0
    for my $k (1:$logn-1) {
        my $half = 1 << ($k - 1)
        my $span = 1 << $k
        my @row = ()
        my $last = $n - $span
        if ($last < 0) {
            for my $i (0:$n-1) { push @row, $table[$k-1]->[$i] }
        } else {
            for my $i (0:$last) {
                my $va = $table[$k-1]->[$i]
                my $vb = $table[$k-1]->[$i + $half]
                push @row, ($va >= $vb ? $va : $vb)
            }
        }
        push @table, \@row
    }
    { table => \@table, n => $n, logn => $logn }
}

fn query_min($s, $l, $r) {
    return undef if $l > $r || $l < 0 || $r >= $s->{n}
    my $k = ilog2($r - $l + 1)
    my $span = 1 << $k
    my $va = $s->{table}->[$k]->[$l]
    my $vb = $s->{table}->[$k]->[$r - $span + 1]
    $va <= $vb ? $va : $vb
}

fn query_max($s, $l, $r) {
    return undef if $l > $r || $l < 0 || $r >= $s->{n}
    my $k = ilog2($r - $l + 1)
    my $span = 1 << $k
    my $va = $s->{table}->[$k]->[$l]
    my $vb = $s->{table}->[$k]->[$r - $span + 1]
    $va >= $vb ? $va : $vb
}

package main;

my $arr = [7, 2, 3, 0, 5, 10, 3, 12, 18, 6]
my $smin = ST::build_min($arr)
my $smax = ST::build_max($arr)
p "array: @$arr"
p "min[2..7] = " . ST::query_min($smin, 2, 7)
p "max[2..7] = " . ST::query_max($smax, 2, 7)
p "min[0..9] = " . ST::query_min($smin, 0, 9)
p "max[0..9] = " . ST::query_max($smax, 0, 9)
