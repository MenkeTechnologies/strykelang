#!/usr/bin/env stryke

package Kosaraju

fn dfs1($u, $g, $visited, $stack) {
    $visited->{$u} = 1; val $ns = $g->{$u} // []
    for val $v (@$ns) { if (!$visited->{$v}) { Kosaraju::dfs1($v, $g, $visited, $stack) } }
    push @$stack, $u
}
fn dfs2($u, $rg, $visited, $comp) {
    $visited->{$u} = 1; push @$comp, $u; val $ns = $rg->{$u} // []
    for val $v (@$ns) { if (!$visited->{$v}) { Kosaraju::dfs2($v, $rg, $visited, $comp) } }
}
fn solve($names, $g) {
    val %v1; var @stack
    for val $u (@$names) { if (!$v1{$u}) { Kosaraju::dfs1($u, $g, \%v1, \@stack) } }
    val %rg
    for val $u (@$names) { val $ns = $g->{$u} // []; for val $v (@$ns) { push @{$rg{$v}}, $u } }
    val %v2; var @sccs
    while ((len @stack) > 0) {
        val $u = pop @stack
        if (!$v2{$u}) { val @comp; Kosaraju::dfs2($u, \%rg, \%v2, \@comp); push @sccs, \@comp }
    }
    \@sccs
}

package main

# --- Basic E2E ---
val @n1 = ("0", "1", "2", "3", "4")
val %g1 = ("1"=>["0"], "0"=>["2", "3"], "2"=>["1"], "3"=>["4"])
val $s1 = Kosaraju::solve \@n1, \%g1
len(@$s1) |> aeq 3, "scc count 3"

# --- Complete Graph ---
val @n2 = ("A", "B", "C")
val %g2 = ("A"=>["B", "C"], "B"=>["A", "C"], "C"=>["A", "B"])
val $s2 = Kosaraju::solve \@n2, \%g2
len(@$s2) |> aeq 1, "complete graph scc=1"

# --- Disconnected ---
val @n3 = ("X", "Y")
val %g3 = ("X"=>[], "Y"=>[])
val $s3 = Kosaraju::solve \@n3, \%g3
len(@$s3) |> aeq 2, "disconnected scc=2"

test_run
