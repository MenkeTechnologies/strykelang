#!/usr/bin/env stryke
# Parse-check every top-level examples/*.stk under --no-interop.
# CI uses examples/run_all_ci.stk; this wrapper runs the parse phase only.
#
# Usage: stryke examples/check_no_interop.stk [--summary]

val %opts = %{ getopts({
    "summary" => { help => "pass --summary to run_all_ci" },
}) }
val $runner = dirname(__FILE__) . "/run_all_ci.stk"
var $cmd    = "$^X \"$runner\" --only=parse"
$cmd .= " --summary" if $opts{summary}
exit system($cmd) >> 8
