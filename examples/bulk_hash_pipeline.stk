#!/usr/bin/env stryke
#
# Bulk hash pipeline — each worker hashes a different input string
# using a different hash function. Master aggregates the (input,
# algorithm, hash) triples into a report. Demonstrates heterogeneous
# per-worker assignment + tabular output.
#
# CI-safe: no network, no file I/O. Clean under --no-interop.

p "── bulk hash pipeline ──"

# 6 (input, algorithm) pairs, 6 workers, one task each.
val @tasks = (
    ["hello",         "sha256"],
    ["world",         "sha256"],
    ["stryke",        "sha1"],
    ["congregation",  "sha1"],
    ["pray",          "md5"],
    ["annex",         "md5"],
)
val $n = len(@tasks)
printf "tasks: %d (input × hash algo pairs)\n", $n

val @workers = congregation($n)
var @sorted_workers = sort { _ <=> _1 } @workers

var %results
for var $i (0:len(@sorted_workers) - 1) {
    val $w = $sorted_workers[$i]
    var ($input, $algo) = @{$tasks[$i]}
    val $code = "${algo}(q{$input})"
    val $div = pray $code, $w
    val %reply = annex $div
    $results{$w} = [$input, $algo, $reply{$w}]
}

p "── results ──"
printf "  %-14s  %-7s  %s\n", "input", "algo", "hash"
for val $w (@sorted_workers) {
    val ($input, $algo, $hash) = @{$results{$w}}
    val $short = len($hash) > 32 ? substr($hash, 0, 16) . "..." . substr($hash, -8) : $hash
    printf "  %-14s  %-7s  %s\n", $input, $algo, $short
}

# Verify: re-hash one input locally and compare.
val $expected = sha256("hello")
val $w0 = $sorted_workers[0]
p $results{$w0}[2] eq $expected ? "✓ worker 0 sha256('hello') matches local" : "✗ hash diverged"

excommunicate(@workers)
p "done"
