#!/usr/bin/env stryke

# Pinning batch Native-W (2026-05-10): Extended Bugs Pinning
# Compliance: docs/STYLE_GUIDE.md

# BUG-021: Scalar-ref to arrayref unwrap
val $x_21 = [1, 2, 3]
val $r_21 = \$x_21
eval { val $val = $$r_21->[0] }
$@ =~ /Can't use arrow deref/ |> aok "BUG-021: scalar-ref to arrayref unwrap fails"

# BUG-023: Autovivification
val %h_23
eval { $h_23{k}[0] = "first" }
$@ =~ /Can't assign to arrow array deref/ |> aok "BUG-023: autovivification fails"

# BUG-030 (FIXED): system() now returns the encoded Perl $? word (exit_code << 8),
# matching stock Perl (`system("false")` → 256). Was returning the raw exit code (1).
val $r_30 = system("false")
$r_30 |> aeq 256, "BUG-030 (FIXED): system('false') returns 256 (Perl-encoded \$?)"

# BUG-031 (FIXED): system(LIST) now sets $? to (exit_code << 8) matching Perl —
# `system("sh","-c","exit 7")` leaves $? = 1792 (= 7 << 8). Was dropping to 0.
system("sh", "-c", "exit 7")
$? |> aeq 1792, "BUG-031 (FIXED): system(LIST) sets \$? to encoded exit code"

# BUG-037 (FIXED): closure-wrapped coderef call now flattens @_ into the
# call list (was returning scalar(@_) before the vm_helper fix).
fn Pin::BugsExtended::my_dbl_37(_) { _ * 2 }
val $f_37 = \&Pin::BugsExtended::my_dbl_37
val $h_37 = fn { $f_37(@_) }
$h_37(5) |> aeq 10, "BUG-037 (FIXED): closure passes \@_ flattened, not as count"

# BUG-044: AOP `after` advice sees $? as the *current* shell-status $? (here
# 1792, leaking from BUG-031's system() above), not the wrapped sub's
# return value (42). Documented behavior says it should be the return value.
fn Pin::BugsExtended::payload_44 { 42 }
oursync $after_q = -1
after "Pin::BugsExtended::payload_44" { $after_q = $? }
Pin::BugsExtended::payload_44()
$after_q != 42 |> aok "BUG-044: AOP after \$? is not the sub return value"

# BUG-063: take(N, LIST) returns empty
val @r_63 = take(3, 1..10)
len(@r_63) |> aeq 0, "BUG-063: take(N, LIST) returns empty"

# BUG-065: head(N, LIST) returns N
val @r_65 = head(3, qw(a b c d e))
join(",", @r_65) |> aeq "3", "BUG-065: head(N, LIST) returns N"

# BUG-088: (&@) block prototype drops trailing args
fn Pin::BugsExtended::myff_88(&@) { val $cb = shift; len(@_) }
val $res_88 = Pin::BugsExtended::myff_88 { 1 } 5, 7
$res_88 |> aeq 0, "BUG-088: block prototype drops trailing args"

# BUG-109 (FIXED): sum(\@a) now sums via arrayref operand (was returning 0).
val @a_109 = (1, 2, 3)
sum(\@a_109) |> aeq 6, "BUG-109 (FIXED): sum(\\@a) sums arrayref contents"

test_run
