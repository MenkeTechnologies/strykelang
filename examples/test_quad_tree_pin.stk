#!/usr/bin/env stryke

package QT;

mysync $CAP = 4

fn new($x, $y, $w, $h) {
    {
        box => [$x, $y, $w, $h],
        pts => [],
        nw => undef, ne => undef, sw => undef, se => undef,
        divided => 0,
    }
}

fn _contains($box, $px, $py) {
    return 0 if $px < $box->[0]
    return 0 if $py < $box->[1]
    return 0 if $px >= $box->[0] + $box->[2]
    return 0 if $py >= $box->[1] + $box->[3]
    1
}

fn _intersects($ra, $rb) {
    return 0 if $ra->[0] + $ra->[2] <= $rb->[0]
    return 0 if $rb->[0] + $rb->[2] <= $ra->[0]
    return 0 if $ra->[1] + $ra->[3] <= $rb->[1]
    return 0 if $rb->[1] + $rb->[3] <= $ra->[1]
    1
}

fn _subdivide($q) {
    val $x = $q->{box}->[0]
    val $y = $q->{box}->[1]
    val $w = $q->{box}->[2]
    val $h = $q->{box}->[3]
    val $hw = $w / 2
    val $hh = $h / 2
    $q->{nw} = QT::new($x, $y, $hw, $hh)
    $q->{ne} = QT::new($x + $hw, $y, $hw, $hh)
    $q->{sw} = QT::new($x, $y + $hh, $hw, $hh)
    $q->{se} = QT::new($x + $hw, $y + $hh, $hw, $hh)
    $q->{divided} = 1
    var @old = @{$q->{pts}}
    $q->{pts} = []
    for val $p (@old) { QT::insert($q, $p) }
}

fn insert($q, $p) {
    return 0 if !QT::_contains($q->{box}, $p->[0], $p->[1])
    if (!$q->{divided}) {
        if (len(@{$q->{pts}}) < $CAP) {
            push @{$q->{pts}}, $p
            return 1
        }
        QT::_subdivide($q)
    }
    return 1 if QT::insert($q->{nw}, $p)
    return 1 if QT::insert($q->{ne}, $p)
    return 1 if QT::insert($q->{sw}, $p)
    return 1 if QT::insert($q->{se}, $p)
    0
}

fn query($q, $box, $out) {
    return if !QT::_intersects($q->{box}, $box)
    for val $p (@{$q->{pts}}) {
        if (QT::_contains($box, $p->[0], $p->[1])) {
            push @$out, $p
        }
    }
    if ($q->{divided}) {
        QT::query($q->{nw}, $box, $out)
        QT::query($q->{ne}, $box, $out)
        QT::query($q->{sw}, $box, $out)
        QT::query($q->{se}, $box, $out)
    }
}

fn count($q) {
    var $c = len(@{$q->{pts}})
    if ($q->{divided}) {
        $c = $c + QT::count($q->{nw})
        $c = $c + QT::count($q->{ne})
        $c = $c + QT::count($q->{sw})
        $c = $c + QT::count($q->{se})
    }
    $c
}

package main;

# --- Empty quadtree ---
val $q0 = QT::new(0, 0, 100, 100)
QT::count($q0) |> aeq 0, "empty count"
$q0->{divided} |> aeq 0, "empty not divided"

val @r0 = ()
QT::query($q0, [0, 0, 50, 50], \@r0)
len(@r0) |> aeq 0, "empty query"

# --- Out-of-bounds insert ---
QT::insert($q0, [-1, 50]) |> aeq 0, "left of box rejected"
QT::insert($q0, [100, 50]) |> aeq 0, "right edge rejected"
QT::insert($q0, [50, -1]) |> aeq 0, "above rejected"
QT::insert($q0, [50, 100]) |> aeq 0, "below rejected"
QT::count($q0) |> aeq 0, "OOB no count"

# --- In-bounds insert ---
QT::insert($q0, [0, 0]) |> aeq 1, "origin ok"
QT::insert($q0, [99, 99]) |> aeq 1, "near max ok"
QT::insert($q0, [50, 50]) |> aeq 1, "center ok"
QT::count($q0) |> aeq 3, "count 3"
$q0->{divided} |> aeq 0, "still not divided"

# --- Insert past capacity triggers subdivision ---
val $q1 = QT::new(0, 0, 100, 100)
for val $p ([10, 10], [20, 20], [30, 30], [40, 40]) { QT::insert($q1, $p) }
$q1->{divided} |> aeq 0, "still 4 in leaf"
QT::insert($q1, [80, 80]) |> aeq 1, "5th triggers subdivide"
$q1->{divided} |> aeq 1, "now divided"
QT::count($q1) |> aeq 5, "5 after subdivide"

# --- Range query: subset in box ---
val $q2 = QT::new(0, 0, 100, 100)
var @pts = ([10, 10], [20, 20], [30, 30], [80, 80], [90, 90],
           [50, 50], [55, 55], [45, 60], [60, 45], [70, 30])
for val $p (@pts) { QT::insert($q2, $p) }
QT::count($q2) |> aeq 10, "10 inserted"

val @r1 = ()
QT::query($q2, [0, 0, 50, 50], \@r1)
len(@r1) |> aeq 3, "[0,0,50x50] -> 3 points"

val @r2 = ()
QT::query($q2, [40, 40, 25, 25], \@r2)
len(@r2) |> aeq 4, "[40,40,25x25] -> 4 points"

val @rall = ()
QT::query($q2, [0, 0, 100, 100], \@rall)
len(@rall) |> aeq 10, "whole box returns all"

val @rnone = ()
QT::query($q2, [0, 0, 5, 5], \@rnone)
len(@rnone) |> aeq 0, "tiny corner empty"

# Query box outside tree bounds returns nothing
val @rout = ()
QT::query($q2, [200, 200, 50, 50], \@rout)
len(@rout) |> aeq 0, "external box empty"

# --- Many distinct points at varied positions (causes deep subdivision) ---
val $q3 = QT::new(0, 0, 64, 64)
for val $i (0:7) {
    QT::insert($q3, [$i * 7 + 1, $i * 7 + 1])
}
QT::count($q3) |> aeq 8, "8 diagonal points kept"
val @rd = ()
QT::query($q3, [0, 0, 64, 64], \@rd)
len(@rd) |> aeq 8, "diagonal query returns 8"

# --- Stress with many points ---
val $qs = QT::new(0, 0, 1000, 1000)
var $seed = 1234
for val $i (1:200) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    val $px = $seed % 1000
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    val $py = $seed % 1000
    QT::insert($qs, [$px, $py])
}
QT::count($qs) |> aeq 200, "stress 200"

# Whole-tree query returns all
val @ra = ()
QT::query($qs, [0, 0, 1000, 1000], \@ra)
len(@ra) |> aeq 200, "stress full query"

# Half-tree query returns roughly half (between 60 and 140 with sane RNG)
val @rh = ()
QT::query($qs, [0, 0, 500, 1000], \@rh)
val $h = len(@rh)
($h > 50 && $h < 150) |> aeq 1, "stress half range plausible"

# Point on boundary
val $qb = QT::new(0, 0, 10, 10)
QT::insert($qb, [0, 0]) |> aeq 1, "inclusive left/top"
QT::insert($qb, [10, 5]) |> aeq 0, "exclusive right"
QT::insert($qb, [5, 10]) |> aeq 0, "exclusive bottom"

test_run
