#!/usr/bin/env stryke

package LH;

fn make_node($val, $left, $right, $rank) {
    { val => $val, left => $left, right => $right, rank => $rank }
}

fn rank_of($h) {
    return 0 if !defined $h
    $h->{rank}
}

fn merge_h($ha, $hb) {
    return $hb if !defined $ha
    return $ha if !defined $hb
    var $lo
    var $hi
    if ($ha->{val} <= $hb->{val}) {
        $lo = $ha
        $hi = $hb
    } else {
        $lo = $hb
        $hi = $ha
    }
    val $new_right = merge_h($lo->{right}, $hi)
    val $rl = rank_of($lo->{left})
    val $rr = rank_of($new_right)
    var $left
    var $right
    if ($rl >= $rr) {
        $left = $lo->{left}
        $right = $new_right
    } else {
        $left = $new_right
        $right = $lo->{left}
    }
    make_node($lo->{val}, $left, $right, rank_of($right) + 1)
}

fn empty() { undef }
fn is_empty($h) { !defined $h }

fn insert($h, $v) {
    merge_h($h, make_node($v, undef, undef, 1))
}

fn find_min($h) {
    return undef if !defined $h
    $h->{val}
}

fn delete_min($h) {
    return undef if !defined $h
    merge_h($h->{left}, $h->{right})
}

fn heap_size($h) {
    return 0 if !defined $h
    1 + heap_size($h->{left}) + heap_size($h->{right})
}

fn from_array($arr) {
    var $h = undef
    for val $v (@$arr) {
        $h = insert($h, $v)
    }
    $h
}

fn drain($h) {
    var @out = ()
    var $cur = $h
    while (defined $cur) {
        push @out, find_min($cur)
        $cur = delete_min($cur)
    }
    \@out
}

# Heap (min-) invariant: every parent <= its children.
fn heap_ok($h) {
    return 1 if !defined $h
    if (defined $h->{left} && $h->{left}->{val} < $h->{val}) {
        return 0
    }
    if (defined $h->{right} && $h->{right}->{val} < $h->{val}) {
        return 0
    }
    heap_ok($h->{left}) && heap_ok($h->{right})
}

# Leftist invariant: rank(left) >= rank(right) at every node.
fn leftist_ok($h) {
    return 1 if !defined $h
    return 0 if rank_of($h->{left}) < rank_of($h->{right})
    leftist_ok($h->{left}) && leftist_ok($h->{right})
}

# Rank-correctness: node.rank == rank(right) + 1; null has rank 0.
fn rank_ok($h) {
    return 1 if !defined $h
    return 0 if $h->{rank} != rank_of($h->{right}) + 1
    rank_ok($h->{left}) && rank_ok($h->{right})
}

package main;

# --- Empty heap ---
val $e = LH::empty()
LH::is_empty($e) |> aeq 1, "empty is_empty"
LH::heap_size($e) |> aeq 0, "empty size"
(defined LH::find_min($e)) |> aeq 0, "empty find_min undef"
(defined LH::delete_min($e)) |> aeq 0, "empty delete_min undef"

# --- Single ---
val $h1 = LH::insert(LH::empty(), 42)
LH::is_empty($h1) |> aeq 0, "single not empty"
LH::heap_size($h1) |> aeq 1, "single size"
LH::find_min($h1) |> aeq 42, "single min"
LH::heap_ok($h1) |> aeq 1, "single heap ok"
LH::leftist_ok($h1) |> aeq 1, "single leftist ok"
LH::rank_ok($h1) |> aeq 1, "single rank ok"
LH::is_empty(LH::delete_min($h1)) |> aeq 1, "delete-min single -> empty"

# --- Inserts ---
var $h2 = LH::empty()
for val $v (5, 2, 8, 1, 9, 3, 7, 4, 6) {
    $h2 = LH::insert($h2, $v)
}
LH::heap_size($h2) |> aeq 9, "9 inserts size"
LH::find_min($h2) |> aeq 1, "min after inserts"
LH::heap_ok($h2) |> aeq 1, "inserts heap ok"
LH::leftist_ok($h2) |> aeq 1, "inserts leftist ok"
LH::rank_ok($h2) |> aeq 1, "inserts rank ok"

# --- Drain produces sorted order ---
val $sorted = LH::drain($h2)
len(@$sorted) |> aeq 9, "drain len"
var $is_sorted = 1
for val $i (0:7) {
    $is_sorted = 0 if $sorted->[$i] > $sorted->[$i+1]
}
$is_sorted |> aeq 1, "drain is sorted"
$sorted->[0] |> aeq 1, "drain[0]"
$sorted->[8] |> aeq 9, "drain[8]"

# --- Drain == original sorted ---
val @inp = (5, 2, 8, 1, 9, 3, 7, 4, 6)
val @ref = sort { _ <=> _1 } @inp
var $match = 1
for val $i (0:8) {
    $match = 0 if $sorted->[$i] != $ref[$i]
}
$match |> aeq 1, "drain equals sorted reference"

# --- Merge two heaps ---
val $ha = LH::from_array([10, 30, 50])
val $hb = LH::from_array([20, 40, 60])
val $m = LH::merge_h($ha, $hb)
LH::heap_size($m) |> aeq 6, "merge size"
LH::find_min($m) |> aeq 10, "merge min"
LH::heap_ok($m) |> aeq 1, "merge heap ok"
LH::leftist_ok($m) |> aeq 1, "merge leftist ok"
LH::rank_ok($m) |> aeq 1, "merge rank ok"
val $md = LH::drain($m)
$md->[0] |> aeq 10, "merge drain[0]"
$md->[5] |> aeq 60, "merge drain[5]"

# --- Merge with empty (identity both sides) ---
val $ne = LH::merge_h(LH::empty(), $ha)
LH::heap_size($ne) |> aeq 3, "merge empty left = orig"
val $en = LH::merge_h($ha, LH::empty())
LH::heap_size($en) |> aeq 3, "merge empty right = orig"

# --- Duplicates ---
val $hd = LH::from_array([3, 3, 3, 1, 1, 2])
LH::heap_size($hd) |> aeq 6, "dup size"
LH::heap_ok($hd) |> aeq 1, "dup heap ok"
LH::leftist_ok($hd) |> aeq 1, "dup leftist ok"
val $dd = LH::drain($hd)
$dd->[0] |> aeq 1, "dup drain[0]"
$dd->[1] |> aeq 1, "dup drain[1]"
$dd->[2] |> aeq 2, "dup drain[2]"
$dd->[5] |> aeq 3, "dup drain[5]"

# --- Negative values ---
val $hn = LH::from_array([0, -5, 3, -10, 7, -2])
LH::find_min($hn) |> aeq -10, "neg min"
val $dn = LH::drain($hn)
$dn->[0] |> aeq -10, "neg drain[0]"
$dn->[5] |> aeq 7, "neg drain[5]"

# --- Stress: random sequence vs sort ---
var $seed = 31415
var @big = ()
for val $i (1:200) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    push @big, ($seed % 1000) - 500
}
val $hb = LH::from_array(\@big)
LH::heap_size($hb) |> aeq 200, "stress size"
LH::heap_ok($hb) |> aeq 1, "stress heap ok"
LH::leftist_ok($hb) |> aeq 1, "stress leftist ok"
LH::rank_ok($hb) |> aeq 1, "stress rank ok"

val $drained = LH::drain($hb)
val @brute = sort { _ <=> _1 } @big
var $bmatch = 1
for val $i (0:199) {
    $bmatch = 0 if $drained->[$i] != $brute[$i]
}
$bmatch |> aeq 1, "stress drain == sort reference"

# --- Stress: merge invariant after many randomised merges ---
var $seed2 = 999
var $big_h = LH::empty()
for val $batch (1:10) {
    var @bunch = ()
    for val $j (1:15) {
        $seed2 = ($seed2 * 1103515245 + 12345) % 2147483648
        push @bunch, $seed2 % 100
    }
    val $bh = LH::from_array(\@bunch)
    $big_h = LH::merge_h($big_h, $bh)
}
LH::heap_size($big_h) |> aeq 150, "merge-stress size"
LH::heap_ok($big_h) |> aeq 1, "merge-stress heap ok"
LH::leftist_ok($big_h) |> aeq 1, "merge-stress leftist ok"
LH::rank_ok($big_h) |> aeq 1, "merge-stress rank ok"
val $msd = LH::drain($big_h)
var $msort = 1
for val $i (0:148) { $msort = 0 if $msd->[$i] > $msd->[$i+1] }
$msort |> aeq 1, "merge-stress drain sorted"

test_run
