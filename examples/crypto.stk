#!/usr/bin/env stryke

# Stryke crypto primitives — all in-binary, no external deps.
# Hashes return hex strings; signing/verification round-trips cleanly
# Argon2 / JWT cover the common app-server use cases.

p "── Cryptographic hashes ───────────────────────────────"
val $msg = "the quick brown fox"
printf "  md5        : %s\n", md5 $msg
printf "  sha256     : %s\n", sha256 $msg
val $sha512_full = sha512 $msg
printf "  sha512     : %s…  (truncated)\n", $sha512_full[0:31]
printf "  sha3_256   : %s\n", sha3_256 $msg
printf "  blake3     : %s\n", blake3 $msg

p ""
p "── HMAC — keyed authentication tag ────────────────────"
val $secret = "shared-secret-32-bytes-or-bigger"
val $tag    = hmac_sha256 $secret, $msg
printf "  hmac_sha256: %s\n", $tag
p "  same key+message always produces the same tag:"
printf "    pass 1   : %s\n", $tag[0:31]
printf "    pass 2   : %s\n", $tag[0:31]

p ""
p "── Argon2id password hashing ──────────────────────────"
val $pw = "correct horse battery staple"
val $hash = argon2_hash($pw)
p "  stored hash : ", substr($hash, 0, 50), "…"
p "  verify OK   : ", argon2_verify($pw, $hash)
p "  verify bad  : ", argon2_verify("wrong-password", $hash)

p ""
p "── JWT — claims + signing in one ──────────────────────"
val $claims = {
    iss => "stryke-demo",
    sub => "alice",
    iat => time(),
    exp => time() + 3600,
    role => "admin",
}
val $token = jwt_encode($claims, "jwt-secret")
p "  token        : ", substr($token, 0, 50), "…"
val $back = jwt_decode($token, "jwt-secret")
p "  decoded sub  : ", $back->{sub}
p "  decoded role : ", $back->{role}

p ""
p "── Bad-tampering JWT — verify fails ───────────────────"
val $bad = substr($token, 0, -3) . "AAA";    # corrupt last 3 chars
var $err = 0
try { jwt_decode($bad, "jwt-secret") } catch ($e) { $err = 1 }
p "  tampered token rejects (catch fires): $err"

p ""
p "── Cross-feature: HMAC-tagged + KV-stored manifest ────"
val $path = "/tmp/stryke_crypto_demo.rkyv"
unlink($path)
val $db = kv_open($path)
val $manifest_json = to_json({
    version => "0.14.2",
    files   => ["stryke", "s", "st"],
})
val $tag = hmac_sha256("manifest-signing-key", $manifest_json)
kv_put($db, "manifest:json", $manifest_json)
kv_put($db, "manifest:tag",  $tag)
kv_commit($db)

val $db2 = kv_open($path)
val $j2 = kv_get($db2, "manifest:json")
val $t2 = kv_get($db2, "manifest:tag")
val $recomputed = hmac_sha256("manifest-signing-key", $j2)
p "  manifest tag verifies after KV roundtrip: ",
    ($t2 eq $recomputed) ? 1 : 0
unlink($path)
