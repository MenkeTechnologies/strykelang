#!/usr/bin/env stryke
# Run: stryke --no-interop examples/parallel_file_hasher.stk

p "--- Parallel Hash ---"
val $examples_dir = dirname(__FILE__)
var @r = ~> glob("$examples_dir/*.stk") \
    head(5) \
    pmaps { [ _ => c"#{_}" |> sha256 ] } \
    collect

for val $row (@r) {
    val $hash = $row->[1]
    p "  #{ $row->[0] }: #{ $hash[0:7] }..."
}

len @r          |> aeq 5,  "cnt"
len($r[0]->[1]) |> aeq 64, "size"
test_run
