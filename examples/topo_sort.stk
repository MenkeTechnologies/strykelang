#!/usr/bin/env stryke

# topo_sort.stk - Topological sort of a DAG via Kahn's algorithm.
#
# Run: stryke --no-interop examples/topo_sort.stk

fn Topo::sort($edges, $nodes) {
    var %indeg = ()
    var %adj   = ()
    for val $n (@$nodes) {
        $indeg{$n} = 0
        $adj{$n}   = []
    }
    for val $e (@$edges) {
        val ($u, $v) = @$e
        push @{$adj{$u}}, $v
        $indeg{$v} = $indeg{$v} + 1
    }
    var @queue = ()
    for val $n (sort @$nodes) {
        push @queue, $n if $indeg{$n} == 0
    }
    var @order = ()
    while (len(@queue) > 0) {
        val $n = shift @queue
        push @order, $n
        val @nexts = sort @{$adj{$n}}
        for val $m (@nexts) {
            $indeg{$m} = $indeg{$m} - 1
            push @queue, $m if $indeg{$m} == 0
        }
    }
    if (len(@order) == len(@$nodes)) {
        return \@order
    }
    return undef
}

p "=== Topological Sort Demo ==="
val @nodes = ("wake", "shower", "dress", "breakfast", "commute", "work")
val @edges = (
    ["wake", "shower"],
    ["shower", "dress"],
    ["dress", "breakfast"],
    ["breakfast", "commute"],
    ["commute", "work"],
    ["wake", "breakfast"],
)
val $order = Topo::sort(\@edges, \@nodes)
p "order: " . join(" -> ", @$order)

p "--- cycle detection ---"
val @cycle = (["a","b"], ["b","c"], ["c","a"])
val @cn    = ("a","b","c")
val $r = Topo::sort(\@cycle, \@cn)
p "cycle result: " . (defined $r ? "ok" : "cycle detected")
