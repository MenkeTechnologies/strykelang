#!/usr/bin/env stryke

fn BWT::transform($s) {
    val $n = len $s
    return +{ bwt => "", idx => 0 } if $n == 0
    var @rotations
    for val $i (0 : $n - 1) {
        val $rot = $i == 0 ? $s : $s[$i : $n - 1] . $s[0 : $i - 1]
        push @rotations, $rot
    }
    val @sorted = ~> @rotations sort { _0 cmp _1 }
    var $last_col = ""
    for val $r (@sorted) { $last_col = $last_col . $r[-1] }
    var $idx = 0
    for val $i (0 : $n - 1) {
        if ($sorted[$i] eq $s) { $idx = $i; last }
    }
    +{ bwt => $last_col, idx => $idx }
}

fn BWT::inverse($bwt, $idx) {
    val $n = len $bwt
    return "" if $n == 0
    var @bwt_arr
    for val $i (0 : $n - 1) { push @bwt_arr, $bwt[$i] }
    val @first_col = ~> @bwt_arr sort { _0 cmp _1 }
    var %cb
    var @ob
    for val $c (@bwt_arr) {
        $cb{$c} = ($cb{$c} // 0) + 1
        push @ob, $cb{$c}
    }
    var %cf
    var @of
    for val $c (@first_col) {
        $cf{$c} = ($cf{$c} // 0) + 1
        push @of, $cf{$c}
    }
    var %first_occ_idx
    for val $j (0 : $n - 1) {
        $first_occ_idx{"#{$first_col[$j]}_#{$of[$j]}"} = $j
    }
    var @lf = (0) x $n
    for val $i (0 : $n - 1) {
        $lf[$i] = $first_occ_idx{"#{$bwt_arr[$i]}_#{$ob[$i]}"}
    }
    var $res = ""
    var $cur = $idx
    for (0 : $n - 1) {
        $res = $bwt_arr[$cur] . $res
        $cur = $lf[$cur]
    }
    $res
}

val $t1 = BWT::transform("banana")
~> $t1->{bwt} aeq("nnbaaa", "bwt of banana")
~> $t1->{idx} aeq(3, "bwt idx of banana")

val $inv1 = BWT::inverse($t1->{bwt}, $t1->{idx})
~> $inv1 aeq("banana", "inverse of banana bwt")

val $t2 = BWT::transform("abracadabra")
val $inv2 = BWT::inverse($t2->{bwt}, $t2->{idx})
~> $inv2 aeq("abracadabra", "roundtrip abracadabra")

val $t3 = BWT::transform("A")
val $inv3 = BWT::inverse($t3->{bwt}, $t3->{idx})
~> $inv3 aeq("A", "roundtrip A")

test_run
