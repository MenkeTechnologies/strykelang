#!/usr/bin/env stryke

package Simplex

fn solve($c, $A, $rhs) {
    my $num_vars = len @$c
    my $num_constraints = len @$A

    my $tableau = []
    
    my $obj_row = []
    for my $v (@$c) { push @$obj_row, -$v }
    for (0 : $num_constraints) { push @$obj_row, 0.0 }
    push @$tableau, $obj_row

    for my $i (0 : $num_constraints - 1) {
        my $row = []
        for my $v (@{$A->[$i]}) { push @$row, $v }
        for my $j (0 : $num_constraints - 1) { push @$row, ($i == $j ? 1.0 : 0.0) }
        push @$row, $rhs->[$i]
        push @$tableau, $row
    }

    my $cols = (len @{$tableau->[0]}) - 1

    while (1) {
        my $pivot_col = -1
        my $min_val = -1e-9
        my $obj = $tableau->[0]
        
        for my $j (0 : $cols - 1) {
            if ($obj->[$j] < $min_val) {
                $min_val = $obj->[$j]
                $pivot_col = $j
            }
        }

        last if $pivot_col == -1

        my $pivot_row = -1
        my $min_ratio = 1e18
        
        for my $i (1 : $num_constraints) {
            my $val = $tableau->[$i]->[$pivot_col]
            if ($val > 1e-9) {
                my $ratio = $tableau->[$i]->[$cols] / $val
                if ($ratio < $min_ratio) {
                    $min_ratio = $ratio
                    $pivot_row = $i
                }
            }
        }

        return undef if $pivot_row == -1

        my $pivot_val = $tableau->[$pivot_row]->[$pivot_col]
        for my $j (0 : $cols) { $tableau->[$pivot_row]->[$j] /= $pivot_val }

        for my $i (0 : $num_constraints) {
            if ($i != $pivot_row) {
                my $factor = $tableau->[$i]->[$pivot_col]
                for my $j (0 : $cols) {
                    $tableau->[$i]->[$j] -= $factor * $tableau->[$pivot_row]->[$j]
                }
            }
        }
    }

    my @solution = (0.0) x $num_vars
    for my $j (0 : $num_vars - 1) {
        my $one_count = 0
        my $one_row = -1
        my $other_count = 0
        
        for my $i (1 : $num_constraints) {
            my $val = $tableau->[$i]->[$j]
            if (abs($val - 1.0) < 1e-9) {
                $one_count++
                $one_row = $i
            } elsif (abs($val) > 1e-9) {
                $other_count++
            }
        }
        
        if ($one_count == 1 && $other_count == 0) {
            $solution[$j] = $tableau->[$one_row]->[$cols]
        }
    }

    { max_value => $tableau->[0]->[$cols], solution => \@solution }
}

package main

my @c = (3.0, 2.0)
my $A = [[2.0, 1.0], [2.0, 3.0], [3.0, 1.0]]
my @b = (18.0, 42.0, 24.0)

my $res = Simplex::solve(\@c, $A, \@b)

(abs($res->{max_value} - 33.0) < 1e-5) |> aeq 1, "max_value matches 33.0"
(abs($res->{solution}->[0] - 3.0) < 1e-5) |> aeq 1, "solution x = 3.0"
(abs($res->{solution}->[1] - 12.0) < 1e-5) |> aeq 1, "solution y = 12.0"

test_run
