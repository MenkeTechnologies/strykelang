#!/usr/bin/env stryke

fn AlgX::solve($X, $Y, $solution, $results) {
    var @cols = keys %$X
    if (len(@cols) == 0) {
        val @copy = @$solution
        push @$results, \@copy
        return undef
    }
    var $min_c = $cols[0]
    var $min_len = len @{$X->{$min_c}}
    for val $c (@cols) {
        val $l = len @{$X->{$c}}
        if ($l < $min_len) { $min_len = $l; $min_c = $c }
    }
    var @rows_for_c = @{$X->{$min_c}}
    for val $r (@rows_for_c) {
        push @$solution, $r
        var %new_X
        for val $k (keys %$X) {
            val @arr = @{$X->{$k}}
            $new_X{$k} = \@arr
        }
        for val $j (@{$Y->{$r}}) {
            if (exists $new_X{$j}) {
                for val $i (@{$new_X{$j}}) {
                    for val $k (@{$Y->{$i}}) {
                        if ($k ne $j && exists $new_X{$k}) {
                            val @filtered = ~> @{$new_X{$k}} grep { _ ne $i }
                            $new_X{$k} = \@filtered
                        }
                    }
                }
                delete $new_X{$j}
            }
        }
        AlgX::solve(\%new_X, $Y, $solution, $results)
        pop @$solution
    }
}

fn AlgX::exact_cover($universe, $subsets) {
    var %X
    for val $item (@$universe) { $X{$item} = [] }
    for val $row (keys %$subsets) {
        for val $item (@{$subsets->{$row}}) { push @{$X{$item}}, $row }
    }
    val @solution
    val @results
    AlgX::solve(\%X, $subsets, \@solution, \@results)
    \@results
}

val @u1 = ("1", "2", "3", "4", "5", "6", "7")
val %s1 = (
    "A" => ["1", "4", "7"],
    "B" => ["1", "4"],
    "C" => ["4", "5", "7"],
    "D" => ["3", "5", "6"],
    "E" => ["2", "3", "6", "7"],
    "F" => ["2", "7"],
)
val $r1 = AlgX::exact_cover(\@u1, \%s1)
~> len(@$r1) aeq(1, "1 solution")
val @sol_sorted = ~> @{$r1->[0]} sort { _0 cmp _1 }
~> join(",", @sol_sorted) aeq("B,D,F", "Solution is B, D, F")

val @u2 = ("1", "2")
val %s2 = ( "A" => ["1"], "B" => ["1"] )
val $r2 = AlgX::exact_cover(\@u2, \%s2)
~> len(@$r2) aeq(0, "0 solutions")

test_run
