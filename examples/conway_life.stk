#!/usr/bin/env stryke

# Conway's Game of Life demo. Evolves a 20x20 grid with seeded patterns
# (glider + blinker + still life) for 5 generations and renders each.
#
# Patterns:
#   * 2D grid as array-of-arrayrefs of 0/1
#   * neighbor count by direct 8-direction probe
#   * t-digest for per-generation latency
#   * HLL for distinct live-cell-count across generations

val $H = 20
val $W = 20

# ── grid construction ───────────────────────────────────────────────

fn Demo::Life::empty_grid() {
    var @g
    for val $r (0:$H - 1) {
        $g[$r] = []
        for val $c (0:$W - 1) {
            $g[$r]->[$c] = 0
        }
    }
    \@g
}

fn Demo::Life::seed($g, $row, $col) {
    return if $row < 0 || $row >= $H || $col < 0 || $col >= $W
    $g->[$row]->[$col] = 1
}

# Seeded patterns:
#   - glider (top-left)
#   - blinker (middle)
#   - block (bottom-right, still life)
fn Demo::Life::seed_demo($g) {
    # Glider at (1,1):
    #   .X.
    #   ..X
    #   XXX
    Demo::Life::seed($g, 1, 2)
    Demo::Life::seed($g, 2, 3)
    Demo::Life::seed($g, 3, 1)
    Demo::Life::seed($g, 3, 2)
    Demo::Life::seed($g, 3, 3)

    # Blinker (horizontal 3-row) at (9, 8):
    Demo::Life::seed($g, 9, 8)
    Demo::Life::seed($g, 9, 9)
    Demo::Life::seed($g, 9, 10)

    # Still-life block at (16, 16):
    Demo::Life::seed($g, 16, 16)
    Demo::Life::seed($g, 16, 17)
    Demo::Life::seed($g, 17, 16)
    Demo::Life::seed($g, 17, 17)
}

# ── neighbor count ─────────────────────────────────────────────────

fn Demo::Life::count_neighbors($g, $r, $c) {
    var $n = 0
    for val $dr (-1, 0, 1) {
        for val $dc (-1, 0, 1) {
            next if $dr == 0 && $dc == 0
            val $nr = $r + $dr
            val $nc = $c + $dc
            next if $nr < 0 || $nr >= $H || $nc < 0 || $nc >= $W
            $n += $g->[$nr]->[$nc]
        }
    }
    $n
}

# ── one generation step ────────────────────────────────────────────

fn Demo::Life::step($g) {
    val $ng = Demo::Life::empty_grid()
    for val $r (0:$H - 1) {
        for val $c (0:$W - 1) {
            val $n = Demo::Life::count_neighbors($g, $r, $c)
            val $alive = $g->[$r]->[$c]
            if ($alive) {
                $ng->[$r]->[$c] = ($n == 2 || $n == 3) ? 1 : 0
            } else {
                $ng->[$r]->[$c] = ($n == 3) ? 1 : 0
            }
        }
    }
    $ng
}

# ── render ─────────────────────────────────────────────────────────

fn Demo::Life::render($g) {
    var @lines
    for val $r (0:$H - 1) {
        var $line = ""
        for val $c (0:$W - 1) {
            $line = $line . ($g->[$r]->[$c] ? "#" : ".")
        }
        push @lines, $line
    }
    \@lines
}

fn Demo::Life::live_count($g) {
    var $n = 0
    for val $r (0:$H - 1) {
        for val $c (0:$W - 1) {
            $n += $g->[$r]->[$c]
        }
    }
    $n
}

# ── simulate ───────────────────────────────────────────────────────

var $grid = Demo::Life::empty_grid()
Demo::Life::seed_demo($grid)

val $td_step = t_digest(100)
val $hll_pop = hll(14)
val $tk_pop = topk(3)

var @population_history

p "── initial state (generation 0) ─────────────────────"
val $lines = Demo::Life::render($grid)
for val $line (@$lines) { p "  $line" }
val $pop0 = Demo::Life::live_count($grid)
printf "  live cells: %d\n", $pop0
push @population_history, $pop0
hll_add($hll_pop, "gen_0_pop_$pop0")

for val $gen (1:5) {
    val $t0 = now_ns()
    $grid = Demo::Life::step($grid)
    td_add($td_step, (now_ns() - $t0) / 1000.0)
    val $pop = Demo::Life::live_count($grid)
    push @population_history, $pop
    hll_add($hll_pop, "gen_${gen}_pop_$pop")
    topk_add($tk_pop, "pop_$pop")
    printf "\n── generation %d (live=%d) ──────────────────────────\n",
        $gen, $pop
    val $lines = Demo::Life::render($grid)
    for val $line (@$lines) { p "  $line" }
}

# ── rollup ──────────────────────────────────────────────────────────

p ""
p "── population history ───────────────────────────────"
for val $i (0:len(@population_history) - 1) {
    printf "  gen %d : %d live cells\n", $i, $population_history[$i]
}

p ""
p "── HLL distinct gen-pop signatures ──────────────────"
printf "  HLL : %d\n", hll_count($hll_pop)
printf "  exact (history length) : %d\n", len @population_history

p ""
p "── most-common gen population (TopK) ────────────────"
var @hits = topk_top($tk_pop)
for val $h (@hits) {
    printf "  %-12s : %d gens\n", $h->[0], $h->[1]
}

p ""
p "── per-generation step latency (t-digest) ───────────"
printf "  p50  : %.1f µs\n", td_quantile($td_step, 0.50)
printf "  p99  : %.1f µs\n", td_quantile($td_step, 0.99)
