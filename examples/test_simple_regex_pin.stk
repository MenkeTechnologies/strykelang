#!/usr/bin/env stryke

fn SR::_eq($pc, $tc) {
    return 1 if $pc eq "."
    $pc eq $tc
}

fn SR::_match_star($c, $re, $j, $s, $i) {
    my $k = $i
    while ($k < (len $s) && SR::_eq($c, substr($s, $k, 1))) {
        $k = $k + 1
    }
    while ($k >= $i) {
        return 1 if SR::_match_here($re, $j, $s, $k)
        $k = $k - 1
    }
    0
}

fn SR::_match_here($re, $j, $s, $i) {
    my $rl = len $re
    return 1 if $j == $rl
    if ($j + 1 < $rl && substr($re, $j + 1, 1) eq "*") {
        return SR::_match_star(substr($re, $j, 1), $re, $j + 2, $s, $i)
    }
    if (substr($re, $j, 1) eq "\$" && $j + 1 == $rl) {
        return $i == (len $s) ? 1 : 0
    }
    if ($i < (len $s) && SR::_eq(substr($re, $j, 1), substr($s, $i, 1))) {
        return SR::_match_here($re, $j + 1, $s, $i + 1)
    }
    0
}

fn SR::match($re, $s) {
    if ((len $re) > 0 && substr($re, 0, 1) eq "^") {
        return SR::_match_here($re, 1, $s, 0)
    }
    my $i = 0
    my $n = len $s
    while (1) {
        return 1 if SR::_match_here($re, 0, $s, $i)
        last if $i >= $n
        $i = $i + 1
    }
    0
}

# --- Literal substring matches ---
SR::match("hello", "hello world") |> aeq 1, "literal match"
SR::match("world", "hello world") |> aeq 1, "literal match end"
SR::match("o w",   "hello world") |> aeq 1, "literal match middle"
SR::match("xyz",   "hello world") |> aeq 0, "literal no match"
SR::match("",      "anything")    |> aeq 1, "empty re matches"
SR::match("",      "")            |> aeq 1, "empty re empty s"
SR::match("a",     "")            |> aeq 0, "non-empty re empty s"

# --- Anchors ---
SR::match("^hello", "hello world")  |> aeq 1, "^ at start"
SR::match("^world", "hello world")  |> aeq 0, "^ not at start"
SR::match("world\$","hello world")  |> aeq 1, "\$ at end"
SR::match("hello\$","hello world")  |> aeq 0, "\$ not at end"
SR::match("^hello\$","hello")       |> aeq 1, "^ \$ exact"
SR::match("^hello\$","hello world") |> aeq 0, "^ \$ no full"
SR::match("^\$",     "")            |> aeq 1, "^ \$ empty"
SR::match("^\$",     "x")           |> aeq 0, "^ \$ non-empty fails"

# --- Dot wildcard ---
SR::match("h.llo", "hello") |> aeq 1, "dot wild"
SR::match("h.llo", "hallo") |> aeq 1, "dot wild any"
SR::match("h.llo", "hllo")  |> aeq 0, "dot requires char"
SR::match("...",   "abc")   |> aeq 1, "three dots match abc"
SR::match("....",  "abc")   |> aeq 0, "four dots fail abc"

# --- Star ---
SR::match("ab*c",  "ac")     |> aeq 1, "b* zero"
SR::match("ab*c",  "abc")    |> aeq 1, "b* one"
SR::match("ab*c",  "abbbc")  |> aeq 1, "b* many"
SR::match("ab*c",  "abbb")   |> aeq 0, "b* missing tail"
SR::match("a*",    "")       |> aeq 1, "a* matches empty"
SR::match("a*",    "aaaa")   |> aeq 1, "a* matches all a"
SR::match(".*",    "anything goes") |> aeq 1, ".* matches all"
SR::match("^.*\$", "anything goes") |> aeq 1, "^.*\$ matches"
SR::match("^a.*z\$", "amazing buzz")    |> aeq 1, "anchored greedy"
SR::match("^a.*z\$", "amazing buz!")    |> aeq 0, "anchored fails"

# --- Combinations ---
SR::match("a.b",   "axb")   |> aeq 1, "literal+dot+literal"
SR::match("^a.*b\$", "ab")  |> aeq 1, "anchored, star with no chars"
SR::match("^a.*b\$", "axxxb") |> aeq 1, "anchored, star with chars"
SR::match("^a.*b\$", "axxxc") |> aeq 0, "anchored, ends wrong"

# Realistic: trailing dot star equivalent to prefix match
SR::match("^foo", "foobar") |> aeq 1, "anchor prefix"
SR::match("bar\$","foobar") |> aeq 1, "anchor suffix"

# Empty pattern with anchors
SR::match("^",  "anything")  |> aeq 1, "^ alone matches anywhere"
SR::match("\$", "anything")  |> aeq 1, "\$ alone matches end"

test_run
