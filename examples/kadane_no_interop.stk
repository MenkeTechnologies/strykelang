#!/usr/bin/env stryke

# Kadane's algorithm — maximum subarray sum in O(n). Walk the array
# tracking two quantities: `cur` = best-sum-ending-here, `best` =
# best-sum-seen-anywhere. Pure reduce-fold, no for / no push. Parses
# clean under `--no-interop`.
#
# Idiomatic stryke per docs/STYLE_GUIDE.md:
#   * `|> reduce` accumulator (rule 3, rule 12)
#   * implicit return on tail expression (rule 7)
#   * `#{…}` interpolation, no `.` concat (rule 1a)
#   * paren-less list-op calls (rule 8)
#
# Namespaced UDFs `Kadane::*`.
#
# Run: stryke --no-interop examples/kadane_no_interop.stk

# Max subarray sum. Returns undef on empty input.
# Seed `{cur, best}` is prepended so head-of-list initializes the
# accumulator — stryke's one-block reduce has no separate init arg.
fn Kadane::max_sum($xs) {
    return undef if len(@$xs) == 0
    val $st = (+{cur => 0, best => -1e18}, @$xs) |> reduce {
        val $c = max(_1, _->{cur} + _1)
        +{ cur => $c, best => max(_->{best}, $c) }
    }
    $st->{best}
}

# Same walk, but also tracks the [lo, hi] indices of the winning slice.
fn Kadane::max_subarray($xs) {
    return undef if len(@$xs) == 0
    val @indexed = 0:len(@$xs) - 1 |> maps { +{ i => _, v => $xs->[_] } }
    val $init = +{ cur => -1e18, c_lo => 0, best => -1e18, lo => 0, hi => 0 }
    val $st = ($init, @indexed) |> reduce {
        val ($v, $i) = (_1->{v}, _1->{i})
        val ($new_cur, $new_c_lo) = (_->{cur} + $v) > $v
            ? (_->{cur} + $v, _->{c_lo})
            : ($v, $i)
        val ($best, $lo, $hi) = $new_cur > _->{best}
            ? ($new_cur, $new_c_lo, $i)
            : (_->{best}, _->{lo}, _->{hi})
        +{ cur => $new_cur, c_lo => $new_c_lo, best => $best, lo => $lo, hi => $hi }
    }
    +{ sum => $st->{best}, lo => $st->{lo}, hi => $st->{hi} }
}

val @cases = (
    +{ xs => [-2, 1, -3, 4, -1, 2, 1, -5, 4],  sum =>  6, lo => 3, hi => 6 },  # LC #53
    +{ xs => [1],                              sum =>  1, lo => 0, hi => 0 },
    +{ xs => [5, 4, -1, 7, 8],                 sum => 23, lo => 0, hi => 4 },
    +{ xs => [-1],                             sum => -1, lo => 0, hi => 0 },
    +{ xs => [-2, -1, -3],                     sum => -1, lo => 1, hi => 1 },  # all-negative
    +{ xs => [0, 0, 0],                        sum =>  0, lo => 0, hi => 0 },
    +{ xs => [1, 2, 3, 4, 5],                  sum => 15, lo => 0, hi => 4 },
    +{ xs => [-3, 5, -2, 6, -1, 4, -8, 2],     sum => 12, lo => 1, hi => 5 },
)

p "── Kadane max-subarray demo ──"
var $fail = 0
for val $c (@cases) {
    val $r       = Kadane::max_subarray $c->{xs}
    val $sum_ok  = $r->{sum} == $c->{sum}
    val $idx_ok  = $r->{lo} == $c->{lo} && $r->{hi} == $c->{hi}
    val $sum_alt = Kadane::max_sum $c->{xs}
    val $alt_ok  = $sum_alt == $c->{sum}
    val $ok      = $sum_ok && $idx_ok && $alt_ok
    $fail++ unless $ok
    val @xs = @{$c->{xs}}
    p "  xs=[@xs]  sum=#{$r->{sum}} (alt #{$sum_alt})  range=[#{$r->{lo}}..#{$r->{hi}}]  #{$ok ? \"\" : \"FAIL\"}"
}
die "#{$fail} / #{len @cases} Kadane cases failed" if $fail > 0

# Universal invariant: the reported slice really sums to the reported total.
for val $c (@cases) {
    val $r   = Kadane::max_subarray $c->{xs}
    val @sub = @{$c->{xs}}[$r->{lo} : $r->{hi}]
    die "slice sum mismatch on @{$c->{xs}}" unless sum(@sub) == $r->{sum}
    # No shorter slice can beat the best-sum we returned (sanity-check via
    # cross-impl agreement, since brute-force is O(n^2) and overkill).
    die "max_sum disagrees with max_subarray" unless Kadane::max_sum($c->{xs}) == $r->{sum}
}

p ""
p "  ALL PASS (8 cases + slice-sum invariant + cross-impl agreement)"
