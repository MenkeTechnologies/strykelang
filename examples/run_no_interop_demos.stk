#!/usr/bin/env stryke
# Run every examples/*_no_interop.stk end-to-end under --no-interop.
# CI uses examples/run_all_ci.stk; this wrapper runs the demos phase only.
#
# Usage: stryke examples/run_no_interop_demos.stk [--summary]

my %opts = %{ getopts(["summary"]) }
my $runner = dirname(__FILE__) . "/run_all_ci.stk"
my $cmd    = "$^X \"$runner\" --only=demos"
$cmd .= " --summary" if $opts{summary}
exit system($cmd) >> 8
