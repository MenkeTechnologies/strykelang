#!/usr/bin/env stryke
# Run check + test on every examples/exercism/ exercise.
# CI uses examples/run_all_ci.stk; this wrapper runs the exercism phase only.
#
# Usage: stryke examples/exercism_run_all.stk [--summary]

my $runner = dirname(__FILE__) . "/run_all_ci.stk"
my $flags  = len(@ARGV) ? " " . join(" ", @ARGV) : ""
exit system("$^X \"$runner\" --only=exercism$flags") >> 8
