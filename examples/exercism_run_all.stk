#!/usr/bin/env stryke
# Run check + test on every examples/exercism/ exercise.
# CI uses examples/run_all_ci.stk; this wrapper runs the exercism phase only.
#
# Usage: stryke examples/exercism_run_all.stk [--summary]

val %opts = %{ getopts({
    "summary" => { help => "pass --summary to run_all_ci" },
}) }
val $runner = dirname(__FILE__) . "/run_all_ci.stk"
var $cmd    = "$^X \"$runner\" --only=exercism"
$cmd .= " --summary" if $opts{summary}
exit system($cmd) >> 8
