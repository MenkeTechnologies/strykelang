#!/usr/bin/env stryke

# Pinning batch Native-J (2026-05-10): Bugs Phase 2 (from BUGS.md 1500-3000)
# Compliance: docs/STYLE_GUIDE.md

# ── CORE:: Prefix ──────────────────────────────────────────────────────────

CORE::length("abc") |> aeq 3, "CORE::length"
CORE::int(3.14) |> aeq 3, "CORE::int"
CORE::abs(-5) |> aeq 5, "CORE::abs"

# ── Hash Kv Slice ──────────────────────────────────────────────────────────

my %h = (a => 1, b => 2, c => 3)
join(",", %h{qw(a c)}) |> aeq "a,1,c,3", "hash kv slice %h{...}"

# ── Multi-level Exists ─────────────────────────────────────────────────────

my %data
!exists($data{x}{y}{z}) |> aok "nested exists missing root"
$data{x} = { y => { z => 42 } }
exists($data{x}{y}{z}) |> aok "nested exists present path"

# ── Return List ────────────────────────────────────────────────────────────

fn get_list = (10, 20, 30)
len(get_list()) |> aeq 3, "return list context"
(get_list())[-1] |> aeq 30, "return scalar context (simulated via last element)"

# ── System / Exit Status ($?) ──────────────────────────────────────────────

system("true")
$? |> aeq 0, "system true sets $? to 0"
system("false")
($? >> 8) |> aeq 1, "exit code 1 propagated"

# ── Regex G Flag ───────────────────────────────────────────────────────────

"a1 b2 c3" =~ /(\w)(\d)/g |> join(",") |> aeq "a1,b2,c3", "regex /g list context (pinned bug)"

# ── PSelect (More) ─────────────────────────────────────────────────────────

our ($tx1, $rx1) = pchannel(1)
our ($tx2, $rx2) = pchannel(1)
$tx2->send("MSG")
pselect($rx1, $rx2)->[0] |> aeq "MSG", "pselect val"

# ── Array End Index ($#arr) ────────────────────────────────────────────────

my @arr = (1:3)
$#arr |> aeq 2, "$#arr is last index"
$#arr = 1
len(@arr) |> aeq 2, "truncating via $#arr"
$#arr = 3
len(@arr) |> aeq 4, "extending via $#arr"

test_run
