#!/usr/bin/env stryke

# Pinning tests for various bugs from BUGS.md

# Pinning test for BUG-089: Closures capture outer-scope `my` vars by value
val $val = 10;
fn Pin::MoreBugs::reader() {
    var $local_val = $val;
    $local_val = 20; # modify local copy
    return $val; # return original outer scope value
}

val $read_val = Pin::MoreBugs::reader();

aeq($read_val, 10, "BUG-089: closure should read the original value");
aeq($val, 10, "BUG-089: outer scope variable should not be modified");

# Pinning test for BUG-037: Closure-captured coderefs flatten args
fn Pin::MoreBugs::call_it($code, @args) {
    $code(@args);
}

var $sum = 0;
fn Pin::MoreBugs::summer(@nums) {
    for val $n (@nums) {
        $sum += $n;
    }
}

Pin::MoreBugs::call_it(\&Pin::MoreBugs::summer, 1, 2, 3);

# According to bug, @args is flattened to a scalar count, so Pin::MoreBugs::summer receives `3` instead of `(1, 2, 3)`.
# The loop `for var $n (3)` will execute once with $n=3.
aeq($sum, 3, "BUG-037: captured coderef gets scalar count of args");


# BUG-140 (FIXED): sum() and product() now unwrap arrayref arguments instead
# of returning 0. `sum([10,11,12])` returns 33; `product([6,7])` returns 42.
val $s = sum([10, 11, 12]);
aeq($s, 33, "BUG-140 (FIXED): sum([10, 11, 12]) unwraps arrayref");

val $p = product([6, 7]);
aeq($p, 42, "BUG-140 (FIXED): product([6, 7]) unwraps arrayref");

test_run
