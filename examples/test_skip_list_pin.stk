#!/usr/bin/env stryke

package SkipList

val $MAX_LEVEL = 16
val $P = 0.5
fn new_node($val, $level) {
    val @next = (undef) x ($level + 1)
    { val => $val, next => \@next }
}
fn new() { { head => new_node(undef, $MAX_LEVEL), level => 0 } }
fn random_level() {
    var $lvl = 0
    while (rand() < $P && $lvl < $MAX_LEVEL) { $lvl++ }
    $lvl
}
fn insert($list, $val) {
    var @update = (undef) x ($MAX_LEVEL + 1)
    var $curr = $list->{head}
    for val $i (rev 0 : $list->{level}) {
        while (defined $curr->{next}->[$i] && $curr->{next}->[$i]->{val} < $val) { $curr = $curr->{next}->[$i] }
        $update[$i] = $curr
    }
    $curr = $curr->{next}->[0]
    if (!defined $curr || $curr->{val} != $val) {
        val $lvl = random_level()
        if ($lvl > $list->{level}) {
            for val $i ($list->{level} + 1 : $lvl) { $update[$i] = $list->{head} }
            $list->{level} = $lvl
        }
        val $new = new_node($val, $lvl)
        for val $i (0 : $lvl) {
            $new->{next}->[$i] = $update[$i]->{next}->[$i]; $update[$i]->{next}->[$i] = $new
        }
    }
}
fn find($list, $val) {
    var $curr = $list->{head}
    for val $i (rev 0 : $list->{level}) {
        while (defined $curr->{next}->[$i] && $curr->{next}->[$i]->{val} < $val) { $curr = $curr->{next}->[$i] }
    }
    $curr = $curr->{next}->[0]
    return (defined $curr && $curr->{val} == $val)
}
fn delete_v($list, $val) {
    var @update = (undef) x ($MAX_LEVEL + 1)
    var $curr = $list->{head}
    for val $i (rev 0 : $list->{level}) {
        while (defined $curr->{next}->[$i] && $curr->{next}->[$i]->{val} < $val) { $curr = $curr->{next}->[$i] }
        $update[$i] = $curr
    }
    $curr = $curr->{next}->[0]
    if (defined $curr && $curr->{val} == $val) {
        for val $i (0 : $list->{level}) {
            last if $update[$i]->{next}->[$i] != $curr
            $update[$i]->{next}->[$i] = $curr->{next}->[$i]
        }
        while ($list->{level} > 0 && !defined $list->{head}->{next}->[$list->{level}]) { $list->{level}-- }
    }
}
fn to_array($list) {
    var @out; var $curr = $list->{head}->{next}->[0]
    while (defined $curr) { push @out, $curr->{val}; $curr = $curr->{next}->[0] }
    \@out
}

package main

# --- Basic ---
val $sl = SkipList::new()
for val $v (10, 5, 20, 15) { SkipList::insert $sl, $v }
join(",", @{SkipList::to_array $sl}) |> aeq "5,10,15,20", "skip list sorted"
SkipList::find($sl, 10) |> aeq 1, "find 10"
SkipList::find($sl, 99) |> aeq 0, "no find 99"

SkipList::delete_v $sl, 10
SkipList::find($sl, 10) |> aeq 0, "10 deleted"
join(",", @{SkipList::to_array $sl}) |> aeq "5,15,20", "after delete"

# --- Stress ---
val $sls = SkipList::new()
var $seed = 42
for (1:100) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    SkipList::insert $sls, ($seed % 1000)
}
val $arr = SkipList::to_array $sls
var $ok = 1
for val $i (0 : (len @$arr) - 2) { $ok = 0 if $arr->[$i] > $arr->[$i+1] }
$ok |> aeq 1, "stress sorted"

test_run
