#!/usr/bin/env stryke

# Pinning batch Native-F (2026-05-10): Exhaustive Bug Alignment (from BUGS.md)

# ── Math & Analytic Divergences ───────────────────────────────────────────

# BUG-127: iota_range ignores arguments after first
assert_eq(len(iota_range(5, 99)), 5, "iota_range ignores tail")

# BUG-128: Lambert W0 at 1 is NaN
assert_eq(tj(lambert_w0(1)), "NaN", "lambert_w0(1) is NaN")
assert_eq(tj(wright_omega(0)), "NaN", "wright_omega(0) is NaN")

# BUG-129: convolve_full returns size, not values
assert_eq(convolve_full([1,2], [3,4]), 3, "convolve_full returns output length")

# BUG-130: detrend_linear returns slope
assert_eq(detrend_linear([1, 2, 3]), 1, "detrend_linear returns slope (1,2,3 -> slope 1)")

# BUG-131: medfilt_1d is global median
assert_eq(medfilt_1d([10, 1, 2, 3], 1), 2.5, "medfilt_1d is global median")

# BUG-132: bs_delta is call-only (no -1 for put)
my $delta = bs_delta(100, 100, 1, 0.05, 0.2) # approx 0.65
assert_ok($delta > 0.6 && $delta < 0.7, "bs_delta returns call delta")

# BUG-133: depreciation_double ignores salvage (args[1])
assert_eq(depreciation_double(1000, 500, 5), 400, "depreciation_double ignores salvage (1000 * 2/5 = 400)")

# BUG-135: dB_voltage ballooning on missing reference
# dB = 20 * log10(V / ref). If ref missing, ref=1e-30.
# 20 * log10(1 / 1e-30) = 20 * 30 = 600.
assert_ok(dB_voltage(1) >= 600, "dB_voltage balloons with missing reference")

# BUG-137: box_blur_kernel radius vs side
my $kernel = box_blur_kernel(3)
assert_eq(len($kernel), 49, "box_blur_kernel(3) side is 7")

# ── List & Collection Pitfalls ─────────────────────────────────────────────

# BUG-140: sum/product skip ARRAYREF innards
assert_eq(sum([10, 20]), 0, "sum([10,20]) yields 0 (bug)")
assert_eq(product([10, 20]), 0, "product([10,20]) yields 0 (bug)")
assert_eq(sum_list([10, 20]), 30, "sum_list works correctly")

# BUG-142: chain_from leaves inner ARRAYREFs opaque
my $chained = chain_from([[1,2], [3,4]])
assert_eq(len($chained), 4, "chain_from with AoA is length 4 (pinned behavior)")

# BUG-147: permutations([1,2,3]) numifies to 0
assert_eq(len(permutations([1,2,3])), 0, "permutations with arrayref returns empty (bug)")

# BUG-149: without([...], LIST) compares ref string
my @list = ([1,2], 10, 20)
my @out = without([1,2], @list)
assert_eq(len(@out), 4, "without arrayref removes nothing and flattens list (pinned behavior)")

# BUG-151: clamp(11, 0, 10) misread order
assert_eq(clamp(11, 0, 10), 11, "clamp(11, 0, 10) returns 11 (bug)")

# BUG-156: seq only uses first arg
assert_eq(seq(2, 5), "2", "seq(2, 5) yields '2' (bug)")

# BUG-158: parse_int("0xff") without radix is 0
assert_eq(tj(parse_int("0xff")), "null", "parse_int('0xff') is null without radix 16")

# BUG-161: percentile scale (0-100) vs quantile (0-1)
assert_eq(percentile(0.5, (1..100)), 1, "percentile(0.5) is 0.5th percentile (min)")
assert_eq(quantile((1..100), 0.5), 50.5, "quantile(0.5) is median")

# BUG-169: HHI uses first share only
assert_eq(hhi(0.3, 0.3, 0.4), 0.09, "hhi(0.3, 0.3, 0.4) is 0.3^2 = 0.09 (bug)")

# BUG-170: moving_average reversed args
assert_eq(moving_average([1,2,3], 5), 5, "moving_average([1,2,3], 5) is 5 (bug)")

# BUG-179: PMT order (RATE, NPER, PV)
my $pmt_bad = pmt(10000, 1, 1)
assert_ok(abs($pmt_bad) > 1000, "pmt with principal first is absurd")

# BUG-180: format_percent(0.125) is "0.1%"
assert_eq(format_percent(0.125), "0.1%", "format_percent(0.125) is '0.1%' (bug)")

test_run
