#!/usr/bin/env stryke

# Exhaustive Bug Pinning (2026-05-15)
# Verifying fixes for BUG-100+ and documented parity gaps.
# Compliance: docs/STYLE_GUIDE.md
# Mode: --no-interop

# ── 1. Array/Range sources in Parallel Macros (BUG FIXED) ───────────────────

val @a1 = (10, 20, 30)
(~> @a1 par_reduce { sum @_ }) |> aeq 60, "par_reduce array source elements"

(~p> @a1 sum) |> aeq 60, "p-arrow array source elements"

(~p> 1:5 sum) |> aeq 15, "p-arrow range source elements"

(~p> [1, 2, 3] sum) |> aeq 6, "p-arrow arrayref source sum"

# ── 2. sum/product/mean/median on arrayrefs (BUG FIXED) ─────────────────────

sum([1, 2, 3]) |> aeq 6, "sum(arrayref)"
product([2, 3, 4]) |> aeq 24, "product(arrayref)"
mean([10, 20, 30]) |> aeq 20, "mean(arrayref)"
median([1, 10, 100]) |> aeq 10, "median(arrayref)"

# ── 3. use/no statement boundary (BUG FIXED) ────────────────────────────────

use strict
fn pin_at_use_strict_fn { 42 }
pin_at_use_strict_fn() |> aeq 42, "use strict followed by fn on next line"

# ── 4. typed my / const my with user types (BUG FIXED) ───────────────────────

struct NS { x => Int }
typed val $s_obj : NS = NS->new(x => 42)
$s_obj->{x} |> aeq 42, "typed my with struct"

class Box { fn area { 7 } }
typed val $b_obj : Box = Box->new
$b_obj->area() |> aeq 7, "typed my with class"

enum Color { Red, Green, Blue }
typed val $c_obj : Color = Color::Red
"$c_obj" |> aeq "Color::Red", "typed my with enum"

const val $cx : Int = 5
$cx |> aeq 5, "const my with type"

# ── 5. Class Instance Reflection (BUG FIXED) ────────────────────────────────

class Person { name: Str = ""; age: Int = 0 }
val $p_obj = Person->new(name => "Bob", age => 25)
ref($p_obj) |> aeq "Person", "ref(class instance)"
# Explicitly sort keys for stable comparison
join(",", sort { _ cmp _1 } keys %$p_obj) |> aeq "age,name", "keys percent_deref class_inst"

# ── 6. Recursive Serialization (BUG FIXED) ──────────────────────────────────

class Inner { v: Int = 0 }
class Outer { name: Str = ""; inner: Any = 0 }
val $i_obj = Inner->new(v => 7)
val $o_obj = Outer->new(name => "x", inner => $i_obj)
to_json($o_obj) |> aeq '{"name":"x","inner":{"v":7}}', "to_json recursive class"

# ── 7. psort implicit params (BUG FIXED) ────────────────────────────────────

val @sorted = psort { _ <=> _1 } (3, 1, 4, 1, 5)
join(",", @sorted) |> aeq "1,1,3,4,5", "psort _ <=> _1"

# ── 8. Hash Slices (BUG FIXED) ──────────────────────────────────────────────

val %h_map = (a => 1, b => 2, c => 3)
val @h_slice = @h_map{a, c}
join(",", @h_slice) |> aeq "1,3", "hash slice @h{a, c}"

# ── 9. exists on missing intermediate (BUG FIXED) ───────────────────────────

val %deep_map = (a => { b => 1 })
exists $deep_map{a}{b} |> aok "exists present"
exists $deep_map{a}{c} |> { _ == 0 } |> aok "exists missing tail"
exists $deep_map{x}{y} |> { _ == 0 } |> aok "exists missing intermediate"

# ── 10. Math/Stats Bug Verification ─────────────────────────────────────────

# BUG-121 FIXED: median_absolute_deviation for even-sized
median_absolute_deviation(1, 2, 100, 101) |> aeq 49.5, "MAD even-n fixed"

# BUG-133 FIXED: depreciation_double salvage
depreciation_double(1000, 200, 5) |> { _ > 0 } |> aok "depreciation_double runs"

# BUG-149 FIXED: without([...], LIST)
without([1, 2], [1, 2, 3, 4]) |> join(",") |> aeq "3,4", "without arrayref filter"

# BUG-163 FIXED: running_reduce { $a + $b }
running_reduce({ _ + _1 }, [1, 2, 3, 4, 5]) |> join(",") |> aeq "1,3,6,10,15", "running_reduce fixed"

# BUG-198 FIXED: derangements(4)
derangements(4) |> aeq 9, "derangements(4) fixed"

# BUG-202 FIXED: prim_mst disconnected
val $disconnected = [[0, 0], [0, 0]]
prim_mst($disconnected) |> { _ == "inf" || _ == "Infinity" } |> aok "prim_mst disconnected fixed"

# ── 11. String/UTF-8 length (PARITY FIXED) ──────────────────────────────────

use utf8;
length("café") |> aeq 4, "length café with utf8"
length("日本語") |> aeq 3, "length nihongo with utf8"

# ── 12. Magic String Increment (PARITY FIXED) ───────────────────────────────

var $s_magic = "Az"
$s_magic++
$s_magic |> aeq "Ba", "magic string increment Az++"

test_run
