#!/usr/bin/env stryke

# Pinning batch Native-F (2026-05-10): Exhaustive Bug Alignment (from BUGS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Math & Analytic Divergences ───────────────────────────────────────────

len(iota_range(5, 99)) |> aeq 5, "iota_range ignores tail"
tj(lambert_w0(1)) |> aeq "NaN", "lambert_w0(1) is NaN"
tj(wright_omega(0)) |> aeq "NaN", "wright_omega(0) is NaN"
convolve_full([1,2], [3,4]) |> aeq 3, "convolve_full returns output length"
detrend_linear([1, 2, 3]) |> aeq 1, "detrend_linear returns slope"
medfilt_1d([10, 1, 2, 3], 1) |> aeq 2.5, "medfilt_1d is global median"

my $delta = bs_delta(100, 100, 1, 0.05, 0.2)
($delta > 0.6 && $delta < 0.7) |> aok "bs_delta returns call delta"
depreciation_double(1000, 500, 5) |> aeq 400, "depreciation_double ignores salvage"
(dB_voltage(1) >= 600) |> aok "dB_voltage balloons with missing reference"
len(box_blur_kernel(3)) |> aeq 49, "box_blur_kernel(3) side is 7"

# ── List & Collection Pitfalls ─────────────────────────────────────────────

sum([10, 20]) |> aeq 30, "sum([10,20]) unwraps arrayref (FIXED): 10+20=30"
product([10, 20]) |> aeq 200, "product([10,20]) unwraps arrayref (FIXED): 10·20=200"
sum_list([10, 20]) |> aeq 30, "sum_list works correctly"
len(chain_from([[1,2], [3,4]])) |> aeq 4, "chain_from length 4 (pinned behavior)"
len(permutations([1,2,3])) |> aeq 18, "permutations(arrayref) sums len of each perm (3! · 3 = 18) when passed as varargs to len"
len(without([1,2], ([1,2], 10, 20))) |> aeq 4, "without arrayref removes nothing (pinned behavior)"
clamp(11, 0, 10) |> aeq 10, "clamp(11, 0, 10) returns 10 (FIXED: bounds now normalized so swap order works)"
seq(2, 5) |> aeq "2", "seq(2, 5) yields '2' (bug)"
tj(parse_int("0xff")) |> aeq "null", "parse_int('0xff') is null without radix"
percentile(0.5, (1:100)) |> aeq 1, "percentile(0.5) is min"
quantile((1:100), 0.5) |> aeq 50.5, "quantile(0.5) is median"
hhi(0.3, 0.3, 0.4) |> aeq 0.34, "hhi(0.3, 0.3, 0.4) = 0.34 (FIXED: sums squares of all share args, not just the first)"
my @ma_empty = moving_average([1,2,3], 5)
scalar(@ma_empty) |> aeq 0, "moving_average(LIST=[1,2,3], WINDOW=5) returns empty (FIXED: pandas-style LIST-first now supported; empty when window > len)"
my $pb = pmt(10000, 1, 1)
abs($pb) > 1000 |> aok "pmt principal first is absurd"
format_percent(0.125) |> aeq "12.5%", "format_percent(0.125) = '12.5%' (FIXED: scales fraction to percent before formatting)"

test_run
