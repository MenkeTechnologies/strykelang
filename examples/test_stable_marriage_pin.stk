#!/usr/bin/env stryke

package StableMarriage

fn solve($men_prefs, $women_prefs) {
    var %men_matches; var %women_matches
    var @free_men = (keys %$men_prefs |> sort)
    var %women_ranks
    for val $w (keys %$women_prefs) {
        val $p = $women_prefs->{$w}
        $women_ranks{$w} = {}
        for val $i (0 : (len @$p) - 1) { $women_ranks{$w}->{$p->[$i]} = $i }
    }
    var %next_proposal
    for val $m (@free_men) { $next_proposal{$m} = 0 }
    while (@free_men) {
        val $m = shift @free_men
        val $w = $men_prefs->{$m}->[$next_proposal{$m}++]
        if (!defined $women_matches{$w}) {
            $women_matches{$w} = $m; $men_matches{$m} = $w
        } else {
            val $m_current = $women_matches{$w}
            if ($women_ranks{$w}->{$m} < $women_ranks{$w}->{$m_current}) {
                $women_matches{$w} = $m; $men_matches{$m} = $w
                push @free_men, $m_current; delete $men_matches{$m_current}
            } else { push @free_men, $m }
        }
    }
    \%men_matches
}

fn verify($matches, $men_prefs, $women_prefs) {
    val %women_matches = rev %$matches
    for val $m (keys %$matches) {
        val $m_match = $matches->{$m}
        val $m_pref_list = $men_prefs->{$m}
        for val $w (@$m_pref_list) {
            last if $w eq $m_match
            val $w_match = $women_matches{$w}
            val $w_pref_list = $women_prefs->{$w}
            var $rank_m = -1; var $rank_match = -1
            for val $i (0 : (len @$w_pref_list) - 1) {
                if ($w_pref_list->[$i] eq $m) { $rank_m = $i }
                if ($w_pref_list->[$i] eq $w_match) { $rank_match = $i }
            }
            return 0 if $rank_m < $rank_match
        }
    }
    1
}

package main

# --- End-to-end Test ---
val %m1 = ( a => ["x", "y"], b => ["y", "x"] )
val %w1 = ( x => ["b", "a"], y => ["a", "b"] )
val $res1 = StableMarriage::solve \%m1, \%w1
$res1->{a} |> aeq "x", "matching a-x"
$res1->{b} |> aeq "y", "matching b-y"
StableMarriage::verify($res1, \%m1, \%w1) |> aeq 1, "basic stable"

# --- Another Case ---
val %m2 = (
    abe  => ["abi", "eve"],
    bob  => ["eve", "abi"],
)
val %w2 = (
    abi  => ["abe", "bob"],
    eve  => ["bob", "abe"],
)
# abe proposes to abi -> engaged
# bob proposes to eve -> engaged
# matches: abe-abi, bob-eve
val $res2 = StableMarriage::solve \%m2, \%w2
$res2->{abe} |> aeq "abi", "abe-abi"
$res2->{bob} |> aeq "eve", "bob-eve"
StableMarriage::verify($res2, \%m2, \%w2) |> aeq 1, "simple stable"

# --- Mismatch Case (instability check) ---
val %bad_matches = ( abe => "eve", bob => "abi" )
StableMarriage::verify(\%bad_matches, \%m2, \%w2) |> aeq 0, "bad matches unstable"

test_run
