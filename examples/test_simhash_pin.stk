#!/usr/bin/env stryke

fn SH::hash32($s) {
    my $h = 2166136261
    my $n = len $s
    for my $i (0:$n-1) {
        $h = $h ^ ord(substr($s, $i, 1))
        $h = ($h * 16777619) % 4294967296
    }
    $h
}

fn SH::shingles($text, $k) {
    my $n = len $text
    return [$text] if $n <= $k
    my @out = ()
    for my $i (0:$n-$k) {
        push @out, substr($text, $i, $k)
    }
    \@out
}

fn SH::compute($text, $k) {
    my @v = ()
    for my $i (0:31) { push @v, 0 }
    my $sh = SH::shingles($text, $k)
    for my $tok (@$sh) {
        my $h = SH::hash32($tok)
        for my $bi (0:31) {
            my $bit = int($h / (2 ** $bi)) % 2
            if ($bit == 1) {
                $v[$bi] = $v[$bi] + 1
            } else {
                $v[$bi] = $v[$bi] - 1
            }
        }
    }
    my $sig = 0
    for my $bi (0:31) {
        if ($v[$bi] >= 0) { $sig = $sig + (2 ** $bi) }
    }
    $sig
}

fn SH::hamming($x, $y) {
    my $z = $x ^ $y
    my $cnt = 0
    for my $bi (0:31) {
        $cnt = $cnt + 1 if int($z / (2 ** $bi)) % 2 == 1
    }
    $cnt
}

# --- hash32 ---
my $hv = SH::hash32("")
$hv |> aeq 2166136261, "fnv1a empty"

my $h_a = SH::hash32("a")
my $h_b = SH::hash32("a")
$h_a |> aeq $h_b, "fnv1a determinism"

(SH::hash32("a") == SH::hash32("b")) |> aeq 0, "fnv1a different chars distinct"
(SH::hash32("hello") == SH::hash32("world")) |> aeq 0, "fnv1a different words distinct"

# Range
my $hh = SH::hash32("foo")
($hh >= 0) |> aeq 1, "hash non-negative"
($hh < 4294967296) |> aeq 1, "hash fits u32"

# --- shingles ---
my $s1 = SH::shingles("hello", 3)
len(@$s1) |> aeq 3, "shingles len=3"
$s1->[0] |> aeq "hel", "shingle 0"
$s1->[1] |> aeq "ell", "shingle 1"
$s1->[2] |> aeq "llo", "shingle 2"

my $s2 = SH::shingles("abc", 3)
len(@$s2) |> aeq 1, "shingles equal len"
$s2->[0] |> aeq "abc", "shingle eq val"

my $s3 = SH::shingles("ab", 3)
len(@$s3) |> aeq 1, "shingles shorter"
$s3->[0] |> aeq "ab", "short shingle val"

my $s4 = SH::shingles("abcdef", 2)
len(@$s4) |> aeq 5, "shingles k=2 len"
$s4->[0] |> aeq "ab", "k=2 first"
$s4->[4] |> aeq "ef", "k=2 last"

# --- compute determinism ---
my $sig_a = SH::compute("hello world", 3)
my $sig_b = SH::compute("hello world", 3)
$sig_a |> aeq $sig_b, "simhash deterministic"

# --- hamming ---
SH::hamming(0, 0) |> aeq 0, "hamming zero"
SH::hamming(1, 0) |> aeq 1, "hamming one bit"
SH::hamming(0xFFFFFFFF, 0) |> aeq 32, "hamming all"
SH::hamming(0xAAAAAAAA, 0x55555555) |> aeq 32, "hamming alternating"
SH::hamming(7, 0) |> aeq 3, "hamming three"
SH::hamming(123, 123) |> aeq 0, "hamming same"

# Symmetry
my $xa = 0x12345678
my $xb = 0xDEADBEEF
SH::hamming($xa, $xb) |> aeq SH::hamming($xb, $xa), "hamming symmetric"

# --- end-to-end: near-duplicate has small hamming ---
my $doc1 = "the quick brown fox jumps over the lazy dog"
my $doc2 = "the quick brown fox jumps over a lazy dog"
my $doc3 = "completely unrelated text about cats and weather"

my $sig1 = SH::compute($doc1, 4)
my $sig2 = SH::compute($doc2, 4)
my $sig3 = SH::compute($doc3, 4)

my $near = SH::hamming($sig1, $sig2)
my $far  = SH::hamming($sig1, $sig3)

($near < 8) |> aeq 1, "near-dup small distance"
($far > $near) |> aeq 1, "unrelated farther than near-dup"
($far >= 10) |> aeq 1, "unrelated noticeably far"

# Identical docs => distance 0
my $sx = SH::compute("same text", 3)
my $sy = SH::compute("same text", 3)
SH::hamming($sx, $sy) |> aeq 0, "identical docs zero"

# Compute non-negative and fits u32
($sig1 >= 0) |> aeq 1, "sig non-negative"
($sig1 < 4294967296) |> aeq 1, "sig fits u32"

test_run
