#!/usr/bin/env stryke

# Graph algorithms: BFS, DFS, shortest path (unweighted).

fn Graph::adj() {
    +{
        A => [qw(B C)],
        B => [qw(A D E)],
        C => [qw(A F)],
        D => [qw(B)],
        E => [qw(B F)],
        F => [qw(C E)],
    }
}

fn Graph::bfs($g, $start) {
    var @order
    var %seen
    var @queue = ($start)
    $seen{$start} = 1
    while (len(@queue) > 0) {
        val $node = shift @queue
        push @order, $node
        for val $nb (@{$g->{$node}}) {
            unless ($seen{$nb}) {
                $seen{$nb} = 1
                push @queue, $nb
            }
        }
    }
    \@order
}

fn Graph::dfs($g, $start) {
    var @order
    var %seen
    var @stack = ($start)
    while (len(@stack) > 0) {
        val $node = pop @stack
        next if $seen{$node}
        $seen{$node} = 1
        push @order, $node
        val @nbs = @{$g->{$node}}
        for val $nb (sort { _1 cmp _ } @nbs) {
            push @stack, $nb unless $seen{$nb}
        }
    }
    \@order
}

fn Graph::shortest_path($g, $src, $dst) {
    var %parent = ($src => undef)
    var @queue = ($src)
    while (len(@queue) > 0) {
        val $node = shift @queue
        if ($node eq $dst) {
            var @path
            var $c = $dst
            while (defined $c) {
                unshift @path, $c
                $c = $parent{$c}
            }
            return \@path
        }
        for val $nb (@{$g->{$node}}) {
            unless (exists $parent{$nb}) {
                $parent{$nb} = $node
                push @queue, $nb
            }
        }
    }
    []
}

fn Graph::connected_components($g) {
    var %seen
    var @comps
    for val $node (sort keys %$g) {
        next if $seen{$node}
        var @comp
        var @queue = ($node)
        $seen{$node} = 1
        while (len(@queue) > 0) {
            val $c = shift @queue
            push @comp, $c
            for val $nb (@{$g->{$c}}) {
                unless ($seen{$nb}) {
                    $seen{$nb} = 1
                    push @queue, $nb
                }
            }
        }
        push @comps, [sort @comp]
    }
    \@comps
}

val $g = Graph::adj()

# BFS from A
join(",", @{Graph::bfs($g, "A")}) |> aeq "A,B,C,D,E,F", "bfs A"

# DFS from A — deterministic via reverse sort on neighbors
join(",", @{Graph::dfs($g, "A")}) |> aeq "A,B,D,E,F,C", "dfs A"

# Shortest paths
join("->", @{Graph::shortest_path($g, "A", "F")}) |> aeq "A->C->F", "sp A->F"
join("->", @{Graph::shortest_path($g, "D", "F")}) |> aeq "D->B->E->F", "sp D->F"
join("->", @{Graph::shortest_path($g, "A", "A")}) |> aeq "A",        "sp self"

# Disconnected: A-B, C-D, isolated E
val $g2 = +{
    A => ["B"], B => ["A"],
    C => ["D"], D => ["C"],
    E => [],
}
val $comps = Graph::connected_components($g2)
len(@$comps) |> aeq 3, "3 components"
join(",", @{$comps->[0]}) |> aeq "A,B", "comp AB"
join(",", @{$comps->[1]}) |> aeq "C,D", "comp CD"
join(",", @{$comps->[2]}) |> aeq "E",    "comp E"

# Graph with cycles still terminates
val $cyc = +{
    A => ["B"],
    B => ["C"],
    C => ["A"],
}
join(",", @{Graph::bfs($cyc, "A")}) |> aeq "A,B,C", "cycle bfs terminates"

test_run
