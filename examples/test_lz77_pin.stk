#!/usr/bin/env stryke

package LZ77

fn compress($text, $window_size, $lookahead_size) {
    my $n = len $text; my @compressed; my $i = 0
    while ($i < $n) {
        my $match_dist = 0; my $match_len = 0
        my $start_window = $i > $window_size ? $i - $window_size : 0
        for (my $j = $start_window; $j < $i; $j++) {
            my $l = 0
            while ($l < $lookahead_size && $i + $l < $n && $text[$j + $l] eq $text[$i + $l]) { $l++ }
            if ($l > $match_len) { $match_len = $l; $match_dist = $i - $j }
        }
        my $next_char = ""
        if ($i + $match_len < $n) { $next_char = $text[$i + $match_len] }
        push @compressed, [$match_dist, $match_len, $next_char]
        $i += $match_len + 1
    }
    \@compressed
}

fn decompress($compressed) {
    my $text = ""
    for my $token (@$compressed) {
        my $dist = $token->[0]; my $length = $token->[1]; my $next_char = $token->[2]
        if ($length > 0) {
            my $start = (len $text) - $dist
            for (my $i = 0; $i < $length; $i++) { $text = $text . $text[$start + $i] }
        }
        $text = $text . $next_char
    }
    $text
}

package main

my $msg1 = "ABABCBABABCAD"
my $c1 = LZ77::compress($msg1, 10, 5)
my $d1 = LZ77::decompress($c1)
~> $d1 aeq($msg1, "LZ77 roundtrip 1")

my $msg2 = "A" x 50
my $c2 = LZ77::compress($msg2, 10, 10)
my $d2 = LZ77::decompress($c2)
~> $d2 aeq($msg2, "LZ77 roundtrip repeats")

test_run
