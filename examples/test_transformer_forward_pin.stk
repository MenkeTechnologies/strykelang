#!/usr/bin/env stryke

package Transformer

fn mat_mul($m1, $m2) {
    val $m1_rows = len @$m1; val $m1_cols = len @{$m1->[0]}
    val $m2_rows = len @$m2; val $m2_cols = len @{$m2->[0]}
    val $res = []
    for val $i (0 : $m1_rows - 1) {
        val $row = []
        for val $j (0 : $m2_cols - 1) {
            var $sum = 0.0
            for val $k (0 : $m1_cols - 1) { $sum += $m1->[$i]->[$k] * $m2->[$k]->[$j] }
            push @$row, $sum
        }
        push @$res, $row
    }
    $res
}

fn mat_transpose($m) {
    val $rows = len @$m; val $cols = len @{$m->[0]}
    val $res = []
    for val $i (0 : $cols - 1) {
        val $row = []
        for val $j (0 : $rows - 1) { push @$row, $m->[$j]->[$i] }
        push @$res, $row
    }
    $res
}

fn mat_scale($m, $scalar) {
    val $res = []
    for val $row (@$m) {
        val $new_row = []
        for val $val (@$row) { push @$new_row, $val * $scalar }
        push @$res, $new_row
    }
    $res
}

fn softmax($m) {
    val $res = []
    for val $row (@$m) {
        var $max_val = -1000000000.0
        for val $val (@$row) { if ($val > $max_val) { $max_val = $val } }
        var $new_row = []; var $sum_exp = 0.0
        for val $val (@$row) { val $e = exp($val - $max_val); push @$new_row, $e; $sum_exp += $e }
        for val $i (0 : (len @$new_row) - 1) { $new_row->[$i] /= $sum_exp }
        push @$res, $new_row
    }
    $res
}

fn self_attention($q, $k, $v) {
    val $d_k = len @{$q->[0]}
    val $k_t = Transformer::mat_transpose($k)
    val $scores = Transformer::mat_mul($q, $k_t)
    val $scaled_scores = Transformer::mat_scale($scores, 1.0 / sqrt($d_k))
    val $attention_weights = Transformer::softmax($scaled_scores)
    val $output = Transformer::mat_mul($attention_weights, $v)
    { output => $output, weights => $attention_weights }
}

package main

val $Q = [[1.0, 0.0], [0.0, 1.0]]
val $K = [[1.0, 0.0], [0.0, 1.0]]
val $V = [[2.0, 0.0], [0.0, 2.0]]

val $res = Transformer::self_attention($Q, $K, $V)

# The attention weights should be heavily skewed towards the diagonal (1 -> 1, 2 -> 2)
# scaled score for [1,0]*[1,0] = 1/sqrt(2) = 0.707
# scaled score for [1,0]*[0,1] = 0
# softmax(0.707, 0) = [0.67, 0.33]

val $w = $res->{weights}
~> abs($w->[0]->[0] - 0.67) <(0.01) aeq(1, "softmax row 0 col 0")
~> abs($w->[0]->[1] - 0.33) <(0.01) aeq(1, "softmax row 0 col 1")
~> abs($w->[1]->[0] - 0.33) <(0.01) aeq(1, "softmax row 1 col 0")
~> abs($w->[1]->[1] - 0.67) <(0.01) aeq(1, "softmax row 1 col 1")

val $out = $res->{output}
~> abs($out->[0]->[0] - 1.34) <(0.01) aeq(1, "output row 0 col 0")
~> abs($out->[1]->[1] - 1.34) <(0.01) aeq(1, "output row 1 col 1")

test_run
