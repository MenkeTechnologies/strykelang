#!/usr/bin/env stryke

# Observer / pub-sub pattern.

fn Pubsub::new() { +{ subs => {}, next_id => 0 } }

fn Pubsub::subscribe($bus, $topic, $cb) {
    $bus->{subs}{$topic} //= {}
    val $id = $bus->{next_id}++
    $bus->{subs}{$topic}{$id} = $cb
    $id
}

fn Pubsub::unsubscribe($bus, $topic, $id) {
    delete $bus->{subs}{$topic}{$id}
    1
}

fn Pubsub::publish($bus, $topic, $msg) {
    var $count = 0
    if (exists $bus->{subs}{$topic}) {
        for val $cb (values %{$bus->{subs}{$topic}}) {
            $cb($msg)
            $count++
        }
    }
    $count
}

fn Pubsub::sub_count = exists _->{subs}{_1} ? len(keys %{_->{subs}{_1}}) : 0

val $bus = Pubsub::new()
var $log = []

val $id1 = Pubsub::subscribe($bus, "news", fn { push @$log, "A:" . _ })
val $id2 = Pubsub::subscribe($bus, "news", fn { push @$log, "B:" . _ })
val $id3 = Pubsub::subscribe($bus, "other", fn { push @$log, "C:" . _ })

Pubsub::sub_count($bus, "news")  |> aeq 2, "news has 2"
Pubsub::sub_count($bus, "other") |> aeq 1, "other has 1"
Pubsub::sub_count($bus, "void")  |> aeq 0, "void has 0"

Pubsub::publish($bus, "news", "hello") |> aeq 2, "publish news → 2"
"@$log" |> aeq "A:hello B:hello", "log after 1 news"

@$log = ()
Pubsub::publish($bus, "other", "ping") |> aeq 1, "publish other → 1"
"@$log" |> aeq "C:ping", "log after 1 other"

@$log = ()
Pubsub::publish($bus, "void", "x") |> aeq 0, "publish void → 0"
len(@$log) |> aeq 0, "no one heard void"

# Unsubscribe one
Pubsub::unsubscribe($bus, "news", $id1)
Pubsub::sub_count($bus, "news") |> aeq 1, "news after unsub → 1"

@$log = ()
Pubsub::publish($bus, "news", "world")
"@$log" |> aeq "B:world", "only B got news"

# Multi-topic
val $cb_all = fn { push @$log, "ALL:" . _ }
Pubsub::subscribe($bus, "news", $cb_all)
Pubsub::subscribe($bus, "other", $cb_all)
@$log = ()
Pubsub::publish($bus, "news", "x")
Pubsub::publish($bus, "other", "y")
len(@$log) |> aeq 4, "4 deliveries across two topics"

# Wildcard-like fan-out using publish_all helper
fn Pubsub::publish_all($bus, $msg) {
    var $total = 0
    for val $topic (keys %{$bus->{subs}}) {
        $total += Pubsub::publish($bus, $topic, $msg)
    }
    $total
}

@$log = ()
Pubsub::publish_all($bus, "broadcast") > 0 |> aok "publish_all delivered"

# Filtered subscribe via wrapper
fn Pubsub::subscribe_where($bus, $topic, $pred, $cb) {
    Pubsub::subscribe($bus, $topic, fn($m) { $cb($m) if $pred($m) })
}

val $bus2 = Pubsub::new()
val $log2 = []
Pubsub::subscribe_where($bus2, "n", fn { _ > 5 }, fn { push @$log2, _ })
Pubsub::publish($bus2, "n", 3)
Pubsub::publish($bus2, "n", 7)
Pubsub::publish($bus2, "n", 10)
Pubsub::publish($bus2, "n", 2)
"@$log2" |> aeq "7 10", "filtered subscribe"

# Counter via mysync (closure capturing shared counter)
mysync $hits = 0
val $bus3 = Pubsub::new()
Pubsub::subscribe($bus3, "tap", fn { $hits++ })
Pubsub::publish($bus3, "tap", "x")
Pubsub::publish($bus3, "tap", "y")
Pubsub::publish($bus3, "tap", "z")
$hits |> aeq 3, "shared counter hits 3"

test_run
