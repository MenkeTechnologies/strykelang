#!/usr/bin/env stryke

# Pinning batch Native-H (2026-05-10): Specialized (AI, Stress, SQLite)
# Compliance: docs/STYLE_GUIDE.md

# ── AI Primitives (Extra) ──────────────────────────────────────────────────

env_set("STRYKE_AI_MODE", "mock-only")
ai_models("openai")->[0] |> aeq "mock-model-1", "ai_models mock-only first"
ai_mock_install("image", "BINARY_DATA")
ai_image("cat") |> aeq "BINARY_DATA", "ai_image mock"

# ── Stress Testing ─────────────────────────────────────────────────────────

stress_cpu(0.1) >= 0 |> aok "stress_cpu"
stress_mem(1e6) |> aeq 1000000, "stress_mem returns bytes touched"

# ── SQLite Builtin ─────────────────────────────────────────────────────────

my $db = sqlite(":memory:")
$db->exec("CREATE TABLE t(x INT)")
$db->exec("INSERT INTO t VALUES (42)")
$db->query("SELECT x FROM t")->[0]{x} |> aeq 42, "sqlite query"

# ── Number Theory & Stats (More) ───────────────────────────────────────────

next_prime(10) |> aeq 11, "next_prime(10)"
next_prime(11) |> aeq 13, "next_prime(11)"
mode_val([1, 2, 2, 3]) |> aeq 2, "mode_val on arrayref"
harmonic_mean(1, 2, 4) |> map { abs(_ - 1.714) < 0.01 } |> aok "harmonic_mean"
geometric_mean(1, 2, 4) |> aeq 2, "geometric_mean"

test_run
