#!/usr/bin/env stryke

# Pinning batch Fixed-Bugs (2026-05-10): Regression guards for recently fixed bugs
# Compliance: docs/STYLE_GUIDE.md

# BUG-090: val ($x_90, @y_90) = (1, 2, 3) binds @y to tail
val ($x_90, @y_90) = (1, 2, 3)
$x_90 |> aeq 1, "BUG-090: head binds correctly"
@y_90 |> len |> aeq 2, "BUG-090: tail binds correctly"

# BUG-101 (FIXED): val ($x) = @arr now binds the first element correctly
# (was returning scalar count).
val @arr_101 = (10, 20, 30)
val ($first_101) = @arr_101
$first_101 |> aeq 10, 'BUG-101 (FIXED): val ($x) = @arr binds first element'

# BUG-110: use strict followed by fn on next line
use strict
fn BUG_110_test { "ok" }
BUG_110_test() |> aeq "ok", "BUG-110: use strict does not swallow fn on next line"

# BUG-114: Class instances recognized correctly
class BUG_114_C {
    val: Int = 0
    fn set_val($v) { $self->val = $v }
    fn get_val { return $self->val }
}
# BUG-114 fix allowed Class->new or Class()
val $obj_114 = BUG_114_C()
$obj_114->set_val(42)
$obj_114->get_val() |> aeq 42, "BUG-114: class method works"
ref($obj_114) |> aeq "BUG_114_C", "BUG-114: ref() returns class name"

# BUG-115: strict vars exempts _, _1
# We are already in 'use strict' from above
fn BUG_115_test {
    # This should not raise "Global symbol $_ requires explicit package name"
    return _ + _1
}
BUG_115_test(5, 7) |> aeq 12, 'BUG-115: strict vars exempts _, _1'

# BUG-117: psort terminates at newline
val @s_117 = (3, 1, 2) |> psort { _ <=> _1 }
val $n_117 = len(@s_117)
$n_117 |> aeq 3, "BUG-117: psort block terminates at newline"
@s_117[0] |> aeq 1, "BUG-117: psort actually sorts"

# BUG-027: $#a = N resizes array
val @a_027 = (1, 2, 3, 4, 5)
$#a_027 = 2
@a_027 |> len |> aeq 3, 'BUG-027: $#a = N truncates array'
$#a_027 = 4
@a_027 |> len |> aeq 5, 'BUG-027: $#a = N grows array'
@a_027[4] |> aeq undef, 'BUG-027: $#a = N pads with undef'

# BUG-019: for (@arr) { _ *= 10 } aliases array element
var @a_019 = (1, 2, 3)
for (@a_019) { _ *= 10 }
@a_019[0] |> aeq 10, "BUG-019: for loop aliases elements (0)"
@a_019[2] |> aeq 30, "BUG-019: for loop aliases elements (2)"

test_run
