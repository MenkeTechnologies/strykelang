#!/usr/bin/env stryke

package RSA

fn gcd($v1, $v2) {
    while ($v2 != 0) { val $t = $v2; $v2 = $v1 % $v2; $v1 = $t }
    $v1
}

fn mod_inverse($v1, $m) {
    val $m0 = $m; var $y = 0; var $x = 1
    return 0 if $m == 1
    while ($v1 > 1) {
        val $q = int($v1 / $m)
        var $t = $m; $m = $v1 % $m; $v1 = $t
        $t = $y; $y = $x - $q * $y; $x = $t
    }
    $x = $x + $m0 if $x < 0
    $x
}

fn mod_pow($base, $exp, $mod) {
    var $res = 1; $base = $base % $mod
    while ($exp > 0) {
        $res = ($res * $base) % $mod if $exp % 2 == 1
        $exp = int($exp / 2)
        $base = ($base * $base) % $mod
    }
    $res
}

fn is_prime($n) {
    return 0 if $n <= 1; return 1 if $n <= 3; return 0 if $n % 2 == 0 || $n % 3 == 0
    var $i = 5
    while ($i * $i <= $n) { return 0 if $n % $i == 0 || $n % ($i + 2) == 0; $i = $i + 6 }
    1
}

fn generate_keypair($p, $q) {
    die "Both numbers must be prime." if !RSA::is_prime($p) || !RSA::is_prime($q)
    val $n = $p * $q; val $phi = ($p - 1) * ($q - 1); var $e = 3
    while ($e < $phi) { last if RSA::gcd($e, $phi) == 1; $e++ }
    val $d = RSA::mod_inverse($e, $phi)
    { public => [$e, $n], private => [$d, $n] }
}

fn encrypt($msg, $public_key) {
    val $e = $public_key->[0]; val $n = $public_key->[1]; var @enc; val $len = len $msg
    for val $i (0:$len-1) { val $m = ord($msg[$i]); push @enc, RSA::mod_pow($m, $e, $n) }
    \@enc
}

fn decrypt($enc, $private_key) {
    val $d = $private_key->[0]; val $n = $private_key->[1]; var $msg = ""
    for val $c (@$enc) { val $m = RSA::mod_pow($c, $d, $n); $msg = $msg . chr($m) }
    $msg
}

package main

val $keys = RSA::generate_keypair(61, 53)
val $pub = $keys->{public}
val $priv = $keys->{private}

val $msg = "HELLO RSA 123"
val $enc = RSA::encrypt($msg, $pub)
val $dec = RSA::decrypt($enc, $priv)
$dec |> aeq $msg, "RSA encryption/decryption roundtrip"

test_run
