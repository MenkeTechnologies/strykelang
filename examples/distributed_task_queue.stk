#!/usr/bin/env stryke
#
# Distributed task queue — master holds a queue of N small jobs, fans
# them out to M workers via per-worker prays in a round-robin loop.
# Each worker processes its assigned job, returns the result. This
# is a pull-shape master/worker pattern (vs harvest's broadcast-shape).
#
# CI-safe: pure loopback fork, no network. Clean under --no-interop.

p "── distributed task queue ──"

# 12 jobs, 4 workers — each worker gets 3 jobs (round-robin).
var @jobs
for val $i (1:12) {
    push @jobs, $i
}
val $n_workers = 4
val @workers = congregation($n_workers)
var @sorted_workers = sort { _ <=> _1 } @workers

printf "jobs: %d  ·  workers: %d  ·  per worker: %d\n",
    len(@jobs), $n_workers, len(@jobs) / $n_workers

# Round-robin assign: job i goes to worker (i % n_workers).
var %assigned   # worker → list of job indices
for val $i (0:len(@jobs) - 1) {
    val $w = $sorted_workers[$i % $n_workers]
    if (exists $assigned{$w}) {
        push @{$assigned{$w}}, $i
    } else {
        $assigned{$w} = [$i]
    }
}

# Each worker processes its job slice — for the demo, "process"
# means compute job_value * job_value + worker_pid_mod (to show
# the worker actually ran the code).
var %results
for val $w (@sorted_workers) {
    var @worker_jobs
    for val $i (@{$assigned{$w}}) {
        push @worker_jobs, $jobs[$i]
    }
    val $job_json = to_json(\@worker_jobs)
    val $code = "
        var \$arr = from_json(q{$job_json});
        var \@out;
        for var \$j (\@\$arr) {
            push \@out, \$j * \$j;
        }
        to_json(\\\@out)
    "
    val $div = pray $code, $w
    val %reply = annex $div
    $results{$w} = from_json($reply{$w})
}

p "── per-worker results ──"
var $total = 0
for val $w (@sorted_workers) {
    var @r = @{$results{$w}}
    printf "  worker %d: %s\n", $w, join(",", @r)
    for val $v (@r) { $total += $v }
}

# Sanity: sum of i*i for i=1..12 = 12*13*25/6 = 650.
printf "fleet sum: %d (expected 650 = sum of i² for i=1..12)\n", $total
p $total == 650 ? "✓ task queue produced correct fleet sum" : "✗ sum off"

excommunicate(@workers)
p "done"
