#!/usr/bin/env stryke

# manacher_no_interop.stk — Longest Palindromic Substring in O(N).
#
# Manacher's algorithm finds the radius of the longest palindrome centered
# at each position in a string.
#
# Run: stryke --no-interop examples/manacher_no_interop.stk

package Manacher

fn solve($s) {
    # Preprocess string: "aba" -> "#a#b#a#"
    my $t = "#"
    my $n = len $s
    for my $i (0 : $n - 1) {
        $t = $t . $s[$i] . "#"
    }
    
    my $m = len $t
    my @p = (0) x $m
    my $c = 0 # current center
    my $r = 0 # current right boundary
    
    for my $i (0 : $m - 1) {
        my $mirr = 2 * $c - $i
        
        if ($i < $r) {
            $p[$i] = min($r - $i, $p[$mirr])
        }
        
        # Attempt to expand around center i
        my $v1 = $i + (1 + $p[$i])
        my $v2 = $i - (1 + $p[$i])
        while ($v1 < $m && $v2 >= 0 && $t[$v1] eq $t[$v2]) {
            $p[$i]++
            $v1++
            $v2--
        }
        
        # If expanded past r, update center and boundary
        if ($i + $p[$i] > $r) {
            $c = $i
            $r = $i + $p[$i]
        }
    }
    
    # Find max radius
    my $max_r = 0
    my $best_c = 0
    for my $i (0 : $m - 1) {
        if ($p[$i] > $max_r) {
            $max_r = $p[$i]
            $best_c = $i
        }
    }
    
    # Extract longest palindrome
    my $start = int(($best_c - $max_r) / 2)
    substr($s, $start, $max_r)
}

package main

p "── Manacher's Algorithm Demo ──"

my $s = "babad"
my $res = Manacher::solve($s)
p "Input: '#{$s}'"
p "Longest Palindrome: '#{$res}'"

my $s2 = "cbbd"
my $res2 = Manacher::solve($s2)
p "\nInput: '#{$s2}'"
p "Longest Palindrome: '#{$res2}'"

p "Done."
