#!/usr/bin/env stryke

# Levenshtein edit distance — minimum insertions / deletions /
# substitutions to turn string A into string B. Classic O(m·n) dynamic-
# programming form, two-row rolling buffer (O(min(m,n)) memory).
# Parses clean under `--no-interop`.
#
# Stryke choices:
#   * `fn`, `p`, `printf`, `len`
#   * Two rolling arrays via `my @prev` / `my @curr`; iterate row by
#     row swapping references each step
#   * `min` 3-argument call (Stryke's variadic min)
#   * `split //` for char access
#   * `die` invariants at the end
#
# Run: stryke --no-interop examples/levenshtein_no_interop.stk
#      stryke --no-interop examples/levenshtein_no_interop.stk kitten sitting

fn lev_dist($s1, $s2) {
    my @ac = split(//, $s1)
    my @bc = split(//, $s2)
    my $m  = len(@ac)
    my $n  = len(@bc)
    return $n if $m == 0
    return $m if $n == 0

    # @prev = previous row (D[i-1][*]); @curr = current row (D[i][*]).
    my @prev = (0:$n)        # D[0][j] = j (j inserts to get from "" to b[0..j-1])
    my @curr = (0) x ($n + 1)

    for my $i (1:$m) {
        $curr[0] = $i        # D[i][0] = i (i deletes)
        for my $j (1:$n) {
            my $cost = $ac[$i - 1] eq $bc[$j - 1] ? 0 : 1
            $curr[$j] = min(
                $prev[$j]     + 1,        # deletion
                $curr[$j - 1] + 1,        # insertion
                $prev[$j - 1] + $cost,    # substitution / match
            )
        }
        @prev = @curr
    }
    $prev[$n]
}

if (len(@ARGV) >= 2) {
    p lev_dist($ARGV[0], $ARGV[1])
    exit 0
}

# Demo table — known distances from the literature.
my @cases = (
    +{ a => "",        b => "",        d => 0 },
    +{ a => "abc",     b => "abc",     d => 0 },
    +{ a => "kitten",  b => "sitting", d => 3 },  # classic example
    +{ a => "saturday",b => "sunday",  d => 3 },
    +{ a => "flaw",    b => "lawn",    d => 2 },
    +{ a => "gumbo",   b => "gambol",  d => 2 },
    +{ a => "hello",   b => "",        d => 5 },  # all deletes
    +{ a => "",        b => "hello",   d => 5 },  # all inserts
    +{ a => "a",       b => "b",       d => 1 },  # single sub
    +{ a => "abcdef",  b => "azcdef",  d => 1 },  # mid sub
)

p "── Levenshtein edit-distance demo ──"
my $fail = 0
for my $c (@cases) {
    my $got = lev_dist($c->{a}, $c->{b})
    my $ok  = ($got == $c->{d})
    $fail++ unless $ok
    printf "  d(%-10s , %-10s) = %d  expect %d  %s\n",
        "\"" . $c->{a} . "\"", "\"" . $c->{b} . "\"",
        $got, $c->{d}, $ok ? "" : "FAIL"
}
die "$fail / " . len(@cases) . " levenshtein cases failed" if $fail > 0
p ""
p "  ALL PASS (10 reference distances match)"
