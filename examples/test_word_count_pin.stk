#!/usr/bin/env stryke

# Pinning test for word_count.stk demo.
# Compliance: docs/STYLE_GUIDE.md

fn WC::tokenize($s) {
    my @words = split / +/, lc($s)
    \@words
}

fn WC::count($s) {
    my %freq = ()
    for my $w (@{WC::tokenize($s)}) {
        $freq{$w} = ($freq{$w} // 0) + 1
    }
    \%freq
}

fn WC::top($freq, $n) {
    my @keys = keys %$freq
    my @sorted = sort { $freq->{_1} <=> $freq->{_} } @keys
    my @top = ()
    for my $k (@sorted[0:$n-1]) {
        push @top, [$k, $freq->{$k}]
    }
    \@top
}

# ── Tokenize ──────────────────────────────────────────────────────────────

my $t1 = WC::tokenize("the quick fox")
len(@$t1) |> aeq 3, "tokenize: 3 words"
$t1->[0]  |> aeq "the",   "tokenize[0]"
$t1->[1]  |> aeq "quick", "tokenize[1]"
$t1->[2]  |> aeq "fox",   "tokenize[2]"

my $t2 = WC::tokenize("HELLO World")
$t2->[0] |> aeq "hello", "tokenize: lowercased"
$t2->[1] |> aeq "world", "tokenize: lowercased 2"

# ── Count basic ───────────────────────────────────────────────────────────

my $c1 = WC::count("a b a c a b")
$c1->{a} |> aeq 3, "count a=3"
$c1->{b} |> aeq 2, "count b=2"
$c1->{c} |> aeq 1, "count c=1"
len(keys %$c1) |> aeq 3, "count: 3 unique"

# ── Count case-insensitive ────────────────────────────────────────────────

my $c2 = WC::count("Foo foo FOO bar")
$c2->{foo} |> aeq 3, "count case-fold foo=3"
$c2->{bar} |> aeq 1, "count case-fold bar=1"

# ── Empty input ───────────────────────────────────────────────────────────

my $c3 = WC::count("")
len(keys %$c3) |> aeq 0, "count empty: no words"

# ── Top-N ────────────────────────────────────────────────────────────────

my $freq = WC::count("the the the cat cat dog")
my $top  = WC::top($freq, 3)
len(@$top)    |> aeq 3,    "top-3: 3 results"
$top->[0][0]  |> aeq "the","top: most frequent is 'the'"
$top->[0][1]  |> aeq 3,    "top: count of 'the' = 3"
$top->[1][0]  |> aeq "cat","top: 2nd is 'cat'"
$top->[1][1]  |> aeq 2,    "top: count of 'cat' = 2"
$top->[2][0]  |> aeq "dog","top: 3rd is 'dog'"
$top->[2][1]  |> aeq 1,    "top: count of 'dog' = 1"

# ── Single word ───────────────────────────────────────────────────────────

my $c4 = WC::count("hello")
$c4->{hello} |> aeq 1, "single word: hello=1"

# ── Sum of all frequencies = token count ──────────────────────────────────

my $text  = "alpha beta gamma alpha beta alpha"
my $f5    = WC::count($text)
my $tok5  = WC::tokenize($text)
my $totsum = 0
for my $v (values %$f5) { $totsum = $totsum + $v }
$totsum |> aeq len(@$tok5), "sum freqs == token count"

test_run
