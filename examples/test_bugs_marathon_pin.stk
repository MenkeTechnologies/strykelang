#!/usr/bin/env stryke

# Pinning batch Bugs-Marathon (2026-05-10): Deep Bugs & Parity
# Compliance: docs/STYLE_GUIDE.md

# ── 1. Weak Refs (BUG-022) ────────────────────────────────────────────────

# weaken and isweak exist but isweak is always false
val $a_22 = [1]
val $b_22 = $a_22
weaken($b_22)
isweak($b_22) |> maps { !_ } |> aok "BUG-022: isweak always false today"

# ── 2. Match Position (BUG-038) ───────────────────────────────────────────

val $s_38 = "abc"
$s_38 =~ /a/g
pos($s_38) |> maps {!defined} |> aok "BUG-038: pos() is undef outside while loop"

# ── 3. Math Constants (BUG-064) ───────────────────────────────────────────

# pi/tau are builtins, PI/TAU/E are barewords (usually)
pi |> maps { _ > 3.14 && _ < 3.15 } |> aok "pi builtin works"
tau |> maps { _ > 6.28 && _ < 6.29 } |> aok "tau builtin works"
# BUG-064 (FIXED): PI and E barewords now resolve to their math constants
# instead of stringifying to "PI"/"E". `tj(PI)` emits the JSON number form.
tj(PI) |> aeq '3.141592653589793', "BUG-064 (FIXED): PI bareword resolves to π"
tj(E)  |> aeq '2.718281828459045', "BUG-064 (FIXED): E bareword resolves to e"

# ── 4. Prototype of Builtins (BUG-052) ────────────────────────────────────

# Builtins have empty prototypes today
prototype("push") |> aeq "", "BUG-052: prototype('push') is empty"

# ── 5. Stress Primitives ──────────────────────────────────────────────────

# stress_cpu(1) runs for 1 second and returns hash count
val $hashes = stress_cpu(1)
$hashes |> maps { _ > 0 } |> aok "stress_cpu(1) returns positive hash count"

# ── 6. refaddr of repeated references (BUG-102) ───────────────────────────

fn Pin::BugsMarathon::myff_102 { 1 }
val $r1_102 = \&Pin::BugsMarathon::myff_102
val $r2_102 = \&Pin::BugsMarathon::myff_102
refaddr($r1_102) != refaddr($r2_102) |> aok "BUG-102: refaddr of repeated \\&fn differs"

# ── 7. Single scalar destructure (BUG-101) ────────────────────────────────

val @arr_101 = (10, 20, 30)
val ($x_101) = @arr_101
$x_101 |> aeq 10, "BUG-101 (FIXED): var (\$x) = \@arr now binds first element (was returning count)"

# ── 8. to_json options (BUG-106) ──────────────────────────────────────────

# to_json treats second arg as array element, not options hashref
to_json({a => 1}, {pretty => 1}) |> aeq '[{"a":1},{"pretty":1}]', "BUG-106: to_json treats options as array element"

# ── 9. BEGIN mutations lost (BUG-078) ─────────────────────────────────────

our $log_78 = ""
BEGIN { $main::log_78 .= "B" }
$log_78 .= "M"
# It seems in some contexts it stringifies to SCALAR(0x...)M
$log_78 |> maps { _ =~ /SCALAR\(0x\w+\)M/ || _ eq "M" } |> aok "BUG-078: BEGIN mutations lost (or stringified bug)"

# ── 10. List-form system (BUG-031 FIXED) ──────────────────────────────────

# system(LIST) now sets $? to the Perl-encoded status word (exit_code << 8).
system("sh", "-c", "exit 7")
$? |> aeq 1792, "BUG-031 (FIXED): system(LIST) sets \$? to (exit_code << 8)"

test_run
