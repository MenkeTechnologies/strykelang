#!/usr/bin/env stryke

package JsonLogic

fn evaluate($rule, $data) {
    return $rule if ref($rule) ne "HASH"
    my ($op) = keys %$rule
    my $args = $rule->{$op}
    my @arr_args = (ref($args) eq "ARRAY" ? @$args : ($args))
    if ($op eq "var") {
        my $path = $arr_args[0]
        return $data->{$path} // $arr_args[1]
    }
    if ($op eq "==") { return evaluate($arr_args[0], $data) == evaluate($arr_args[1], $data) ? 1 : 0 }
    if ($op eq "!=") { return evaluate($arr_args[0], $data) != evaluate($arr_args[1], $data) ? 1 : 0 }
    if ($op eq ">")  { return evaluate($arr_args[0], $data) >  evaluate($arr_args[1], $data) ? 1 : 0 }
    if ($op eq "<")  { return evaluate($arr_args[0], $data) <  evaluate($arr_args[1], $data) ? 1 : 0 }
    if ($op eq "and") {
        for my $arg (@arr_args) { return 0 if !evaluate($arg, $data) }
        return 1
    }
    if ($op eq "or") {
        for my $arg (@arr_args) { return 1 if evaluate($arg, $data) }
        return 0
    }
    if ($op eq "if") {
        if (evaluate($arr_args[0], $data)) { return evaluate($arr_args[1], $data) }
        return evaluate($arr_args[2], $data)
    }
    if ($op eq "+") {
        my $sum = 0
        for my $arg (@arr_args) { $sum = $sum + evaluate($arg, $data) }
        return $sum
    }
    return undef
}

package main

# --- Basic E2E ---
my $data = { a => 10, b => 20 }
JsonLogic::evaluate({ "==" => [{ var => "a" }, 10] }, $data) |> aeq 1, "var a == 10"
JsonLogic::evaluate({ "==" => [{ var => "a" }, 20] }, $data) |> aeq 0, "var a != 20"

# --- Logic ---
JsonLogic::evaluate({ "and" => [{ ">" => [{ var => "b" }, 15] }, { "==" => [{ var => "a" }, 10] }] }, $data) 
    |> aeq 1, "and logic true"

# --- Control ---
JsonLogic::evaluate({ "if" => [{ ">" => [{ var => "a" }, 5] }, "yes", "no"] }, $data) 
    |> aeq "yes", "if logic"

# --- Math ---
JsonLogic::evaluate({ "+" => [1, 2, { var => "a" }] }, $data) |> aeq 13, "math sum"

test_run
