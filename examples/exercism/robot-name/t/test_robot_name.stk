#!/usr/bin/env stryke
require "./RobotName.stk"

val $r = Exercism::RobotName::new()
val $n1 = Exercism::RobotName::name($r)
assert_ok $n1 =~ /^[A-Z]{2}\d{3}$/, "name format"
assert_eq Exercism::RobotName::name($r), $n1, "name persists"

Exercism::RobotName::reset_name($r)
val $n2 = Exercism::RobotName::name($r)
assert_ok $n2 =~ /^[A-Z]{2}\d{3}$/, "reset name format"
assert_ok $n1 ne $n2, "reset gives a different name"

# Many bots get unique names
var %seen
for val $i (1..50) {
    val $b = Exercism::RobotName::new()
    val $n = Exercism::RobotName::name($b)
    assert_ok !exists $seen{$n}, "robot $i unique"
    $seen{$n} = 1
}

test_run
