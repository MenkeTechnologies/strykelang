#!/usr/bin/env stryke
require "./VariableLengthQuantity.stk"

fn j($a)  { join(",", @{$a}) }
fn jr($a) { my $r = $a; ref($r) eq 'ARRAY' && $r->[0] eq 'ok' ? "ok:" . join(",", @{$r->[1]}) : "error:" . $r->[1] }

assert_eq j(Exercism::VariableLengthQuantity::encode([0])),       "0",         "0 → 1 byte"
assert_eq j(Exercism::VariableLengthQuantity::encode([127])),     "127",       "127 → 1 byte"
assert_eq j(Exercism::VariableLengthQuantity::encode([128])),     "129,0",     "128 → 2 bytes (0x81, 0x00)"
assert_eq j(Exercism::VariableLengthQuantity::encode([0xff])),    "129,127",   "255 → 2 bytes"
assert_eq j(Exercism::VariableLengthQuantity::encode([0x4000])),  "129,128,0", "0x4000 → 3 bytes"
assert_eq j(Exercism::VariableLengthQuantity::encode([1,2,3])),   "1,2,3",     "multi"

assert_eq jr(Exercism::VariableLengthQuantity::decode([0])),         "ok:0",      "decode 0"
assert_eq jr(Exercism::VariableLengthQuantity::decode([127])),       "ok:127",    "decode 127"
assert_eq jr(Exercism::VariableLengthQuantity::decode([129,0])),     "ok:128",    "decode 128"
assert_eq jr(Exercism::VariableLengthQuantity::decode([129,128,0])), "ok:16384",  "decode 0x4000"
assert_eq jr(Exercism::VariableLengthQuantity::decode([0x81])),      "error:incomplete sequence", "incomplete"

test_run
