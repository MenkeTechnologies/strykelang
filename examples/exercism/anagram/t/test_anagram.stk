#!/usr/bin/env stryke
require "./Anagram.stk"

fn jn { join(",", @{Exercism::Anagram::match_anagrams(_, _1)}) }

assert_eq jn("diaper",  ["hello","world","zombies","pants"]),      "",                 "no matches"
assert_eq jn("solemn",  ["lemons","cherry","melons"]),             "lemons,melons",    "detects two anagrams"
assert_eq jn("listen",  ["enlists","google","inlets","banana"]),   "inlets",           "detects multiple anagrams with different case"
assert_eq jn("BANANA",  ["BANANA","Banana","banana"]),             "",                 "does not detect anagram subsets"
assert_eq jn("Orchestra", ["cashregister","Carthorse","radishes"]),"Carthorse",        "anagram is case-insensitive"
assert_eq jn("Orchestra", ["cashregister","carthorse","radishes"]),"carthorse",        "case-insensitive cands"
assert_eq jn("mass",    ["last"]),                                 "",                 "different length is not anagram"
assert_eq jn("Ether",   ["Earthquakes"]),                          "",                 "diff length, share letter"
assert_eq jn("good",    ["dog","goody"]),                          "",                 "no matches with diff length"

test_run
