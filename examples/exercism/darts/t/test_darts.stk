#!/usr/bin/env stryke
require "./Darts.stk"

assert_eq Exercism::Darts::score_dart(-9, 9),     0,  "Missed target"
assert_eq Exercism::Darts::score_dart(0, 10),     1,  "On the outer circle"
assert_eq Exercism::Darts::score_dart(-5, 0),     5,  "On the middle circle"
assert_eq Exercism::Darts::score_dart(0, -1),    10,  "On the inner circle"
assert_eq Exercism::Darts::score_dart(0, 0),     10,  "Exactly on center"
assert_eq Exercism::Darts::score_dart(-0.1, -0.1),10, "Near the center"
assert_eq Exercism::Darts::score_dart(0.7, 0.7), 10,  "Just within the inner circle"
assert_eq Exercism::Darts::score_dart(0.8, -0.8), 5,  "Just outside the inner circle"
assert_eq Exercism::Darts::score_dart(-3.5, 3.5), 5,  "Just within the middle circle"
assert_eq Exercism::Darts::score_dart(-3.6, -3.6),1,  "Just outside the middle circle"
assert_eq Exercism::Darts::score_dart(-7, 7),     1,  "Just within the outer circle"
assert_eq Exercism::Darts::score_dart(7.1, -7.1), 0,  "Just outside the outer circle"
assert_eq Exercism::Darts::score_dart(0.5, -4),   5,  "Asymmetric position between the inner and middle circles"

test_run
