#!/usr/bin/env stryke
require "./Alphametics.stk"

# Unsolvable cases should return undef.
assert_eq Exercism::Alphametics::solve("XX + YY == ZZ"), undef, "no solution → undef"

# Helper sanity.
assert_eq Exercism::Alphametics::_value("ABC", { A => 1, B => 2, C => 3 }), 123, "value 123"
assert_eq Exercism::Alphametics::_value("XY",  { X => 4, Y => 7 }),          47,  "value 47"

test_run
