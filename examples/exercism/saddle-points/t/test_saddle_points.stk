#!/usr/bin/env stryke
require "./SaddlePoints.stk"

fn fmt {
    join("|", map { join(",", @$_) } @{$_[0]})
}

assert_eq fmt(Exercism::SaddlePoints::saddle_points([[9,8,7],[5,3,2],[6,6,7]])), "1,3", "single saddle"
assert_eq fmt(Exercism::SaddlePoints::saddle_points([[1,2,3],[3,1,2],[2,3,1]])), "",    "no saddle"
assert_eq fmt(Exercism::SaddlePoints::saddle_points([[4,5,4],[3,5,5],[1,5,4]])), "1,2|2,2|3,2", "multiple saddle"
assert_eq fmt(Exercism::SaddlePoints::saddle_points([])),                        "",    "empty matrix"

test_run
