#!/usr/bin/env stryke
fn Exercism::SaddlePoints::saddle_points($m) {
    val $rows = 0 + @$m
    return [] if $rows == 0
    val $cols = 0 + @{$m->[0]}
    val @row_max = ~> 0:$rows-1 map { max(@{$m->[_]}) }
    val @col_min = ~> 0:$cols-1 map {
        ~> 0:$rows-1 map { $m->[_][_<] } min
    }
    var @out
    for val $r (0:$rows - 1) {
        ~> 0:$cols - 1 ep {
            push @out, [$r + 1, _ + 1] if $m->[$r][_] == $row_max[$r] && $m->[$r][_] == $col_min[_]
        }
    }
    \@out
}
