#!/usr/bin/env stryke
fn Exercism::Proverb::proverb($items, $qual) {
    return "" unless len(@$items)
    val $tail = length($qual) ? "$qual " : ""
    (~> 0:len(@$items)-2 map { val $cur = $items->[_]; val $nxt = $items->[_ + 1]; "For want of a $cur the $nxt was lost.\n" } join("")) . "And all for the want of a $tail$items->[0]."
}
