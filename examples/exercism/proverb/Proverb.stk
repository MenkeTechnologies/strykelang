#!/usr/bin/env stryke
fn Exercism::Proverb::proverb($items, $qual) {
    return "" unless len(@$items)
    my $tail = length($qual) ? "$qual " : ""
    (~> 0:len(@$items)-2 map { my $cur = $items->[_]; my $nxt = $items->[_ + 1]; "For want of a $cur the $nxt was lost.\n" } |> join("")) . "And all for the want of a $tail$items->[0]."
}
