#!/usr/bin/env stryke
my $dir = __FILE__ =~ s{/t/[^/]+$}{}r
require "$dir/DifferenceOfSquares.stk"

assert_eq Exercism::DifferenceOfSquares::square_of_sum(1),          1,        "square of sum 1"
assert_eq Exercism::DifferenceOfSquares::square_of_sum(5),          225,      "square of sum 5"
assert_eq Exercism::DifferenceOfSquares::square_of_sum(100),        25502500, "square of sum 100"
assert_eq Exercism::DifferenceOfSquares::sum_of_squares(1),         1,        "sum of squares 1"
assert_eq Exercism::DifferenceOfSquares::sum_of_squares(5),         55,       "sum of squares 5"
assert_eq Exercism::DifferenceOfSquares::sum_of_squares(100),       338350,   "sum of squares 100"
assert_eq Exercism::DifferenceOfSquares::difference_of_squares(1),  0,        "difference 1"
assert_eq Exercism::DifferenceOfSquares::difference_of_squares(5),  170,      "difference 5"
assert_eq Exercism::DifferenceOfSquares::difference_of_squares(100), 25164150, "difference 100"

test_run
