#!/usr/bin/env stryke
fn Exercism::DifferenceOfSquares::square_of_sum = sum(1:_) ** 2
fn Exercism::DifferenceOfSquares::sum_of_squares = ~> 1:_ map {_ ** 2} sum
fn Exercism::DifferenceOfSquares::difference_of_squares = Exercism::DifferenceOfSquares::square_of_sum(_) - Exercism::DifferenceOfSquares::sum_of_squares(_)
