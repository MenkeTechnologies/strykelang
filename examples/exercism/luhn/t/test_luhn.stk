#!/usr/bin/env stryke
require "./Luhn.stk"

assert_ok !Exercism::Luhn::is_luhn_valid("1"),                "single digit strings can not be valid"
assert_ok !Exercism::Luhn::is_luhn_valid("0"),                "a single zero is invalid"
assert_ok  Exercism::Luhn::is_luhn_valid("059"),              "a simple valid SIN that remains valid if reversed"
assert_ok  Exercism::Luhn::is_luhn_valid("59"),               "a simple valid SIN that becomes invalid if reversed"
assert_ok  Exercism::Luhn::is_luhn_valid("055 444 285"),      "a valid Canadian SIN"
assert_ok !Exercism::Luhn::is_luhn_valid("055 444 286"),      "invalid Canadian SIN"
assert_ok !Exercism::Luhn::is_luhn_valid("8273 1232 7352 0569"), "invalid credit card"
assert_ok !Exercism::Luhn::is_luhn_valid("1 2345 6789 1234 5678 9012"), "invalid long number with even digits"
assert_ok !Exercism::Luhn::is_luhn_valid("1 2345 6789 1234 5678 9013"), "invalid long number, odd"
assert_ok  Exercism::Luhn::is_luhn_valid("095 245 88"),       "valid number with an even number of digits"
assert_ok  Exercism::Luhn::is_luhn_valid("234 567 891 234"),  "valid strings with a non-digit added at the end is invalid"
assert_ok !Exercism::Luhn::is_luhn_valid("059a"),             "non-numeric chars invalid"
assert_ok !Exercism::Luhn::is_luhn_valid("055-444-285"),      "dashes invalid"
assert_ok !Exercism::Luhn::is_luhn_valid("055# 444\$ 285"),   "punctuation invalid"
assert_ok !Exercism::Luhn::is_luhn_valid(" 0"),               "single zero with space is invalid"
assert_ok  Exercism::Luhn::is_luhn_valid("0000 0"),           "more than a single zero is valid"
assert_ok  Exercism::Luhn::is_luhn_valid("091"),              "input digit 9 correctly converts"
assert_ok  Exercism::Luhn::is_luhn_valid("9999999999 9999999999 9999999999 9999999999"), "very long valid"
assert_ok  Exercism::Luhn::is_luhn_valid("109"),              "valid 109"
assert_ok !Exercism::Luhn::is_luhn_valid("055b 444 285"),     "invalid letter"
assert_ok !Exercism::Luhn::is_luhn_valid(":9"),               "punctuation char"
assert_ok !Exercism::Luhn::is_luhn_valid("59%59"),            "percent in middle"

test_run
