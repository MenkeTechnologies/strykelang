#!/usr/bin/env stryke
fn Exercism::Luhn::is_luhn_valid($s) {
    $s =~ s/\s+//gr |> {
        my $clean = $_
        return 0 unless length($clean) > 1 && $clean =~ /^\d+$/
        my $cnt = 0
        sum(map {
            my $d = $_
            $d = $d * 2 if $cnt++ % 2 == 1
            $d > 9 ? $d - 9 : $d
        } chars(rev $clean)) % 10 == 0 ? 1 : 0
    }
}
