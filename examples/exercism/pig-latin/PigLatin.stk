#!/usr/bin/env stryke
fn Exercism::PigLatin::_trans($w) {
    $w = lc $w
    return "${w}ay" if $w =~ /^([aeiou]|xr|yt)/
    return "$2$1ay" if $w =~ /^([^aeiouy]+)(y.+)/
    return "$2$1ay" if $w =~ /^([^aeiou]*qu)(.+)/
    return "$2$1ay" if $w =~ /^([^aeiou]+)(.+)/
    "${w}ay"
}

fn Exercism::PigLatin::translate($s) { ~> $s split(/\s+/) map { Exercism::PigLatin::_trans } |> join(" ") }
