#!/usr/bin/env stryke
fn Exercism::PigLatin::_trans {
    $w = lc _
    return "${w}ay" if $w =~ /^([aeiou]|xr|yt)/
    return "$2$1ay" if $w =~ /^([^aeiouy]+)(y.+)/
    return "$2$1ay" if $w =~ /^([^aeiou]*qu)(.+)/
    return "$2$1ay" if $w =~ /^([^aeiou]+)(.+)/
    "${w}ay"
}

fn Exercism::PigLatin::translate = ~> _ split(/\s+/) map { Exercism::PigLatin::_trans } join(" ")
