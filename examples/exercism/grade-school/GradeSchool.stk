fn Exercism::GradeSchool::new { { roster => {} } }
fn Exercism::GradeSchool::add($s, $student, $g) {
    $s->{roster}{$student} = $g unless exists $s->{roster}{$student}
    $s
}

fn Exercism::GradeSchool::roster($s, $g) {
    var @gs
    if (defined $g) { @gs = ($g) }
    else { var %seen; @gs = ~> values %{$s->{roster}} sort { _ <=> _1 } fi { !$seen{_}++ } }
    [~> @gs map { [~> keys %{$s->{roster}} fi { $s->{roster}{_} == _< } sort] }]
}
