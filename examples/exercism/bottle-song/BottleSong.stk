#!/usr/bin/env stryke
my @_NUM = ("No","One","Two","Three","Four","Five","Six","Seven","Eight","Nine","Ten")

fn Exercism::BottleSong::_word($n) { $_NUM[$n] // "$n" }

fn Exercism::BottleSong::recite($args) {
    my $start  = $args->{start_bottles}
    my $verses = $args->{take_down} // 1
    my @out
    for my $i (0..$verses - 1) {
        my $n  = $start - $i
        my $b  = $n == 1 ? "bottle"  : "bottles"
        my $nn = $n - 1
        my $bn = $nn == 1 ? "bottle" : "bottles"
        my $line1 = Exercism::BottleSong::_word($n)  . " green $b hanging on the wall,"
        my $line3 = "And if one green bottle should accidentally fall,"
        my $next  = $nn == 0 ? "no green bottles" : Exercism::BottleSong::_word($nn) . " green $bn"
        my $line4 = "There'll be $next hanging on the wall."
        push @out, "$line1\n$line1\n$line3\n$line4"
    }
    join("\n\n", @out)
}
