#!/usr/bin/env stryke
require "./SecretHandshake.stk"

fn jn { join(",", @{Exercism::SecretHandshake::handshake(_0)}) }

assert_eq jn(1),  "wink",                                 "wink for 1"
assert_eq jn(2),  "double blink",                         "double blink for 2"
assert_eq jn(4),  "close your eyes",                      "close your eyes for 4"
assert_eq jn(8),  "jump",                                 "jump for 8"
assert_eq jn(3),  "wink,double blink",                    "combine 1+2"
assert_eq jn(19), "double blink,wink",                    "reverse with 16"
assert_eq jn(15), "wink,double blink,close your eyes,jump", "all four"
assert_eq jn(31), "jump,close your eyes,double blink,wink", "all four reversed"
assert_eq jn(0),  "",                                     "no commands"
assert_eq jn("piggies"), "",                              "non-numeric"

test_run
