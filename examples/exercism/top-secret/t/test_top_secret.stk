#!/usr/bin/env stryke
require "./TopSecret.stk"

assert_eq Exercism::TopSecret::decode_secret_message("def message(a), do: nil"), "m", "1-arg"
assert_eq Exercism::TopSecret::decode_secret_message("def message(a, b), do: nil"), "me", "2-arg"
assert_eq Exercism::TopSecret::decode_secret_message("def hello(a), do: nil\ndef world(b, c), do: nil"), "hwo", "two fns"

test_run
