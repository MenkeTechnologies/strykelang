#!/usr/bin/env stryke
my $dir = __FILE__ =~ s{/t/[^/]+$}{}r
require "$dir/Isogram.stk"

assert_ok  Exercism::Isogram::is_isogram(""),                     "empty string"
assert_ok  Exercism::Isogram::is_isogram("isogram"),              "isogram with only lower case characters"
assert_ok !Exercism::Isogram::is_isogram("eleven"),               "word with one duplicated character"
assert_ok !Exercism::Isogram::is_isogram("zzyzx"),                "word with one duplicated character from the end of the alphabet"
assert_ok  Exercism::Isogram::is_isogram("subdermatoglyphic"),    "longest reported english isogram"
assert_ok !Exercism::Isogram::is_isogram("Alphabet"),             "word with duplicated character in mixed case"
assert_ok !Exercism::Isogram::is_isogram("alphAbet"),             "word with duplicated character in mixed case, lowercase first"
assert_ok  Exercism::Isogram::is_isogram("thumbscrew-japingly"),  "hypothetical isogrammic word with hyphen"
assert_ok !Exercism::Isogram::is_isogram("thumbscrew-jappingly"), "hypothetical word with duplicated character following hyphen"
assert_ok  Exercism::Isogram::is_isogram("six-year-old"),         "isogram with duplicated hyphen"
assert_ok  Exercism::Isogram::is_isogram("Emily Jung Schwartzkopf"), "made-up name that is an isogram"
assert_ok !Exercism::Isogram::is_isogram("accentor"),             "duplicated character in the middle"
assert_ok !Exercism::Isogram::is_isogram("angola"),               "same first and last characters"
assert_ok !Exercism::Isogram::is_isogram("up-to-date"),           "word with duplicated character and with two hyphens"

test_run
