#!/usr/bin/env stryke
my %_AT = map { (chr(97 + $_), chr(122 - $_)) } 0..25

fn Exercism::AtbashCipher::decode_atbash($s) {
    ~> $s lc chars map { /\d/ ? $_ : $_AT{$_} // "" } |> join ""
}

fn Exercism::AtbashCipher::encode_atbash($s) {
    Exercism::AtbashCipher::decode_atbash($s) =~ s/(.{5})(?=.)/$1 /gr
}
