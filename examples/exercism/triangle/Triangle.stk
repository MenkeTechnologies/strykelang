#!/usr/bin/env stryke
fn Exercism::Triangle::kind($x, $y, $z) {
    die "TriangleError" if $x <= 0 || $y <= 0 || $z <= 0
    die "TriangleError" if $x + $y <= $z || $x + $z <= $y || $y + $z <= $x
      $x == $y && $y == $z ? "equilateral"
    : $x == $y || $y == $z || $x == $z ? "isosceles"
    : "scalene"
}
