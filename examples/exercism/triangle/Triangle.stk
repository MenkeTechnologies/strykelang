#!/usr/bin/env stryke
fn Exercism::Triangle::kind($a, $b, $c) {
    die "TriangleError" if $a <= 0 || $b <= 0 || $c <= 0
    die "TriangleError" if $a + $b <= $c || $a + $c <= $b || $b + $c <= $a
      $a == $b && $b == $c ? "equilateral"
    : $a == $b || $b == $c || $a == $c ? "isosceles"
    : "scalene"
}
