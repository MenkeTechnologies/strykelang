#!/usr/bin/env stryke
fn Exercism::ListOps::append    { [@{_}, @{_1}] }
fn Exercism::ListOps::concat    { [map { @{_} } @{_}] }
fn Exercism::ListOps::filter    { var ($f, $l) = @_; [grep $f, @$l] }
fn Exercism::ListOps::list_length { len @{_}  }
fn Exercism::ListOps::map_op    { var ($f, $l) = @_; [map $f, @$l] }
fn Exercism::ListOps::foldl     { var ($f, $l, $init) = @_; var $r = $init; $r = $f($r, _) for @$l; $r }
fn Exercism::ListOps::foldr     { val ($f, $l, $init) = @_; var $r = $init; $r = $f(_, $r) for rev(@$l); $r }
fn Exercism::ListOps::reverse_op { [rev @{_}] }
