#!/usr/bin/env stryke
require "./Dominoes.stk"

fn ok { _->[0] eq "ok" ? 1 : 0 }

assert_eq ok(Exercism::Dominoes::chain([])),                      1, "empty chain"
assert_eq ok(Exercism::Dominoes::chain([[1,1]])),                 1, "single double"
assert_eq ok(Exercism::Dominoes::chain([[1,2],[2,1]])),           1, "two-piece loop"
assert_eq ok(Exercism::Dominoes::chain([[1,2],[3,4]])),           0, "impossible"
assert_eq ok(Exercism::Dominoes::chain([[1,3],[3,1]])),           1, "two-piece reverse"

test_run
