#!/usr/bin/env stryke
require "./PrimeFactors.stk"

fn jn { join(",", @{Exercism::PrimeFactors::factors(_0)}) }

assert_eq jn(1),         "",                "no factors"
assert_eq jn(2),         "2",               "prime number"
assert_eq jn(9),         "3,3",             "square of a prime"
assert_eq jn(8),         "2,2,2",           "cube of a prime"
assert_eq jn(12),        "2,2,3",           "product of primes and non-primes"
assert_eq jn(625),       "5,5,5,5",         "product of primes"
assert_eq jn(93819012551), "11,9539,894119", "factors include a large prime"

test_run
