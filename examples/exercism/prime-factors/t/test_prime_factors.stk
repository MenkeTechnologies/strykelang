#!/usr/bin/env stryke
require "./PrimeFactors.stk"

fn j { join(",", @{Exercism::PrimeFactors::factors(_0)}) }

assert_eq j(1),         "",                "no factors"
assert_eq j(2),         "2",               "prime number"
assert_eq j(9),         "3,3",             "square of a prime"
assert_eq j(8),         "2,2,2",           "cube of a prime"
assert_eq j(12),        "2,2,3",           "product of primes and non-primes"
assert_eq j(625),       "5,5,5,5",         "product of primes"
assert_eq j(93819012551), "11,9539,894119", "factors include a large prime"

test_run
