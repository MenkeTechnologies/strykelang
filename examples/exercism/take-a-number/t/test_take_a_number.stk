#!/usr/bin/env stryke
require "./TakeANumber.stk"

my $m = Exercism::TakeANumber::start()
assert_eq Exercism::TakeANumber::report_state($m), 0, "fresh = 0"

assert_eq Exercism::TakeANumber::take_a_number($m), 1, "first ticket"
assert_eq Exercism::TakeANumber::take_a_number($m), 2, "second ticket"
assert_eq Exercism::TakeANumber::take_a_number($m), 3, "third ticket"
assert_eq Exercism::TakeANumber::report_state($m),  3, "state == 3"

assert_eq Exercism::TakeANumber::stop(),  "stopped", "stop returns label"

test_run
