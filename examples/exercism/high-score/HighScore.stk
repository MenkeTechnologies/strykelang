#!/usr/bin/env stryke

fn Exercism::HighScore::new                                    = {}
fn Exercism::HighScore::add_player($scores, $name, $score)     { my %h = %{$scores}; $h{$name} = $score // 0; \%h }
fn Exercism::HighScore::remove_player($scores, $name)          { my %h = %{$scores}; delete $h{$name};        \%h }
fn Exercism::HighScore::reset_score($scores, $name)            { my %h = %{$scores}; $h{$name} = 0;            \%h }
fn Exercism::HighScore::update_score($scores, $name, $score)   { my %h = %{$scores}; $h{$name} = ($h{$name} // 0) + $score; \%h }
fn Exercism::HighScore::get_players($scores)                   = [sort keys %{$scores}]
