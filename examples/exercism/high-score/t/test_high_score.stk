#!/usr/bin/env stryke
require "./HighScore.stk"

fn jn($a) { join(",", @{$a}) }

val $s0 = Exercism::HighScore::new()
assert_eq scalar(keys %{$s0}), 0, "new is empty"

val $s1 = Exercism::HighScore::add_player($s0, "Alice", 100)
assert_eq $s1->{Alice}, 100, "add_player records score"

val $s2 = Exercism::HighScore::add_player($s1, "Bob")
assert_eq $s2->{Bob}, 0, "add_player default 0"

val $s3 = Exercism::HighScore::update_score($s2, "Alice", 50)
assert_eq $s3->{Alice}, 150, "update_score adds"

val $s4 = Exercism::HighScore::reset_score($s3, "Alice")
assert_eq $s4->{Alice}, 0, "reset_score → 0"

val $s5 = Exercism::HighScore::remove_player($s4, "Bob")
assert_eq exists($s5->{Bob}), 0, "remove_player drops key"

val $s6 = Exercism::HighScore::add_player(Exercism::HighScore::add_player({}, "Bob", 5), "Alice", 10)
assert_eq jn(Exercism::HighScore::get_players($s6)), "Alice,Bob", "get_players sorted"

test_run
