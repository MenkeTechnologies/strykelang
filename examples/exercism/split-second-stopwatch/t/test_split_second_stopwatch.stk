#!/usr/bin/env stryke
require "./SplitSecondStopwatch.stk"

val $sw = Exercism::SplitSecondStopwatch::new()
assert_eq Exercism::SplitSecondStopwatch::state($sw), "ready", "ready"

val $r1 = Exercism::SplitSecondStopwatch::start($sw)
assert_eq Exercism::SplitSecondStopwatch::state($r1), "running", "started"

val $r2 = Exercism::SplitSecondStopwatch::lap($r1)
assert_eq scalar(@{$r2->{laps}}), 1, "one lap"

val $r3 = Exercism::SplitSecondStopwatch::stop($r2)
assert_eq Exercism::SplitSecondStopwatch::state($r3), "stopped", "stopped"

val $r4 = Exercism::SplitSecondStopwatch::reset($r3)
assert_eq Exercism::SplitSecondStopwatch::state($r4), "ready", "reset"

# Errors.
val $e = eval { Exercism::SplitSecondStopwatch::start($r1) }
assert_ok $@ =~ /already running/, "double start errors"

val $e2 = eval { Exercism::SplitSecondStopwatch::stop($sw) }
assert_ok $@ =~ /not running/, "stop unran errors"

test_run
