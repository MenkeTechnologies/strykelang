#!/usr/bin/env stryke
require "./BinarySearch.stk"

assert_eq Exercism::BinarySearch::binary_search([6], 6),                                       0, "single element list, finds first"
assert_eq Exercism::BinarySearch::binary_search([1, 3, 4, 6, 8, 9, 11], 6),                    3, "finds in middle"
assert_eq Exercism::BinarySearch::binary_search([1, 3, 4, 6, 8, 9, 11], 1),                    0, "finds first element"
assert_eq Exercism::BinarySearch::binary_search([1, 3, 4, 6, 8, 9, 11], 11),                   6, "finds last element"
assert_eq Exercism::BinarySearch::binary_search([1, 3, 5, 8, 13, 21, 34, 55, 89, 144], 144),   9, "value at upper bound"
assert_eq Exercism::BinarySearch::binary_search([1, 3, 5, 8, 13, 21, 34, 55, 89, 144], 21),    5, "in larger list"

my $err = eval { Exercism::BinarySearch::binary_search([1,3,5], 2); 0 } || $@
assert_ok $err =~ /value not in array/, "value not present"
$err = eval { Exercism::BinarySearch::binary_search([], 1); 0 } || $@
assert_ok $err =~ /value not in array/, "empty array"

test_run
