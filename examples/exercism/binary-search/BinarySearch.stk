#!/usr/bin/env stryke
fn Exercism::BinarySearch::binary_search($arr, $target) {
    var ($lo, $hi) = (0, len(@$arr) - 1)
    while ($lo <= $hi) {
        val $mid = int(($lo + $hi) / 2)
        return $mid if $arr->[$mid] == $target
        if ($target < $arr->[$mid]) { $hi = $mid - 1 } else { $lo = $mid + 1 }
    }
    die "value not in array"
}
