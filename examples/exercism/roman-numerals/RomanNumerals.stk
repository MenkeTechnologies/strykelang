#!/usr/bin/env stryke
var @_R = ([1000,"M"],[900,"CM"],[500,"D"],[400,"CD"],[100,"C"],[90,"XC"],[50,"L"],[40,"XL"],[10,"X"],[9,"IX"],[5,"V"],[4,"IV"],[1,"I"])

fn Exercism::RomanNumerals::to_roman($n) {
    var $out = ""
    for val $row (@_R) {
        val ($v, $sym) = @$row
        $out .= $sym x int($n / $v)
        $n %= $v
    }
    $out
}
