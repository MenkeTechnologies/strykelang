#!/usr/bin/env stryke
my %_AL = (eggs => 1, peanuts => 2, shellfish => 4, strawberries => 8,
           tomatoes => 16, chocolate => 32, pollen => 64, cats => 128)

fn Exercism::Allergies::allergic_to($item, $score) { $_AL{$item} & $score }

fn Exercism::Allergies::list_allergies($score) {
    [grep { Exercism::Allergies::allergic_to($_, $score) } sort { $_AL{$a} <=> $_AL{$b} } keys %_AL]
}
