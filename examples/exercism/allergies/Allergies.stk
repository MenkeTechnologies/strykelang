#!/usr/bin/env stryke
val %h = (eggs => 1, peanuts => 2, shellfish => 4, strawberries => 8, tomatoes => 16, chocolate => 32, pollen => 64, cats => 128)

fn Exercism::Allergies::allergic_to = $h{_} & _1

fn Exercism::Allergies::list_allergies= [~> %h keys sort { $h{_0} <=> $h{_1} } grep { Exercism::Allergies::allergic_to(_, _<) }]
