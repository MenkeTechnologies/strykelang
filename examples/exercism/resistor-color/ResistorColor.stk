#!/usr/bin/env stryke

const my %COLORS = (
    black  => 0,
    brown  => 1,
    red    => 2,
    orange => 3,
    yellow => 4,
    green  => 5,
    blue   => 6,
    violet => 7,
    grey   => 8,
    white  => 9,
)

fn Exercism::ResistorColor::code   = $COLORS{_}
fn Exercism::ResistorColor::colors = ["black","brown","red","orange","yellow","green","blue","violet","grey","white"]
