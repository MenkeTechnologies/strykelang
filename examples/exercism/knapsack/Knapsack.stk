#!/usr/bin/env stryke
fn Exercism::Knapsack::maximum_value($items, $cap) {
    var @dp = (0) x ($cap + 1)
    for val $it (@$items) {
        val $w = $it->{weight}
        val $v = $it->{value}
        for val $c (rev($w:$cap)) {
            $dp[$c] = max($dp[$c], $dp[$c - $w] + $v)
        }
    }
    $dp[$cap]
}
