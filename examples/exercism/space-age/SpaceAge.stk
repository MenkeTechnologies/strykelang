#!/usr/bin/env stryke
my %_P = (
    mercury => 0.2408467,    venus   => 0.61519726,
    earth   => 1.0,          mars    => 1.8808158,
    jupiter => 11.862615,    saturn  => 29.447498,
    uranus  => 84.016846,    neptune => 164.79132,
)
my $_EARTH_SEC = 31557600.0

fn Exercism::SpaceAge::on_planet($planet, $secs) {
    my $p = $_P{lc $planet}
    die "unknown planet: $planet" unless defined $p
    sprintf("%.2f", $secs / ($_EARTH_SEC * $p)) + 0
}
