#!/usr/bin/env stryke
require "./Markdown.stk"

assert_eq Exercism::Markdown::parse("This is a paragraph"),  "<p>This is a paragraph</p>", "paragraph"
assert_eq Exercism::Markdown::parse("# Header!"),            "<h1>Header!</h1>",           "h1"
assert_eq Exercism::Markdown::parse("## Sub Header"),        "<h2>Sub Header</h2>",        "h2"
assert_eq Exercism::Markdown::parse("###### Tiny"),          "<h6>Tiny</h6>",              "h6"
assert_eq Exercism::Markdown::parse("__hello__"),            "<p><strong>hello</strong></p>", "bold"
assert_eq Exercism::Markdown::parse("_italics_"),            "<p><em>italics</em></p>",    "italic"
assert_eq Exercism::Markdown::parse("__bold__ and _italic_"), "<p><strong>bold</strong> and <em>italic</em></p>", "both"
assert_eq Exercism::Markdown::parse("* item1\n* item2"),     "<ul><li>item1</li><li>item2</li></ul>", "list"
assert_eq Exercism::Markdown::parse("# Header!\n* __Bold Item__\n* _Italic Item_"),
          "<h1>Header!</h1><ul><li><strong>Bold Item</strong></li><li><em>Italic Item</em></li></ul>", "mixed"

test_run
