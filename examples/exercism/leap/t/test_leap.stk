#!/usr/bin/env stryke
require "./Leap.stk"

assert_ok !Exercism::Leap::is_leap_year(2015), "year not divisible by 4 in common year"
assert_ok !Exercism::Leap::is_leap_year(1970), "year divisible by 2, not divisible by 4"
assert_ok  Exercism::Leap::is_leap_year(1996), "year divisible by 4, not divisible by 100"
assert_ok  Exercism::Leap::is_leap_year(1960), "year divisible by 4 and 5"
assert_ok !Exercism::Leap::is_leap_year(2100), "year divisible by 100, not by 400"
assert_ok !Exercism::Leap::is_leap_year(1900), "year divisible by 100 but not by 3"
assert_ok  Exercism::Leap::is_leap_year(2000), "year divisible by 400"
assert_ok  Exercism::Leap::is_leap_year(2400), "year divisible by 400 but not by 125"
assert_ok !Exercism::Leap::is_leap_year(1800), "year divisible by 200, not by 400"

test_run
