#!/usr/bin/env stryke
fn Exercism::Series::slices($args) {
    my $s   = $args->{series}
    my $len = $args->{sliceLength}
    die "slice length cannot be zero"     if $len == 0
    die "slice length cannot be negative" if $len < 0
    die "series cannot be empty"          if $s eq ""
    die "slice length cannot be greater than series length" if $len > length($s)
    [map { substr($s, _, $len) } 0..length($s) - $len]
}
