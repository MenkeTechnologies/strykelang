#!/usr/bin/env stryke
require "./KillerSudokuHelper.stk"

fn jn($a) { join("|", map { join(",", @{$_}) } @{$a}) }

assert_eq jn(Exercism::KillerSudokuHelper::combinations(2, 3)),  "1,2",                "size=2 sum=3"
assert_eq jn(Exercism::KillerSudokuHelper::combinations(2, 5)),  "1,4|2,3",            "size=2 sum=5"
assert_eq jn(Exercism::KillerSudokuHelper::combinations(3, 6)),  "1,2,3",              "size=3 sum=6"
assert_eq jn(Exercism::KillerSudokuHelper::combinations(2, 17)), "8,9",                "size=2 sum=17"
assert_eq jn(Exercism::KillerSudokuHelper::combinations(2, 20)), "",                   "impossible"

val $c = Exercism::KillerSudokuHelper::combinations(3, 12)
val $filt = Exercism::KillerSudokuHelper::filter($c, [5])
var $has_5 = 0
for val $combo (@{$filt}) { for val $d (@{$combo}) { $has_5 = 1 if $d == 5 } }
assert_eq $has_5, 0, "exclude 5 → no 5 in any combo"
var $cnt = 0
for (@{$filt}) { $cnt++ }
assert_ok $cnt > 0, "still finds some combos"

test_run
