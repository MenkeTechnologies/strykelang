#!/usr/bin/env stryke

const my $BILLABLE_DAYS = 22

fn Exercism::FreelancerRates::daily_rate($hourly)                          = $hourly * 8.0
fn Exercism::FreelancerRates::apply_discount($before, $disc)               = $before * (100 - $disc) / 100
fn Exercism::FreelancerRates::monthly_rate($hourly, $disc)                 = ceil(Exercism::FreelancerRates::apply_discount(Exercism::FreelancerRates::daily_rate($hourly), $disc) * $BILLABLE_DAYS)
fn Exercism::FreelancerRates::days_in_budget($budget, $hourly, $disc)     = int($budget / Exercism::FreelancerRates::apply_discount(Exercism::FreelancerRates::daily_rate($hourly), $disc) * 10) / 10
