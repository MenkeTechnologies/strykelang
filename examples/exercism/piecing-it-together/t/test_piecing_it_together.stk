#!/usr/bin/env stryke
require "./JigsawPuzzle.stk"

val $r = Exercism::JigsawPuzzle::fill({ rows => 4, columns => 8 })
assert_eq $r->{pieces},       32, "pieces = 4*8"
assert_eq $r->{aspect_ratio}, 2,  "8/4 = 2"
assert_eq $r->{format},       "landscape", "landscape"
assert_eq $r->{border},       20, "border = 2*4+2*8-4"
assert_eq $r->{inside},       12, "inside = 2*6"

val $sq = Exercism::JigsawPuzzle::fill({ rows => 5, columns => 5 })
assert_eq $sq->{format}, "square", "1:1 square"

val $port = Exercism::JigsawPuzzle::fill({ rows => 6, columns => 3 })
assert_eq $port->{format}, "portrait", "3/6 portrait"

test_run
