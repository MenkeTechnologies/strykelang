#!/usr/bin/env stryke
require "./RpnCalculator.stk"

fn add  = fn ($stack) { val @s = @{$stack}; [@s[0..$#s-2], $s[-2] + $s[-1]] }
fn idiv = fn ($stack) { val @s = @{$stack}; $s[-1] == 0 and die "Cannot divide by 0"; [@s[0..$#s-2], int($s[-2] / $s[-1])] }
fn jok($r) { ref($r) eq 'ARRAY' && $r->[0] eq 'ok' ? "ok:" . join(",", @{$r->[1]}) : ref($r) eq 'ARRAY' ? "error:" . $r->[1] : $r }

assert_eq jok(Exercism::RpnCalculator::calculate([1,2], add())),     "ok:3",      "1+2=3"
assert_eq jok(Exercism::RpnCalculator::calculate([6,0], idiv())),    "error",     "div0 returns error"
assert_eq jok(Exercism::RpnCalculator::calculate([6,2], idiv())),    "ok:3",      "6/2=3"

assert_eq jok(Exercism::RpnCalculator::calculate_verbose([6,0], idiv())), "error:Cannot divide by 0", "verbose includes message"
assert_eq jok(Exercism::RpnCalculator::calculate_verbose([6,2], idiv())), "ok:3", "verbose success"

assert_eq join(",", @{Exercism::RpnCalculator::calculate_bang([2,3], add())}), "5", "bang trusts"

test_run
