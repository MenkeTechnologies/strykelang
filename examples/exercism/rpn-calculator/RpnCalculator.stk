#!/usr/bin/env stryke

fn Exercism::RpnCalculator::calculate_bang = _1(_)

fn Exercism::RpnCalculator::calculate {
    val $r = eval { _1(_) }
    $@ ? "error" : ["ok", $r]
}

fn Exercism::RpnCalculator::calculate_verbose {
    val $r = eval { _1(_) }
    $@ ? ["error", "$@" =~ s/\s+at .*//rs] : ["ok", $r]
}
