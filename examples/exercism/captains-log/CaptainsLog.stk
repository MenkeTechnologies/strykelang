#!/usr/bin/env stryke

const val @CLASSES = qw(D H J K L M N R T Y)

fn Exercism::CaptainsLog::random_planet_class           = $CLASSES[int(rand() * len(@CLASSES))]
fn Exercism::CaptainsLog::random_ship_registry_number   = sprintf("NCC-%d", int(rand() * 9000) + 1000)
fn Exercism::CaptainsLog::random_stardate               = rand() * 1000.0 + 41000.0
fn Exercism::CaptainsLog::format_stardate($s)           = sprintf("%.1f", $s)
