#!/usr/bin/env stryke
fn Exercism::PacmanRules::eat_ghost($power, $touching)              = $power && $touching
fn Exercism::PacmanRules::score($pellet, $dot)                       = $pellet || $dot
fn Exercism::PacmanRules::lose($power, $touching)                    = $touching && !$power
fn Exercism::PacmanRules::win($eaten_all, $power, $touching)         = $eaten_all && !Exercism::PacmanRules::lose($power, $touching)
