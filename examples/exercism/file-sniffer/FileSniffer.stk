#!/usr/bin/env stryke

const val %MIME = (
    exe => "application/octet-stream",
    bmp => "image/bmp",
    png => "image/png",
    jpg => "image/jpg",
    gif => "image/gif",
)

fn Exercism::FileSniffer::type_from_extension($ext) = $MIME{$ext}

fn Exercism::FileSniffer::type_from_binary($bin) =
    $bin =~ /^\x7FELF/                 ? $MIME{exe} :
    $bin =~ /^BM/                      ? $MIME{bmp} :
    $bin =~ /^\x89PNG\x0D\x0A\x1A\x0A/ ? $MIME{png} :
    $bin =~ /^\xFF\xD8\xFF/            ? $MIME{jpg} :
    $bin =~ /^GIF/                     ? $MIME{gif} :
                                       undef

fn Exercism::FileSniffer::verify($binary, $ext) {
    val $t = Exercism::FileSniffer::type_from_binary($binary)
    defined($t) && $t eq Exercism::FileSniffer::type_from_extension($ext)
        ? ["ok", $t]
        : ["error", "Warning, file format and file extension do not match."]
}
