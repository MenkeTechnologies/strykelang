#!/usr/bin/env stryke
val @_KIDS = qw(Alice Bob Charlie David Eve Fred Ginny Harriet Ileana Joseph Kincaid Larry)
val %_PLANT = (G=>"grass", C=>"clover", R=>"radishes", V=>"violets")
val %_POS = map { ($_KIDS[_], _ * 2) } 0:len(@_KIDS) - 1

fn Exercism::KindergartenGarden::plants($diagram, $student) {
    val $p = $_POS{$student}
    [~> $diagram split(/\n/) map { $_PLANT{_[$p]}, $_PLANT{_[$p+1]} }]
}
