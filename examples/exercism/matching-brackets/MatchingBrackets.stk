#!/usr/bin/env stryke
val %_M = ("[" => "]", "(" => ")", "{" => "}")

fn Exercism::MatchingBrackets::has_matching_brackets($s) {
    var @stk
    for val $c (chars($s)) {
        if (exists $_M{$c}) { push @stk, $c }
        elsif ($c =~ /[\])}]/) {
            return 0 unless @stk && $c eq $_M{pop @stk}
        }
    }
    len(@stk) == 0
}
