#!/usr/bin/env stryke
require "./Yacht.stk"

assert_eq Exercism::Yacht::score([5,5,5,5,5], "yacht"),         50, "yacht (all same)"
assert_eq Exercism::Yacht::score([1,3,3,2,5], "yacht"),         0,  "not yacht"
assert_eq Exercism::Yacht::score([1,1,1,3,5], "ones"),          3,  "ones"
assert_eq Exercism::Yacht::score([3,3,1,3,5], "ones"),          1,  "ones single"
assert_eq Exercism::Yacht::score([2,2,2,2,2], "twos"),          10, "twos"
assert_eq Exercism::Yacht::score([1,3,4,5,6], "twos"),          0,  "no twos"
assert_eq Exercism::Yacht::score([3,3,3,3,3], "threes"),        15, "threes"
assert_eq Exercism::Yacht::score([4,5,5,4,5], "fours"),         8,  "fours"
assert_eq Exercism::Yacht::score([5,5,5,5,5], "fives"),         25, "fives"
assert_eq Exercism::Yacht::score([6,6,6,6,6], "sixes"),         30, "sixes"
assert_eq Exercism::Yacht::score([1,1,2,2,2], "full house"),    8,  "full house"
assert_eq Exercism::Yacht::score([1,1,1,2,2], "full house"),    7,  "full house 1s/2s"
assert_eq Exercism::Yacht::score([1,1,1,1,3], "full house"),    0,  "four of a kind no fh"
assert_eq Exercism::Yacht::score([1,1,1,1,3], "four of a kind"),4,  "four of a kind"
assert_eq Exercism::Yacht::score([3,3,3,3,3], "four of a kind"),12, "five matches four"
assert_eq Exercism::Yacht::score([1,2,3,4,5], "little straight"),30, "little straight"
assert_eq Exercism::Yacht::score([2,3,4,5,6], "big straight"),  30, "big straight"
assert_eq Exercism::Yacht::score([1,2,3,4,6], "little straight"),0, "not little"
assert_eq Exercism::Yacht::score([3,3,5,6,6], "choice"),        23, "choice"

test_run
