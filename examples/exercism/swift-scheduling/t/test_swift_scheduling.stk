#!/usr/bin/env stryke
require "./SwiftScheduling.stk"

assert_eq Exercism::SwiftScheduling::delivery_date("2024-01-10T09:00:00", "+ 5 days"),  "2024-01-15T09:00:00", "+5 days"
assert_eq Exercism::SwiftScheduling::delivery_date("2024-01-10T09:00:00", "10 days"),    "2024-01-20T09:00:00", "10 days"
assert_eq Exercism::SwiftScheduling::delivery_date("2024-01-10T09:00:00", "next month"), "2024-02-10T09:00:00", "next month"
assert_eq Exercism::SwiftScheduling::delivery_date("2024-11-10T09:00:00", "+ 3 months"), "2025-02-10T09:00:00", "3 months crosses year"

test_run
