#!/usr/bin/env stryke

# Game state: { rolls => [], finished => bool }.
fn Exercism::Bowling::new = { rolls => [], finished => 0 }

fn Exercism::Bowling::roll {
    var ($g, $p) = (_, _1)
    die "Game is already complete" if $g->{finished}
    die "Negative roll" if $p < 0
    die "Roll exceeds remaining pins" if $p > 10
    val $rolls = [@{$g->{rolls}}, $p]
    val $g2    = { rolls => $rolls, finished => 0 }
    Exercism::Bowling::_check_complete($g2)
    $g2
}

fn Exercism::Bowling::_check_complete {
    val @r = @{_->{rolls}}
    var ($frame, $i) = (0, 0)
    while ($frame < 9 && $i < @r) {
        if ($r[$i] == 10) { $i++ } else { $i += 2 }
        $frame++
    }
    return unless $frame == 9 && $i < @r
    # 10th frame: 2 normal rolls, +1 bonus if strike/spare
    val $remaining = @r - $i
    if ($r[$i] == 10) {
        _->{finished} = 1 if $remaining >= 3
    } elsif ($i + 1 < @r && $r[$i] + $r[$i + 1] == 10) {
        _->{finished} = 1 if $remaining >= 3
    } else {
        _->{finished} = 1 if $remaining >= 2
    }
}

fn Exercism::Bowling::score {
    die "Game is incomplete" unless _->{finished}
    val @r = @{_->{rolls}}
    var $total = 0
    var ($i, $frame) = (0, 0)
    while ($frame < 10) {
        if ($r[$i] == 10) {
            $total += 10 + $r[$i + 1] + $r[$i + 2]
            $i++
        } elsif ($r[$i] + $r[$i + 1] == 10) {
            $total += 10 + $r[$i + 2]
            $i += 2
        } else {
            $total += $r[$i] + $r[$i + 1]
            $i += 2
        }
        $frame++
    }
    $total
}
