#!/usr/bin/env stryke
require "./RpgCharacterSheet.stk"

assert_ok Exercism::RpgCharacterSheet::welcome_message() =~ /Welcome/, "welcome"

val $r = Exercism::RpgCharacterSheet::roll_dice()
assert_ok $r >= 3 && $r <= 18, "roll in valid range"

val $c = Exercism::RpgCharacterSheet::run()
assert_eq $c->{name},      "Hero",   "default name"
assert_eq $c->{class},     "Wizard", "default class"
assert_eq $c->{hitpoints}, 10,       "default hp"

test_run
