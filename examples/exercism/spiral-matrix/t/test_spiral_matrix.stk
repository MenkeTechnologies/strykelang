#!/usr/bin/env stryke
require "./SpiralMatrix.stk"

fn fmt { join("|", map { join(",", @$_) } @{$_[0]}) }

assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(0)),  "",                                              "0x0"
assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(1)),  "1",                                             "1x1"
assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(2)),  "1,2|4,3",                                       "2x2"
assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(3)),  "1,2,3|8,9,4|7,6,5",                             "3x3"
assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(4)),  "1,2,3,4|12,13,14,5|11,16,15,6|10,9,8,7",        "4x4"
assert_eq fmt(Exercism::SpiralMatrix::spiral_matrix(5)),  "1,2,3,4,5|16,17,18,19,6|15,24,25,20,7|14,23,22,21,8|13,12,11,10,9", "5x5"

test_run
