#!/usr/bin/env stryke
require "./OcrNumbers.stk"

assert_eq Exercism::OcrNumbers::convert([
    "    ",
    "  | ",
    "  | ",
    "    ",
]), "1", "one"

assert_eq Exercism::OcrNumbers::convert([
    " _ ",
    " _|",
    "|_ ",
    "   ",
]), "2", "two"

assert_eq Exercism::OcrNumbers::convert([
    " _ ",
    " _|",
    " _|",
    "   ",
]), "3", "three"

assert_eq Exercism::OcrNumbers::convert([
    " _  _ ",
    "  | _|",
    "  ||_ ",
    "      ",
]), "12", "twelve"

assert_eq Exercism::OcrNumbers::convert([
    " _  _  _  _  _  _  _  _  _ ",
    "  ||_|  | _||_| _||_|  ||_|",
    "  ||_|  ||_  _|  | _|  | _|",
    "                           ",
]), "1234567890", "all digits"

# Multiple rows
assert_eq Exercism::OcrNumbers::convert([
    "    ",
    "  | ",
    "  | ",
    "    ",
    " _  ",
    " _| ",
    "|_  ",
    "    ",
]), "1,2", "stacked"

my $err = eval { Exercism::OcrNumbers::convert(["   "]); 0 } || $@
assert_ok $err =~ /multiple of four/, "wrong row count"
$err = eval { Exercism::OcrNumbers::convert(["    ","  ","   ","   "]); 0 } || $@
assert_ok $err =~ /multiple of three/, "wrong col count"

test_run
