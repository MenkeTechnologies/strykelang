#!/usr/bin/env stryke
require "./Matrix.stk"

fn j { join(",", @{$_[0]}) }

my $m = Exercism::Matrix::new("1 2\n10 20")
assert_eq j(Exercism::Matrix::row($m, 1)),    "1,2",   "row 1"
assert_eq j(Exercism::Matrix::row($m, 2)),    "10,20", "row 2"
assert_eq j(Exercism::Matrix::column($m, 1)), "1,10",  "col 1"
assert_eq j(Exercism::Matrix::column($m, 2)), "2,20",  "col 2"

my $b = Exercism::Matrix::new("9 8 7\n19 18 17\n29 28 27\n39 38 37")
assert_eq j(Exercism::Matrix::row($b, 4)),    "39,38,37", "row 4"
assert_eq j(Exercism::Matrix::column($b, 2)), "8,18,28,38", "col 2"

test_run
