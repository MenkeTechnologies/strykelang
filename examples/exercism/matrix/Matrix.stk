#!/usr/bin/env stryke
fn Exercism::Matrix::new = { string => _ }

fn Exercism::Matrix::row($self, $idx) {
    val @rows = split /\n/, $self->{string}
    [split / /, $rows[$idx - 1]]
}

fn Exercism::Matrix::column($self, $idx) {
    val @rows = split /\n/, $self->{string}
    [map { (split / /, _)[$idx - 1] } @rows]
}
