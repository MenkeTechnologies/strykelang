#!/usr/bin/env stryke
fn Exercism::Matrix::new($s) { { string => $s } }

fn Exercism::Matrix::row($self, $idx) {
    my @rows = split /\n/, $self->{string}
    [split / /, $rows[$idx - 1]]
}

fn Exercism::Matrix::column($self, $idx) {
    my @rows = split /\n/, $self->{string}
    [map { (split / /, $_)[$idx - 1] } @rows]
}
