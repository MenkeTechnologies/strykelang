#!/usr/bin/env stryke
require "./PascalsTriangle.stk"

fn fmt { join("|", map { join(",", @$_) } @{$_[0]}) }

assert_eq fmt(Exercism::PascalsTriangle::rows(0)),  "",          "zero rows"
assert_eq fmt(Exercism::PascalsTriangle::rows(1)),  "1",         "one row"
assert_eq fmt(Exercism::PascalsTriangle::rows(2)),  "1|1,1",     "two rows"
assert_eq fmt(Exercism::PascalsTriangle::rows(3)),  "1|1,1|1,2,1", "three rows"
assert_eq fmt(Exercism::PascalsTriangle::rows(4)),  "1|1,1|1,2,1|1,3,3,1", "four rows"
assert_eq fmt(Exercism::PascalsTriangle::rows(5)),  "1|1,1|1,2,1|1,3,3,1|1,4,6,4,1", "five rows"

test_run
