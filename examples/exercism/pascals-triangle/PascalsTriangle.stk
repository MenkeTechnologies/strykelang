#!/usr/bin/env stryke
fn Exercism::PascalsTriangle::rows($n) {
    return [] if $n <= 0
    my @t = ([1])
    for my $i (1..$n - 1) {
        my $prev = $t[-1]
        my @row = (1)
        for my $j (1..$i - 1) { push @row, $prev->[$j - 1] + $prev->[$j] }
        push @row, 1
        push @t, \@row
    }
    \@t
}
