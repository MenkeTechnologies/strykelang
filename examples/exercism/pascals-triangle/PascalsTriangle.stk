#!/usr/bin/env stryke
fn Exercism::PascalsTriangle::rows($n) {
    return [] if $n <= 0
    var @t = ([1])
    for val $i (1:$n - 1) {
        val $prev = $t[-1]
        var @row = (1)
        ~> 1:$i - 1 ep { push @row, $prev->[_ - 1] + $prev->[_] }
        push @row, 1
        push @t, \@row
    }
    \@t
}
