#!/usr/bin/env stryke
require "./Tournament.stk"

val $in = "Allegoric Alaskans;Blithering Badgers;win\n" .
         "Devastating Donkeys;Courageous Californians;draw\n" .
         "Devastating Donkeys;Allegoric Alaskans;win\n" .
         "Courageous Californians;Blithering Badgers;loss\n" .
         "Blithering Badgers;Devastating Donkeys;loss\n" .
         "Allegoric Alaskans;Courageous Californians;win"

val $out = Exercism::Tournament::tally($in)
assert_ok $out =~ /^Team\s+\| MP \|/, "header"
assert_ok $out =~ /Devastating Donkeys\s+\|  3 \|  2 \|  1 \|  0 \|  7/, "Donkeys row"
assert_ok $out =~ /Allegoric Alaskans\s+\|  3 \|  2 \|  0 \|  1 \|  6/, "Alaskans row"
assert_ok $out =~ /Blithering Badgers\s+\|  3 \|  0 \|  0 \|  3 \|  0/, "Badgers row"

assert_eq Exercism::Tournament::tally(""), "Team                           | MP |  W |  D |  L |  P", "empty"

test_run
