#!/usr/bin/env stryke
require "./LucasNumbers.stk"

fn jn($a) { join(",", @{$a}) }

assert_eq jn(Exercism::LucasNumbers::generate(1)), "2",                "length 1"
assert_eq jn(Exercism::LucasNumbers::generate(2)), "2,1",              "length 2"
assert_eq jn(Exercism::LucasNumbers::generate(3)), "2,1,3",            "length 3"
assert_eq jn(Exercism::LucasNumbers::generate(4)), "2,1,3,4",          "length 4"
assert_eq jn(Exercism::LucasNumbers::generate(5)), "2,1,3,4,7",        "length 5"
assert_eq jn(Exercism::LucasNumbers::generate(10)),"2,1,3,4,7,11,18,29,47,76", "length 10"

test_run
