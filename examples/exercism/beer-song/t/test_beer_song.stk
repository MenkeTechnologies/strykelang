#!/usr/bin/env stryke
require "./BeerSong.stk"

assert_eq Exercism::BeerSong::verse(8),
    "8 bottles of beer on the wall, 8 bottles of beer.\nTake one down and pass it around, 7 bottles of beer on the wall.",
    "verse 8"

assert_eq Exercism::BeerSong::verse(2),
    "2 bottles of beer on the wall, 2 bottles of beer.\nTake one down and pass it around, 1 bottle of beer on the wall.",
    "verse 2 — bottle singular at 1"

assert_eq Exercism::BeerSong::verse(1),
    "1 bottle of beer on the wall, 1 bottle of beer.\nTake it down and pass it around, no more bottles of beer on the wall.",
    "verse 1"

assert_eq Exercism::BeerSong::verse(0),
    "No more bottles of beer on the wall, no more bottles of beer.\nGo to the store and buy some more, 99 bottles of beer on the wall.",
    "verse 0"

# Sing two verses
my $two = Exercism::BeerSong::sing({ bottles => 8, verses => 2 })
assert_ok $two =~ /^8 bottles/, "sing two verses starts at 8"
assert_ok $two =~ /7 bottles of beer.*Take one down/s, "sing two verses includes 7"

test_run
