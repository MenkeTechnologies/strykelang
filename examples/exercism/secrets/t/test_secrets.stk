#!/usr/bin/env stryke
require "./Secrets.stk"

my $add5 = Exercism::Secrets::secret_add(5)
assert_eq $add5->(3),   8, "add 5"
assert_eq $add5->(0),   5, "add 5 to 0"

my $sub3 = Exercism::Secrets::secret_subtract(3)
assert_eq $sub3->(10),  7, "subtract 3"

my $times4 = Exercism::Secrets::secret_multiply(4)
assert_eq $times4->(6), 24, "multiply 4"

my $div2 = Exercism::Secrets::secret_divide(2)
assert_eq $div2->(11),  5,  "integer divide 2"

my $and1 = Exercism::Secrets::secret_and(0b1010)
assert_eq $and1->(0b1100), 0b1000, "bitand"

my $xor1 = Exercism::Secrets::secret_xor(0xFF)
assert_eq $xor1->(0x0F), 0xF0, "xor"

my $combined = Exercism::Secrets::secret_combine($add5, $times4)
assert_eq $combined->(3), 32, "combine (3+5)*4"

test_run
