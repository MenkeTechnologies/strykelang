#!/usr/bin/env stryke
fn Exercism::Secrets::secret_add      { my $s = _; fn { _ + $s } }
fn Exercism::Secrets::secret_subtract { my $s = _; fn { _ - $s } }
fn Exercism::Secrets::secret_multiply { my $s = _; fn { _ * $s } }
fn Exercism::Secrets::secret_divide   { my $s = _; fn { int(_ / $s) } }
fn Exercism::Secrets::secret_and      { my $s = _; fn { _ & $s } }
fn Exercism::Secrets::secret_xor      { my $s = _; fn { _ ^ $s } }
fn Exercism::Secrets::secret_combine  { my ($f, $g) = (_, _1); fn { $g->($f->(_)) } }
