#!/usr/bin/env stryke
fn Exercism::Secrets::secret_add($s)             { fn { _ + $s } }
fn Exercism::Secrets::secret_subtract($s)        { fn { _ - $s } }
fn Exercism::Secrets::secret_multiply($s)        { fn { _ * $s } }
fn Exercism::Secrets::secret_divide($s)          { fn { int(_ / $s) } }
fn Exercism::Secrets::secret_and($s)             { fn { _ & $s } }
fn Exercism::Secrets::secret_xor($s)             { fn { _ ^ $s } }
fn Exercism::Secrets::secret_combine($f, $g)     { fn { $g($f(_)) } }
