#!/usr/bin/env stryke
require "./ReverseString.stk"

assert_eq Exercism::ReverseString::str_reverse(""),          "",            "an empty string"
assert_eq Exercism::ReverseString::str_reverse("robot"),     "tobor",       "a word"
assert_eq Exercism::ReverseString::str_reverse("Ramen"),     "nemaR",       "a capitalized word"
assert_eq Exercism::ReverseString::str_reverse("I'm hungry!"), "!yrgnuh m'I","a sentence with punctuation"
assert_eq Exercism::ReverseString::str_reverse("racecar"),   "racecar",     "a palindrome"
assert_eq Exercism::ReverseString::str_reverse("drawer"),    "reward",      "an even-sized word"

test_run
