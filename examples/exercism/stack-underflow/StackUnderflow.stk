#!/usr/bin/env stryke

fn Exercism::StackUnderflow::add { val @s = @{_}; @s < 2 and die "stack underflow"; [@s[0..$#s - 2], $s[-2] + $s[-1]] }
fn Exercism::StackUnderflow::sub { val @s = @{_}; @s < 2 and die "stack underflow"; [@s[0..$#s - 2], $s[-2] - $s[-1]] }
fn Exercism::StackUnderflow::mul { val @s = @{_}; @s < 2 and die "stack underflow"; [@s[0..$#s - 2], $s[-2] * $s[-1]] }

fn Exercism::StackUnderflow::div {
    val @s = @{_}
    @s < 2 and die "stack underflow"
    $s[-1] == 0 and die "division by zero"
    [@s[0..$#s - 2], int($s[-2] / $s[-1])]
}

# Catch underflow and report a friendly message.
fn Exercism::StackUnderflow::safe_div {
    val @s = @{_}
    return "stack underflow"   if @s < 2
    return "division by zero"  if $s[-1] == 0
    [@s[0..$#s - 2], int($s[-2] / $s[-1])]
}
