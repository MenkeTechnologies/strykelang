#!/usr/bin/env stryke

package TP;

varsync $rng = 12345

fn _rand() {
    $rng = ($rng * 1103515245 + 12345) % 2147483648
    $rng
}

fn _node($k) {
    { key => $k, prio => TP::_rand(), left => undef, right => undef }
}

fn _rot_right($t) {
    var $l = $t->{left}
    $t->{left} = $l->{right}
    $l->{right} = $t
    $l
}

fn _rot_left($t) {
    var $r = $t->{right}
    $t->{right} = $r->{left}
    $r->{left} = $t
    $r
}

fn insert($t, $k) {
    return TP::_node($k) if !defined $t
    if ($k < $t->{key}) {
        $t->{left} = TP::insert($t->{left}, $k)
        if ($t->{left}->{prio} < $t->{prio}) {
            return TP::_rot_right($t)
        }
    } elsif ($k > $t->{key}) {
        $t->{right} = TP::insert($t->{right}, $k)
        if ($t->{right}->{prio} < $t->{prio}) {
            return TP::_rot_left($t)
        }
    }
    $t
}

fn contains($t, $k) {
    return 0 if !defined $t
    return 1 if $t->{key} == $k
    return TP::contains($t->{left}, $k) if $k < $t->{key}
    TP::contains($t->{right}, $k)
}

fn _inorder($t, $out) {
    return if !defined $t
    TP::_inorder($t->{left}, $out)
    push @$out, $t->{key}
    TP::_inorder($t->{right}, $out)
}

fn inorder($t) {
    val @out = ()
    TP::_inorder($t, \@out)
    \@out
}

fn size($t) {
    return 0 if !defined $t
    1 + TP::size($t->{left}) + TP::size($t->{right})
}

fn height($t) {
    return 0 if !defined $t
    val $hl = TP::height($t->{left})
    val $hr = TP::height($t->{right})
    1 + ($hl > $hr ? $hl : $hr)
}

fn _check_heap($t) {
    return 1 if !defined $t
    if (defined $t->{left}) {
        return 0 if $t->{left}->{prio} < $t->{prio}
        return 0 if !TP::_check_heap($t->{left})
    }
    if (defined $t->{right}) {
        return 0 if $t->{right}->{prio} < $t->{prio}
        return 0 if !TP::_check_heap($t->{right})
    }
    1
}

fn _check_bst($t, $lo, $hi) {
    return 1 if !defined $t
    return 0 if defined $lo && $t->{key} <= $lo
    return 0 if defined $hi && $t->{key} >= $hi
    return 0 if !TP::_check_bst($t->{left}, $lo, $t->{key})
    TP::_check_bst($t->{right}, $t->{key}, $hi)
}

package main;

# Empty treap
val $t0 = undef
TP::size($t0) |> aeq 0, "empty size"
TP::height($t0) |> aeq 0, "empty height"
TP::contains($t0, 5) |> aeq 0, "empty contains"
len(@{TP::inorder($t0)}) |> aeq 0, "empty inorder len"
TP::_check_heap($t0) |> aeq 1, "empty heap-ordered"

# Single insertion
val $t1 = TP::insert(undef, 42)
TP::size($t1) |> aeq 1, "single size"
TP::height($t1) |> aeq 1, "single height"
TP::contains($t1, 42) |> aeq 1, "single contains"
TP::contains($t1, 41) |> aeq 0, "single no neighbor"
join(",", @{TP::inorder($t1)}) |> aeq "42", "single inorder"

# Multiple insertions: sorted inorder, no dups
var $t = undef
for val $k (5, 2, 8, 1, 7, 3, 9, 4, 6) {
    $t = TP::insert($t, $k)
}
TP::size($t) |> aeq 9, "size after 9"
join(",", @{TP::inorder($t)}) |> aeq "1,2,3,4,5,6,7,8,9", "inorder sorted"
TP::_check_heap($t) |> aeq 1, "heap-ordered after 9"
TP::_check_bst($t, undef, undef) |> aeq 1, "BST property after 9"

# Contains
for val $k (1, 2, 3, 4, 5, 6, 7, 8, 9) {
    TP::contains($t, $k) |> aeq 1, "contains " . $k
}
TP::contains($t, 0) |> aeq 0, "missing 0"
TP::contains($t, 10) |> aeq 0, "missing 10"
TP::contains($t, 100) |> aeq 0, "missing 100"

# Duplicate insertions are no-ops on key
var $td = $t
val $size_before = TP::size($td)
$td = TP::insert($td, 5)
$td = TP::insert($td, 7)
TP::size($td) |> aeq $size_before, "dup insert no-op size"
join(",", @{TP::inorder($td)}) |> aeq "1,2,3,4,5,6,7,8,9", "dup insert no-op order"

# Ascending insertions would force linear BST but treap should balance
var $ta = undef
for val $i (1:30) { $ta = TP::insert($ta, $i) }
TP::size($ta) |> aeq 30, "ascending size 30"
TP::_check_heap($ta) |> aeq 1, "ascending heap-ordered"
TP::_check_bst($ta, undef, undef) |> aeq 1, "ascending BST"
# Height should be much less than 30 (linear chain)
(TP::height($ta) < 30) |> aeq 1, "ascending not linear"
(TP::height($ta) < 20) |> aeq 1, "ascending sub-linear"

# Descending insertions
var $tdc = undef
for val $i (30:1:-1) { $tdc = TP::insert($tdc, $i) }
TP::size($tdc) |> aeq 30, "descending size 30"
TP::_check_heap($tdc) |> aeq 1, "descending heap-ordered"
TP::_check_bst($tdc, undef, undef) |> aeq 1, "descending BST"
(TP::height($tdc) < 30) |> aeq 1, "descending not linear"

# Stress: insert 100 random-ish keys, all properties hold, inorder sorted
var $ts = undef
var $seed = 99
var %seen = ()
for val $i (1:200) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    val $k = $seed % 500
    if (!exists $seen{$k}) {
        $seen{$k} = 1
        $ts = TP::insert($ts, $k)
    }
}
val $sz = TP::size($ts)
$sz |> aeq len(keys %seen), "stress size matches"
TP::_check_heap($ts) |> aeq 1, "stress heap-ordered"
TP::_check_bst($ts, undef, undef) |> aeq 1, "stress BST"

# Inorder sorted
val $io = TP::inorder($ts)
var $sorted = 1
for val $i (0:len(@$io)-2) {
    $sorted = 0 if $io->[$i] >= $io->[$i + 1]
}
$sorted |> aeq 1, "stress inorder strictly sorted"

# Height stays sub-linear (much less than size)
(TP::height($ts) < $sz / 2) |> aeq 1, "stress balanced height"

test_run
