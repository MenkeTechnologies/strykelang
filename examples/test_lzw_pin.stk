#!/usr/bin/env stryke

package LZW

fn compress($uncompressed) {
    var $dict_size = 256
    var %dictionary
    for val $i (0:255) { $dictionary{chr($i)} = $i }

    var $w = ""
    var @result
    val $n = len $uncompressed
    for val $i (0:$n-1) {
        val $c = $uncompressed[$i]
        val $wc = $w . $c
        if (exists $dictionary{$wc}) {
            $w = $wc
        } else {
            push @result, $dictionary{$w}
            $dictionary{$wc} = $dict_size++
            $w = $c
        }
    }
    push @result, $dictionary{$w} if $w ne ""
    \@result
}

fn decompress($compressed) {
    var $dict_size = 256
    var %dictionary
    for val $i (0:255) { $dictionary{$i} = chr($i) }

    var $w = chr($compressed->[0])
    var $result = $w
    val $n = len @$compressed
    for val $i (1:$n-1) {
        val $k = $compressed->[$i]
        var $entry = ""
        if (exists $dictionary{$k}) {
            $entry = $dictionary{$k}
        } elsif ($k == $dict_size) {
            $entry = $w . $w[0]
        } else {
            die "Bad compressed k: #{$k}"
        }
        
        $result = $result . $entry
        $dictionary{$dict_size++} = $w . $entry[0]
        $w = $entry
    }
    $result
}

package main

val $msg = "TOBEORNOTTOBEORTOBEORNOT"
val $comp = LZW::compress($msg)
val $decomp = LZW::decompress($comp)
$decomp |> aeq $msg, "LZW roundtrip"

val $msg2 = "A" x 100
val $comp2 = LZW::compress($msg2)
val $decomp2 = LZW::decompress($comp2)
$decomp2 |> aeq $msg2, "LZW roundtrip 100 As"

test_run
