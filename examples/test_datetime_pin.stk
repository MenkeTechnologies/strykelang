#!/usr/bin/env stryke

# Date / time utilities. Custom-built calendars (avoid stdlib date parsing).

# Days in each month (non-leap)
val @days_in_month = (31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31)

fn Date::is_leap = (_ % 400 == 0) || (_ % 4 == 0 && _ % 100 != 0) ? 1 : 0

Date::is_leap(2000) |> aok "2000 leap"
Date::is_leap(2004) |> aok "2004 leap"
Date::is_leap(2024) |> aok "2024 leap"
Date::is_leap(2100) |> aeq 0, "2100 not leap"
Date::is_leap(1900) |> aeq 0, "1900 not leap"
Date::is_leap(2023) |> aeq 0, "2023 not leap"

fn Date::days_in_month($y, $m) {
    return 29 if $m == 2 && Date::is_leap($y)
    $days_in_month[$m - 1]
}

Date::days_in_month(2024, 2) |> aeq 29, "feb 2024"
Date::days_in_month(2023, 2) |> aeq 28, "feb 2023"
Date::days_in_month(2024, 4) |> aeq 30, "apr 30"
Date::days_in_month(2024, 7) |> aeq 31, "jul 31"

# Days since 1970-01-01 (epoch)
fn Date::to_days($y, $m, $d) {
    var $days = 0
    for val $yr (1970 : $y - 1) {
        $days += Date::is_leap($yr) ? 366 : 365
    }
    for val $mo (1 : $m - 1) {
        $days += Date::days_in_month($y, $mo)
    }
    $days + $d - 1
}

Date::to_days(1970, 1, 1)  |> aeq 0,    "epoch day 0"
Date::to_days(1970, 1, 2)  |> aeq 1,    "epoch day 1"
Date::to_days(1971, 1, 1)  |> aeq 365,  "year 1"
Date::to_days(1972, 1, 1)  |> aeq 730,  "year 2 non-leap before"
Date::to_days(1973, 1, 1)  |> aeq 1096, "year 3 after 1972 leap"
Date::to_days(2000, 1, 1)  |> aeq 10957, "y2k"

# Day-of-week — 1970-01-01 was a Thursday (4 if Sun=0)
fn Date::dow($y, $m, $d) {
    (4 + Date::to_days($y, $m, $d)) % 7
}

Date::dow(1970, 1, 1)  |> aeq 4, "1970-01-01 Thu"
Date::dow(2000, 1, 1)  |> aeq 6, "2000-01-01 Sat"
Date::dow(2024, 1, 1)  |> aeq 1, "2024-01-01 Mon"
Date::dow(2024, 12, 25) |> aeq 3, "2024-12-25 Wed"
Date::dow(2025, 1, 1)  |> aeq 3, "2025-01-01 Wed"

# Add days to a date
fn Date::add_days($y, $m, $d, $n) {
    var $total = Date::to_days($y, $m, $d) + $n
    var $year = 1970
    while (1) {
        val $yd = Date::is_leap($year) ? 366 : 365
        last if $total < $yd
        $total -= $yd
        $year++
    }
    var $mo = 1
    while (1) {
        val $md = Date::days_in_month($year, $mo)
        last if $total < $md
        $total -= $md
        $mo++
    }
    [$year, $mo, $total + 1]
}

fn Date::fmt = sprintf("%04d-%02d-%02d", _, _1, _2)

val $d = Date::add_days(2024, 1, 1, 31)
Date::fmt(@$d) |> aeq "2024-02-01", "add 31 days"

val $d2 = Date::add_days(2024, 2, 28, 1)
Date::fmt(@$d2) |> aeq "2024-02-29", "2024 leap +1"

val $d3 = Date::add_days(2023, 2, 28, 1)
Date::fmt(@$d3) |> aeq "2023-03-01", "2023 non-leap +1"

val $d4 = Date::add_days(2024, 12, 31, 1)
Date::fmt(@$d4) |> aeq "2025-01-01", "year roll +1"

val $d5 = Date::add_days(2024, 1, 1, 365)
Date::fmt(@$d5) |> aeq "2024-12-31", "leap year 365"

val $d6 = Date::add_days(2024, 1, 1, 366)
Date::fmt(@$d6) |> aeq "2025-01-01", "leap year 366"

# Diff in days
fn Date::diff = Date::to_days(_->[0], _->[1], _->[2]) -
                Date::to_days(_1->[0], _1->[1], _1->[2])

Date::diff([2024, 12, 31], [2024, 1, 1]) |> aeq 365, "2024 has 366 days but 365 diffs"
Date::diff([2024, 1, 1], [2024, 1, 1])    |> aeq 0,   "same day"
Date::diff([2024, 2, 1], [2024, 1, 1])    |> aeq 31,  "jan to feb"

# Day name
val @day_names = ("Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat")
fn Date::day_name = $day_names[Date::dow(_, _1, _2)]

Date::day_name(2024, 1, 1)  |> aeq "Mon", "Mon name"
Date::day_name(2024, 12, 25) |> aeq "Wed", "Wed name"

# Quarter
fn Date::quarter = int((_1 - 1) / 3) + 1

Date::quarter(2024, 1)  |> aeq 1, "Q1"
Date::quarter(2024, 4)  |> aeq 2, "Q2"
Date::quarter(2024, 8)  |> aeq 3, "Q3"
Date::quarter(2024, 12) |> aeq 4, "Q4"

# Year fraction (approx)
fn Date::year_fraction($y, $m, $d) {
    val $year_len = Date::is_leap($y) ? 366 : 365
    val $start = Date::to_days($y, 1, 1)
    val $cur   = Date::to_days($y, $m, $d)
    ($cur - $start) / $year_len
}

abs(Date::year_fraction(2024, 7, 1) - 0.499) < 0.01 |> aok "mid-year"
Date::year_fraction(2024, 1, 1) |> aeq 0, "jan 1 = 0"

test_run
