#!/usr/bin/env stryke
# Run: stryke --no-interop examples/network_utilities.stk

p "--- Net ---"
val $i = "192.168.1.1"
p "IP: $i (Pri: #{ ip_is_private($i) })"

val $net = "192.168.1.0/24"
ip_in_cidr "192.168.1.50", $net |> aok "in"

var @s = @{ ip_sort qw(10.0.0.5 8.8.8.8) }
val $first = shift @s
$first |> aeq "8.8.8.8", "sort"
test_run
