#!/usr/bin/env stryke

# hopcroft_karp_no_interop.stk — Maximum Bipartite Matching.
#
# Finds the maximum matching in a bipartite graph in O(E * sqrt(V)) time.
#
# Run: stryke --no-interop examples/hopcroft_karp_no_interop.stk

package HopcroftKarp

fn bfs($u_size, $adj, $pair_u, $pair_v, $dist) {
    var @queue
    for (var $u = 1; $u <= $u_size; $u++) {
        if ($pair_u->[$u] == 0) {
            $dist->[$u] = 0
            push @queue, $u
        } else {
            $dist->[$u] = 1000000000 # Infinity
        }
    }
    
    $dist->[0] = 1000000000
    
    var $head = 0
    while ($head < len @queue) {
        val $u = $queue[$head++]
        if ($dist->[$u] < $dist->[0]) {
            val $u_adj = $adj->[$u] // []
            for val $v (@$u_adj) {
                val $u_next = $pair_v->[$v]
                if ($dist->[$u_next] == 1000000000) {
                    $dist->[$u_next] = $dist->[$u] + 1
                    push @queue, $u_next
                }
            }
        }
    }
    
    return $dist->[0] != 1000000000
}

fn dfs($u, $adj, $pair_u, $pair_v, $dist) {
    if ($u != 0) {
        val $u_adj = $adj->[$u] // []
        for val $v (@$u_adj) {
            val $u_next = $pair_v->[$v]
            if ($dist->[$u_next] == $dist->[$u] + 1) {
                if (HopcroftKarp::dfs($u_next, $adj, $pair_u, $pair_v, $dist)) {
                    $pair_v->[$v] = $u
                    $pair_u->[$u] = $v
                    return 1
                }
            }
        }
        $dist->[$u] = 1000000000
        return 0
    }
    1
}

fn solve($u_size, $v_size, $adj) {
    # 1-based indexing for vertices. 0 represents NIL (unmatched).
    val @pair_u = (0) x ($u_size + 1)
    val @pair_v = (0) x ($v_size + 1)
    val @dist   = (0) x ($u_size + 1)
    
    var $matching = 0
    
    while (HopcroftKarp::bfs($u_size, $adj, \@pair_u, \@pair_v, \@dist)) {
        for (var $u = 1; $u <= $u_size; $u++) {
            if ($pair_u[$u] == 0) {
                if (HopcroftKarp::dfs($u, $adj, \@pair_u, \@pair_v, \@dist)) {
                    $matching++
                }
            }
        }
    }
    
    { count => $matching, pair_u => \@pair_u, pair_v => \@pair_v }
}

package main

p "── Hopcroft-Karp Demo ──"

# U = {1, 2, 3, 4}, V = {1, 2, 3, 4}
# Edges: (1, 2), (1, 3), (2, 1), (3, 2), (4, 2), (4, 4)
val $adj = [
    [],        # 0 (NIL)
    [2, 3],    # U1 connects to V2, V3
    [1],       # U2 connects to V1
    [2],       # U3 connects to V2
    [2, 4]     # U4 connects to V2, V4
]

val $u_size = 4
val $v_size = 4

val $res = HopcroftKarp::solve($u_size, $v_size, $adj)

p "Maximum Bipartite Matching: #{$res->{count}}"
for (var $u = 1; $u <= $u_size; $u++) {
    val $v = $res->{pair_u}->[$u]
    if ($v != 0) {
        p "  U#{$u} -> V#{$v}"
    }
}

p "Done."
