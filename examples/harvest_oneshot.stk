#!/usr/bin/env stryke
#
# harvest one-shot — the most ergonomic scatter-gather shape. One call
# replaces the `pray + annex` pair when you don't need to inspect the
# divination handle in between.
#
# Compare:
#   long form:   val $div = pray $code, @workers; val %r = annex $div
#   harvest:     val %r = harvest $code, @workers
#
# CI-safe: pure loopback fork, no network. Clean under --no-interop.

p "── harvest: one-shot scatter+gather ──"

val @workers = congregation(3)
printf "spawned %d workers\n", len(@workers)

# Each worker computes the sum of 1..1000 and returns it. Same compute
# on every worker so we can verify identical answers.
val %results = harvest "var \$s = 0; for var \$i (1:1000) { \$s += \$i } \$s", @workers, 5_000

p "── per-worker results ──"
for val $sid (sort { _ <=> _1 } keys %results) {
    printf "  worker %d: %s\n", $sid, $results{$sid}
}

# Sanity: sum 1..1000 = 500500.
val $expected = 500_500
var $all_match = 1
for val $sid (keys %results) {
    $all_match = 0 unless $results{$sid} eq "$expected"
}
p $all_match ? "✓ all 3 workers returned $expected (= 1000*1001/2)" : "✗ workers diverged"

# Custom timeout — harvest's optional last-arg integer >= 100 is a timeout.
val %fast = harvest "42", @workers, 1_000
printf "fast harvest with 1s timeout: %d workers replied\n", len(keys %fast)

excommunicate(@workers)
p "done"
