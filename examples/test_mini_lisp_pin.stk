#!/usr/bin/env stryke

package Lisp

fn tokenize($code) {
    my $c = $code
    $c =~ s/\(/ ( /g; $c =~ s/\)/ ) /g
    my @tokens = split /\s+/, $c
    my @clean = grep { len(_) > 0 } @tokens
    \@clean
}

fn parse($tokens) {
    return undef if !@$tokens
    my $token = shift @$tokens
    if ($token eq "(") {
        my @list
        while (@$tokens && $tokens->[0] ne ")") { push @list, parse($tokens) }
        shift @$tokens if @$tokens && $tokens->[0] eq ")"
        \@list
    } else {
        if ($token =~ /^-?\d+$/) { return int($token) }
        $token
    }
}

fn new_env($outer) { { vars => {}, outer => $outer } }
fn env_find($env, $var) {
    if (exists $env->{vars}->{$var}) { return $env }
    return undef if !defined $env->{outer}
    env_find $env->{outer}, $var
}

fn eval_v($x, $env) {
    if (ref($x) eq "") {
        if ($x =~ /^-?\d+$/) { return $x }
        my $found = env_find $env, $x
        return undef if !defined $found
        return $found->{vars}->{$x}
    }
    return $x if ref($x) ne "ARRAY"
    my @list = @$x
    return [] if !@list
    my $op = $list[0]
    if ($op eq "define") {
        my $val = eval_v($list[2], $env)
        $env->{vars}->{$list[1]} = $val
        return $val
    }
    if ($op eq "if") {
        my $cond = eval_v $list[1], $env
        return eval_v(($cond ? $list[2] : $list[3]), $env)
    }
    if ($op eq "fn") { return { params => $list[1], body => $list[2], env => $env } }
    my $proc = eval_v $op, $env
    my @args; for my $i (1 : (len @list) - 1) { push @args, eval_v($list[$i], $env) }
    if (ref($proc) eq "HASH") {
        my $new_e = new_env $proc->{env}
        my @p = @{$proc->{params}}
        for my $i (0 : (len @p) - 1) { $new_e->{vars}->{$p[$i]} = $args[$i] }
        return eval_v $proc->{body}, $new_e
    } else { return $proc->(@args) }
}

fn setup_env($env) {
    $env->{vars}->{"+"} = fn { my $s = 0; for (@_) { $s = $s + _ } $s }
    $env->{vars}->{"-"} = fn { _ - _1 }
    $env->{vars}->{"*"} = fn { my $p = 1; for (@_) { $p = $p * _ } $p }
    $env->{vars}->{"="} = fn { _ == _1 ? 1 : 0 }
    $env->{vars}->{">"} = fn { _ > _1 ? 1 : 0 }
}

package main

# --- Basic E2E ---
my $env = Lisp::new_env undef
Lisp::setup_env $env

fn lisp_run_test($code, $e) {
    my $tokens = Lisp::tokenize $code
    my $ast = Lisp::parse $tokens
    Lisp::eval_v $ast, $e
}

lisp_run_test("(define x 5)", $env) |> aeq 5, "define x"
lisp_run_test("(+ x 10)", $env)    |> aeq 15, "x + 10 = 15"
lisp_run_test("(if (= x 5) 1 0)", $env) |> aeq 1, "if x==5"

# --- Recursion ---
lisp_run_test("(define fact (fn (n) (if (= n 0) 1 (* n (fact (- n 1))))))", $env)
lisp_run_test("(fact 5)", $env) |> aeq 120, "factorial 5 = 120"

# --- Scoping ---
lisp_run_test("(define make-add (fn (n) (fn (x) (+ x n))))", $env)
lisp_run_test("(define add5 (make-add 5))", $env)
lisp_run_test("(add5 10)", $env) |> aeq 15, "closure capture"

test_run
