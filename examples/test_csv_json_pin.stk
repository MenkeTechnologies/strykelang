#!/usr/bin/env stryke

# CSV parsing & writing (quote-aware) + JSON roundtrip via builtins.

fn Csv::parse_line($line) {
    var @out
    var $cur = ""
    var $in_quote = 0
    val @chars = split(//, $line)
    var $i = 0
    while ($i < len(@chars)) {
        val $c = $chars[$i]
        if ($in_quote) {
            if ($c eq '"') {
                if ($i + 1 < len(@chars) && $chars[$i + 1] eq '"') {
                    $cur .= '"'
                    $i += 2
                    next
                }
                $in_quote = 0
                $i++
                next
            }
            $cur .= $c
            $i++
        } else {
            if ($c eq ',') {
                push @out, $cur
                $cur = ""
                $i++
                next
            }
            if ($c eq '"') {
                $in_quote = 1
                $i++
                next
            }
            $cur .= $c
            $i++
        }
    }
    push @out, $cur
    \@out
}

fn Csv::parse($text) {
    var @rows
    for val $line (split(/\n/, $text)) {
        next if $line eq ""
        push @rows, Csv::parse_line($line)
    }
    \@rows
}

fn Csv::quote($v) {
    if ($v =~ /[",\n]/) {
        var $q = $v
        $q =~ s/"/""/g
        qq("$q")
    } else {
        $v
    }
}

fn Csv::write_row($cells) {
    join(",", map { Csv::quote(_) } @$cells)
}

fn Csv::write($rows) {
    join("\n", map { Csv::write_row(_) } @$rows)
}

# Simple unquoted parsing
val $r1 = Csv::parse_line("a,b,c,d")
join("|", @$r1) |> aeq "a|b|c|d", "plain 4 cols"

# Quoted fields with comma
val $r2 = Csv::parse_line('hello,"wo,rld",end')
join("|", @$r2) |> aeq "hello|wo,rld|end", "quoted comma"

# Embedded double-quote
val $r3 = Csv::parse_line('a,"say ""hi""",b')
join("|", @$r3) |> aeq 'a|say "hi"|b', "embedded quote"

# Empty cells
val $r4 = Csv::parse_line("a,,c,")
join("|", @$r4) |> aeq "a||c|", "empty cells"

# Multi-line parse
val $rows = Csv::parse("name,age\nAlice,30\nBob,25\n")
len(@$rows)         |> aeq 3, "3 rows"
$rows->[0][0]       |> aeq "name", "header name"
$rows->[1][1]       |> aeq "30",   "Alice age"
$rows->[2][0]       |> aeq "Bob",  "Bob name"

# Roundtrip
val $orig = [
    ["name", "city"],
    ["Alice", "NYC"],
    ["Bob", "San Francisco, CA"],
    ['Eve', q(O'Hare, "the airport")],
]
val $serialized = Csv::write($orig)
val $parsed = Csv::parse($serialized)
len(@$parsed)        |> aeq 4, "roundtrip rows"
$parsed->[2][1]      |> aeq "San Francisco, CA", "comma value"
$parsed->[3][1]      |> aeq q(O'Hare, "the airport"), "quote+comma"

# JSON roundtrip via builtins
val $tmp = tempdir()
val $file = "$tmp/data.json"
val %obj = (
    users => [
        +{ id => 1, name => "alice" },
        +{ id => 2, name => "bob"   },
    ],
    count => 2,
    nested => +{ a => +{ b => +{ c => 42 } } },
)
wj($file, \%obj)
val $loaded = rj($file)
$loaded->{count}              |> aeq 2,       "json count"
$loaded->{users}[0]{name}     |> aeq "alice", "json deep array"
$loaded->{nested}{a}{b}{c}    |> aeq 42,      "json deep nested"

test_run
