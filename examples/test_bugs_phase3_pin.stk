#!/usr/bin/env stryke

# Pinning batch Native-L (2026-05-10): Bugs Phase 3 (from BUGS.md 3000-4091)
# Compliance: docs/STYLE_GUIDE.md

# ── AOP Limitations ───────────────────────────────────────────────────────

fn Pin::BugsPhase3::target_args = _
around "Pin::BugsPhase3::target_args" {
    $INTERCEPT_ARGS[0] = "ignored"
    proceed()
}
Pin::BugsPhase3::target_args("world") |> aeq "world", "AOP cannot mutate @INTERCEPT_ARGS"

fn Pin::BugsPhase3::target_compose = 1
around "Pin::BugsPhase3::target_compose" { proceed() + 10 }
around "Pin::BugsPhase3::target_compose" { proceed() * 100 }
Pin::BugsPhase3::target_compose() |> aeq 11, "Multiple around advice do not compose"

# ── RefAddr ───────────────────────────────────────────────────────────────

my @arr_ref = (1, 2)
my $r1 = \@arr_ref
my $r2 = \@arr_ref
refaddr($r1) != refaddr($r2) |> aok "refaddr of repeated backslash-at differs"

# ── BEGIN Mutations ───────────────────────────────────────────────────────

our $log_begin = ""
BEGIN { $main::log_begin .= "B:" }
$log_begin .= "M:"
$log_begin |> aeq "M:", "BEGIN mutations to package vars are lost"

# ── Destructuring Bugs ────────────────────────────────────────────────────

fn Pin::BugsPhase3::test_slurp {
    my ($first, @rest) = @_
    len(@rest)
}
Pin::BugsPhase3::test_slurp(1, 2, 3) |> aeq 2, "my ($s, @rest) = @_ correctly takes tail"

my @items = (10, 20, 30)
my ($x_single) = @items
$x_single |> aeq 10, "my (\$x) = \@arr binds first element (FIXED, was returning count)"

# ── Filehandle Bugs ───────────────────────────────────────────────────────

my $tmp = tempdir()
my $out_file = "$tmp/out.txt"
open(my $fh_out, ">", $out_file)
printf $fh_out "n=%d", 42
close($fh_out)
(-s $out_file) |> aeq 0, "printf $fh writes to STDOUT"

open(my $fh_in, "<", $out_file)
eof($fh_in) |> maps { !_ } |> aok "eof on empty file is false"
close($fh_in)

# ── Parallel Source (BUG-108) ──────────────────────────────────────────────

my @source_list = (10, 20, 30)
# BUG-108 is FIXED: ~p> correctly expands the array source
~p> @source_list sum |> aeq 60, "~p> @array correctly sums elements (fixed bug)"

test_run
