#!/usr/bin/env stryke
# Rosetta Code: Sieve of Eratosthenes

fn my_sieve($limit) {
    my @is_prime
    push @is_prime, 0 for 0..1
    push @is_prime, 1 for 2..$limit
    
    for (my $p = 2; $p * $p <= $limit; $p++) {
        next unless $is_prime[$p]
        for (my $i = $p * $p; $i <= $limit; $i += $p) {
            $is_prime[$i] = 0
        }
    }
    
    my @primes
    for my $i (2..$limit) {
        push @primes, $i if $is_prime[$i]
    }
    @primes
}
