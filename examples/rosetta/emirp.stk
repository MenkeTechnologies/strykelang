#!/usr/bin/env stryke
# Rosetta Code: Emirp Primes

fn is_prime($n) {
    return 0 if $n < 2
    return 1 if $n < 4
    return 0 if $n % 2 == 0
    my $i = 3
    while ($i * $i <= $n) { return 0 if $n % $i == 0; $i += 2 }
    1
}

fn rev($n) { ~> { $n } split // reverse join "" }

fn is_emirp($n) {
    my $r = rev($n)
    is_prime($n) && $r != $n && is_prime($r)
}

p "First 20 emirps:"
~> { 2..1000 } filter { is_emirp } take 20 join ", " p
