#!/usr/bin/env stryke
# Rosetta Code: Concurrent Computing

my $start = el()

my @tasks = (
    async { sleep 0.3; "Task A done" },
    async { sleep 0.1; "Task B done" },
    async { sleep 0.2; "Task C done" }
)

my @results = @tasks |> map { await }
my $elapsed = el() - $start

p "Results: " . join ", ", @results
printf "Elapsed: %.2fs (parallel, not %.1fs sequential)\n", $elapsed, 0.6
