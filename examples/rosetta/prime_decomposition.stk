#!/usr/bin/env stryke
# Rosetta Code: Prime Decomposition

fn factorize($n) {
    my @f
    my $d = 2
    while ($d * $d <= $n) {
        while ($n % $d == 0) { push @f, $d; $n /= $d }
        $d++
    }
    push @f, $n if $n > 1
    @f
}

~> { (12, 100, 1001, 65536) } fore {
    p "$_ = " . (~> { factorize($_) } join " × ")
}
