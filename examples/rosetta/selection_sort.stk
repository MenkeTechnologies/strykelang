#!/usr/bin/env stryke
# Rosetta Code: Selection Sort

fn selection(@a) {
    for my $i (0..$#a-1) {
        my $min = $i
        ~> { $i+1..$#a } fore { $min = $_ if $a[$_] < $a[$min] }
        ($a[$i], $a[$min]) = ($a[$min], $a[$i]) if $min != $i
    }
    @a
}

my @u = (64, 25, 12, 22, 11)
p "Original: " . (~> { @u } join ", ")
p "Sorted:   " . (~> { selection(@u) } join ", ")
