#!/usr/bin/env stryke
# Rosetta Code: Classes

class Animal {
    name;
    fn speak { "Animal sound" }
}

class Dog extends Animal {
    fn speak { "Woof!" }
}

class Cat extends Animal {
    fn speak { "Meow!" }
}

my @animals = (
    Dog(name => "Rex"),
    Cat(name => "Mittens"),
    Animal(name => "Generic")
);

for my $a (@animals) {
    printf "%s says: %s\n", $a->name, $a->speak();
}
