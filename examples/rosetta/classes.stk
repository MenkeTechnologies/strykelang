#!/usr/bin/env stryke
# Rosetta Code: Classes

class Point {
    field x: Int = 0
    field y: Int = 0
    
    method move($dx, $dy) {
        $self->x($self->x + $dx)
        $self->y($self->y + $dy)
        $self
    }
    
    method to_string { "(" . $self->x . ", " . $self->y . ")" }
}

my $p = Point->new(x => 3, y => 4)
p "Initial: " . $p->to_string
$p->move(2, -1)
p "After move(2,-1): " . $p->to_string
