#!/usr/bin/env stryke
# Rosetta Code: Amicable Pairs

fn spd($n) { $n < 2 ? 0 : ~> { 1..int($n/2) } filter { $n % $_ == 0 } sum }

fn amicable($lim) {
    ~> { 2..$lim } map {
        my $b = spd($_)
        $b > $_ && $b <= $lim && spd($b) == $_ ? [$_, $b] : ()
    } grep { @$_ }
}

p "Amicable pairs < 20000:"
~> { amicable(20000) } fore { p "  $_->[0] and $_->[1]" }
