#!/usr/bin/env stryke
# Rosetta Code: Letter Frequency

fn letter_frequency($text) {
    my %freq;
    my @chars = split("", $text);
    for my $c (@chars) {
        if ($c =~ /[a-zA-Z]/) {
            $freq{lc($c)}++;
        }
    }
    return \%freq;
}

my $sample = "The quick brown fox jumps over the lazy dog.";
my $res = letter_frequency($sample);

print "Letter frequencies:\n";
for my $k (sort keys %$res) {
    printf "%s: %d\n", $k, $res->{$k};
}
