#!/usr/bin/env stryke
# Rosetta Code: 99 Bottles of Beer

fn bottles($n) {
    $n == 0 ? "no more bottles" : $n == 1 ? "1 bottle" : "$n bottles"
}

~> { reverse 1..99 } fore {
    p bottles($_) . " of beer on the wall, " . bottles($_) . " of beer."
    p "Take one down, pass it around, " . bottles($_ - 1) . " of beer on the wall.\n"
}
