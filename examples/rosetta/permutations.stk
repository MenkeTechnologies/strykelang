#!/usr/bin/env stryke
# Rosetta Code: Permutations

fn perm(@a) {
    return ([@a]) if @a <= 1
    my @res
    ~> { 0..$#a } fore {
        my @rest = @a
        my $first = splice(@rest, $_, 1)
        ~> { perm(@rest) } fore { push @res, [$first, @$_] }
    }
    @res
}

p "Permutations of (1,2,3):"
~> { perm(1,2,3) } fore { p "  (" . (~> { @$_ } join ", ") . ")" }
