#!/usr/bin/env stryke
# Rosetta Code: Digital Root

fn digit_sum($n) { ~> { $n } split // sum }

fn digital_root($n) {
    my $p = 0
    while ($n >= 10) { $n = digit_sum($n); $p++ }
    ($n, $p)
}

~> { (627615, 39390, 588225) } fore {
    my ($root, $p) = digital_root($_)
    p "$_ → root=$root persistence=$p"
}
