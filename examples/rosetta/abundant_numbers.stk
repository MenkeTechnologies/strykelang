#!/usr/bin/env stryke
# Rosetta Code: Abundant, Deficient, and Perfect Numbers

fn sum_div($n) {
    my $lim = int($n / 2)
    ~> { 1..$lim } filter { $n % $_ == 0 } sum
}

fn classify($n) {
    my $s = sum_div($n)
    $s > $n ? "abundant" : $s < $n ? "deficient" : "perfect"
}

p "Classification 1-20:"
~> { 1..20 } fore { p "$_: " . classify($_) }

p "\nFirst 10 abundant:"
~> { 1..1000 } filter { classify($_) eq "abundant" } take 10 join ", " p
