#!/usr/bin/env stryke
# Rosetta Code: Y Combinator

fn Y($f) {
    my $g = fn ($x) { $f->(fn (@a) { $x->($x)->(@a) }) }
    $g->($g)
}

my $fact = Y(fn ($f) {
    fn ($n) { $n <= 1 ? 1 : $n * $f->($n - 1) }
})

my $fib = Y(fn ($f) {
    fn ($n) { $n <= 1 ? $n : $f->($n - 1) + $f->($n - 2) }
})

p "Factorial via Y combinator:"
0..10 |> fore { p "$_! = " . $fact->($_) }

p "\nFibonacci via Y combinator:"
0..10 |> map { $fib->($_) } |> join ", " |> p
