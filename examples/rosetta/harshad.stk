#!/usr/bin/env stryke
# Rosetta Code: Harshad (Niven) Numbers

fn dsum($n) { ~> { $n } split // sum }
fn is_harshad($n) { $n % dsum($n) == 0 }

p "First 20 Harshad numbers:"
~> { 1..1000 } filter { is_harshad } take 20 join ", " p

p "First Harshad > 1000:"
~> { 1001..2000 } filter { is_harshad } first p
