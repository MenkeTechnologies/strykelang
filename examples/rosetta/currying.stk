#!/usr/bin/env stryke
# Rosetta Code: Currying and Partial Application

fn curry($f) {
    fn ($x) { fn ($y) { $f->($x, $y) } }
}

fn add($x, $y) { $x + $y }
fn mul($x, $y) { $x * $y }

my $add5 = curry(\&add)->(5)
my $mul3 = curry(\&mul)->(3)

p "add5(10) = " . $add5->(10)
p "mul3(7) = " . $mul3->(7)

# Pipeline with partial application
p "Pipeline: " . (10 |> $add5 |> $mul3)
