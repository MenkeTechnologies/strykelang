#!/usr/bin/env stryke
# Rosetta Code: Faces from a mesh

struct Vertex { x, y, z }
struct Face { indices }

fn Rosetta::Mesh::get_cube() {
    my @vertices = (
        Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 1, 0), Vertex(0, 1, 0),
        Vertex(0, 0, 1), Vertex(1, 0, 1), Vertex(1, 1, 1), Vertex(0, 1, 1)
    )
    
    my @faces = (
        Face([0, 1, 2, 3]), # bottom
        Face([4, 5, 6, 7]), # top
        Face([0, 1, 5, 4]), # front
        Face([2, 3, 7, 6]), # back
        Face([0, 3, 7, 4]), # left
        Face([1, 2, 6, 5])  # right
    )
    
    (\@vertices, \@faces)
}

my ($v, $f) = Rosetta::Mesh::get_cube()
assert_eq len(@$v), 8, "Cube has 8 vertices"
assert_eq len(@$f), 6, "Cube has 6 faces"
assert_eq len(@{$f->[0]->{indices}}), 4, "First face has 4 vertices"

test_run
