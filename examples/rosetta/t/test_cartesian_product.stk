#!/usr/bin/env stryke
# Rosetta Code: Cartesian product

fn my_cartesian_product($a_ref, $b_ref) {
    my @res = ()
    for my $x (@$a_ref) {
        for my $y (@$b_ref) {
            push @res, [$x, $y]
        }
    }
    \@res
}

my $p = my_cartesian_product([1, 2], ["a", "b"])
assert_eq scalar(@$p), 4, "2x2 product has 4 elements"
assert_eq $p->[0][0], 1, "first element x"
assert_eq $p->[0][1], "a", "first element y"
assert_eq $p->[3][1], "b", "last element y"

# Verify all combinations
my $joined = ~> @$p map { join("-", @$_) } |> join(",")
assert_eq $joined, "1-a,1-b,2-a,2-b", "all combinations"

test_run
