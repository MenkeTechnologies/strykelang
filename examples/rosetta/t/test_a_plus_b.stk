#!/usr/bin/env stryke
# Rosetta Code: A+B

fn Rosetta::APlusB::add($a, $b) {
    $a + $b
}

fn Rosetta::APlusB::sum_list(@nums) {
    ~> @nums reduce { _0 + _1 }
}

assert_eq Rosetta::APlusB::add(2, 3), 5, "2+3=5"
assert_eq Rosetta::APlusB::add(-5, 10), 5, "-5+10=5"
assert_eq Rosetta::APlusB::add(0, 0), 0, "0+0=0"
assert_eq Rosetta::APlusB::add(1000000, 1), 1000001, "large numbers"

assert_eq Rosetta::APlusB::sum_list(1, 2, 3, 4, 5), 15, "sum 1..5"
assert_eq Rosetta::APlusB::sum_list(10, 20, 30), 60, "sum 10,20,30"

test_run
