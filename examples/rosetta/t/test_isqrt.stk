#!/usr/bin/env stryke
# Rosetta Code: Integer square root (Newton/Heron's method, exact for big ints)

fn Rosetta::ISqrt::compute($n) {
    return 0 if $n == 0
    return 1 if $n < 4
    my $x = int($n / 2)
    my $y = int(($x + int($n / $x)) / 2)
    while ($y < $x) {
        $x = $y
        $y = int(($x + int($n / $x)) / 2)
    }
    $x
}

# Perfect squares
for my $i (0..50) {
    my $sq = $i * $i
    assert_eq Rosetta::ISqrt::compute($sq), $i, "isqrt($sq) = $i"
}

# Non-perfect squares: must be floor(sqrt(n))
my @cases = (
    [2, 1],     [3, 1],
    [5, 2],     [10, 3],
    [99, 9],    [100, 10],   [101, 10],
    [9999, 99], [10000, 100], [10001, 100],
    [123456789, 11111],
    [999999999, 31622]
)
for my $c (@cases) {
    assert_eq Rosetta::ISqrt::compute($c->[0]), $c->[1], "isqrt($c->[0])"
}

# Property: isqrt(n)^2 <= n < (isqrt(n)+1)^2
for my $n (1, 7, 50, 200, 1000, 99999) {
    my $r = Rosetta::ISqrt::compute($n)
    assert_ok $r * $r <= $n,         "$r^2 <= $n"
    assert_ok ($r + 1) * ($r + 1) > $n, "($r+1)^2 > $n"
}

test_run
