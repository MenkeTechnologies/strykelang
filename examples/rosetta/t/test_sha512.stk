#!/usr/bin/env stryke
# Rosetta Code: SHA-512

fn Rosetta::SHA512::compute($s) {
    $s |> sha512()
}

assert_eq Rosetta::SHA512::compute("abc"), "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f", "sha512 abc"

test_run
