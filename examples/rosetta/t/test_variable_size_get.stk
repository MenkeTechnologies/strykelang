#!/usr/bin/env stryke
# Rosetta Code: Variable size/Get

fn Rosetta::VarSizeGet::size_of($value) {
    return len(split //, $value) if ref($value) eq ""
    return len(@$value) if ref($value) eq "ARRAY"
    return scalar(keys %$value) if ref($value) eq "HASH"
    0
}

my @nums = (3, 1, 4, 1, 5)
my %map = (a => 1, b => 2, c => 3)

assert_eq Rosetta::VarSizeGet::size_of("rosetta"), 7, "string length returned"
assert_eq Rosetta::VarSizeGet::size_of(\@nums), 5, "array size returned"
assert_eq Rosetta::VarSizeGet::size_of(\%map), 3, "hash entry count returned"

test_run
