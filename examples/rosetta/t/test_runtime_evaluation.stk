#!/usr/bin/env stryke
# Rosetta Code: Runtime evaluation

fn Rosetta::RuntimeEval::demo() {
    # 1. Simple expression evaluation
    val $code = "2 + 3 * 4"
    val $res1 = eval $code
    assert_eq $res1, 14, "eval simple expression"
    
    # 2. Evaluation in current scope
    val $x = 10
    val $res2 = eval "\$x + 5"
    assert_eq $res2, 15, "eval with local variable"
    
    # 3. Dynamic function definition
    eval "fn Rosetta::RuntimeEval::dynamic_func(\$a) { \$a * 2 }"
    val $res3 = Rosetta::RuntimeEval::dynamic_func(21)
    assert_eq $res3, 42, "eval defines function"
    
    # 4. Error handling in eval
    val $res4 = eval "1 / 0"
    # In Stryke, division by zero might throw or return undef/inf depending on implementation.
    # Let's check $@ if supported, or just verify it doesn't crash the script.
}

Rosetta::RuntimeEval::demo()
test_run
