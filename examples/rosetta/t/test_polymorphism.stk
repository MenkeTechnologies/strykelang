#!/usr/bin/env stryke
# Rosetta Code: Polymorphism
# Method dispatch on a "kind" tag: every shape responds to area() and
# perimeter() but uses its own formula. Demonstrates ad-hoc and
# parametric polymorphism via tagged unions.

fn Rosetta::Poly::area($shape) {
    my $pi = 4 * atan2(1, 1)
    if    ($shape->{kind} eq "circle")    { $pi * $shape->{r} * $shape->{r} }
    elsif ($shape->{kind} eq "rectangle") { $shape->{w} * $shape->{h} }
    elsif ($shape->{kind} eq "triangle")  { 0.5 * $shape->{b} * $shape->{h} }
    elsif ($shape->{kind} eq "square")    { $shape->{s} * $shape->{s} }
    else                                   { undef }
}

fn Rosetta::Poly::perimeter($shape) {
    my $pi = 4 * atan2(1, 1)
    if    ($shape->{kind} eq "circle")    { 2 * $pi * $shape->{r} }
    elsif ($shape->{kind} eq "rectangle") { 2 * ($shape->{w} + $shape->{h}) }
    elsif ($shape->{kind} eq "square")    { 4 * $shape->{s} }
    elsif ($shape->{kind} eq "triangle")  {
        # Equilateral assumed when only base + height supplied.
        $shape->{a} + $shape->{b_side} + $shape->{c_side}
    }
    else                                   { undef }
}

fn Rosetta::Poly::describe($shape) {
    sprintf("%s: area=%.4f, perimeter=%.4f",
        $shape->{kind},
        Rosetta::Poly::area($shape),
        Rosetta::Poly::perimeter($shape))
}

# Circle
my $c = { kind => "circle", r => 5 }
my $pi = 4 * atan2(1, 1)
assert_near Rosetta::Poly::area($c),       $pi * 25, 1e-9, "circle area"
assert_near Rosetta::Poly::perimeter($c),  2 * $pi * 5, 1e-9, "circle perimeter"

# Rectangle
my $r = { kind => "rectangle", w => 3, h => 4 }
assert_eq Rosetta::Poly::area($r),       12, "rectangle area"
assert_eq Rosetta::Poly::perimeter($r),  14, "rectangle perimeter"

# Square
my $sq = { kind => "square", s => 7 }
assert_eq Rosetta::Poly::area($sq),       49, "square area"
assert_eq Rosetta::Poly::perimeter($sq),  28, "square perimeter"

# Triangle
my $t = { kind => "triangle", b => 4, h => 3, a => 3, b_side => 4, c_side => 5 }
assert_eq Rosetta::Poly::area($t),       6,  "3-4-5 triangle area"
assert_eq Rosetta::Poly::perimeter($t),  12, "3-4-5 triangle perimeter"

# Same call site, different dispatch
my @shapes = ($c, $r, $sq, $t)
my @areas = map { Rosetta::Poly::area($_) } @shapes
assert_eq len(@areas), 4, "4 areas computed"

# Unknown kind
my $u = { kind => "blob" }
assert_ok !defined(Rosetta::Poly::area($u)), "unknown kind → undef"

# Pipe form
$c |> Rosetta::Poly::area |> assert_near($pi * 25, 1e-9, "pipe circle area")

test_run
