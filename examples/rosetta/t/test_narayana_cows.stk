#!/usr/bin/env stryke
# Rosetta Code: Narayana's cows sequence

fn Rosetta::NarayanaCows::compute($n) {
    if ($n < 3) {
        1
    } else {
        var $a0 = 1
        var $a1 = 1
        var $a2 = 1
        for val $i (3:$n) {
            val $a3 = $a2 + $a0
            ($a0, $a1, $a2) = ($a1, $a2, $a3)
        }
        $a2
    }
}

assert_eq Rosetta::NarayanaCows::compute(0), 1, "a(0)"
assert_eq Rosetta::NarayanaCows::compute(3), 2, "a(3)"
assert_eq Rosetta::NarayanaCows::compute(4), 3, "a(4)"
assert_eq Rosetta::NarayanaCows::compute(5), 4, "a(5)"
assert_eq Rosetta::NarayanaCows::compute(10), 28, "a(10)"

10 |> Rosetta::NarayanaCows::compute |> assert_eq(28, "pipe narayana")

test_run
