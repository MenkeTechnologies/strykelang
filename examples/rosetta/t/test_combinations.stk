#!/usr/bin/env stryke
# Rosetta Code: Combinations

fn Rosetta::Combinations::generate($k, @arr) {
    my @result
    if ($k == 0) {
        @result = ([])
    } elsif ($k > len(@arr)) {
        @result = ()
    } elsif ($k == len(@arr)) {
        @result = ([@arr])
    } else {
        my $first = shift @arr
        my @with_first = Rosetta::Combinations::generate($k - 1, @arr)
        @with_first = map { [$first, @$_] } @with_first
        
        my @without_first = Rosetta::Combinations::generate($k, @arr)
        
        @result = (@with_first, @without_first)
    }
    @result
}

fn Rosetta::Combinations::count($n, $k) {
    my $result = 1
    for my $i (1..$k) {
        $result = $result * ($n - $i + 1) / $i
    }
    int($result)
}

my @c2 = Rosetta::Combinations::generate(2, 1, 2, 3, 4)
assert_eq len(@c2), 6, "C(4,2) = 6"

my @c3 = Rosetta::Combinations::generate(3, 1, 2, 3, 4, 5)
assert_eq len(@c3), 10, "C(5,3) = 10"

my @c0 = Rosetta::Combinations::generate(0, 1, 2, 3)
assert_eq len(@c0), 1, "C(n,0) = 1"

my @cn = Rosetta::Combinations::generate(3, 1, 2, 3)
assert_eq len(@cn), 1, "C(n,n) = 1"

assert_eq Rosetta::Combinations::count(4, 2), 6, "count C(4,2)"
assert_eq Rosetta::Combinations::count(10, 3), 120, "count C(10,3)"
assert_eq Rosetta::Combinations::count(5, 0), 1, "count C(5,0)"

test_run
