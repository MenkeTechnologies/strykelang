#!/usr/bin/env stryke
# Rosetta Code: Forward-backward algorithm

fn Rosetta::ForwardBackward::solve($obs, $states, $start_p, $trans_p, $emit_p) {
    val $T = len(@$obs)
    var @fwd = ()
    
    # Forward pass
    var %fwd_0
    var $sum_fwd_0 = 0
    for val $s (@$states) {
        $fwd_0{$s} = $start_p->{$s} * $emit_p->{$s}->{$obs->[0]}
        $sum_fwd_0 += $fwd_0{$s}
    }
    # Normalize to prevent underflow
    for val $s (@$states) { $fwd_0{$s} /= $sum_fwd_0 }
    push @fwd, \%fwd_0
    
    for (var $t = 1; $t < $T; $t++) {
        var %fwd_t
        var $sum_fwd_t = 0
        for val $curr_s (@$states) {
            var $sum = 0
            for val $prev_s (@$states) {
                $sum += $fwd[-1]->{$prev_s} * $trans_p->{$prev_s}->{$curr_s}
            }
            $fwd_t{$curr_s} = $sum * $emit_p->{$curr_s}->{$obs->[$t]}
            $sum_fwd_t += $fwd_t{$curr_s}
        }
        for val $s (@$states) { $fwd_t{$s} /= $sum_fwd_t }
        push @fwd, \%fwd_t
    }
    
    # Backward pass
    var @bkw = ()
    # Initialize backward array to same size
    for (var $i = 0; $i < $T; $i++) { push @bkw, {} }
    
    var $sum_bkw_T = 0
    for val $s (@$states) {
        $bkw[$T - 1]->{$s} = 1.0
        $sum_bkw_T += 1.0
    }
    for val $s (@$states) { $bkw[$T - 1]->{$s} /= $sum_bkw_T }
    
    for (var $t = $T - 2; $t >= 0; $t--) {
        var $sum_bkw_t = 0
        for val $curr_s (@$states) {
            var $sum = 0
            for val $next_s (@$states) {
                $sum += $trans_p->{$curr_s}->{$next_s} * $emit_p->{$next_s}->{$obs->[$t+1]} * $bkw[$t+1]->{$next_s}
            }
            $bkw[$t]->{$curr_s} = $sum
            $sum_bkw_t += $sum
        }
        for val $s (@$states) { $bkw[$t]->{$s} /= $sum_bkw_t }
    }
    
    # Posterior probabilities
    var @posterior = ()
    for (var $t = 0; $t < $T; $t++) {
        var %post_t
        var $sum_post = 0
        for val $s (@$states) {
            $post_t{$s} = $fwd[$t]->{$s} * $bkw[$t]->{$s}
            $sum_post += $post_t{$s}
        }
        for val $s (@$states) { $post_t{$s} /= $sum_post }
        push @posterior, \%post_t
    }
    
    \@posterior
}

val @states = ("Rain", "NoRain")
val @obs = ("Umbrella", "Umbrella", "NoUmbrella", "Umbrella", "Umbrella")

val %start_p = ( "Rain" => 0.5, "NoRain" => 0.5 )

val %trans_p = (
    "Rain"   => { "Rain" => 0.7, "NoRain" => 0.3 },
    "NoRain" => { "Rain" => 0.3, "NoRain" => 0.7 }
)

val %emit_p = (
    "Rain"   => { "Umbrella" => 0.9, "NoUmbrella" => 0.1 },
    "NoRain" => { "Umbrella" => 0.2, "NoUmbrella" => 0.8 }
)

val $posteriors = Rosetta::ForwardBackward::solve(\@obs, \@states, \%start_p, \%trans_p, \%emit_p)

# We can check day 1 (index 0), observation Umbrella. Rain should be more likely.
val $day1_rain = $posteriors->[0]->{"Rain"}
assert_ok $day1_rain > 0.5, "Rain more likely on day 1 (saw Umbrella)"

# Day 3 (index 2), observation NoUmbrella. NoRain should be more likely.
val $day3_norain = $posteriors->[2]->{"NoRain"}
assert_ok $day3_norain > 0.5, "NoRain more likely on day 3 (saw NoUmbrella)"

test_run
