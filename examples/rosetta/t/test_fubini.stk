#!/usr/bin/env stryke
# Rosetta Code: Fubini numbers

var %FUBINI_MEMO

fn Rosetta::Fubini::binomial($n, $k) {
    if ($k < 0 || $k > $n) { 0 }
    elsif ($k == 0 || $k == $n) { 1 }
    else {
        var $res = 1
        val $kk = $k < $n - $k ? $k : $n - $k
        for val $i (1:$kk) {
            $res = $res * ($n - $i + 1) / $i
        }
        int($res + 0.5)
    }
}

fn Rosetta::Fubini::compute($n) {
    if ($n == 0) { 1 }
    elsif (exists $FUBINI_MEMO{$n}) { $FUBINI_MEMO{$n} }
    else {
        var $sum = 0
        for val $k (1:$n) {
            val $b = Rosetta::Fubini::binomial($n, $k)
            val $f = Rosetta::Fubini::compute($n - $k)
            $sum += $b * $f
        }
        $FUBINI_MEMO{$n} = $sum
        $sum
    }
}

assert_eq Rosetta::Fubini::compute(0), 1, "F0"
assert_eq Rosetta::Fubini::compute(1), 1, "F1"
assert_eq Rosetta::Fubini::compute(2), 3, "F2 (1 + 2*1)"
assert_eq Rosetta::Fubini::compute(3), 13, "F3"
assert_eq Rosetta::Fubini::compute(4), 75, "F4"

4 |> Rosetta::Fubini::compute |> assert_eq(75, "pipe fubini")

test_run
