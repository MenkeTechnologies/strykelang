#!/usr/bin/env stryke
# Rosetta Code: Least Common Multiple (using pipes)

fn Rosetta::LCM::gcd($a, $b) {
    my $aa = $a; my $bb = $b
    while ($bb != 0) {
        ($aa, $bb) = ($bb, $aa % $bb)
    }
    $aa
}

fn Rosetta::LCM::compute($a, $b) {
    if ($a == 0 || $b == 0) { return 0 }
    my $res = ($a * $b) / Rosetta::LCM::gcd($a, $b)
    abs($res)
}

fn Rosetta::LCM::solve(@nums) {
    @nums |> reduce { Rosetta::LCM::compute(_0, _1) }
}

assert_eq Rosetta::LCM::solve(12, 18), 36, "lcm(12, 18)"
assert_eq Rosetta::LCM::solve(2, 3, 4), 12, "lcm(2, 3, 4)"
assert_eq Rosetta::LCM::solve(7, 13), 91, "lcm(7, 13)"

test_run
