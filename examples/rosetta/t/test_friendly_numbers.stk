#!/usr/bin/env stryke
# Rosetta Code: Friendly numbers — pairs (m, n) with sigma(m)/m == sigma(n)/n
# (Same abundancy index.) Solitary numbers have a unique index.

fn Rosetta::Friendly::sigma($n) {
    var $s = 0
    for val $d (1:$n) {
        $s += $d if $n % $d == 0
    }
    $s
}

fn Rosetta::Friendly::gcd($a, $b) {
    while ($b != 0) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn Rosetta::Friendly::abundancy($n) {
    val $s = Rosetta::Friendly::sigma($n)
    val $g = Rosetta::Friendly::gcd($s, $n)
    [int($s / $g), int($n / $g)]
}

# Group 1..n by abundancy index, return groups with size > 1
fn Rosetta::Friendly::groups($n) {
    val %by_idx
    for val $i (1:$n) {
        val $idx = Rosetta::Friendly::abundancy($i)
        val $key = "$idx->[0]/$idx->[1]"
        push @{$by_idx{$key}}, $i
    }
    var %big
    for val $k (keys %by_idx) {
        $big{$k} = $by_idx{$k} if len(@{$by_idx{$k}}) > 1
    }
    \%big
}

# 6 is perfect: sigma(6) = 1+2+3+6 = 12 = 2*6, abundancy = 2/1
assert_eq join("/", @{Rosetta::Friendly::abundancy(6)}), "2/1", "abundancy(6) = 2/1"

# 28 is also perfect: same abundancy 2/1
assert_eq join("/", @{Rosetta::Friendly::abundancy(28)}), "2/1", "abundancy(28) = 2/1"

# Smallest friendly pair: (30, 140) — abundancy 12/5
assert_eq join("/", @{Rosetta::Friendly::abundancy(30)}), "12/5", "abundancy(30) = 12/5"
assert_eq join("/", @{Rosetta::Friendly::abundancy(140)}), "12/5", "abundancy(140) = 12/5"

# (240, 3110400) share abundancy ... too large for trial division — verify abundancy(80) and (200) instead
# (80, 200) share abundancy 117/40? Actually check (24, 91963648) — out of range too
# Just confirm (30, 140) come up in groups search up to 200
val $groups = Rosetta::Friendly::groups(200)
var $found = 0
for val $key (keys %$groups) {
    val @members = @{$groups->{$key}}
    val %m = map { _ => 1 } @members
    if (exists $m{30} && exists $m{140}) {
        $found = 1
    }
}
assert_ok $found, "30 and 140 in same group"

# Solitary by virtue of abundancy 1/1: just {1}
val $abu_1 = Rosetta::Friendly::abundancy(1)
assert_eq join("/", @$abu_1), "1/1", "abundancy(1) = 1/1"

test_run
