#!/usr/bin/env stryke
# Rosetta Code: Jury stability criterion

fn Rosetta::Jury::poly_at($coeffs, $x) {
    var $sum = 0.0
    val $n = len(@$coeffs) - 1
    for val $i (0:$n) {
        $sum += $coeffs->[$i] * ($x ** ($n - $i))
    }
    $sum
}

fn Rosetta::Jury::reduce_row($row) {
    val $m = len(@$row)
    val $a0 = $row->[0]
    val $an = $row->[-1]
    var @next
    for val $i (0:$m - 2) {
        push @next, $a0 * $row->[$i] - $an * $row->[$m - 1 - $i]
    }
    \@next
}

fn Rosetta::Jury::stable($coeffs) {
    val $n = len(@$coeffs) - 1
    return 0 if Rosetta::Jury::poly_at($coeffs, 1) <= 0
    return 0 if ((-1) ** $n) * Rosetta::Jury::poly_at($coeffs, -1) <= 0
    return 0 if abs($coeffs->[-1]) >= $coeffs->[0]
    if ($n == 2) {
        return 1
    }

    var $row = [@$coeffs]
    while (len(@$row) > 1) {
        $row = Rosetta::Jury::reduce_row($row)
        return 0 if abs($row->[0]) <= abs($row->[-1])
    }
    1
}

assert_eq Rosetta::Jury::stable([1, -0.5, 0.2]), 1, "stable second-order polynomial"
assert_eq Rosetta::Jury::stable([1, 0, 1.2]), 0, "fails |a_n| < a_0"
assert_eq len(@{Rosetta::Jury::reduce_row([1, -0.5, 0.2])}), 2, "row reduction decreases degree"

test_run
