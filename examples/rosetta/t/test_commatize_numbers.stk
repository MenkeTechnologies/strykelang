#!/usr/bin/env stryke
# Rosetta Code: Commatizing numbers — insert thousands separators.
# Idiomatic stryke: walk the integer part right-to-left, group by 3.

fn Rosetta::Commatize::insert($n) {
    my $s = "$n"
    my $sign = ""
    if ($s =~ /^-/) {
        $sign = "-"
        $s = substr($s, 1)
    }
    my @parts = split /\./, $s
    my $whole = $parts[0]
    my $frac  = len(@parts) > 1 ? "." . $parts[1] : ""
    # Walk reversed digits with a true digit count (chars skips split's empty boundaries).
    my @digits = $whole |> chars
    my @rev = reverse(@digits)
    my @grouped
    for my $i (0 .. len(@rev) - 1) {
        push @grouped, "," if $i > 0 && $i % 3 == 0
        push @grouped, $rev[$i]
    }
    my @final = reverse(@grouped)
    $sign . join("", @final) . $frac
}

assert_eq Rosetta::Commatize::insert(0),                 "0",                 "0"
assert_eq Rosetta::Commatize::insert(123),               "123",               "no comma needed"
assert_eq Rosetta::Commatize::insert(1234),              "1,234",             "1234"
assert_eq Rosetta::Commatize::insert(1000000),           "1,000,000",         "one million"
assert_eq Rosetta::Commatize::insert(1234567890),        "1,234,567,890",     "ten digits"
assert_eq Rosetta::Commatize::insert(-1234567),          "-1,234,567",        "negative"
assert_eq Rosetta::Commatize::insert("3.14159"),         "3.14159",           "decimal short"
assert_eq Rosetta::Commatize::insert("1234567.89"),      "1,234,567.89",      "decimal long"

test_run
