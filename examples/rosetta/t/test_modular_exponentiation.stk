#!/usr/bin/env stryke
# Rosetta Code: Modular exponentiation — fast pow_mod via right-to-left binary

fn Rosetta::ModExp::pow_mod($base, $exp, $mod) {
    return 0 if $mod == 1
    my $result = 1
    $base = $base % $mod
    while ($exp > 0) {
        if ($exp & 1) {
            $result = ($result * $base) % $mod
        }
        $exp = $exp >> 1
        $base = ($base * $base) % $mod
    }
    $result
}

assert_eq Rosetta::ModExp::pow_mod(2, 10, 1000), 24, "2^10 mod 1000 = 24"
assert_eq Rosetta::ModExp::pow_mod(3, 0, 7), 1, "x^0 = 1"
assert_eq Rosetta::ModExp::pow_mod(0, 5, 7), 0, "0^k = 0"
assert_eq Rosetta::ModExp::pow_mod(7, 100, 1), 0, "anything mod 1 = 0"
assert_eq Rosetta::ModExp::pow_mod(5, 13, 23), 21, "5^13 mod 23 = 21"
assert_eq Rosetta::ModExp::pow_mod(2, 20, 1000000), 48576, "2^20 mod 1e6"

# Fermat's little theorem: a^(p-1) mod p = 1 when gcd(a,p)=1
assert_eq Rosetta::ModExp::pow_mod(3, 6, 7), 1, "3^6 mod 7 = 1 (Fermat)"
assert_eq Rosetta::ModExp::pow_mod(10, 12, 13), 1, "10^12 mod 13 = 1 (Fermat)"

# Pipe form
2 |> Rosetta::ModExp::pow_mod(10, 1000) |> assert_eq(24, "pipe 2^10 mod 1000 = 24")

test_run
