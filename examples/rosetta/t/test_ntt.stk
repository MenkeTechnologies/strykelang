#!/usr/bin/env stryke
# Rosetta Code: Number theoretic transform

fn Rosetta::NTT::mod_pow($base, $exp, $mod) {
    my $res = 1
    $base %= $mod
    while ($exp > 0) {
        if ($exp % 2 == 1) { $res = ($res * $base) % $mod }
        $base = ($base * $base) % $mod
        $exp = $exp / 2 | 0
    }
    $res
}

fn Rosetta::NTT::transform($a, $n, $g, $p) {
    my @res
    for (my $i = 0; $i < $n; $i++) {
        my $sum = 0
        for (my $j = 0; $j < $n; $j++) {
            my $exp = ($i * $j) % ($p - 1)
            my $w = Rosetta::NTT::mod_pow($g, $exp, $p)
            $sum = ($sum + $a->[$j] * $w) % $p
        }
        push @res, $sum
    }
    \@res
}

# Example from a source: p=7, n=3, g=2? No, n must divide p-1.
# p=7, p-1=6. n=3 divides 6.
# 2^2 = 4, 2^4 = 16 = 2, 2^6 = 64 = 1.
# So g=2^2 = 4 is a 3rd root of unity mod 7.
my $p = 7
my $n = 3
my $g = 4 # 4^3 = 64 = 1 mod 7.

my @a = (1, 2, 3)
my $res = Rosetta::NTT::transform(\@a, $n, $g, $p)
# res[0] = 1*4^0 + 2*4^0 + 3*4^0 = 1+2+3 = 6 mod 7
# res[1] = 1*4^0 + 2*4^1 + 3*4^2 = 1+8+48 = 57 = 1 mod 7
# res[2] = 1*4^0 + 2*4^2 + 3*4^4 = 1+32+3*256 = 1+4+3*4 = 1+4+12 = 17 = 3 mod 7

assert_eq join(",", @$res), "6,1,3", "NTT example results"

test_run
