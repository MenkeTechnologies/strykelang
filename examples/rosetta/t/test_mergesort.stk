#!/usr/bin/env stryke
# Rosetta Code: Mergesort

fn Rosetta::Mergesort::merge($left, $right) {
    var @res
    while (len(@$left) > 0 && len(@$right) > 0) {
        if ($left->[0] <= $right->[0]) {
            push @res, shift @$left
        } else {
            push @res, shift @$right
        }
    }
    push @res, @$left
    push @res, @$right
    \@res
}

fn Rosetta::Mergesort::sort($arr) {
    val $n = len(@$arr)
    return $arr if $n <= 1
    
    val $mid = $n / 2 | 0
    val @left = @$arr[0 : $mid - 1]
    val @right = @$arr[$mid : $n - 1]
    
    val $left_sorted = Rosetta::Mergesort::sort(\@left)
    val $right_sorted = Rosetta::Mergesort::sort(\@right)
    
    Rosetta::Mergesort::merge($left_sorted, $right_sorted)
}

val $data = [4, 65, 2, -31, 0, 99, 2, 83, 782, 1]
val $sorted = Rosetta::Mergesort::sort($data)
assert_eq join(",", @$sorted), "-31,0,1,2,2,4,65,83,99,782", "mergesort works"

# Parallel sort test (manual partition)
val $mid = len(@$data) / 2 | 0
val @l = @$data[0 : $mid - 1]
val @r = @$data[$mid : len(@$data)-1]

# Use ~> to sort halves in parallel
val @parts = (\@l, \@r)
val @sorted_parts = ~> @parts map {Rosetta::Mergesort::sort}
val $final = Rosetta::Mergesort::merge($sorted_parts[0], $sorted_parts[1])
assert_eq join(",", @$final), "-31,0,1,2,2,4,65,83,99,782", "parallel mergesort works"

test_run
