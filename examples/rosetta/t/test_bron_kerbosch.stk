#!/usr/bin/env stryke
# Rosetta Code: Bron-Kerbosch maximal-clique enumeration.
# Graph is a hash from vertex → array of neighbors. Returns all maximal
# cliques as arrays of sorted vertices.

fn Rosetta::BK::set_to_arr($s) { sort { _0 cmp _1 } keys %$s }

fn Rosetta::BK::set_intersect($a, $b) {
    my %r
    for my $k (keys %$a) { $r{$k} = 1 if exists $b->{$k} }
    \%r
}

fn Rosetta::BK::set_minus($a, $b) {
    my %r
    for my $k (keys %$a) { $r{$k} = 1 unless exists $b->{$k} }
    \%r
}

fn Rosetta::BK::neighbors($graph, $v) {
    my %s
    for my $u (@{$graph->{$v}}) { $s{$u} = 1 }
    \%s
}

fn Rosetta::BK::recurse($graph, $r, $p, $x, $cliques) {
    if (len(keys %$p) == 0 && len(keys %$x) == 0) {
        push @$cliques, [Rosetta::BK::set_to_arr($r)]
        return
    }
    # Pivot: choose vertex from P ∪ X with the most neighbors in P
    # (Tomita-style pivoting reduces work).
    my %pu
    for my $k (keys %$p) { $pu{$k} = 1 }
    for my $k (keys %$x) { $pu{$k} = 1 }
    my $pivot
    my $best = -1
    for my $v (keys %pu) {
        my $cnt = 0
        my $nb = $graph->{$v} // []
        for my $u (@$nb) { $cnt++ if exists $p->{$u} }
        if ($cnt > $best) { $best = $cnt; $pivot = $v }
    }
    my $nb_pivot = Rosetta::BK::neighbors($graph, $pivot)
    my $candidates = Rosetta::BK::set_minus($p, $nb_pivot)
    for my $v (Rosetta::BK::set_to_arr($candidates)) {
        my $n_v = Rosetta::BK::neighbors($graph, $v)
        my %r_new
        for my $k (keys %$r) { $r_new{$k} = 1 }
        $r_new{$v} = 1
        my $p_new = Rosetta::BK::set_intersect($p, $n_v)
        my $x_new = Rosetta::BK::set_intersect($x, $n_v)
        Rosetta::BK::recurse($graph, \%r_new, $p_new, $x_new, $cliques)
        delete $p->{$v}
        $x->{$v} = 1
    }
}

fn Rosetta::BK::cliques($graph) {
    my %pset; for my $v (keys %$graph) { $pset{$v} = 1 }
    my %xset
    my %rset
    my @cliques
    Rosetta::BK::recurse($graph, \%rset, \%pset, \%xset, \@cliques)
    \@cliques
}

fn Rosetta::BK::format_cliques($cs) {
    my @rows = map { join(",", @{_0}) } @$cs
    @rows = sort { _0 cmp _1 } @rows
    join("|", @rows)
}

# Triangle 1-2-3 (single 3-clique)
my $g1 = {
    "1" => ["2", "3"],
    "2" => ["1", "3"],
    "3" => ["1", "2"]
}
assert_eq Rosetta::BK::format_cliques(Rosetta::BK::cliques($g1)), "1,2,3", "triangle"

# Path 1-2-3 (two 2-cliques)
my $g2 = {
    "1" => ["2"],
    "2" => ["1", "3"],
    "3" => ["2"]
}
assert_eq Rosetta::BK::format_cliques(Rosetta::BK::cliques($g2)), "1,2|2,3", "path"

# K4 (one 4-clique)
my $g3 = {
    "1" => ["2", "3", "4"],
    "2" => ["1", "3", "4"],
    "3" => ["1", "2", "4"],
    "4" => ["1", "2", "3"]
}
assert_eq Rosetta::BK::format_cliques(Rosetta::BK::cliques($g3)), "1,2,3,4", "K4"

# Two disjoint triangles
my $g4 = {
    "1" => ["2", "3"], "2" => ["1", "3"], "3" => ["1", "2"],
    "4" => ["5", "6"], "5" => ["4", "6"], "6" => ["4", "5"]
}
assert_eq Rosetta::BK::format_cliques(Rosetta::BK::cliques($g4)), "1,2,3|4,5,6", "two triangles"

# Wikipedia example: 6 vertices, three maximal cliques:
# 1-2-5, 1-4-5, 2-3, 3-4, 4-5-6 ... let's use the canonical sample
# (vertices 1..6, edges: 12,15,25,14,45,23,34,46,56)
my $g5 = {
    "1" => ["2", "5", "4"],
    "2" => ["1", "5", "3"],
    "3" => ["2", "4"],
    "4" => ["1", "5", "3", "6"],
    "5" => ["1", "2", "4", "6"],
    "6" => ["4", "5"]
}
my $r5 = Rosetta::BK::format_cliques(Rosetta::BK::cliques($g5))
# Expected maximal cliques (per Wikipedia BK example): {1,2,5}, {1,4,5}, {2,3}, {3,4}, {4,5,6}
assert_eq $r5, "1,2,5|1,4,5|2,3|3,4|4,5,6", "Wikipedia BK example"

test_run
