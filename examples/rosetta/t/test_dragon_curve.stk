#!/usr/bin/env stryke
# Rosetta Code: Dragon curve (Heighway dragon)

fn Rosetta::DragonCurve::step($s) {
    my $inverted = ~> split("", $s) map { _ eq "R" ? "L" : "R" } |> join("")
    my $reversed = reverse($inverted)
    $s . "R" . $reversed
}

fn Rosetta::DragonCurve::solve($n) {
    my $res = "R"
    for (1..$n) {
        $res = Rosetta::DragonCurve::step($res)
    }
    $res
}

assert_eq Rosetta::DragonCurve::solve(0), "R", "Dragon n=0"
assert_eq Rosetta::DragonCurve::solve(1), "RRL", "Dragon n=1"
assert_eq Rosetta::DragonCurve::solve(2), "RRLRRLL", "Dragon n=2"
assert_eq Rosetta::DragonCurve::solve(3), "RRLRRLLRRRLLRLL", "Dragon n=3"

# Length should be 2^(n+1) - 1
assert_eq length(Rosetta::DragonCurve::solve(10)), 2047, "Dragon n=10 length"

test_run
