#!/usr/bin/env stryke
# Rosetta Code: Depth-first search

fn Rosetta::DFS::dfs_recursive($graph, $u, $visited, $order) {
    push @$order, $u
    $visited->{$u} = 1
    for val $v (@{$graph->{$u}}) {
        if (!exists $visited->{$v}) {
            Rosetta::DFS::dfs_recursive($graph, $v, $visited, $order)
        }
    }
}

fn Rosetta::DFS::solve($graph, $start) {
    val $visited = {}
    val $order = []
    Rosetta::DFS::dfs_recursive($graph, $start, $visited, $order)
    $order
}

val $graph = {
    "A" => ["B", "C"],
    "B" => ["D", "E"],
    "C" => ["F"],
    "D" => [],
    "E" => ["F"],
    "F" => []
}

val $res = Rosetta::DFS::solve($graph, "A")
# DFS from A with this adjacency order: A -> B -> D, then B -> E -> F, then C
assert_eq join(",", @$res), "A,B,D,E,F,C", "DFS order from A"

test_run
