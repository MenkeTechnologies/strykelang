#!/usr/bin/env stryke
# Rosetta Code: Fenwick tree

fn Rosetta::Fenwick::update($tree, $idx, $val) {
    my $n = scalar(@$tree) - 1
    $idx++ # 1-based internal
    while ($idx <= $n) {
        $tree->[$idx] += $val
        $idx += $idx & -$idx
    }
}

fn Rosetta::Fenwick::query($tree, $idx) {
    $idx++
    my $s = 0
    while ($idx > 0) {
        $s += $tree->[$idx]
        $idx -= $idx & -$idx
    }
    $s
}

fn Rosetta::Fenwick::range_query($tree, $l, $r) {
    Rosetta::Fenwick::query($tree, $r) - Rosetta::Fenwick::query($tree, $l - 1)
}

my $n = 10
my @tree = map { 0 } 0..$n
Rosetta::Fenwick::update(\@tree, 0, 1)
Rosetta::Fenwick::update(\@tree, 1, 2)
Rosetta::Fenwick::update(\@tree, 2, 3)
Rosetta::Fenwick::update(\@tree, 3, 4)
Rosetta::Fenwick::update(\@tree, 4, 5)

assert_eq Rosetta::Fenwick::query(\@tree, 0), 1, "prefix sum 0"
assert_eq Rosetta::Fenwick::query(\@tree, 2), 6, "prefix sum 2"
assert_eq Rosetta::Fenwick::query(\@tree, 4), 15, "prefix sum 4"
assert_eq Rosetta::Fenwick::range_query(\@tree, 1, 3), 9, "range sum 1..3"

test_run
