#!/usr/bin/env stryke
# Rosetta Code: Unique elements

fn Rosetta::UniqueElements::get($arr_ref) {
    val @arr = @$arr_ref
    var %seen
    var @unique = ()
    for val $x (@arr) {
        if (!exists $seen{$x}) {
            push @unique, $x
            $seen{$x} = 1
        }
    }
    \@unique
}

val $data = [1, 2, 3, 2, 1, 4, 5, 4]
val $res = Rosetta::UniqueElements::get($data)
assert_eq join(",", @$res), "1,2,3,4,5", "unique elements"

val $data2 = ["a", "b", "a", "c"]
val $res2 = Rosetta::UniqueElements::get($data2)
assert_eq join(",", @$res2), "a,b,c", "unique strings"

test_run
