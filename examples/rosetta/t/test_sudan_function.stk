#!/usr/bin/env stryke
# Rosetta Code: Sudan function F(n, x, y)
# F(0, x, y) = x + y
# F(n+1, x, 0) = x  (n ≥ 0)
# F(n+1, x, y+1) = F(n, F(n+1, x, y), F(n+1, x, y) + y + 1)
# Like Ackermann's function, the Sudan function is recursive but not
# primitive recursive.

fn Rosetta::Sudan::f($n, $x, $y) {
    return $x + $y if $n == 0
    return $x     if $y == 0
    my $inner = Rosetta::Sudan::f($n, $x, $y - 1)
    Rosetta::Sudan::f($n - 1, $inner, $inner + $y)
}

# Base
assert_eq Rosetta::Sudan::f(0, 3, 4), 7,  "F(0, 3, 4) = 7"
assert_eq Rosetta::Sudan::f(0, 0, 0), 0,  "F(0, 0, 0) = 0"

# F(n+1, x, 0) = x
assert_eq Rosetta::Sudan::f(1, 5, 0),  5,  "F(1, 5, 0) = 5"
assert_eq Rosetta::Sudan::f(2, 7, 0),  7,  "F(2, 7, 0) = 7"

# Small values
assert_eq Rosetta::Sudan::f(1, 1, 1), 3, "F(1, 1, 1)"
assert_eq Rosetta::Sudan::f(1, 1, 2), 8, "F(1, 1, 2)"
assert_eq Rosetta::Sudan::f(1, 2, 1), 5, "F(1, 2, 1)"
assert_eq Rosetta::Sudan::f(1, 2, 2), 12, "F(1, 2, 2) = F(0, 5, 7) = 12"

# Sanity: F(0, x, y) is symmetric (commutativity of +)
for my $x (0..4) {
    for my $y (0..4) {
        assert_eq Rosetta::Sudan::f(0, $x, $y),
            Rosetta::Sudan::f(0, $y, $x),
            sprintf("F(0,%d,%d) symmetric", $x, $y)
    }
}

# Pipe form
0 |> fn { Rosetta::Sudan::f(_, 3, 4) } |> assert_eq(7, "pipe F(0,3,4)")

test_run
