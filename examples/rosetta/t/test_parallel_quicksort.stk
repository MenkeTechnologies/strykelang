#!/usr/bin/env stryke
# Rosetta Code: Parallel QuickSort
# Uses sort with numeric comparison

# Test with a randomized list
my @data = ~> 1:100 map { int(rand(1000)) }
my @sorted = sort { _0 <=> _1 } @data

# Verify order: every adjacent pair must be non-decreasing
my $ok = ~> 0:len(@sorted)-2 all { $sorted[_] <= $sorted[_+1] }
assert_ok $ok, "Parallel QuickSort result is sorted"
assert_eq len(@sorted), 100, "Parallel QuickSort preserved all elements"

test_run
