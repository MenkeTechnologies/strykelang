#!/usr/bin/env stryke
# Rosetta Code: Floyd's triangle

fn Rosetta::FloydTriangle::generate($n) {
    var @rows = ()
    var $curr = 1
    for val $i (1:$n) {
        var @row = ()
        for val $j (1:$i) {
            push @row, $curr
            $curr = $curr + 1
        }
        push @rows, [@row]
    }
    \@rows
}

val $res = Rosetta::FloydTriangle::generate(5)
assert_eq len(@$res), 5, "5 rows"
assert_eq join(",", @{$res->[0]}), "1", "row 1"
assert_eq join(",", @{$res->[1]}), "2,3", "row 2"
assert_eq join(",", @{$res->[4]}), "11,12,13,14,15", "row 5"

test_run
