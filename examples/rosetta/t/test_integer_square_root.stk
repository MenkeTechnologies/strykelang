#!/usr/bin/env stryke
# Rosetta Code: Integer square root

fn Rosetta::IntSqrt::compute($n) {
    if ($n < 0) { 0 }
    else {
        my $root = int(sqrt($n))
        $root
    }
}

assert_eq Rosetta::IntSqrt::compute(16), 4, "isqrt(16)"
assert_eq Rosetta::IntSqrt::compute(17), 4, "isqrt(17)"
assert_eq Rosetta::IntSqrt::compute(25), 5, "isqrt(25)"
assert_eq Rosetta::IntSqrt::compute(0), 0, "isqrt(0)"

test_run
