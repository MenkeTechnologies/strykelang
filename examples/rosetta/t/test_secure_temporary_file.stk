#!/usr/bin/env stryke
# Rosetta Code: Secure temporary file

fn Rosetta::SecureTemp::run {
    # tempfile() in Stryke creates a unique file in the system temp dir
    # with restricted permissions by default (equivalent to mkstemp).
    val $path = tempfile()
    
    # Write some data
    var $data = "Secret data"
    write_file($path, $data)
    
    # Verify it exists and content is correct
    assert_ok(-f $path, "Temp file exists")
    val $read = slurp($path)
    assert_eq($read, $data, "Content is correct")
    
    # In a real scenario, we might chmod 0600 if not already done by tempfile()
    chmod($path, 0600)
    
    # Clean up
    unlink($path)
    assert_ok(!(-f $path), "Temp file removed")
    
    $path
}

val $p = Rosetta::SecureTemp::run()
p "Secure temp file task completed using $p"

test_run
