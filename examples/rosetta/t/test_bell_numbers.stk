#!/usr/bin/env stryke
# Rosetta Code: Bell numbers

fn Rosetta::BellNumbers::binomial($n, $k) {
    if ($k < 0 || $k > $n) {
        0
    } elsif ($k == 0 || $k == $n) {
        1
    } else {
        my $res = 1
        my $kk = $k < $n - $k ? $k : $n - $k
        for my $i (1..$kk) {
            $res = $res * ($n - $i + 1) / $i
        }
        int($res + 0.5)
    }
}

fn Rosetta::BellNumbers::compute($n) {
    if ($n == 0) {
        1
    } else {
        my @tri
        $tri[0] = [1]
        for my $i (1..$n) {
            my $row = []
            $row->[0] = $tri[$i-1]->[$i-1]
            for my $j (1..$i) {
                $row->[$j] = $row->[$j-1] + $tri[$i-1]->[$j-1]
            }
            $tri[$i] = $row
        }
        $tri[$n]->[0]
    }
}

assert_eq Rosetta::BellNumbers::compute(0), 1, "B0"
assert_eq Rosetta::BellNumbers::compute(1), 1, "B1"
assert_eq Rosetta::BellNumbers::compute(2), 2, "B2"
assert_eq Rosetta::BellNumbers::compute(3), 5, "B3"
assert_eq Rosetta::BellNumbers::compute(4), 15, "B4"
assert_eq Rosetta::BellNumbers::compute(5), 52, "B5"
assert_eq Rosetta::BellNumbers::compute(10), 115975, "B10"

10 |> Rosetta::BellNumbers::compute |> assert_eq(115975, "pipe bell")

test_run
