#!/usr/bin/env stryke
# Rosetta Code: Autogram checker — sentence whose stated letter counts equal
# its actual letter counts (e.g. Lee Sallows' classic).

fn Rosetta::Autogram::word_to_n($w) {
    val %m = (
        "one"=>1, "two"=>2, "three"=>3, "four"=>4, "five"=>5, "six"=>6, "seven"=>7,
        "eight"=>8, "nine"=>9, "ten"=>10, "eleven"=>11, "twelve"=>12, "thirteen"=>13,
        "fourteen"=>14, "fifteen"=>15, "sixteen"=>16, "seventeen"=>17, "eighteen"=>18,
        "nineteen"=>19, "twenty"=>20, "thirty"=>30, "forty"=>40, "fifty"=>50,
        "sixty"=>60, "seventy"=>70, "eighty"=>80, "ninety"=>90,
    )
    var $n = 0
    for val $part (split /[\s-]+/, lc $w) {
        next if $part eq "and" || $part eq ""
        $n += $m{$part} // 0
    }
    $n
}

fn Rosetta::Autogram::actual_letter_counts($s) {
    var %cnt
    for val $ch (split("", lc $s)) {
        $cnt{$ch} = ($cnt{$ch} // 0) + 1 if $ch =~ /[a-z]/
    }
    %cnt
}

fn Rosetta::Autogram::is_autogram($sentence) {
    val %actual = Rosetta::Autogram::actual_letter_counts($sentence)
    var %claimed
    while ($sentence =~ /\b([a-z]+(?:[-\s][a-z]+)*?)\s+([a-z])(?:'s)?\b/gi) {
        val $num_word = $1
        val $letter   = lc $2
        val $n = Rosetta::Autogram::word_to_n($num_word)
        next if $n == 0
        $claimed{$letter} = $n
    }
    for val $L ("a".."z") {
        val $a = $actual{$L} // 0
        val $c = $claimed{$L} // 0
        return 0 if $c != 0 && $c != $a
    }
    1
}

# Bogus claim: "nineteen e's" but the sentence has only 4 e's.
val $bogus = "this sentence has nineteen e's"
assert_ok !Rosetta::Autogram::is_autogram($bogus), "bogus claim rejected"

# Counts function basics
val %cnt = Rosetta::Autogram::actual_letter_counts("Aaa Bb Bb")
assert_eq $cnt{a}, 3, "3 a's"
assert_eq $cnt{b}, 4, "4 b's"

# word_to_n
assert_eq Rosetta::Autogram::word_to_n("twenty-seven"), 27, "twenty-seven"
assert_eq Rosetta::Autogram::word_to_n("five"),         5,  "five"
assert_eq Rosetta::Autogram::word_to_n("eighteen"),     18, "eighteen"

test_run
