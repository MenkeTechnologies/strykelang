#!/usr/bin/env stryke
# Rosetta Code: Ordered partitions

fn Rosetta::OrderedPartitions::generate($n) {
    my @res = ()
    if ($n == 0) {
        push @res, []
        return \@res
    }
    for my $i (1..$n) {
        my $sub = Rosetta::OrderedPartitions::generate($n - $i)
        for my $p (@$sub) {
            push @res, [$i, @$p]
        }
    }
    \@res
}

my $p3 = Rosetta::OrderedPartitions::generate(3)
# Partitions of 3: (1,1,1), (1,2), (2,1), (3)
assert_eq scalar(@$p3), 4, "3 has 4 ordered partitions"

my $joined = ~> @$p3 map { join("", @$_) } |> join(",")
assert_eq $joined, "111,12,21,3", "partitions of 3"

test_run
