#!/usr/bin/env stryke
# Rosetta Code: Ordered partitions

fn Rosetta::OrderedPartitions::generate($n) {
    var @res = ()
    if ($n == 0) {
        push @res, []
        return \@res
    }
    for val $i (1:$n) {
        val $sub = Rosetta::OrderedPartitions::generate($n - $i)
        for val $p (@$sub) {
            push @res, [$i, @$p]
        }
    }
    \@res
}

val $p3 = Rosetta::OrderedPartitions::generate(3)
# Partitions of 3: (1,1,1), (1,2), (2,1), (3)
assert_eq len(@$p3), 4, "3 has 4 ordered partitions"

val $joined = ~> @$p3 map { join("", @{_}) } |> join(",")
assert_eq $joined, "111,12,21,3", "partitions of 3"

test_run
