#!/usr/bin/env stryke
# Rosetta Code: Sub-unit squares
# Squares S = n² such that 0 ≤ n < 100, where S is split into two
# halves a, b at the midpoint of its decimal digits, and a + b is
# also a square. The classic example is 88209: 88 + 209 = 297 …
# nope; the rosetta task is "n² where the right half subtracted from
# the left half yields the original n" (a Kaprekar-like split).
# We implement: n² split into two halves p (left) and q (right) such
# that p - q = n. (E.g. 297² = 88209, 88 - 209 = -121 → fails;
# 297² = 88209, but 88 + 209 = 297 ✓ Kaprekar.)
# Rosetta "sub-unit squares" follows the variant a - b = n.

fn Rosetta::SubUnit::digit_count($n) {
    return 1 if $n == 0
    my $c = 0
    my $x = abs($n)
    while ($x > 0) { $c++; $x = int($x / 10) }
    $c
}

fn Rosetta::SubUnit::split_subtract($n) {
    return undef if $n < 0
    my $sq = $n * $n
    my $d = Rosetta::SubUnit::digit_count($sq)
    return undef if $d < 2
    my $half = int($d / 2)
    # Try every split offset from 1..d-1 (left side has `i` digits).
    my @hits
    for my $i (1..$d - 1) {
        my $right_digits = $d - $i
        my $factor = 1
        for my $k (~> 1:$right_digits) { $factor *= 10 }
        my $left  = int($sq / $factor)
        my $right = $sq % $factor
        push @hits, $i if $left - $right == $n
    }
    @hits
}

fn Rosetta::SubUnit::is($n) {
    my @hits = Rosetta::SubUnit::split_subtract($n)
    len(@hits) > 0
}

fn Rosetta::SubUnit::find_below($limit) {
    1:$limit |> grep { Rosetta::SubUnit::is(_) }
}

# Helper sanity
assert_eq Rosetta::SubUnit::digit_count(88209), 5, "88209 has 5 digits"
assert_eq Rosetta::SubUnit::digit_count(0),    1, "0 has 1 digit"
assert_eq Rosetta::SubUnit::digit_count(10),   2, "10 has 2 digits"

# n = 1: 1² = 1 (1 digit) — too short; should return no split
my @r1 = Rosetta::SubUnit::split_subtract(1)
assert_eq len(@r1), 0, "1² too short to split"

# n = 0
my @r0 = Rosetta::SubUnit::split_subtract(0)
assert_eq len(@r0), 0, "0² is a single zero, no split"

# Known sub-unit (a - b = n) families:
# n = 9, 9² = 81, 8 - 1 = 7 ≠ 9 (no)
# n = 100: 100² = 10000, 100 - 00 = 100 ✓ ; 10 - 000 = 10 ≠ 100; …
assert_eq Rosetta::SubUnit::is(100), 1, "100 satisfies (a - b = n)"

# 297² = 88209, 88 - 209 = -121, 882 - 09 = 873; no a-b matches 297
assert_eq Rosetta::SubUnit::is(297), 0, "297 fails the a-b = n rule"

# Find all sub-unit squares with n ≤ 1000
my @all = Rosetta::SubUnit::find_below(1000)
assert_ok len(@all) >= 1, "found some sub-unit squares ≤ 1000"

# Pipe form
100 |> Rosetta::SubUnit::is |> assert_eq(1, "pipe is(100)")

test_run
