#!/usr/bin/env stryke
# Rosetta Code: Multiplicative digital root and persistence

fn Rosetta::MultiplicativeDigitalRoot::multiplicative_digital_root_and_persistence($n) {
    var $persistence = 0
    var $curr = $n
    while (len("$curr") > 1) {
        val @digits = ~> "$curr" chars map {int}
        var $prod = 1
        for val $d (@digits) { $prod *= $d }
        $curr = $prod
        $persistence++
    }
    ($curr, $persistence)
}

var ($root, $pers) = Rosetta::MultiplicativeDigitalRoot::multiplicative_digital_root_and_persistence(327)
assert_eq $root, 8, "MDR(327) is 8"
assert_eq $pers, 2, "MP(327) is 2"

($root, $pers) = Rosetta::MultiplicativeDigitalRoot::multiplicative_digital_root_and_persistence(77)
assert_eq $root, 8, "MDR(77) is 8"
assert_eq $pers, 4, "MP(77) is 4"

test_run
