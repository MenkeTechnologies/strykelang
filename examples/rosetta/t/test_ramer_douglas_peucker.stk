#!/usr/bin/env stryke
# Rosetta Code: Ramer-Douglas-Peucker polyline simplification

fn Rosetta::RDP::perp_dist($pt, $a, $b) {
    val $dx = $b->[0] - $a->[0]
    val $dy = $b->[1] - $a->[1]
    val $len = sqrt($dx * $dx + $dy * $dy)
    return sqrt(($pt->[0] - $a->[0]) ** 2 + ($pt->[1] - $a->[1]) ** 2) if $len == 0
    abs($dy * $pt->[0] - $dx * $pt->[1] + $b->[0] * $a->[1] - $b->[1] * $a->[0]) / $len
}

fn Rosetta::RDP::simplify($pts, $eps) {
    val $n = len(@$pts)
    return [@$pts] if $n < 3
    var $max_d = 0
    var $idx = 0
    for val $i (1:$n - 2) {
        val $d = Rosetta::RDP::perp_dist($pts->[$i], $pts->[0], $pts->[$n - 1])
        if ($d > $max_d) {
            $max_d = $d
            $idx = $i
        }
    }
    if ($max_d > $eps) {
        val @left_pts = @$pts[0:$idx]
        val @right_pts = @$pts[$idx:$n - 1]
        val $l = Rosetta::RDP::simplify(\@left_pts, $eps)
        val $r = Rosetta::RDP::simplify(\@right_pts, $eps)
        var @combined = @$l[0..len(@$l) - 2]
        push @combined, @$r
        \@combined
    } else {
        [$pts->[0], $pts->[$n - 1]]
    }
}

# Straight line stays as endpoints
val $line = [[0,0], [1,1], [2,2], [3,3], [4,4]]
val $sl = Rosetta::RDP::simplify($line, 0.5)
assert_eq len(@$sl), 2, "collinear -> 2 endpoints"
assert_eq $sl->[0][0], 0, "first x"
assert_eq $sl->[1][0], 4, "last x"

# Sharp triangle preserved
val $tri = [[0,0], [2,3], [4,0]]
val $st = Rosetta::RDP::simplify($tri, 0.5)
assert_eq len(@$st), 3, "triangle peak preserved"

# Tiny noise on a line gets smoothed
val $noisy = [[0,0], [1,0.01], [2,0.02], [3,-0.01], [4,0]]
val $sm = Rosetta::RDP::simplify($noisy, 0.1)
assert_eq len(@$sm), 2, "small noise smoothed to endpoints"

# Larger noise preserved
val $big_noise = [[0,0], [1,1], [2,0]]
val $sb = Rosetta::RDP::simplify($big_noise, 0.5)
assert_eq len(@$sb), 3, "big spike preserved"

# Two points stay
val $two = [[0,0], [5,5]]
val $st2 = Rosetta::RDP::simplify($two, 0.1)
assert_eq len(@$st2), 2, "2 input -> 2 output"

# eps = 0 keeps everything except strictly collinear interior
val $exact = [[0,0], [1,1], [2,2], [3,5]]
val $sx = Rosetta::RDP::simplify($exact, 0)
assert_ok len(@$sx) >= 3, "eps=0 keeps non-collinear bend"

test_run
