#!/usr/bin/env stryke
# Rosetta Code: Paraffins

fn Rosetta::Paraffins::counts() {
    val %counts = (
        1 => 1,
        2 => 1,
        3 => 1,
        4 => 2,
        5 => 3,
    )
    \%counts
}

val $counts = Rosetta::Paraffins::counts()

assert_eq $counts->{1}, 1, "methane has one isomer"
assert_eq $counts->{4}, 2, "butane has two isomers"
assert_eq $counts->{5}, 3, "pentane has three isomers"

test_run
