#!/usr/bin/env stryke
# Rosetta Code: Active object
# Stryke closures capture lexicals by VALUE, so shared mutable state goes through
# a hashref/arrayref. The published interface is a hash of method-closures, all
# closing over the same backing record.

fn Rosetta::ActiveObj::new() {
    var $state = { log => [], count => 0 }
    {
        add => fn {
            push @{$state->{log}}, _
            $state->{count} += 1
            $state->{count}
        },
        size     => fn { $state->{count} },
        snapshot => fn { [@{$state->{log}}] },
        reset    => fn {
            $state->{log} = []
            $state->{count} = 0
            0
        },
    }
}

val $obj = Rosetta::ActiveObj::new()
assert_eq $obj->{add}("hello"),   1, "add returns count"
assert_eq $obj->{add}("world"),   2, "add returns count"
assert_eq $obj->{add}("rosetta"), 3, "add returns count"
assert_eq $obj->{size}(), 3, "3 items"

val $snap = $obj->{snapshot}()
assert_eq join(",", @$snap), "hello,world,rosetta", "snapshot order"

$obj->{reset}()
assert_eq $obj->{size}(), 0, "reset clears"

# Two instances are independent — separate $state hashrefs.
val $a = Rosetta::ActiveObj::new()
val $b = Rosetta::ActiveObj::new()
$a->{add}("x")
assert_eq $a->{size}(), 1, "a has 1"
assert_eq $b->{size}(), 0, "b unaffected"

test_run
