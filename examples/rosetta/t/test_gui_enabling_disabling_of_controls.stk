#!/usr/bin/env stryke
# Rosetta Code: GUI enabling/disabling of controls

fn Rosetta::GUIEnable::window() {
    { agree => 0, submit_enabled => 0 }
}

fn Rosetta::GUIEnable::toggle_agree($win, $value) {
    $win->{agree} = $value
    $win->{submit_enabled} = $value ? 1 : 0
}

val $win = Rosetta::GUIEnable::window()

assert_eq $win->{submit_enabled}, 0, "submit starts disabled"
Rosetta::GUIEnable::toggle_agree($win, 1)
assert_eq $win->{submit_enabled}, 1, "checking agreement enables submit"
Rosetta::GUIEnable::toggle_agree($win, 0)
assert_eq $win->{submit_enabled}, 0, "unchecking agreement disables submit"

test_run
