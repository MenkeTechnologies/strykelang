#!/usr/bin/env stryke
# Rosetta Code: Multiple distinct objects
# Initialise an array of N independent objects (NOT N references to
# the same shared object). Mutations to one element must not affect
# the others.

fn Rosetta::DistinctObj::make_distinct($n) {
    my @arr
    for my $i (~> 1:$n) {
        push @arr, { id => $i, value => 0, log => [] }
    }
    \@arr
}

fn Rosetta::DistinctObj::make_shared_bug($n) {
    # Anti-pattern: every slot points to the same object.
    my $shared = { id => 0, value => 0, log => [] }
    my @arr = ($shared) x $n
    \@arr
}

# Distinct construction: 5 separate hashes
my $a = Rosetta::DistinctObj::make_distinct(5)
assert_eq len(@$a), 5, "5 elements"

# Mutating one slot leaves the others unchanged
$a->[2]{value} = 100
push @{$a->[2]{log}}, "tagged"
assert_eq $a->[0]{value}, 0, "slot 0 untouched"
assert_eq $a->[1]{value}, 0, "slot 1 untouched"
assert_eq $a->[2]{value}, 100, "slot 2 mutated"
assert_eq $a->[3]{value}, 0, "slot 3 untouched"
assert_eq scalar(@{$a->[0]{log}}), 0, "slot 0 log empty"
assert_eq scalar(@{$a->[2]{log}}), 1, "slot 2 log has tag"

# id field per slot
for my $i (0..4) {
    assert_eq $a->[$i]{id}, $i + 1, sprintf("slot %d id = %d", $i, $i + 1)
}

# Anti-pattern: shared reference. Mutating one slot mutates *all*.
my $b = Rosetta::DistinctObj::make_shared_bug(3)
$b->[0]{value} = 99
assert_eq $b->[1]{value}, 99, "shared bug: slot 1 also 99"
assert_eq $b->[2]{value}, 99, "shared bug: slot 2 also 99"

# Pipe form
3 |> Rosetta::DistinctObj::make_distinct |> fn { len(@$_) } |> assert_eq(3, "pipe count")

test_run
