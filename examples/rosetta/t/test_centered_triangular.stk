#!/usr/bin/env stryke
# Rosetta Code: Centered triangular numbers

fn Rosetta::CenteredTriangular::compute($n) {
    int((3 * $n * $n + 3 * $n + 2) / 2)
}

assert_eq Rosetta::CenteredTriangular::compute(1), 4, "CT 1"
assert_eq Rosetta::CenteredTriangular::compute(2), 10, "CT 2"
assert_eq Rosetta::CenteredTriangular::compute(3), 19, "CT 3"
assert_eq Rosetta::CenteredTriangular::compute(4), 31, "CT 4"

10 |> Rosetta::CenteredTriangular::compute |> assert_eq(166, "pipe centered triangular")

test_run
