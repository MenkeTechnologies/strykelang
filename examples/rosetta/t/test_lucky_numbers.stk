#!/usr/bin/env stryke
# Rosetta Code: Lucky numbers

fn Rosetta::LuckyNumbers::generate($max) {
    # Start with odd numbers only
    var @l = grep { _ % 2 == 1 } (1:$max)
    var $idx = 1
    
    while ($idx < len(@l)) {
        val $skip = $l[$idx]
        if ($skip > len(@l)) { last }
        
        var @next_nums
        for (var $i = 0; $i < len(@l); $i++) {
            if (($i + 1) % $skip != 0) {
                push @next_nums, $l[$i]
            }
        }
        @l = @next_nums
        $idx++
    }
    \@l
}

val $res = Rosetta::LuckyNumbers::generate(50)
assert_eq join(",", @$res), "1,3,7,9,13,15,21,25,31,33,37,43,49", "Lucky numbers up to 50"

# The 25th lucky number is 111 (per OEIS A000959)
val $res_large = Rosetta::LuckyNumbers::generate(150)
assert_eq $res_large->[24], 111, "25th lucky number"

test_run
