#!/usr/bin/env stryke
# Rosetta Code: Sum of divisors

fn Rosetta::SumDivisors::get($n) {
    my @res = 1:$n |> grep { $n % $_ == 0 }
    @res
}

fn Rosetta::SumDivisors::sum($n) {
    my @d = Rosetta::SumDivisors::get($n)
    my $sum = 0
    for my $v (@d) { $sum = $sum + $v }
    $sum
}

assert_eq Rosetta::SumDivisors::sum(6), 12, "sum divisors 6"
assert_eq Rosetta::SumDivisors::sum(12), 28, "sum divisors 12"

6 |> Rosetta::SumDivisors::sum |> assert_eq(12, "pipe sum divisors")

test_run
