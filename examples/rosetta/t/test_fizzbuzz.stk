#!/usr/bin/env stryke
# Rosetta Code: FizzBuzz

fn Rosetta::FizzBuzz::compute($n) {
    if ($n % 15 == 0) {
        "FizzBuzz"
    } elsif ($n % 3 == 0) {
        "Fizz"
    } elsif ($n % 5 == 0) {
        "Buzz"
    } else {
        $n
    }
}

fn Rosetta::FizzBuzz::list($max) {
    # Using thread macro and pmap for a parallel fizzbuzz
    ~> 1:$max pmap { Rosetta::FizzBuzz::compute(_) }
}

assert_eq Rosetta::FizzBuzz::compute(1), 1, "fizzbuzz(1)"
assert_eq Rosetta::FizzBuzz::compute(3), "Fizz", "fizzbuzz(3)"
assert_eq Rosetta::FizzBuzz::compute(5), "Buzz", "fizzbuzz(5)"
assert_eq Rosetta::FizzBuzz::compute(15), "FizzBuzz", "fizzbuzz(15)"
assert_eq Rosetta::FizzBuzz::compute(7), 7, "fizzbuzz(7)"

my @list = Rosetta::FizzBuzz::list(15)
assert_eq $list[2], "Fizz", "list[3] is Fizz"
assert_eq $list[14], "FizzBuzz", "list[15] is FizzBuzz"

test_run
