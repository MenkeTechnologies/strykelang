#!/usr/bin/env stryke
# Rosetta Code: Pseudo-random numbers/Combined recursive generator MRG32k3a

fn Rosetta::MRG::new($seed) {
    { x1 => [$seed, 0, 0], x2 => [$seed, 0, 0] }
}

fn Rosetta::MRG::posmod($x, $m) { (($x % $m) + $m) % $m }

fn Rosetta::MRG::next_int($state) {
    val $m1 = (2 ** 32) - 209
    val $m2 = (2 ** 32) - 22853

    val $x1i = Rosetta::MRG::posmod(1403580 * $state->{x1}[1] - 810728 * $state->{x1}[2], $m1)
    val $x2i = Rosetta::MRG::posmod(527612 * $state->{x2}[0] - 1370589 * $state->{x2}[2], $m2)
    $state->{x1} = [$x1i, $state->{x1}[0], $state->{x1}[1]]
    $state->{x2} = [$x2i, $state->{x2}[0], $state->{x2}[1]]
    val $z = Rosetta::MRG::posmod($x1i - $x2i, $m1)
    $z + 1
}

fn Rosetta::MRG::hist5($seed, $n) {
    val $rng = Rosetta::MRG::new($seed)
    val $m1 = (2 ** 32) - 209
    val $d  = $m1 + 1
    var @h = (0, 0, 0, 0, 0)
    for val $i (1:$n) {
        val $x = Rosetta::MRG::next_int($rng)
        val $bucket = int(($x * 5) / $d)
        $h[$bucket]++
    }
    \@h
}

val $rng = Rosetta::MRG::new(1234567)
var @vals
for val $i (1:5) { push @vals, Rosetta::MRG::next_int($rng) }

assert_eq join(",", @vals), "1459213977,2827710106,4245671317,3877608661,2595287583", "first five integers"
assert_eq join(",", @{Rosetta::MRG::hist5(987654321, 100000)}), "20002,20060,19948,20059,19931", "histogram counts"

test_run
