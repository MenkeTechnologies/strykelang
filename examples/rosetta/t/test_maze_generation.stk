#!/usr/bin/env stryke
# Rosetta Code: Maze generation
# Generate a random rectangular maze using recursive backtracking
# (depth-first search). The maze is represented as a w × h grid of
# cells; each cell tracks the four wall booleans (N, S, E, W).
# Initial state: all walls up. Carve a wall down whenever we cross
# from one cell to a previously-unvisited neighbour.

fn Rosetta::MazeGen::new_grid($w, $h) {
    var @grid
    for val $r (~> 1:$h) {
        var @row
        for val $c (~> 1:$w) {
            push @row, { N => 1, S => 1, E => 1, W => 1, visited => 0 }
        }
        push @grid, \@row
    }
    \@grid
}

fn Rosetta::MazeGen::carve($grid, $w, $h) {
    var @stack = ([0, 0])
    $grid->[0][0]{visited} = 1
    while (len(@stack) > 0) {
        val $top = $stack[-1]
        var ($r, $c) = @$top
        var @candidates
        push @candidates, ["N", -1, 0] if $r > 0      && !$grid->[$r - 1][$c]{visited}
        push @candidates, ["S",  1, 0] if $r < $h - 1 && !$grid->[$r + 1][$c]{visited}
        push @candidates, ["W",  0, -1] if $c > 0      && !$grid->[$r][$c - 1]{visited}
        push @candidates, ["E",  0,  1] if $c < $w - 1 && !$grid->[$r][$c + 1]{visited}
        if (len(@candidates) == 0) {
            pop @stack
            next
        }
        val $pick = $candidates[int(rand(len(@candidates)))]
        val ($dir, $dr, $dc) = @$pick
        val $nr = $r + $dr
        val $nc = $c + $dc
        $grid->[$r][$c]{$dir} = 0
        val %opp = (N => "S", S => "N", E => "W", W => "E")
        $grid->[$nr][$nc]{$opp{$dir}} = 0
        $grid->[$nr][$nc]{visited} = 1
        push @stack, [$nr, $nc]
    }
    $grid
}

fn Rosetta::MazeGen::generate($w, $h) {
    val $g = Rosetta::MazeGen::new_grid($w, $h)
    Rosetta::MazeGen::carve($g, $w, $h)
}

fn Rosetta::MazeGen::reachable($grid, $w, $h) {
    # BFS from (0,0) to count reachable cells
    var @queue = ([0, 0])
    var %seen
    $seen{"0,0"} = 1
    while (len(@queue) > 0) {
        val $cell = shift @queue
        val ($r, $c) = @$cell
        var @neighbours
        push @neighbours, [$r - 1, $c] if !$grid->[$r][$c]{N}
        push @neighbours, [$r + 1, $c] if !$grid->[$r][$c]{S}
        push @neighbours, [$r, $c - 1] if !$grid->[$r][$c]{W}
        push @neighbours, [$r, $c + 1] if !$grid->[$r][$c]{E}
        for val $n (@neighbours) {
            val $key = "$n->[0],$n->[1]"
            next if exists $seen{$key}
            $seen{$key} = 1
            push @queue, $n
        }
    }
    len(keys %seen)
}

# Generation produces a connected maze
val $maze = Rosetta::MazeGen::generate(5, 5)
assert_eq Rosetta::MazeGen::reachable($maze, 5, 5), 25, "5×5 fully connected"

# Larger maze
val $big = Rosetta::MazeGen::generate(10, 10)
assert_eq Rosetta::MazeGen::reachable($big, 10, 10), 100, "10×10 fully connected"

# Every cell visited
var $all_visited = 1
for val $row (@$big) {
    for val $cell (@$row) {
        $all_visited = 0 if !$cell->{visited}
    }
}
assert_ok $all_visited, "every cell visited during carve"

# Walls reciprocal: if cell A has its E wall down, cell to its right has W wall down
var $reciprocal_ok = 1
for val $r (0:9) {
    for val $c (0:8) {
        val $a = $maze_cell_e_open = !$big->[$r][$c]{E}
        val $b = !$big->[$r][$c + 1]{W}
        $reciprocal_ok = 0 if $a != $b
    }
}
assert_ok $reciprocal_ok, "wall reciprocity holds"

# 1×1 maze: still works
val $tiny = Rosetta::MazeGen::generate(1, 1)
assert_eq Rosetta::MazeGen::reachable($tiny, 1, 1), 1, "1×1 trivially connected"

# Pipe form
val $piped = Rosetta::MazeGen::generate(3, 3)
assert_eq Rosetta::MazeGen::reachable($piped, 3, 3), 9, "pipe 3×3 connected"

test_run
