#!/usr/bin/env stryke
# Rosetta Code: Chaos game

fn Rosetta::ChaosGame::generate($iterations) {
    # Equilateral triangle vertices
    val @vertices = ([0, 0], [1, 0], [0.5, 0.866])
    
    var @points
    var $curr = [0.5, 0.5] # Start point
    push @points, $curr
    
    for (1:$iterations) {
        val $v = @vertices[int(rand(3))]
        val $nx = ($curr->[0] + $v->[0]) / 2.0
        val $ny = ($curr->[1] + $v->[1]) / 2.0
        $curr = [$nx, $ny]
        push @points, $curr
    }
    \@points
}

val $pts = Rosetta::ChaosGame::generate(100)
assert_eq len(@$pts), 101, "101 points generated"

# All points should be within the bounding box [0, 1] x [0, 1]
var $all_in = 1
for val $p (@$pts) {
    if ($p->[0] < 0 || $p->[0] > 1 || $p->[1] < 0 || $p->[1] > 1) {
        $all_in = 0
    }
}
assert_ok $all_in, "all points within bounds"

test_run
