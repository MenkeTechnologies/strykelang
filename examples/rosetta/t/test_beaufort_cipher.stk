#!/usr/bin/env stryke
# Rosetta Code: Beaufort cipher

fn Rosetta::Beaufort::codec($text, $key) {
    val $t = $text |> uc() |> { _ =~ s/[^A-Z]//gr }
    val $k = $key |> uc() |> { _ =~ s/[^A-Z]//gr }
    return "" if len($k) == 0
    
    val @t_chars = $t |> chars()
    val @k_chars = $k |> chars()
    val $k_len = len(@k_chars)
    
    val @res = ~> 0:(len(@t_chars)-1) map {
        val $p_val = ord($t_chars[_]) - ord("A")
        val $k_val = ord($k_chars[_ % $k_len]) - ord("A")

        var $c_val = ($k_val - $p_val) % 26
        if ($c_val < 0) { $c_val += 26 }
        chr($c_val + ord("A"))
    }
    
    join("", @res)
}

val $t = "DEFENDTHEEASTWALLOFTHECASTLE"
val $key = "FORTIFICATION"
val $enc = Rosetta::Beaufort::codec($t, $key)

# We will just verify it's reciprocal
assert_eq Rosetta::Beaufort::codec($enc, $key), $t, "decode with Beaufort is reciprocal"
assert_eq len($enc), len($t), "same length"

test_run
