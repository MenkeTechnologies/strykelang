#!/usr/bin/env stryke
# Rosetta Code: Hofstadter Figure-Figure sequences

fn Rosetta::HofstadterFF::compute($n) {
    my @r = (0, 1)
    my @s = (0, 2)
    my %in_r = (1 => 1)
    
    for my $i (2..$n) {
        my $next_r = $r[$i-1] + $s[$i-1]
        push @r, $next_r
        $in_r{$next_r} = 1
        
        # S is the sequence of integers not in R
        my $last_s = $s[-1]
        my $next_s = $last_s + 1
        while (exists $in_r{$next_s}) {
            $next_s++
        }
        push @s, $next_s
    }
    ([@r], [@s])
}

my ($r_ref, $s_ref) = Rosetta::HofstadterFF::compute(10)
assert_eq join(",", @$r_ref), "0,1,3,7,12,18,26,35,45,56,69", "R sequence up to n=10"
assert_eq join(",", @$s_ref), "0,2,4,5,6,8,9,10,11,13,14", "S sequence up to n=10"

test_run
