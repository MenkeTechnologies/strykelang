#!/usr/bin/env stryke
# Rosetta Code: Ludic numbers

fn Rosetta::Ludic::generate($n) {
    var @ludics = (1)
    var @nums = (2:$n)
    while (len(@nums) > 0) {
        val $skip = shift @nums
        push @ludics, $skip
        if (len(@nums) == 0) { last }
        var @next_nums = ()
        for val $i (0..len(@nums)-1) {
            if (($i + 1) % $skip != 0) {
                push @next_nums, $nums[$i]
            }
        }
        @nums = @next_nums
        if (len(@ludics) > 100) { last }
    }
    \@ludics
}

val $res = Rosetta::Ludic::generate(25)
assert_eq join(",", @$res), "1,2,3,5,7,11,13,17,23,25", "Ludic up to 25"

val $res2 = Rosetta::Ludic::generate(200)
assert_eq $res2->[24], 107, "25th Ludic is 107"

test_run
