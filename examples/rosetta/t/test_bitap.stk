#!/usr/bin/env stryke
# Rosetta Code: Bitap algorithm

fn Rosetta::Bitap::solve($text, $pattern) {
    val $m = len($pattern)
    return 0 if $m == 0
    
    val @p_chars = $pattern |> chars()
    var @mask = map { ~0 } 0:255
    
    for (var $i = 0; $i < $m; $i++) {
        val $char_code = ord($p_chars[$i])
        $mask[$char_code] &= ~(1 << $i)
    }
    
    var $r = ~1
    val @t_chars = $text |> chars()
    for (var $i = 0; $i < len(@t_chars); $i++) {
        val $char_code = ord($t_chars[$i])
        $r |= $mask[$char_code]
        $r <<= 1
        
        if (!($r & (1 << $m))) {
            return $i - $m + 1
        }
    }
    
    -1
}

assert_eq Rosetta::Bitap::solve("hello world", "world"), 6, "Bitap find world"
assert_eq Rosetta::Bitap::solve("hello world", "word"), -1, "Bitap not find word"
assert_eq Rosetta::Bitap::solve("stryke is fast", "stryke"), 0, "Bitap find stryke"

test_run
