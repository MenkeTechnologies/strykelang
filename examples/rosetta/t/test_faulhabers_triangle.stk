#!/usr/bin/env stryke
# Rosetta Code: Faulhaber's triangle
# Row n contains the rational coefficients (in increasing power of n)
# of the polynomial Σ_{k=1..N} k^n in N. Returned as [num, den] pairs.

fn Rosetta::Faulhaber::gcd($a, $b) {
    $a = abs($a); $b = abs($b)
    while ($b != 0) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn Rosetta::Faulhaber::reduce($num, $den) {
    my $g = Rosetta::Faulhaber::gcd($num, $den)
    return [$num / $g, $den / $g] if $den > 0
    [-$num / $g, -$den / $g]
}

fn Rosetta::Faulhaber::add_frac($a, $b) {
    my $num = $a->[0] * $b->[1] + $b->[0] * $a->[1]
    my $den = $a->[1] * $b->[1]
    Rosetta::Faulhaber::reduce($num, $den)
}

fn Rosetta::Faulhaber::mul_frac($a, $b) {
    Rosetta::Faulhaber::reduce($a->[0] * $b->[0], $a->[1] * $b->[1])
}

fn Rosetta::Faulhaber::binom($n, $k) {
    return 0 if $k < 0 || $k > $n
    my $r = 1
    for my $i (~> 1:$k) {
        $r = $r * ($n - $i + 1) / $i
    }
    $r
}

fn Rosetta::Faulhaber::bernoulli($n) {
    # Akiyama-Tanigawa algorithm — returns Bernoulli B_n with B_1 = +1/2.
    my @a
    for my $m (~> 0:$n) {
        push @a, [1, $m + 1]
        for (my $j = $m; $j >= 1; $j--) {
            $a[$j - 1] = Rosetta::Faulhaber::mul_frac(
                [$j, 1],
                Rosetta::Faulhaber::add_frac(
                    $a[$j - 1],
                    [-$a[$j]->[0], $a[$j]->[1]]))
        }
    }
    $a[0]
}

fn Rosetta::Faulhaber::row($p) {
    # F[p][k] = (-1)^(p-k) · C(p, k) · B_{p-k} / (p+1) · (p+1) = …
    # Use closed form: 1/(p+1) · Σ_{k=0..p} C(p+1, k) · B_k · N^(p+1-k)
    # The triangle entry for power N^(j+1) (0-indexed in row p) is
    #     C(p+1, p-j) · B_{p-j} / (p+1)
    my @row
    for my $j (0..$p) {
        my $idx = $p - $j
        my $b = Rosetta::Faulhaber::bernoulli($idx)
        my $c = Rosetta::Faulhaber::binom($p + 1, $idx)
        my $term = Rosetta::Faulhaber::mul_frac([$c, 1], $b)
        $term = Rosetta::Faulhaber::mul_frac($term, [1, $p + 1])
        push @row, $term
    }
    \@row
}

fn Rosetta::Faulhaber::row_str($r) {
    join(" ", map { $_->[1] == 1 ? "$_->[0]" : "$_->[0]/$_->[1]" } @$r)
}

# Bernoulli sanity (B_n with B_1 = +1/2)
my $b0 = Rosetta::Faulhaber::bernoulli(0)
assert_eq $b0->[0], 1, "B_0 num"
assert_eq $b0->[1], 1, "B_0 den"

my $b1 = Rosetta::Faulhaber::bernoulli(1)
assert_eq $b1->[0], 1, "B_1 num (+1/2 convention)"
assert_eq $b1->[1], 2, "B_1 den"

my $b2 = Rosetta::Faulhaber::bernoulli(2)
assert_eq $b2->[0], 1, "B_2 num"
assert_eq $b2->[1], 6, "B_2 den"

my $b3 = Rosetta::Faulhaber::bernoulli(3)
assert_eq $b3->[0], 0, "B_3 = 0"

# Faulhaber row 0 (sum of 1..N of N^0 = N): coefficient of N^1 is 1
my $r0 = Rosetta::Faulhaber::row(0)
assert_eq Rosetta::Faulhaber::row_str($r0), "1", "row 0: just 1"

# Row 1: Σ k = N(N+1)/2 = N²/2 + N/2
my $r1 = Rosetta::Faulhaber::row(1)
assert_eq Rosetta::Faulhaber::row_str($r1), "1/2 1/2", "row 1: 1/2, 1/2"

# Row 2: Σ k² = N(N+1)(2N+1)/6 = N³/3 + N²/2 + N/6
my $r2 = Rosetta::Faulhaber::row(2)
assert_eq Rosetta::Faulhaber::row_str($r2), "1/6 1/2 1/3", "row 2: 1/6, 1/2, 1/3"

# Row 3: Σ k³ = (N(N+1)/2)² = N⁴/4 + N³/2 + N²/4
my $r3 = Rosetta::Faulhaber::row(3)
assert_eq Rosetta::Faulhaber::row_str($r3), "0 1/4 1/2 1/4", "row 3: 0, 1/4, 1/2, 1/4"

# Pipe form
2 |> Rosetta::Faulhaber::row |> Rosetta::Faulhaber::row_str |> assert_eq("1/6 1/2 1/3", "pipe row(2)")

test_run
