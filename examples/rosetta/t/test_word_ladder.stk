#!/usr/bin/env stryke
# Rosetta Code: Word ladder

fn Rosetta::WordLadder::is_adjacent($w1, $w2) {
    return 0 if length($w1) != length($w2)
    var $diff = 0
    for val $i (0:length($w1)-1) {
        if (substr($w1, $i, 1) ne substr($w2, $i, 1)) {
            $diff++
            return 0 if $diff > 1
        }
    }
    $diff == 1
}

fn Rosetta::WordLadder::solve($start, $end, $dictionary) {
    return [$start] if $start eq $end
    
    var @queue = ([$start])
    var %visited; $visited{$start} = 1
    
    while (len(@queue) > 0) {
        val $path = shift @queue
        val $word = $path->[len(@$path)-1]
        
        for val $next (@$dictionary) {
            if (!exists $visited{$next} && Rosetta::WordLadder::is_adjacent($word, $next)) {
                val @new_path = (@$path, $next)
                if ($next eq $end) { return \@new_path }
                $visited{$next} = 1
                push @queue, \@new_path
            }
        }
    }
    undef
}

# Test with a small dictionary
val @dict = qw(boy bay may man mat hat cat)
val $res = Rosetta::WordLadder::solve("boy", "cat", \@dict)

assert_ok defined($res), "Found a path from boy to cat"
assert_eq join("->", @$res), "boy->bay->may->mat->cat", "Correct path"

# Test another path
val $res2 = Rosetta::WordLadder::solve("hat", "man", \@dict)
assert_eq join("->", @$res2), "hat->mat->man", "Correct path for hat->man"

# Test no path
val $res3 = Rosetta::WordLadder::solve("boy", "hat", ["boy", "bay"])
assert_ok !defined($res3), "No path found when dictionary is small"

test_run
