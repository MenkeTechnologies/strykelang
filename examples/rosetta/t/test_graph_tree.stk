#!/usr/bin/env stryke
# Rosetta Code: Identify if a Graph is a Tree

fn Rosetta::GraphTree::check($adj) {
    val @nodes = keys %$adj
    return 1 if len(@nodes) == 0
    
    var %visited
    var @q = ($nodes[0])
    $visited{$nodes[0]} = 1
    var $edges = 0
    
    while (len(@q)) {
        val $u = shift @q
        for val $v (@{$adj->{$u}}) {
            $edges = $edges + 1
            if (!$visited{$v}) {
                $visited{$v} = 1
                push @q, $v
            }
        }
    }
    
    len(keys %visited) == len(@nodes) && ($edges / 2) == (len(@nodes) - 1)
}

val $tree = { A => ["B", "C"], B => ["A"], C => ["A"] }
assert_ok Rosetta::GraphTree::check($tree), "simple tree"
val $not_tree = { A => ["B", "C"], B => ["A", "C"], C => ["A", "B"] }
assert_ok !Rosetta::GraphTree::check($not_tree), "triangle not a tree"

test_run
