#!/usr/bin/env stryke
# Rosetta Code: Abbreviated Sunday names

fn abbreviate_days {
    my @days = ("Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday")
    @days |> map { substr($_, 0, 3) }
}

my @abbrev = abbreviate_days()
assert_eq join(",", @abbrev), "Sun,Mon,Tue,Wed,Thu,Fri,Sat", "abbrev days"

test_run
