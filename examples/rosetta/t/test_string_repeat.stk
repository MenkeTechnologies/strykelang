#!/usr/bin/env stryke
# Rosetta Code: Repeat a String

fn my_repeat_string($s, $n) {
    $s x $n
}

fn repeat_array($n, @arr) {
    my @result
    push @result, @arr for 1..$n
    @result
}

assert_eq my_repeat_string("ha", 3), "hahaha", "repeat ha 3x"
assert_eq my_repeat_string("*", 5), "*****", "repeat * 5x"
assert_eq my_repeat_string("abc", 1), "abc", "repeat 1x"
assert_eq my_repeat_string("test", 0), "", "repeat 0x"

assert_eq "=" x 10, "==========", "x operator"
assert_eq "-" x 20, "--------------------", "line of dashes"

my @rep = repeat_array(3, 1, 2)
assert_eq join(",", @rep), "1,2,1,2,1,2", "repeat array"

my @single = repeat_array(4, 0)
assert_eq join(",", @single), "0,0,0,0", "repeat single"

test_run
