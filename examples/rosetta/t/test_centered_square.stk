#!/usr/bin/env stryke
# Rosetta Code: Centered square numbers

fn Rosetta::CenteredSquare::compute($n) {
    $n * $n + ($n + 1) * ($n + 1)
}

assert_eq Rosetta::CenteredSquare::compute(0), 1, "CS 0"
assert_eq Rosetta::CenteredSquare::compute(1), 5, "CS 1"
assert_eq Rosetta::CenteredSquare::compute(2), 13, "CS 2"
assert_eq Rosetta::CenteredSquare::compute(3), 25, "CS 3"

10 |> Rosetta::CenteredSquare::compute |> assert_eq(221, "pipe centered square")

test_run
