#!/usr/bin/env stryke
# Rosetta Code: Gauss-Legendre algorithm for pi (quadratic convergence)

fn Rosetta::GaussLegendre::pi($iters) {
    my $a = 1.0
    my $b = 1.0 / sqrt(2.0)
    my $t = 0.25
    my $p = 1.0
    for my $i (1..$iters) {
        my $a_next = ($a + $b) / 2.0
        my $b_next = sqrt($a * $b)
        my $t_next = $t - $p * (($a - $a_next) ** 2)
        my $p_next = 2 * $p
        $a = $a_next
        $b = $b_next
        $t = $t_next
        $p = $p_next
    }
    (($a + $b) ** 2) / (4 * $t)
}

my $real_pi = 4 * atan2(1, 1)

# After 1 iter, ~3 digits accurate
my $pi1 = Rosetta::GaussLegendre::pi(1)
assert_ok abs($pi1 - $real_pi) < 2e-3, "1 iter within 2e-3 ($pi1)"

# After 3 iters, ~14 digits (double-precision limit reached fast)
my $pi3 = Rosetta::GaussLegendre::pi(3)
assert_ok abs($pi3 - $real_pi) < 1e-13, "3 iters near double-precision pi ($pi3)"

# After 5 iters, fully saturated double precision
my $pi5 = Rosetta::GaussLegendre::pi(5)
assert_ok abs($pi5 - $real_pi) < 1e-15, "5 iters at double-precision limit ($pi5)"

# Convergence: each iter strictly reduces error (or stays at machine epsilon)
my $err_prev = abs(Rosetta::GaussLegendre::pi(1) - $real_pi)
for my $k (2..4) {
    my $err = abs(Rosetta::GaussLegendre::pi($k) - $real_pi)
    assert_ok($err <= $err_prev + 1e-16, "iter $k error not worse than iter " . ($k - 1))
    $err_prev = $err
}

# 0 iterations -> initial guess (a+b)^2 / 4t with starting values
my $pi0 = Rosetta::GaussLegendre::pi(0)
my $expected_0 = ((1.0 + 1.0/sqrt(2.0)) ** 2) / 1.0
assert_ok abs($pi0 - $expected_0) < 1e-12, "0 iter returns initial estimate"

test_run
