#!/usr/bin/env stryke
# Rosetta Code: ABC Problem

fn Rosetta::ABCProblem::check_recursive($chars_ref, $blocks_ref) {
    if (len(@$chars_ref) == 0) {
        return 1
    }
    
    my @chars = @$chars_ref
    my @blocks = @$blocks_ref
    my $c = shift @chars
    
    for my $i (0..len(@blocks)-1) {
        if (index($blocks[$i], $c) >= 0) {
            my @remaining = @blocks
            splice(@remaining, $i, 1)
            if (Rosetta::ABCProblem::check_recursive(\@chars, \@remaining)) {
                return 1
            }
        }
    }
    0
}

fn Rosetta::ABCProblem::check($word, @blocks) {
    my @chars = ~> $word lc chars
    my @b_list = ~> @blocks map { lc(_) }
    Rosetta::ABCProblem::check_recursive(\@chars, \@b_list)
}

my @blocks = ("BO", "XK", "DQ", "CP", "NA", "GT", "RE", "TG", "QD", "FS", "JW", "HU", "VI", "AN", "OB", "ER", "FS", "LY", "PC", "ZM")

assert_ok Rosetta::ABCProblem::check("A", @blocks), "can make A"
assert_ok Rosetta::ABCProblem::check("BARK", @blocks), "can make BARK"
assert_ok !Rosetta::ABCProblem::check("BOOK", @blocks), "cannot make BOOK (needs two O blocks)"
assert_ok Rosetta::ABCProblem::check("TREAT", @blocks), "can make TREAT"
assert_ok !Rosetta::ABCProblem::check("COMMON", @blocks), "cannot make COMMON"
assert_ok Rosetta::ABCProblem::check("SQUAD", @blocks), "can make SQUAD"
assert_ok Rosetta::ABCProblem::check("CONFUSE", @blocks), "can make CONFUSE"

"BARK" |> Rosetta::ABCProblem::check(@blocks) |> assert_ok("pipe BARK")

test_run
