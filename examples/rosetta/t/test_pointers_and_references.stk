#!/usr/bin/env stryke
# Rosetta Code: Pointers and references

fn Rosetta::Pointers::demo() {
    val $val = 42
    
    # Create a reference to $val
    var $ref = \$val
    
    # Modify $val through the reference
    $$ref = 100
    
    # Assert that $val was modified
    assert_eq $val, 100, "Value modified through reference"
    
    # References to complex types
    val @arr = (1, 2, 3)
    var $arr_ref = \@arr
    
    $arr_ref->[0] = 99
    assert_eq $arr[0], 99, "Array modified through reference"
}

Rosetta::Pointers::demo()

test_run
