#!/usr/bin/env stryke
# Rosetta Code: Digit fifth powers

fn Rosetta::DigitFifthPowers::sum($n) {
    var $sum = 0
    val @digits = ~> "$n" chars map {int}
    for val $d (@digits) { $sum += $d ** 5 }
    $sum
}

fn Rosetta::DigitFifthPowers::check($n) {
    Rosetta::DigitFifthPowers::sum($n) == $n
}

assert_ok Rosetta::DigitFifthPowers::check(4150), "4150 is sum of 5th powers"
assert_ok Rosetta::DigitFifthPowers::check(4151), "4151 is sum of 5th powers"
assert_ok !Rosetta::DigitFifthPowers::check(123), "123 is not"

4150 |> Rosetta::DigitFifthPowers::check |> assert_ok("pipe fifth powers")

test_run
