#!/usr/bin/env stryke
# Rosetta Code: Self-descriptive numbers

fn Rosetta::SelfDescriptive::check($n) {
    val $s = str($n)
    val @chars = split //, $s
    val $len = len(@chars)

    for val $i (0:$len-1) {
        val $digit_at_pos_i = int(substr($s, $i, 1))
        val $char_to_count = str($i)
        var $count = 0
        for val $char (@chars) {
            if ($char eq $char_to_count) {
                $count = $count + 1
            }
        }
        if ($digit_at_pos_i != $count) {
            return 0 # Not self-descriptive
        }
    }
    1 # Is self-descriptive
}

assert_eq Rosetta::SelfDescriptive::check(2020), 1, "2020 is self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(1210), 1, "1210 is self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(21200), 1, "21200 is self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(3211000), 1, "3211000 is self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(42101000), 1, "42101000 is self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(1), 0, "1 is not self-descriptive"

# Check for numbers that are not self-descriptive
assert_eq Rosetta::SelfDescriptive::check(11), 0, "11 is not self-descriptive"
assert_eq Rosetta::SelfDescriptive::check(22), 0, "22 is not self-descriptive"

test_run
