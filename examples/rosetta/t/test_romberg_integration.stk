#!/usr/bin/env stryke
# Rosetta Code: Romberg integration — Richardson extrapolation applied
# to the trapezoidal rule. Produces a triangular table R[i][j] where
# R[i][j] is the (j+1)-th order estimate using 2^i subintervals.

fn Rosetta::Romberg::compute($f, $a, $b, $n) {
    my @r
    my $h = $b - $a
    push @r, [0.5 * $h * ($f->($a) + $f->($b))]

    for my $i (~> 1:$n) {
        $h /= 2
        my $sum = 0
        my $cnt = 1 << ($i - 1)
        for my $k (~> 1:$cnt) { $sum += $f->($a + (2 * $k - 1) * $h) }
        my @row
        push @row, 0.5 * $r[$i - 1][0] + $sum * $h
        for my $j (~> 1:$i) {
            my $denom = (1 << (2 * $j)) - 1
            push @row, $row[$j - 1] + ($row[$j - 1] - $r[$i - 1][$j - 1]) / $denom
        }
        push @r, \@row
    }
    \@r
}

fn Rosetta::Romberg::integrate($f, $a, $b, $n) {
    my $r = Rosetta::Romberg::compute($f, $a, $b, $n)
    $r->[$n][$n]
}

fn Rosetta::Romberg::approx_eq($x, $y, $eps) { abs($x - $y) < $eps }

# ∫_0^1 x^2 dx = 1/3
my $f_sq = fn ($x) { $x * $x }
my $i1 = Rosetta::Romberg::integrate($f_sq, 0, 1, 4)
assert_ok Rosetta::Romberg::approx_eq($i1, 1/3, 1e-10), "x^2 on [0,1] = 1/3"

# ∫_0^pi sin(x) dx = 2
my $f_sin = fn ($x) { sin($x) }
my $i2 = Rosetta::Romberg::integrate($f_sin, 0, atan2(0, -1), 5)
assert_ok Rosetta::Romberg::approx_eq($i2, 2.0, 1e-10), "sin on [0,π] = 2"

# ∫_0^1 e^x dx = e - 1
my $f_exp = fn ($x) { exp($x) }
my $i3 = Rosetta::Romberg::integrate($f_exp, 0, 1, 5)
assert_ok Rosetta::Romberg::approx_eq($i3, exp(1) - 1, 1e-10), "e^x on [0,1] = e - 1"

# ∫_1^2 1/x dx = ln 2
my $f_inv = fn ($x) { 1 / $x }
my $i4 = Rosetta::Romberg::integrate($f_inv, 1, 2, 5)
assert_ok Rosetta::Romberg::approx_eq($i4, log(2), 1e-10), "1/x on [1,2] = ln 2"

# ∫_0^1 4/(1+x^2) dx = π
my $f_pi = fn ($x) { 4 / (1 + $x * $x) }
my $pi = Rosetta::Romberg::integrate($f_pi, 0, 1, 7)
assert_ok Rosetta::Romberg::approx_eq($pi, atan2(0, -1), 1e-10), "4/(1+x²) on [0,1] = π"

# Triangular table: 1×1 base case = trapezoid only
my $r0 = Rosetta::Romberg::compute($f_sq, 0, 1, 0)
assert_eq len(@$r0), 1, "n=0 yields 1 row"
assert_ok Rosetta::Romberg::approx_eq($r0->[0][0], 0.5, 1e-12), "n=0 = trapezoid 0.5"

test_run
