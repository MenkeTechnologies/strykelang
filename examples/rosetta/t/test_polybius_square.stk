#!/usr/bin/env stryke
# Rosetta Code: Polybius square (5x5 grid, I/J share a cell)

fn Rosetta::Polybius::build() {
    var @grid
    val $alpha = "ABCDEFGHIKLMNOPQRSTUVWXYZ"   # no J
    for val $r (0:4) {
        var @row
        for val $c (0:4) {
            push @row, substr($alpha, $r * 5 + $c, 1)
        }
        push @grid, \@row
    }
    \@grid
}

fn Rosetta::Polybius::encode($plain) {
    val $grid = Rosetta::Polybius::build()
    val $alpha = "ABCDEFGHIKLMNOPQRSTUVWXYZ"
    var $out = ""
    val $up = uc($plain)
    for val $i (0..length($up)-1) {
        var $ch = substr($up, $i, 1)
        $ch = "I" if $ch eq "J"
        val $idx = index($alpha, $ch)
        next if $idx < 0
        val $r = int($idx / 5) + 1
        val $c = ($idx % 5) + 1
        $out .= "$r$c"
    }
    $out
}

fn Rosetta::Polybius::decode($cipher) {
    val $grid = Rosetta::Polybius::build()
    var $out = ""
    var $i = 0
    while ($i + 1 < length($cipher)) {
        val $r = int(substr($cipher, $i, 1)) - 1
        val $c = int(substr($cipher, $i + 1, 1)) - 1
        $out .= $grid->[$r][$c]
        $i += 2
    }
    $out
}

# Single letters
assert_eq Rosetta::Polybius::encode("A"), "11", "A -> 11"
assert_eq Rosetta::Polybius::encode("Z"), "55", "Z -> 55"
assert_eq Rosetta::Polybius::encode("K"), "25", "K -> 25"
assert_eq Rosetta::Polybius::encode("J"), "24", "J merged with I -> 24"

# Round-trip
val $enc = Rosetta::Polybius::encode("HELLO")
assert_eq $enc, "2315313134", "HELLO encoded"
assert_eq Rosetta::Polybius::decode($enc), "HELLO", "HELLO round-trip"

# Non-alpha characters skipped
assert_eq Rosetta::Polybius::encode("HI THERE"), "23244423154215", "spaces ignored"

# Lowercase normalised
assert_eq Rosetta::Polybius::encode("abc"), "111213", "lowercase encoded same as upper"

test_run
