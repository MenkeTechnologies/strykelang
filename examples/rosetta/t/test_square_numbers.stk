#!/usr/bin/env stryke
# Rosetta Code: Perfect square

fn Rosetta::Square::check($n) {
    if ($n < 0) {
        0
    } else {
        my $root = int(sqrt($n))
        $root * $root == $n
    }
}

assert_ok Rosetta::Square::check(0), "0 is square"
assert_ok Rosetta::Square::check(1), "1 is square"
assert_ok Rosetta::Square::check(4), "4 is square"
assert_ok Rosetta::Square::check(9), "9 is square"
assert_ok Rosetta::Square::check(100), "100 is square"
assert_ok !Rosetta::Square::check(2), "2 is not"
assert_ok !Rosetta::Square::check(3), "3 is not"
assert_ok !Rosetta::Square::check(-1), "-1 is not"

100 |> Rosetta::Square::check |> assert_ok("pipe square")

test_run
