#!/usr/bin/env stryke
# Rosetta Code: Perfect square

fn my_is_square($n) {
    if ($n < 0) {
        0
    } else {
        my $root = int(sqrt($n))
        $root * $root == $n
    }
}

assert_ok my_is_square(0), "0 is square"
assert_ok my_is_square(1), "1 is square"
assert_ok my_is_square(4), "4 is square"
assert_ok my_is_square(9), "9 is square"
assert_ok my_is_square(100), "100 is square"
assert_ok !my_is_square(2), "2 is not"
assert_ok !my_is_square(3), "3 is not"
assert_ok !my_is_square(-1), "-1 is not"

100 |> my_is_square |> assert_ok("pipe square")

test_run
