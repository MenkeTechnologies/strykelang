#!/usr/bin/env stryke
# Rosetta Code: Determinant

fn det2x2($m) {
    $m->[0]->[0] * $m->[1]->[1] - $m->[0]->[1] * $m->[1]->[0]
}

fn det3x3($m) {
    my $a = $m->[0]->[0]
    my $b = $m->[0]->[1]
    my $c = $m->[0]->[2]
    my $d = $m->[1]->[0]
    my $e = $m->[1]->[1]
    my $f = $m->[1]->[2]
    my $g = $m->[2]->[0]
    my $h = $m->[2]->[1]
    my $i = $m->[2]->[2]
    
    $a * ($e * $i - $f * $h) - $b * ($d * $i - $f * $g) + $c * ($d * $h - $e * $g)
}

my $m2 = [[1, 2], [3, 4]]
assert_eq det2x2($m2), -2, "det 2x2"

my $m3 = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
assert_eq det3x3($m3), 0, "det 3x3 (singular)"

my $m3b = [[6, 1, 1], [4, -2, 5], [2, 8, 7]]
assert_eq det3x3($m3b), -306, "det 3x3"

test_run
