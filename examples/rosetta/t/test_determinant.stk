#!/usr/bin/env stryke
# Rosetta Code: Determinant

fn Rosetta::Determinant::det2x2($m) {
    $m->[0]->[0] * $m->[1]->[1] - $m->[0]->[1] * $m->[1]->[0]
}

fn Rosetta::Determinant::det3x3($m) {
    val $a = $m->[0]->[0]
    val $b = $m->[0]->[1]
    val $c = $m->[0]->[2]
    val $d = $m->[1]->[0]
    val $e = $m->[1]->[1]
    val $f = $m->[1]->[2]
    val $g = $m->[2]->[0]
    val $h = $m->[2]->[1]
    val $i = $m->[2]->[2]
    
    $a * ($e * $i - $f * $h) - $b * ($d * $i - $f * $g) + $c * ($d * $h - $e * $g)
}

val $m2 = [[1, 2], [3, 4]]
assert_eq Rosetta::Determinant::det2x2($m2), -2, "det 2x2"

val $m3 = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
assert_eq Rosetta::Determinant::det3x3($m3), 0, "det 3x3 (singular)"

val $m3b = [[6, 1, 1], [4, -2, 5], [2, 8, 7]]
assert_eq Rosetta::Determinant::det3x3($m3b), -306, "det 3x3"

test_run
