#!/usr/bin/env stryke
# Rosetta Code: Zumkeller numbers — divisors of n can be partitioned into
# two disjoint sets with equal sums.

fn Rosetta::Zumkeller::divisors($n) {
    my @d
    my $i = 1
    while ($i * $i <= $n) {
        if ($n % $i == 0) {
            push @d, $i
            push @d, int($n / $i) if $i * $i != $n
        }
        $i += 1
    }
    \@d
}

fn Rosetta::Zumkeller::can_split($divs, $target, $idx, $cache) {
    return 1 if $target == 0
    return 0 if $target < 0
    return 0 if $idx >= scalar(@$divs)
    my $key = "$idx:$target"
    return $cache->{$key} if exists $cache->{$key}
    my $with    = Rosetta::Zumkeller::can_split($divs, $target - $divs->[$idx], $idx + 1, $cache)
    my $without = Rosetta::Zumkeller::can_split($divs, $target, $idx + 1, $cache)
    my $result = ($with || $without) ? 1 : 0
    $cache->{$key} = $result
    $result
}

fn Rosetta::Zumkeller::is_zumkeller($n) {
    my $divs = Rosetta::Zumkeller::divisors($n)
    my $sum = 0
    for my $d (@$divs) { $sum += $d }
    return 0 if $sum % 2 != 0
    my %cache
    Rosetta::Zumkeller::can_split($divs, int($sum / 2), 0, \%cache)
}

fn Rosetta::Zumkeller::list($limit) {
    1:$limit |> grep { Rosetta::Zumkeller::is_zumkeller($_) }
}

# OEIS A083207: 6, 12, 20, 24, 28, 30, 40, 42, 48, 54, 56, 60, 66, 70, 78, 80, 84, 88, 90, 96
my @first20 = Rosetta::Zumkeller::list(96)
assert_eq join(",", @first20),
    "6,12,20,24,28,30,40,42,48,54,56,60,66,70,78,80,84,88,90,96",
    "first 20 Zumkeller numbers"

assert_ok Rosetta::Zumkeller::is_zumkeller(6),  "6 is Zumkeller (1+2+3 == 6)"
assert_ok Rosetta::Zumkeller::is_zumkeller(60), "60 is Zumkeller"
assert_ok !Rosetta::Zumkeller::is_zumkeller(8), "8 is not Zumkeller"

test_run
