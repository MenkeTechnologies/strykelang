#!/usr/bin/env stryke
# Rosetta Code: Perceptron

fn Rosetta::Perceptron::train($data, $labels, $learning_rate, $epochs) {
    val $num_features = len(@{$data->[0]})
    var @weights = map { 0.0 } 1:$num_features
    var $bias = 0.0
    
    for (var $e = 0; $e < $epochs; $e++) {
        for (var $i = 0; $i < len(@$data); $i++) {
            val $x = $data->[$i]
            val $y = $labels->[$i]
            
            # Dot product
            var $sum = $bias
            for (var $j = 0; $j < $num_features; $j++) {
                $sum += $x->[$j] * $weights[$j]
            }
            
            # Activation (Heaviside step function)
            val $y_pred = $sum > 0 ? 1 : 0
            
            # Update
            if ($y != $y_pred) {
                val $error = $y - $y_pred
                for (var $j = 0; $j < $num_features; $j++) {
                    $weights[$j] += $error * $learning_rate * $x->[$j]
                }
                $bias += $error * $learning_rate
            }
        }
    }
    
    { weights => \@weights, bias => $bias }
}

fn Rosetta::Perceptron::predict($model, $x) {
    val $weights = $model->{weights}
    val $bias = $model->{bias}
    
    var $sum = $bias
    for (var $j = 0; $j < len(@$weights); $j++) {
        $sum += $x->[$j] * $weights->[$j]
    }
    $sum > 0 ? 1 : 0
}

# OR Gate
val $data = [
    [0, 0],
    [0, 1],
    [1, 0],
    [1, 1]
]
val $labels = [0, 1, 1, 1]

val $model = Rosetta::Perceptron::train($data, $labels, 0.1, 100)

assert_eq Rosetta::Perceptron::predict($model, [0, 0]), 0, "OR(0,0) = 0"
assert_eq Rosetta::Perceptron::predict($model, [0, 1]), 1, "OR(0,1) = 1"
assert_eq Rosetta::Perceptron::predict($model, [1, 0]), 1, "OR(1,0) = 1"
assert_eq Rosetta::Perceptron::predict($model, [1, 1]), 1, "OR(1,1) = 1"

# AND Gate
val $labels_and = [0, 0, 0, 1]
val $model_and = Rosetta::Perceptron::train($data, $labels_and, 0.1, 100)

assert_eq Rosetta::Perceptron::predict($model_and, [0, 0]), 0, "AND(0,0) = 0"
assert_eq Rosetta::Perceptron::predict($model_and, [0, 1]), 0, "AND(0,1) = 0"
assert_eq Rosetta::Perceptron::predict($model_and, [1, 0]), 0, "AND(1,0) = 0"
assert_eq Rosetta::Perceptron::predict($model_and, [1, 1]), 1, "AND(1,1) = 1"

test_run
