#!/usr/bin/env stryke
# Rosetta Code: Tetrahedral numbers

fn Rosetta::Tetrahedral::compute($n) {
    int($n * ($n + 1) * ($n + 2) / 6)
}

fn Rosetta::Tetrahedral::list($max_n) {
    ~> 1:$max_n map { Rosetta::Tetrahedral::compute(_) }
}

assert_eq Rosetta::Tetrahedral::compute(1), 1, "T1"
assert_eq Rosetta::Tetrahedral::compute(2), 4, "T2"
assert_eq Rosetta::Tetrahedral::compute(3), 10, "T3"
assert_eq Rosetta::Tetrahedral::compute(4), 20, "T4"
assert_eq Rosetta::Tetrahedral::compute(5), 35, "T5"

my @list = Rosetta::Tetrahedral::list(5)
assert_eq join(",", @list), "1,4,10,20,35", "Tetrahedral list"

5 |> Rosetta::Tetrahedral::compute |> assert_eq(35, "pipe tetrahedral")

test_run
