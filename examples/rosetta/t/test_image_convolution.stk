#!/usr/bin/env stryke
# Rosetta Code: Image convolution

fn Rosetta::ImageConvolution::convolve($image, $kernel) {
    val $img_h = len(@$image)
    val $img_w = len(@{$image->[0]})
    val $ker_h = len(@$kernel)
    val $ker_w = len(@{$kernel->[0]})
    
    val $kh_half = int($ker_h / 2)
    val $kw_half = int($ker_w / 2)
    
    val @result
    
    # We use map to build the result array
    ~> 0..($img_h - 1) map {
        var @row
        for val $c (0..($img_w - 1)) {
            var $sum = 0.0
            for val $kr (0..($ker_h - 1)) {
                for val $kc (0..($ker_w - 1)) {
                    val $img_r = _ + $kr - $kh_half
                    val $img_c = $c + $kc - $kw_half
                    
                    # Zero-padding for edges
                    var $val = 0
                    if ($img_r >= 0 && $img_r < $img_h && $img_c >= 0 && $img_c < $img_w) {
                        $val = $image->[$img_r][$img_c]
                    }
                    $sum += $val * $kernel->[$kr][$kc]
                }
            }
            push @row, $sum
        }
        \@row
    }
}

# Simple 3x3 image
val $img = [
    [10, 10, 10],
    [10, 50, 10],
    [10, 10, 10]
]

# Blur kernel 3x3
val $kernel = [
    [0.111, 0.111, 0.111],
    [0.111, 0.111, 0.111],
    [0.111, 0.111, 0.111]
]

val @res = Rosetta::ImageConvolution::convolve($img, $kernel)

# Center pixel should be (50 + 8*10) / 9 = 130 / 9 = 14.444
val $center = $res[1][1]
assert_ok abs($center - 14.444) < 0.1, "Center pixel blurred correctly"

# Corner pixel 0,0: overlaps with 4 pixels of the image
# (10 + 10 + 10 + 50) / 9 = 80 / 9 = 8.888
val $corner = $res[0][0]
assert_ok abs($corner - 8.888) < 0.1, "Corner pixel blurred correctly"

test_run
