#!/usr/bin/env stryke
# Rosetta Code: Sophie Germain primes

fn Rosetta::SophieGermain::check($p) {
    is_prime($p) && is_prime(2 * $p + 1)
}

assert_ok Rosetta::SophieGermain::check(2), "2 is Sophie Germain (2*2+1=5)"
assert_ok Rosetta::SophieGermain::check(3), "3 is Sophie Germain (2*3+1=7)"
assert_ok Rosetta::SophieGermain::check(5), "5 is Sophie Germain (2*5+1=11)"
assert_ok Rosetta::SophieGermain::check(11), "11 is Sophie Germain (2*11+1=23)"
assert_ok !Rosetta::SophieGermain::check(7), "7 is not (2*7+1=15)"

11 |> Rosetta::SophieGermain::check |> assert_ok("pipe Sophie Germain")

test_run
