#!/usr/bin/env stryke
# Rosetta Code: The Twelve Days of Christmas — verse generator

fn Rosetta::TwelveDays::ordinals() {
    ("first", "second", "third", "fourth", "fifth", "sixth",
     "seventh", "eighth", "ninth", "tenth", "eleventh", "twelfth")
}

fn Rosetta::TwelveDays::gifts() {
    ("A partridge in a pear tree.",
     "Two turtle doves, and",
     "Three french hens,",
     "Four calling birds,",
     "Five golden rings,",
     "Six geese a-laying,",
     "Seven swans a-swimming,",
     "Eight maids a-milking,",
     "Nine ladies dancing,",
     "Ten lords a-leaping,",
     "Eleven pipers piping,",
     "Twelve drummers drumming,")
}

fn Rosetta::TwelveDays::verse($day) {
    val @ords = Rosetta::TwelveDays::ordinals()
    val @gifts = Rosetta::TwelveDays::gifts()
    val $ord = $ords[$day - 1]
    var @lines
    push @lines, "On the $ord day of Christmas my true love gave to me:"
    for (var $i = $day - 1; $i >= 0; $i -= 1) {
        push @lines, $gifts[$i]
    }
    join("\n", @lines)
}

fn Rosetta::TwelveDays::all() {
    var @verses
    for val $day (1:12) {
        push @verses, Rosetta::TwelveDays::verse($day)
    }
    join("\n\n", @verses)
}

val $v1 = Rosetta::TwelveDays::verse(1)
assert_eq $v1, "On the first day of Christmas my true love gave to me:\nA partridge in a pear tree.", "verse 1"

val $v2 = Rosetta::TwelveDays::verse(2)
val $v2_want = "On the second day of Christmas my true love gave to me:\nTwo turtle doves, and\nA partridge in a pear tree."
assert_eq $v2, $v2_want, "verse 2"

val $v12 = Rosetta::TwelveDays::verse(12)
assert_ok $v12 =~ /^On the twelfth day/, "verse 12 starts correctly"
assert_ok $v12 =~ /A partridge in a pear tree\.$/, "verse 12 ends with partridge"
assert_ok $v12 =~ /Twelve drummers drumming/, "verse 12 has drummers"

val $all = Rosetta::TwelveDays::all()
val @lines = split /\n/, $all
# 12 verses, each verse has (1 + day_count) lines, plus 11 blank separator lines
# total content lines = sum(1+i, i=1..12) = 12 + 78 = 90, plus 11 blanks = 101
assert_eq len(@lines), 101, "complete song line count"

test_run
