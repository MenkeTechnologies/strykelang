#!/usr/bin/env stryke
# Rosetta Code: Set consolidation

fn Rosetta::Consolidate::consolidate($list) {
    var @sets
    for val $item (@$list) {
        push @sets, set(@$item)
    }
    
    var $changed = 1
    while ($changed) {
        $changed = 0
        var @res
        for val $i (0..len(@sets)-1) {
            var $s = $sets[$i]
            next unless defined $s
            for val $j ($i+1..len(@sets)-1) {
                val $t = $sets[$j]
                next unless defined $t
                
                # Manual intersection check
                val $intersect = $s & $t
                if (len($intersect->values) > 0) {
                    $sets[$i] = $s | $t
                    $s = $sets[$i]
                    $sets[$j] = undef
                    $changed = 1
                }
            }
            if (defined $s) {
                push @res, $s
                $sets[$i] = undef
            }
        }
        @sets = @res
    }
    \@sets
}

val @input = ([1, 2], [3, 4], [2, 3])
val $res = Rosetta::Consolidate::consolidate(\@input)
# Expected: {1, 2, 3, 4}
assert_eq len(@$res), 1, "consolidated to 1 set"
assert_eq len($res->[0]->values), 4, "consolidated set size 4"

val @input2 = ([1, 2], [3, 4], [5, 6])
val $res2 = Rosetta::Consolidate::consolidate(\@input2)
assert_eq len(@$res2), 3, "consolidated to 3 sets"

test_run
