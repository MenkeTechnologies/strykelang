#!/usr/bin/env stryke
# Rosetta Code: Longest common prefix

fn Rosetta::LongestCommonPrefix::common($s1, $s2) {
    my @c1 = chars($s1)
    my @c2 = chars($s2)
    my $len = scalar(@c1) < scalar(@c2) ? scalar(@c1) : scalar(@c2)
    my $res = ""
    my $i = 0
    while ($i < $len) {
        if ($c1[$i] eq $c2[$i]) {
            $res = $res . $c1[$i]
        } else {
            $i = $len # break
        }
        $i++
    }
    $res
}

fn Rosetta::LongestCommonPrefix::solve(@strings) {
    if (scalar(@strings) == 0) {
        ""
    } else {
        @strings |> reduce { Rosetta::LongestCommonPrefix::common($a, $b) }
    }
}

assert_eq Rosetta::LongestCommonPrefix::solve("interspecies", "interstellar", "interstate"), "inters", "prefix inters"
assert_eq Rosetta::LongestCommonPrefix::solve("throne", "throne"), "throne", "prefix throne"
assert_eq Rosetta::LongestCommonPrefix::solve("throne", "dungeon"), "", "no prefix"

# Pipe
qw(interspecies interstellar interstate) |> Rosetta::LongestCommonPrefix::solve |> assert_eq("inters", "pipe prefix")

test_run
