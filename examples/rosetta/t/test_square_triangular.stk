#!/usr/bin/env stryke
# Rosetta Code: Square-triangular numbers

fn Rosetta::SquareTriangular::is_triangular($n) {
    my $val = 8 * $n + 1
    my $root = int(sqrt($val))
    $root * $root == $val
}

fn Rosetta::SquareTriangular::is_square($n) {
    my $root = int(sqrt($n))
    $root * $root == $n
}

fn Rosetta::SquareTriangular::check($n) {
    Rosetta::SquareTriangular::is_square($n) && Rosetta::SquareTriangular::is_triangular($n)
}

assert_ok Rosetta::SquareTriangular::check(1), "1 is square and triangular"
assert_ok Rosetta::SquareTriangular::check(36), "36 is square (6^2) and triangular (8*9/2)"
assert_ok Rosetta::SquareTriangular::check(1225), "1225 is square (35^2) and triangular (49*50/2)"
assert_ok !Rosetta::SquareTriangular::check(10), "10 is triangular but not square"
assert_ok !Rosetta::SquareTriangular::check(16), "16 is square but not triangular"

1225 |> Rosetta::SquareTriangular::check |> assert_ok("pipe square-triangular")

test_run
