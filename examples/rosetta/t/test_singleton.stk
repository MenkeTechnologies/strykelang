#!/usr/bin/env stryke
# Rosetta Code: Singleton
# Module-level singleton: every call to `instance()` returns the same
# object. Demonstrate identity, mutation propagation, and reset.

my $Rosetta_Singleton_instance = undef

fn Rosetta::Singleton::instance() {
    if (!defined $Rosetta_Singleton_instance) {
        $Rosetta_Singleton_instance = { count => 0, log => [] }
    }
    $Rosetta_Singleton_instance
}

fn Rosetta::Singleton::reset() {
    $Rosetta_Singleton_instance = undef
}

fn Rosetta::Singleton::tick($label) {
    my $i = Rosetta::Singleton::instance()
    $i->{count}++
    push @{$i->{log}}, $label
    $i->{count}
}

# Reset to known state
Rosetta::Singleton::reset()

# First call constructs
my $a = Rosetta::Singleton::instance()
assert_ok defined($a), "first call returns a value"
assert_eq $a->{count}, 0, "fresh count = 0"

# Second call returns the *same* object
my $b = Rosetta::Singleton::instance()
$a->{count} = 7
assert_eq $b->{count}, 7, "mutation visible through second handle"

# Tick increments and logs
Rosetta::Singleton::reset()
assert_eq Rosetta::Singleton::tick("hello"), 1, "first tick"
assert_eq Rosetta::Singleton::tick("world"), 2, "second tick"
assert_eq Rosetta::Singleton::tick("foo"),   3, "third tick"

my $i = Rosetta::Singleton::instance()
assert_eq $i->{count}, 3, "count visible"
assert_eq join(",", @{$i->{log}}), "hello,world,foo", "log preserved"

# Reset destroys state
Rosetta::Singleton::reset()
my $fresh = Rosetta::Singleton::instance()
assert_eq $fresh->{count}, 0, "after reset: count 0"
assert_eq scalar(@{$fresh->{log}}), 0, "after reset: empty log"

# Pipe form
() |> fn { Rosetta::Singleton::tick("piped") } |> assert_eq(1, "pipe tick #1")

test_run
