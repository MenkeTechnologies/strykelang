#!/usr/bin/env stryke
# Rosetta Code: Combinations

fn Rosetta::Combinations::generate($n, $k) {
    if ($k == 0) { return [[]] }
    if ($n < $k) { return [] }
    
    val $with_first = Rosetta::Combinations::generate($n - 1, $k - 1)
    var @res
    for val $c (@$with_first) {
        push @res, [ $n - 1, @$c ]
    }
    
    val $without_first = Rosetta::Combinations::generate($n - 1, $k)
    for val $c (@$without_first) {
        push @res, $c
    }
    
    \@res
}

val $c52 = Rosetta::Combinations::generate(5, 2)
assert_eq len(@$c52), 10, "5 choose 2 = 10"

# Combinations of 3 from 5
val $c53 = Rosetta::Combinations::generate(5, 3)
assert_eq len(@$c53), 10, "5 choose 3 = 10"

test_run
