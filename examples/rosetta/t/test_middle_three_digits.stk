#!/usr/bin/env stryke
# Rosetta Code: Middle three digits

fn middle_three_digits {
    my $n = $_[0]
    my $s = ~> $n abs >{ sprintf("%d", _) }
    my $len = length($s)
    
    if ($len < 3 || $len % 2 == 0) {
        "invalid"
    } else {
        my $mid = int($len / 2)
        substr($s, $mid - 1, 3)
    }
}

assert_eq middle_three_digits(12345), "234", "12345 -> 234"
assert_eq middle_three_digits(123), "123", "123 -> 123"
assert_eq middle_three_digits(1234567), "345", "1234567 -> 345"
assert_eq middle_three_digits(1234), "invalid", "1234 -> invalid"
assert_eq middle_three_digits(12), "invalid", "12 -> invalid"
assert_eq middle_three_digits(-12345), "234", "negative 12345 -> 234"

test_run
