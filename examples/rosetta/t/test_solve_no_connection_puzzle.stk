#!/usr/bin/env stryke
# Rosetta Code: Solve the no connection puzzle
# Eight pegs labelled A..H must be placed on eight nodes (numbered
# 1..8) of a small graph such that no two pegs that are adjacent in
# the alphabet share a graph edge. The standard rosetta graph:
#
#         1
#        /|\
#       / | \
#      2--3--4
#      |\ |  |
#      | \|  |
#      5--6--7
#       \ | /
#        \|/
#         8
#
# Edges: 1-2, 1-3, 1-4, 2-3, 2-5, 2-6, 3-4, 3-6, 4-7, 5-6, 5-8, 6-7, 6-8, 7-8.

fn Rosetta::NoConn::edges() {
    [[1,2],[1,3],[1,4],[2,3],[2,5],[2,6],[3,4],[3,6],
     [4,7],[5,6],[5,8],[6,7],[6,8],[7,8]]
}

fn Rosetta::NoConn::adj() {
    my $es = Rosetta::NoConn::edges()
    my %adj
    for my $n (1..8) { $adj{$n} = {} }
    for my $e (@$es) {
        $adj{$e->[0]}{$e->[1]} = 1
        $adj{$e->[1]}{$e->[0]} = 1
    }
    \%adj
}

fn Rosetta::NoConn::solve_helper($adj, $assign, $used, $idx) {
    return [@$assign] if $idx == 9   # 1..8 placed
    my $letter = chr(ord("A") + $idx - 1)
    for my $node (1..8) {
        next if $used->{$node}
        # Forbid edges between consecutive letters
        my $prev = $assign->[$idx - 2]
        my $next = $assign->[$idx]      # not yet placed
        if (defined $prev && $adj->{$node}{$prev}) { next }
        $assign->[$idx - 1] = $node
        $used->{$node} = 1
        my $r = Rosetta::NoConn::solve_helper($adj, $assign, $used, $idx + 1)
        if (defined $r) { return $r }
        $used->{$node} = 0
    }
    undef
}

fn Rosetta::NoConn::solve() {
    my $adj = Rosetta::NoConn::adj()
    my @assign = (undef) x 8
    my %used
    Rosetta::NoConn::solve_helper($adj, \@assign, \%used, 1)
}

fn Rosetta::NoConn::is_valid($assign, $adj) {
    my $n = len(@$assign)
    return 0 if $n != 8
    my %seen
    for my $node (@$assign) {
        return 0 if exists $seen{$node}
        return 0 if $node < 1 || $node > 8
        $seen{$node} = 1
    }
    for my $i (0..$n - 2) {
        return 0 if $adj->{$assign->[$i]}{$assign->[$i + 1]}
    }
    1
}

# A solution exists
my $sol = Rosetta::NoConn::solve()
assert_ok defined($sol), "solver returned an assignment"
assert_eq len(@$sol), 8, "8 letters placed"

# Validate solution
my $adj = Rosetta::NoConn::adj()
assert_eq Rosetta::NoConn::is_valid($sol, $adj), 1, "solution passes validity check"

# Every node used exactly once
my %used
for my $n (@$sol) { $used{$n}++ }
assert_eq scalar(keys %used), 8, "all 8 nodes used"
for my $n (1..8) {
    assert_eq $used{$n}, 1, sprintf("node %d used once", $n)
}

# Edge validation
my $edges = Rosetta::NoConn::edges()
my $total_adj = 0
for my $e (@$edges) {
    $total_adj++ if defined $adj->{$e->[0]}{$e->[1]}
    $total_adj++ if defined $adj->{$e->[1]}{$e->[0]}
}
assert_eq $total_adj, 28, "14 edges → 28 directed entries"

# Tampering detection: swap A and B's positions; A-B is an edge violation
# only if the swapped nodes were adjacent in the graph.
my @bad = @$sol
($bad[0], $bad[1]) = ($bad[1], $bad[0])
# This may or may not be a valid solution depending on graph. Just check:
my $valid_after_swap = Rosetta::NoConn::is_valid(\@bad, $adj)
assert_ok $valid_after_swap == 0 || $valid_after_swap == 1, "validity is boolean"

# Pipe form
() |> fn { Rosetta::NoConn::solve() } |> fn { len(@$_) } |> assert_eq(8, "pipe solver length")

test_run
