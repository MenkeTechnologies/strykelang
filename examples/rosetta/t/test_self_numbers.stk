#!/usr/bin/env stryke
# Rosetta Code: Self numbers

fn Rosetta::SelfNumbers::sum_digits($n) {
    my $sum = 0
    my @digits = str($n) |> chars
    for my $d (@digits) {
        $sum = $sum + int($d)
    }
    $sum
}

fn Rosetta::SelfNumbers::check($n) {
    my $found = 0
    # A candidate m must be less than n
    my $start = $n - 100
    if ($start < 1) { $start = 1 }
    for my $m ($start..$n-1) {
        if ($m + Rosetta::SelfNumbers::sum_digits($m) == $n) {
            $found = 1
            return 0
        }
    }
    1
}

assert_ok Rosetta::SelfNumbers::check(1), "1 is self number"
assert_ok Rosetta::SelfNumbers::check(20), "20 is self number"
assert_ok !Rosetta::SelfNumbers::check(21), "21 is not (15+6)"
assert_ok Rosetta::SelfNumbers::check(31), "31 is self number"

20 |> Rosetta::SelfNumbers::check |> assert_ok("pipe self number check")

test_run
