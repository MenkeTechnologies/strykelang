#!/usr/bin/env stryke
# Rosetta Code: Needleman-Wunsch algorithm

fn Rosetta::NeedlemanWunsch::solve($s1, $s2, $match, $mismatch, $gap) {
    val @c1 = $s1 |> chars()
    val @c2 = $s2 |> chars()
    val $n1 = len(@c1)
    val $n2 = len(@c2)
    
    val @f = map { [ map { 0 } 0:$n2 ] } 0:$n1
    
    for (var $i = 0; $i <= $n1; $i++) { $f[$i]->[0] = $i * $gap }
    for (var $j = 0; $j <= $n2; $j++) { $f[0]->[$j] = $j * $gap }
    
    for (var $i = 1; $i <= $n1; $i++) {
        for (var $j = 1; $j <= $n2; $j++) {
            val $score = ($c1[$i-1] eq $c2[$j-1]) ? $match : $mismatch
            val $match_v = $f[$i-1]->[$j-1] + $score
            val $delete = $f[$i-1]->[$j] + $gap
            val $insert = $f[$i]->[$j-1] + $gap
            $f[$i]->[$j] = max($match_v, max($delete, $insert))
        }
    }
    
    var $res1 = ""
    var $res2 = ""
    var $i = $n1
    var $j = $n2
    
    while ($i > 0 || $j > 0) {
        if ($i > 0 && $j > 0) {
            val $score = ($c1[$i-1] eq $c2[$j-1]) ? $match : $mismatch
            if ($f[$i]->[$j] == $f[$i-1]->[$j-1] + $score) {
                $res1 = $c1[$i-1] . $res1
                $res2 = $c2[$j-1] . $res2
                $i--; $j--
                next
            }
        }
        if ($i > 0 && $f[$i]->[$j] == $f[$i-1]->[$j] + $gap) {
            $res1 = $c1[$i-1] . $res1
            $res2 = "-" . $res2
            $i--
        } else {
            $res1 = "-" . $res1
            $res2 = $c2[$j-1] . $res2
            $j--
        }
    }
    
    ($res1, $res2, $f[$n1]->[$n2])
}

val ($a1, $a2, $score) = Rosetta::NeedlemanWunsch::solve("GATTACA", "GCATGCU", 1, -1, -1)
assert_eq $score, 0, "Needleman-Wunsch score"
# GATTACA
# GCA-TGCU
# G A T T A C A -
# G C A - T G C U
# The actual alignment can vary but score should be 0.
# Let's check score.
assert_eq len($a1), len($a2), "alignment lengths match"

test_run
