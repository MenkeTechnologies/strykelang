#!/usr/bin/env stryke
# Rosetta Code: Count inversions via merge sort
# An inversion is a pair (i, j) with i < j and arr[i] > arr[j].

fn Rosetta::Inversions::merge_count($a) {
    my $n = scalar(@$a)
    return [[@$a], 0] if $n <= 1
    my $mid = int($n / 2)
    my @left = @$a[0..$mid - 1]
    my @right = @$a[$mid..$n - 1]
    my $l = Rosetta::Inversions::merge_count(\@left)
    my $r = Rosetta::Inversions::merge_count(\@right)
    my @ml = @{$l->[0]}
    my @mr = @{$r->[0]}
    my $count = $l->[1] + $r->[1]
    my @merged
    my ($i, $j) = (0, 0)
    while ($i < scalar(@ml) && $j < scalar(@mr)) {
        if ($ml[$i] <= $mr[$j]) {
            push @merged, $ml[$i++]
        } else {
            push @merged, $mr[$j++]
            $count += scalar(@ml) - $i
        }
    }
    while ($i < scalar(@ml)) { push @merged, $ml[$i++] }
    while ($j < scalar(@mr)) { push @merged, $mr[$j++] }
    [\@merged, $count]
}

fn Rosetta::Inversions::count($a) {
    Rosetta::Inversions::merge_count($a)->[1]
}

# Already sorted -> 0 inversions
assert_eq Rosetta::Inversions::count([1, 2, 3, 4, 5]), 0, "sorted -> 0"

# Reverse sorted -> n*(n-1)/2 inversions
assert_eq Rosetta::Inversions::count([5, 4, 3, 2, 1]), 10, "5..1 -> 10"
assert_eq Rosetta::Inversions::count([4, 3, 2, 1]), 6, "4..1 -> 6"

# Single swap
assert_eq Rosetta::Inversions::count([1, 3, 2, 4, 5]), 1, "one swap -> 1"

# Empty / single
assert_eq Rosetta::Inversions::count([]), 0, "empty"
assert_eq Rosetta::Inversions::count([42]), 0, "single"

# Duplicates: equal elements are NOT inversions
assert_eq Rosetta::Inversions::count([2, 2, 2]), 0, "all equal -> 0"

# Classic teaching example
assert_eq Rosetta::Inversions::count([2, 4, 1, 3, 5]), 3, "2,4,1,3,5 -> 3"
assert_eq Rosetta::Inversions::count([3, 1, 2]), 2, "3,1,2 -> 2"

# Result is independent of merge_count's sort order — verify sorted output
my $r = Rosetta::Inversions::merge_count([3, 1, 4, 1, 5, 9, 2, 6])
assert_eq join(",", @{$r->[0]}), "1,1,2,3,4,5,6,9", "merge produces sorted output"

test_run
