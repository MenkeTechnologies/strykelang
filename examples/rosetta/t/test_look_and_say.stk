#!/usr/bin/env stryke
# Rosetta Code: Look-and-Say Sequence

fn Rosetta::LookAndSay::next_step($s) {
    if (length($s) == 0) { "" }
    else {
        my @chars = ~> $s chars
        my $res = ""
        my $curr = $chars[0]
        my $count = 1
        
        for my $i (1..$#chars) {
            if ($chars[$i] eq $curr) {
                $count = $count + 1
            } else {
                $res = $res . $count . $curr
                $curr = $chars[$i]
                $count = 1
            }
        }
        $res . $count . $curr
    }
}

fn Rosetta::LookAndSay::generate($start, $n) {
    my @seq = ($start)
    for my $i (1..$n-1) {
        my $prev = $seq[-1]
        my $next = Rosetta::LookAndSay::next_step($prev)
        push @seq, $next
    }
    \@seq
}

assert_eq Rosetta::LookAndSay::next_step("1"), "11", "1 -> 11"
assert_eq Rosetta::LookAndSay::next_step("11"), "21", "11 -> 21"
assert_eq Rosetta::LookAndSay::next_step("21"), "1211", "21 -> 1211"
assert_eq Rosetta::LookAndSay::next_step("1211"), "111221", "1211 -> 111221"

my $s = Rosetta::LookAndSay::generate("1", 5)
assert_eq join(",", @$s), "1,11,21,1211,111221", "first 5 terms"

test_run
