#!/usr/bin/env stryke
# Rosetta Code: Relatively prime

fn Rosetta::RelativelyPrime::gcd($a, $b) {
    while ($b != 0) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn Rosetta::RelativelyPrime::are_relatively_prime($a, $b) {
    Rosetta::RelativelyPrime::gcd($a, $b) == 1
}

assert_ok Rosetta::RelativelyPrime::are_relatively_prime(2, 3), "2 and 3"
assert_ok Rosetta::RelativelyPrime::are_relatively_prime(10, 21), "10 and 21"
assert_ok !Rosetta::RelativelyPrime::are_relatively_prime(10, 15), "10 and 15 not (5)"

# Chaining
10 |> Rosetta::RelativelyPrime::are_relatively_prime(21) |> assert_ok("pipe relative prime")

test_run
