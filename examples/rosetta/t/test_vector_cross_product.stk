#!/usr/bin/env stryke
# Rosetta Code: Vector cross product

fn my_cross_product {
    my $a = $_[0]
    my $b = $_[1]
    
    my @res = (
        $a->[1] * $b->[2] - $a->[2] * $b->[1],
        $a->[2] * $b->[0] - $a->[0] * $b->[2],
        $a->[0] * $b->[1] - $a->[1] * $b->[0]
    )
    ([@res])
}

my $v1 = [1, 2, 3]
my $v2 = [4, 5, 6]
my $cp = my_cross_product($v1, $v2)
assert_eq join(",", @$cp), "-3,6,-3", "cross product of [1,2,3] and [4,5,6]"

my $i = [1, 0, 0]
my $j = [0, 1, 0]
my $k = my_cross_product($i, $j)
assert_eq join(",", @$k), "0,0,1", "i x j = k"

test_run
