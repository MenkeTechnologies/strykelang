#!/usr/bin/env stryke
# Rosetta Code: Vector cross product

fn Rosetta::CrossProduct::cross_product {
    val @res = (
        _->[1] * _1->[2] - _->[2] * _1->[1],
        _->[2] * _1->[0] - _->[0] * _1->[2],
        _->[0] * _1->[1] - _->[1] * _1->[0]
    )
    \@res
}

val $v1 = [1, 2, 3]
val $v2 = [4, 5, 6]
val $cp = Rosetta::CrossProduct::cross_product($v1, $v2)
assert_eq join(",", @$cp), "-3,6,-3", "cross product of [1,2,3] and [4,5,6]"

val $i = [1, 0, 0]
val $j = [0, 1, 0]
val $k = Rosetta::CrossProduct::cross_product($i, $j)
assert_eq join(",", @$k), "0,0,1", "i x j = k"

test_run
