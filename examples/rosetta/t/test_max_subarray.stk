#!/usr/bin/env stryke
# Rosetta Code: Maximum subarray sum

fn Rosetta::MaxSubarray::sum(@arr) {
    if (len(@arr) == 0) {
        0
    } else {
        var $max_so_far = $arr[0]
        var $curr_max = $arr[0]
        for val $i (1..len(@arr)-1) {
            val $x = $arr[$i]
            $curr_max = $x > $curr_max + $x ? $x : $curr_max + $x
            $max_so_far = $curr_max > $max_so_far ? $curr_max : $max_so_far
        }
        $max_so_far
    }
}

val @data = (-2, 1, -3, 4, -1, 2, 1, -5, 4)
assert_eq Rosetta::MaxSubarray::sum(@data), 6, "max subarray of (-2, 1, -3, 4, -1, 2, 1, -5, 4) is 6"

val @data2 = (1, 2, 3)
assert_eq Rosetta::MaxSubarray::sum(@data2), 6, "all positive"

val @data3 = (-1, -2, -3)
assert_eq Rosetta::MaxSubarray::sum(@data3), -1, "all negative"

@data |> Rosetta::MaxSubarray::sum |> assert_eq(6, "pipe max_subarray")

test_run
