#!/usr/bin/env stryke
# Rosetta Code: Unix/ls

fn Rosetta::UnixLS::list($dir) {
    # Strip directory prefix for the output
    ~> glob("$dir/*") map {
        _ =~ s/^$dir\///
       _
    }
}

# Build a known fixture in a tmpdir so the test is CWD-independent
# (the prior `glob("t/*")` form was relative to CWD and depended on
# stryke being invoked from the project root — fragile under
# `cargo test` vs. running the test file directly).
my $tmp = tempdir()
for my $name ("alpha.txt", "beta.txt", "gamma.txt") {
    open(my $fh, ">", "$tmp/$name") or die "create: $!"
    close $fh
}

my @t_files = Rosetta::UnixLS::list($tmp)

# Cleanup before assertions so they fire even on partial cleanup.
for my $name ("alpha.txt", "beta.txt", "gamma.txt") {
    unlink "$tmp/$name"
}
rmdir($tmp)

assert_ok len(@t_files) == 3, "Listed 3 files in fixture dir"
assert_ok len(grep { _ eq "beta.txt" } @t_files) > 0, "Found beta.txt"
assert_ok len(grep { _ eq "alpha.txt" } @t_files) > 0, "Found alpha.txt"

test_run
