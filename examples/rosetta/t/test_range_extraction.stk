#!/usr/bin/env stryke
# Rosetta Code: Range extraction — compress sorted ints into "a-b,c,..." form

fn Rosetta::RangeExtraction::extract(@nums) {
    my $n = len(@nums)
    return "" if $n == 0
    my @groups
    my $i = 0
    while ($i < $n) {
        my $j = $i
        while ($j + 1 < $n && $nums[$j+1] == $nums[$j] + 1) { $j += 1 }
        if ($j - $i >= 2) {
            push @groups, "$nums[$i]-$nums[$j]"
        } else {
            for my $k ($i..$j) {
                push @groups, "$nums[$k]"
            }
        }
        $i = $j + 1
    }
    join(",", @groups)
}

my @data = (0, 1, 2, 4, 6, 7, 8, 11, 12, 14, 15, 17, 18, 19, 20)
assert_eq Rosetta::RangeExtraction::extract(@data), "0-2,4,6-8,11,12,14,15,17-20", "classic Rosetta sample"

my @full_run = (1, 2, 3, 4, 5)
assert_eq Rosetta::RangeExtraction::extract(@full_run), "1-5", "full run becomes 1-5"

my @scattered = (1, 3, 5, 7)
assert_eq Rosetta::RangeExtraction::extract(@scattered), "1,3,5,7", "no consecutive runs"

my @two = (10, 11)
assert_eq Rosetta::RangeExtraction::extract(@two), "10,11", "two adjacent stay listed"

my @neg = (-3, -2, -1, 0, 5)
assert_eq Rosetta::RangeExtraction::extract(@neg), "-3-0,5", "negative range"

assert_eq Rosetta::RangeExtraction::extract(), "", "empty"

test_run
