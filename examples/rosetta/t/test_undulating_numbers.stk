#!/usr/bin/env stryke
# Rosetta Code: Undulating numbers
# An n-digit base-10 number is undulating if its digits alternate
# strictly between exactly two distinct values: a, b, a, b, … with a ≠ b.
# Three-or-more-digit numbers only.

fn Rosetta::Undulating::is($n) {
    my $s = "$n"
    return 0 if length($s) < 3
    my @d = split //, $s
    my $a = $d[0]
    my $b = $d[1]
    return 0 if $a eq $b
    for my $i (0..len(@d) - 1) {
        my $expected = $i % 2 == 0 ? $a : $b
        return 0 if $d[$i] ne $expected
    }
    1
}

fn Rosetta::Undulating::list_below($limit) {
    100:$limit |> grep { Rosetta::Undulating::is(_) }
}

# Direct cases
assert_eq Rosetta::Undulating::is(101),  1, "101 undulates"
assert_eq Rosetta::Undulating::is(121),  1, "121 undulates"
assert_eq Rosetta::Undulating::is(12121),1, "12121 undulates"
assert_eq Rosetta::Undulating::is(123),  0, "123 doesn't"
assert_eq Rosetta::Undulating::is(111),  0, "111 same digit"
assert_eq Rosetta::Undulating::is(1212), 1, "1212 undulates"
assert_eq Rosetta::Undulating::is(99),   0, "99 too short"
assert_eq Rosetta::Undulating::is(98989),1, "98989 undulates"

# Count of three-digit undulating numbers: 9 * 9 = 81
my @u3 = ~> 100:999 |> grep { Rosetta::Undulating::is(_) }
assert_eq scalar(@u3), 81, "81 three-digit undulating numbers"

# First 10 undulating numbers ≥ 100
my @u = Rosetta::Undulating::list_below(199)
assert_eq join(",", @u[0..8]),
    "101,121,131,141,151,161,171,181,191",
    "first batch ≤ 199 (a = 1 family)"

# Pipe form
12321 |> Rosetta::Undulating::is |> assert_eq(0, "12321 is palindrome but not undulating")
12121 |> Rosetta::Undulating::is |> assert_eq(1, "12121 is both")

test_run
