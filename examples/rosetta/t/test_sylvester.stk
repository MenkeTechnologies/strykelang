#!/usr/bin/env stryke
# Rosetta Code: Sylvester's sequence

fn sylvester($n) {
    if ($n == 0) {
        2
    } else {
        my $s = 2
        for my $i (1..$n) {
            $s = $s * $s - $s + 1
        }
        $s
    }
}

assert_eq sylvester(0), 2, "s(0)"
assert_eq sylvester(1), 3, "s(1)"
assert_eq sylvester(2), 7, "s(2)"
assert_eq sylvester(3), 43, "s(3)"
assert_eq sylvester(4), 1807, "s(4)"

4 |> sylvester |> assert_eq(1807, "pipe sylvester")

test_run
