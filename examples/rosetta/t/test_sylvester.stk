#!/usr/bin/env stryke
# Rosetta Code: Sylvester's sequence

fn Rosetta::Sylvester::nth($n) {
    if ($n == 0) {
        2
    } else {
        my $s = 2
        for my $i (1..$n) {
            $s = $s * $s - $s + 1
        }
        $s
    }
}

assert_eq Rosetta::Sylvester::nth(0), 2, "s(0)"
assert_eq Rosetta::Sylvester::nth(1), 3, "s(1)"
assert_eq Rosetta::Sylvester::nth(2), 7, "s(2)"
assert_eq Rosetta::Sylvester::nth(3), 43, "s(3)"
assert_eq Rosetta::Sylvester::nth(4), 1807, "s(4)"

4 |> Rosetta::Sylvester::nth |> assert_eq(1807, "pipe sylvester")

test_run
