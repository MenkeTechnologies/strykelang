#!/usr/bin/env stryke
# Rosetta Code: Bioinformatics/Base count

fn Rosetta::DNABaseCount::compute($dna) {
    var $counts = {A => 0, C => 0, G => 0, T => 0}
    var @bases = ~> $dna uc chars
    for val $b (@bases) {
        if (exists $counts->{$b}) {
            $counts->{$b} = $counts->{$b} + 1
        }
    }
    $counts
}

val $dna = "CGATATATGGGTTTTAGC"
val $res = Rosetta::DNABaseCount::compute($dna)
assert_eq $res->{A}, 4, "Count of A"
assert_eq $res->{C}, 2, "Count of C"
assert_eq $res->{G}, 5, "Count of G"
assert_eq $res->{T}, 7, "Count of T"

test_run
