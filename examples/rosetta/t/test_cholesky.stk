#!/usr/bin/env stryke
# Rosetta Code: Cholesky Decomposition

fn Rosetta::Cholesky::decompose($A) {
    my $n = scalar(@$A)
    my @L
    for my $i (0..$n-1) {
        my @row
        for my $j (0..$n-1) { push @row, 0.0 }
        push @L, \@row
    }
    
    for my $i (0..$n-1) {
        for my $j (0..$i) {
            my $sum = 0.0
            for my $k (0..$j-1) {
                $sum = $sum + $L[$i]->[$k] * $L[$j]->[$k]
            }
            if ($i == $j) {
                $L[$i]->[$j] = sqrt($A->[$i]->[$i] - $sum)
            } else {
                $L[$i]->[$j] = (1.0 / $L[$j]->[$j]) * ($A->[$i]->[$j] - $sum)
            }
        }
    }
    \@L
}

my $A = [[25, 15, -5], [15, 18, 0], [-5, 0, 11]]
my $L = Rosetta::Cholesky::decompose($A)

# Expected: [[5, 0, 0], [3, 3, 0], [-1, 1, 3]]
assert_eq $L->[0]->[0], 5, "L[0][0]"
assert_eq $L->[1]->[0], 3, "L[1][0]"
assert_eq $L->[1]->[1], 3, "L[1][1]"
assert_eq $L->[2]->[2], 3, "L[2][2]"

test_run
