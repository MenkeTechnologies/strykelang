#!/usr/bin/env stryke
# Rosetta Code: Sum and product of an array

fn Rosetta::SumProduct::demo() {
    "Sum and Product of Array Examples:" |> p
    
    var @numbers = (1, 2, 3, 4, 5)
    "Array: " . join(", ", @numbers) |> p
    
    # Sum using reduce
    val $sum = @numbers |> sum
    "Sum: $sum" |> p
    
    # Product using reduce 
    val $product = @numbers |> product
    "Product: $product" |> p
    
    # Manual sum calculation
    var $manual_sum = 0
    for val $n (@numbers) {
        $manual_sum += $n
    }
    "Manual sum: $manual_sum" |> p
    
    # Manual product calculation
    var $manual_product = 1
    for val $n (@numbers) {
        $manual_product *= $n
    }
    "Manual product: $manual_product" |> p
    
    # Threading example
    val $threaded_sum = ~> @numbers sum
    
    # Different arrays
    val @decimals = (1.5, 2.5, 3.5)
    "Decimals: " . join(", ", @decimals) |> p
    "Decimal sum: " . (@decimals |> sum) |> p
    "Decimal product: " . (@decimals |> product) |> p
    
    val @mixed = (-2, 0, 3, 7)
    "Mixed (with negative/zero): " . join(", ", @mixed) |> p
    "Mixed sum: " . (@mixed |> sum) |> p
    "Mixed product: " . (@mixed |> product) |> p
}

Rosetta::SumProduct::demo()
test_run
