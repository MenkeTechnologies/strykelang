#!/usr/bin/env stryke
# Rosetta Code: Literals/Floating point

fn Rosetta::FloatLiterals::demo() {
    val $a = 3.14159
    val $b = 1.0e-10
    val $c = 2.0
    val $d = 0.5
    
    ($a, $b, $c, $d)
}

val ($a, $b, $c, $d) = Rosetta::FloatLiterals::demo()
assert_eq $a, 3.14159, "Standard decimal"
assert_eq $b, 1e-10, "Scientific notation"
assert_eq $c, 2.0, "Trailing dot"
assert_eq $d, 0.5, "Leading dot"

test_run
