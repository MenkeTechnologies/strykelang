#!/usr/bin/env stryke
# Rosetta Code: Password generator
# Build random passwords with a guaranteed minimum from each
# required class (lowercase, uppercase, digit, symbol).

fn Rosetta::PwGen::pool($flags) {
    val $lower = "abcdefghijklmnopqrstuvwxyz"
    val $upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    val $digit = "0123456789"
    val $sym   = "!#\$%&()*+,-./:;<=>?\@[]^_{|}~"
    var $pool = ""
    $pool .= $lower if $flags->{lower}
    $pool .= $upper if $flags->{upper}
    $pool .= $digit if $flags->{digit}
    $pool .= $sym   if $flags->{symbol}
    $pool
}

fn Rosetta::PwGen::generate($length, $flags) {
    return undef if $length < 4
    val $pool = Rosetta::PwGen::pool($flags)
    return undef if length($pool) == 0
    var @out
    # Force one character from each enabled class.
    var @classes
    push @classes, "abcdefghijklmnopqrstuvwxyz"      if $flags->{lower}
    push @classes, "ABCDEFGHIJKLMNOPQRSTUVWXYZ"      if $flags->{upper}
    push @classes, "0123456789"                       if $flags->{digit}
    push @classes, "!#\$%&()*+,-./:;<=>?\@[]^_{|}~"   if $flags->{symbol}
    for val $c (@classes) {
        push @out, substr($c, int(rand(length($c))), 1)
    }
    while (len(@out) < $length) {
        push @out, substr($pool, int(rand(length($pool))), 1)
    }
    # Fisher-Yates shuffle
    for (var $i = len(@out) - 1; $i > 0; $i--) {
        var $j = int(rand($i + 1))
        ($out[$i], $out[$j]) = ($out[$j], $out[$i])
    }
    join("", @out)
}

fn Rosetta::PwGen::has_class($pw, $regex) {
    $pw =~ $regex ? 1 : 0
}

# Generate with all classes
val $flags_all = { lower => 1, upper => 1, digit => 1, symbol => 1 }
for val $i (~> 1:30) {
    val $pw = Rosetta::PwGen::generate(16, $flags_all)
    assert_eq length($pw), 16, "length 16"
    assert_eq Rosetta::PwGen::has_class($pw, qr/[a-z]/), 1, "has lowercase"
    assert_eq Rosetta::PwGen::has_class($pw, qr/[A-Z]/), 1, "has uppercase"
    assert_eq Rosetta::PwGen::has_class($pw, qr/[0-9]/), 1, "has digit"
    assert_eq Rosetta::PwGen::has_class($pw, qr/[!#\$%&()*+,\-.\/:;<=>?\@\[\]\^_{|}~]/),
        1, "has symbol"
}

# All-lowercase only
val $pw_lower = Rosetta::PwGen::generate(20, { lower => 1 })
assert_eq length($pw_lower), 20, "length 20"
assert_eq Rosetta::PwGen::has_class($pw_lower, qr/[A-Z0-9]/), 0, "no upper or digit"

# Length too short rejected
assert_ok !defined(Rosetta::PwGen::generate(3, $flags_all)), "length < 4 rejected"

# Empty flag set rejected
assert_ok !defined(Rosetta::PwGen::generate(10, {})), "no classes rejected"

# Pipe form
12 |> fn { Rosetta::PwGen::generate(_, $flags_all) } |> length |> assert_eq(12, "pipe length")

test_run
