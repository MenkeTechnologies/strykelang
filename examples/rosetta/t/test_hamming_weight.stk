#!/usr/bin/env stryke
# Rosetta Code: Hamming weight

fn Rosetta::HammingWeight::compute($n) {
    my $count = 0
    my $num = $n
    while ($num > 0) {
        if ($num % 2 == 1) { $count++ }
        $num = int($num / 2)
    }
    $count
}

assert_eq Rosetta::HammingWeight::compute(7), 3, "7 has 3 ones"
assert_eq Rosetta::HammingWeight::compute(8), 1, "8 has 1 one"
assert_eq Rosetta::HammingWeight::compute(0), 0, "0 has 0 ones"

15 |> Rosetta::HammingWeight::compute |> assert_eq(4, "pipe hamming_weight")

test_run
