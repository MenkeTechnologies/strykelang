#!/usr/bin/env stryke
# Rosetta Code: Hamming weight

fn hamming_weight($n) {
    my $count = 0
    while ($n > 0) {
        if ($n % 2 == 1) { $count++ }
        $n = int($n / 2)
    }
    $count
}

assert_eq hamming_weight(7), 3, "7 has 3 ones"
assert_eq hamming_weight(8), 1, "8 has 1 one"
assert_eq hamming_weight(0), 0, "0 has 0 ones"

15 |> hamming_weight |> assert_eq(4, "pipe hamming_weight")

test_run
