#!/usr/bin/env stryke
# Rosetta Code: Flatten a List (single level)

fn Rosetta::Flatten::solve(@list) {
    var @result
    for val $item (@list) {
        if (ref($item) eq 'ARRAY') {
            push @result, @$item
        } else {
            push @result, $item
        }
    }
    @result
}

val @nested = ([1, 2], [3, 4], 5)
val @flat = Rosetta::Flatten::solve(@nested)
assert_eq join(",", @flat), "1,2,3,4,5", "flatten single level"

val @simple = (1, 2, 3)
val @flat_simple = Rosetta::Flatten::solve(@simple)
assert_eq join(",", @flat_simple), "1,2,3", "flatten simple"

val @mixed = ([1], 2, [3, 4])
val @flat_mixed = Rosetta::Flatten::solve(@mixed)
assert_eq join(",", @flat_mixed), "1,2,3,4", "flatten mixed"

test_run
