#!/usr/bin/env stryke
# Rosetta Code: Factor pairs of n — all (a, b) with a*b = n and a <= b

fn Rosetta::FactorPairs::all($n) {
    return [] if $n < 1
    my @pairs
    my $i = 1
    while ($i * $i <= $n) {
        if ($n % $i == 0) {
            push @pairs, [$i, int($n / $i)]
        }
        $i++
    }
    \@pairs
}

fn Rosetta::FactorPairs::sig($n) {
    ~> Rosetta::FactorPairs::all($n)->@* map { _->[0] . "x" . _->[1] } |> join ","
}

assert_eq Rosetta::FactorPairs::sig(12), "1x12,2x6,3x4", "12 = 1*12, 2*6, 3*4"
assert_eq Rosetta::FactorPairs::sig(36), "1x36,2x18,3x12,4x9,6x6", "36 incl. perfect square 6*6"
assert_eq Rosetta::FactorPairs::sig(7), "1x7", "prime"
assert_eq Rosetta::FactorPairs::sig(1), "1x1", "1 = 1*1"
assert_eq Rosetta::FactorPairs::sig(100), "1x100,2x50,4x25,5x20,10x10", "100 = perfect square"
assert_eq Rosetta::FactorPairs::sig(60), "1x60,2x30,3x20,4x15,5x12,6x10", "60 has 6 pairs"

# Edge cases
assert_eq len(@{Rosetta::FactorPairs::all(0)}), 0, "0 has no factor pairs"
assert_eq len(@{Rosetta::FactorPairs::all(-5)}), 0, "negative has none"

# Number of factor pairs = ceil(num_divisors / 2)
my $r = Rosetta::FactorPairs::all(48)   # 48 has divisors: 1,2,3,4,6,8,12,16,24,48 (10 divisors)
assert_eq len(@$r), 5, "48 -> 5 pairs (10/2)"

# Perfect squares have an "odd" divisor count, last pair is (sqrt, sqrt)
my $sq = Rosetta::FactorPairs::all(16)
my $last = $sq->[-1]
assert_eq $last->[0], $last->[1], "perfect square last pair has equal halves"
assert_eq $last->[0], 4, "16 -> last pair is (4, 4)"

test_run
