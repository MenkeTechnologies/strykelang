#!/usr/bin/env stryke
# Rosetta Code: Text processing/Max licenses in use
# Parse a log of "License OUT" / "License IN" events and report the
# peak concurrent license usage along with each timestamp it occurred.

fn Rosetta::License::parse($lines) {
    my @events
    for my $line (@$lines) {
        next if $line =~ /^\s*$/
        if ($line =~ /^License\s+(IN|OUT)\s+\@\s*(.+)$/) {
            push @events, [$1, $2]
        }
    }
    \@events
}

fn Rosetta::License::max_in_use($events) {
    my $cur = 0
    my $max = 0
    my @peak_times
    for my $e (@$events) {
        if ($e->[0] eq "OUT") {
            $cur++
            if ($cur > $max) { $max = $cur; @peak_times = ($e->[1]) }
            elsif ($cur == $max) { push @peak_times, $e->[1] }
        } else {
            $cur--
        }
    }
    [$max, \@peak_times]
}

# Sample log
my @lines = (
    'License OUT @ 2008/10/03_23:51:05 for job 4001',
    'License OUT @ 2008/10/03_23:57:09 for job 4002',
    'License IN  @ 2008/10/04_00:00:34 for job 4001',
    'License OUT @ 2008/10/04_00:02:50 for job 4003',
    'License OUT @ 2008/10/04_00:04:20 for job 4004',
    'License OUT @ 2008/10/04_00:05:00 for job 4005',
    'License IN  @ 2008/10/04_00:06:15 for job 4002',
)

my $events = Rosetta::License::parse(\@lines)
assert_eq scalar(@$events), 7, "7 events parsed"

# Each event has direction and timestamp
for my $e (@$events) {
    assert_ok $e->[0] eq "IN" || $e->[0] eq "OUT", "direction valid"
    assert_ok length($e->[1]) > 0, "timestamp non-empty"
}

# Peak: 4 licenses at job 4005's OUT
my $r = Rosetta::License::max_in_use($events)
assert_eq $r->[0], 4, "peak = 4 licenses"
assert_ok scalar(@{$r->[1]}) >= 1, "at least one peak time"

# Empty log
my $empty = Rosetta::License::max_in_use([])
assert_eq $empty->[0], 0, "empty log peak = 0"

# Single OUT
my $one = Rosetta::License::max_in_use([["OUT", "now"]])
assert_eq $one->[0], 1, "single OUT peak = 1"

# Pipe form
\@lines |> Rosetta::License::parse |> fn { scalar(@$_) } |> assert_eq(7, "pipe count")

test_run
