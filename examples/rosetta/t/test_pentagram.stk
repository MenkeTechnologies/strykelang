#!/usr/bin/env stryke
# Rosetta Code: Pentagram
# Compute the 5 outer points of a regular pentagram inscribed in a
# unit circle, and the 5 inner intersection points (the pentagon
# formed inside). Returns [{outer => [...], inner => [...]}].

fn Rosetta::Pentagram::outer_points($r, $cx, $cy) {
    val $pi = 4 * atan2(1, 1)
    var @pts
    for val $k (0:4) {
        val $angle = $pi / 2 + 2 * $pi * $k / 5
        push @pts, [$cx + $r * cos($angle), $cy + $r * sin($angle)]
    }
    \@pts
}

fn Rosetta::Pentagram::edges() {
    # Connect every other vertex (step 2 mod 5 → star)
    [[0, 2], [2, 4], [4, 1], [1, 3], [3, 0]]
}

fn Rosetta::Pentagram::inner_radius($r) {
    # The inner pentagon of a regular pentagram inscribed in radius r
    # has radius r' = r · (3 - √5) / 2 = r / φ²  where φ = (1+√5)/2.
    val $phi = (1 + sqrt(5)) / 2
    $r / ($phi * $phi)
}

# Five outer points on unit circle
val $outer = Rosetta::Pentagram::outer_points(1, 0, 0)
assert_eq len(@$outer), 5, "5 outer points"

# All five outer points on the circle of radius 1
var $on_circle = 1
for val $p (@$outer) {
    val $r2 = $p->[0] * $p->[0] + $p->[1] * $p->[1]
    $on_circle = 0 if abs($r2 - 1) > 1e-9
}
assert_ok $on_circle, "all outer points lie on unit circle"

# Edge list connects the star
val $es = Rosetta::Pentagram::edges()
assert_eq len(@$es), 5, "5 star edges"

# Each vertex appears in exactly two edges
var @count = (0) x 5
for val $e (@$es) {
    $count[$e->[0]]++
    $count[$e->[1]]++
}
for val $i (0:4) {
    assert_eq $count[$i], 2, sprintf("vertex %d in 2 edges", $i)
}

# Inner radius shrinks by φ² ≈ 2.618
val $phi = (1 + sqrt(5)) / 2
val $expected_inner = 1 / ($phi * $phi)
assert_near Rosetta::Pentagram::inner_radius(1), $expected_inner, 1e-12,
    "inner radius = r / φ²"

# All star angles at outer vertices are 36°
var $angle_ok = 1
for val $i (0:4) {
    val $a = $outer->[$i]
    val $b = $outer->[($i + 2) % 5]
    val $c = $outer->[($i + 3) % 5]
    val $abx = $b->[0] - $a->[0]
    val $aby = $b->[1] - $a->[1]
    val $acx = $c->[0] - $a->[0]
    val $acy = $c->[1] - $a->[1]
    val $dot = $abx * $acx + $aby * $acy
    val $nb  = sqrt($abx * $abx + $aby * $aby)
    val $nc  = sqrt($acx * $acx + $acy * $acy)
    val $cos_t = $dot / ($nb * $nc)
    val $expected_cos = cos(36 * (4 * atan2(1, 1)) / 180)
    $angle_ok = 0 if abs($cos_t - $expected_cos) > 1e-9
}
assert_ok $angle_ok, "every star tip is 36°"

# Pipe form
1 |> Rosetta::Pentagram::inner_radius |> assert_near($expected_inner, 1e-12, "pipe inner_radius")

test_run
