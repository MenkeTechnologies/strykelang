#!/usr/bin/env stryke
# Rosetta Code: Handle a signal

fn Rosetta::HandleSignal::new() {
    my @log
    { handlers => {}, counts => {}, stopped => 0, log => \@log }
}

fn Rosetta::HandleSignal::register($bus, $signal, $name) {
    if (!exists $bus->{handlers}{$signal}) {
        my @handlers
        $bus->{handlers}{$signal} = \@handlers
    }
    push @{$bus->{handlers}{$signal}}, $name
}

fn Rosetta::HandleSignal::dispatch($bus, $signal) {
    return 0 if !exists $bus->{handlers}{$signal}
    for my $name (@{$bus->{handlers}{$signal}}) {
        push @{$bus->{log}}, $name
        my $count = exists $bus->{counts}{$name} ? $bus->{counts}{$name} : 0
        $bus->{counts}{$name} = $count + 1
        if ($name eq "shutdown") { $bus->{stopped} = 1 }
    }
    len(@{$bus->{handlers}{$signal}})
}

my $bus = Rosetta::HandleSignal::new()
Rosetta::HandleSignal::register($bus, "TERM", "flush")
Rosetta::HandleSignal::register($bus, "TERM", "shutdown")

assert_eq Rosetta::HandleSignal::dispatch($bus, "TERM"), 2, "two TERM handlers ran"
assert_eq join(",", @{$bus->{log}}), "flush,shutdown", "handlers ran in registration order"
assert_eq $bus->{counts}{flush}, 1, "flush count recorded"
assert_eq $bus->{stopped}, 1, "shutdown handler toggled stopped flag"
assert_eq Rosetta::HandleSignal::dispatch($bus, "HUP"), 0, "unhandled signal is ignored"

test_run
