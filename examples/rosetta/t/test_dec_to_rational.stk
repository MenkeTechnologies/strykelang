#!/usr/bin/env stryke
# Rosetta Code: Convert decimal number to rational

fn Math::GCD::gcd($a, $b) {
    $a = abs($a); $b = abs($b)
    while ($b != 0) { my $t = $b; $b = $a % $b; $a = $t }
    $a
}

# Stern-Brocot approach: continued fraction expansion of x to rational p/q
# truncated when the next term would push the denominator past max_q.
fn Rosetta::DecToRat::from_float($x, $max_q) {
    my $sign = $x < 0 ? -1 : 1
    $x = abs($x)
    my $h0 = 0; my $h1 = 1
    my $k0 = 1; my $k1 = 0
    my $b = $x
    my $eps = 1e-12
    while (1) {
        my $a = int($b)
        my $h2 = $a * $h1 + $h0
        my $k2 = $a * $k1 + $k0
        last if $k2 > $max_q
        $h0 = $h1; $h1 = $h2
        $k0 = $k1; $k1 = $k2
        last if abs($b - $a) < $eps
        $b = 1 / ($b - $a)
    }
    [$sign * $h1, $k1]
}

# 0.5 -> 1/2
my $r = Rosetta::DecToRat::from_float(0.5, 1000)
assert_eq $r->[0], 1, "0.5 num"
assert_eq $r->[1], 2, "0.5 den"

# 0.75 -> 3/4
my $r2 = Rosetta::DecToRat::from_float(0.75, 1000)
assert_eq $r2->[0], 3, "0.75 num"
assert_eq $r2->[1], 4, "0.75 den"

# 0.333333... -> 1/3
my $r3 = Rosetta::DecToRat::from_float(1.0/3.0, 1000)
assert_eq $r3->[0], 1, "1/3 num"
assert_eq $r3->[1], 3, "1/3 den"

# pi approx -> 22/7 with denominator cap 10
my $r4 = Rosetta::DecToRat::from_float(3.14159265358979, 10)
assert_eq $r4->[0], 22, "pi -> 22"
assert_eq $r4->[1], 7,  "pi -> /7"

# Negative
my $r5 = Rosetta::DecToRat::from_float(-0.625, 1000)
assert_eq $r5->[0], -5, "-0.625 num"
assert_eq $r5->[1], 8,  "-0.625 den"

test_run
