#!/usr/bin/env stryke
# Rosetta Code: Gzip compression

fn Rosetta::Gzip::compress($data) {
    gzip($data)
}

fn Rosetta::Gzip::decompress($data) {
    gunzip($data)
}

val $original = "This is some data to compress with gzip in Stryke."
val $compressed = $original |> Rosetta::Gzip::compress()
val $decompressed = $compressed |> Rosetta::Gzip::decompress()

$decompressed |> assert_eq($original, "Decompressed matches original")
(len $compressed) |> assert_ok("Compressed data has length")

test_run
