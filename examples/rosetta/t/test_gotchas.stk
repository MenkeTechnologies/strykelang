#!/usr/bin/env stryke
# Rosetta Code: Gotchas

fn Rosetta::Gotchas::demo() {
    # A common gotcha in Perl-like languages is the difference between
    # numeric equality (==) and string equality (eq).
    
    val $a = "10.0"
    val $b = "10"
    
    val $numeric_eq = ($a == $b)
    val $string_eq = ($a eq $b)
    
    ($numeric_eq, $string_eq)
}

val ($num_eq, $str_eq) = Rosetta::Gotchas::demo()
assert_ok $num_eq, "10.0 == 10 is true (numeric)"
assert_ok !$str_eq, "10.0 eq 10 is false (string)"

test_run
