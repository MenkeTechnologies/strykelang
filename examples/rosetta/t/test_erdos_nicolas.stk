#!/usr/bin/env stryke
# Rosetta Code: Erdős–Nicolas numbers (OEIS A194472)
# A non-perfect positive integer n is Erdős–Nicolas if some prefix of
# its sorted divisors sums to n. Equivalently, there exists a proper
# divisor d of n such that the sum of all divisors of n that are ≤ d
# equals n.

fn Rosetta::ErdosNicolas::divisors($n) {
    1:$n |> grep { $n % _ == 0 }
}

fn Rosetta::ErdosNicolas::is($n) {
    return 0 if $n < 2
    my @d = Rosetta::ErdosNicolas::divisors($n)
    # Drop n itself — Erdős–Nicolas considers proper-divisor prefixes.
    pop @d
    my $s = 0
    for my $i (0..len(@d) - 1) {
        $s += $d[$i]
        # Need k > 1 (i.e. at least two divisors) and not all of them
        # (that would make n perfect).
        return 1 if $s == $n && $i >= 1 && $i < len(@d) - 1
    }
    0
}

fn Rosetta::ErdosNicolas::first($k) {
    my @found
    my $n = 1
    while (len(@found) < $k) {
        $n++
        push @found, $n if Rosetta::ErdosNicolas::is($n)
    }
    @found
}

# Sanity on divisor list
my @d24 = Rosetta::ErdosNicolas::divisors(24)
assert_eq join(",", @d24), "1,2,3,4,6,8,12,24", "divisors of 24"

# 24 is the first Erdős–Nicolas number
assert_eq Rosetta::ErdosNicolas::is(24), 1, "24 is Erdős–Nicolas (1+2+3+4+6+8 = 24)"

# Perfect numbers should NOT qualify (sum of *all* proper divisors equals n,
# but the definition requires a strict prefix).
assert_eq Rosetta::ErdosNicolas::is(6),  0, "6 (perfect) is not E-N"
assert_eq Rosetta::ErdosNicolas::is(28), 0, "28 (perfect) is not E-N"

# A few small non-members
assert_eq Rosetta::ErdosNicolas::is(12), 0, "12 is not E-N"
assert_eq Rosetta::ErdosNicolas::is(20), 0, "20 is not E-N"
assert_eq Rosetta::ErdosNicolas::is(30), 0, "30 is not E-N"

# First 1 Erdős–Nicolas number
my @first = Rosetta::ErdosNicolas::first(1)
assert_eq $first[0], 24, "first E-N number is 24"

# Pipe form
24 |> Rosetta::ErdosNicolas::is |> assert_eq(1, "pipe is(24)")

# Threaded: scan a small window
my @hits = ~> 1:100 |> grep { Rosetta::ErdosNicolas::is(_) }
assert_eq join(",", @hits), "24", "only 24 in 1..100"

test_run
