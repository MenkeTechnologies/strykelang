#!/usr/bin/env stryke
# Rosetta Code: Huffman coding

fn Rosetta::HuffmanCoding::build_tree($freqs) {
    var @nodes = ()
    for val $char (keys %$freqs) {
        push @nodes, { char => $char, freq => $freqs->{$char} }
    }
    
    while (len(@nodes) > 1) {
        # Sort by freq
        @nodes = sort { _->{freq} <=> $b->{freq} } @nodes
        val $left = shift @nodes
        val $right = shift @nodes
        val $parent = {
            left => $left,
            right => $right,
            freq => $left->{freq} + $right->{freq}
        }
        push @nodes, $parent
    }
    $nodes[0]
}

fn Rosetta::HuffmanCoding::get_codes($node, $prefix, $codes) {
    if (exists $node->{char}) {
        $codes->{$node->{char}} = $prefix
    } else {
        Rosetta::HuffmanCoding::get_codes($node->{left}, $prefix . "0", $codes)
        Rosetta::HuffmanCoding::get_codes($node->{right}, $prefix . "1", $codes)
    }
}

val $freqs = { "a" => 5, "b" => 9, "c" => 12, "d" => 13, "e" => 16, "f" => 45 }
val $tree = Rosetta::HuffmanCoding::build_tree($freqs)
val $codes = {}
Rosetta::HuffmanCoding::get_codes($tree, "", $codes)

assert_eq len($codes->{f}), 1, "f should have shortest code"
assert_ok len($codes->{a}) > len($codes->{f}), "a should have longer code than f"

test_run
