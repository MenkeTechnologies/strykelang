#!/usr/bin/env stryke
# Rosetta Code: State name puzzle
# Find all unordered pairs of US state names whose concatenated
# letters can be partitioned into two different state names.
# Classic puzzle credited to Martin Gardner / Will Shortz.

fn Rosetta::StatePuzzle::canonical($s) {
    var $clean = $s
    $clean =~ s/\s+//g
    join("", sort split //, lc($clean))
}

fn Rosetta::StatePuzzle::find_pairs($states) {
    val $n = len(@$states)
    val %by_key
    for val $i (0:$n - 2) {
        for val $j ($i + 1:$n - 1) {
            val $k = Rosetta::StatePuzzle::canonical($states->[$i] . $states->[$j])
            push @{$by_key{$k}}, [$i, $j]
        }
    }
    var @pairs
    for val $k (keys %by_key) {
        val $list = $by_key{$k}
        next if len(@$list) < 2
        val $first  = $list->[0]
        val $second = $list->[1]
        push @pairs, [
            [$states->[$first->[0]],  $states->[$first->[1]]],
            [$states->[$second->[0]], $states->[$second->[1]]]
        ]
    }
    @pairs
}

# Helper sanity
assert_eq Rosetta::StatePuzzle::canonical("North Dakota"),
    Rosetta::StatePuzzle::canonical("Dakota North"),
    "canonical sorts letters"

# Concrete: NORTH CAROLINA + SOUTH DAKOTA == NORTH DAKOTA + SOUTH CAROLINA
val $left  = Rosetta::StatePuzzle::canonical("North Carolina" . "South Dakota")
val $right = Rosetta::StatePuzzle::canonical("North Dakota" . "South Carolina")
assert_eq $left, $right, "NC + SD letters = ND + SC letters"

# A second classic: New Hampshire + Vermont
# Test that pair-finding for the small set picks up a swap
val @states = ("North Carolina", "South Dakota", "North Dakota", "South Carolina")
val @pairs = Rosetta::StatePuzzle::find_pairs(\@states)
assert_ok len(@pairs) >= 1, "found a state-pair swap"

# The pair contains both originals and a rearrangement
val $pair = $pairs[0]
val $orig_set = join("|", sort @{$pair->[0]})
val $rearr_set = join("|", sort @{$pair->[1]})
assert_ok $orig_set ne $rearr_set, "rearrangement differs from original"
assert_eq Rosetta::StatePuzzle::canonical($pair->[0][0] . $pair->[0][1]),
    Rosetta::StatePuzzle::canonical($pair->[1][0] . $pair->[1][1]),
    "letters preserved"

# Pipe form
"Texas" |> Rosetta::StatePuzzle::canonical |> assert_eq("aestx", "pipe canonical")

test_run
