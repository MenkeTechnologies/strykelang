#!/usr/bin/env stryke
# Rosetta Code: Soloway's recurring rainfall

fn Rosetta::Rainfall::average($mock_inputs) {
    var $sum = 0.0
    var $count = 0
    
    for val $val (@$mock_inputs) {
        if ($val == 999) {
            last
        }
        if ($val >= 0) {
            $sum += $val
            $count++
        }
    }
    
    if ($count == 0) {
        return 0.0
    }
    $sum / $count
}

# Test cases
val $res1 = Rosetta::Rainfall::average([10, 20, -5, 30, 999, 50])
# Valid: 10, 20, 30. (Sum 60, Count 3, Avg 20)
assert_eq $res1, 20.0, "Average with negative and 999 terminator"

val $res2 = Rosetta::Rainfall::average([999])
assert_eq $res2, 0.0, "Average with immediate terminator"

val $res3 = Rosetta::Rainfall::average([-1, -2, 999])
assert_eq $res3, 0.0, "Average with only negatives"

test_run
