#!/usr/bin/env stryke
# Rosetta Code: Bitmap/Bézier curves/Cubic

fn Rosetta::Bezier::cubic($p0, $p1, $p2, $p3, $steps) {
    my @points
    for (my $i = 0; $i <= $steps; $i++) {
        my $t = $i / $steps
        my $omt = 1 - $t
        # B(t) = (1-t)^3 P0 + 3(1-t)^2 t P1 + 3(1-t) t^2 P2 + t^3 P3
        my $x = $omt**3 * $p0->[0] + 3 * $omt**2 * $t * $p1->[0] + 3 * $omt * $t**2 * $p2->[0] + $t**3 * $p3->[0]
        my $y = $omt**3 * $p0->[1] + 3 * $omt**2 * $t * $p1->[1] + 3 * $omt * $t**2 * $p2->[1] + $t**3 * $p3->[1]
        push @points, [$x, $y]
    }
    \@points
}

my $p0 = [0, 0]
my $p1 = [0, 10]
my $p2 = [10, 10]
my $p3 = [10, 0]
my $curve = Rosetta::Bezier::cubic($p0, $p1, $p2, $p3, 10)

assert_eq len(@$curve), 11, "Curve has 11 points"
assert_eq $curve->[0]->[0], 0, "Start x"
assert_eq $curve->[10]->[0], 10, "End x"
# Midpoint t=0.5: 0.125*0 + 3*0.25*0.5*0 + 3*0.5*0.25*10 + 0.125*10 = 0 + 0 + 3.75 + 1.25 = 5
assert_eq $curve->[5]->[0], 5, "Midpoint x"
# Midpoint t=0.5: 0.125*0 + 3*0.25*0.5*10 + 3*0.5*0.25*10 + 0.125*0 = 0 + 3.75 + 3.75 + 0 = 7.5
assert_eq $curve->[5]->[1], 7.5, "Midpoint y"

test_run
