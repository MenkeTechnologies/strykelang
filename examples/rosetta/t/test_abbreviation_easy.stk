#!/usr/bin/env stryke
# Rosetta Code: Abbreviation, easy

fn Rosetta::Abbreviation::solve($commands_str, $input_str) {
    val @commands = $commands_str |> split(/\s+/)
    var %abbrevs
    
    @commands |> map {
        var $last_upper = -1
        for (var $i = 0; $i < length(_); $i++) {
            if (substr(_, $i, 1) =~ /[A-Z]/) {
                $last_upper = $i
            }
        }

        val $full = lc(_)
        val $min_len = $last_upper + 1
        
        if ($min_len == 0 && length($full) > 0) {
            $abbrevs{$full} = $full
        } else {
            for (var $i = $min_len; $i <= length($full); $i++) {
                val $abbr = substr($full, 0, $i)
                $abbrevs{$abbr} = $full
            }
        }
    }
    
    val @input_words = $input_str |> split(/\s+/)
    var @results
    @input_words |> map {
        val $word = lc(_)
        if (exists $abbrevs{$word}) {
            push @results, $abbrevs{$word}
        } else {
            push @results, "*error*"
        }
    }
    join(" ", @results)
}

val $commands = "Add ALTer  BAckup Bottom  CLeAn cLOse CoPy Delete Help iNsert List Move Quit Edit Replace REtrieve Save SHow Table Type"
val $input = "re fORe ba TAB"
val $expected = "retrieve *error* backup table"

assert_eq(Rosetta::Abbreviation::solve($commands, $input), $expected, "abbreviation easy test")

test_run
