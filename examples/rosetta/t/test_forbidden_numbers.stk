#!/usr/bin/env stryke
# Rosetta Code: Forbidden numbers

fn Rosetta::ForbiddenNumbers::check($n, @forbidden) {
    val $s = "$n"
    var $found = 0
    for val $f (@forbidden) {
        if (index($s, "$f") != -1) {
            $found = 1
            last
        }
    }
    $found
}

fn Rosetta::ForbiddenNumbers::count_not_forbidden($limit, @forbidden) {
    # Using parallel grep to count
    ~> 1:$limit grep { !Rosetta::ForbiddenNumbers::check(_, @forbidden) } |> len()
}

# Example: count numbers up to 100 with no digit 1 or 3
val @forbidden13 = (1, 3)
val $count = Rosetta::ForbiddenNumbers::count_not_forbidden(100, @forbidden13)

# 1..100:
# Forbidden: 1, 3, 10..19, 21, 23, 30..39, 41, 43, 51, 53, 61, 63, 71, 73, 81, 83, 91, 93, 100
# Digits available: 0, 2, 4, 5, 6, 7, 8, 9 (8 digits)
# 1-digit: 2, 4, 5, 6, 7, 8, 9 (7 numbers)
# 2-digits: [2,4,5,6,7,8,9] x [0,2,4,5,6,7,8,9] (7 * 8 = 56 numbers)
# Total: 7 + 56 = 63. (100 is forbidden as it has 1)
assert_eq $count, 63, "Count non-forbidden up to 100 (no 1,3)"

# Finding the Nth non-forbidden number
fn Rosetta::ForbiddenNumbers::nth($n, @forbidden) {
    var $count = 0
    var $curr = 0
    while ($count < $n) {
        $curr++
        if (!Rosetta::ForbiddenNumbers::check($curr, @forbidden)) {
            $count++
        }
    }
    $curr
}

# 1st: 2, 2nd: 4, 3rd: 5, 4th: 6, 5th: 7, 6th: 8, 7th: 9, 8th: 20, 9: 22, 10: 24
assert_eq Rosetta::ForbiddenNumbers::nth(10, @forbidden13), 24, "10th non-forbidden (no 1,3) is 24"

test_run
