#!/usr/bin/env stryke
# Rosetta Code: QR Decomposition

fn Rosetta::QrDecomposition::dot($v1, $v2) {
    var $sum = 0.0
    for val $i (0..len(@$v1)-1) { $sum = $sum + $v1->[$i] * $v2->[$i] }
    $sum
}

fn Rosetta::Qr::decompose($A) {
    val $rows = len(@$A)
    val $cols = len(@{$A->[0]})
    var @Q; var @R
    
    # Initialize R
    for val $i (0:$cols-1) {
        var @row
        for val $j (0:$cols-1) { push @row, 0.0 }
        push @R, \@row
    }
    
    # Orthogonalization
    var @u
    for val $j (0:$cols-1) {
        var @v
        for val $i (0:$rows-1) { push @v, $A->[$i]->[$j] }
        
        for val $i (0:$j-1) {
            val $ui = $u[$i]
            $R[$i]->[$j] = Rosetta::QrDecomposition::dot($ui, \@v)
            for val $k (0:$rows-1) { $v[$k] = $v[$k] - $R[$i]->[$j] * $ui->[$k] }
        }
        
        $R[$j]->[$j] = sqrt(Rosetta::QrDecomposition::dot(\@v, \@v))
        var @q_col
        for val $k (0:$rows-1) { push @q_col, $v[$k] / $R[$j]->[$j] }
        push @u, \@q_col
    }
    
    # Q is built from u columns
    for val $i (0:$rows-1) {
        var @row
        for val $j (0:$cols-1) { push @row, $u[$j]->[$i] }
        push @Q, \@row
    }
    
    (\@Q, \@R)
}

val $A = [[12, -51, 4], [6, 167, -68], [-4, 24, -41]]
val ($Q, $R) = Rosetta::Qr::decompose($A)

# Check R diagonal
assert_ok abs($R->[0]->[0] - 14.0) < 0.0001, "R[0][0] is 14"
assert_ok abs($R->[1]->[1] - 175.0) < 0.0001, "R[1][1] is 175"

test_run
