#!/usr/bin/env stryke
# Rosetta Code: Longest increasing subsequence — O(n log n) patience sort

fn Rosetta::LisFast::lower_bound($tails, $x) {
    my ($lo, $hi) = (0, len(@$tails))
    while ($lo < $hi) {
        my $mid = int(($lo + $hi) / 2)
        if ($tails->[$mid] < $x) {
            $lo = $mid + 1
        } else {
            $hi = $mid
        }
    }
    $lo
}

fn Rosetta::LisFast::length_only($arr) {
    my @tails
    for my $x (@$arr) {
        my $i = Rosetta::LisFast::lower_bound(\@tails, $x)
        if ($i == len(@tails)) {
            push @tails, $x
        } else {
            $tails[$i] = $x
        }
    }
    len(@tails)
}

fn Rosetta::LisFast::sequence($arr) {
    my $n = len(@$arr)
    return [] if $n == 0
    my @tails
    my @tail_idx
    my @prev = (-1) x $n
    for my $i (0..$n - 1) {
        my $x = $arr->[$i]
        my $pos = Rosetta::LisFast::lower_bound(\@tails, $x)
        if ($pos == len(@tails)) {
            push @tails, $x
            push @tail_idx, $i
        } else {
            $tails[$pos] = $x
            $tail_idx[$pos] = $i
        }
        $prev[$i] = $pos > 0 ? $tail_idx[$pos - 1] : -1
    }
    my @seq
    my $cur = $tail_idx[-1]
    while ($cur != -1) {
        unshift @seq, $arr->[$cur]
        $cur = $prev[$cur]
    }
    \@seq
}

# Classic
assert_eq Rosetta::LisFast::length_only([10, 22, 9, 33, 21, 50, 41, 60]), 5, "LIS length = 5"
assert_eq Rosetta::LisFast::length_only([3, 10, 2, 1, 20]), 3, "LIS [3,10,20] len = 3"

# Strictly increasing -> all
assert_eq Rosetta::LisFast::length_only([1, 2, 3, 4, 5]), 5, "increasing -> n"

# Strictly decreasing -> 1
assert_eq Rosetta::LisFast::length_only([5, 4, 3, 2, 1]), 1, "decreasing -> 1"

# Empty / single
assert_eq Rosetta::LisFast::length_only([]), 0, "empty -> 0"
assert_eq Rosetta::LisFast::length_only([7]), 1, "single -> 1"

# Duplicates: strict LIS
assert_eq Rosetta::LisFast::length_only([1, 1, 1, 1]), 1, "all equal strict -> 1"
assert_eq Rosetta::LisFast::length_only([1, 2, 2, 3]), 3, "with dup -> 3"

# Reconstruct one valid sequence
my $seq = Rosetta::LisFast::sequence([10, 22, 9, 33, 21, 50, 41, 60])
assert_eq len(@$seq), 5, "reconstructed LIS length = 5"
# Validate it is strictly increasing
for my $i (1..len(@$seq) - 1) {
    assert_ok($seq->[$i] > $seq->[$i - 1], "seq[$i] > seq[" . ($i - 1) . "]")
}

test_run
