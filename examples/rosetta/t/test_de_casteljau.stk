#!/usr/bin/env stryke
# Rosetta Code: de Casteljau's algorithm
# Evaluate a Bezier curve at parameter t in [0, 1].

fn Rosetta::DeCasteljau::eval($pts, $t) {
    my @work = map { [$_->[0], $_->[1]] } @$pts
    my $n = len(@work)
    my $omt = 1 - $t
    while ($n > 1) {
        for my $i (0..$n-2) {
            $work[$i][0] = $omt * $work[$i][0] + $t * $work[$i + 1][0]
            $work[$i][1] = $omt * $work[$i][1] + $t * $work[$i + 1][1]
        }
        $n--
    }
    [$work[0][0], $work[0][1]]
}

fn Rosetta::DeCasteljau::close($x, $y) { abs($x - $y) < 1e-9 }

# Linear (degree 1): straight line from P0 to P1
my $line = [[0, 0], [10, 20]]
my $p0 = Rosetta::DeCasteljau::eval($line, 0.0)
my $p1 = Rosetta::DeCasteljau::eval($line, 1.0)
my $pmid = Rosetta::DeCasteljau::eval($line, 0.5)
assert_ok Rosetta::DeCasteljau::close($p0->[0], 0), "line t=0 x"
assert_ok Rosetta::DeCasteljau::close($p0->[1], 0), "line t=0 y"
assert_ok Rosetta::DeCasteljau::close($p1->[0], 10), "line t=1 x"
assert_ok Rosetta::DeCasteljau::close($p1->[1], 20), "line t=1 y"
assert_ok Rosetta::DeCasteljau::close($pmid->[0], 5), "line t=0.5 x = 5"
assert_ok Rosetta::DeCasteljau::close($pmid->[1], 10), "line t=0.5 y = 10"

# Quadratic: P0=(0,0), P1=(1,2), P2=(2,0). Closed form: B(t) = (2t, 4t(1-t))
my $quad = [[0, 0], [1, 2], [2, 0]]
my $q_mid = Rosetta::DeCasteljau::eval($quad, 0.5)
assert_ok Rosetta::DeCasteljau::close($q_mid->[0], 1.0), "quad t=0.5 x = 1"
assert_ok Rosetta::DeCasteljau::close($q_mid->[1], 1.0), "quad t=0.5 y = 1"
my $q_q = Rosetta::DeCasteljau::eval($quad, 0.25)
assert_ok Rosetta::DeCasteljau::close($q_q->[0], 0.5), "quad t=0.25 x = 0.5"
assert_ok Rosetta::DeCasteljau::close($q_q->[1], 0.75), "quad t=0.25 y = 0.75"

# Cubic Bezier passes through endpoints exactly
my $cubic = [[0, 0], [1, 3], [2, 3], [3, 0]]
my $c0 = Rosetta::DeCasteljau::eval($cubic, 0.0)
my $c1 = Rosetta::DeCasteljau::eval($cubic, 1.0)
assert_ok Rosetta::DeCasteljau::close($c0->[0], 0), "cubic t=0 x"
assert_ok Rosetta::DeCasteljau::close($c0->[1], 0), "cubic t=0 y"
assert_ok Rosetta::DeCasteljau::close($c1->[0], 3), "cubic t=1 x"
assert_ok Rosetta::DeCasteljau::close($c1->[1], 0), "cubic t=1 y"

# Single point -> degenerate constant curve
my $deg = Rosetta::DeCasteljau::eval([[7, 11]], 0.42)
assert_ok Rosetta::DeCasteljau::close($deg->[0], 7), "single point x"
assert_ok Rosetta::DeCasteljau::close($deg->[1], 11), "single point y"

test_run
