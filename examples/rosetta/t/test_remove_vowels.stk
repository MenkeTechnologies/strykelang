#!/usr/bin/env stryke
# Rosetta Code: Remove vowels

fn Rosetta::RemoveVowels::remove_vowels($str) {
    my $modified_str = $str;
    $modified_str =~ tr/aeiouAEIOU//d;
    $modified_str;
}

assert_eq Rosetta::RemoveVowels::remove_vowels("Hello World"), "Hll Wrld", "remove from hello world"
assert_eq Rosetta::RemoveVowels::remove_vowels("Stryke Language"), "Stryk Lngg", "remove from stryke"
assert_eq Rosetta::RemoveVowels::remove_vowels("AEIOU"), "", "only vowels"
assert_eq Rosetta::RemoveVowels::remove_vowels("bcd"), "bcd", "no vowels"

"madam" |> Rosetta::RemoveVowels::remove_vowels |> assert_eq("mdm", "pipe remove vowels")

test_run
