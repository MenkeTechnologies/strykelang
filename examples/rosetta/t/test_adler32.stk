#!/usr/bin/env stryke
# Rosetta Code: Adler-32

fn Rosetta::Adler32::compute($text) {
    my $a = 1
    my $b = 0
    my $mod = 65521
    
    # Calculate checksum
    for my $c ($text |> chars() |> map { ord($_) }) {
        $a = ($a + $c) % $mod
        $b = ($b + $a) % $mod
    }
    
    # Return 32-bit integer
    ($b << 16) | $a
}

my $t1 = "Wikipedia"
my $h1 = Rosetta::Adler32::compute($t1)
# 300286872 -> 0x11E60398
assert_eq $h1, 300286872, "Adler-32 Wikipedia"

my $t2 = "Stryke"
my $h2 = Rosetta::Adler32::compute($t2)
# S=83, t=116, r=114, y=121, k=107, e=101 => sum = 642, a=643
# b:
# 83+1=84
# 84+116=200
# 200+114=314
# 314+121=435
# 435+107=542
# 542+101=643
# b = 84+200+314+435+542+643 = 2218
# (2218 << 16) | 643 = 145358848 | 643 = 145359491
assert_eq $h2, 145359491, "Adler-32 Stryke"

test_run
