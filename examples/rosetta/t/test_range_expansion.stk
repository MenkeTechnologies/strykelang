#!/usr/bin/env stryke
# Rosetta Code: Range expansion

fn Rosetta::RangeExpansion::solve($s) {
    val @parts = split /,/, $s
    var @res
    for val $p (@parts) {
        if ($p =~ /(-?\d+)-(-?\d+)/) {
            val $start = $1
            val $end = $2
            push @res, ($start:$end)
        } else {
            push @res, $p
        }
    }
    \@res
}

val $exp = Rosetta::RangeExpansion::solve("-6,-3-1,3-5,7,8,14,15,17-20")
assert_eq join(",", @$exp), "-6,-3,-2,-1,0,1,3,4,5,7,8,14,15,17,18,19,20", "range expansion"

test_run
