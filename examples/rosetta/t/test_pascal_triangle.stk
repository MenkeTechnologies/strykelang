#!/usr/bin/env stryke
# Rosetta Code: Pascal's Triangle

fn Rosetta::PascalTriangle::next_row($prev) {
    val @p = @$prev
    var @mid
    for val $i (0..len(@p)-2) {
        push @mid, $p[$i] + $p[$i+1]
    }
    val @res = (1, @mid, 1)
    \@res
}

fn Rosetta::PascalTriangle::generate($n) {
    var @rows = ([1])
    for val $i (1:$n-1) {
        push @rows, Rosetta::PascalTriangle::next_row($rows[-1])
    }
    \@rows
}

fn Rosetta::PascalTriangle::to_str($n) {
    val $p = Rosetta::PascalTriangle::generate($n)
    var @rows
    for val $row (@$p) {
        push @rows, join(",", @$row)
    }
    join(";", @rows)
}

assert_eq Rosetta::PascalTriangle::to_str(1), "1", "pascal 1"
assert_eq Rosetta::PascalTriangle::to_str(2), "1;1,1", "pascal 2"
assert_eq Rosetta::PascalTriangle::to_str(3), "1;1,1;1,2,1", "pascal 3"
assert_eq Rosetta::PascalTriangle::to_str(5), "1;1,1;1,2,1;1,3,3,1;1,4,6,4,1", "pascal 5"

test_run
