#!/usr/bin/env stryke
# Rosetta Code: Pascal's Triangle

fn next_row {
    my $prev = $_[0]
    my @p = @$prev
    my @mid
    for my $i (0..scalar(@p)-2) {
        push @mid, $p[$i] + $p[$i+1]
    }
    my @res = (1, @mid, 1)
    my $result = [@res]
    $result
}

fn pascal {
    my $n = $_[0]
    my @rows = ([1])
    for my $i (1..$n-1) {
        push @rows, next_row($rows[-1])
    }
    my $result = [@rows]
    $result
}

fn matrix_to_string {
    my $m = $_[0]
    my @rows
    for my $row (@$m) {
        push @rows, join(",", @$row)
    }
    join(";", @rows)
}

fn pascal_to_str {
    my $n = $_[0]
    my $p = pascal($n)
    matrix_to_string($p)
}

assert_eq pascal_to_str(1), "1", "pascal 1"
assert_eq pascal_to_str(2), "1;1,1", "pascal 2"
assert_eq pascal_to_str(3), "1;1,1;1,2,1", "pascal 3"
assert_eq pascal_to_str(5), "1;1,1;1,2,1;1,3,3,1;1,4,6,4,1", "pascal 5"

test_run
