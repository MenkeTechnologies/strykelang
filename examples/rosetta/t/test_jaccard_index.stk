#!/usr/bin/env stryke
# Rosetta Code: Jaccard index

fn Rosetta::JaccardIndex::compute($a_ref, $b_ref) {
    var %set_a
    var %set_b
    for val $x (@$a_ref) { $set_a{$x} = 1 }
    for val $x (@$b_ref) { $set_b{$x} = 1 }
    
    var $intersection = 0
    val @keys_a = keys %set_a
    for val $k (@keys_a) {
        if (exists $set_b{$k}) { $intersection++ }
    }
    
    var $union = len(@keys_a)
    val @keys_b = keys %set_b
    for val $k (@keys_b) {
        if (!exists $set_a{$k}) { $union++ }
    }
    
    if ($union == 0) { return 1.0 }
    $intersection / $union
}

val $s1 = [1, 2, 3, 4]
val $s2 = [3, 4, 5, 6]
# intersection: 3, 4 (size 2)
# union: 1, 2, 3, 4, 5, 6 (size 6)
# index: 2/6 = 0.3333
assert_near Rosetta::JaccardIndex::compute($s1, $s2), 0.3333, 0.0001, "Jaccard index 1,2,3,4 vs 3,4,5,6"

val $s3 = ["apple", "banana"]
val $s4 = ["apple", "banana"]
assert_eq Rosetta::JaccardIndex::compute($s3, $s4), 1.0, "Identical sets"

test_run
