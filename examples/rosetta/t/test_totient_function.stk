#!/usr/bin/env stryke
# Rosetta Code: Totient function

fn my_gcd($a, $b) {
    while ($b != 0) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn totient($n) {
    if ($n == 1) { 1 }
    else {
        my $count = 0
        for my $i (1..$n) {
            if (my_gcd($i, $n) == 1) { $count++ }
        }
        $count
    }
}

assert_eq totient(1), 1, "phi(1)"
assert_eq totient(2), 1, "phi(2)"
assert_eq totient(5), 4, "phi(5) prime"
assert_eq totient(10), 4, "phi(10) (1,3,7,9)"
assert_eq totient(12), 4, "phi(12) (1,5,7,11)"

10 |> totient |> assert_eq(4, "pipe totient")

test_run
