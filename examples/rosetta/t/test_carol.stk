#!/usr/bin/env stryke
# Rosetta Code: Carol numbers

fn carol($n) {
    (2**$n - 1)**2 - 2
}

fn carol_list($max_n) {
    ~> 1..$max_n map { carol($_) }
}

assert_eq carol(1), -1, "C1"
assert_eq carol(2), 7, "C2"
assert_eq carol(3), 47, "C3"
assert_eq carol(4), 223, "C4"

my @list = carol_list(4)
assert_eq join(",", @list), "-1,7,47,223", "Carol list"

4 |> carol |> assert_eq(223, "pipe Carol")

test_run
