#!/usr/bin/env stryke
# Rosetta Code: Carol numbers

fn Rosetta::Carol::compute($n) {
    (2**$n - 1)**2 - 2
}

fn Rosetta::Carol::list($max_n) {
    ~> 1:$max_n map { Rosetta::Carol::compute($_) }
}

assert_eq Rosetta::Carol::compute(1), -1, "C1"
assert_eq Rosetta::Carol::compute(2), 7, "C2"
assert_eq Rosetta::Carol::compute(3), 47, "C3"
assert_eq Rosetta::Carol::compute(4), 223, "C4"

my @list = Rosetta::Carol::list(4)
assert_eq join(",", @list), "-1,7,47,223", "Carol list"

4 |> Rosetta::Carol::compute |> assert_eq(223, "pipe Carol")

test_run
