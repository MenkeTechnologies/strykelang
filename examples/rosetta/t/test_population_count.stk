#!/usr/bin/env stryke
# Rosetta Code: Population count
# Count of 1-bits in the binary representation of a non-negative integer.
# Define popcount, then derive evil/odious classifications:
#   evil   = popcount even, OEIS A001969
#   odious = popcount odd,  OEIS A000069

fn Rosetta::PopCount::count($n) {
    my $c = 0
    while ($n > 0) {
        $c += $n & 1
        $n = $n >> 1
    }
    $c
}

fn Rosetta::PopCount::is_evil($n)   { Rosetta::PopCount::count($n) % 2 == 0 }
fn Rosetta::PopCount::is_odious($n) { Rosetta::PopCount::count($n) % 2 == 1 }

fn Rosetta::PopCount::three_pow_seq($k) {
    1:$k |> map {
        my $p = 1
        for my $j (~> 1:$_ - 1) { $p *= 3 }
        Rosetta::PopCount::count($p)
    }
}

# Direct
assert_eq Rosetta::PopCount::count(0),   0, "popcount(0) = 0"
assert_eq Rosetta::PopCount::count(1),   1, "popcount(1) = 1"
assert_eq Rosetta::PopCount::count(7),   3, "popcount(7) = 3"
assert_eq Rosetta::PopCount::count(255), 8, "popcount(255) = 8"
assert_eq Rosetta::PopCount::count(0b1010101010), 5, "popcount of alternating"

# Evil and odious classification (rosetta task)
# First 30 evil numbers: 0, 3, 5, 6, 9, 10, 12, 15, 17, 18, 20, 23, 24, 27, 29, 30, 33, …
my @evil = ~> 0:35 |> grep { Rosetta::PopCount::is_evil(_) }
assert_eq join(",", @evil[0..9]),
    "0,3,5,6,9,10,12,15,17,18",
    "first 10 evil numbers"

# First 10 odious numbers: 1, 2, 4, 7, 8, 11, 13, 14, 16, 19, …
my @odious = ~> 0:35 |> grep { Rosetta::PopCount::is_odious(_) }
assert_eq join(",", @odious[0..9]),
    "1,2,4,7,8,11,13,14,16,19",
    "first 10 odious numbers"

# Popcount of 3^n for n=0..29 (rosetta task: first 30)
my @pop3 = ~> 1:30 |> map {
    my $p = 1
    for my $j (~> 1:$_ - 1) { $p *= 3 }
    Rosetta::PopCount::count($p)
}
# 3^0=1 → 1; 3^1=3 → 2; 3^2=9 → 2; 3^3=27 → 4; 3^4=81 → 3; …
assert_eq join(",", @pop3[0..6]), "1,2,2,4,3,6,6", "popcount(3^0..6)"

# Pipe form
0xFFFF |> Rosetta::PopCount::count |> assert_eq(16, "pipe popcount(0xFFFF)")

test_run
