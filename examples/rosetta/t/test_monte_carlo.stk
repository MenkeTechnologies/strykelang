#!/usr/bin/env stryke
# Rosetta Code: Monte Carlo methods

fn Rosetta::MonteCarlo::pi_sequential($samples) {
    var $inside = 0
    for val $i (1:$samples) {
        val $x = rand()
        val $y = rand()
        if ($x * $x + $y * $y <= 1.0) {
            $inside++
        }
    }
    4.0 * $inside / $samples
}

fn Rosetta::MonteCarlo::pi_parallel($samples, $workers) {
    val $chunk = int($samples / $workers)
    val @results = ~> 1:$workers pmap {
        var $inside = 0
        srand(_ + now_ns)
        for val $i (1:$chunk) {
            val $x = rand()
            val $y = rand()
            if ($x * $x + $y * $y <= 1.0) {
                $inside++
            }
        }
        $inside
    }
    var $total_inside = 0
    for val $v (@results) {
        $total_inside += $v
    }
    4.0 * $total_inside / ($chunk * $workers)
}

val $pi_seq = Rosetta::MonteCarlo::pi_sequential(100000)
assert_ok $pi_seq > 3.1 && $pi_seq < 3.2, "Sequential MC Pi is approximately Pi: $pi_seq"

val $pi_par = Rosetta::MonteCarlo::pi_parallel(100000, 4)
assert_ok $pi_par > 3.1 && $pi_par < 3.2, "Parallel MC Pi is approximately Pi: $pi_par"

# Pipeline version: using the dedicated pmap_reduce builtin
val $inside_pipe = 0 + (1:10000 |> pmap_reduce { srand(_ + now_ns); val $x = rand(); val $y = rand(); ($x*$x + $y*$y <= 1.0) ? 1 : 0 } { $a + $b })
val $pi_pipe = 4.0 * $inside_pipe / 10000
assert_ok $pi_pipe > 3.0 && $pi_pipe < 3.3, "Pipeline MC Pi is approximately Pi: $pi_pipe"

test_run
