#!/usr/bin/env stryke
# Rosetta Code: Moebius function

fn Rosetta::Moebius::compute($n) {
    if ($n == 1) {
        1
    } else {
        my @factors = prime_factors($n)
        my %counts
        my $has_square = 0
        for my $f (@factors) {
            $counts{$f}++
            if ($counts{$f} > 1) { $has_square = 1 }
        }
        
        if ($has_square) {
            0
        } else {
            my $num_factors = len(@factors)
            if ($num_factors % 2 == 0) { 1 }
            else { -1 }
        }
    }
}

assert_eq Rosetta::Moebius::compute(1), 1, "mu(1) = 1"
assert_eq Rosetta::Moebius::compute(2), -1, "mu(2) = -1"
assert_eq Rosetta::Moebius::compute(4), 0, "mu(4) = 0"
assert_eq Rosetta::Moebius::compute(6), 1, "mu(6) = 1 (2*3)"
assert_eq Rosetta::Moebius::compute(10), 1, "mu(10) = 1 (2*5)"
assert_eq Rosetta::Moebius::compute(30), -1, "mu(30) = -1 (2*3*5)"

6 |> Rosetta::Moebius::compute |> assert_eq(1, "pipe Moebius")

test_run
