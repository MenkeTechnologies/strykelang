#!/usr/bin/env stryke
# Rosetta Code: Bifid cipher

fn Rosetta::Bifid::prepare_key($key) {
    val $alphabet = "ABCDEFGHIKLMNOPQRSTUVWXYZ" # No J
    var $k = $key |> uc() |> { _ =~ s/J/I/gr } |> { _ =~ s/[^A-Z]//gr }
    $k .= $alphabet
    
    var %seen
    var @grid
    for val $c ($k |> chars()) {
        if (!exists $seen{$c}) {
            push @grid, $c
            $seen{$c} = 1
        }
    }
    \@grid
}

fn Rosetta::Bifid::find_pos($grid, $char) {
    for (var $i = 0; $i < 25; $i++) {
        if ($grid->[$i] eq $char) {
            return [$i / 5 | 0, $i % 5]
        }
    }
    [-1, -1]
}

fn Rosetta::Bifid::encode($text, $key) {
    val $grid = Rosetta::Bifid::prepare_key($key)
    val $t = $text |> uc() |> { _ =~ s/J/I/gr } |> { _ =~ s/[^A-Z]//gr }
    var @chars = $t |> chars()
    
    var @rows
    var @cols
    
    for val $c (@chars) {
        val $p = Rosetta::Bifid::find_pos($grid, $c)
        push @rows, $p->[0]
        push @cols, $p->[1]
    }
    
    val @combined = (@rows, @cols)
    var @res
    for (var $i = 0; $i < len(@combined); $i += 2) {
        val $r = $combined[$i]
        val $c = $combined[$i+1]
        push @res, $grid->[$r * 5 + $c]
    }
    
    join("", @res)
}

fn Rosetta::Bifid::decode($text, $key) {
    val $grid = Rosetta::Bifid::prepare_key($key)
    val $t = $text |> uc() |> { _ =~ s/J/I/gr } |> { _ =~ s/[^A-Z]//gr }
    var @chars = $t |> chars()
    
    var @combined
    for val $c (@chars) {
        val $p = Rosetta::Bifid::find_pos($grid, $c)
        push @combined, $p->[0], $p->[1]
    }
    
    val $n = len(@combined) / 2
    val @rows = @combined[0 : $n-1]
    val @cols = @combined[$n : 2*$n-1]
    
    val @res = ~> 0:($n-1) map {
        val $r = $rows[_]
        val $c = $cols[_]
        $grid->[$r * 5 + $c]
    }
    
    join("", @res)
}

val $key = "BIFID"
val $t = "ATTACKATDAWN"
val $enc = Rosetta::Bifid::encode($t, $key)

# The expected ciphertext for "ATTACKATDAWN" with key "BIFID"
assert_eq $enc, "DQEDBXYUAYUG", "encode ATTACKATDAWN with Bifid"
assert_eq Rosetta::Bifid::decode($enc, $key), $t, "decode with Bifid cipher"

test_run
