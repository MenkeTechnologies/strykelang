#!/usr/bin/env stryke
# Rosetta Code: Hello world/Web server

fn Rosetta::Web::start($port) {
    # spawn the server so we can test it
    spawn {
        serve($port, fn {
            val ($req) = @_
            "Hello World!"
        })
    }
}

val $port = 18081
Rosetta::Web::start($port)

# Give the server a moment to start
sleep 0.1

val $res = fetch("http://localhost:$port")
assert_eq $res, "Hello World!", "web server returned hello world"

test_run
