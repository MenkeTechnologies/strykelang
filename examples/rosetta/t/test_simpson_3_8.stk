#!/usr/bin/env stryke
# Rosetta Code: Simpson's 3/8 rule — composite quadrature with n divisible by 3

fn Rosetta::Simpson38::integrate($f, $a, $b, $n) {
    return undef if $n <= 0 || $n % 3 != 0
    val $h = ($b - $a) / $n
    var $sum = $f($a) + $f($b)
    for val $i (1:$n - 1) {
        val $x = $a + $i * $h
        val $w = ($i % 3 == 0) ? 2 : 3
        $sum += $w * $f($x)
    }
    3 * $h / 8 * $sum
}

fn Rosetta::Simpson38::close($x, $y, $eps) { abs($x - $y) < $eps }

# Integral of x^2 from 0 to 1 = 1/3
val $i1 = Rosetta::Simpson38::integrate(fn { _ ** 2 }, 0, 1, 9)
assert_ok Rosetta::Simpson38::close($i1, 1.0/3.0, 1e-9), "x^2 [0,1] = 1/3 (got $i1)"

# Integral of sin(x) from 0 to pi = 2
val $pi = 4 * atan2(1, 1)
val $i2 = Rosetta::Simpson38::integrate(fn {sin}, 0, $pi, 30)
assert_ok Rosetta::Simpson38::close($i2, 2.0, 1e-4), "sin [0,pi] = 2 (got $i2)"

# Integral of e^x from 0 to 1 = e - 1
val $i3 = Rosetta::Simpson38::integrate(fn {exp}, 0, 1, 30)
val $expected3 = exp(1) - 1
assert_ok Rosetta::Simpson38::close($i3, $expected3, 1e-6), "e^x [0,1] = e-1 (got $i3)"

# Integral of cos(x) from 0 to pi/2 = 1
val $i4 = Rosetta::Simpson38::integrate(fn {cos}, 0, $pi / 2, 30)
assert_ok Rosetta::Simpson38::close($i4, 1.0, 1e-6), "cos [0, pi/2] = 1 (got $i4)"

# Integral of x^3 from 0 to 2 = 4
val $i5 = Rosetta::Simpson38::integrate(fn { _ ** 3 }, 0, 2, 9)
assert_ok Rosetta::Simpson38::close($i5, 4.0, 1e-9), "x^3 [0,2] = 4 (got $i5)"

# n must be a positive multiple of 3
assert_ok !defined(Rosetta::Simpson38::integrate(fn { 1 }, 0, 1, 4)), "n=4 not divisible by 3 -> undef"
assert_ok !defined(Rosetta::Simpson38::integrate(fn { 1 }, 0, 1, 0)), "n=0 -> undef"

# Smaller n -> coarser, but should still match constant function exactly
val $i_const = Rosetta::Simpson38::integrate(fn { 7 }, 0, 5, 3)
assert_ok Rosetta::Simpson38::close($i_const, 35.0, 1e-9), "constant 7 over [0,5] = 35"

test_run
