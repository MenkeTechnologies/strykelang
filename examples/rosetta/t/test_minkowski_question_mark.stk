#!/usr/bin/env stryke
# Rosetta Code: Minkowski question-mark function
# Maps the rational interval [0, 1] to itself, sending continued
# fraction [0; a1, a2, …] to 2 · Σ (-1)^(k+1) / 2^(a1 + … + ak).
# Computed iteratively via the binary expansion that follows from the
# continued-fraction representation.

fn Rosetta::Minkowski::eval($x) {
    return $x if $x < 0 || $x > 1
    val $p = int($x)
    val $q = 1
    var $a = $x - int($x)
    var $b = 1
    var $r = $p / $q
    var $sign = 1.0
    var $denom = 0.5
    for val $i (~> 1:80) {
        last if $a == 0
        val $n = int($b / $a)
        val $rest = $b - $n * $a
        $r += $sign * $n * $denom
        $denom /= (1 << $n)
        $b = $a
        $a = $rest
        $sign = -$sign
    }
    $r + ($a == 0 ? 0 : $sign * $denom)
}

fn Rosetta::Minkowski::eval_series($x, $depth) {
    # Direct series form on the continued fraction.
    return $x if $x < 0 || $x > 1
    return $x if $x == 0 || $x == 1
    val $a = int($x)
    var $rem = $x - $a
    var $sum = $a + 0
    var $sign = 1
    var $cum = 0
    for val $k (~> 1:$depth) {
        last if $rem == 0
        val $inv = 1 / $rem
        val $n = int($inv)
        $cum += $n
        $sum += $sign * 2 / (2 ** $cum)
        $sign = -$sign
        $rem = $inv - $n
    }
    $sum
}

# Boundary
assert_eq Rosetta::Minkowski::eval(0), 0, "?(0) = 0"
assert_eq Rosetta::Minkowski::eval(1), 1, "?(1) = 1"

# Rationals: ?(p/q) is dyadic
# ?(1/2) = 1/2
assert_near Rosetta::Minkowski::eval_series(1/2, 30), 0.5, 1e-9, "?(1/2) = 1/2"

# ?(1/3) = 1/4
assert_near Rosetta::Minkowski::eval_series(1/3, 30), 0.25, 1e-9, "?(1/3) = 1/4"

# ?(2/3) = 3/4
assert_near Rosetta::Minkowski::eval_series(2/3, 30), 0.75, 1e-9, "?(2/3) = 3/4"

# ?(1/4) = 1/8
assert_near Rosetta::Minkowski::eval_series(1/4, 30), 0.125, 1e-9, "?(1/4) = 1/8"

# ?(1/φ) where φ = golden ratio: irrational input → irrational output
val $phi = (1 + sqrt(5)) / 2
val $val = Rosetta::Minkowski::eval_series(1 / $phi, 50)
assert_ok $val > 0 && $val < 1, "?(1/φ) lies in (0, 1)"

# Monotonicity sanity: ?(0.3) < ?(0.5) < ?(0.8)
assert_ok Rosetta::Minkowski::eval_series(0.3, 30) < Rosetta::Minkowski::eval_series(0.5, 30),
    "monotone 0.3 < 0.5"
assert_ok Rosetta::Minkowski::eval_series(0.5, 30) < Rosetta::Minkowski::eval_series(0.8, 30),
    "monotone 0.5 < 0.8"

# Pipe form
1/3 |> fn { Rosetta::Minkowski::eval_series(_, 30) } |> assert_near(0.25, 1e-9, "pipe ?(1/3)")

test_run
