#!/usr/bin/env stryke
# Rosetta Code: Integer roots

fn integer_root($n, $base) {
    if ($n == 0) { return 0 }
    if ($n == 1) { return 1 }
    
    my $x = $n
    my $y = int((($base - 1) * $x + $n / ($x ** ($base - 1))) / $base)
    while ($y < $x) {
        $x = $y
        $y = int((($base - 1) * $x + $n / ($x ** ($base - 1))) / $base)
    }
    $x
}

assert_eq integer_root(8, 3), 2, "3rd root of 8"
assert_eq integer_root(27, 3), 3, "3rd root of 27"
assert_eq integer_root(100, 2), 10, "2nd root of 100"
assert_eq integer_root(100, 3), 4, "3rd root of 100 (int(4.64) = 4)"

test_run
