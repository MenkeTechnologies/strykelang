#!/usr/bin/env stryke
# Rosetta Code: Matrix Transpose

fn Rosetta::Transpose::transpose {
    val $rows = len(@$_)
    val $cols = len(@{_->[0]})
    var @res
    for val $j (0:$cols-1) {
        var @new_row
        for val $i (0:$rows-1) {
            push @new_row, _->[$i][$j]
        }
        push @res, [@new_row]
    }
    [@res]
}

fn Rosetta::Transpose::to_string {
    var @rows
    for val $row (@$_) {
        push @rows, join(",", @$row)
    }
    join(";", @rows)
}

val $mtx = [[1, 2, 3], [4, 5, 6]]
val $t = Rosetta::Transpose::transpose($mtx)
assert_eq Rosetta::Transpose::to_string($t), "1,4;2,5;3,6", "2x3 to 3x2"

val $mtx2 = [[1, 2], [3, 4], [5, 6]]
val $t2 = Rosetta::Transpose::transpose($mtx2)
assert_eq Rosetta::Transpose::to_string($t2), "1,3,5;2,4,6", "3x2 to 2x3"

test_run
