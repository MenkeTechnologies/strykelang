#!/usr/bin/env stryke
# Rosetta Code: Matrix Transpose

fn my_transpose {
    my $m = $_[0]
    my $rows = scalar(@$m)
    my $cols = scalar(@{$m->[0]})
    my @res
    for my $j (0..$cols-1) {
        my @new_row
        for my $i (0..$rows-1) {
            push @new_row, $m->[$i][$j]
        }
        push @res, [@new_row]
    }
    [@res]
}

fn matrix_to_string {
    my $m = $_[0]
    my @rows
    for my $row (@$m) {
        push @rows, join(",", @$row)
    }
    join(";", @rows)
}

my $mtx = [[1, 2, 3], [4, 5, 6]]
my $t = my_transpose($mtx)
assert_eq matrix_to_string($t), "1,4;2,5;3,6", "2x3 to 3x2"

my $mtx2 = [[1, 2], [3, 4], [5, 6]]
my $t2 = my_transpose($mtx2)
assert_eq matrix_to_string($t2), "1,3,5;2,4,6", "3x2 to 2x3"

test_run
