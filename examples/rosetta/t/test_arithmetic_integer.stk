#!/usr/bin/env stryke
# Rosetta Code: Arithmetic/Integer

fn arithmetic_demo() {
    "Integer Arithmetic Examples:" |> p
    
    my $a = 17
    my $b = 5
    
    "a = $a, b = $b" |> p
    
    # Basic arithmetic operations
    ($a + $b) |> map { "Addition: $a + $b = $_" } |> p
    ($a - $b) |> map { "Subtraction: $a - $b = $_" } |> p
    ($a * $b) |> map { "Multiplication: $a * $b = $_" } |> p
    ($a / $b) |> map { "Division: $a / $b = $_" } |> p
    ($a / $b) |> int |> map { "Integer division: $a ÷ $b = $_" } |> p
    ($a % $b) |> map { "Modulo: $a % $b = $_" } |> p
    ($a ** $b) |> map { "Exponentiation: $a ** $b = $_" } |> p
    
    # Bitwise operations
    ($a & $b) |> map { "Bitwise AND: $a & $b = $_" } |> p
    ($a | $b) |> map { "Bitwise OR: $a | $b = $_" } |> p
    ($a ^ $b) |> map { "Bitwise XOR: $a ^ $b = $_" } |> p
    ($a << 2) |> map { "Left shift: $a << 2 = $_" } |> p
    ($a >> 2) |> map { "Right shift: $a >> 2 = $_" } |> p
    
    # Assignment operators
    my $c = $a
    $c += $b
    "After +=: $c" |> p
    
    $c -= $b
    "After -=: $c" |> p
    
    $c *= 2
    "After *=: $c" |> p
    
    $c /= 2
    "After /=: $c" |> p
    
    # Increment/decrement
    my $x = 10
    (++$x) |> map { "Pre-increment: $_" } |> p
    ($x++) |> map { "Post-increment: $_ (x is now $x)" } |> p
    (--$x) |> map { "Pre-decrement: $_" } |> p
    ($x--) |> map { "Post-decrement: $_ (x is now $x)" } |> p
}

arithmetic_demo
