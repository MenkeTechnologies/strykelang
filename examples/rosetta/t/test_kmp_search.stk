#!/usr/bin/env stryke
# Rosetta Code: Knuth-Morris-Pratt string search

fn Rosetta::KMP::prefix($p) {
    val @chars = ~> $p chars
    val $m = len(@chars)
    var @pi = (0)
    var $k = 0
    for val $q (1:$m-1) {
        while ($k > 0 && $chars[$k] ne $chars[$q]) {
            $k = $pi[$k-1]
        }
        if ($chars[$k] eq $chars[$q]) {
            $k++
        }
        $pi[$q] = $k
    }
    \@pi
}

fn Rosetta::KMP::search($t, $p) {
    val @t_chars = ~> $t chars
    val @p_chars = ~> $p chars
    val $n = len(@t_chars)
    val $m = len(@p_chars)
    if ($m == 0) { return 0 }
    
    val $pi_ref = Rosetta::KMP::prefix($p)
    val @pi = @$pi_ref
    var $q = 0
    for val $i (0:$n-1) {
        while ($q > 0 && @p_chars[$q] ne $t_chars[$i]) {
            $q = $pi[$q-1]
        }
        if (@p_chars[$q] eq $t_chars[$i]) {
            $q++
        }
        if ($q == $m) {
            return $i - $m + 1
        }
    }
    -1
}

assert_eq Rosetta::KMP::search("abcabcabc", "abc"), 0, "Find abc at 0"
assert_eq Rosetta::KMP::search("abcabcabc", "bca"), 1, "Find bca at 1"
assert_eq Rosetta::KMP::search("abcabcabc", "cab"), 2, "Find cab at 2"
assert_eq Rosetta::KMP::search("ABC ABCDAB ABCDABCDABDE", "ABCDABD"), 15, "Complex match"
assert_eq Rosetta::KMP::search("hello world", "bye"), -1, "Not found"

test_run
