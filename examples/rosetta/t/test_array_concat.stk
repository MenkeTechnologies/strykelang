#!/usr/bin/env stryke
# Rosetta Code: Array Concatenation

fn Rosetta::ArrayConcat::demo() {
    var @a = (1, 2, 3)
    val @b = (4, 5, 6)
    val @c = (@a, @b)
    join(",", @c) |> assert_eq("1,2,3,4,5,6", "concat with comma")

    val @d = (7, 8)
    val @all = (@a, @b, @d)
    join(",", @all) |> assert_eq("1,2,3,4,5,6,7,8", "concat three arrays")

    val @empty = ()
    val @with_empty = (@a, @empty, @b)
    join(",", @with_empty) |> assert_eq("1,2,3,4,5,6", "concat with empty")

    push @a, @b
    join(",", @a) |> assert_eq("1,2,3,4,5,6", "push array onto array")
}

Rosetta::ArrayConcat::demo()
test_run
