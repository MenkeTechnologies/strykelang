#!/usr/bin/env stryke
# Rosetta Code: Zsigmondy numbers Z(a, b)(n)
# For coprime integers a > b ≥ 1 and n ≥ 1, the nth Zsigmondy number
# is the largest factor of (a^n - b^n) that is coprime to a^k - b^k
# for every 1 ≤ k < n. By Zsigmondy's theorem, Z(a, b, n) > 1 for
# every n ≥ 1 except a small list of exceptions.

fn Rosetta::Zsigmondy::gcd($x, $y) {
    $x = abs($x); $y = abs($y)
    while ($y != 0) { ($x, $y) = ($y, $x % $y) }
    $x
}

fn Rosetta::Zsigmondy::value($a, $b, $n) {
    my $cur = $a ** $n - $b ** $n
    return undef if $cur <= 0
    for my $k (1..$n - 1) {
        my $earlier = $a ** $k - $b ** $k
        next if $earlier == 0
        my $g = Rosetta::Zsigmondy::gcd($cur, $earlier)
        while ($g > 1) {
            $cur = int($cur / $g)
            $g = Rosetta::Zsigmondy::gcd($cur, $earlier)
        }
    }
    $cur
}

fn Rosetta::Zsigmondy::sequence($a, $b, $count) {
    1:$count |> map { Rosetta::Zsigmondy::value($a, $b, _) }
}

# Z(2, 1, n) — first 10 values
my @z21 = Rosetta::Zsigmondy::sequence(2, 1, 10)
# 2^n - 1 sequence: 1, 3, 7, 15, 31, 63, 127, 255, 511, 1023
# Strip out factors shared with earlier indices:
# Z(2,1,1) = 1 (no earlier; primitive part is 1)
# Z(2,1,2) = 3 (3)
# Z(2,1,3) = 7 (7, after stripping gcd with 1, 3)
# Z(2,1,4) = 5 (15 / gcd with 1,3,7 = 15/3 = 5)
# Z(2,1,5) = 31 (prime)
# Z(2,1,6) = 1 (Zsigmondy exception! 2^6 - 1 = 63 = 9*7 = 3^2*7, fully accounted by earlier)
# Z(2,1,7) = 127 (prime)
# Z(2,1,8) = 17
# Z(2,1,9) = 73
# Z(2,1,10) = 11
assert_eq join(",", @z21), "1,3,7,5,31,1,127,17,73,11", "Z(2,1) first 10"

# Z(3, 2, n) — first 5 values
my @z32 = Rosetta::Zsigmondy::sequence(3, 2, 5)
# 3^n - 2^n: 1, 5, 19, 65, 211 (5 stripped from 65 → 13)
# Z(3,2,1) = 1
# Z(3,2,2) = 5
# Z(3,2,3) = 19
# Z(3,2,4) = 65/gcd-with-1,5,19 = 65/5 = 13
# Z(3,2,5) = 211
assert_eq join(",", @z32), "1,5,19,13,211", "Z(3,2) first 5"

# Property: Z(a,b,n) divides a^n - b^n
my $div_ok = 1
for my $n (1..8) {
    my $z = Rosetta::Zsigmondy::value(2, 1, $n)
    my $f = 2 ** $n - 1
    $div_ok = 0 if $f % $z != 0
}
assert_ok $div_ok, "Z(2,1,n) divides 2^n - 1"

# Pipe form
4 |> fn { Rosetta::Zsigmondy::value(2, 1, _) } |> assert_eq(5, "pipe Z(2,1,4)")

test_run
