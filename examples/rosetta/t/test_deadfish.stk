#!/usr/bin/env stryke
# Rosetta Code: Deadfish

fn Rosetta::Deadfish::execute($cmd) {
    my $v = 0
    my @res
    my @chars = chars($cmd)
    for my $c (@chars) {
        if ($c eq "i") { $v++ }
        elsif ($c eq "d") { $v-- }
        elsif ($c eq "s") { $v *= $v }
        elsif ($c eq "o") { push @res, $v }
        
        if ($v == -1 || $v == 256) { $v = 0 }
    }
    \@res
}

assert_eq join(",", @{ Rosetta::Deadfish::execute("iissso") }), "0", "iissso"
assert_eq join(",", @{ Rosetta::Deadfish::execute("diissisdo") }), "288", "diissisdo"

"iissso" |> Rosetta::Deadfish::execute |> { join(",", @$_) } |> assert_eq("0", "pipe deadfish")

test_run
