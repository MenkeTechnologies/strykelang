#!/usr/bin/env stryke
# Rosetta Code: Hamming Distance

fn Rosetta::HammingDistance::compute($s1, $s2) {
    my @c1 = ~> $s1 chars
    my @c2 = ~> $s2 chars
    
    0..scalar(@c1)-1 |> grep {
        my $i = $_
        $c1[$i] ne $c2[$i]
    } |> scalar
}

assert_eq Rosetta::HammingDistance::compute("karolin", "kathrin"), 3, "karolin vs kathrin"
assert_eq Rosetta::HammingDistance::compute("karolin", "kerstin"), 3, "karolin vs kerstin"
assert_eq Rosetta::HammingDistance::compute("1011101", "1001001"), 2, "binary distance"
assert_eq Rosetta::HammingDistance::compute("abc", "abc"), 0, "equal strings"

test_run
