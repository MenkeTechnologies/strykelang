#!/usr/bin/env stryke
# Rosetta Code: Ear-clipping polygon triangulation (simple polygon, CCW)

fn Rosetta::EarClip::cross($o, $u, $v) {
    ($u->[0] - $o->[0]) * ($v->[1] - $o->[1]) - ($u->[1] - $o->[1]) * ($v->[0] - $o->[0])
}

fn Rosetta::EarClip::point_in_tri($p, $a, $b, $c) {
    val $d1 = Rosetta::EarClip::cross($a, $b, $p)
    val $d2 = Rosetta::EarClip::cross($b, $c, $p)
    val $d3 = Rosetta::EarClip::cross($c, $a, $p)
    val $has_neg = $d1 < 0 || $d2 < 0 || $d3 < 0
    val $has_pos = $d1 > 0 || $d2 > 0 || $d3 > 0
    !($has_neg && $has_pos)
}

fn Rosetta::EarClip::triangulate($poly) {
    val @pts = map { [_->[0], _->[1]] } @$poly
    val $n = len(@pts)
    return [] if $n < 3
    var @indices = (0:$n - 1)
    var @tris
    var $guard = 0
    while (len(@indices) > 3) {
        last if ++$guard > 1000
        var $found = 0
        val $m = len(@indices)
        for val $ii (0:$m - 1) {
            val $prev = $indices[($ii - 1 + $m) % $m]
            val $cur = $indices[$ii]
            val $next = $indices[($ii + 1) % $m]
            val $a = $pts[$prev]
            val $b = $pts[$cur]
            val $c = $pts[$next]
            next if Rosetta::EarClip::cross($a, $b, $c) <= 0   # not convex
            var $is_ear = 1
            for val $jj (0:$m - 1) {
                next if $jj == ($ii - 1 + $m) % $m || $jj == $ii || $jj == ($ii + 1) % $m
                if (Rosetta::EarClip::point_in_tri($pts[$indices[$jj]], $a, $b, $c)) {
                    $is_ear = 0
                    last
                }
            }
            if ($is_ear) {
                push @tris, [$prev, $cur, $next]
                splice(@indices, $ii, 1)
                $found = 1
                last
            }
        }
        last unless $found
    }
    push @tris, [@indices] if len(@indices) == 3
    \@tris
}

# Triangle -> single tri
val $tri = [[0,0], [1,0], [0,1]]
val $t1 = Rosetta::EarClip::triangulate($tri)
assert_eq len(@$t1), 1, "triangle -> 1 tri"

# Square -> 2 tris
val $sq = [[0,0], [4,0], [4,4], [0,4]]
val $t2 = Rosetta::EarClip::triangulate($sq)
assert_eq len(@$t2), 2, "square -> 2 tris"

# Pentagon -> 3 tris (n - 2)
val $pent = [[0,0], [4,0], [5,3], [2,5], [-1,3]]
val $t3 = Rosetta::EarClip::triangulate($pent)
assert_eq len(@$t3), 3, "pentagon -> 3 tris"

# L-shape (concave hexagon) -> 4 tris
val $L = [[0,0], [4,0], [4,2], [2,2], [2,4], [0,4]]
val $t4 = Rosetta::EarClip::triangulate($L)
assert_eq len(@$t4), 4, "L-shape -> 4 tris"

# All triangles use only original vertex indices, in range
for val $t (@$t4) {
    for val $ix (@$t) {
        assert_ok($ix >= 0 && $ix < 6, "L-shape tri index in range")
    }
}

test_run
