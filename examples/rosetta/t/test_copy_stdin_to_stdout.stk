#!/usr/bin/env stryke
# Rosetta Code: Copy stdin to stdout

fn Rosetta::CopyStdin::demo() {
    # In a real environment, this would read from STDIN.
    # For the test, we can mock it or just show the logic.
    
    # Logic: slurp("/dev/stdin") or while(<STDIN>)
    # We'll use a string for the demo/test assertions.
    
    my $input = "Test Input\nLine 2"
    # To actually copy stdin to stdout in a script:
    # print slurp("/dev/stdin")
    
    "Mocked Copy Stdin to Stdout:" |> p
    print($input)
    p "" # newline
    
    # Assertions
    assert_eq $input, "Test Input\nLine 2", "Input matches output logic"
}

Rosetta::CopyStdin::demo()
test_run
