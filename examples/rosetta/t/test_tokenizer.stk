#!/usr/bin/env stryke
# Rosetta Code: Tokenizer — minimal arithmetic-expression tokenizer.
# Produces a list of [kind, text] pairs for an input like "1 + 2 * (3 - 4)".

fn Rosetta::Tokenizer::lex($src) {
    my @out
    my $i = 0
    my $n = length($src)
    while ($i < $n) {
        my $c = substr($src, $i, 1)
        if ($c =~ /\s/) {
            $i += 1
            next
        }
        if ($c =~ /[0-9]/) {
            my $j = $i
            $j += 1 while $j < $n && substr($src, $j, 1) =~ /[0-9]/
            push @out, ["NUM", substr($src, $i, $j - $i)]
            $i = $j
            next
        }
        if ($c =~ /[a-zA-Z_]/) {
            my $j = $i
            $j += 1 while $j < $n && substr($src, $j, 1) =~ /[a-zA-Z_0-9]/
            push @out, ["IDENT", substr($src, $i, $j - $i)]
            $i = $j
            next
        }
        if ($c eq "(" || $c eq ")") {
            push @out, [$c eq "(" ? "LPAREN" : "RPAREN", $c]
            $i += 1
            next
        }
        if ($c eq "+" || $c eq "-" || $c eq "*" || $c eq "/") {
            push @out, ["OP", $c]
            $i += 1
            next
        }
        die "tokenizer: unexpected char `$c` at $i"
    }
    \@out
}

my $toks = Rosetta::Tokenizer::lex("1 + 2 * (3 - 4)")
assert_eq len(@$toks), 9, "9 tokens for `1 + 2 * (3 - 4)`"
assert_eq $toks->[0][0], "NUM",    "first kind"
assert_eq $toks->[0][1], "1",      "first text"
assert_eq $toks->[1][0], "OP",     "second kind"
assert_eq $toks->[3][0], "OP",     "fourth (the *)"
assert_eq $toks->[4][0], "LPAREN", "open paren"
assert_eq $toks->[8][0], "RPAREN", "close paren"

# Identifiers and multi-digit numbers.
my $t2 = Rosetta::Tokenizer::lex("foo + 42")
assert_eq $t2->[0][0], "IDENT", "ident kind"
assert_eq $t2->[0][1], "foo",   "ident text"
assert_eq $t2->[2][1], "42",    "two-digit number"

# Whitespace is skipped, no token emitted.
my $t3 = Rosetta::Tokenizer::lex("   x   ")
assert_eq len(@$t3), 1,     "whitespace-only padding skipped"
assert_eq $t3->[0][1], "x",    "single ident"

test_run
