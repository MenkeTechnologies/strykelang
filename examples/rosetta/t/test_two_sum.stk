#!/usr/bin/env stryke
# Rosetta Code: Two sum — find a pair of indices summing to target

fn Rosetta::TwoSum::find($arr, $target) {
    my %seen
    my $n = len(@$arr)
    for my $i (0..$n-1) {
        my $need = $target - $arr->[$i]
        if (exists $seen{$need}) {
            return [$seen{$need}, $i]
        }
        $seen{$arr->[$i]} = $i
    }
    undef
}

my $r = Rosetta::TwoSum::find([2, 7, 11, 15], 9)
assert_eq join(",", @$r), "0,1", "[2,7,11,15] target 9 -> indices 0,1"

my $r2 = Rosetta::TwoSum::find([3, 2, 4], 6)
assert_eq join(",", @$r2), "1,2", "[3,2,4] target 6 -> indices 1,2"

my $r3 = Rosetta::TwoSum::find([3, 3], 6)
assert_eq join(",", @$r3), "0,1", "duplicates [3,3]"

assert_eq Rosetta::TwoSum::find([1, 2, 3], 100), undef, "no two sum"
assert_eq Rosetta::TwoSum::find([], 5), undef, "empty array"

test_run
