#!/usr/bin/env stryke
# Rosetta Code: Factors of an integer

fn Rosetta::Factors::factors($n) {
    var @f
    for val $i (1:$n) {
        if ($n % $i == 0) { push @f, $i }
    }
    \@f
}

val $f6 = Rosetta::Factors::factors(6)
assert_eq join(",", @$f6), "1,2,3,6", "factors 6"

val $f12 = Rosetta::Factors::factors(12)
assert_eq join(",", @$f12), "1,2,3,4,6,12", "factors 12"

val $f13 = Rosetta::Factors::factors(13)
assert_eq join(",", @$f13), "1,13", "factors 13 (prime)"

val $f1 = Rosetta::Factors::factors(1)
assert_eq join(",", @$f1), "1", "factors 1"

test_run
