#!/usr/bin/env stryke
# Rosetta Code: Regula falsi (false position) root finding

fn Rosetta::RegulaFalsi::find($f, $a, $b, $eps, $max_iter) {
    var $fa = $f($a)
    var $fb = $f($b)
    return undef if $fa * $fb > 0
    var $c = $a
    for val $i (1:$max_iter) {
        $c = ($a * $fb - $b * $fa) / ($fb - $fa)
        val $fc = $f($c)
        return $c if abs($fc) < $eps
        if ($fa * $fc < 0) {
            $b = $c
            $fb = $fc
        } else {
            $a = $c
            $fa = $fc
        }
    }
    $c
}

fn Rosetta::RegulaFalsi::close($x, $y) { abs($x - $y) < 1e-6 }

# x^2 - 2 = 0  has root sqrt(2)
val $sqrt2 = Rosetta::RegulaFalsi::find(fn { _ * _ - 2 }, 1, 2, 1e-9, 100)
assert_ok Rosetta::RegulaFalsi::close($sqrt2, sqrt(2)), "sqrt(2) ~ $sqrt2"

# x^3 - x - 2 = 0 has a real root ~1.5214
val $cubic = Rosetta::RegulaFalsi::find(fn { _ ** 3 - _ - 2 }, 1, 2, 1e-9, 200)
assert_ok Rosetta::RegulaFalsi::close($cubic, 1.5213797068), "x^3-x-2 root ~ $cubic"

# cos(x) - x = 0 has unique root ~0.7390851
val $dottie = Rosetta::RegulaFalsi::find(fn { cos(_) - _ }, 0, 1, 1e-9, 200)
assert_ok Rosetta::RegulaFalsi::close($dottie, 0.7390851332), "Dottie ~ $dottie"

# Already-bracketed exact root
val $linear = Rosetta::RegulaFalsi::find(fn { 2 * _ - 6 }, 0, 10, 1e-9, 100)
assert_ok Rosetta::RegulaFalsi::close($linear, 3), "linear root = 3"

# Bracket with same sign -> undef
val $no_sign = Rosetta::RegulaFalsi::find(fn { _ * _ + 1 }, -1, 1, 1e-9, 50)
assert_ok !defined($no_sign), "no sign change -> undef"

# Negative root: x^2 - 3 = 0 -> -sqrt(3)
val $neg = Rosetta::RegulaFalsi::find(fn { _ * _ - 3 }, -2, 0, 1e-9, 200)
assert_ok Rosetta::RegulaFalsi::close($neg, -sqrt(3)), "-sqrt(3) ~ $neg"

test_run
