#!/usr/bin/env stryke
# Rosetta Code: Check if two polygons overlap (Separating Axis Theorem on convex polygons).

fn Math::Poly::edges($poly) {
    my @es
    my $n = len(@$poly)
    for my $i (0..$n-1) {
        my $j = ($i + 1) % $n
        push @es, [$poly->[$j]->[0] - $poly->[$i]->[0],
                   $poly->[$j]->[1] - $poly->[$i]->[1]]
    }
    @es
}

fn Math::Poly::project($poly, $axis) {
    my $min = undef; my $max = undef
    for my $p (@$poly) {
        my $proj = $p->[0] * $axis->[0] + $p->[1] * $axis->[1]
        $min = $proj if !defined($min) || $proj < $min
        $max = $proj if !defined($max) || $proj > $max
    }
    [$min, $max]
}

fn Rosetta::PolyOverlap::overlap($a, $b) {
    for my $poly ($a, $b) {
        for my $e (Math::Poly::edges($poly)) {
            # Normal to edge: (-dy, dx)
            my $axis = [-$e->[1], $e->[0]]
            my $pa = Math::Poly::project($a, $axis)
            my $pb = Math::Poly::project($b, $axis)
            return 0 if $pa->[1] < $pb->[0] || $pb->[1] < $pa->[0]
        }
    }
    1
}

my $A = [[0,0],[10,0],[10,10],[0,10]]
my $B = [[5,5],[15,5],[15,15],[5,15]]   # overlaps A
my $C = [[20,20],[30,20],[30,30],[20,30]] # disjoint
my $D = [[10,10],[20,10],[20,20],[10,20]] # touches A at corner

assert_ok  Rosetta::PolyOverlap::overlap($A, $B), "A-B overlap"
assert_ok !Rosetta::PolyOverlap::overlap($A, $C), "A-C disjoint"
assert_ok  Rosetta::PolyOverlap::overlap($A, $D), "A-D corner touch counts"

# Non-square polygons
my $T1 = [[0,0],[5,0],[5,5]]
my $T2 = [[2,1],[8,1],[8,7]]
assert_ok  Rosetta::PolyOverlap::overlap($T1, $T2), "triangles overlap"

test_run
