#!/usr/bin/env stryke
# Rosetta Code: Stern-Brocot sequence

fn my_stern_brocot($n) {
    my @sb = (1, 1)
    my $i = 0
    while (scalar(@sb) < $n) {
        my $a = $sb[$i]
        my $b = $sb[$i+1]
        push @sb, $a + $b, $b
        $i++
    }
    \@sb[0..$n-1]
}

my $res = my_stern_brocot(15)
# SB: 1, 1, 2, 1, 3, 2, 3, 1, 4, 3, 5, 2, 5, 3, 4
assert_eq join(",", @$res), "1,1,2,1,3,2,3,1,4,3,5,2,5,3,4", "Stern-Brocot up to 15"

test_run
