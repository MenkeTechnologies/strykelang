#!/usr/bin/env stryke
# Rosetta Code: Compound data type — points, with structure operations.

struct Point { x, y }

fn Rosetta::Compound::distance($p, $q) {
    sqrt(($p->x - $q->x) ** 2 + ($p->y - $q->y) ** 2)
}

fn Rosetta::Compound::midpoint($p, $q) {
    Point(x => ($p->x + $q->x) / 2, y => ($p->y + $q->y) / 2)
}

fn Rosetta::Compound::translate($p, $dx, $dy) {
    Point(x => $p->x + $dx, y => $p->y + $dy)
}

my $a = Point(x => 0, y => 0)
my $b = Point(x => 3, y => 4)

assert_eq $a->x, 0, "x access"
assert_eq $a->y, 0, "y access"
assert_eq $b->x, 3, "x access"
assert_eq $b->y, 4, "y access"

assert_eq Rosetta::Compound::distance($a, $b), 5, "3-4-5 triangle"

my $m = Rosetta::Compound::midpoint($a, $b)
assert_eq $m->x, 1.5, "midpoint x"
assert_eq $m->y, 2,   "midpoint y"

my $t = Rosetta::Compound::translate($b, -3, -4)
assert_eq $t->x, 0, "translate x"
assert_eq $t->y, 0, "translate y"

# pipeline form: list of points -> distances from origin
my @pts = (Point(x=>0,y=>0), Point(x=>3,y=>4), Point(x=>5,y=>12))
my @ds = ~> @pts map { Rosetta::Compound::distance(_, Point(x=>0,y=>0)) }
assert_eq join(",", @ds), "0,5,13", "distances from origin"

test_run
