#!/usr/bin/env stryke
# Rosetta Code: URL Encoding/Decoding (Manual)

fn Rosetta::UrlEncode::url_encode($str) {
    var @chars = $str |> chars
    var $res = ""
    for val $c (@chars) {
        if ($c =~ /[a-zA-Z0-9._~-]/) {
            $res = $res . $c
        } else {
            $res = $res . sprintf("%%%02X", ord($c))
        }
    }
    $res
}

fn Rosetta::UrlDecode::url_decode($str) {
    var $res = ""
    var $i = 0
    val $len = length($str)
    while ($i < $len) {
        val $c = substr($str, $i, 1)
        if ($c eq "%") {
            val $h = substr($str, $i + 1, 2)
            $res = $res . chr(hex($h))
            $i = $i + 3
        } else {
            $res = $res . $c
            $i = $i + 1
        }
    }
    $res
}

val $input = "http://rosettacode.org/wiki/URL_encoding"
val $encoded = Rosetta::UrlEncode::url_encode($input)
assert_eq $encoded, "http%3A%2F%2Frosettacode.org%2Fwiki%2FURL_encoding", "manual url encode"

val $decoded = Rosetta::UrlDecode::url_decode($encoded)
assert_eq $decoded, $input, "manual url decode"

test_run
