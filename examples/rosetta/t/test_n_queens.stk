#!/usr/bin/env stryke
# Rosetta Code: N-Queens Problem (Bitmask implementation)

fn Rosetta::NQueens::solve_recursive($ld, $cols, $rd, $all) {
    if ($cols == $all) {
        return 1
    }
    
    my $count = 0
    my $poss = $all & ~($ld | $cols | $rd)
    
    while ($poss > 0) {
        my $bit = $poss & -$poss
        $poss = $poss - $bit
        $count = $count + Rosetta::NQueens::solve_recursive(($ld | $bit) << 1, $cols | $bit, ($rd | $bit) >> 1, $all)
    }
    $count
}

fn Rosetta::NQueens::solve($n) {
    if ($n == 0) { return 0 }
    my $all = (1 << $n) - 1
    Rosetta::NQueens::solve_recursive(0, 0, 0, $all)
}

assert_eq Rosetta::NQueens::solve(1), 1, "N-Queens(1)"
assert_eq Rosetta::NQueens::solve(4), 2, "N-4 queens"
assert_eq Rosetta::NQueens::solve(5), 10, "N-Queens(5)"
assert_eq Rosetta::NQueens::solve(6), 4, "N-Queens(6)"
assert_eq Rosetta::NQueens::solve(8), 92, "N-Queens(8)"

test_run
