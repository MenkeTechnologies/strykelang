#!/usr/bin/env stryke
# Rosetta Code: Matrix Addition

fn Rosetta::MatrixAdd::matrix_add {
    val $m1 = _
    val $m2 = _1
    val $rows = len(@$m1)
    val $cols = len(@{$m1->[0]})
    val @res = ~> 0:$rows-1 map {
        val @row = ~> 0:$cols-1 map { $m1->[_<][_] + $m2->[_<][_] }
        \@row
    }
    \@res
}

fn Rosetta::MatrixAdd::to_string {
    val $m = _
    val @rows = ~> @$m map { join(",", @{_}) }
    join(";", @rows)
}

val $a = [[1, 2], [3, 4]]
val $b = [[5, 6], [7, 8]]
val $sum = Rosetta::MatrixAdd::matrix_add($a, $b)
assert_eq Rosetta::MatrixAdd::to_string($sum), "6,8;10,12", "matrix add 2x2"

test_run
