#!/usr/bin/env stryke
# Rosetta Code: Array Length

fn Rosetta::ArrayLength::get(@arr) {
    scalar(@arr)
}

fn Rosetta::ArrayLength::last_index(@arr) {
    $#arr
}

my @one = (42)
assert_eq Rosetta::ArrayLength::get(@one), 1, "single element"
assert_eq Rosetta::ArrayLength::last_index(@one), 0, "last index of single"

my @five = (1, 2, 3, 4, 5)
assert_eq Rosetta::ArrayLength::get(@five), 5, "five elements"
assert_eq Rosetta::ArrayLength::last_index(@five), 4, "last index of five"

my @range = 1:100
assert_eq Rosetta::ArrayLength::get(@range), 100, "range length"
assert_eq Rosetta::ArrayLength::last_index(@range), 99, "range last index"

my @nested = ([1,2], [3,4], [5,6])
assert_eq Rosetta::ArrayLength::get(@nested), 3, "nested arrays"

test_run
