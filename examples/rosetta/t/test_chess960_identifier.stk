#!/usr/bin/env stryke
# Rosetta Code: Find Chess960 starting position identifier

fn Rosetta::Chess960::id_to_pos($id) {
    my $n = $id
    my @backline
    for (0:7) { push @backline, undef }
    
    # 1. Light-square bishop
    my $b_light = $n % 4
    $backline[2 * $b_light + 1] = "B"
    $n = int($n / 4)
    
    # 2. Dark-square bishop
    my $b_dark = $n % 4
    $backline[2 * $b_dark] = "B"
    $n = int($n / 4)
    
    # 3. Queen
    my $q_pos = $n % 6
    $n = int($n / 6)
    my $count = 0
    for my $i (0:7) {
        if (!defined $backline[$i]) {
            if ($count == $q_pos) {
                $backline[$i] = "Q"
                last
            }
            $count++
        }
    }
    
    # 4. Knights
    my $k_id = $n
    # There are 10 ways to place 2 knights on 5 squares:
    my @k_placements = (
        [0, 1], [0, 2], [0, 3], [0, 4],
        [1, 2], [1, 3], [1, 4],
        [2, 3], [2, 4],
        [3, 4]
    )
    my $k_pair = $k_placements[$k_id]
    $count = 0
    for my $i (0:7) {
        if (!defined $backline[$i]) {
            if ($count == $k_pair->[0] || $count == $k_pair->[1]) {
                $backline[$i] = "N"
            }
            $count++
        }
    }
    
    # 5. Rooks and King: R-K-R
    for my $i (0:7) {
        if (!defined $backline[$i]) {
            $backline[$i] = "R"
            # find next
            for my $j ($i+1:7) {
                if (!defined $backline[$j]) {
                    $backline[$j] = "K"
                    # find next
                    for my $k ($j+1:7) {
                        if (!defined $backline[$k]) {
                            $backline[$k] = "R"
                            last
                        }
                    }
                    last
                }
            }
            last
        }
    }
    
    join("", @backline)
}

# Identifier 518 is the standard starting position RNBQKBNR
# Wait, let's check.
my $pos518 = Rosetta::Chess960::id_to_pos(518)
p "ID 518: $pos518"
assert_eq $pos518, "RNBQKBNR", "Identifier 518 is standard chess"

# ID 0
my $pos0 = Rosetta::Chess960::id_to_pos(0)
p "ID 0: $pos0"
assert_eq $pos0, "BBQNNRKR", "Identifier 0"

test_run
