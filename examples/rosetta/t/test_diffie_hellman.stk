#!/usr/bin/env stryke
# Rosetta Code: Diffie-Hellman key exchange

fn Rosetta::DH::mod_pow($base, $exp, $mod) {
    my $res = 1
    $base %= $mod
    while ($exp > 0) {
        if ($exp % 2 == 1) {
            $res = ($res * $base) % $mod
        }
        $base = ($base * $base) % $mod
        $exp = $exp / 2 | 0
    }
    $res
}

# Parameters (RFC 3526 group 5, but smaller for demo)
my $p = 24251 # a prime
my $g = 2     # a generator

# Alice's secret
my $a = 123
my $A = Rosetta::DH::mod_pow($g, $a, $p)

# Bob's secret
my $b = 456
my $B = Rosetta::DH::mod_pow($g, $b, $p)

# Shared secret computation
my $s_alice = Rosetta::DH::mod_pow($B, $a, $p)
my $s_bob = Rosetta::DH::mod_pow($A, $b, $p)

assert_eq $s_alice, $s_bob, "Shared secrets match"
p "Shared secret: $s_alice"

test_run
