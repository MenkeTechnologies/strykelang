#!/usr/bin/env stryke
# Rosetta Code: Variable declaration reset

fn Rosetta::VarReset::new_env() { {} }

fn Rosetta::VarReset::declare($env, $name, $value) {
    $env->{$name} = $value
}

fn Rosetta::VarReset::reset($env, $name) {
    delete $env->{$name}
}

fn Rosetta::VarReset::get($env, $name) {
    exists $env->{$name} ? $env->{$name} : "undef"
}

my $env = Rosetta::VarReset::new_env()
Rosetta::VarReset::declare($env, "counter", 41)
assert_eq Rosetta::VarReset::get($env, "counter"), 41, "declared variable is present"
Rosetta::VarReset::reset($env, "counter")
assert_eq Rosetta::VarReset::get($env, "counter"), "undef", "reset clears declaration"
Rosetta::VarReset::declare($env, "counter", 99)
assert_eq Rosetta::VarReset::get($env, "counter"), 99, "variable can be declared again after reset"

test_run
