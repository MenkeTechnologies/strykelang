#!/usr/bin/env stryke
# Rosetta Code: Mayan calendar

fn Rosetta::Mayan::tzolkin($days) {
    my @names = qw(Imix Ik Akbal Kan Chicchan Cimi Manik Lamat Muluc Oc Chuen Eb Ben Ix Men Cib Caban Etznab Cauac Ahau)
    my $num = ($days + 3) % 13 + 1
    my $name = $names[($days + 19) % 20]
    "$num $name"
}

fn Rosetta::Mayan::haab($days) {
    my @months = qw(Pop Uo Zip Zotz Tzec Xul Yaxkin Mol Chen Yax Zac Ceh Mac Kankin Muan Pax Kayab Cumku Uayeb)
    my $haab_days = ($days + 348) % 365
    my $month_idx = int($haab_days / 20)
    my $day = $haab_days % 20
    "$day $months[$month_idx]"
}

fn Rosetta::Mayan::long_count($days) {
    my $baktun = int($days / 144000)
    my $katun  = int($days / 7200) % 20
    my $tun    = int($days / 360) % 20
    my $uinal  = int($days / 20) % 18
    my $kin    = $days % 20
    "$baktun.$katun.$tun.$uinal.$kin"
}

fn Rosetta::Mayan::from_gregorian($date_str) {
    # correlation constant to match 2012-12-21 as 13.0.0.0.0
    my $c = 1856305
    my $epoch_days = int(datetime_parse_rfc3339("${date_str}T00:00:00Z") / 86400)
    my $days = $epoch_days + $c
    
    my $lc = Rosetta::Mayan::long_count($days)
    my $tz = Rosetta::Mayan::tzolkin($days)
    my $ha = Rosetta::Mayan::haab($days)
    
    "$lc  $tz  $ha"
}

# Test cases
assert_eq Rosetta::Mayan::from_gregorian("2012-12-21"), "13.0.0.0.0  4 Ahau  3 Kankin", "End of 13th baktun"
assert_eq Rosetta::Mayan::from_gregorian("2004-12-21"), "12.19.11.15.18  7 Etznab  1 Kankin", "2004-12-21"
assert_eq Rosetta::Mayan::from_gregorian("1970-01-01"), "12.17.16.7.5  13 Chicchan  3 Kankin", "Unix Epoch"

test_run
