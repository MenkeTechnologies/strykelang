#!/usr/bin/env stryke
# Rosetta Code: Levenshtein distance

fn Rosetta::Levenshtein::compute($s1, $s2) {
    my @c1 = ~> $s1 chars
    my @c2 = ~> $s2 chars
    my $len1 = scalar(@c1)
    my $len2 = scalar(@c2)
    
    my @d
    for my $i (0..$len1) { $d[$i] = [] }
    for my $i (0..$len1) { $d[$i][0] = $i }
    for my $j (0..$len2) { $d[0][$j] = $j }
    
    for my $i (1..$len1) {
        for my $j (1..$len2) {
            my $cost = ($c1[$i-1] eq $c2[$j-1]) ? 0 : 1
            my @v = ($d[$i-1][$j] + 1, $d[$i][$j-1] + 1, $d[$i-1][$j-1] + $cost)
            $d[$i][$j] = @v |> reduce { ($a < $b) ? $a : $b }
        }
    }
    
    $d[$len1][$len2]
}

assert_eq Rosetta::Levenshtein::compute("saturday", "sunday"), 3, "saturday vs sunday"
assert_eq Rosetta::Levenshtein::compute("kitten", "sitting"), 3, "kitten vs sitting"
assert_eq Rosetta::Levenshtein::compute("book", "back"), 2, "book vs back"

test_run
