#!/usr/bin/env stryke
# Rosetta Code: Levenshtein distance

fn Rosetta::Levenshtein::compute($s1, $s2) {
    val @c1 = ~> $s1 chars
    val @c2 = ~> $s2 chars
    val $len1 = len(@c1)
    val $len2 = len(@c2)
    
    var @d
    for val $i (0:$len1) { $d[$i] = [] }
    for val $i (0:$len1) { $d[$i][0] = $i }
    for val $j (0:$len2) { $d[0][$j] = $j }
    
    for val $i (1:$len1) {
        for val $j (1:$len2) {
            val $cost = ($c1[$i-1] eq $c2[$j-1]) ? 0 : 1
            val @v = ($d[$i-1][$j] + 1, $d[$i][$j-1] + 1, $d[$i-1][$j-1] + $cost)
            $d[$i][$j] = @v |> reduce { (_0 < _1) ? _0 : _1 }
        }
    }
    
    $d[$len1][$len2]
}

assert_eq Rosetta::Levenshtein::compute("saturday", "sunday"), 3, "saturday vs sunday"
assert_eq Rosetta::Levenshtein::compute("kitten", "sitting"), 3, "kitten vs sitting"
assert_eq Rosetta::Levenshtein::compute("book", "back"), 2, "book vs back"

test_run
