#!/usr/bin/env stryke
# Rosetta Code: Factors of an integer (using pipes)

fn Rosetta::Factors::compute($n) {
    if ($n <= 0) { return [] }
    my @res = ~> 1:$n grep { $n % _ == 0 }
    \@res
}

my $f1 = Rosetta::Factors::compute(45)
assert_eq join(",", @$f1), "1,3,5,9,15,45", "factors of 45"

my $f2 = Rosetta::Factors::compute(53)
assert_eq join(",", @$f2), "1,53", "factors of 53"

my $f3 = Rosetta::Factors::compute(64)
assert_eq join(",", @$f3), "1,2,4,8,16,32,64", "factors of 64"

test_run
