#!/usr/bin/env stryke
# Rosetta Code: Abundant, deficient and perfect numbers

fn Rosetta::ADPNumbers::sum_divisors($n) {
    if ($n < 2) {
        0
    } else {
        var $sum = 0
        val $limit = int($n / 2)
        for val $i (1:$limit) {
            if ($n % $i == 0) { $sum = $sum + $i }
        }
        $sum
    }
}

fn Rosetta::ADPNumbers::classify($n) {
    val $sum = Rosetta::ADPNumbers::sum_divisors($n)
    if ($sum == $n) {
        "perfect"
    } elsif ($sum > $n) {
        "abundant"
    } else {
        "deficient"
    }
}

assert_eq Rosetta::ADPNumbers::classify(6), "perfect", "6 is perfect"
assert_eq Rosetta::ADPNumbers::classify(28), "perfect", "28 is perfect"
assert_eq Rosetta::ADPNumbers::classify(12), "abundant", "12 is abundant (1+2+3+4+6=16 > 12)"
assert_eq Rosetta::ADPNumbers::classify(18), "abundant", "18 is abundant"
assert_eq Rosetta::ADPNumbers::classify(8), "deficient", "8 is deficient (1+2+4=7 < 8)"
assert_eq Rosetta::ADPNumbers::classify(13), "deficient", "13 is deficient"

test_run
