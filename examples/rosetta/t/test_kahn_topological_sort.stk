#!/usr/bin/env stryke
# Rosetta Code: Kahn's algorithm — topological sort by repeatedly removing
# nodes with zero in-degree.

fn Rosetta::Kahn::sort($edges, $nodes) {
    var %in_deg
    var %adj
    for val $n (@$nodes) {
        $in_deg{$n} = 0
        $adj{$n} = []
    }
    ~> @$edges ep {
        val ($u, $v) = (_->[0], _->[1])
        push @{$adj{$u}}, $v
        $in_deg{$v}++
    }
    var @queue = grep { $in_deg{_} == 0 } @$nodes
    var @order
    while (len(@queue)) {
        val $u = shift @queue
        push @order, $u
        for val $v (@{$adj{$u}}) {
            $in_deg{$v}--
            push @queue, $v if $in_deg{$v} == 0
        }
    }
    return undef if len(@order) != len(@$nodes)
    \@order
}

fn Rosetta::Kahn::valid($order, $edges) {
    var %pos
    for val $i (0..len(@$order)-1) { $pos{$order->[$i]} = $i }
    for val $e (@$edges) {
        return 0 if $pos{$e->[0]} >= $pos{$e->[1]}
    }
    1
}

# DAG with 6 nodes, classic topo example
val $edges = [["A","B"], ["A","C"], ["B","D"], ["C","D"], ["D","E"], ["F","E"]]
val $nodes = ["A","B","C","D","E","F"]
val $order = Rosetta::Kahn::sort($edges, $nodes)
assert_ok defined($order), "DAG has a topological order"
assert_eq len(@$order), 6, "all 6 nodes in order"
assert_ok Rosetta::Kahn::valid($order, $edges), "every edge u->v has pos(u) < pos(v)"

# Linear chain
val $chain = Rosetta::Kahn::sort([["1","2"],["2","3"],["3","4"]], ["1","2","3","4"])
assert_eq join(",", @$chain), "1,2,3,4", "linear chain order"

# Cycle -> undef
val $cyc = Rosetta::Kahn::sort([["A","B"],["B","C"],["C","A"]], ["A","B","C"])
assert_ok !defined($cyc), "cycle returns undef"

# Already-isolated nodes (no edges) -> any permutation
val $iso = Rosetta::Kahn::sort([], ["X","Y","Z"])
assert_ok defined($iso), "no edges -> some order"
assert_eq len(@$iso), 3, "all 3 nodes present"

# Self-loop -> cycle -> undef
val $loop = Rosetta::Kahn::sort([["A","A"]], ["A"])
assert_ok !defined($loop), "self-loop is a cycle"

test_run
