#!/usr/bin/env stryke
# Rosetta Code: Mian-Chowla sequence

fn Rosetta::MianChowla::mian_chowla($n) {
    var @a = (1)
    while (len(@a) < $n) {
        var $next = $a[-1] + 1
        var $found = 0
        while (!$found) {
            var %sums
            var $valid = 1
            val @temp = (@a, $next)
            for var $i (0..len(@temp)-1) {
                for var $j ($i..len(@temp)-1) {
                    val $s = $temp[$i] + $temp[$j]
                    if (exists $sums{$s}) {
                        $valid = 0
                        $i = len(@temp) # break
                        $j = len(@temp) # break
                    }
                    $sums{$s} = 1
                }
            }
            if ($valid) {
                push @a, $next
                $found = 1
            } else {
                $next++
            }
        }
    }
    \@a
}

val $res = Rosetta::MianChowla::mian_chowla(5)
assert_eq join(",", @$res), "1,2,4,8,13", "Mian-Chowla first 5"

5 |> Rosetta::MianChowla::mian_chowla |> map { _->[4] } |> assert_eq(13, "pipe Mian-Chowla")

test_run
