#!/usr/bin/env stryke
# Rosetta Code: Brilliant numbers

fn Rosetta::BrilliantNumbers::get_factors($n) {
    var @factors
    var $d = 2
    var $temp = $n
    while ($d * $d <= $temp) {
        while ($temp % $d == 0) {
            push @factors, $d
            $temp = int($temp / $d)
        }
        $d++
    }
    push @factors, $temp if $temp > 1
    @factors
}

fn Rosetta::BrilliantNumbers::check($n) {
    val @f = Rosetta::BrilliantNumbers::get_factors($n)
    if (len(@f) != 2) {
        0
    } else {
        len("$f[0]") == len("$f[1]")
    }
}

assert_ok Rosetta::BrilliantNumbers::check(4), "4 is brilliant (2*2)"
assert_ok Rosetta::BrilliantNumbers::check(6), "6 is brilliant (2*3)"
assert_ok Rosetta::BrilliantNumbers::check(10), "10 is brilliant (2*5)"
assert_ok Rosetta::BrilliantNumbers::check(14), "14 is brilliant (2*7)"
assert_ok Rosetta::BrilliantNumbers::check(15), "15 is brilliant (3*5)"
assert_ok Rosetta::BrilliantNumbers::check(21), "21 is brilliant (3*7)"
assert_ok Rosetta::BrilliantNumbers::check(221), "221 is brilliant (13*17)"
assert_ok !Rosetta::BrilliantNumbers::check(22), "22 is not brilliant (2*11)"
assert_ok !Rosetta::BrilliantNumbers::check(33), "33 is not brilliant (3*11)"

221 |> Rosetta::BrilliantNumbers::check |> assert_ok("pipe brilliant")

test_run
