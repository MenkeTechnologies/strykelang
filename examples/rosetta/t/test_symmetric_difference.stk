#!/usr/bin/env stryke
# Rosetta Code: Symmetric difference of two sets — A △ B = (A \ B) ∪ (B \ A)

fn Rosetta::SymDiff::compute($a, $b) {
    var %in_a
    var %in_b
    for val $x (@$a) { $in_a{$x} = 1 }
    for val $x (@$b) { $in_b{$x} = 1 }
    var @out
    for val $k (keys %in_a) { push @out, $k if !exists $in_b{$k} }
    for val $k (keys %in_b) { push @out, $k if !exists $in_a{$k} }
    [sort @out]
}

# Numeric set example
val $r1 = Rosetta::SymDiff::compute([1, 2, 3, 4], [3, 4, 5, 6])
assert_eq join(",", @$r1), "1,2,5,6", "{1,2,3,4} △ {3,4,5,6}"

# Disjoint sets — symmetric difference equals union
val $r2 = Rosetta::SymDiff::compute([1, 2], [3, 4])
assert_eq join(",", @$r2), "1,2,3,4", "disjoint -> union"

# Identical sets — empty result
val $r3 = Rosetta::SymDiff::compute([1, 2, 3], [1, 2, 3])
assert_eq len(@$r3), 0, "identical -> empty"

# A subset of B
val $r4 = Rosetta::SymDiff::compute([2, 3], [1, 2, 3, 4])
assert_eq join(",", @$r4), "1,4", "subset case"

# Empty inputs
val $r5 = Rosetta::SymDiff::compute([], [1, 2])
assert_eq join(",", @$r5), "1,2", "empty A"

val $r6 = Rosetta::SymDiff::compute([1, 2], [])
assert_eq join(",", @$r6), "1,2", "empty B"

# String elements
val $r7 = Rosetta::SymDiff::compute(["John", "Bob", "Mary"], ["Mary", "Sue", "Bob"])
assert_eq join(",", @$r7), "John,Sue", "name sets"

# Duplicates within input are dropped (set semantics)
val $r8 = Rosetta::SymDiff::compute([1, 1, 2, 2, 3], [3, 3, 4, 4])
assert_eq join(",", @$r8), "1,2,4", "duplicates collapsed"

test_run
