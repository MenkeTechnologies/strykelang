#!/usr/bin/env stryke
# Rosetta Code: Sleep Sort

fn Rosetta::SleepSort::sleep_sort($list) {
    mysync @res
    var @tasks
    for val $v (@$list) {
        push @tasks, spawn {
            sleep($v * 0.05)
            push @res, $v
        }
    }
    for val $t (@tasks) { await($t) }
    \@res
}

val @input = (3, 1, 4, 2)
val $sorted = Rosetta::SleepSort::sleep_sort(\@input)
assert_eq join(",", @$sorted), "1,2,3,4", "sleep sort"

test_run
