#!/usr/bin/env stryke
# Rosetta Code: Jaro-Winkler distance

fn Rosetta::JaroWinkler::jaro($s1, $s2) {
    my $len1 = length($s1)
    my $len2 = length($s2)
    return 1.0 if $len1 == 0 && $len2 == 0
    return 0.0 if $len1 == 0 || $len2 == 0
    
    my $match_distance = (max($len1, $len2) / 2 | 0) - 1
    $match_distance = 0 if $match_distance < 0
    
    my @c1 = $s1 |> chars()
    my @c2 = $s2 |> chars()
    
    my @m1 = map { 0 } 1:$len1
    my @m2 = map { 0 } 1:$len2
    
    my $matches = 0
    for (my $i = 0; $i < $len1; $i++) {
        my $start = max(0, $i - $match_distance)
        my $end = min($len2 - 1, $i + $match_distance)
        
        for (my $j = $start; $j <= $end; $j++) {
            if (!$m2[$j] && $c1[$i] eq $c2[$j]) {
                $m1[$i] = 1
                $m2[$j] = 1
                $matches++
                last
            }
        }
    }
    
    return 0.0 if $matches == 0
    
    my $transpositions = 0
    my $k = 0
    for (my $i = 0; $i < $len1; $i++) {
        if ($m1[$i]) {
            while (!$m2[$k]) { $k++ }
            if ($c1[$i] ne $c2[$k]) {
                $transpositions++
            }
            $k++
        }
    }
    
    my $t = $transpositions / 2
    (1.0/3.0) * ($matches / $len1 + $matches / $len2 + ($matches - $t) / $matches)
}

fn Rosetta::JaroWinkler::solve($s1, $s2) {
    my $j = Rosetta::JaroWinkler::jaro($s1, $s2)
    my $p = 0.1 # scaling factor
    
    # Common prefix up to 4 chars
    my $l = 0
    my @c1 = $s1 |> chars()
    my @c2 = $s2 |> chars()
    my $min_len = min(min(len(@c1), len(@c2)), 4)
    
    for (my $i = 0; $i < $min_len; $i++) {
        if ($c1[$i] eq $c2[$i]) {
            $l++
        } else {
            last
        }
    }
    
    $j + $l * $p * (1.0 - $j)
}

# MARTHA vs MARHTA
# Jaro: m=6, t=2/2=1. J = 1/3 * (6/6 + 6/6 + 5/6) = 1/3 * (2.8333) = 0.9444
# Prefix: MAR (actually MAR is 3, but MARTH is 4?) wait. MARTHA vs MARHTA prefix is MAR (3).
# Oh wait, MARTHA vs MARHTA. Prefix: M, A, R. T matches H? No. So l=3.
# JW = 0.9444 + 3 * 0.1 * (1 - 0.9444) = 0.9444 + 0.3 * 0.0556 = 0.9444 + 0.0167 = 0.9611

my $res = Rosetta::JaroWinkler::solve("MARTHA", "MARHTA")
assert_ok abs($res - 0.9611) < 0.001, "JW(MARTHA, MARHTA)"

my $res2 = Rosetta::JaroWinkler::solve("DIXON", "DICKSONX")
# Jaro: D-D, I-I, X-X, O-?, N-N. m=4.
# D I X N vs D I C K S O N X
# m=4. |s1|=5, |s2|=8.
# J = 1/3 * (4/5 + 4/8 + 4/4) = 1/3 * (0.8 + 0.5 + 1) = 1/3 * 2.3 = 0.7667
# Prefix: DI (2).
# JW = 0.7667 + 2 * 0.1 * (1 - 0.7667) = 0.7667 + 0.2 * 0.2333 = 0.7667 + 0.0467 = 0.8133
assert_ok abs($res2 - 0.8133) < 0.001, "JW(DIXON, DICKSONX)"

test_run
