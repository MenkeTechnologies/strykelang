#!/usr/bin/env stryke
# Rosetta Code: 100 Doors

fn Rosetta::OneHundredDoors::solve($n) {
    # A door is open if it is toggled an odd number of times.
    # It is toggled for every divisor it has.
    # Numbers with an odd number of divisors are perfect squares.
    ~> 1:$n pgrep {
        my $door = $_
        my @divs = grep { $door % $_ == 0 } 1:$door
        scalar(@divs) % 2 == 1
    }
}

fn Rosetta::OneHundredDoors::solve_optimized($n) {
    ~> 1:$n pgrep {
        my $s = sqrt($_)
        $s == int($s)
    }
}

my @result = Rosetta::OneHundredDoors::solve(100)
assert_eq join(",", @result), "1,4,9,16,25,36,49,64,81,100", "100 doors puzzle"

my @opt = Rosetta::OneHundredDoors::solve_optimized(100)
assert_eq join(",", @opt), "1,4,9,16,25,36,49,64,81,100", "optimized (perfect squares)"

my @small = Rosetta::OneHundredDoors::solve(10)
assert_eq join(",", @small), "1,4,9", "10 doors"

test_run
