#!/usr/bin/env stryke
# Rosetta Code: Entropy

fn Rosetta::Entropy::shannon($s) {
    val $len = len($s)
    if ($len == 0) { return 0 }
    var $counts = {}
    val @chars = ~> $s chars
    for val $c (@chars) {
        $counts->{$c} = ($counts->{$c} || 0) + 1
    }
    
    var $entropy = 0
    for val $char (keys %$counts) {
        val $p = $counts->{$char} / $len
        $entropy -= $p * (log($p) / log(2))
    }
    $entropy
}

assert_near Rosetta::Entropy::shannon("1223334444"), 1.8464, 0.0001, "Entropy of 1223334444"
assert_eq Rosetta::Entropy::shannon("aaaaa"), 0, "Entropy of aaaaa is 0"
assert_eq Rosetta::Entropy::shannon(""), 0, "Entropy of empty string"

test_run
