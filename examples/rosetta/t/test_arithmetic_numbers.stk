#!/usr/bin/env stryke
# Rosetta Code: Arithmetic numbers

fn my_divisors($n) {
    my @d
    for my $i (1..$n) {
        if ($n % $i == 0) { push @d, $i }
    }
    \@d
}

fn is_arithmetic($n) {
    my $divs_ref = my_divisors($n)
    my @divs = @$divs_ref
    my $sum = 0
    for my $d (@divs) { $sum += $d }
    my $count = scalar(@divs)
    $sum % $count == 0
}

assert_ok is_arithmetic(1), "1 is arithmetic (div 1, sum 1, mean 1)"
assert_ok is_arithmetic(3), "3 is arithmetic (div 1,3, sum 4, mean 2)"
assert_ok is_arithmetic(5), "5 is arithmetic (div 1,5, sum 6, mean 3)"
assert_ok is_arithmetic(6), "6 is arithmetic (div 1,2,3,6, sum 12, mean 3)"
assert_ok !is_arithmetic(2), "2 is not (div 1,2, sum 3, mean 1.5)"
assert_ok !is_arithmetic(4), "4 is not (div 1,2,4, sum 7, mean 2.33)"

6 |> is_arithmetic |> assert_ok("pipe arithmetic")

test_run
