#!/usr/bin/env stryke
# Rosetta Code: Arithmetic numbers

fn Rosetta::ArithmeticNumbers::get_divisors($n) {
    var @d
    for val $i (1:$n) {
        if ($n % $i == 0) { push @d, $i }
    }
    \@d
}

fn Rosetta::ArithmeticNumbers::check($n) {
    val $divs_ref = Rosetta::ArithmeticNumbers::get_divisors($n)
    var @divs = @$divs_ref
    var $sum = 0
    for val $d (@divs) { $sum += $d }
    val $count = len(@divs)
    $sum % $count == 0
}

assert_ok Rosetta::ArithmeticNumbers::check(1), "1 is arithmetic (div 1, sum 1, mean 1)"
assert_ok Rosetta::ArithmeticNumbers::check(3), "3 is arithmetic (div 1,3, sum 4, mean 2)"
assert_ok Rosetta::ArithmeticNumbers::check(5), "5 is arithmetic (div 1,5, sum 6, mean 3)"
assert_ok Rosetta::ArithmeticNumbers::check(6), "6 is arithmetic (div 1,2,3,6, sum 12, mean 3)"
assert_ok !Rosetta::ArithmeticNumbers::check(2), "2 is not (div 1,2, sum 3, mean 1.5)"
assert_ok !Rosetta::ArithmeticNumbers::check(4), "4 is not (div 1,2,4, sum 7, mean 2.33)"

6 |> Rosetta::ArithmeticNumbers::check |> assert_ok("pipe arithmetic")

test_run
