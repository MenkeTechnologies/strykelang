#!/usr/bin/env stryke
# Rosetta Code: Count Character Occurrences

fn Rosetta::CountOccurrences::solve($s) {
    var $counts = {}
    var @chars = chars($s)
    for val $c (@chars) {
        $counts->{$c} = $counts->{$c} + 1
    }
    $counts
}

val $res = Rosetta::CountOccurrences::solve("banana")
assert_eq $res->{b}, 1, "b count"
assert_eq $res->{a}, 3, "a count"
assert_eq $res->{n}, 2, "n count"

val $res2 = Rosetta::CountOccurrences::solve("mississippi")
assert_eq $res2->{m}, 1, "m count"
assert_eq $res2->{i}, 4, "i count"
assert_eq $res2->{s}, 4, "s count"
assert_eq $res2->{p}, 2, "p count"

test_run
