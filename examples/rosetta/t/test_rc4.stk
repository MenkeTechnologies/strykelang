#!/usr/bin/env stryke
# Rosetta Code: RC4

fn Rosetta::RC4::ksa($key) {
    val @key_bytes = $key |> chars() |> map {ord}
    val $key_len = len(@key_bytes)
    var @s = 0:255
    
    var $j = 0
    for (var $i = 0; $i < 256; $i++) {
        $j = ($j + $s[$i] + $key_bytes[$i % $key_len]) % 256
        # Swap
        val $tmp = $s[$i]
        $s[$i] = $s[$j]
        $s[$j] = $tmp
    }
    \@s
}

fn Rosetta::RC4::prga($s, $len) {
    var $i = 0
    var $j = 0
    var @keystream
    for (var $k = 0; $k < $len; $k++) {
        $i = ($i + 1) % 256
        $j = ($j + $s->[$i]) % 256
        
        # Swap
        val $tmp = $s->[$i]
        $s->[$i] = $s->[$j]
        $s->[$j] = $tmp
        
        val $t = ($s->[$i] + $s->[$j]) % 256
        push @keystream, $s->[$t]
    }
    @keystream
}

fn Rosetta::RC4::solve($key, $data) {
    val $s = Rosetta::RC4::ksa($key)
    val @data_bytes = $data |> chars() |> map {ord}
    val @keystream = Rosetta::RC4::prga($s, len(@data_bytes))
    
    var @res
    for (var $i = 0; $i < len(@data_bytes); $i++) {
        push @res, $data_bytes[$i] ^ $keystream[$i]
    }
    @res
}

# Test with Wikipedia example
# Key "Key", Data "Plaintext"
val @encrypted = Rosetta::RC4::solve("Key", "Plaintext")
# Hex output: BB F3 16 E8 D9 40 AF 0A D3
val @hex = @encrypted |> map { sprintf("%02X", _) }
assert_eq join(" ", @hex), "BB F3 16 E8 D9 40 AF 0A D3", "RC4 Wikipedia example"

# Round trip
fn Rosetta::RC4::to_string(@bytes) {
    @bytes |> map {chr} |> join("")
}

val $original = "Stryke is fast!"
val @cipher = Rosetta::RC4::solve("secret", $original)
val @plain_bytes = Rosetta::RC4::solve("secret", Rosetta::RC4::to_string(@cipher))
assert_eq Rosetta::RC4::to_string(@plain_bytes), $original, "RC4 round trip"

test_run
