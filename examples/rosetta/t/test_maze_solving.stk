#!/usr/bin/env stryke
# Rosetta Code: Maze solving
# Given a fully-connected maze (each cell has 4 wall flags), find the
# shortest path from start to goal via BFS. Returns the path as a
# list of (row, col) cells, or undef if unreachable.

fn Rosetta::MazeSolve::neighbours($grid, $r, $c) {
    my @out
    push @out, [$r - 1, $c] if !$grid->[$r][$c]{N}
    push @out, [$r + 1, $c] if !$grid->[$r][$c]{S}
    push @out, [$r, $c - 1] if !$grid->[$r][$c]{W}
    push @out, [$r, $c + 1] if !$grid->[$r][$c]{E}
    @out
}

fn Rosetta::MazeSolve::shortest_path($grid, $start, $goal) {
    my %parent
    my $start_key = "$start->[0],$start->[1]"
    my $goal_key  = "$goal->[0],$goal->[1]"
    my @queue = ($start)
    $parent{$start_key} = "ROOT"
    while (len(@queue) > 0) {
        my $cell = shift @queue
        my $key = "$cell->[0],$cell->[1]"
        if ($key eq $goal_key) {
            my @path
            my $cur = $key
            while ($cur ne "ROOT") {
                my @parts = split /,/, $cur
                unshift @path, [$parts[0] + 0, $parts[1] + 0]
                $cur = $parent{$cur}
            }
            return \@path
        }
        for my $n (Rosetta::MazeSolve::neighbours($grid, $cell->[0], $cell->[1])) {
            my $nk = "$n->[0],$n->[1]"
            next if exists $parent{$nk}
            $parent{$nk} = $key
            push @queue, $n
        }
    }
    undef
}

fn Rosetta::MazeSolve::open_grid($w, $h) {
    # Test fixture: a fully-open w × h grid (no internal walls).
    my @grid
    for my $r (0..$h - 1) {
        my @row
        for my $c (0..$w - 1) {
            push @row, {
                N => $r == 0      ? 1 : 0,
                S => $r == $h - 1 ? 1 : 0,
                W => $c == 0      ? 1 : 0,
                E => $c == $w - 1 ? 1 : 0,
            }
        }
        push @grid, \@row
    }
    \@grid
}

# 4×4 fully-open grid: shortest path from (0,0) to (3,3) is 7 steps.
my $g = Rosetta::MazeSolve::open_grid(4, 4)
my $p = Rosetta::MazeSolve::shortest_path($g, [0, 0], [3, 3])
assert_eq len(@$p), 7, "Manhattan path length = 7"
assert_eq $p->[0][0], 0,  "start at row 0"
assert_eq $p->[0][1], 0,  "start at col 0"
assert_eq $p->[-1][0], 3, "end at row 3"
assert_eq $p->[-1][1], 3, "end at col 3"

# Same start as goal: path of length 1
my $self = Rosetta::MazeSolve::shortest_path($g, [1, 1], [1, 1])
assert_eq len(@$self), 1, "self path = 1 cell"

# Walled-off cell unreachable
my $blocked = Rosetta::MazeSolve::open_grid(3, 3)
$blocked->[1][1] = { N => 1, S => 1, E => 1, W => 1 }
$blocked->[0][1]{S} = 1
$blocked->[2][1]{N} = 1
$blocked->[1][0]{E} = 1
$blocked->[1][2]{W} = 1
my $cant = Rosetta::MazeSolve::shortest_path($blocked, [0, 0], [1, 1])
assert_ok !defined($cant), "fully-walled cell unreachable"

# Path follows only open edges
my $edge_ok = 1
for my $i (0..len(@$p) - 2) {
    my ($r1, $c1) = @{$p->[$i]}
    my ($r2, $c2) = @{$p->[$i + 1]}
    my $dr = $r2 - $r1; my $dc = $c2 - $c1
    if    ($dr == -1 && $dc == 0) { $edge_ok = 0 if $g->[$r1][$c1]{N} }
    elsif ($dr ==  1 && $dc == 0) { $edge_ok = 0 if $g->[$r1][$c1]{S} }
    elsif ($dr == 0 && $dc == -1) { $edge_ok = 0 if $g->[$r1][$c1]{W} }
    elsif ($dr == 0 && $dc ==  1) { $edge_ok = 0 if $g->[$r1][$c1]{E} }
    else { $edge_ok = 0 }
}
assert_ok $edge_ok, "every step crosses an open wall"

# Pipe form
my $piped = Rosetta::MazeSolve::shortest_path($g, [0, 0], [0, 3])
assert_eq len(@$piped), 4, "pipe 1-row path"

test_run
