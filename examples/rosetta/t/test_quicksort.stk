#!/usr/bin/env stryke
# Rosetta Code: Sorting

fn numeric_sort {
    sort { $a <=> $b } @_
}

my @sorted = numeric_sort(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq join(",", @sorted), "1,1,2,3,4,5,6,9", "sort basic"

my @single = numeric_sort(42)
assert_eq join(",", @single), "42", "sort single"

my @neg = numeric_sort(-5, 3, -1, 0, 2)
assert_eq join(",", @neg), "-5,-1,0,2,3", "sort with negatives"

test_run
