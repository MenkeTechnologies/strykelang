#!/usr/bin/env stryke
# Rosetta Code: Longest common substring

fn Rosetta::LCSSubstring::solve($s1, $s2) {
    my @c1 = ~> $s1 chars
    my @c2 = ~> $s2 chars
    my $m = len(@c1)
    my $n = len(@c2)
    my @table = ()
    for my $i (0..$m) {
        $table[$i] = []
        for my $j (0..$n) {
            $table[$i][$j] = 0
        }
    }
    
    my $max_len = 0
    my $end_idx = 0
    
    for my $i (1..$m) {
        for my $j (1..$n) {
            if ($c1[$i-1] eq $c2[$j-1]) {
                $table[$i][$j] = $table[$i-1][$j-1] + 1
                if ($table[$i][$j] > $max_len) {
                    $max_len = $table[$i][$j]
                    $end_idx = $i
                }
            }
        }
    }
    substr($s1, $end_idx - $max_len, $max_len)
}

assert_eq Rosetta::LCSSubstring::solve("abcde", "abfde"), "ab", "LCS substring abcde/abfde"
assert_eq Rosetta::LCSSubstring::solve("thisisatest", "testing123testing"), "test", "LCS substring test"
assert_eq Rosetta::LCSSubstring::solve("apple", "banana"), "a", "Common 'a'"

test_run
