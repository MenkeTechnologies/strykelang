#!/usr/bin/env stryke
# Rosetta Code: Calkin-Wilf sequence
# a(1)=1; a(n+1) = 1/(2*floor(a(n)) + 1 - a(n))
# Each rational appears once in lowest terms.

fn Math::GCD::gcd($a, $b) {
    while ($b != 0) { my $t = $b; $b = $a % $b; $a = $t }
    $a
}

fn Rosetta::CalkinWilf::next_rat($p, $q) {
    # next = 1 / (2*floor(p/q) + 1 - p/q)
    # Let f = int(p/q). new = q / ((2f+1)*q - p)
    my $f = int($p / $q)
    my $np = $q
    my $nq = (2 * $f + 1) * $q - $p
    my $g = Math::GCD::gcd($np, $nq)
    [int($np / $g), int($nq / $g)]
}

fn Rosetta::CalkinWilf::first_n($count) {
    my @res = ([1, 1])
    my ($p, $q) = (1, 1)
    while (len(@res) < $count) {
        my $r = Rosetta::CalkinWilf::next_rat($p, $q)
        $p = $r->[0]
        $q = $r->[1]
        push @res, [$p, $q]
    }
    @res
}

my @s = Rosetta::CalkinWilf::first_n(15)
my @str = ~> @s map { _->[0] . "/" . _->[1] }
# 1/1,1/2,2/1,1/3,3/2,2/3,3/1,1/4,4/3,3/5,5/2,2/5,5/3,3/4,4/1
assert_eq join(",", @str),
    "1/1,1/2,2/1,1/3,3/2,2/3,3/1,1/4,4/3,3/5,5/2,2/5,5/3,3/4,4/1",
    "first 15 Calkin-Wilf rationals"

test_run
