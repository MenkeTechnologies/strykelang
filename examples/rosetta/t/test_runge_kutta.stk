#!/usr/bin/env stryke
# Rosetta Code: Runge-Kutta 4th order

fn Rosetta::RungeKutta::solve($f, $x, $y, $h, $steps) {
    var @res = ([$x, $y])
    for val $i (1:$steps) {
        val $k1 = $h * $f($x, $y)
        val $k2 = $h * $f($x + $h/2, $y + $k1/2)
        val $k3 = $h * $f($x + $h/2, $y + $k2/2)
        val $k4 = $h * $f($x + $h, $y + $k3)
        
        $y += ($k1 + 2*$k2 + 2*$k3 + $k4) / 6
        $x += $h
        push @res, [$x, $y]
    }
    @res
}

# y' = x * sqrt(y)
val $f = fn($x, $y) { $x * sqrt($y) }
val $h = 0.1
val $steps = 100 # from 0 to 10
val @results = Rosetta::RungeKutta::solve($f, 0, 1, $h, $steps)

# Exact solution: y(x) = (1/16) * (x^2 + 4)^2
fn Rosetta::RungeKutta::exact($x) {
    0.0625 * ($x * $x + 4) ** 2
}

# Check a few points
for val $step (0, 10, 50, 100) {
    val $p = $results[$step]
    val $x = $p->[0]
    val $y = $p->[1]
    val $exact_y = Rosetta::RungeKutta::exact($x)
    assert_ok abs($y - $exact_y) < 0.0001, "RK4 at x=$x: $y vs exact $exact_y"
}

test_run
