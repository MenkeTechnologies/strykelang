#!/usr/bin/env stryke
# Rosetta Code: Running total / cumulative sum.
# `_<` (previous topic) carries the running accumulator across iters of
# a single-pass map — no temp var, no fold/scan plumbing.

fn Rosetta::Running::total(@xs) {
    my $acc = 0
    ~> @xs map { $acc += $_; $acc }
}

# Variant: rolling product.
fn Rosetta::Running::product(@xs) {
    my $acc = 1
    ~> @xs map { $acc *= $_; $acc }
}

# Cumulative sum 1..5: 1, 3, 6, 10, 15 (the triangular numbers).
my @t = Rosetta::Running::total(1, 2, 3, 4, 5)
assert_eq join(",", @t), "1,3,6,10,15", "cumulative 1..5 → triangular"

# Empty input → empty.
my @empty_input = ()
my @e = Rosetta::Running::total(@empty_input)
assert_eq len(@e), 0, "empty input"

# Single element passes through.
my @s = Rosetta::Running::total(42)
assert_eq join(",", @s), "42", "single element"

# Negatives: cumulative -1, -3, -6, -10.
my @n = Rosetta::Running::total(-1, -2, -3, -4)
assert_eq join(",", @n), "-1,-3,-6,-10", "negatives"

# Rolling product 1..6 = factorials 1, 2, 6, 24, 120, 720.
my @p = Rosetta::Running::product(1, 2, 3, 4, 5, 6)
assert_eq join(",", @p), "1,2,6,24,120,720", "rolling product → factorials"

test_run
