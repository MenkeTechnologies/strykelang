#!/usr/bin/env stryke
# Rosetta Code: Multiple regression
# Solve y = X · β + ε via the normal equations:
#   β = (Xᵀ X)⁻¹ Xᵀ y
# Implementation includes a transpose, matrix multiply, and 2×2 / 3×3
# Gauss-Jordan inverse.

fn Rosetta::MultiReg::transpose($m) {
    val $rows = len(@$m)
    val $cols = len(@{$m->[0]})
    var @t
    for val $c (0:$cols - 1) {
        var @row
        for val $r (0:$rows - 1) { push @row, $m->[$r][$c] }
        push @t, \@row
    }
    \@t
}

fn Rosetta::MultiReg::matmul($a, $b) {
    val $ar = len(@$a); val $ac = len(@{$a->[0]})
    val $bc = len(@{$b->[0]})
    var @out
    for val $i (0:$ar - 1) {
        var @row
        for val $j (0:$bc - 1) {
            var $s = 0
            for val $k (0:$ac - 1) { $s += $a->[$i][$k] * $b->[$k][$j] }
            push @row, $s
        }
        push @out, \@row
    }
    \@out
}

fn Rosetta::MultiReg::matvec($a, $v) {
    var @out
    for val $row (@$a) {
        var $s = 0
        for val $i (0..len(@$v) - 1) { $s += $row->[$i] * $v->[$i] }
        push @out, $s
    }
    \@out
}

fn Rosetta::MultiReg::solve_linear($a, $b) {
    # Solve square system $a * x = $b via Gauss-Jordan.
    val $n = len(@$a)
    var @aug
    for val $i (0:$n - 1) {
        push @aug, [@{$a->[$i]}, $b->[$i]]
    }
    for var $r (0:$n - 1) {
        var $pivot = $r
        while ($pivot < $n && abs($aug[$pivot][$r]) < 1e-12) { $pivot++ }
        return undef if $pivot == $n
        ($aug[$r], $aug[$pivot]) = ($aug[$pivot], $aug[$r]) if $pivot != $r
        val $div = $aug[$r][$r]
        for val $c ($r:$n) { $aug[$r][$c] /= $div }
        for val $i (0:$n - 1) {
            next if $i == $r
            val $f = $aug[$i][$r]
            next if abs($f) < 1e-15
            for val $c ($r:$n) { $aug[$i][$c] -= $f * $aug[$r][$c] }
        }
    }
    var @x
    for val $i (0:$n - 1) { push @x, $aug[$i][$n] }
    \@x
}

fn Rosetta::MultiReg::fit($xs, $ys) {
    # $xs is m × p (m observations, p features incl. bias column).
    val $xt = Rosetta::MultiReg::transpose($xs)
    val $xtx = Rosetta::MultiReg::matmul($xt, $xs)
    val $xty = Rosetta::MultiReg::matvec($xt, $ys)
    Rosetta::MultiReg::solve_linear($xtx, $xty)
}

# Linear data y = 2x + 3
val $X = [[1, 1], [1, 2], [1, 3], [1, 4], [1, 5]]      # bias column + x
val $y = [5, 7, 9, 11, 13]
val $beta = Rosetta::MultiReg::fit($X, $y)
assert_near $beta->[0], 3, 1e-9, "intercept = 3"
assert_near $beta->[1], 2, 1e-9, "slope     = 2"

# Two-feature plane: y = 1 + 2·x1 + 3·x2
val $X2 = [
    [1, 0, 0], [1, 1, 0], [1, 0, 1], [1, 1, 1],
    [1, 2, 1], [1, 0, 2], [1, 2, 2],
]
val $y2 = [1, 3, 4, 6, 8, 7, 11]
val $b2 = Rosetta::MultiReg::fit($X2, $y2)
assert_near $b2->[0], 1, 1e-9, "intercept"
assert_near $b2->[1], 2, 1e-9, "x1 coefficient"
assert_near $b2->[2], 3, 1e-9, "x2 coefficient"

# Helper sanity
val $mt = Rosetta::MultiReg::transpose([[1, 2, 3], [4, 5, 6]])
assert_eq join(",", @{$mt->[0]}), "1,4", "transpose row 0"
assert_eq join(",", @{$mt->[2]}), "3,6", "transpose row 2"

# matmul
val $mm = Rosetta::MultiReg::matmul([[1, 2], [3, 4]], [[5], [6]])
assert_eq $mm->[0][0], 17, "1*5 + 2*6"
assert_eq $mm->[1][0], 39, "3*5 + 4*6"

# Pipe form
val $simple = Rosetta::MultiReg::fit([[1, 1], [1, 2]], [3, 5])
assert_near $simple->[0], 1, 1e-9, "pipe intercept"
assert_near $simple->[1], 2, 1e-9, "pipe slope"

test_run
