#!/usr/bin/env stryke
# Rosetta Code: Factorial/Trailing zeros

fn Rosetta::FactorialTrailingZeros::solve($n) {
    my $curr_n = $n
    my $count = 0
    while ($curr_n >= 5) {
        $curr_n = int($curr_n / 5)
        $count = $count + $curr_n
    }
    $count
}

assert_eq Rosetta::FactorialTrailingZeros::solve(25), 6, "25! has 6 trailing zeros"
assert_eq Rosetta::FactorialTrailingZeros::solve(100), 24, "100! has 24 trailing zeros"
assert_eq Rosetta::FactorialTrailingZeros::solve(1000), 249, "1000! has 249 trailing zeros"
assert_eq Rosetta::FactorialTrailingZeros::solve(4), 0, "4! has 0"

test_run
