#!/usr/bin/env stryke
# Rosetta Code: Yellowstone sequence (OEIS A098550)
# a(1)=1, a(2)=2, a(3)=3. For n>=4, a(n) = smallest unused k such that
#   gcd(k, a(n-1)) == 1 and gcd(k, a(n-2)) > 1

fn Rosetta::Yellowstone::gcd($a, $b) {
    var $x = $a
    var $y = $b
    while ($y != 0) {
        ($x, $y) = ($y, $x % $y)
    }
    $x
}

fn Rosetta::Yellowstone::generate($count) {
    var @seq = (1, 2, 3)
    var %used
    $used{1} = 1; $used{2} = 1; $used{3} = 1
    while (len(@seq) < $count) {
        val $prev = $seq[-1]
        val $prev2 = $seq[-2]
        var $n = 4
        while (1) {
            if (!$used{$n}
                && Rosetta::Yellowstone::gcd($n, $prev) == 1
                && Rosetta::Yellowstone::gcd($n, $prev2) > 1) {
                push @seq, $n
                $used{$n} = 1
                last
            }
            $n += 1
        }
    }
    \@seq
}

val $seq = Rosetta::Yellowstone::generate(15)
assert_eq join(",", @$seq), "1,2,3,4,9,8,15,14,5,6,25,12,35,16,7", "Yellowstone first 15"

val $seq30 = Rosetta::Yellowstone::generate(30)
assert_eq $seq30->[29], 17, "30th Yellowstone term"

test_run
