#!/usr/bin/env stryke
# Rosetta Code: Safe primes

fn Rosetta::SafePrimes::is_prime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        my $limit = sqrt($n)
        my $res = 1
        my $i = 3
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

fn SafePrimes::is_safe_prime($p) {
    if (!Rosetta::SafePrimes::is_prime($p)) {
        0
    } else {
        my $q = ($p - 1) / 2
        Rosetta::SafePrimes::is_prime($q)
    }
}

assert_ok SafePrimes::is_safe_prime(5), "5 is safe (2*2+1)"
assert_ok SafePrimes::is_safe_prime(7), "7 is safe (2*3+1)"
assert_ok SafePrimes::is_safe_prime(11), "11 is safe (2*5+1)"
assert_ok SafePrimes::is_safe_prime(23), "23 is safe (2*11+1)"
assert_ok !SafePrimes::is_safe_prime(13), "13 is not (2*6+1)"

23 |> SafePrimes::is_safe_prime |> assert_ok("pipe safe prime")

test_run
