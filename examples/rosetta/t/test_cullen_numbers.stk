#!/usr/bin/env stryke
# Rosetta Code: Cullen numbers

fn cullen($n) {
    $n * (2 ** $n) + 1
}

fn cullen_list($max_n) {
    ~> 1..$max_n map { cullen($_) }
}

assert_eq cullen(1), 3, "C1"
assert_eq cullen(2), 9, "C2 (2*4+1)"
assert_eq cullen(3), 25, "C3 (3*8+1)"
assert_eq cullen(4), 65, "C4"

my @list = cullen_list(5)
assert_eq join(",", @list), "3,9,25,65,161", "Cullen list"

5 |> cullen |> assert_eq(161, "pipe cullen 5")

test_run
