#!/usr/bin/env stryke
# Rosetta Code: Polygonal numbers

fn Rosetta::Polygonal::compute($s, $n) {
    (($s - 2) * $n * $n - ($s - 4) * $n) / 2
}

# s=3: triangular, s=4: square, s=5: pentagonal
assert_eq Rosetta::Polygonal::compute(3, 10), 55, "Tri(10) = 55"
assert_eq Rosetta::Polygonal::compute(4, 10), 100, "Sq(10) = 100"
assert_eq Rosetta::Polygonal::compute(5, 10), 145, "Pent(10) = 145"
assert_eq Rosetta::Polygonal::compute(6, 10), 190, "Hex(10) = 190"

test_run
