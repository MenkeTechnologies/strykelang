#!/usr/bin/env stryke
# Rosetta Code: Backpropagation

fn Rosetta::Backprop::sigmoid($x) {
    1.0 / (1.0 + exp(-$x))
}

fn Rosetta::Backprop::sigmoid_derivative($x) {
    $x * (1.0 - $x)
}

fn Rosetta::Backprop::train($data, $labels, $learning_rate, $epochs) {
    # 2 input, 2 hidden, 1 output
    val @w_h = ([rand(), rand()], [rand(), rand()])
    var @b_h = (rand(), rand())
    var @w_o = (rand(), rand())
    var @b_o = rand()
    
    for (var $e = 0; $e < $epochs; $e++) {
        for (var $i = 0; $i < len(@$data); $i++) {
            val $x = $data->[$i]
            val $y = $labels->[$i]
            
            # Forward pass
            var @h_in
            var @h_out
            for (var $j = 0; $j < 2; $j++) {
                var $sum = $b_h[$j]
                for (var $k = 0; $k < 2; $k++) {
                    $sum += $x->[$k] * $w_h[$j]->[$k]
                }
                push @h_in, $sum
                push @h_out, Rosetta::Backprop::sigmoid($sum)
            }
            
            var $o_in = $b_o
            for (var $j = 0; $j < 2; $j++) {
                $o_in += $h_out[$j] * $w_o[$j]
            }
            val $o_out = Rosetta::Backprop::sigmoid($o_in)
            
            # Backward pass
            val $o_error = $y - $o_out
            val $o_delta = $o_error * Rosetta::Backprop::sigmoid_derivative($o_out)
            
            var @h_delta
            for (var $j = 0; $j < 2; $j++) {
                val $h_error = $o_delta * $w_o[$j]
                push @h_delta, $h_error * Rosetta::Backprop::sigmoid_derivative($h_out[$j])
            }
            
            # Update weights
            for (var $j = 0; $j < 2; $j++) {
                $w_o[$j] += $o_delta * $h_out[$j] * $learning_rate
            }
            $b_o += $o_delta * $learning_rate
            
            for (var $j = 0; $j < 2; $j++) {
                for (var $k = 0; $k < 2; $k++) {
                    $w_h[$j]->[$k] += $h_delta[$j] * $x->[$k] * $learning_rate
                }
                $b_h[$j] += $h_delta[$j] * $learning_rate
            }
        }
    }
    
    { w_h => \@w_h, b_h => \@b_h, w_o => \@w_o, b_o => $b_o }
}

fn Rosetta::Backprop::predict($model, $x) {
    val $w_h = $model->{w_h}
    val $b_h = $model->{b_h}
    val $w_o = $model->{w_o}
    val $b_o = $model->{b_o}
    
    var @h_out
    for (var $j = 0; $j < 2; $j++) {
        var $sum = $b_h->[$j]
        for (var $k = 0; $k < 2; $k++) {
            $sum += $x->[$k] * $w_h->[$j]->[$k]
        }
        push @h_out, Rosetta::Backprop::sigmoid($sum)
    }
    
    var $o_in = $b_o
    for (var $j = 0; $j < 2; $j++) {
        $o_in += $h_out[$j] * $w_o->[$j]
    }
    Rosetta::Backprop::sigmoid($o_in)
}

# XOR problem
val $data = [ [0,0], [0,1], [1,0], [1,1] ]
val $labels = [0, 1, 1, 0]

# Pin the RNG so training is deterministic — without this the test is flaky:
# random init occasionally lands a 2-2-1 net in a local minimum where the
# (1,0) / (1,1) outputs don't separate inside 10k epochs.
srand(1)
val $model = Rosetta::Backprop::train($data, $labels, 0.5, 10000)

# Loose thresholds (< 0.5 vs >= 0.5) — the deterministic seed converges far
# tighter, but this is a learning test, not a precision test. Asserting only
# the classification boundary keeps the test robust to minor RNG / floating-
# point drift across stryke versions.
assert_ok Rosetta::Backprop::predict($model, [0, 0]) < 0.5, "XOR(0,0) → 0"
assert_ok Rosetta::Backprop::predict($model, [0, 1]) > 0.5, "XOR(0,1) → 1"
assert_ok Rosetta::Backprop::predict($model, [1, 0]) > 0.5, "XOR(1,0) → 1"
assert_ok Rosetta::Backprop::predict($model, [1, 1]) < 0.5, "XOR(1,1) → 0"

test_run
