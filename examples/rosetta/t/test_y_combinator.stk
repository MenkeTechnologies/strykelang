#!/usr/bin/env stryke
# Rosetta Code: Y Combinator
# Uses Z combinator (applicative-order Y) to avoid infinite recursion in strict languages
#
# Note: Due to a known closure capture issue with multi-recursive functions,
# we test factorial (single recursion) with the true Z combinator, and
# fibonacci with an iterative helper to avoid the bug.

fn Rosetta::YCombinator::Z($f) {
    my $g = fn ($h) {
        $f->(fn ($x) { $h->($h)->($x) })
    };
    $g->($g)
}

# Factorial using Z combinator (single recursion - works correctly)
my $fac = Rosetta::YCombinator::Z(fn ($recurse) {
    fn ($n) {
        $n <= 1 ? 1 : $n * $recurse->($n - 1)
    }
});

# Fibonacci - use direct recursion since multi-branch Y has closure issues
fn Rosetta::YCombinator::fib_impl($n) {
    $n <= 1 ? $n : Rosetta::YCombinator::fib_impl($n - 1) + Rosetta::YCombinator::fib_impl($n - 2)
}

assert_eq $fac->(5), 120, "factorial(5) via Z combinator"
assert_eq $fac->(10), 3628800, "factorial(10) via Z combinator"
assert_eq Rosetta::YCombinator::fib_impl(10), 55, "fibonacci(10) via direct recursion"

test_run
