#!/usr/bin/env stryke
# Rosetta Code: Dot Product

fn dot_product(@a, @b) {
    my $sum = 0
    for my $i (0..$#a) {
        $sum += $a[$i] * $b[$i]
    }
    $sum
}

fn magnitude(@v) {
    sqrt(dot_product(@v, @v))
}

my @a = (1, 3, -5)
my @b = (4, -2, -1)
assert_eq dot_product(@a, @b), 3, "dot product [1,3,-5].[4,-2,-1]"

my @c = (1, 2, 3)
my @d = (4, 5, 6)
assert_eq dot_product(@c, @d), 32, "dot product [1,2,3].[4,5,6]"

my @e = (1, 0, 0)
my @f = (0, 1, 0)
assert_eq dot_product(@e, @f), 0, "orthogonal vectors"

my @g = (3, 4)
assert_eq magnitude(@g), 5, "magnitude of [3,4]"

my @unit = (1, 0, 0)
assert_eq magnitude(@unit), 1, "unit vector magnitude"

test_run
