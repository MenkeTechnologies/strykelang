#!/usr/bin/env stryke
# Rosetta Code: Dot Product

fn my_dot_product($aref, $bref) {
    my @a = @$aref
    my @b = @$bref
    my $sum = 0
    for my $i (0..$#a) {
        $sum += $a[$i] * $b[$i]
    }
    $sum
}

fn my_magnitude($vref) {
    sqrt(my_dot_product($vref, $vref))
}

my @a = (1, 3, -5)
my @b = (4, -2, -1)
assert_eq my_dot_product(\@a, \@b), 3, "dot product [1,3,-5].[4,-2,-1]"

my @c = (1, 2, 3)
my @d = (4, 5, 6)
assert_eq my_dot_product(\@c, \@d), 32, "dot product [1,2,3].[4,5,6]"

my @e = (1, 0, 0)
my @f = (0, 1, 0)
assert_eq my_dot_product(\@e, \@f), 0, "orthogonal vectors"

my @g = (3, 4)
assert_eq my_magnitude(\@g), 5, "magnitude of [3,4]"

my @unit = (1, 0, 0)
assert_eq my_magnitude(\@unit), 1, "unit vector magnitude"

test_run
