#!/usr/bin/env stryke
# Rosetta Code: Nelder-Mead simplex method for unconstrained minimization.
# Maintains an n-dimensional simplex of n+1 vertices and at each step:
#  1. Reflect worst vertex through centroid of the rest.
#  2. If reflection is best, try expansion. If reflection is "ok", keep it.
#  3. Else try contraction (inside or outside).
#  4. If still no improvement, shrink toward best.

fn Rosetta::NM::vec_add($u, $v) {
    val @r = ~> 0:len(@$u) - 1 |> map { $u->[_0] + $v->[_0] }
    \@r
}

fn Rosetta::NM::vec_sub($u, $v) {
    val @r = ~> 0:len(@$u) - 1 |> map { $u->[_0] - $v->[_0] }
    \@r
}

fn Rosetta::NM::vec_scale($u, $k) {
    val @r = ~> 0:len(@$u) - 1 |> map { $u->[_0] * $k }
    \@r
}

fn Rosetta::NM::centroid($simplex) {
    val $count = len(@$simplex)
    val $dim = len(@{$simplex->[0]})
    var @c = ~> 0:$dim - 1 |> map { 0 }
    for val $i (~> 0:$count - 1) {
        for val $d (~> 0:$dim - 1) { $c[$d] += $simplex->[$i][$d] }
    }
    val @r = ~> 0:$dim - 1 |> map { $c[_0] / $count }
    \@r
}

fn Rosetta::NM::sort_simplex($simplex, $f) {
    var @scored
    for val $v (@$simplex) { push @scored, [$f($v), $v] }
    @scored = sort { _0->[0] <=> _1->[0] } @scored
    val @out = map { _0->[1] } @scored
    \@out
}

fn Rosetta::NM::minimize($f, $start, $iters) {
    val $n = len(@$start)
    # Build initial simplex: x0 plus x0 + step*e_i. Use unit-ish steps so
    # the simplex covers enough of the search space to start moving.
    var @simplex = ($start)
    for val $i (~> 0:$n - 1) {
        var @v = @$start
        $v[$i] += ($v[$i] == 0 ? 1.0 : 0.5 * $v[$i])
        push @simplex, \@v
    }
    val $alpha = 1.0; val $gamma = 2.0; val $rho = 0.5; val $sigma = 0.5
    for val $iter (~> 0:$iters - 1) {
        val $sorted = Rosetta::NM::sort_simplex(\@simplex, $f)
        @simplex = @$sorted
        val $best = $simplex[0]
        val $worst = $simplex[$n]
        val $second_worst = $simplex[$n - 1]
        val @top = @simplex[0:$n - 1]
        val $cent = Rosetta::NM::centroid(\@top)
        val $reflected = Rosetta::NM::vec_add($cent,
            Rosetta::NM::vec_scale(Rosetta::NM::vec_sub($cent, $worst), $alpha))
        val $fr = $f($reflected)
        val $fb = $f($best)
        val $fsw = $f($second_worst)
        val $fw = $f($worst)
        if ($fr < $fb) {
            val $expanded = Rosetta::NM::vec_add($cent,
                Rosetta::NM::vec_scale(Rosetta::NM::vec_sub($cent, $worst), $gamma))
            val $fe = $f($expanded)
            $simplex[$n] = $fe < $fr ? $expanded : $reflected
            next
        }
        if ($fr < $fsw) {
            $simplex[$n] = $reflected
            next
        }
        # Contraction
        var $contracted
        if ($fr < $fw) {
            $contracted = Rosetta::NM::vec_add($cent,
                Rosetta::NM::vec_scale(Rosetta::NM::vec_sub($reflected, $cent), $rho))
        } else {
            $contracted = Rosetta::NM::vec_add($cent,
                Rosetta::NM::vec_scale(Rosetta::NM::vec_sub($worst, $cent), $rho))
        }
        val $fc = $f($contracted)
        if ($fc < $fw) {
            $simplex[$n] = $contracted
            next
        }
        # Shrink
        for val $i (~> 1:$n) {
            val $s = Rosetta::NM::vec_add($best,
                Rosetta::NM::vec_scale(Rosetta::NM::vec_sub($simplex[$i], $best), $sigma))
            $simplex[$i] = $s
        }
    }
    val $sorted = Rosetta::NM::sort_simplex(\@simplex, $f)
    $sorted->[0]
}

fn Rosetta::NM::close($x, $y, $eps) { abs($x - $y) < $eps }

# Quadratic bowl: f(x,y) = (x-3)^2 + (y+2)^2, minimum at (3, -2).
val $f1 = fn ($v) { ($v->[0] - 3) ** 2 + ($v->[1] + 2) ** 2 }
val $r1 = Rosetta::NM::minimize($f1, [0, 0], 200)
assert_ok Rosetta::NM::close($r1->[0],  3, 1e-3), "bowl x*"
assert_ok Rosetta::NM::close($r1->[1], -2, 1e-3), "bowl y*"

# Sphere in 3D: minimum at (0,0,0).
val $f2 = fn ($v) { $v->[0] ** 2 + $v->[1] ** 2 + $v->[2] ** 2 }
val $r2 = Rosetta::NM::minimize($f2, [1, 1, 1], 300)
assert_ok Rosetta::NM::close($r2->[0], 0, 1e-3), "sphere x*"
assert_ok Rosetta::NM::close($r2->[1], 0, 1e-3), "sphere y*"
assert_ok Rosetta::NM::close($r2->[2], 0, 1e-3), "sphere z*"

# Booth function: f(x,y) = (x+2y-7)^2 + (2x+y-5)^2, minimum at (1, 3).
val $f3 = fn ($v) {
    val $a = $v->[0] + 2 * $v->[1] - 7
    val $b = 2 * $v->[0] + $v->[1] - 5
    $a * $a + $b * $b
}
val $r3 = Rosetta::NM::minimize($f3, [0, 0], 400)
assert_ok Rosetta::NM::close($r3->[0], 1, 1e-2), "Booth x*"
assert_ok Rosetta::NM::close($r3->[1], 3, 1e-2), "Booth y*"

# 1D: |x - 5|. Subgradient at the kink, but Nelder-Mead handles it.
val $f4 = fn ($v) { abs($v->[0] - 5) }
val $r4 = Rosetta::NM::minimize($f4, [0], 200)
assert_ok Rosetta::NM::close($r4->[0], 5, 1e-3), "|x-5| min at 5"

test_run
