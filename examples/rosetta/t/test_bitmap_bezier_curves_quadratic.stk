#!/usr/bin/env stryke
# Rosetta Code: Bitmap/Bézier curves/Quadratic

fn Rosetta::Bezier::quadratic($p0, $p1, $p2, $steps) {
    var @points
    for (var $i = 0; $i <= $steps; $i++) {
        val $t = $i / $steps
        val $omt = 1 - $t
        # B(t) = (1-t)^2 P0 + 2(1-t)t P1 + t^2 P2
        val $x = $omt**2 * $p0->[0] + 2 * $omt * $t * $p1->[0] + $t**2 * $p2->[0]
        val $y = $omt**2 * $p0->[1] + 2 * $omt * $t * $p1->[1] + $t**2 * $p2->[1]
        push @points, [$x, $y]
    }
    \@points
}

val $p0 = [0, 0]
val $p1 = [5, 10]
val $p2 = [10, 0]
val $curve = Rosetta::Bezier::quadratic($p0, $p1, $p2, 10)

assert_eq len(@$curve), 11, "Curve has 11 points"
assert_eq $curve->[0]->[0], 0, "Start x"
assert_eq $curve->[10]->[0], 10, "End x"
assert_eq $curve->[5]->[0], 5, "Midpoint x"
assert_eq $curve->[5]->[1], 5, "Midpoint y"

test_run
