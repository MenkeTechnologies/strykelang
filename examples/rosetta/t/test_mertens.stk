#!/usr/bin/env stryke
# Rosetta Code: Mertens function

fn Rosetta::Mertens::moebius($n) {
    if ($n == 1) {
        1
    } else {
        my @factors = prime_factors($n)
        my %counts
        my $has_square = 0
        for my $f (@factors) {
            $counts{$f}++
            if ($counts{$f} > 1) { $has_square = 1 }
        }
        if ($has_square) { 0 }
        else {
            my $num_factors = scalar(@factors)
            if ($num_factors % 2 == 0) { 1 }
            else { -1 }
        }
    }
}

fn Rosetta::Mertens::compute($n) {
    my $sum = 0
    for my $k (1..$n) {
        $sum += Rosetta::Mertens::moebius($k)
    }
    $sum
}

assert_eq Rosetta::Mertens::compute(1), 1, "M(1) = 1"
assert_eq Rosetta::Mertens::compute(10), -1, "M(10) = -1"
assert_eq Rosetta::Mertens::compute(20), -3, "M(20) = -3"
assert_eq Rosetta::Mertens::compute(100), 1, "M(100) = 1"

10 |> Rosetta::Mertens::compute |> assert_eq(-1, "pipe Mertens")

test_run
