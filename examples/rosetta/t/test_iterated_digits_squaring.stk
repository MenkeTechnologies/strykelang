#!/usr/bin/env stryke
# Rosetta Code: Iterated digits squaring

fn Rosetta::IteratedDigitsSquaring::compute($n) {
    my $curr = $n
    while ($curr != 1 && $curr != 89) {
        my $sum = 0
        my @digits = ~> "$curr" chars
        ~> @digits ep {
            $sum += int(_) * int(_)
        }
        $curr = $sum
    }
    $curr
}

assert_eq Rosetta::IteratedDigitsSquaring::compute(7), 1, "7 -> 49 -> 97 -> 130 -> 10 -> 1"
assert_eq Rosetta::IteratedDigitsSquaring::compute(145), 89, "145 -> 1+16+25=42 -> 16+4=20 -> 4 -> 16 -> 37 -> 58 -> 89"
assert_eq Rosetta::IteratedDigitsSquaring::compute(42), 89, "42 ends in 89"

test_run
