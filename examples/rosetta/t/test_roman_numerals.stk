#!/usr/bin/env stryke
# Rosetta Code: Roman Numerals

my @_roman_vals = (1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1)
my @_roman_syms = qw(M CM D CD C XC L XL X IX V IV I)

fn Rosetta::RomanNumerals::to_roman($n) {
    my $result = ""
    for my $i (0..$#_roman_vals) {
        while ($n >= $_roman_vals[$i]) {
            $result .= $_roman_syms[$i]
            $n -= $_roman_vals[$i]
        }
    }
    $result
}

fn Rosetta::RomanNumerals::from_roman($r) {
    my %val = (I => 1, V => 5, X => 10, L => 50, C => 100, D => 500, M => 1000)
    my @chars = $r |> split //
    my $total = 0
    for my $i (0..$#chars) {
        my $v = $val{$chars[$i]}
        my $next = $i < $#chars ? $val{$chars[$i + 1]} : 0
        $total += $v < $next ? -$v : $v
    }
    $total
}

assert_eq Rosetta::RomanNumerals::to_roman(1), "I", "Rosetta::RomanNumerals::to_roman(1)"
assert_eq Rosetta::RomanNumerals::to_roman(4), "IV", "Rosetta::RomanNumerals::to_roman(4)"
assert_eq Rosetta::RomanNumerals::to_roman(9), "IX", "Rosetta::RomanNumerals::to_roman(9)"
assert_eq Rosetta::RomanNumerals::to_roman(49), "XLIX", "Rosetta::RomanNumerals::to_roman(49)"
assert_eq Rosetta::RomanNumerals::to_roman(1999), "MCMXCIX", "Rosetta::RomanNumerals::to_roman(1999)"
assert_eq Rosetta::RomanNumerals::to_roman(2024), "MMXXIV", "Rosetta::RomanNumerals::to_roman(2024)"

assert_eq Rosetta::RomanNumerals::from_roman("I"), 1, "Rosetta::RomanNumerals::from_roman(I)"
assert_eq Rosetta::RomanNumerals::from_roman("IV"), 4, "Rosetta::RomanNumerals::from_roman(IV)"
assert_eq Rosetta::RomanNumerals::from_roman("MCMXCIX"), 1999, "Rosetta::RomanNumerals::from_roman(MCMXCIX)"

test_run
