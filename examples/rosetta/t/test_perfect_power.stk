#!/usr/bin/env stryke
# Rosetta Code: Perfect power

fn Rosetta::PerfectPower::check($n) {
    if ($n < 4) {
        $n == 1
    } else {
        my $found = 0
        # Try a^b = n for b from 2 up to log2(n)
        my $limit_b = int(log($n) / log(2) + 0.5)
        for my $b (2..$limit_b) {
            my $a = int($n**(1/$b) + 0.5)
            if ($a**$b == $n) {
                $found = 1
                return 1
            }
        }
        $found
    }
}

assert_ok Rosetta::PerfectPower::check(1), "1 is perfect power"
assert_ok Rosetta::PerfectPower::check(4), "4 is perfect power (2^2)"
assert_ok Rosetta::PerfectPower::check(8), "8 is perfect power (2^3)"
assert_ok Rosetta::PerfectPower::check(9), "9 is perfect power (3^2)"
assert_ok Rosetta::PerfectPower::check(32), "32 is perfect power (2^5)"
assert_ok Rosetta::PerfectPower::check(36), "36 is perfect power (6^2)"
assert_ok !Rosetta::PerfectPower::check(6), "6 is not"
assert_ok !Rosetta::PerfectPower::check(10), "10 is not"

36 |> Rosetta::PerfectPower::check |> assert_ok("pipe perfect power")

test_run
