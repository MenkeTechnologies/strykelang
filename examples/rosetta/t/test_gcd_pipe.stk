#!/usr/bin/env stryke
# Rosetta Code: Greatest Common Divisor (using pipes)

fn Rosetta::GCD::compute($a, $b) {
    my $aa = $a; my $bb = $b
    while ($bb != 0) {
        ($aa, $bb) = ($bb, $aa % $bb)
    }
    $aa
}

fn Rosetta::GCD::solve(@nums) {
    @nums |> reduce { Rosetta::GCD::compute(_0, _1) }
}

assert_eq Rosetta::GCD::solve(12, 18), 6, "gcd(12, 18)"
assert_eq Rosetta::GCD::solve(12, 18, 24), 6, "gcd(12, 18, 24)"
assert_eq Rosetta::GCD::solve(7, 13), 1, "gcd(7, 13)"

test_run
