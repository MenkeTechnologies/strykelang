#!/usr/bin/env stryke
# Rosetta Code: Sequence of non-squares

fn non_square($n) {
    int($n + 0.5 + sqrt($n))
}

fn Rosetta::IsSquare::is_square($n) {
    my $root = int(sqrt($n))
    $root * $root == $n
}

assert_eq non_square(1), 2, "a(1)=2"
assert_eq non_square(2), 3, "a(2)=3"
assert_eq non_square(3), 5, "a(3)=5"
assert_eq non_square(4), 6, "a(4)=6"

# Verify non-squares up to 20
for my $i (1..20) {
    my $val = non_square($i)
    assert_ok !Rosetta::IsSquare::is_square($val), "$val is not square"
}

10 |> non_square |> assert_eq(13, "pipe non-square")

test_run
