#!/usr/bin/env stryke
# Rosetta Code: Write language name in 3D ASCII

fn Rosetta::ThreeDName::render($word) {
    my $w = len($word)
    [
        "   " . ("_" x $w),
        "  /" . (" " x $w) . "/|",
        " /" . $word . "/ |",
        "+" . ("-" x $w) . "+ |",
        "| " . $word . " | +",
        "|/" . ("_" x $w) . "|/",
    ]
}

my $art = Rosetta::ThreeDName::render("STRYKE")
my $joined = join("\n", @$art)

assert_eq len(@$art), 6, "six lines of 3D ASCII"
assert_eq $joined =~ /STRYKE/, 1, "language name is visible"
assert_eq $joined =~ /\//, 1, "3D slanted edge present"
assert_eq $joined =~ /\|/, 1, "side wall present"

test_run
