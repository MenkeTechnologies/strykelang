#!/usr/bin/env stryke
# Rosetta Code: Resistor mesh
# Compute the equivalent resistance between two nodes (A, B) of an
# m × n grid where every adjacent pair of nodes is connected by a
# 1-ohm resistor.
#
# Method: solve the Laplacian system L · v = i, where i has +1 at A,
# -1 at B, 0 elsewhere; ground one node by removing its row/column.
# Then R = v[A] - v[B].

fn Rosetta::ResMesh::index($i, $j, $cols) { $i * $cols + $j }

fn Rosetta::ResMesh::laplacian($rows, $cols) {
    my $n = $rows * $cols
    my @L
    for my $i (~> 1:$n) { push @L, [(0) x $n] }
    for my $r (0..$rows - 1) {
        for my $c (0..$cols - 1) {
            my $u = Rosetta::ResMesh::index($r, $c, $cols)
            for my $d ([1, 0], [-1, 0], [0, 1], [0, -1]) {
                my $rr = $r + $d->[0]
                my $cc = $c + $d->[1]
                next if $rr < 0 || $rr >= $rows || $cc < 0 || $cc >= $cols
                my $v = Rosetta::ResMesh::index($rr, $cc, $cols)
                $L[$u][$u] += 1
                $L[$u][$v] -= 1
            }
        }
    }
    \@L
}

fn Rosetta::ResMesh::solve_resistance($rows, $cols, $a_idx, $b_idx) {
    my $n = $rows * $cols
    my $L = Rosetta::ResMesh::laplacian($rows, $cols)
    # Ground node 0: remove row/column 0.
    my @M
    for my $i (1..$n - 1) {
        my @row
        for my $j (1..$n - 1) { push @row, $L->[$i][$j] }
        push @M, \@row
    }
    my @b = (0) x ($n - 1)
    if ($a_idx > 0) { $b[$a_idx - 1] += 1 }
    if ($b_idx > 0) { $b[$b_idx - 1] -= 1 }
    # Augment and Gauss-Jordan
    my $m = $n - 1
    for my $i (0..$m - 1) { push @{$M[$i]}, $b[$i] }
    for my $r (0..$m - 1) {
        my $pivot = $r
        while ($pivot < $m && abs($M[$pivot][$r]) < 1e-12) { $pivot++ }
        return undef if $pivot == $m
        ($M[$r], $M[$pivot]) = ($M[$pivot], $M[$r]) if $pivot != $r
        my $div = $M[$r][$r]
        for my $c ($r..$m) { $M[$r][$c] /= $div }
        for my $i (0..$m - 1) {
            next if $i == $r
            my $f = $M[$i][$r]
            next if abs($f) < 1e-15
            for my $c ($r..$m) { $M[$i][$c] -= $f * $M[$r][$c] }
        }
    }
    my @v = (0)         # node 0 is ground
    for my $i (0..$m - 1) { push @v, $M[$i][$m] }
    $v[$a_idx] - $v[$b_idx]
}

# 2×2 grid: A = (0,0), B = (1,1) — two parallel paths of two 1-ohm
# resistors each → 1Ω + 1Ω in parallel = 0.5Ω + 0.5Ω = 1Ω. Wait,
# two paths in parallel of 2Ω each = 1Ω.
my $r2x2 = Rosetta::ResMesh::solve_resistance(2, 2, 0, 3)
assert_near $r2x2, 1.0, 1e-9, "2×2 corner-to-corner = 1Ω"

# 1×n grid: simple series chain of (n-1) ohms
my $r1x4 = Rosetta::ResMesh::solve_resistance(1, 4, 0, 3)
assert_near $r1x4, 3.0, 1e-9, "1×4 series = 3Ω"
my $r1x10 = Rosetta::ResMesh::solve_resistance(1, 10, 0, 9)
assert_near $r1x10, 9.0, 1e-9, "1×10 series = 9Ω"

# 2×3 grid corner-to-corner
my $r2x3 = Rosetta::ResMesh::solve_resistance(2, 3, 0, 5)
assert_ok abs($r2x3) > 0.5 && abs($r2x3) < 2.5, "2×3 corner resistance reasonable"

# 5×5 grid corner-to-corner — value lives in (1.5, 3) for a square mesh
my $r5x5 = Rosetta::ResMesh::solve_resistance(5, 5, 0, 24)
assert_ok $r5x5 > 1.5 && $r5x5 < 3.0, "5×5 corner-to-corner in expected range"

# Pipe form
2 |> fn { Rosetta::ResMesh::solve_resistance(_, 2, 0, 3) } |> assert_near(1, 1e-9, "pipe 2×2")

test_run
