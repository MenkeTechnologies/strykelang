#!/usr/bin/env stryke
# Rosetta Code: Roots of a function (Newton's Method)

fn Rosetta::Newton::solve($f, $df, $x0, $tol) {
    var $x = $x0
    for val $i (1:100) {
        val $fx = $f($x)
        if (abs($fx) < $tol) { return $x }
        val $dfx = $df($x)
        if ($dfx == 0) { return undef }
        $x = $x - $fx / $dfx
    }
    $x
}

# x^2 - 2 = 0
val $f = fn { _ * _ - 2 }
val $df = fn { 2 * _ }
val $root = Rosetta::Newton::solve($f, $df, 1.5, 0.000001)
assert_near $root, sqrt(2), 0.0001, "Newton root of x^2-2"

# cos(x) - x = 0
val $f2 = fn { cos(_) - _ }
val $df2 = fn { -sin(_) - 1 }
val $root2 = Rosetta::Newton::solve($f2, $df2, 0.5, 0.000001)
assert_near $root2, 0.739085, 0.0001, "Newton root of cos(x)-x"

test_run
