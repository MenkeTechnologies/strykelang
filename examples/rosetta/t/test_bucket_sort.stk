#!/usr/bin/env stryke
# Rosetta Code: Bucket sort

fn Rosetta::BucketSort::solve($arr, $bucket_count) {
    return $arr if len(@$arr) <= 1
    
    var $min = $arr->[0]
    var $max = $arr->[0]
    for val $x (@$arr) {
        $min = $x if $x < $min
        $max = $x if $x > $max
    }
    
    if ($min == $max) { return $arr }
    
    val $buckets = [ ~> 1:$bucket_count map { [] } ]
    val $range = $max - $min
    
    for val $x (@$arr) {
        val $idx = int(($x - $min) / $range * ($bucket_count - 1))
        push @{$buckets->[$idx]}, $x
    }
    
    var @res
    for val $b (@$buckets) {
        # Sort each bucket (using built-in sort)
        val @sorted_b = sort { _0 <=> _1 } @$b
        push @res, @sorted_b
    }
    \@res
}

val @data = (0.42, 0.32, 0.33, 0.52, 0.37, 0.47, 0.51)
val $sorted = Rosetta::BucketSort::solve(\@data, 5)
assert_eq join(",", @$sorted), "0.32,0.33,0.37,0.42,0.47,0.51,0.52", "bucket sort floats"

val @data2 = (5, 3, 8, 1, 2, 7, 4, 6)
val $sorted2 = Rosetta::BucketSort::solve(\@data2, 3)
assert_eq join(",", @$sorted2), "1,2,3,4,5,6,7,8", "bucket sort ints"

test_run
