#!/usr/bin/env stryke
# Rosetta Code: Primorial numbers

fn Rosetta::IsPrime::is_prime($n) {
    if ($n < 2) {
        0
    } elsif ($n == 2) {
        1
    } elsif ($n % 2 == 0) {
        0
    } else {
        var $i = 3
        val $limit = sqrt($n)
        var $res = 1
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

# Pn = product of the FIRST n primes (Rosetta's convention), distinct from
# stryke's built-in `primorial(n) = product of all primes ≤ n`. Lives under
# `Rosetta::Primorial::pn` to avoid the builtin shadow.
fn Rosetta::Primorial::pn($n) {
    if ($n == 0) {
        1
    } else {
        var @primes
        var $p = 2
        while (len(@primes) < $n) {
            if (Rosetta::IsPrime::is_prime($p)) {
                push @primes, $p
            }
            $p++
        }
        @primes |> reduce { _0 * _1 }
    }
}

assert_eq Rosetta::Primorial::pn(0), 1, "P0"
assert_eq Rosetta::Primorial::pn(1), 2, "P1"
assert_eq Rosetta::Primorial::pn(2), 6, "P2 (2*3)"
assert_eq Rosetta::Primorial::pn(3), 30, "P3 (2*3*5)"
assert_eq Rosetta::Primorial::pn(5), 2310, "P5"

5 |> Rosetta::Primorial::pn |> assert_eq(2310, "pipe Rosetta::Primorial::pn")

test_run
