#!/usr/bin/env stryke
# Rosetta Code: Execute Brainfuck

fn Rosetta::Brainfuck::execute($code) {
    val @chars = split "", $code
    var %jumps
    var @stack

    # Precompute jumps
    for (var $i = 0; $i < len(@chars); $i++) {
        if ($chars[$i] eq "[") {
            push @stack, $i
        } elsif ($chars[$i] eq "]") {
            val $start = pop @stack
            $jumps{$start} = $i
            $jumps{$i} = $start
        }
    }

    var @tape
    for (var $i = 0; $i < 30000; $i++) {
        push @tape, 0
    }

    var $ptr = 0
    var $pc = 0
    var $output = ""

    while ($pc < len(@chars)) {
        val $c = $chars[$pc]

        if ($c eq ">") {
            $ptr++
        } elsif ($c eq "<") {
            $ptr--
        } elsif ($c eq "+") {
            $tape[$ptr] = ($tape[$ptr] + 1) % 256
        } elsif ($c eq "-") {
            $tape[$ptr] = ($tape[$ptr] - 1) % 256
            if ($tape[$ptr] < 0) {
                $tape[$ptr] += 256
            }
        } elsif ($c eq ".") {
            $output .= chr($tape[$ptr])
        } elsif ($c eq ",") {
            # Input not implemented
        } elsif ($c eq "[") {
            if ($tape[$ptr] == 0) {
                $pc = $jumps{$pc}
            }
        } elsif ($c eq "]") {
            if ($tape[$ptr] != 0) {
                $pc = $jumps{$pc}
            }
        }
        $pc++
    }
    $output
}

# Test 1: Simple Hello World
val $hw_code = "++++++++[>++++[>++>+++>+++>+<<<<-]>+>+>->>+[<]<-]>>.>---.+++++++..+++.>>.<-.<.+++.------.--------.>>+.>++."
assert_eq Rosetta::Brainfuck::execute($hw_code), "Hello World!\n", "Brainfuck: Hello World"

# Test 2: Simple arithmetic and output
assert_eq Rosetta::Brainfuck::execute("+++++ ."), chr(5), "Brainfuck: Simple Increment"

# Test 3: Nested loops (Multiplication: 3 * 7 = 21)
assert_eq Rosetta::Brainfuck::execute("+++ [ > +++++++ < - ] > ."), chr(21), "Brainfuck: Multiplication"

# Test 4: Cell wrapping (0 - 1 = 255)
assert_eq Rosetta::Brainfuck::execute("- ."), chr(255), "Brainfuck: Underflow Wrap"

# Test 5: Complex Nested Loops (Print 'A')
assert_eq Rosetta::Brainfuck::execute("++++++ [ > ++++++++++ < - ] > +++++ ."), "A", "Brainfuck: Nested Loop 'A'"

test_run
