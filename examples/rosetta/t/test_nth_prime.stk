#!/usr/bin/env stryke
# Rosetta Code: Nth prime

fn Rosetta::NthPrime::solve($n) {
    my $count = 0
    my $candidate = 1
    while ($count < $n) {
        $candidate++
        if (is_prime($candidate)) {
            $count++
        }
    }
    $candidate
}

assert_eq Rosetta::NthPrime::solve(1), 2, "1st prime"
assert_eq Rosetta::NthPrime::solve(2), 3, "2nd prime"
assert_eq Rosetta::NthPrime::solve(5), 11, "5th prime"
assert_eq Rosetta::NthPrime::solve(10), 29, "10th prime"

10 |> Rosetta::NthPrime::solve |> assert_eq(29, "pipe 10th prime")

test_run
