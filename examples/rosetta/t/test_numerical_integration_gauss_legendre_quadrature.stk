#!/usr/bin/env stryke
# Rosetta Code: Numerical integration/Gauss-Legendre Quadrature

fn Rosetta::GaussLegendre::nodes_weights($n) {
    my $pi = 3.141592653589793
    my $eps = 1e-14
    my @nodes
    my @weights
    my $m = int(($n + 1) / 2)

    for my $i (1 .. $m) {
        my $z = cos($pi * ($i - 0.25) / ($n + 0.5))
        my $pp = 0.0
        for my $iter (1 .. 20) {
            my $p1 = 1.0
            my $p2 = 0.0
            for my $j (1 .. $n) {
                my $p3 = $p2
                $p2 = $p1
                $p1 = ((2 * $j - 1) * $z * $p2 - ($j - 1) * $p3) / $j
            }
            $pp = $n * ($z * $p1 - $p2) / ($z * $z - 1)
            my $z1 = $z
            $z = $z1 - $p1 / $pp
            last if abs($z - $z1) < $eps
        }
        my $w = 2 / ((1 - $z * $z) * $pp * $pp)
        $nodes[$i - 1] = -$z
        $nodes[$n - $i] = $z
        $weights[$i - 1] = $w
        $weights[$n - $i] = $w
    }

    (\@nodes, \@weights)
}

fn Rosetta::GaussLegendre::integrate($f, $a, $b, $n) {
    my ($nodes, $weights) = Rosetta::GaussLegendre::nodes_weights($n)
    my $half = ($b - $a) / 2
    my $mid = ($a + $b) / 2
    my $sum = 0.0
    for my $i (0 .. $n - 1) {
        $sum += $weights->[$i] * $f->($half * $nodes->[$i] + $mid)
    }
    $half * $sum
}

my ($nodes, $weights) = Rosetta::GaussLegendre::nodes_weights(5)
my $sum_w = 0.0
for my $w (@$weights) { $sum_w += $w }
my $ans = Rosetta::GaussLegendre::integrate(fn ($x) { exp($x) }, -3, 3, 5)

assert_ok abs($nodes->[0] + $nodes->[4]) < 1e-12, "nodes are symmetric"
assert_ok abs($nodes->[2]) < 1e-12, "middle node is zero"
assert_ok abs($sum_w - 2.0) < 1e-12, "weights sum to 2"
assert_ok abs($ans - 20.0355777184) < 1e-6, "5-point quadrature on exp(x) over [-3,3]"

test_run
