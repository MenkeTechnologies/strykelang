#!/usr/bin/env stryke
# Rosetta Code: Betrothed Numbers

fn Rosetta::BetrothedNumbers::sum_divisors($n) {
    if ($n < 2) { return 0 }
    var $sum = 0
    val $limit = int($n / 2)
    for val $i (1:$limit) {
        if ($n % $i == 0) {
            $sum = $sum + $i
        }
    }
    $sum
}

fn Rosetta::BetrothedNumbers::solve($limit) {
    var @res
    for val $a (1:$limit) {
        val $s = Rosetta::BetrothedNumbers::sum_divisors($a)
        if ($s > 1) {
            val $b = $s - 1
            if ($b > $a) {
                if (Rosetta::BetrothedNumbers::sum_divisors($b) == $a + 1) {
                    push @res, [$a, $b]
                }
            }
        }
    }
    \@res
}

val $pairs = Rosetta::BetrothedNumbers::solve(1000)
# First pair is (48, 75)
assert_eq $pairs->[0]->[0], 48, "first betrothed a"
assert_eq $pairs->[0]->[1], 75, "first betrothed b"

# Second pair is (140, 195)
assert_eq $pairs->[1]->[0], 140, "second betrothed a"
assert_eq $pairs->[1]->[1], 195, "second betrothed b"

test_run
