#!/usr/bin/env stryke
# Rosetta Code: Powerful numbers

fn Rosetta::PowerfulNumbers::check($n) {
    if ($n == 1) {
        1
    } else {
        my @factors = prime_factors($n)
        my %unique_factors
        for my $f (@factors) { $unique_factors{$f} = 1 }
        
        my $all_sq = 1
        for my $p (keys %unique_factors) {
            if ($n % ($p * $p) != 0) {
                $all_sq = 0
            }
        }
        $all_sq
    }
}

assert_ok Rosetta::PowerfulNumbers::check(1), "1 is powerful"
assert_ok Rosetta::PowerfulNumbers::check(4), "4 is powerful (2^2)"
assert_ok Rosetta::PowerfulNumbers::check(8), "8 is powerful (2^3, 2^2 is factor)"
assert_ok Rosetta::PowerfulNumbers::check(9), "9 is powerful (3^2)"
assert_ok Rosetta::PowerfulNumbers::check(72), "72 is powerful (2^3 * 3^2, 4 and 9 are factors)"
assert_ok !Rosetta::PowerfulNumbers::check(12), "12 is not (2^2 * 3, but 3^2 is not factor)"

72 |> Rosetta::PowerfulNumbers::check |> assert_ok("pipe powerful")

test_run
