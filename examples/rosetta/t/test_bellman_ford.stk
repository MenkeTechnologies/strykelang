#!/usr/bin/env stryke
# Rosetta Code: Bellman-Ford algorithm

fn Rosetta::BellmanFord::solve($nodes, $edges, $source) {
    var %distance
    var %predecessor
    for val $n (@$nodes) {
        $distance{"$n"} = 1e9
        $predecessor{"$n"} = undef
    }
    $distance{"$source"} = 0
    
    val $count = len(@$nodes)
    for (1:$count-1) {
        for val $edge (@$edges) {
            var ($u, $v, $w) = @$edge
            if ($distance{"$u"} != 1e9 && $distance{"$u"} + $w < $distance{"$v"}) {
                $distance{"$v"} = $distance{"$u"} + $w
                $predecessor{"$v"} = "$u"
            }
        }
    }
    
    # Check for negative cycles
    for val $edge (@$edges) {
        val ($u, $v, $w) = @$edge
        if ($distance{"$u"} != 1e9 && $distance{"$u"} + $w < $distance{"$v"}) {
            return undef
        }
    }
    
    \%distance
}

val @nodes = (1, 2, 3, 4, 5)
val @edges = (
    [1, 2, 10], [1, 3, 3], [2, 3, 1], [2, 4, 2],
    [3, 2, 4], [3, 4, 8], [3, 5, 2], [4, 5, 7], [5, 4, 9]
)

val $dist = Rosetta::BellmanFord::solve(\@nodes, \@edges, 1)

assert_eq $dist->{1}, 0, "dist 1"
assert_eq $dist->{2}, 7, "dist 2"
assert_eq $dist->{3}, 3, "dist 3"
assert_eq $dist->{4}, 9, "dist 4"
assert_eq $dist->{5}, 5, "dist 5"

# Negative cycle test
val @edges2 = ([1, 2, 1], [2, 3, 1], [3, 1, -3])
val $res2 = Rosetta::BellmanFord::solve([1, 2, 3], \@edges2, 1)
assert_eq $res2, undef, "negative cycle detected"

test_run
