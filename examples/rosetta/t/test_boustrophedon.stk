#!/usr/bin/env stryke
# Rosetta Code: Boustrophedon transform

fn Rosetta::Boustrophedon::transform($arr_ref) {
    val @arr = @$arr_ref
    val $n = len(@arr)
    if ($n == 0) { return ([]) }
    
    var @res = ($arr[0])
    var @prev_row = ($arr[0])
    
    for val $i (1:$n-1) {
        var @curr_row = ()
        if ($i % 2 == 1) {
            # left to right
            $curr_row[0] = $arr[$i]
            for val $j (1:$i) {
                $curr_row[$j] = $curr_row[$j-1] + $prev_row[$j-1]
            }
        } else {
            # right to left
            $curr_row[$i] = $arr[$i]
            for val $j (~> (0:$i-1) rev) {
                $curr_row[$j] = $curr_row[$j+1] + $prev_row[$j]
            }
        }
        @prev_row = @curr_row
        push @res, ($i % 2 == 1 ? $curr_row[$i] : $curr_row[0])
    }
    \@res
}

# e.g. for (1, 0, 0, 0, ...) it should give Euler numbers (1, 1, 1, 2, 5, 16, 61, ...)
val $res = Rosetta::Boustrophedon::transform([1, 0, 0, 0, 0, 0])
assert_eq join(",", @$res), "1,1,1,2,5,16", "Euler numbers via Boustrophedon"

test_run
