#!/usr/bin/env stryke
# Rosetta Code: Rot-13

fn Rosetta::Rot13::rot13($s) {
    ~> $s >{split //, _} map {
        _ =~ /[A-Ma-m]/ ? chr(ord(_) + 13)
      : _ =~ /[N-Zn-z]/ ? chr(ord(_) - 13)
      : _
    } |> join ""
}

assert_eq Rosetta::Rot13::rot13("Hello"), "Uryyb", "rot13 Hello"
assert_eq Rosetta::Rot13::rot13("Uryyb"), "Hello", "rot13 Uryyb"
assert_eq Rosetta::Rot13::rot13("The Quick Brown Fox"), "Gur Dhvpx Oebja Sbk", "rot13 sentence"
assert_eq Rosetta::Rot13::rot13("ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"), "NOPQRSTUVWXYZABCDEFGHIJKLMnopqrstuvwxyzabcdefghijklm", "full alphabet"

assert_eq Rosetta::Rot13::rot13("123!@#"), "123!@#", "non-alpha unchanged"
assert_eq Rosetta::Rot13::rot13(""), "", "empty string"

my $original = "Why did the chicken cross the road?"
assert_eq Rosetta::Rot13::rot13(Rosetta::Rot13::rot13($original)), $original, "rot13 is self-inverse"

test_run
