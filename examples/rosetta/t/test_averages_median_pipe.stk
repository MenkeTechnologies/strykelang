#!/usr/bin/env stryke
# Rosetta Code: Averages/Median (using pipes)

fn Rosetta::Average::median(@arr) {
    my $len = len(@arr)
    if ($len == 0) { return undef }
    my @sorted = sort { _0 <=> _1 } @arr
    if ($len % 2 == 1) {
        return $sorted[$len / 2]
    } else {
        return ($sorted[$len / 2 - 1] + $sorted[$len / 2]) / 2
    }
}

my @odd = (4.1, 5.6, 7.2, 1.7, 9.3, 4.4, 3.2)
# Sorted: 1.7, 3.2, 4.1, 4.4, 5.6, 7.2, 9.3
# Median: 4.4
assert_eq Rosetta::Average::median(@odd), 4.4, "median of odd number of elements"

my @even = (4.1, 5.6, 7.2, 1.7, 9.3, 4.4, 3.2, 5.0)
# Sorted: 1.7, 3.2, 4.1, 4.4, 5.0, 5.6, 7.2, 9.3
# Median: (4.4 + 5.0) / 2 = 4.7
assert_eq Rosetta::Average::median(@even), 4.7, "median of even number of elements"

test_run
