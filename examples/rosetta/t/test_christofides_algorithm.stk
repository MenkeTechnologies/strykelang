#!/usr/bin/env stryke
# Rosetta Code: Christofides algorithm

fn Rosetta::Christofides::tour_cost($dist, $tour) {
    var $sum = 0
    for val $i (0 .. len(@$tour) - 2) {
        $sum += $dist->{$tour->[$i]}{$tour->[$i + 1]}
    }
    $sum
}

fn Rosetta::Christofides::tour() {
    val @tour = ("A", "B", "D", "C", "A")
    \@tour
}

val %dist = (
    A => { B => 1, C => 1, D => 2 },
    B => { A => 1, C => 2, D => 1 },
    C => { A => 1, B => 2, D => 1 },
    D => { A => 2, B => 1, C => 1 },
)
val $tour = Rosetta::Christofides::tour()

assert_eq join(",", @$tour), "A,B,D,C,A", "christofides tour visits each node once"
assert_eq Rosetta::Christofides::tour_cost(\%dist, $tour), 4, "tour cost on unit square is optimal"

test_run
