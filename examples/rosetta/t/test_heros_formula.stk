#!/usr/bin/env stryke
# Rosetta Code: Hero's formula

fn Rosetta::Hero::area($a, $b, $c) {
    my $s = ($a + $b + $c) / 2.0
    sqrt($s * ($s - $a) * ($s - $b) * ($s - $c))
}

assert_eq Rosetta::Hero::area(3, 4, 5), 6, "Area of 3-4-5 triangle"
assert_ok abs(Rosetta::Hero::area(7, 8, 9) - 26.8328) < 0.001, "Area of 7-8-9 triangle"

test_run
