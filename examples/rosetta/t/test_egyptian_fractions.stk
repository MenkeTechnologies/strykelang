#!/usr/bin/env stryke
# Rosetta Code: Egyptian Fractions

fn egyptian {
    my $n = $_[0]
    my $d = $_[1]
    my @res = ()
    while ($n != 0) {
        my $x = int(($d + $n - 1) / $n)
        push @res, $x
        $n = $x * $n - $d
        $d = $d * $x
        # Simplify n/d if possible to avoid large numbers?
        # For simplicity in this example we just continue
    }
    \@res
}

# 43/48 = 1/2 + 1/3 + 1/16
my $f1 = egyptian(43, 48)
assert_eq join(",", @$f1), "2,3,16", "43/48"

# 5/121 = 1/25 + 1/757 + 1/763309 + ...
# Greedy algorithm results
my $f2 = egyptian(5, 121)
assert_eq $f2->[0], 25, "5/121 first term"

test_run
