#!/usr/bin/env stryke
# Rosetta Code: Averages/Pythagorean means

fn Rosetta::PythagoreanMeans::arithmetic(@nums) {
    my $sum = 0
    my $count = scalar(@nums)
    if ($count == 0) { return 0 }
    for my $x (@nums) { $sum += $x }
    $sum / $count
}

fn Rosetta::PythagoreanMeans::geometric(@nums) {
    my $count = scalar(@nums)
    if ($count == 0) { return 0 }
    my $prod = 1
    for my $x (@nums) { $prod *= $x }
    $prod ** (1 / $count)
}

fn Rosetta::PythagoreanMeans::harmonic(@nums) {
    my $count = scalar(@nums)
    if ($count == 0) { return 0 }
    my $sum_inv = 0
    for my $x (@nums) { $sum_inv += 1 / $x }
    $count / $sum_inv
}

my @data = (1..10)
my $am = Rosetta::PythagoreanMeans::arithmetic(@data)
my $gm = Rosetta::PythagoreanMeans::geometric(@data)
my $hm = Rosetta::PythagoreanMeans::harmonic(@data)

assert_near $am, 5.5, 0.0001, "Arithmetic mean of 1..10"
assert_near $gm, 4.5287, 0.0001, "Geometric mean of 1..10"
assert_near $hm, 3.4141, 0.0001, "Harmonic mean of 1..10"

assert_ok $am >= $gm, "AM >= GM"
assert_ok $gm >= $hm, "GM >= HM"

test_run
