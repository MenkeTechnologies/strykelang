#!/usr/bin/env stryke
# Rosetta Code: Chaocipher

fn Rosetta::Chaocipher::permute_left($alpha, $char) {
    var @a = split("", $alpha)
    while ($a[0] ne $char) {
        push @a, shift @a
    }
    val $c = splice(@a, 1, 1)
    splice(@a, 13, 0, $c)
    join("", @a)
}

fn Rosetta::Chaocipher::permute_right($alpha, $char) {
    var @a = split("", $alpha)
    while ($a[0] ne $char) {
        push @a, shift @a
    }
    push @a, shift @a
    val $c = splice(@a, 2, 1)
    splice(@a, 13, 0, $c)
    join("", @a)
}

fn Rosetta::Chaocipher::encrypt($plain, $left, $right) {
    var $l = $left
    var $r = $right
    var $cipher = ""
    
    for val $p (split("", $plain)) {
        val $idx = index($r, $p)
        val $c = substr($l, $idx, 1)
        $cipher .= $c
        
        $l = Rosetta::Chaocipher::permute_left($l, $c)
        $r = Rosetta::Chaocipher::permute_right($r, $p)
    }
    $cipher
}

val $l_init = "HXUCZVAMDSLKPEFJRIGTWOBNYQ"
val $r_init = "PTLNBQDEOYSFAVZKGJRIHWXUMC"
val $plain = "WELLDONEISBETTERTHANWELLSAID"

val $cipher = Rosetta::Chaocipher::encrypt($plain, $l_init, $r_init)
p "Chaocipher: $cipher"

assert_eq $cipher, "OAHQHCNYNXTSZJRRHJBYHQKSOUJY", "Chaocipher encryption matches RC example"

test_run
