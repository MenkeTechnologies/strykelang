#!/usr/bin/env stryke
# Rosetta Code: Power iteration

fn Rosetta::PowerIteration::dot_product($v1, $v2) {
    var $sum = 0
    for (var $i = 0; $i < len(@$v1); $i++) {
        $sum += $v1->[$i] * $v2->[$i]
    }
    $sum
}

fn Rosetta::PowerIteration::matrix_vector_mul($m, $v) {
    var @res
    for (var $i = 0; $i < len(@$m); $i++) {
        push @res, Rosetta::PowerIteration::dot_product($m->[$i], $v)
    }
    \@res
}

fn Rosetta::PowerIteration::normalize($v) {
    val $norm = sqrt(Rosetta::PowerIteration::dot_product($v, $v))
    val @res = ~> @$v map { _ / $norm }
    \@res
}

fn Rosetta::PowerIteration::solve($matrix, $num_simulations) {
    val $n = len(@$matrix)
    # Start with a random vector (or all 1s for simplicity)
    val @v = map { 1.0 } 1:$n
    var $vec = Rosetta::PowerIteration::normalize(\@v)
    
    for (1:$num_simulations) {
        $vec = Rosetta::PowerIteration::matrix_vector_mul($matrix, $vec)
        $vec = Rosetta::PowerIteration::normalize($vec)
    }
    
    # Rayleigh quotient for eigenvalue: (v^T M v) / (v^T v)
    val $Mv = Rosetta::PowerIteration::matrix_vector_mul($matrix, $vec)
    val $eigenvalue = Rosetta::PowerIteration::dot_product($vec, $Mv) / Rosetta::PowerIteration::dot_product($vec, $vec)
    
    ($eigenvalue, $vec)
}

val $M = [
    [2, -1,  0],
    [-1,  2, -1],
    [0, -1,  2]
]

val ($eigenval, $eigenvec) = Rosetta::PowerIteration::solve($M, 100)
# Eigenvalues of this 3x3 matrix are 2 - sqrt(2), 2, 2 + sqrt(2)
# The dominant eigenvalue is 2 + sqrt(2) approx 3.41421356

assert_ok abs($eigenval - 3.4142) < 0.01, "Dominant eigenvalue of matrix is approx 3.414"

test_run
