#!/usr/bin/env stryke
# Rosetta Code: Circular primes

fn Rosetta::CircularPrimes::is_prime_custom($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        my $limit = sqrt($n)
        my $res = 1
        for my $i (1..int($limit)) {
            my $v = $i * 2 + 1
            if ($v > $limit) { next }
            if ($n % $v == 0) {
                $res = 0
                return 0
            }
        }
        $res
    }
}

fn Rosetta::CircularPrimes::rotate($s) {
    my $first = substr($s, 0, 1)
    my $rest = substr($s, 1)
    $rest . $first
}

fn Rosetta::CircularPrimes::check($n) {
    my $s = "$n"
    my $len = length($s)
    my $all_prime = 1
    for my $i (1..$len) {
        # Using the builtin is_prime for speed, or the custom one if requested
        if (!is_prime(int($s))) {
            $all_prime = 0
            return 0
        }
        $s = Rosetta::CircularPrimes::rotate($s)
    }
    $all_prime
}

assert_ok Rosetta::CircularPrimes::check(2), "2 is circular prime"
assert_ok Rosetta::CircularPrimes::check(197), "197 is circular prime"
assert_ok Rosetta::CircularPrimes::check(1193), "1193 is circular prime"
assert_ok !Rosetta::CircularPrimes::check(19), "19 is not circular (91 is not prime)"

197 |> Rosetta::CircularPrimes::check |> assert_ok("pipe circular prime")

test_run
