#!/usr/bin/env stryke
# Rosetta Code: Leibniz pi formula — pi/4 = 1 - 1/3 + 1/5 - 1/7 + ...

fn Rosetta::Leibniz::pi($n) {
    var $sum = 0.0
    var $sign = 1.0
    for val $k (0:$n - 1) {
        $sum += $sign / (2 * $k + 1)
        $sign = -$sign
    }
    4 * $sum
}

val $real_pi = 4 * atan2(1, 1)

# Slow convergence: 1000 terms gives ~3 digits
val $pi1k = Rosetta::Leibniz::pi(1000)
assert_ok abs($pi1k - $real_pi) < 1e-2, "1000 terms within 1e-2 ($pi1k)"

# 100k terms ~5 digits
val $pi100k = Rosetta::Leibniz::pi(100000)
assert_ok abs($pi100k - $real_pi) < 1e-4, "100k terms within 1e-4 ($pi100k)"

# 1 term: 4
assert_eq Rosetta::Leibniz::pi(1), 4, "1 term -> 4"

# 2 terms: 4 - 4/3 ~ 2.667
val $two = Rosetta::Leibniz::pi(2)
assert_ok abs($two - (4 - 4.0/3)) < 1e-12, "2 terms = 4 - 4/3"

# Alternating: each step crosses pi (once we have at least a few terms)
val $a = Rosetta::Leibniz::pi(50)
val $b = Rosetta::Leibniz::pi(51)
assert_ok(($a > $real_pi) != ($b > $real_pi), "successive partial sums alternate around pi")

# 0 terms -> 0
assert_eq Rosetta::Leibniz::pi(0), 0, "0 terms -> 0"

# More terms always closer (eventually)
val $err_a = abs(Rosetta::Leibniz::pi(100) - $real_pi)
val $err_b = abs(Rosetta::Leibniz::pi(1000) - $real_pi)
assert_ok $err_b < $err_a, "more terms -> smaller error"

test_run
