#!/usr/bin/env stryke
# Rosetta Code: Narcissist

fn Rosetta::Narcissist::check($input) {
    # In a real RC Narcissist, the program source is compared.
    # For this test, we'll mock the source.
    val $source = slurp($0)
    
    if ($input eq $source) {
        return "Accept"
    } else {
        return "Reject"
    }
}

# Setup: this file IS the source.
val $src = slurp($0)
val $res1 = Rosetta::Narcissist::check($src)
assert_eq $res1, "Accept", "Input matching source is accepted"

val $res2 = Rosetta::Narcissist::check("not the source")
assert_eq $res2, "Reject", "Different input is rejected"

test_run
