#!/usr/bin/env stryke
# Rosetta Code: System time

fn Rosetta::Time::now() {
    time()
}

fn Rosetta::Time::strftime($ts, $fmt) {
    datetime_strftime($ts, $fmt)
}

my $now = Rosetta::Time::now()
$now |> assert_ok("Time is a positive integer")

$now |> Rosetta::Time::strftime("%Y") |> assert_eq("2026", "Year is 2026")

test_run
