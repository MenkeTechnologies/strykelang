#!/usr/bin/env stryke
# Rosetta Code: Rule 110

fn Rosetta::Rule110::next_gen($state) {
    my $len = length($state)
    my $padded = "0" . $state . "0"
    my @chars = chars($padded)
    
    my $next_state = ~> 1..$len map {
        my $i = $_
        my $pattern = $chars[$i-1] . $chars[$i] . $chars[$i+1]
        
        # Rule 110:
        # 111 -> 0, 110 -> 1, 101 -> 1, 100 -> 0
        # 011 -> 1, 010 -> 1, 001 -> 1, 000 -> 0
        if ($pattern eq "111" || $pattern eq "100" || $pattern eq "000") {
            "0"
        } else {
            "1"
        }
    } |> join("")
    
    $next_state
}

my $initial = "000000000000001"
my $gen1 = Rosetta::Rule110::next_gen($initial)
my $gen2 = Rosetta::Rule110::next_gen($gen1)

assert_eq $gen1, "000000000000011", "gen 1"
assert_eq $gen2, "000000000000111", "gen 2"

test_run
