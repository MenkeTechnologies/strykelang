#!/usr/bin/env stryke
# Rosetta Code: Main step of GOST 28147-89

fn Rosetta::GOST::sbox() {
    [
        [4, 10, 9, 2, 13, 8, 0, 14, 6, 11, 1, 12, 7, 15, 5, 3],
        [14, 11, 4, 12, 6, 13, 15, 10, 2, 3, 8, 1, 0, 7, 5, 9],
        [5, 8, 1, 13, 10, 3, 4, 2, 14, 15, 12, 7, 6, 0, 9, 11],
        [7, 13, 10, 1, 0, 8, 9, 15, 14, 4, 6, 12, 11, 2, 5, 3],
        [6, 12, 7, 1, 5, 15, 13, 8, 4, 10, 9, 14, 0, 3, 11, 2],
        [4, 11, 10, 0, 7, 2, 1, 13, 3, 6, 8, 5, 9, 12, 15, 14],
        [13, 11, 4, 1, 3, 15, 5, 9, 0, 10, 14, 7, 6, 8, 2, 12],
        [1, 15, 13, 0, 5, 7, 10, 4, 9, 2, 3, 14, 6, 11, 8, 12],
    ]
}

fn Rosetta::GOST::rotl32($x, $bits) {
    (($x << $bits) | (($x & 0xFFFFFFFF) >> (32 - $bits))) & 0xFFFFFFFF
}

fn Rosetta::GOST::main_step($left, $right, $key, $sbox) {
    my $sum = ($left + $key) & 0xFFFFFFFF
    my $sub = 0
    for my $i (0 .. 7) {
        my $nibble = ($sum >> ($i * 4)) & 0xF
        $sub |= $sbox->[$i][$nibble] << ($i * 4)
    }
    my $mixed = Rosetta::GOST::rotl32($sub, 11) ^ $right
    [$mixed & 0xFFFFFFFF, $left & 0xFFFFFFFF]
}

my $sbox = Rosetta::GOST::sbox()
my $res = Rosetta::GOST::main_step(0x043B0421, 0x04320430, 0xE2C104F9, $sbox)

assert_eq sprintf("%08X", $res->[0]), "07CF881F", "new left matches reference"
assert_eq sprintf("%08X", $res->[1]), "043B0421", "new right is previous left"

test_run
