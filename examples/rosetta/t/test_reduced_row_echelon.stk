#!/usr/bin/env stryke
# Rosetta Code: Reduced row echelon form (RREF)
# Gauss-Jordan elimination on a matrix of floats. Each row is an
# arrayref; matrix is an arrayref of rows.

fn Rosetta::Rref::compute($m_in) {
    my @m
    for my $r (@$m_in) { push @m, [@$r] }
    my $rows = len(@m)
    return [] if $rows == 0
    my $cols = len(@{$m[0]})
    my $lead = 0
    for my $r (0..$rows - 1) {
        return \@m if $lead >= $cols
        my $i = $r
        while ($i < $rows && abs($m[$i][$lead]) < 1e-12) { $i++ }
        if ($i == $rows) {
            $lead++
            $r--
            next
        }
        ($m[$i], $m[$r]) = ($m[$r], $m[$i])
        my $pivot = $m[$r][$lead]
        for my $c (0..$cols - 1) { $m[$r][$c] /= $pivot }
        for my $j (0..$rows - 1) {
            next if $j == $r
            my $factor = $m[$j][$lead]
            for my $c (0..$cols - 1) {
                $m[$j][$c] -= $factor * $m[$r][$c]
            }
        }
        $lead++
    }
    \@m
}

fn Rosetta::Rref::near_eq($a, $b) {
    return 0 if len(@$a) != len(@$b)
    for my $i (0..len(@$a) - 1) {
        return 0 if len(@{$a->[$i]}) != len(@{$b->[$i]})
        for my $j (0..len(@{$a->[$i]}) - 1) {
            return 0 if abs($a->[$i][$j] - $b->[$i][$j]) > 1e-9
        }
    }
    1
}

# Rosetta canonical 3×4 example
my $m1 = [
    [1, 2, -1, -4],
    [2, 3, -1, -11],
    [-2, 0, -3, 22],
]
my $r1 = Rosetta::Rref::compute($m1)
my $exp1 = [
    [1, 0, 0, -8],
    [0, 1, 0,  1],
    [0, 0, 1, -2],
]
assert_eq Rosetta::Rref::near_eq($r1, $exp1), 1, "rosetta canonical 3×4 → diag"

# 2×3 underdetermined
my $m2 = [
    [1, 2, 3],
    [2, 4, 6],
]
my $r2 = Rosetta::Rref::compute($m2)
# Expected: [[1, 2, 3], [0, 0, 0]]
assert_near $r2->[0][0], 1, 1e-9, "first row leading 1"
assert_near $r2->[1][0], 0, 1e-9, "second row zeroed"
assert_near $r2->[1][1], 0, 1e-9, "second row col 1"
assert_near $r2->[1][2], 0, 1e-9, "second row col 2"

# Identity matrix is its own RREF
my $id = [[1, 0, 0], [0, 1, 0], [0, 0, 1]]
my $rid = Rosetta::Rref::compute($id)
assert_eq Rosetta::Rref::near_eq($rid, $id), 1, "identity is RREF"

# Permutation needed
my $m3 = [[0, 1, 2], [1, 0, 3]]
my $r3 = Rosetta::Rref::compute($m3)
# Expected: [[1, 0, 3], [0, 1, 2]]
assert_near $r3->[0][0], 1, 1e-9, "swap row 0 col 0"
assert_near $r3->[1][1], 1, 1e-9, "swap row 1 col 1"

# Pipe form
$m1 |> Rosetta::Rref::compute |> fn { $_->[0][3] } |> assert_near(-8, 1e-9, "pipe rref result")

test_run
