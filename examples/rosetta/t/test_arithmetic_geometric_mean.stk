#!/usr/bin/env stryke
# Rosetta Code: Arithmetic-geometric mean

fn Rosetta::AGM::compute($a, $g) {
    for my $i (1..10) {
        my $next_a = ($a + $g) / 2
        my $next_g = sqrt($a * $g)
        $a = $next_a
        $g = $next_g
    }
    $a
}

my $res = Rosetta::AGM::compute(1, 1 / sqrt(2))
assert_near $res, 0.847213, 0.0001, "AGM(1, 1/sqrt(2))"

# Pipe
1 |> Rosetta::AGM::compute(0.707106) |> assert_near(0.847213, 0.0001, "pipe AGM")

test_run
