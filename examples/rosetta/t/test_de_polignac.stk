#!/usr/bin/env stryke
# Rosetta Code: De Polignac numbers
# Odd k such that k - 2^n is composite for every n >= 0 with 2^n < k.

fn Rosetta::DePolignac::is_prime($n) {
    return 0 if $n < 2
    return 1 if $n == 2
    return 0 if $n % 2 == 0
    my $i = 3
    while ($i * $i <= $n) {
        return 0 if $n % $i == 0
        $i += 2
    }
    1
}

fn Rosetta::DePolignac::is_de_polignac($k) {
    return 1 if $k == 1   # special: no n yields k - 2^n prime
    return 0 if $k % 2 == 0 || $k < 1
    my $p = 1
    while ($p < $k) {
        return 0 if Rosetta::DePolignac::is_prime($k - $p)
        $p *= 2
    }
    1
}

fn Rosetta::DePolignac::first_n($count) {
    my @res = (1)   # 1 is the conventional first element
    my $k = 3
    while (len(@res) < $count) {
        push @res, $k if Rosetta::DePolignac::is_de_polignac($k)
        $k += 2
    }
    @res
}

# OEIS A006285: 1,127,149,251,331,337,373,509,599,701,757,809,...
# (1 is included by convention as no n yields 1-2^n=prime; technically 1 is a special start)
my @first10 = Rosetta::DePolignac::first_n(10)
assert_eq join(",", @first10),
    "1,127,149,251,331,337,373,509,599,701",
    "first 10 De Polignac"

assert_ok  Rosetta::DePolignac::is_de_polignac(127), "127 De Polignac"
assert_ok !Rosetta::DePolignac::is_de_polignac(7),   "7 = 2+5 is prime"

test_run
