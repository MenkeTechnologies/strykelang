#!/usr/bin/env stryke
# Rosetta Code: Comb sort

fn Rosetta::CombSort::sort($list) {
    my @arr = @$list
    my $len = len(@arr)
    my $gap = $len
    my $swapped = 1
    
    while ($gap > 1 || $swapped) {
        $gap = int($gap / 1.3)
        if ($gap < 1) { $gap = 1 }
        
        $swapped = 0
        for my $i (0..$len-$gap-1) {
            if ($arr[$i] > $arr[$i + $gap]) {
                ($arr[$i], $arr[$i + $gap]) = ($arr[$i + $gap], $arr[$i])
                $swapped = 1
            }
        }
    }
    
    \@arr
}

my $data = [9, 8, 3, 7, 5, 6, 4, 1]
my $sorted = Rosetta::CombSort::sort($data)
assert_eq join(",", @$sorted), "1,3,4,5,6,7,8,9", "comb sort"

my $data2 = [5, 1, 4, 2, 8]
my $sorted2 = Rosetta::CombSort::sort($data2)
assert_eq join(",", @$sorted2), "1,2,4,5,8", "comb sort 2"

test_run
