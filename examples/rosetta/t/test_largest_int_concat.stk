#!/usr/bin/env stryke
# Rosetta Code: Largest int from concatenated ints

fn Rosetta::LargestIntConcat::solve(@nums) {
    # Sort strings by $b.$a cmp $a.$b
    my @sorted = sort { (_1 . _0) cmp (_0 . _1) } @nums
    join("", @sorted)
}

assert_eq Rosetta::LargestIntConcat::solve(1, 34, 3, 98, 9, 76, 45, 4), "998764543431", "largest concat 1"
assert_eq Rosetta::LargestIntConcat::solve(54, 546, 548, 60), "6054854654", "largest concat 2"

(1, 34, 3, 98, 9, 76, 45, 4) |> Rosetta::LargestIntConcat::solve |> assert_eq("998764543431", "pipe largest concat")

test_run
