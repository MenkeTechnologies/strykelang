#!/usr/bin/env stryke
# Rosetta Code: ADFGVX cipher

fn Rosetta::ADFGVX::prepare_grid($key_square) {
    var %grid
    val @chars = $key_square |> chars()
    val @labels = ("A", "D", "F", "G", "V", "X")
    for (var $i = 0; $i < 6; $i++) {
        for (var $j = 0; $j < 6; $j++) {
            val $c = $chars[$i * 6 + $j]
            $grid{$c} = $labels[$i] . $labels[$j]
        }
    }
    \%grid
}

fn Rosetta::ADFGVX::encode($text, $key_square, $keyword) {
    val $grid = Rosetta::ADFGVX::prepare_grid($key_square)
    val $t = $text |> uc() |> { _ =~ s/[^A-Z0-9]//gr }
    
    var $fractionated = ""
    for val $c ($t |> chars()) {
        $fractionated .= $grid->{$c}
    }
    
    # Columnar transposition
    val @kw = $keyword |> chars()
    val $n = len(@kw)
    var @cols
    for (1:$n) { push @cols, "" }
    
    val @f_chars = $fractionated |> chars()
    for (var $i = 0; $i < len(@f_chars); $i++) {
        $cols[$i % $n] .= $f_chars[$i]
    }
    
    # Sort columns by keyword
    var @indices = sort { $kw[_0] cmp $kw[_1] } 0:($n - 1)
    
    var $res = ""
    for val $idx (@indices) {
        $res .= $cols[$idx]
    }
    $res
}

val $key_sq = "NA1C3H8TB2O5W7PK4M6RS+0GDTLY9IQUVJXFZ" # 36 chars
val $kw = "PRIVACY"
val $text = "ATTACK AT 1200"
# Expected ciphertext: depends on grid and keyword sorting.
# We'll just test round trip properties or a known small example.

# Simplified 6x6 grid
val $sq = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
val $enc = Rosetta::ADFGVX::encode("HELLO", $sq, "KEY")

assert_ok len($enc) == 10, "encoded length is twice the text length"

test_run
