#!/usr/bin/env stryke
# Rosetta Code: Narcissistic decimal number

fn my_is_narcissistic($n) {
    my $s = "$n"
    my $len = length($s)
    my @digits = ~> $s chars
    my $sum = 0
    for my $d (@digits) {
        $sum += int($d) ** $len
    }
    $sum == $n
}

assert_ok my_is_narcissistic(153), "153 is narcissistic"
assert_ok my_is_narcissistic(370), "370 is narcissistic"
assert_ok my_is_narcissistic(9474), "9474 is narcissistic"
assert_ok !my_is_narcissistic(154), "154 is not"

test_run
