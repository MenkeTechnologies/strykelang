#!/usr/bin/env stryke
# Rosetta Code: Narcissistic decimal number

fn Rosetta::Narcissistic::check($n) {
    val $s = "$n"
    val $len = len($s)
    val @digits = ~> $s chars
    var $sum = 0
    for val $d (@digits) {
        $sum += int($d) ** $len
    }
    $sum == $n
}

assert_ok Rosetta::Narcissistic::check(153), "153 is narcissistic"
assert_ok Rosetta::Narcissistic::check(370), "370 is narcissistic"
assert_ok Rosetta::Narcissistic::check(9474), "9474 is narcissistic"
assert_ok !Rosetta::Narcissistic::check(154), "154 is not"

test_run
