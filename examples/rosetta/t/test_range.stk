#!/usr/bin/env stryke
# Rosetta Code: Range Extraction and Expansion

fn extract_ranges(@nums) {
    return "" unless @nums
    @nums = sort { $a <=> $b } @nums
    
    my @ranges
    my $start = $nums[0]
    my $end = $nums[0]
    
    for my $i (1..$#nums) {
        if ($nums[$i] == $end + 1) {
            $end = $nums[$i]
        } else {
            push @ranges, ($end > $start + 1 ? "$start-$end" : $end > $start ? "$start,$end" : "$start")
            $start = $nums[$i]
            $end = $nums[$i]
        }
    }
    push @ranges, ($end > $start + 1 ? "$start-$end" : $end > $start ? "$start,$end" : "$start")
    join ",", @ranges
}

fn expand_range($spec) {
    my @result
    for my $part ($spec |> split /,/) {
        if ($part =~ /^(-?\d+)-(-?\d+)$/) {
            push @result, ($1..$2)
        } else {
            push @result, int($part)
        }
    }
    @result
}

assert_eq extract_ranges(1, 2, 3, 5, 7, 8, 9), "1-3,5,7-9", "extract ranges"
assert_eq extract_ranges(1, 3, 5, 7), "1,3,5,7", "no ranges"
assert_eq extract_ranges(1, 2, 3, 4, 5), "1-5", "single range"

my @expanded = expand_range("1-3,5,7-9")
assert_eq join(",", @expanded), "1,2,3,5,7,8,9", "expand range"

my @single = expand_range("5")
assert_eq join(",", @single), "5", "expand single"

test_run
