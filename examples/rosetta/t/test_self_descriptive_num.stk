#!/usr/bin/env stryke
# Rosetta Code: Self-descriptive numbers

fn Rosetta::SelfDescriptive::check($n) {
    my @digits = ~> "$n" chars
    my $len = scalar(@digits)
    my @counts = (0) x $len
    for my $d (@digits) {
        if ($d < $len) {
            $counts[$d]++
        } else {
            return 0
        }
    }
    for my $i (0..$len-1) {
        if ($counts[$i] != $digits[$i]) { return 0 }
    }
    1
}

assert_ok Rosetta::SelfDescriptive::check(1210), "1210 is self-descriptive (1 '0', 2 '1's, 1 '2', 0 '3's)"
assert_ok Rosetta::SelfDescriptive::check(2020), "2020 is self-descriptive"
assert_ok !Rosetta::SelfDescriptive::check(1234), "1234 is not"

test_run
