#!/usr/bin/env stryke
# Rosetta Code: Vigenere Cipher

fn Rosetta::VigenereCipher::encrypt($text, $key) {
    val @tc = ~> $text uc chars grep { _ =~ /[A-Z]/ }
    val @kc = ~> $key uc chars grep { _ =~ /[A-Z]/ }
    val $klen = len(@kc)
    
    0..len(@tc)-1 |> map {
        val $i = _
        val $shift = ord($kc[$i % $klen]) - 65
        chr((ord($tc[$i]) - 65 + $shift) % 26 + 65)
    } |> join ""
}

fn Rosetta::VigenereCipher::decrypt($text, $key) {
    val @tc = ~> $text uc chars grep { _ =~ /[A-Z]/ }
    val @kc = ~> $key uc chars grep { _ =~ /[A-Z]/ }
    val $klen = len(@kc)
    
    0..len(@tc)-1 |> map {
        val $i = _
        val $shift = ord($kc[$i % $klen]) - 65
        chr((ord($tc[$i]) - 65 - $shift + 26) % 26 + 65)
    } |> join ""
}

val $msg = "ATTACKATDAWN"
val $key = "LEMON"
val $enc = Rosetta::VigenereCipher::encrypt($msg, $key)
assert_eq $enc, "LXFOPVEFRNHR", "encrypt ATTACKATDAWN with LEMON"
assert_eq Rosetta::VigenereCipher::decrypt($enc, $key), "ATTACKATDAWN", "decrypt roundtrip"

test_run
