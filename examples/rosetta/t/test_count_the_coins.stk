#!/usr/bin/env stryke
# Rosetta Code: Count the coins

val @COINS = (1, 5, 10, 25, 50, 100)
var %CHANGE_MEMO

fn Rosetta::CountTheCoins::solve($amount, $coin_idx) {
    if ($amount == 0) {
        1
    } elsif ($amount < 0 || $coin_idx < 0) {
        0
    } else {
        val $key = "$amount,$coin_idx"
        if (exists $CHANGE_MEMO{$key}) {
            $CHANGE_MEMO{$key}
        } else {
            val $without = Rosetta::CountTheCoins::solve($amount, $coin_idx - 1)
            val $with = Rosetta::CountTheCoins::solve($amount - $COINS[$coin_idx], $coin_idx)
            val $res = $without + $with
            $CHANGE_MEMO{$key} = $res
            $res
        }
    }
}

assert_eq Rosetta::CountTheCoins::solve(100, 5), 293, "ways to make 100"

test_run
