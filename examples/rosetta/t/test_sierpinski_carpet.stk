#!/usr/bin/env stryke
# Rosetta Code: Sierpinski Carpet

fn in_carpet($x, $y) {
    while ($x > 0 || $y > 0) {
        if ($x % 3 == 1 && $y % 3 == 1) {
            return 0
        }
        $x = $x / 3
        $y = $y / 3
    }
    1
}

fn carpet_row($y, $size) {
    my $res = ""
    for my $x (0..$size-1) {
        if (in_carpet($x, $y)) {
            $res = $res . "#"
        } else {
            $res = $res . " "
        }
    }
    $res
}

assert_eq carpet_row(0, 3), "###", "carpet row 0 size 3"
assert_eq carpet_row(1, 3), "# #", "carpet row 1 size 3"
assert_eq carpet_row(2, 3), "###", "carpet row 2 size 3"

assert_eq carpet_row(0, 9), "#########", "carpet row 0 size 9"
assert_eq carpet_row(4, 9), "# #   # #", "carpet row 4 size 9"

test_run
