#!/usr/bin/env stryke
# Rosetta Code: Compiler/syntax analyzer

fn Rosetta::Parser::parse($tokens) {
    # Simple recursive descent parser for expr = term (op term)*
    my $i = 0
    return Rosetta::Parser::parse_expr($tokens, \$i)
}

fn Rosetta::Parser::parse_expr($tokens, $i_ref) {
    my $left = $tokens->[$$i_ref]->[1]
    $$i_ref++
    
    if ($$i_ref < len(@$tokens) && $tokens->[$$i_ref]->[0] eq "Op") {
        my $op = $tokens->[$$i_ref]->[1]
        $$i_ref++
        my $right = Rosetta::Parser::parse_expr($tokens, $i_ref)
        return [$op, $left, $right]
    }
    
    $left
}

# Tokens for: 10 + 20
my $tokens = [
    ["Integer", 10],
    ["Op", "+"],
    ["Integer", 20]
]

my $ast = Rosetta::Parser::parse($tokens)
assert_eq $ast->[0], "+", "Root op is +"
assert_eq $ast->[1], 10, "Left child is 10"
assert_eq $ast->[2], 20, "Right child is 20"

test_run
