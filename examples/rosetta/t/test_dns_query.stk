#!/usr/bin/env stryke
# Rosetta Code: DNS query

fn Rosetta::Dns::resolve($hostname) {
    # net_dns returns a list of IP addresses
    my @ips = net_dns($hostname)
    \@ips
}

# Testing DNS query is difficult in a CI environment without network access.
# We'll mock it if it fails or just check it's a list.
my $ips = Rosetta::Dns::resolve("localhost")
assert_ok len(@$ips) >= 1, "Resolved localhost"
assert_ok $ips->[0] eq "127.0.0.1" || $ips->[0] eq "::1", "Localhost IP correct"

test_run
