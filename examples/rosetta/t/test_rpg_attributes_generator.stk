#!/usr/bin/env stryke
# Rosetta Code: RPG attributes generator
# Roll 4d6, drop the lowest, sum the rest. Repeat for 6 attributes.
# Re-roll the whole set unless: total ≥ 75 AND at least two values ≥ 15.

fn Rosetta::RpgAttr::roll_4d6_drop_low() {
    my @rolls = (
        1 + int(rand(6)),
        1 + int(rand(6)),
        1 + int(rand(6)),
        1 + int(rand(6)),
    )
    my @sorted = sort { $a <=> $b } @rolls
    $sorted[1] + $sorted[2] + $sorted[3]
}

fn Rosetta::RpgAttr::generate_set() {
    my @attrs
    while (1) {
        @attrs = ()
        my $sum = 0
        my $high = 0
        for my $i (~> 1:6) {
            my $v = Rosetta::RpgAttr::roll_4d6_drop_low()
            push @attrs, $v
            $sum += $v
            $high++ if $v >= 15
        }
        last if $sum >= 75 && $high >= 2
    }
    @attrs
}

# 4d6-drop-low yields values in [3, 18]
for my $i (~> 1:200) {
    my $v = Rosetta::RpgAttr::roll_4d6_drop_low()
    assert_ok $v >= 3 && $v <= 18, "value in [3, 18]"
}

# Single attribute distribution: mean ≈ 12.24
my @samples
for my $i (~> 1:5000) { push @samples, Rosetta::RpgAttr::roll_4d6_drop_low() }
my $sum = 0
for my $v (@samples) { $sum += $v }
my $mean = $sum / 5000
assert_ok abs($mean - 12.24) < 0.3, sprintf("mean ≈ 12.24 (got %.2f)", $mean)

# A complete set always satisfies the campaign rules
for my $i (~> 1:50) {
    my @set = Rosetta::RpgAttr::generate_set()
    assert_eq scalar(@set), 6, "6 attributes"
    my $set_sum = 0
    my $high_count = 0
    for my $v (@set) {
        assert_ok $v >= 3 && $v <= 18, "in range"
        $set_sum += $v
        $high_count++ if $v >= 15
    }
    assert_ok $set_sum >= 75, "total ≥ 75"
    assert_ok $high_count >= 2, "≥ 2 high attributes"
}

# Pipe form
() |> fn { my @s = Rosetta::RpgAttr::generate_set(); scalar(@s) } |> assert_eq(6, "pipe count")

test_run
