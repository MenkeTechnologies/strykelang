#!/usr/bin/env stryke
# Rosetta Code: RPG attributes generator
# Roll 4d6, drop the lowest, sum the rest. Repeat for 6 attributes.
# Re-roll the whole set unless: total ≥ 75 AND at least two values ≥ 15.

fn Rosetta::RpgAttr::roll_4d6_drop_low() {
    val @rolls = (
        1 + int(rand(6)),
        1 + int(rand(6)),
        1 + int(rand(6)),
        1 + int(rand(6)),
    )
    val @sorted = sort { _ <=> _1 } @rolls
    $sorted[1] + $sorted[2] + $sorted[3]
}

fn Rosetta::RpgAttr::generate_set() {
    var @attrs
    while (1) {
        @attrs = ()
        var $sum = 0
        var $high = 0
        for val $i (~> 1:6) {
            val $v = Rosetta::RpgAttr::roll_4d6_drop_low()
            push @attrs, $v
            $sum += $v
            $high++ if $v >= 15
        }
        last if $sum >= 75 && $high >= 2
    }
    @attrs
}

# 4d6-drop-low yields values in [3, 18]
for val $i (~> 1:200) {
    val $v = Rosetta::RpgAttr::roll_4d6_drop_low()
    assert_ok $v >= 3 && $v <= 18, "value in [3, 18]"
}

# Single attribute distribution: mean ≈ 12.24
var @samples
for val $i (~> 1:5000) { push @samples, Rosetta::RpgAttr::roll_4d6_drop_low() }
var $sum = 0
for val $v (@samples) { $sum += $v }
val $mean = $sum / 5000
assert_ok abs($mean - 12.24) < 0.3, sprintf("mean ≈ 12.24 (got %.2f)", $mean)

# A complete set always satisfies the campaign rules
for val $i (~> 1:50) {
    val @set = Rosetta::RpgAttr::generate_set()
    assert_eq len(@set), 6, "6 attributes"
    var $set_sum = 0
    var $high_count = 0
    for val $v (@set) {
        assert_ok $v >= 3 && $v <= 18, "in range"
        $set_sum += $v
        $high_count++ if $v >= 15
    }
    assert_ok $set_sum >= 75, "total ≥ 75"
    assert_ok $high_count >= 2, "≥ 2 high attributes"
}

# Pipe form
() |> fn { val @s = Rosetta::RpgAttr::generate_set(); len(@s) } |> assert_eq(6, "pipe count")

test_run
