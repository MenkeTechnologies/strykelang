#!/usr/bin/env stryke
# Rosetta Code: Inventory sequence

fn Rosetta::InventorySequence::next_step(@nums) {
    my %counts
    for my $n (@nums) { $counts{$n}++ }
    my @res = ()
    for my $k (~> keys %counts sort) {
        push @res, $counts{$k}, $k
    }
    @res
}

my @s1 = (1)
my @s2 = Rosetta::InventorySequence::next_step(@s1)
assert_eq join(",", @s2), "1,1", "inv(1) -> 1,1"

my @s3 = Rosetta::InventorySequence::next_step(@s2)
assert_eq join(",", @s3), "2,1", "inv(1,1) -> 2,1"

my @s4 = Rosetta::InventorySequence::next_step(@s3)
assert_eq join(",", @s4), "1,1,1,2", "inv(2,1) -> 1,1,1,2"

test_run
