#!/usr/bin/env stryke
# Rosetta Code: Inventory sequence

fn Rosetta::InventorySequence::next_step(@nums) {
    var %counts
    for val $n (@nums) { $counts{$n}++ }
    var @res = ()
    for val $k (~> keys %counts sort) {
        push @res, $counts{$k}, $k
    }
    @res
}

val @s1 = (1)
val @s2 = Rosetta::InventorySequence::next_step(@s1)
assert_eq join(",", @s2), "1,1", "inv(1) -> 1,1"

val @s3 = Rosetta::InventorySequence::next_step(@s2)
assert_eq join(",", @s3), "2,1", "inv(1,1) -> 2,1"

val @s4 = Rosetta::InventorySequence::next_step(@s3)
assert_eq join(",", @s4), "1,1,1,2", "inv(2,1) -> 1,1,1,2"

test_run
