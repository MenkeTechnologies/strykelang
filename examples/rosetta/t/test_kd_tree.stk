#!/usr/bin/env stryke
# Rosetta Code: K-d tree

fn Rosetta::KDTree::build($points, $depth) {
    val $n = len(@$points)
    return undef if $n == 0
    
    val $k = len(@{$points->[0]})
    val $axis = $depth % $k
    
    val @sorted = sort { _0->[$axis] <=> _1->[$axis] } @$points
    val $mid = $n / 2 | 0
    
    val @left = @sorted[0 : $mid - 1]
    val @right = @sorted[$mid + 1 : $n - 1]
    
    {
        point => $sorted[$mid],
        left  => Rosetta::KDTree::build(\@left, $depth + 1),
        right => Rosetta::KDTree::build(\@right, $depth + 1)
    }
}

fn Rosetta::KDTree::sq_dist($p1, $p2) {
    var $d = 0
    for (var $i = 0; $i < len(@$p1); $i++) {
        $d += ($p1->[$i] - $p2->[$i]) ** 2
    }
    $d
}

fn Rosetta::KDTree::nearest($node, $target, $depth, $best) {
    return $best if !defined $node
    
    val $d = Rosetta::KDTree::sq_dist($node->{point}, $target)
    var $best_d = Rosetta::KDTree::sq_dist($best, $target)
    
    if ($d < $best_d) {
        $best = $node->{point}
        $best_d = $d
    }
    
    val $k = len(@$target)
    val $axis = $depth % $k
    
    var $nearer
    var $further
    if ($target->[$axis] < $node->{point}->[$axis]) {
        $nearer = $node->{left}
        $further = $node->{right}
    } else {
        $nearer = $node->{right}
        $further = $node->{left}
    }
    
    $best = Rosetta::KDTree::nearest($nearer, $target, $depth + 1, $best)
    
    # Check if we need to check the other side
    if (($target->[$axis] - $node->{point}->[$axis]) ** 2 < Rosetta::KDTree::sq_dist($best, $target)) {
        $best = Rosetta::KDTree::nearest($further, $target, $depth + 1, $best)
    }
    
    $best
}

val @points = ([2,3], [5,4], [9,6], [4,7], [8,1], [7,2])
val $tree = Rosetta::KDTree::build(\@points, 0)

val $target = [9, 2]
val $near = Rosetta::KDTree::nearest($tree, $target, 0, $points[0])
assert_eq join(",", @$near), "8,1", "nearest to (9,2) is (8,1)"

test_run
