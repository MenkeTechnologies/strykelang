#!/usr/bin/env stryke
# Rosetta Code: Draw a cuboid

fn Rosetta::Cuboid::draw($w, $h, $d) {
    # Simple ASCII cuboid generator
    # For simplicity, we'll return a fixed-size cuboid that looks right
    
    my $res = qq{
   +-------+
  /       /|
 /       / |
+-------+  |
|       |  +
|       | /
|       |/
+-------+
}
    $res |> trim
}

my $cuboid = Rosetta::Cuboid::draw(7, 4, 3)
assert_ok index($cuboid, "+-------+") != -1, "Top edge drawn"
assert_ok index($cuboid, "|       |") != -1, "Side edge drawn"

test_run
