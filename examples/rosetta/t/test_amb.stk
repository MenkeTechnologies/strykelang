#!/usr/bin/env stryke
# Rosetta Code: Amb

fn solve_amb {
    my @a = (1, 2, 3)
    my @b = (4, 5, 6)
    
    for my $x (@a) {
        for my $y (@b) {
            if ($x + $y == 7) {
                return ($x, $y)
            }
        }
    }
    ()
}

my @res = solve_amb()
assert_eq join(",", @res), "1,6", "amb solver result"

test_run
