#!/usr/bin/env stryke
# Rosetta Code: Amb

fn Rosetta::Amb::solve() {
    my @a = (1, 2, 3)
    my @b = (4, 5, 6)
    
    for my $x (@a) {
        for my $y (@b) {
            if ($x + $y == 7) {
                return [$x, $y]
            }
        }
    }
    []
}

my $res = Rosetta::Amb::solve()
assert_eq join(",", @$res), "1,6", "amb solver result"

test_run
