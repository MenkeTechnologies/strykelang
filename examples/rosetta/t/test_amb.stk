#!/usr/bin/env stryke
# Rosetta Code: Amb

fn Rosetta::Amb::solve() {
    val @a = (1, 2, 3)
    val @b = (4, 5, 6)
    
    for val $x (@a) {
        for val $y (@b) {
            if ($x + $y == 7) {
                return [$x, $y]
            }
        }
    }
    []
}

val $res = Rosetta::Amb::solve()
assert_eq join(",", @$res), "1,6", "amb solver result"

test_run
