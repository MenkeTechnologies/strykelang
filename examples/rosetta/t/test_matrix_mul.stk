#!/usr/bin/env stryke
# Rosetta Code: Matrix Multiplication

fn Rosetta::Matrix::to_str($m) {
    var @rows
    for val $row (@$m) {
        push @rows, join(",", @$row)
    }
    join(";", @rows)
}

# 2x2 * 2x2
val $a = [[1,2], [3,4]]
val $b = [[5,6], [7,8]]
val $c = [matrix_mul($a, $b)]
assert_eq Rosetta::Matrix::to_str($c), "19,22;43,50", "2x2 * 2x2"

# Identity matrix
val $i = [[1,0], [0,1]]
val $d = [mm($a, $i)]
assert_eq Rosetta::Matrix::to_str($d), "1,2;3,4", "A * I = A"

# 2x3 * 3x2
val $e = [[1,2,3], [4,5,6]]
val $f = [[7,8], [9,10], [11,12]]
val $g = [matmul($e, $f)]
assert_eq Rosetta::Matrix::to_str($g), "58,64;139,154", "2x3 * 3x2"

# 1x3 * 3x1 (dot product as matrix)
val $h = [[1,2,3]]
val $j = [[4], [5], [6]]
val $k = [matrix_mul($h, $j)]
assert_eq Rosetta::Matrix::to_str($k), "32", "1x3 * 3x1 = dot product"

# 3x1 * 1x3 (outer product)
val $l = [matrix_mul($j, $h)]
assert_eq Rosetta::Matrix::to_str($l), "4,8,12;5,10,15;6,12,18", "3x1 * 1x3 = outer product"

test_run
