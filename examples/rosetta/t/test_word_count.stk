#!/usr/bin/env stryke
# Rosetta Code: Word Count

fn Rosetta::WordCount::solve($s) {
    my $counts = {}
    my @words = split /\s+/, $s
    for my $w (@words) {
        if ($w ne "") { $counts->{$w} = $counts->{$w} + 1 }
    }
    $counts
}

my $res = Rosetta::WordCount::solve("hello world hello")
assert_eq $res->{hello}, 2, "hello count"
assert_eq $res->{world}, 1, "world count"

my $res2 = Rosetta::WordCount::solve("apple banana apple cherry banana apple")
assert_eq $res2->{apple}, 3, "apple count"
assert_eq $res2->{banana}, 2, "banana count"
assert_eq $res2->{cherry}, 1, "cherry count"

test_run
