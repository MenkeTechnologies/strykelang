#!/usr/bin/env stryke
# Rosetta Code: Host introspection

fn Rosetta::HostIntrospection::get_info() {
    var %info
    $info{hostname} = net_hostname()

    val @interfaces = net_interfaces()
    $info{interfaces} = \@interfaces

    \%info
}

val $info = Rosetta::HostIntrospection::get_info()
assert_ok len($info->{hostname}) > 0, "Hostname present"
assert_ok len(@{$info->{interfaces}}) > 0, "Interfaces found"

# Every interface entry has a name.
val $if0 = $info->{interfaces}->[0]
assert_ok exists $if0->{name}, "Interface has name"

# At least one non-loopback interface should expose a MAC. Loopback (`lo`)
# legitimately has no MAC, so we look for the first hardware interface
# rather than blindly checking $if0. CI runners (containers, minimal VMs)
# may have only loopback; in that case we just skip the MAC check.
val @hw = grep { $_->{name} ne "lo" && $_->{name} !~ /^lo[0-9]/ } @{$info->{interfaces}}
if (len(@hw) > 0) {
    val $hw0 = $hw[0]
    assert_ok exists $hw0->{mac} && len($hw0->{mac}) > 0,
              "Hardware interface has mac"
}

test_run
