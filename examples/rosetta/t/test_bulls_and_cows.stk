#!/usr/bin/env stryke
# Rosetta Code: Bulls and Cows

fn Rosetta::BullsAndCows::get_score($secret, $guess) {
    var @s = str($secret) |> chars
    val @g = str($guess) |> chars
    var $bulls = 0
    var $cows = 0
    
    var %s_count; var %g_count
    for val $i (0..len(@s)-1) {
        if ($s[$i] eq $g[$i]) {
            $bulls = $bulls + 1
        } else {
            $s_count{$s[$i]} = $s_count{$s[$i]} + 1
            $g_count{$g[$i]} = $g_count{$g[$i]} + 1
        }
    }
    
    for val $k (keys %g_count) {
        $cows = $cows + min($s_count{$k}, $g_count{$k}) if exists $s_count{$k}
    }
    [$bulls, $cows]
}

val $score1 = Rosetta::BullsAndCows::get_score(1234, 1234)
assert_eq $score1->[0], 4, "4 bulls"
assert_eq $score1->[1], 0, "0 cows"

val $score2 = Rosetta::BullsAndCows::get_score(1234, 4321)
assert_eq $score2->[0], 0, "0 bulls"
assert_eq $score2->[1], 4, "4 cows"

val $score3 = Rosetta::BullsAndCows::get_score(1234, 1357)
assert_eq $score3->[0], 1, "1 bull (1)"
assert_eq $score3->[1], 1, "1 cow (3)"

test_run
