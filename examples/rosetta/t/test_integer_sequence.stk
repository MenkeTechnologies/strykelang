#!/usr/bin/env stryke
# Rosetta Code: Integer Sequence

fn integers_from($start) {
    my @seq
    push @seq, $_ for $start..$start+99
    @seq
}

fn naturals {
    integers_from(1)
}

fn range_inclusive($a, $b) {
    $a..$b
}

my @from_1 = integers_from(1)
assert_eq $from_1[0], 1, "from 1: first"
assert_eq $from_1[99], 100, "from 1: 100th"

my @from_0 = integers_from(0)
assert_eq $from_0[0], 0, "from 0: first"

my @nat = naturals()
assert_eq $nat[0], 1, "naturals start at 1"
assert_eq scalar(@nat), 100, "100 naturals"

my @r = range_inclusive(5, 10)
assert_eq join(",", @r), "5,6,7,8,9,10", "range 5..10"

my @squares = 1..10 |> map { $_ * $_ }
assert_eq join(",", @squares), "1,4,9,16,25,36,49,64,81,100", "first 10 squares"

test_run
