#!/usr/bin/env stryke
# Rosetta Code: Stream merge — k-way merge of pre-sorted streams

fn Rosetta::StreamMerge::two($a, $b) {
    var @out
    var $i = 0; var $j = 0
    val $na = len(@$a); val $nb = len(@$b)
    while ($i < $na && $j < $nb) {
        if ($a->[$i] <= $b->[$j]) {
            push @out, $a->[$i]; $i += 1
        } else {
            push @out, $b->[$j]; $j += 1
        }
    }
    while ($i < $na) { push @out, $a->[$i]; $i += 1 }
    while ($j < $nb) { push @out, $b->[$j]; $j += 1 }
    \@out
}

fn Rosetta::StreamMerge::k_way($streams) {
    var @result
    var @cursors
    for val $i (0..len(@$streams)-1) { $cursors[$i] = 0 }
    while (1) {
        var $best = -1
        var $best_v
        for val $i (0..len(@$streams)-1) {
            val $cur = $cursors[$i]
            next if $cur >= len(@{$streams->[$i]})
            val $v = $streams->[$i]->[$cur]
            if ($best == -1 || $v < $best_v) {
                $best = $i
                $best_v = $v
            }
        }
        last if $best == -1
        push @result, $best_v
        $cursors[$best] += 1
    }
    \@result
}

# Two-stream merge
val $r2 = Rosetta::StreamMerge::two([1, 4, 7], [2, 3, 5, 8])
assert_eq join(",", @$r2), "1,2,3,4,5,7,8", "two-way merge"

# Empty-source edge cases
val $rE1 = Rosetta::StreamMerge::two([], [1, 2, 3])
assert_eq join(",", @$rE1), "1,2,3", "empty + sorted"
val $rE2 = Rosetta::StreamMerge::two([1, 2], [])
assert_eq join(",", @$rE2), "1,2", "sorted + empty"

# k-way
val $rk = Rosetta::StreamMerge::k_way([[1, 4, 8], [2, 3, 9], [0, 5, 7, 10]])
assert_eq join(",", @$rk), "0,1,2,3,4,5,7,8,9,10", "3-way merge"

# Single stream
val $r1 = Rosetta::StreamMerge::k_way([[1, 2, 3, 4]])
assert_eq join(",", @$r1), "1,2,3,4", "1-way is identity"

# All empty
val $r0 = Rosetta::StreamMerge::k_way([[], [], []])
assert_eq len(@$r0), 0, "all empty -> empty"

# Duplicates preserved
val $rd = Rosetta::StreamMerge::two([1, 1, 2], [1, 2, 3])
assert_eq join(",", @$rd), "1,1,1,2,2,3", "duplicates preserved"

test_run
