#!/usr/bin/env stryke
# Rosetta Code: Selection Sort

fn selection_sort(@arr) {
    my $n = scalar(@arr)
    for my $i (0..$n-2) {
        my $min_idx = $i
        for my $j ($i+1..$n-1) {
            $min_idx = $j if $arr[$j] < $arr[$min_idx]
        }
        if ($min_idx != $i) {
            ($arr[$i], $arr[$min_idx]) = ($arr[$min_idx], $arr[$i])
        }
    }
    @arr
}

my @sorted = selection_sort(64, 25, 12, 22, 11)
assert_eq join(",", @sorted), "11,12,22,25,64", "selection sort"

my @single = selection_sort(42)
assert_eq join(",", @single), "42", "single element"

my @already = selection_sort(1, 2, 3, 4, 5)
assert_eq join(",", @already), "1,2,3,4,5", "already sorted"

my @reverse = selection_sort(5, 4, 3, 2, 1)
assert_eq join(",", @reverse), "1,2,3,4,5", "reverse"

my @dups = selection_sort(3, 1, 4, 1, 5)
assert_eq join(",", @dups), "1,1,3,4,5", "with duplicates"

test_run
