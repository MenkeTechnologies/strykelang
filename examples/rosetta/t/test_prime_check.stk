#!/usr/bin/env stryke
# Rosetta Code: Primality by Trial Division

fn Rosetta::PrimeCheck::check($n) {
    if ($n < 2) {
        0
    } elsif ($n < 4) {
        1
    } elsif ($n % 2 == 0) {
        0
    } else {
        my $i = 3
        my $is_p = 1
        while ($i * $i <= $n && $is_p) {
            if ($n % $i == 0) {
                $is_p = 0
            }
            $i += 2
        }
        $is_p
    }
}

fn Rosetta::PrimeCheck::list($max) {
    2:$max |> grep { Rosetta::PrimeCheck::check(_) }
}

assert_ok Rosetta::PrimeCheck::check(2), "2 is prime"
assert_ok Rosetta::PrimeCheck::check(17), "17 is prime"
assert_ok Rosetta::PrimeCheck::check(97), "97 is prime"
assert_ok !Rosetta::PrimeCheck::check(1), "1 is not prime"
assert_ok !Rosetta::PrimeCheck::check(4), "4 is not prime"
assert_ok !Rosetta::PrimeCheck::check(15), "15 is not prime"

my @primes = Rosetta::PrimeCheck::list(20)
assert_eq join(",", @primes), "2,3,5,7,11,13,17,19", "primes up to 20"

test_run
