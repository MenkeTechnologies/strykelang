#!/usr/bin/env stryke
# Rosetta Code: Pentagonal numbers

fn pentagonal($n) {
    int($n * (3 * $n - 1) / 2)
}

fn my_is_pentagonal($n) {
    my $val = 24 * $n + 1
    my $root = int(sqrt($val))
    if ($root * $root == $val) {
        ($root + 1) % 6 == 0
    } else {
        0
    }
}

assert_eq pentagonal(1), 1, "P1"
assert_eq pentagonal(2), 5, "P2"
assert_eq pentagonal(3), 12, "P3"
assert_eq pentagonal(4), 22, "P4"
assert_eq pentagonal(5), 35, "P5"

assert_ok my_is_pentagonal(1), "1 is pentagonal"
assert_ok my_is_pentagonal(5), "5 is pentagonal"
assert_ok my_is_pentagonal(35), "35 is pentagonal"
assert_ok !my_is_pentagonal(2), "2 is not"
assert_ok !my_is_pentagonal(7), "7 is not"

35 |> my_is_pentagonal |> assert_ok("pipe pentagonal")

test_run
