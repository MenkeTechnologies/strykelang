#!/usr/bin/env stryke
# Rosetta Code: K-nearest neighbors

fn Rosetta::KNN::distance($p1, $p2) {
    var $sum = 0
    for (var $i = 0; $i < len(@$p1); $i++) {
        $sum += ($p1->[$i] - $p2->[$i]) ** 2
    }
    sqrt($sum)
}

fn Rosetta::KNN::solve($training_data, $labels, $test_point, $k) {
    var @distances
    for (var $i = 0; $i < len(@$training_data); $i++) {
        val $dist = Rosetta::KNN::distance($training_data->[$i], $test_point)
        push @distances, { idx => $i, dist => $dist }
    }
    
    val @sorted = sort { _->{dist} <=> $b->{dist} } @distances
    
    var %counts
    var $max_count = 0
    var $best_label = undef
    
    for (var $i = 0; $i < $k; $i++) {
        val $idx = $sorted[$i]->{idx}
        val $label = $labels->[$idx]
        $counts{$label}++
        if ($counts{$label} > $max_count) {
            $max_count = $counts{$label}
            $best_label = $label
        }
    }
    
    $best_label
}

val $train = [
    [1.0, 1.0], [1.2, 1.0], [0.8, 1.2], # Class A
    [5.0, 5.0], [5.1, 4.9], [4.8, 5.2]  # Class B
]
val $labels = ["A", "A", "A", "B", "B", "B"]

val $test1 = [1.0, 1.2]
val $res1 = Rosetta::KNN::solve($train, $labels, $test1, 3)
assert_eq $res1, "A", "kNN classification A"

val $test2 = [4.9, 5.0]
val $res2 = Rosetta::KNN::solve($train, $labels, $test2, 3)
assert_eq $res2, "B", "kNN classification B"

test_run
