#!/usr/bin/env stryke
# Rosetta Code: BK tree (Burkhard-Keller tree) — index strings under a
# discrete metric (typically Levenshtein) for fast approximate-match
# lookup. Each child of a node is keyed by its distance to the parent;
# the triangle inequality lets us prune subtrees during search.

fn Rosetta::BK::levenshtein($a, $b) {
    val $la = length($a)
    val $lb = length($b)
    return $lb if $la == 0
    return $la if $lb == 0
    var @prev = ~> 0:$lb
    for val $i (~> 1:$la) {
        var @cur = ($i)
        val $ac = substr($a, $i - 1, 1)
        for val $j (~> 1:$lb) {
            val $cost = $ac eq substr($b, $j - 1, 1) ? 0 : 1
            val $del = $prev[$j] + 1
            val $ins = $cur[$j - 1] + 1
            val $sub = $prev[$j - 1] + $cost
            var $m = $del < $ins ? $del : $ins
            $m = $sub if $sub < $m
            push @cur, $m
        }
        @prev = @cur
    }
    $prev[$lb]
}

fn Rosetta::BK::new() { { root => undef } }

fn Rosetta::BK::insert($t, $word) {
    if (!defined $t->{root}) {
        $t->{root} = { word => $word, children => {} }
        return
    }
    var $node = $t->{root}
    while (1) {
        val $d = Rosetta::BK::levenshtein($word, $node->{word})
        return if $d == 0
        if (exists $node->{children}{$d}) {
            $node = $node->{children}{$d}
        } else {
            $node->{children}{$d} = { word => $word, children => {} }
            return
        }
    }
}

fn Rosetta::BK::search($t, $query, $threshold) {
    var @out
    return \@out if !defined $t->{root}
    Rosetta::BK::sr($t->{root}, $query, $threshold, \@out)
    @out = sort { _0 cmp _1 } @out
    \@out
}

fn Rosetta::BK::sr($node, $query, $threshold, $out) {
    val $d = Rosetta::BK::levenshtein($query, $node->{word})
    push @$out, $node->{word} if $d <= $threshold
    val $lo = $d - $threshold
    val $hi = $d + $threshold
    for val $key (keys %{$node->{children}}) {
        if ($key >= $lo && $key <= $hi) {
            Rosetta::BK::sr($node->{children}{$key}, $query, $threshold, $out)
        }
    }
}

# Levenshtein sanity
assert_eq Rosetta::BK::levenshtein("kitten", "sitting"), 3, "kitten/sitting"
assert_eq Rosetta::BK::levenshtein("hello", "hello"), 0, "identical"
assert_eq Rosetta::BK::levenshtein("", "abc"), 3, "empty/abc"
assert_eq Rosetta::BK::levenshtein("abc", ""), 3, "abc/empty"
assert_eq Rosetta::BK::levenshtein("abc", "yabd"), 2, "abc/yabd"

# Build a small dictionary
val $tree = Rosetta::BK::new()
var @words = ("book", "books", "boo", "boon", "cook", "cake", "cape", "cart", "car",
             "loop", "look", "took", "tool", "noon", "moon")
for val $w (@words) { Rosetta::BK::insert($tree, $w) }

# Search with threshold 1 from "book"
val $r1 = Rosetta::BK::search($tree, "book", 1)
# distance 0: book; distance 1: books, boo, boon, cook, look, took
assert_eq join(",", @$r1), "boo,book,books,boon,cook,look,took",
    "search book ≤1"

# threshold 2 from "ook" — should match more
val $r2 = Rosetta::BK::search($tree, "ook", 2)
assert_ok len(@$r2) > len(@$r1), "looser threshold finds more"

# Single threshold-0 query: only exact match
val $r3 = Rosetta::BK::search($tree, "cake", 0)
assert_eq join(",", @$r3), "cake", "exact match cake"

# Query that's 3 away from many: "hi"
val $r4 = Rosetta::BK::search($tree, "hi", 2)
assert_eq join(",", @$r4), "", "no matches within 2 for hi"

# Add a duplicate — no effect.
val $tree2 = Rosetta::BK::new()
Rosetta::BK::insert($tree2, "test")
Rosetta::BK::insert($tree2, "test")
val $r5 = Rosetta::BK::search($tree2, "test", 0)
assert_eq join(",", @$r5), "test", "duplicate insert"

# Empty tree
val $empty = Rosetta::BK::new()
val $r6 = Rosetta::BK::search($empty, "anything", 5)
assert_eq len(@$r6), 0, "empty tree no matches"

test_run
