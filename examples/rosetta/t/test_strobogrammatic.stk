#!/usr/bin/env stryke
# Rosetta Code: Strobogrammatic numbers

fn Rosetta::Strobogrammatic::is_strobogrammatic($n) {
    val $s = "$n"
    val @chars = chars($s)
    var $res_s = ""
    var $valid = 1
    for val $c (@chars) {
        if ($c eq "0") { $res_s = "0" . $res_s }
        elsif ($c eq "1") { $res_s = "1" . $res_s }
        elsif ($c eq "6") { $res_s = "9" . $res_s }
        elsif ($c eq "8") { $res_s = "8" . $res_s }
        elsif ($c eq "9") { $res_s = "6" . $res_s }
        else { $valid = 0 }
    }
    var $final = 0
    if ($valid) {
        if ($res_s eq $s) {
            $final = 1
        }
    }
    $final
}

assert_ok Rosetta::Strobogrammatic::is_strobogrammatic(69), "69 is strobogrammatic"
assert_ok Rosetta::Strobogrammatic::is_strobogrammatic(88), "88 is strobogrammatic"
assert_ok Rosetta::Strobogrammatic::is_strobogrammatic(818), "818 is strobogrammatic"
assert_ok !Rosetta::Strobogrammatic::is_strobogrammatic(66), "66 is not (flips to 99)"
assert_eq Rosetta::Strobogrammatic::is_strobogrammatic(2), 0, "2 is not"

69 |> Rosetta::Strobogrammatic::is_strobogrammatic |> assert_ok("pipe Strobogrammatic")

test_run
