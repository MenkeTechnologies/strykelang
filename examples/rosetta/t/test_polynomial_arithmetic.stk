#!/usr/bin/env stryke
# Rosetta Code: Polynomial arithmetic

fn Rosetta::Polynomial::add($p1, $p2) {
    my $n1 = len(@$p1)
    my $n2 = len(@$p2)
    my $n = max($n1, $n2)
    my @res
    for (my $i = 0; $i < $n; $i++) {
        my $v1 = $i < $n1 ? $p1->[$i] : 0
        my $v2 = $i < $n2 ? $p2->[$i] : 0
        push @res, $v1 + $v2
    }
    \@res
}

fn Rosetta::Polynomial::mul($p1, $p2) {
    my $n1 = len(@$p1)
    my $n2 = len(@$p2)
    my $n = $n1 + $n2 - 1
    my @res = map { 0 } 1:$n
    
    for (my $i = 0; $i < $n1; $i++) {
        for (my $j = 0; $j < $n2; $j++) {
            $res[$i + $j] += $p1->[$i] * $p2->[$j]
        }
    }
    \@res
}

# (1 + 2x + 3x^2) + (4 + 5x) = (5 + 7x + 3x^2)
my $a = [1, 2, 3]
my $b = [4, 5]
my $sum = Rosetta::Polynomial::add($a, $b)
assert_eq join(",", @$sum), "5,7,3", "polynomial add"

# (1 + 2x) * (3 + 4x) = 3 + 4x + 6x + 8x^2 = 3 + 10x + 8x^2
my $c = [1, 2]
my $d = [3, 4]
my $prod = Rosetta::Polynomial::mul($c, $d)
assert_eq join(",", @$prod), "3,10,8", "polynomial mul"

test_run
