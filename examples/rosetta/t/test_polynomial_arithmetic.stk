#!/usr/bin/env stryke
# Rosetta Code: Polynomial arithmetic

fn Rosetta::Polynomial::add($p1, $p2) {
    val $n1 = len(@$p1)
    val $n2 = len(@$p2)
    val $n = max($n1, $n2)
    var @res
    for (var $i = 0; $i < $n; $i++) {
        val $v1 = $i < $n1 ? $p1->[$i] : 0
        val $v2 = $i < $n2 ? $p2->[$i] : 0
        push @res, $v1 + $v2
    }
    \@res
}

fn Rosetta::Polynomial::mul($p1, $p2) {
    val $n1 = len(@$p1)
    val $n2 = len(@$p2)
    val $n = $n1 + $n2 - 1
    var @res = map { 0 } 1:$n
    
    for (var $i = 0; $i < $n1; $i++) {
        for (var $j = 0; $j < $n2; $j++) {
            $res[$i + $j] += $p1->[$i] * $p2->[$j]
        }
    }
    \@res
}

# (1 + 2x + 3x^2) + (4 + 5x) = (5 + 7x + 3x^2)
val $a = [1, 2, 3]
val $b = [4, 5]
val $sum = Rosetta::Polynomial::add($a, $b)
assert_eq join(",", @$sum), "5,7,3", "polynomial add"

# (1 + 2x) * (3 + 4x) = 3 + 4x + 6x + 8x^2 = 3 + 10x + 8x^2
val $c = [1, 2]
val $d = [3, 4]
val $prod = Rosetta::Polynomial::mul($c, $d)
assert_eq join(",", @$prod), "3,10,8", "polynomial mul"

test_run
