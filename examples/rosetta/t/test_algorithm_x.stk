#!/usr/bin/env stryke
# Rosetta Code: Exact Cover (Algorithm X)

# Simplified check for exact cover
fn Rosetta::AlgorithmX::check($rows_ref, $num_cols) {
    my %seen
    for my $row (@$rows_ref) {
        for my $col (@$row) {
            if ($seen{$col}) { return 0 }
            $seen{$col} = 1
        }
    }
    len(keys %seen) == $num_cols
}

my @r1 = (0, 1)
my @r2 = (0, 2)
my @r3 = (2, 3)
my @r4 = (1)

assert_ok Rosetta::AlgorithmX::check([[0, 2], [1], [3]], 4), "exact cover [0,2],[1],[3] for 4 cols"
assert_ok !Rosetta::AlgorithmX::check([[0, 1], [0, 2]], 3), "conflict not exact cover"

test_run
