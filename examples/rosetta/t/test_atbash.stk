#!/usr/bin/env stryke
# Rosetta Code: Atbash Cipher

fn Rosetta::Atbash::cipher($s) {
    ~> $s chars map {
        _ =~ /[A-Z]/ ? chr(90 - (ord(_) - 65))
      : _ =~ /[a-z]/ ? chr(122 - (ord(_) - 97))
      : _
    } |> join ""
}

assert_eq Rosetta::Atbash::cipher("ABCDEFGHIJKLMNOPQRSTUVWXYZ"), "ZYXWVUTSRQPONMLKJIHGFEDCBA", "upper alphabet"
assert_eq Rosetta::Atbash::cipher("abcdefghijklmnopqrstuvwxyz"), "zyxwvutsrqponmlkjihgfedcba", "lower alphabet"
assert_eq Rosetta::Atbash::cipher("Hello"), "Svool", "atbash Hello"
assert_eq Rosetta::Atbash::cipher("Svool"), "Hello", "atbash Svool"

assert_eq Rosetta::Atbash::cipher("Test 123!"), "Gvhg 123!", "with non-alpha"
assert_eq Rosetta::Atbash::cipher(""), "", "empty"

my $original = "The quick brown fox"
assert_eq Rosetta::Atbash::cipher(Rosetta::Atbash::cipher($original)), $original, "atbash is self-inverse"

test_run
