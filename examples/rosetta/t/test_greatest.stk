#!/usr/bin/env stryke
# Rosetta Code: Greatest Element of a List

fn greatest(@nums) {
    @nums |> reduce { $a > $b ? $a : $b }
}

fn least(@nums) {
    @nums |> reduce { $a < $b ? $a : $b }
}

fn minmax(@nums) {
    my $min = $nums[0]
    my $max = $nums[0]
    for my $n (@nums) {
        $min = $n if $n < $min
        $max = $n if $n > $max
    }
    ($min, $max)
}

assert_eq greatest(3, 1, 4, 1, 5, 9, 2, 6), 9, "greatest of list"
assert_eq greatest(42), 42, "single element"
assert_eq greatest(-5, -2, -10, -1), -1, "greatest negative"

assert_eq least(3, 1, 4, 1, 5, 9, 2, 6), 1, "least of list"
assert_eq least(-5, -2, -10, -1), -10, "least negative"

my ($min, $max) = minmax(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq $min, 1, "min via minmax"
assert_eq $max, 9, "max via minmax"

test_run
