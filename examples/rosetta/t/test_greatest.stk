#!/usr/bin/env stryke
# Rosetta Code: Greatest Element of a List

fn Rosetta::Greatest::max(@nums) {
    my $max = $nums[0]
    for my $n (@nums) {
        $max = $n if $n > $max
    }
    $max
}

fn Rosetta::Greatest::min(@nums) {
    my $min = $nums[0]
    for my $n (@nums) {
        $min = $n if $n < $min
    }
    $min
}

fn Rosetta::Greatest::minmax(@nums) {
    my $min = $nums[0]
    my $max = $nums[0]
    for my $n (@nums) {
        $min = $n if $n < $min
        $max = $n if $n > $max
    }
    ($min, $max)
}

assert_eq Rosetta::Greatest::max(3, 1, 4, 1, 5, 9, 2, 6), 9, "greatest of list"
assert_eq Rosetta::Greatest::max(42), 42, "single element"
assert_eq Rosetta::Greatest::max(-5, -2, -10, -1), -1, "greatest negative"

assert_eq Rosetta::Greatest::min(3, 1, 4, 1, 5, 9, 2, 6), 1, "least of list"
assert_eq Rosetta::Greatest::min(-5, -2, -10, -1), -10, "least negative"

my ($min, $max) = Rosetta::Greatest::minmax(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq $min, 1, "min via minmax"
assert_eq $max, 9, "max via minmax"

test_run
