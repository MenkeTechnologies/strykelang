#!/usr/bin/env stryke
# Rosetta Code: Perfect numbers

fn Rosetta::PerfectNumbers::divisors($n) {
    my @divs = (1) # Proper divisors start with 1
    my $limit = int(sqrt($n))
    for my $i (2..$limit) {
        if ($n % $i == 0) {
            push @divs, $i
            my $j = $n / $i
            if ($j != $i) {
                push @divs, $j
            }
        }
    }
    @divs = sort { _0 <=> _1 } @divs # Sort the divisors numerically
    \@divs # Return the sorted list of proper divisors
}

fn Rosetta::PerfectNumbers::is_perfect($n) {
    if ($n < 2) {
        return 0 # Not perfect
    } else {
        my @divs = @{ Rosetta::PerfectNumbers::divisors($n) } # Gets the list of proper divisors
        my $sum = 0
        for my $d (@divs) { $sum += $d } # Sums the list
        return $sum == $n ? 1 : 0; # Explicitly return 1 for true, 0 for false
    }
}

fn Rosetta::PerfectNumbers::perfect_numbers($max) {
    my @perfects
    for my $n (2..$max) {
        if (Rosetta::PerfectNumbers::is_perfect($n)) {
            push @perfects, $n
        }
    }
    \@perfects
}

assert_eq join(",", @{ Rosetta::PerfectNumbers::divisors(6) }), "1,2,3", "proper divisors of 6"
assert_eq join(",", @{ Rosetta::PerfectNumbers::divisors(28) }), "1,2,4,7,14", "proper divisors of 28"
assert_eq join(",", @{ Rosetta::PerfectNumbers::divisors(1) }), "1", "proper divisors of 1"

assert_ok Rosetta::PerfectNumbers::is_perfect(6), "6 is perfect (1+2+3)"
assert_ok Rosetta::PerfectNumbers::is_perfect(28), "28 is perfect (1+2+4+7+14)"
assert_ok Rosetta::PerfectNumbers::is_perfect(496), "496 is perfect"
assert_ok !Rosetta::PerfectNumbers::is_perfect(1), "1 is not perfect"
assert_ok !Rosetta::PerfectNumbers::is_perfect(12), "12 is not perfect"
assert_ok !Rosetta::PerfectNumbers::is_perfect(100), "100 is not perfect"

my @perfects = @{ Rosetta::PerfectNumbers::perfect_numbers(500) }
assert_eq join(",", @perfects), "6,28,496", "perfect numbers up to 500"

test_run
