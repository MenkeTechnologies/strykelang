#!/usr/bin/env stryke
# Rosetta Code: Perfect Numbers

fn divisors($n) {
    1..int($n/2) |> filter { $n % $_ == 0 }
}

fn is_perfect($n) {
    return 0 if $n < 2
    my @divs = divisors($n)
    my $sum = @divs |> reduce { $a + $b }
    $sum == $n
}

fn perfect_numbers($max) {
    2..$max |> filter { is_perfect($_) }
}

assert_ok is_perfect(6), "6 is perfect (1+2+3)"
assert_ok is_perfect(28), "28 is perfect (1+2+4+7+14)"
assert_ok is_perfect(496), "496 is perfect"

assert_ok !is_perfect(1), "1 is not perfect"
assert_ok !is_perfect(12), "12 is not perfect"
assert_ok !is_perfect(100), "100 is not perfect"

my @perfects = perfect_numbers(500)
assert_eq join(",", @perfects), "6,28,496", "perfect numbers up to 500"

my @div6 = divisors(6)
assert_eq join(",", @div6), "1,2,3", "divisors of 6"

my @div28 = divisors(28)
assert_eq join(",", @div28), "1,2,4,7,14", "divisors of 28"

test_run
