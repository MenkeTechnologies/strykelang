#!/usr/bin/env stryke
# Rosetta Code: Pick random element
# Pure utility on top of stryke's `rand` builtin. Returns one element
# uniformly at random from a non-empty array.

fn Rosetta::Pick::one(@arr) {
    return undef if len(@arr) == 0
    $arr[int(rand(len(@arr)))]
}

fn Rosetta::Pick::n($arr_ref, $n) {
    var @out
    for val $i (~> 1:$n) {
        push @out, Rosetta::Pick::one(@$arr_ref)
    }
    @out
}

# Single-element array always returns that element
val @single = ("only")
for val $i (~> 1:50) {
    assert_eq Rosetta::Pick::one(@single), "only", "single-element pick"
}

# Empty
assert_ok !defined(Rosetta::Pick::one()), "empty array → undef"

# Picks come from input set only
val @set = (10, 20, 30, 40, 50)
val %allowed = map { _ => 1 } @set
val @samples = Rosetta::Pick::n(\@set, 200)
var $all_in = 1
for val $s (@samples) { $all_in = 0 if !exists $allowed{$s} }
assert_ok $all_in, "every pick belongs to source array"

# Distribution sanity: every element appears at least once across 5000 picks
val @big_samples = Rosetta::Pick::n(\@set, 5000)
var %seen
for val $s (@big_samples) { $seen{$s}++ }
var $coverage = 1
for val $e (@set) { $coverage = 0 if !exists $seen{$e} }
assert_ok $coverage, "every input element appears in 5000 picks"

# Pipe form
val @vals = ("a", "b", "c")
val $p = Rosetta::Pick::one(@vals)
assert_ok defined($p), "pipe pick returns something"

test_run
