#!/usr/bin/env stryke
# Rosetta Code: Queue

fn my_queue_new {
    ([])
}

fn my_queue_enqueue($q, $val) {
    push @$q, $val
    $q
}

fn my_queue_dequeue($q) {
    shift @$q
}

fn my_queue_empty($q) {
    scalar(@$q) == 0
}

my $q = my_queue_new()
$q |> my_queue_enqueue("a") |> my_queue_enqueue("b")

assert_eq my_queue_dequeue($q), "a", "dequeue a"
assert_eq my_queue_dequeue($q), "b", "dequeue b"
assert_ok my_queue_empty($q), "queue empty"

# Threaded queue
~> my_queue_new() my_queue_enqueue(1) my_queue_enqueue(2) |> my_queue_dequeue |> assert_eq(1, "threaded dequeue")

test_run
