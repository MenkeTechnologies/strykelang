#!/usr/bin/env stryke
# Rosetta Code: Queue

fn Rosetta::Queue::new {
    []
}

fn Rosetta::Queue::enqueue($q, $val) {
    push @$q, $val
    $q
}

fn Rosetta::Queue::dequeue($q) {
    shift @$q
}

fn Rosetta::Queue::is_empty($q) {
    len(@$q) == 0
}

my $q = Rosetta::Queue::new()
$q |> Rosetta::Queue::enqueue("a") |> Rosetta::Queue::enqueue("b")

assert_eq Rosetta::Queue::dequeue($q), "a", "dequeue a"
assert_eq Rosetta::Queue::dequeue($q), "b", "dequeue b"
assert_ok Rosetta::Queue::is_empty($q), "queue empty"

# Pipe-forward queue
my $q2 = Rosetta::Queue::new() |> Rosetta::Queue::enqueue(1) |> Rosetta::Queue::enqueue(2)
assert_eq Rosetta::Queue::dequeue($q2), 1, "pipe-forward dequeue"

test_run
