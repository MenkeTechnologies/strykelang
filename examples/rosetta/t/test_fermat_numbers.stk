#!/usr/bin/env stryke
# Rosetta Code: Fermat numbers

fn Rosetta::Fermat::compute($n) {
    (2**(2**$n)) + 1
}

assert_eq Rosetta::Fermat::compute(0), 3, "F0"
assert_eq Rosetta::Fermat::compute(1), 5, "F1"
assert_eq Rosetta::Fermat::compute(2), 17, "F2"
assert_eq Rosetta::Fermat::compute(3), 257, "F3"
assert_eq Rosetta::Fermat::compute(4), 65537, "F4"

3 |> Rosetta::Fermat::compute |> assert_eq(257, "pipe fermat")

test_run
