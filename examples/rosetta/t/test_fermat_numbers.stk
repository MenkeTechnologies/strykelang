#!/usr/bin/env stryke
# Rosetta Code: Fermat numbers

fn fermat($n) {
    (2**(2**$n)) + 1
}

assert_eq fermat(0), 3, "F0"
assert_eq fermat(1), 5, "F1"
assert_eq fermat(2), 17, "F2"
assert_eq fermat(3), 257, "F3"
assert_eq fermat(4), 65537, "F4"

3 |> fermat |> assert_eq(257, "pipe fermat")

test_run
