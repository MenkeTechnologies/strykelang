#!/usr/bin/env stryke
# Rosetta Code: Count occurrences of a substring (using pipes)

fn Rosetta::CountSubstring::solve($text, $sub) {
    # Using split to count occurrences
    my @parts = $text |> split($sub)
    len(@parts) - 1
}

assert_eq Rosetta::CountSubstring::solve("the three truths", "th"), 3, "count 'th' in 'the three truths'"
assert_eq Rosetta::CountSubstring::solve("ababababab", "abab"), 2, "count 'abab' in 'ababababab'" # Note: split might not handle overlapping, Rosetta Code usually means non-overlapping

test_run
