#!/usr/bin/env stryke
# Rosetta Code: Dot product (using zip, map, and reduce with pipes)

fn Rosetta::DotProduct::solve($a, $b) {
    zip(@$a, @$b) |> map { $_->[0] * $_->[1] } |> sum()
}

my @vec1 = (1, 3, -5)
my @vec2 = (4, -2, -1)
# 1*4 + 3*(-2) + (-5)*(-1) = 4 - 6 + 5 = 3

assert_eq Rosetta::DotProduct::solve(\@vec1, \@vec2), 3, "dot product of [1, 3, -5] and [4, -2, -1]"

test_run
