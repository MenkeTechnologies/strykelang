#!/usr/bin/env stryke
# Rosetta Code: Deconvolution/1D

fn Rosetta::Deconvolution::run($h, $f) {
    # h = f * g. Find g.
    # Using polynomial long division.
    my @h = @$h
    my @f = @$f
    my @g
    
    my $len_g = len(@h) - len(@f) + 1
    for (my $i = 0; $i < $len_g; $i++) {
        my $coeff = $h[$i] / $f[0]
        push @g, $coeff
        
        # Subtract coeff * f from h starting at index i
        for (my $j = 0; $j < len(@f); $j++) {
            $h[$i + $j] -= $coeff * $f[$j]
        }
    }
    \@g
}

# Example: f = [1, 2, 3], g = [4, 5, 6]
# Convolution h = f * g = [4, 13, 28, 27, 18]
my $h = [4, 13, 28, 27, 18]
my $f = [1, 2, 3]
my $g = Rosetta::Deconvolution::run($h, $f)

assert_eq $g->[0], 4, "g_0 matches"
assert_eq $g->[1], 5, "g_1 matches"
assert_eq $g->[2], 6, "g_2 matches"

test_run
