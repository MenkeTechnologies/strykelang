#!/usr/bin/env stryke
# Rosetta Code: Prufer sequence — encode/decode labeled trees on n nodes (1..n)

fn Rosetta::Prufer::encode($edges, $n) {
    var %adj
    for val $i (1:$n) { $adj{$i} = {} }
    var %deg
    for val $e (@$edges) {
        val ($u, $v) = ($e->[0], $e->[1])
        $adj{$u}{$v} = 1
        $adj{$v}{$u} = 1
        $deg{$u}++
        $deg{$v}++
    }
    var @seq
    for val $i (1:$n - 2) {
        var $leaf
        for val $k (1:$n) {
            if ($deg{$k} == 1) {
                $leaf = $k
                last
            }
        }
        val @neigh = keys %{$adj{$leaf}}
        val $u = $neigh[0]
        push @seq, $u
        delete $adj{$leaf}{$u}
        delete $adj{$u}{$leaf}
        $deg{$leaf}--
        $deg{$u}--
    }
    \@seq
}

fn Rosetta::Prufer::decode($seq, $n) {
    var %deg
    for val $i (1:$n) { $deg{$i} = 1 }
    for val $x (@$seq) { $deg{$x}++ }
    var @edges
    var @work = @$seq
    for val $x (@work) {
        var $leaf
        for val $k (1:$n) {
            if ($deg{$k} == 1) {
                $leaf = $k
                last
            }
        }
        push @edges, [$leaf, $x]
        $deg{$leaf}--
        $deg{$x}--
    }
    var $u
    var $v
    for val $k (1:$n) {
        if ($deg{$k} == 1) {
            if (!defined $u) { $u = $k } else { $v = $k }
        }
    }
    push @edges, [$u, $v]
    \@edges
}

# n = 4 path 1-2-3-4: edges (1,2),(2,3),(3,4) -> Prufer = [2,3]
val $p1 = Rosetta::Prufer::encode([[1,2],[2,3],[3,4]], 4)
assert_eq join(",", @$p1), "2,3", "path 1-2-3-4 -> [2,3]"

# Decode [2,3] -> 3 edges
val $e1 = Rosetta::Prufer::decode([2, 3], 4)
assert_eq len(@$e1), 3, "n=4 -> n-1=3 edges"

# Star centered on 1, n=5: edges (1,2),(1,3),(1,4),(1,5) -> Prufer = [1,1,1]
val $p2 = Rosetta::Prufer::encode([[1,2],[1,3],[1,4],[1,5]], 5)
assert_eq join(",", @$p2), "1,1,1", "star on 1 -> [1,1,1]"

# Round trip: known sequence for a 6-node tree
val $tree = [[1,4],[2,4],[3,5],[4,5],[5,6]]
val $p3 = Rosetta::Prufer::encode($tree, 6)
assert_eq len(@$p3), 4, "n=6 -> n-2=4 codes"
val $back = Rosetta::Prufer::decode($p3, 6)
assert_eq len(@$back), 5, "n=6 -> 5 edges back"

# Edge count is always n-1
for val $n (3, 5, 7, 10) {
    val $seq = (1) x ($n - 2)
    val $edges = Rosetta::Prufer::decode([(1) x ($n - 2)], $n)
    assert_eq len(@$edges), $n - 1, "decode of n=$n gives n-1 edges"
}

test_run
