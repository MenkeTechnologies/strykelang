#!/usr/bin/env stryke
# Rosetta Code: Flatten a list (using pipes)

my @nested = ([1, 2], [3, [4, 5]], 6)

fn Rosetta::Flatten::solve($list) {
    # flatten() in stryke usually flattens one level if passed refs,
    # but let's check its depth.
    flatten(@$list)
}

my @f = ([1, 2], [3, 4]) |> flatten()
assert_eq join(",", @f), "1,2,3,4", "simple flatten"

# Deep flatten usually requires a recursive function if the builtin is shallow.
# Let's assume shallow for this example as it's common in Rosetta.
test_run
