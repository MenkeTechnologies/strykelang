#!/usr/bin/env stryke
# Rosetta Code: Abelian sandpile model/Identity

# Stabilization function
fn Rosetta::Sandpile::stabilize($grid, $size) {
    var $toppled = 1
    while ($toppled) {
        $toppled = 0
        for val $y (0:($size - 1)) {
            for val $x (0:($size - 1)) {
                if ($grid->[$y]->[$x] >= 4) {
                    val $count = int($grid->[$y]->[$x] / 4)
                    $grid->[$y]->[$x] %= 4
                    for val $d ([-1, 0], [1, 0], [0, -1], [0, 1]) {
                        val $ny = $y + $d->[0]
                        val $nx = $x + $d->[1]
                        if ($ny >= 0 && $ny < $size && $nx >= 0 && $nx < $size) {
                            $grid->[$ny]->[$nx] += $count
                        }
                    }
                    $toppled = 1
                }
            }
        }
    }
}

fn Rosetta::Sandpile::identity($size) {
    # 1. Start with 6 grains everywhere
    val @z = 1:$size |> map { val @r = 1:$size |> map { 6 }; \@r }
    
    # 2. Stabilize z to get s(z)
    # We need a copy because stabilize modifies in place
    val @sz = 1:$size |> map { val @r = 1:$size |> map { 6 }; \@r }
    Rosetta::Sandpile::stabilize(\@sz, $size)
    
    # 3. id = z - s(z) stabilized
    val @id = 1:$size |> map {
        val $y = _ - 1
        val @r = 1:$size |> map {
            val $x = _ - 1
            6 - $sz[$y]->[$x]
        }
        \@r
    }
    Rosetta::Sandpile::stabilize(\@id, $size)
    return \@id
}

fn Rosetta::Sandpile::display($grid) {
    for val $row (@$grid) {
        @$row |> join(" ") |> p
    }
}

fn Rosetta::Sandpile::demo_identity() {
    val $size = 5
    ("Abelian Sandpile Identity (" . $size . "x" . $size . "):") |> p
    val $id = Rosetta::Sandpile::identity($size)
    Rosetta::Sandpile::display($id)
    
    # Test assertions
    # The identity element is the same as the stabilization of (6,6,6...) - stabilization(6,6,6...)
    # For 5x5, the center is 0.
    assert_eq $id->[2]->[2], 0, "5x5 identity center should be 0"
    assert_eq $id->[0]->[0], 2, "5x5 identity corner (0,0) should be 2"
    assert_eq $id->[0]->[1], 3, "5x5 identity (0,1) should be 3"
}

Rosetta::Sandpile::demo_identity()
test_run
