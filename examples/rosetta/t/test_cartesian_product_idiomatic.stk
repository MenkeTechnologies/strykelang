#!/usr/bin/env stryke
# Rosetta Code: Cartesian product

fn Rosetta::CartesianProduct::solve($sets) {
    var @res = ([])
    for val $s (@$sets) {
        var @new_res
        for val $p (@res) {
            for val $x (@$s) {
                push @new_res, [ @$p, $x ]
            }
        }
        @res = @new_res
    }
    \@res
}

val $s1 = [1, 2]
val $s2 = [3, 4]
val $cp = Rosetta::CartesianProduct::solve([$s1, $s2])
# [1,3], [1,4], [2,3], [2,4]
assert_eq len(@$cp), 4, "4 elements in CP"
assert_eq join(",", @{$cp->[0]}), "1,3", "first element"
assert_eq join(",", @{$cp->[-1]}), "2,4", "last element"

# Parallel map test
val @sets = ([1,2], [3,4], [5,6])
val $cp3 = Rosetta::CartesianProduct::solve(\@sets)
assert_eq len(@$cp3), 8, "2^3 = 8 elements in CP"

test_run
