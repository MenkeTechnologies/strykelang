#!/usr/bin/env stryke
# Rosetta Code: RSA cipher

fn Rosetta::RSA::gcd($a, $b) {
    while ($b) {
        ($a, $b) = ($b, $a % $b)
    }
    $a
}

fn Rosetta::RSA::mod_inverse($a, $m) {
    var ($m0, $x0, $x1) = ($m, 0, 1)
    return 0 if $m == 1
    while ($a > 1) {
        val $q = $a / $m | 0
        var $t = $m
        $m = $a % $m
        $a = $t
        $t = $x0
        $x0 = $x1 - $q * $x0
        $x1 = $t
    }
    $x1 < 0 ? $x1 + $m0 : $x1
}

fn Rosetta::RSA::mod_pow($base, $exp, $mod) {
    var $res = 1
    $base %= $mod
    while ($exp > 0) {
        if ($exp % 2 == 1) {
            $res = ($res * $base) % $mod
        }
        $base = ($base * $base) % $mod
        $exp = $exp / 2 | 0
    }
    $res
}

fn Rosetta::RSA::generate_keys($p, $q) {
    val $n = $p * $q
    val $phi = ($p - 1) * ($q - 1)
    
    var $e = 3
    while (Rosetta::RSA::gcd($e, $phi) != 1) {
        $e += 2
    }
    
    val $d = Rosetta::RSA::mod_inverse($e, $phi)
    # pub: (e, n), priv: (d, n)
    ([$e, $n], [$d, $n])
}

fn Rosetta::RSA::encrypt($m, $pub) {
    Rosetta::RSA::mod_pow($m, $pub->[0], $pub->[1])
}

fn Rosetta::RSA::decrypt($c, $priv) {
    Rosetta::RSA::mod_pow($c, $priv->[0], $priv->[1])
}

# Use small primes for demo (must not overflow during $base * $base)
# sqrt(2^63 - 1) is about 3e9. So $base can be up to 3e9.
# $n should be less than 3e9 if we want simple mod_pow without overflow handling.
var $p = 61
val $q = 53
val ($pub, $priv) = Rosetta::RSA::generate_keys($p, $q)

val $message = 42
val $cipher = Rosetta::RSA::encrypt($message, $pub)
val $plain = Rosetta::RSA::decrypt($cipher, $priv)

assert_eq $plain, $message, "RSA round trip for message 42"

# Test with a string (char by char for simplicity)
val $text = "Stryke"
val @ciphers = ~> $text chars map { 
    Rosetta::RSA::encrypt(ord(_), $pub) 
}
val $decoded = ~> @ciphers map { 
    chr(Rosetta::RSA::decrypt(_, $priv)) 
} |> join("")

assert_eq $decoded, $text, "RSA round trip for string 'Stryke'"

test_run
