#!/usr/bin/env stryke
# Rosetta Code: Pisano periods.
# pi(m) is the length of the cycle of (Fibonacci numbers mod m).
# OEIS A001175: pi(1..10) = 1, 3, 8, 6, 20, 24, 16, 12, 24, 60.

fn Rosetta::Pisano::period($m) {
    return 0 if $m < 1
    return 1 if $m == 1
    my ($_0, $_1) = (0, 1)
    for my $i (1 .. $m * 6) {
        ($_0, $_1) = ($_1, ($_0 + $_1) % $m)
        return $i if $_0 == 0 && $_1 == 1
    }
    -1
}

# OEIS A001175 first 10.
my @pi = ~> 1:10 map { Rosetta::Pisano::period($_) }
assert_eq join(",", @pi),
    "1,3,8,6,20,24,16,12,24,60",
    "Pisano periods 1..10"

assert_eq Rosetta::Pisano::period(11), 10, "pi(11) = 10"
assert_eq Rosetta::Pisano::period(12), 24, "pi(12) = 24"
assert_eq Rosetta::Pisano::period(100), 300, "pi(100) = 300"

test_run
