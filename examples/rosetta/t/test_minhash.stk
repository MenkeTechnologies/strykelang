#!/usr/bin/env stryke
# Rosetta Code: MinHash

fn Rosetta::MinHash::hash($s, $seed) {
    # Simple hash function variant
    var $hash = $seed
    for val $c ($s |> chars() |> map {ord}) {
        $hash = (($hash * 31) + $c) % 4294967296
    }
    $hash
}

fn Rosetta::MinHash::solve($str1, $str2, $num_hashes) {
    # Generate shingles (e.g. k=3)
    val @s1 = $str1 |> chars()
    val @s2 = $str2 |> chars()
    
    var %shingles1
    for (var $i = 0; $i < len(@s1) - 2; $i++) {
        $shingles1{$s1[$i] . $s1[$i+1] . $s1[$i+2]} = 1
    }
    
    var %shingles2
    for (var $i = 0; $i < len(@s2) - 2; $i++) {
        $shingles2{$s2[$i] . $s2[$i+1] . $s2[$i+2]} = 1
    }
    
    var @k1 = keys %shingles1
    var @k2 = keys %shingles2
    
    # Compute minhash signatures
    var @sig1
    var @sig2
    
    for (var $i = 0; $i < $num_hashes; $i++) {
        val $seed = $i * 12345 + 67890
        
        var $min1 = 1e18
        for val $sh (@k1) {
            val $h = Rosetta::MinHash::hash($sh, $seed)
            if ($h < $min1) { $min1 = $h }
        }
        push @sig1, $min1
        
        var $min2 = 1e18
        for val $sh (@k2) {
            val $h = Rosetta::MinHash::hash($sh, $seed)
            if ($h < $min2) { $min2 = $h }
        }
        push @sig2, $min2
    }
    
    # Estimate Jaccard similarity
    var $matches = 0
    for (var $i = 0; $i < $num_hashes; $i++) {
        if ($sig1[$i] == $sig2[$i]) {
            $matches++
        }
    }
    
    $matches / $num_hashes
}

val $s1 = "the quick brown fox jumps over the lazy dog"
val $s2 = "the quick brown dog jumps over the lazy fox"

val $sim = Rosetta::MinHash::solve($s1, $s2, 100)
# Should have a relatively high similarity since they share many shingles
assert_ok $sim > 0.5, "Minhash similarity > 0.5"

val $s3 = "a completely different sentence"
val $sim2 = Rosetta::MinHash::solve($s1, $s3, 100)
assert_ok $sim2 < 0.2, "Minhash similarity < 0.2"

test_run
