#!/usr/bin/env stryke
# Rosetta Code: 2D maximum subarray (Kadane's 2D). Find the contiguous
# rectangle in a 2D matrix with the largest sum in O(n²·m) by fixing
# row pairs and running 1D Kadane on the column sums.

fn Rosetta::Kadane2D::max_subarray_1d($arr) {
    val $n = len(@$arr)
    var $best = -1e18
    var $best_lo = 0
    var $best_hi = 0
    var $cur = 0
    var $cur_lo = 0
    for val $i (~> 0:$n - 1) {
        if ($cur <= 0) {
            $cur = $arr->[$i]
            $cur_lo = $i
        } else {
            $cur += $arr->[$i]
        }
        if ($cur > $best) {
            $best = $cur
            $best_lo = $cur_lo
            $best_hi = $i
        }
    }
    { sum => $best, lo => $best_lo, hi => $best_hi }
}

fn Rosetta::Kadane2D::solve($matrix) {
    val $rows = len(@$matrix)
    return { sum => 0, top => 0, bottom => 0, left => 0, right => 0 } if $rows == 0
    val $cols = len(@{$matrix->[0]})
    var $best = -1e18
    var $best_top = 0; var $best_bottom = 0
    var $best_left = 0; var $best_right = 0
    for val $top (~> 0:$rows - 1) {
        var @col_sums = ~> 1:$cols |> map { 0 }
        for val $bottom ($top:$rows - 1) {
            for val $c (~> 0:$cols - 1) { $col_sums[$c] += $matrix->[$bottom][$c] }
            val $r = Rosetta::Kadane2D::max_subarray_1d(\@col_sums)
            if ($r->{sum} > $best) {
                $best = $r->{sum}
                $best_top = $top
                $best_bottom = $bottom
                $best_left = $r->{lo}
                $best_right = $r->{hi}
            }
        }
    }
    {
        sum => $best,
        top => $best_top, bottom => $best_bottom,
        left => $best_left, right => $best_right
    }
}

fn Rosetta::Kadane2D::naive_sum($m, $top, $left, $bottom, $right) {
    var $s = 0
    for val $i ($top:$bottom) {
        for val $j ($left:$right) { $s += $m->[$i][$j] }
    }
    $s
}

# Canonical example with mixed signs.
# Expected best rect: rows 1..3, cols 1..3 with sum 29.
val $m1 = [
    [ 1,  2, -1, -4, -20],
    [-8, -3,  4,  2,   1],
    [ 3,  8, 10,  1,   3],
    [-4, -1,  1,  7,  -6]
]
val $r1 = Rosetta::Kadane2D::solve($m1)
assert_eq $r1->{sum}, 29, "canonical max sum = 29"
# Verify the reported rectangle has the claimed sum.
assert_eq Rosetta::Kadane2D::naive_sum($m1, $r1->{top}, $r1->{left},
    $r1->{bottom}, $r1->{right}), 29, "rect sum matches"

# All positive matrix: best is the whole thing.
val $m2 = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]
val $r2 = Rosetta::Kadane2D::solve($m2)
assert_eq $r2->{sum}, 45, "all-positive whole matrix"
assert_eq $r2->{top}, 0, "top=0"
assert_eq $r2->{bottom}, 2, "bottom=2"
assert_eq $r2->{left}, 0, "left=0"
assert_eq $r2->{right}, 2, "right=2"

# All negative: best is the largest single value.
val $m3 = [
    [-3, -2, -1],
    [-5, -4, -7],
    [-2, -1, -8]
]
val $r3 = Rosetta::Kadane2D::solve($m3)
assert_eq $r3->{sum}, -1, "all-negative max single = -1"

# Single row
val $r4 = Rosetta::Kadane2D::solve([[-2, 1, -3, 4, -1, 2, 1, -5, 4]])
assert_eq $r4->{sum}, 6, "1xN: classic Kadane = 6"
assert_eq $r4->{top}, 0,  "top=0"
assert_eq $r4->{left}, 3, "left=3"
assert_eq $r4->{right}, 6, "right=6"

# Single column
val $r5 = Rosetta::Kadane2D::solve([[1], [2], [-100], [3], [4], [-1], [5]])
assert_eq $r5->{sum}, 11, "Nx1 = 3+4-1+5 = 11"

# Single cell
val $r6 = Rosetta::Kadane2D::solve([[42]])
assert_eq $r6->{sum}, 42, "single cell"

# Empty input
val $r7 = Rosetta::Kadane2D::solve([])
assert_eq $r7->{sum}, 0, "empty matrix sum = 0"

# 1D Kadane sanity
val $kr = Rosetta::Kadane2D::max_subarray_1d([-2, 1, -3, 4, -1, 2, 1, -5, 4])
assert_eq $kr->{sum}, 6, "1D classic"
assert_eq $kr->{lo}, 3, "lo = 3"
assert_eq $kr->{hi}, 6, "hi = 6"

test_run
