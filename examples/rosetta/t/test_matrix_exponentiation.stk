#!/usr/bin/env stryke
# Rosetta Code: Matrix exponentiation

fn my_matrix_mul($a, $b) {
    my $m = scalar(@$a)
    my $n = scalar(@{$a->[0]})
    my $p = scalar(@{$b->[0]})
    my @res = ()
    for my $i (0..$m-1) {
        $res[$i] = []
        for my $j (0..$p-1) {
            my $sum = 0
            for my $k (0..$n-1) {
                $sum += $a->[$i][$k] * $b->[$k][$j]
            }
            $res[$i][$j] = $sum
        }
    }
    \@res
}

fn my_matrix_pow($a, $n) {
    my $size = scalar(@$a)
    my @res = ()
    for my $i (0..$size-1) {
        $res[$i] = []
        for my $j (0..$size-1) {
            $res[$i][$j] = ($i == $j ? 1 : 0)
        }
    }
    my $base = $a
    my $curr_n = $n
    while ($curr_n > 0) {
        if ($curr_n % 2 == 1) {
            my $tmp = my_matrix_mul([@res], $base)
            @res = @$tmp
        }
        my $tmp2 = my_matrix_mul($base, $base)
        $base = $tmp2
        $curr_n = int($curr_n / 2)
    }
    \@res
}

my $m = [[1, 1], [1, 0]]
my $res = my_matrix_pow($m, 5)
# Fibonacci matrix power 5 should be [[8, 5], [5, 3]]
assert_eq $res->[0][0], 8, "Fib(6)"
assert_eq $res->[0][1], 5, "Fib(5)"
assert_eq $res->[1][0], 5, "Fib(5)"
assert_eq $res->[1][1], 3, "Fib(4)"

test_run
