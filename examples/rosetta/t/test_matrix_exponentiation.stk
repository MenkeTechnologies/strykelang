#!/usr/bin/env stryke
# Rosetta Code: Matrix exponentiation

fn Rosetta::MatrixPow::mul($a, $b) {
    val $m = len(@$a)
    val $n = len(@{$a->[0]})
    val $p = len(@{$b->[0]})
    var @res = ()
    for val $i (0:$m-1) {
        $res[$i] = []
        for val $j (0:$p-1) {
            var $sum = 0
            for val $k (0:$n-1) {
                $sum += $a->[$i][$k] * $b->[$k][$j]
            }
            $res[$i][$j] = $sum
        }
    }
    \@res
}

fn Rosetta::MatrixPow::compute($a, $n) {
    val $size = len(@$a)
    var @res = ()
    for val $i (0:$size-1) {
        $res[$i] = []
        for val $j (0:$size-1) {
            $res[$i][$j] = ($i == $j ? 1 : 0)
        }
    }
    var $base = $a
    var $curr_n = $n
    while ($curr_n > 0) {
        if ($curr_n % 2 == 1) {
            val $tmp = Rosetta::MatrixPow::mul([@res], $base)
            @res = @$tmp
        }
        val $tmp2 = Rosetta::MatrixPow::mul($base, $base)
        $base = $tmp2
        $curr_n = int($curr_n / 2)
    }
    \@res
}

val $m = [[1, 1], [1, 0]]
val $res = Rosetta::MatrixPow::compute($m, 5)
# Fibonacci matrix power 5 should be [[8, 5], [5, 3]]
assert_eq $res->[0][0], 8, "Fib(6)"
assert_eq $res->[0][1], 5, "Fib(5)"
assert_eq $res->[1][0], 5, "Fib(5)"
assert_eq $res->[1][1], 3, "Fib(4)"

test_run
