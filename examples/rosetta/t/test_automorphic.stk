#!/usr/bin/env stryke
# Rosetta Code: Automorphic numbers

fn Rosetta::Automorphic::check($n) {
    my $sq = $n * $n
    my $s_n = "$n"
    my $s_sq = "$sq"
    my $len = length($s_n)
    my $end = substr($s_sq, length($s_sq) - $len)
    $end eq $s_n
}

assert_ok Rosetta::Automorphic::check(1), "1 is automorphic"
assert_ok Rosetta::Automorphic::check(5), "5 is automorphic (25)"
assert_ok Rosetta::Automorphic::check(6), "6 is automorphic (36)"
assert_ok Rosetta::Automorphic::check(25), "25 is automorphic (625)"
assert_ok Rosetta::Automorphic::check(76), "76 is automorphic (5776)"
assert_ok !Rosetta::Automorphic::check(7), "7 is not (49)"

25 |> Rosetta::Automorphic::check |> assert_ok("pipe automorphic")

test_run
