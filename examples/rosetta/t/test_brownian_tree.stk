#!/usr/bin/env stryke
# Rosetta Code: Brownian tree

fn Rosetta::BrownianTree::generate($size, $num_particles) {
    var @grid
    for (0..($size - 1)) {
        var @row
        for (0..($size - 1)) { push @row, 0 }
        push @grid, \@row
    }
    
    # Seed at the center
    val $cx = int($size / 2)
    val $cy = int($size / 2)
    $grid[$cy]->[$cx] = 1
    
    var $count = 0
    while ($count < $num_particles) {
        # Release from random point on boundary
        var ($px, $py)
        if (rand() < 0.5) {
            $px = int(rand($size))
            $py = rand() < 0.5 ? 0 : $size - 1
        } else {
            $px = rand() < 0.5 ? 0 : $size - 1
            $py = int(rand($size))
        }
        
        # Random walk
        while (1) {
            val $dx = int(rand(3)) - 1
            val $dy = int(rand(3)) - 1
            $px += $dx
            $py += $dy
            
            # Clamp to grid
            $px = 0 if $px < 0; $px = $size - 1 if $px >= $size
            $py = 0 if $py < 0; $py = $size - 1 if $py >= $size
            
            # Check neighbors for stickiness
            var $touches = 0
            for (var $nx = $px - 1; $nx <= $px + 1; $nx++) {
                for (var $ny = $py - 1; $ny <= $py + 1; $ny++) {
                    next if $nx < 0 || $nx >= $size || $ny < 0 || $ny >= $size
                    if ($grid[$ny]->[$nx] == 1) {
                        $touches = 1
                        last
                    }
                }
                last if $touches
            }
            
            if ($touches) {
                $grid[$py]->[$px] = 1
                $count++
                last
            }
            
            # If it gets too far from center, just restart to save time (not strictly DLA but common optimization)
            val $dist_sq = ($px - $cx)**2 + ($py - $cy)**2
            if ($dist_sq > ($size/2)**2) {
                last
            }
        }
    }
    \@grid
}

val $size = 20
val $tree = Rosetta::BrownianTree::generate($size, 50)
assert_eq len(@$tree), $size, "Tree grid height matches"
assert_eq len(@{$tree->[0]}), $size, "Tree grid width matches"

# Verify there is at least one point set
var $found = 0
for val $row (@$tree) {
    for val $cell (@$row) {
        $found = 1 if $cell == 1
    }
}
assert_eq $found, 1, "At least one point in Brownian tree"

test_run
