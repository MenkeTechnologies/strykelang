#!/usr/bin/env stryke
# Rosetta Code: Hash from two arrays — pair up keys and values

fn Rosetta::HashFromArrays::build($keys, $vals) {
    my %h
    my $n = len(@$keys)
    for my $i (0..$n-1) {
        $h{$keys->[$i]} = $vals->[$i]
    }
    \%h
}

# Idiomatic stryke: zip + reduce
fn Rosetta::HashFromArrays::zip_build($keys, $vals) {
    my $n = len(@$keys)
    my %h
    ~> 0:$n-1 map { $h{$keys->[_]} = $vals->[_] }
    \%h
}

my @ks = ("red", "green", "blue", "yellow")
my @vs = (1, 2, 3, 4)

my $h = Rosetta::HashFromArrays::build(\@ks, \@vs)
assert_eq $h->{red}, 1, "red => 1"
assert_eq $h->{green}, 2, "green => 2"
assert_eq $h->{blue}, 3, "blue => 3"
assert_eq $h->{yellow}, 4, "yellow => 4"
assert_eq len(keys %$h), 4, "4 keys total"

my $h2 = Rosetta::HashFromArrays::zip_build(\@ks, \@vs)
assert_eq $h2->{blue}, 3, "zip variant blue => 3"

# Empty arrays produce empty hash
my @ek; my @ev
my $eh = Rosetta::HashFromArrays::build(\@ek, \@ev)
assert_eq len(keys %$eh), 0, "empty arrays -> empty hash"

test_run
