#!/usr/bin/env stryke
# Rosetta Code: Bezout's identity — for integers a, b, find x, y such
# that ax + by = gcd(a, b). Extended Euclidean algorithm.

fn Rosetta::Bezout::extended($a, $b) {
    my $old_r = $a; my $r = $b
    my $old_s = 1; my $s = 0
    my $old_t = 0; my $t = 1
    while ($r != 0) {
        my $q = int($old_r / $r)
        ($old_r, $r) = ($r, $old_r - $q * $r)
        ($old_s, $s) = ($s, $old_s - $q * $s)
        ($old_t, $t) = ($t, $old_t - $q * $t)
    }
    { gcd => $old_r, x => $old_s, y => $old_t }
}

# Modular inverse via Bezout: a · x ≡ 1 (mod n) iff gcd(a, n) = 1.
fn Rosetta::Bezout::mod_inverse($a, $n) {
    my $r = Rosetta::Bezout::extended($a, $n)
    return undef if $r->{gcd} != 1
    (($r->{x} % $n) + $n) % $n
}

# Solve ax ≡ b (mod n): existence iff gcd(a, n) | b.
fn Rosetta::Bezout::solve_linear_congruence($a, $b, $n) {
    my $r = Rosetta::Bezout::extended($a, $n)
    my $g = $r->{gcd}
    return undef if $b % $g != 0
    my $x = ($r->{x} * int($b / $g)) % $n
    (($x % $n) + $n) % $n
}

# Verify Bezout identity for many a, b pairs.
my @cases = (
    [240, 46], [99, 78], [1, 5], [12, 18],
    [97, 64], [101, 7], [12345, 6789],
    [1000, 1001], [54321, 12345]
)
for my $c (@cases) {
    my ($a, $b) = @$c
    my $r = Rosetta::Bezout::extended($a, $b)
    my $check = $a * $r->{x} + $b * $r->{y}
    assert_eq $check, $r->{gcd}, "$a · ${\$r->{x}} + $b · ${\$r->{y}} = ${\$r->{gcd}}"
}

# Specific known values from CLRS / Wikipedia.
# gcd(99, 78) = 3 with 99·-11 + 78·14 = 3
my $r1 = Rosetta::Bezout::extended(99, 78)
assert_eq $r1->{gcd}, 3, "gcd(99, 78) = 3"
assert_eq 99 * $r1->{x} + 78 * $r1->{y}, 3, "Bezout 99/78"

# gcd(240, 46) = 2 with 240·-9 + 46·47 = 2
my $r2 = Rosetta::Bezout::extended(240, 46)
assert_eq $r2->{gcd}, 2, "gcd(240, 46) = 2"

# Coprime: gcd = 1
my $r3 = Rosetta::Bezout::extended(101, 7)
assert_eq $r3->{gcd}, 1, "gcd(101, 7) = 1 (coprime)"

# Modular inverse
assert_eq Rosetta::Bezout::mod_inverse(3, 11), 4,  "3⁻¹ mod 11 = 4"
assert_eq Rosetta::Bezout::mod_inverse(7, 26), 15, "7⁻¹ mod 26 = 15"
assert_eq Rosetta::Bezout::mod_inverse(2, 5), 3,   "2⁻¹ mod 5 = 3"
assert_ok !defined Rosetta::Bezout::mod_inverse(4, 6),  "no inverse: gcd(4,6)≠1"

# Linear congruence
# 14x ≡ 30 (mod 100): gcd(14, 100) = 2 | 30, has 2 solutions mod 100.
# Smallest non-negative: 95.
assert_eq Rosetta::Bezout::solve_linear_congruence(14, 30, 100), 95, "14x ≡ 30 (mod 100)"
assert_ok !defined Rosetta::Bezout::solve_linear_congruence(4, 5, 6),
    "no solution: gcd(4,6)∤5"
assert_eq Rosetta::Bezout::solve_linear_congruence(3, 1, 11), 4, "3x ≡ 1 (mod 11)"

test_run
