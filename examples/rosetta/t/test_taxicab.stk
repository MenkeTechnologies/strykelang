#!/usr/bin/env stryke
# Rosetta Code: Taxicab numbers

fn count_cube_sums($n) {
    my $count = 0
    my $limit = int($n**(1/3))
    for my $a (1..$limit) {
        my $a3 = $a**3
        my $rem = $n - $a3
        if ($rem > $a3) {
            my $b = int($rem**(1/3) + 0.5)
            if ($b**3 == $rem) {
                $count++
            }
        }
    }
    $count
}

assert_eq count_cube_sums(1729), 2, "1729 has 2 cube sums"
assert_eq count_cube_sums(4104), 2, "4104 has 2 cube sums (2^3+16^3, 9^3+15^3)"
assert_eq count_cube_sums(100), 0, "100 has 0 cube sums"

1729 |> count_cube_sums |> assert_eq(2, "pipe taxicab")

test_run
