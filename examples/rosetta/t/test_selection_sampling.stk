#!/usr/bin/env stryke
# Rosetta Code: Selection sampling (Algorithm S)

fn Rosetta::SelectionSampling::solve($n, $max) {
    var @sample = ()
    var $m = 0 # items selected so far
    for val $i (1:$max) {
        if (int(rand($max - $i + 1)) < ($n - $m)) {
            push @sample, $i
            $m++
        }
        if ($m == $n) { last }
    }
    \@sample
}

val $n = 3
val $max = 10
val $res = Rosetta::SelectionSampling::solve($n, $max)
assert_eq len(@$res), 3, "Sample size is 3"
# Verify elements are in range and unique
var %seen
for val $x (@$res) {
    assert_ok $x >= 1 && $x <= 10, "$x in range"
    assert_ok !exists $seen{$x}, "$x is unique"
    $seen{$x} = 1
}

test_run
