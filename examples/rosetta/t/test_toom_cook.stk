#!/usr/bin/env stryke
# Rosetta Code: Toom-Cook 3 multiplication. Splits each operand into 3
# parts and uses 5 sub-multiplies + linear combinations (vs Karatsuba's
# 3 sub-multiplies on a 2-way split).

fn Rosetta::Toom::digits($x) {
    return 1 if $x == 0
    var $d = 0
    var $n = $x < 0 ? -$x : $x
    while ($n > 0) { $d++; $n = int($n / 10) }
    $d
}

fn Rosetta::Toom::pow10($k) {
    var $r = 1
    for (~> 1:$k) { $r *= 10 }
    $r
}

fn Rosetta::Toom::split3($x, $base) {
    val $b2 = $base * $base
    val $hi = int($x / $b2)
    val $rem = $x - $hi * $b2
    val $mid = int($rem / $base)
    val $lo = $rem - $mid * $base
    [$lo, $mid, $hi]
}

fn Rosetta::Toom::mul($x, $y) {
    return $x * $y if $x < 1000 || $y < 1000
    val $n = Rosetta::Toom::digits($x)
    val $m = Rosetta::Toom::digits($y)
    val $third = int(($n > $m ? $n : $m) / 3) + 1
    val $base = Rosetta::Toom::pow10($third)
    var $a = Rosetta::Toom::split3($x, $base)
    var $b = Rosetta::Toom::split3($y, $base)
    val ($a0, $a1, $a2) = @$a
    val ($b0, $b1, $b2) = @$b

    # Evaluate at points 0, 1, -1, 2, ∞
    val $p0 = $a0
    val $p1 = $a0 + $a1 + $a2
    val $pm1 = $a0 - $a1 + $a2
    val $p2 = $a0 + 2 * $a1 + 4 * $a2
    val $pinf = $a2

    val $q0 = $b0
    val $q1 = $b0 + $b1 + $b2
    val $qm1 = $b0 - $b1 + $b2
    val $q2 = $b0 + 2 * $b1 + 4 * $b2
    val $qinf = $b2

    # 5 sub-multiplies
    val $r0 = Rosetta::Toom::mul($p0, $q0)
    val $r1 = Rosetta::Toom::mul($p1, $q1)
    val $rm1 = Rosetta::Toom::mul($pm1, $qm1)
    val $r2 = Rosetta::Toom::mul($p2, $q2)
    val $rinf = Rosetta::Toom::mul($pinf, $qinf)

    # Solve P(t) = c0 + c1·t + c2·t² + c3·t³ + c4·t⁴ given P at {0, 1, -1, 2, ∞}.
    val $c0 = $r0
    val $c4 = $rinf
    val $c2 = int(($r1 + $rm1) / 2) - $c0 - $c4
    val $c3 = int(($r2 - $c0 - 4 * $c2 - 16 * $c4 - $r1 + $rm1) / 6)
    val $c1 = int(($r1 - $rm1) / 2) - $c3

    # Compose: result = c0 + c1·B + c2·B² + c3·B³ + c4·B⁴
    val $b1pow = $base
    val $b2pow = $base * $base
    val $b3pow = $b2pow * $base
    val $b4pow = $b2pow * $b2pow
    $c0 + $c1 * $b1pow + $c2 * $b2pow + $c3 * $b3pow + $c4 * $b4pow
}

# Below the threshold the function falls through to native multiply; above it,
# the Toom-3 path actually runs. Make sure the recursion gets exercised.
assert_eq Rosetta::Toom::mul(0, 12345), 0, "0 * x"
assert_eq Rosetta::Toom::mul(7, 9), 63, "single digit"
assert_eq Rosetta::Toom::mul(123, 456), 56088, "small (native path)"

# Above the threshold (>= 1000): exercise the Toom-3 split.
assert_eq Rosetta::Toom::mul(1234, 5678), 7006652, "4-digit Toom-3"
assert_eq Rosetta::Toom::mul(12345, 67890), 838102050, "5-digit Toom-3"
assert_eq Rosetta::Toom::mul(99999, 99999), 9999800001, "near-1e5 squared"
assert_eq Rosetta::Toom::mul(123456, 987654), 121931812224, "6-digit Toom-3"
assert_eq Rosetta::Toom::mul(1000000, 1000000), 1000000000000, "1e6 * 1e6"

# Cross-validate against native multiplication on a random-ish grid.
for val $x (1234, 9999, 12345, 999999, 7777777) {
    for val $y (4321, 5555, 88888, 123456, 9999999) {
        assert_eq Rosetta::Toom::mul($x, $y), $x * $y, "$x * $y matches native"
    }
}

# Helper sanity
assert_eq Rosetta::Toom::digits(0), 1, "digits(0) = 1"
assert_eq Rosetta::Toom::digits(999), 3, "digits(999) = 3"
assert_eq Rosetta::Toom::pow10(3), 1000, "10^3"
val $sp = Rosetta::Toom::split3(123456789, 1000)
assert_eq join(",", @$sp), "789,456,123", "split3(123456789, 1000)"

test_run
