#!/usr/bin/env stryke
# Rosetta Code: Lowest path sum in a 2D matrix (move right or down).

fn Rosetta::LowestPath::sum($grid) {
    val $rows = len(@$grid)
    return 0 if $rows == 0
    val $cols = len(@{$grid->[0]})

    var @dp
    for val $r (0:$rows-1) {
        $dp[$r] = []
        for val $c (0:$cols-1) {
            val $cell = $grid->[$r]->[$c]
            if ($r == 0 && $c == 0) {
                $dp[$r][$c] = $cell
            } elsif ($r == 0) {
                val $left = $dp[$r][$c-1]
                $dp[$r][$c] = $left + $cell
            } elsif ($c == 0) {
                val $up = $dp[$r-1][$c]
                $dp[$r][$c] = $up + $cell
            } else {
                val $up   = $dp[$r-1][$c]
                val $left = $dp[$r][$c-1]
                val $best = $up < $left ? $up : $left
                $dp[$r][$c] = $best + $cell
            }
        }
    }
    $dp[$rows-1][$cols-1]
}

# 3x3 sample (LeetCode #64)
val $g1 = [
    [1, 3, 1],
    [1, 5, 1],
    [4, 2, 1]
]
# Best: 1→3→1→1→1 = 7
assert_eq Rosetta::LowestPath::sum($g1), 7, "LeetCode 3x3 sample"

# Single row
val $g2 = [[1, 2, 3, 4]]
assert_eq Rosetta::LowestPath::sum($g2), 10, "single row sums all"

# Single column
val $g3 = [[1], [2], [3], [4]]
assert_eq Rosetta::LowestPath::sum($g3), 10, "single column"

# Single cell
val $g4 = [[42]]
assert_eq Rosetta::LowestPath::sum($g4), 42, "single cell"

# Larger 4x4 with clear best path
val $g5 = [
    [1, 9, 9, 9],
    [1, 9, 9, 9],
    [1, 1, 1, 9],
    [9, 9, 1, 1]
]
# Path: 1,1,1,1,1,1,1 = 7 (via the L-shape of 1's plus cell (3,3))
assert_eq Rosetta::LowestPath::sum($g5), 7, "L-shape minimum"

# Negative-cell grid (still valid for the recurrence)
val $g6 = [
    [1, -2,  3],
    [4, -5,  6],
    [7,  8, -9]
]
# Path candidates...let's just verify the algorithm works on it (no crash) and matches manual best path:
# Path 1→-2→-5→6→-9 = -9; or 1→-2→3→6→-9 = -1; or 1→4→-5→8→-9 = -1; ... Many paths.
# 1→-2→-5→6→-9 = -9 is the lowest.
assert_eq Rosetta::LowestPath::sum($g6), -9, "negative cells supported"

test_run
