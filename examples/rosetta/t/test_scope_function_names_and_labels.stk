#!/usr/bin/env stryke
# Rosetta Code: Scope/Function names and labels

fn Rosetta::ScopeNames::helper_name() {
    "Rosetta::ScopeNames::helper_name"
}

fn Rosetta::ScopeNames::walk() {
    my @trace
    for my $outer (1 .. 3) {
        push @trace, "outer-$outer"
        for my $inner (1 .. 3) {
            push @trace, "inner-$outer-$inner"
            if ($outer == 2 && $inner == 2) {
                push @trace, "break-outer"
                return \@trace
            }
        }
    }
    \@trace
}

my $trace = Rosetta::ScopeNames::walk()

assert_eq Rosetta::ScopeNames::helper_name(), "Rosetta::ScopeNames::helper_name", "function keeps fully qualified name"
assert_eq join(",", @$trace), "outer-1,inner-1-1,inner-1-2,inner-1-3,outer-2,inner-2-1,inner-2-2,break-outer", "named outer flow is visible in trace"
assert_eq $trace->[-1], "break-outer", "outer label break point recorded"

test_run
