#!/usr/bin/env stryke
# Rosetta Code: Miller-Rabin primality test

fn power($a, $b, $m) {
    my $res = 1
    $a %= $m
    while ($b > 0) {
        if ($b % 2 == 1) { $res = ($res * $a) % $m }
        $a = ($a * $a) % $m
        $b = int($b / 2)
    }
    $res
}

fn my_miller_rabin($n, $k) {
    if ($n == 2 || $n == 3) { return 1 }
    if ($n < 2 || $n % 2 == 0) { return 0 }
    
    my $d = $n - 1
    my $s = 0
    while ($d % 2 == 0) {
        $d = int($d / 2)
        $s++
    }
    
    for my $i (1..$k) {
        my $a = 2 + int(rand($n - 4))
        my $x = power($a, $d, $n)
        if ($x == 1 || $x == $n - 1) { next }
        my $composite = 1
        for my $r (1..$s-1) {
            $x = ($x * $x) % $n
            if ($x == $n - 1) {
                $composite = 0
                last
            }
        }
        if ($composite) { return 0 }
    }
    1
}

assert_ok my_miller_rabin(13, 5), "13 is prime"
assert_ok my_miller_rabin(17, 5), "17 is prime"
assert_ok !my_miller_rabin(15, 5), "15 is not prime"
assert_ok !my_miller_rabin(100, 5), "100 is not prime"
assert_ok my_miller_rabin(101, 5), "101 is prime"

test_run
