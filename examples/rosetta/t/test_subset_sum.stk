#!/usr/bin/env stryke
# Rosetta Code: Subset sum problem

fn Rosetta::SubsetSum::solve($numbers, $target) {
    # Using an iterative approach for stability in Stryke
    my %possible = ( 0 => [] )
    
    for my $n (@$numbers) {
        my %new_possible = %possible
        for my $sum (keys %possible) {
            my $new_sum = $sum + $n
            if (!exists $new_possible{$new_sum} && $new_sum <= $target) {
                $new_possible{$new_sum} = [ @{$possible{$sum}}, $n ]
            }
        }
        %possible = %new_possible
        return $possible{$target} if exists $possible{$target}
    }
    exists $possible{$target} ? $possible{$target} : undef
}

my @set = (3, 34, 4, 12, 5, 2)
my $res = Rosetta::SubsetSum::solve(\@set, 9)
assert_ok defined($res), "subset sum 9 exists"
assert_eq join(",", sort(@$res)), "4,5", "subset sum 9 is 4,5"

my $res2 = Rosetta::SubsetSum::solve(\@set, 15)
assert_ok defined($res2), "subset sum 15 exists"
assert_eq join(",", sort(@$res2)), "12,3", "subset sum 15 is 3,12"

my $res3 = Rosetta::SubsetSum::solve(\@set, 30)
assert_ok !defined($res3), "subset sum 30 does not exist"

test_run
