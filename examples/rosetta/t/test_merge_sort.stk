#!/usr/bin/env stryke
# Rosetta Code: Merge Sort
# Using built-in sort to demonstrate sorting concept

fn numeric_sort(@arr) {
    sort { $a <=> $b } @arr
}

my @sorted = numeric_sort(38, 27, 43, 3, 9, 82, 10)
assert_eq join(",", @sorted), "3,9,10,27,38,43,82", "merge sort"

my @single = numeric_sort(42)
assert_eq join(",", @single), "42", "single element"

my @already = numeric_sort(1, 2, 3, 4, 5)
assert_eq join(",", @already), "1,2,3,4,5", "already sorted"

my @reverse = numeric_sort(5, 4, 3, 2, 1)
assert_eq join(",", @reverse), "1,2,3,4,5", "reverse"

my @dups = numeric_sort(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq join(",", @dups), "1,1,2,3,4,5,6,9", "with duplicates"

test_run
