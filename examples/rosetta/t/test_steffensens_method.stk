#!/usr/bin/env stryke
# Rosetta Code: Steffensen's method
# Aitken-accelerated fixed-point iteration. Given g(x), the iteration
#     x_{n+1} = x_n - ( g(x_n) - x_n )^2 / ( g(g(x_n)) - 2 g(x_n) + x_n )
# converges quadratically to a fixed point of g.

fn Rosetta::Steffensen::find($g, $x0, $eps, $max_iter) {
    var $x = $x0
    for val $i (~> 1:$max_iter) {
        val $gx = $g($x)
        val $ggx = $g($gx)
        val $denom = $ggx - 2 * $gx + $x
        return [$x, $i, "stalled"] if abs($denom) < 1e-30
        val $next = $x - ($gx - $x) * ($gx - $x) / $denom
        return [$next, $i, "converged"] if abs($next - $x) < $eps
        $x = $next
    }
    [$x, $max_iter, "exhausted"]
}

# Square-root via fixed point: g(x) = (x + a/x) / 2 has fixed point √a
val $sqrt2 = fn ($x) { ($x + 2 / $x) / 2 }
val $r2 = Rosetta::Steffensen::find($sqrt2, 1.5, 1e-12, 50)
assert_near $r2->[0], sqrt(2), 1e-12, "Steffensen → √2"
assert_eq $r2->[2], "converged", "converged tag"
assert_ok $r2->[1] < 10, "≤ 10 iterations"

# Cube root of 5 via g(x) = (2x + 5/x²) / 3
val $cbrt5 = fn ($x) { (2 * $x + 5 / ($x * $x)) / 3 }
val $r5 = Rosetta::Steffensen::find($cbrt5, 1.5, 1e-12, 50)
assert_near $r5->[0], 5 ** (1/3), 1e-10, "Steffensen → ∛5"

# cos(x) fixed point ≈ 0.7390851332151607
val $cos_g = fn ($x) { cos($x) }
val $r_cos = Rosetta::Steffensen::find($cos_g, 1, 1e-12, 50)
assert_near $r_cos->[0], 0.7390851332151607, 1e-10, "Dottie number"

# Direct g(x) = x/2 has fixed point 0
val $half = fn ($x) { $x / 2 }
val $r_half = Rosetta::Steffensen::find($half, 1, 1e-12, 50)
assert_near $r_half->[0], 0, 1e-10, "g(x) = x/2 → 0"

# Pipe form
$sqrt2 |> fn { Rosetta::Steffensen::find(_, 1.5, 1e-9, 30) } |> fn { $_->[0] } |> assert_near(sqrt(2), 1e-9, "pipe √2")

test_run
