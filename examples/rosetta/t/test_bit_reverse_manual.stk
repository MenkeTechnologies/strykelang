#!/usr/bin/env stryke
# Rosetta Code: Reverse bits (Manual)

fn Rosetta::BitReverse::solve($n, $bits) {
    my $res = 0
    my $curr = $n
    for my $i (1..$bits) {
        $res = ($res << 1) | ($curr & 1)
        $curr = $curr >> 1
    }
    $res
}

assert_eq Rosetta::BitReverse::solve(1, 8), 128, "reverse 1 (8 bits) is 128"
assert_eq Rosetta::BitReverse::solve(170, 8), 85, "reverse 170 (10101010) is 85 (01010101)"

test_run
