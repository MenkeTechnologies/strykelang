#!/usr/bin/env stryke
# Rosetta Code: Kurtosis

fn Rosetta::Stats::kurtosis(@data) {
    my $n = cnt(@data)
    return 0 if $n < 4
    
    my $mu = avg(@data)
    my $m2 = @data |> map { (_ - $mu) ** 2 } |> avg()
    
    return 0 if $m2 == 0
    
    my $m4 = @data |> map { (_ - $mu) ** 4 } |> avg()
    ($m4 / ($m2 ** 2)) - 3
}

my @data = (2, 4, 6, 3, 1)
# mu = 3.2. m2 = 2.96. m4 = 17.4752.
# kurtosis = 17.4752 / (2.96^2) - 3 approx -1.00548
my $kurt = Rosetta::Stats::kurtosis(@data)
assert_ok abs($kurt - (-1.00548)) < 0.001, "kurtosis of (2, 4, 6, 3, 1)"

# Normal-ish distribution would be near 0 excess kurtosis
# Uniform distribution has negative excess kurtosis
my @uniform = (1, 2, 3, 4, 5)
# mu=3. m2=2. m4=6.8. kurtosis = 6.8 / 4 - 3 = 3.4 - 3 = -1.3
my $u_kurt = Rosetta::Stats::kurtosis(@uniform)
assert_ok abs($u_kurt - (-1.3)) < 1e-10, "kurtosis of (1..5)"

test_run
