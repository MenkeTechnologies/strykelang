#!/usr/bin/env stryke
# Rosetta Code: Color wheel

fn Rosetta::ColorWheel::demo() {
    "Color Wheel (Terminal Approximation):" |> p
    
    # We use ANSI 256-color codes to approximate a color wheel.
    # The hue is mapped to the angle of the point (x, y).
    for my $y (-8:8) {
        my $line = ""
        for my $x (-16:16) {
            # Adjust x for terminal aspect ratio (approx 2:1)
            my $nx = $x / 2
            my $dist = sqrt($nx*$nx + $y*$y)
            if ($dist <= 8) {
                my $angle = atan2($y, $nx) # -PI to PI
                # Map angle to 0..255 for ANSI 256-color palette
                # Note: palette 16-231 is the 6x6x6 color cube.
                # palette 232-255 is grayscale.
                # palette 0-15 are basic colors.
                # For a better wheel, we could use a specific mapping.
                # But even a simple 0..255 mapping shows the "wheel" effect.
                my $color = 16 + int(($angle + 3.14159) / (2 * 3.14159) * 215)
                $line .= "\e[38;5;${color}m█\e[0m"
            } else {
                $line .= " "
            }
        }
        $line |> p
    }
    
    # Assertions
    assert_ok 1, "Color wheel rendered"
}

Rosetta::ColorWheel::demo()
test_run
