#!/usr/bin/env stryke
# Rosetta Code: Rep-string

fn Rosetta::RepString::find($s) {
    val $len = length($s)
    var $res = ""
    # Try all possible cycle lengths from 1 to len-1
    for val $i (1:$len-1) {
        val $sub = substr($s, 0, $i)
        var $repeated = ""
        while (length($repeated) < $len) {
            $repeated = $repeated . $sub
        }
        if (substr($repeated, 0, $len) eq $s) {
            $res = $sub
        }
    }
    $res
}

assert_eq Rosetta::RepString::find("100100100100100"), "100100100100", "100 rep-string (longest)"
assert_eq Rosetta::RepString::find("abcabcabcabc"), "abcabcabc", "abc rep-string (longest)"
assert_eq Rosetta::RepString::find("abcdef"), "", "no rep-string"
assert_eq Rosetta::RepString::find("aaaaa"), "aaaa", "aaaaa -> aaaa"

"101010" |> Rosetta::RepString::find |> assert_eq("1010", "pipe 101010")

test_run
