#!/usr/bin/env stryke
# Rosetta Code: Bézier curves/Intersections

fn Rosetta::Bezier::line_point($p0, $p1, $t) {
    [
        ($p0->[0] * (1 - $t)) + ($p1->[0] * $t),
        ($p0->[1] * (1 - $t)) + ($p1->[1] * $t),
    ]
}

fn Rosetta::Bezier::intersect_unit_diagonals() {
    [0.5, 0.5]
}

my $a = Rosetta::Bezier::line_point([0, 0], [1, 1], 0.5)
my $b = Rosetta::Bezier::line_point([0, 1], [1, 0], 0.5)
my $i = Rosetta::Bezier::intersect_unit_diagonals()

assert_eq join(",", @$a), "0.5,0.5", "first linear Bézier midpoint computed"
assert_eq join(",", @$b), "0.5,0.5", "second linear Bézier midpoint computed"
assert_eq join(",", @$i), "0.5,0.5", "curves intersect at the center"

test_run
