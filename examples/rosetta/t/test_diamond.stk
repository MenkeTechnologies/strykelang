#!/usr/bin/env stryke
# Rosetta Code: Diamond lines

fn Rosetta::Diamond::row($char, $max_char) {
    val $dist = ord($char) - ord("A")
    val $max_dist = ord($max_char) - ord("A")
    val $outer = $max_dist - $dist
    var $res = ""
    for val $i (1:$outer) { $res = $res . " " }
    $res = $res . $char
    if ($dist > 0) {
        val $inner = 2 * $dist - 1
        for val $i (1:$inner) { $res = $res . " " }
        $res = $res . $char
    }
    # Symmetric trailing spaces not strictly needed for visualization but good for tests
    for val $i (1:$outer) { $res = $res . " " }
    $res
}

fn Rosetta::Diamond::build($max_char) {
    var @rows
    var @chars = ("A" .. $max_char)
    for val $c (@chars) {
        push @rows, Rosetta::Diamond::row($c, $max_char)
    }
    var @rev_chars = rev(@chars)
    shift @rev_chars # remove max_char
    for val $c (@rev_chars) {
        push @rows, Rosetta::Diamond::row($c, $max_char)
    }
    \@rows
}

val $d_c = Rosetta::Diamond::build("C")
assert_eq $d_c->[0], "  A  ", "diamond C row 0"
assert_eq $d_c->[1], " B B ", "diamond C row 1"
assert_eq $d_c->[2], "C   C", "diamond C row 2"
assert_eq $d_c->[3], " B B ", "diamond C row 3"
assert_eq $d_c->[4], "  A  ", "diamond C row 4"

test_run
