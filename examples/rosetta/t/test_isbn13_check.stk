#!/usr/bin/env stryke
# Rosetta Code: ISBN13 check digit

fn Rosetta::ISBN13::clean($s) {
    $s =~ s/[\s-]+//g
    $s
}

fn Rosetta::ISBN13::compute_check($digits12) {
    my $sum = 0
    for my $i (0..11) {
        my $d = substr($digits12, $i, 1) + 0
        $sum += ($i % 2 == 0) ? $d : 3 * $d
    }
    (10 - $sum % 10) % 10
}

fn Rosetta::ISBN13::is_valid($isbn) {
    my $clean = Rosetta::ISBN13::clean($isbn)
    return 0 unless length($clean) == 13
    return 0 unless $clean =~ /^\d+$/
    my $check = Rosetta::ISBN13::compute_check(substr($clean, 0, 12))
    $check == (substr($clean, 12, 1) + 0)
}

assert_ok  Rosetta::ISBN13::is_valid("978-0596520687"),    "Programming Perl 4e"
assert_ok  Rosetta::ISBN13::is_valid("978-0-13-468599-1"), "K&R 2e style spacing"
assert_ok  Rosetta::ISBN13::is_valid("9780470059029"),     "no separators"
assert_ok !Rosetta::ISBN13::is_valid("978-0596520688"),    "bad check digit"
assert_ok !Rosetta::ISBN13::is_valid("978059652068"),      "12 digits"
assert_ok !Rosetta::ISBN13::is_valid("978-0596-letters"),  "non-digits"

assert_eq Rosetta::ISBN13::compute_check("978059652068"), 7, "compute=7"

test_run
