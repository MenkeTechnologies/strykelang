#!/usr/bin/env stryke
# Rosetta Code: Max flow (Edmonds-Karp)

fn Rosetta::MaxFlow::solve($capacity, $source, $sink) {
    my $n = scalar(@$capacity)
    my @flow = ~> 0:$n-1 map { [ map { 0 } 1:$n ] }
    my $max_flow = 0
    
    while (1) {
        my @parent = map { -1 } 1:$n
        my @queue = ($source)
        $parent[$source] = $source
        
        my $found_path = 0
        while (scalar(@queue) > 0) {
            my $u = shift @queue
            if ($u == $sink) {
                $found_path = 1
                last
            }
            
            for (my $v = 0; $v < $n; $v++) {
                if ($parent[$v] == -1 && $capacity->[$u]->[$v] - $flow[$u]->[$v] > 0) {
                    $parent[$v] = $u
                    push @queue, $v
                }
            }
        }
        
        last if !$found_path
        
        my $path_flow = 1e18 # Infinity
        my $s = $sink
        while ($s != $source) {
            my $u = $parent[$s]
            my $residual = $capacity->[$u]->[$s] - $flow[$u]->[$s]
            $path_flow = min($path_flow, $residual)
            $s = $u
        }
        
        $max_flow += $path_flow
        my $v = $sink
        while ($v != $source) {
            my $u = $parent[$v]
            $flow[$u]->[$v] += $path_flow
            $flow[$v]->[$u] -= $path_flow
            $v = $u
        }
    }
    
    $max_flow
}

# Example graph
# 0: source, 5: sink
my $cap = [
    [0, 16, 13,  0,  0,  0],
    [0,  0, 10, 12,  0,  0],
    [0,  4,  0,  0, 14,  0],
    [0,  0,  9,  0,  0, 20],
    [0,  0,  0,  7,  0,  4],
    [0,  0,  0,  0,  0,  0]
]

my $res = Rosetta::MaxFlow::solve($cap, 0, 5)
assert_eq $res, 23, "Max flow is 23"

test_run
