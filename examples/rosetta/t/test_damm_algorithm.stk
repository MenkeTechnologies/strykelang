#!/usr/bin/env stryke
# Rosetta Code: Damm algorithm

fn Rosetta::Damm::checksum($number) {
    my $table = [
        [0, 3, 1, 7, 5, 9, 8, 6, 4, 2],
        [7, 0, 9, 2, 1, 5, 4, 8, 6, 3],
        [4, 2, 0, 6, 8, 7, 1, 3, 5, 9],
        [1, 7, 5, 0, 9, 8, 3, 4, 2, 6],
        [6, 1, 2, 3, 0, 4, 5, 9, 7, 8],
        [3, 6, 7, 4, 2, 0, 9, 5, 8, 1],
        [5, 8, 6, 9, 7, 2, 0, 1, 3, 4],
        [8, 9, 4, 5, 3, 6, 2, 0, 1, 7],
        [9, 4, 3, 8, 6, 1, 7, 2, 0, 5],
        [2, 5, 8, 1, 4, 3, 6, 7, 9, 0]
    ]
    
    my @digits = ~> "$number" chars
    my $interim = 0
    for my $d (@digits) {
        $interim = $table->[$interim][$d]
    }
    $interim
}

assert_eq Rosetta::Damm::checksum("572"), 4, "Checksum of 572 is 4"
assert_eq Rosetta::Damm::checksum("5724"), 0, "Checksum of 5724 is 0 (valid)"
assert_ok Rosetta::Damm::checksum("1234567") != 0, "1234567 not valid"

test_run
