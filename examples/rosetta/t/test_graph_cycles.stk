#!/usr/bin/env stryke
# Rosetta Code: Cycles in a Graph

fn Rosetta::GraphCycles::backtrack($curr, $path, $visited, $adj, $cycles) {
    push @$path, $curr
    $visited->{$curr} = 1
    for val $next (@{$adj->{$curr}}) {
        if (len(@$path) >= 3 && $next eq $path->[0]) {
            push @$cycles, [@$path]
        } elsif (!$visited->{$next}) {
            Rosetta::GraphCycles::backtrack($next, [@$path], { %$visited }, $adj, $cycles)
        }
    }
}

fn Rosetta::GraphCycles::solve($adj) {
    val @cycles
    ~> keys %$adj ep {
        Rosetta::GraphCycles::backtrack(_, [], {}, $adj, \@cycles)
    }
    \@cycles
}

val $g = { A => ["B"], B => ["C"], C => ["A"] }
val $c = Rosetta::GraphCycles::solve($g)
assert_ok len(@$c) > 0, "found cycle in triangle"
test_run
