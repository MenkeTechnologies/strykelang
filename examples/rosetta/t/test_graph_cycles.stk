#!/usr/bin/env stryke
# Rosetta Code: Cycles in a Graph

fn Rosetta::GraphCycles::backtrack($curr, $path, $visited, $adj, $cycles) {
    push @$path, $curr
    $visited->{$curr} = 1
    for my $next (@{$adj->{$curr}}) {
        if (scalar(@$path) >= 3 && $next eq $path->[0]) {
            push @$cycles, [@$path]
        } elsif (!$visited->{$next}) {
            Rosetta::GraphCycles::backtrack($next, [@$path], { %$visited }, $adj, $cycles)
        }
    }
}

fn Rosetta::GraphCycles::solve($adj) {
    my @cycles
    for my $node (keys %$adj) {
        Rosetta::GraphCycles::backtrack($node, [], {}, $adj, \@cycles)
    }
    \@cycles
}

my $g = { A => ["B"], B => ["C"], C => ["A"] }
my $c = Rosetta::GraphCycles::solve($g)
assert_ok scalar(@$c) > 0, "found cycle in triangle"
test_run
