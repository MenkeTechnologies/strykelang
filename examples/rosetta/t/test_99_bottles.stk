#!/usr/bin/env stryke
# Rosetta Code: 99 Bottles of Beer

fn bottle_str {
    my $n = $_[0]
    if ($n == 0) { "no more bottles" }
    elsif ($n == 1) { "1 bottle" }
    else { "$n bottles" }
}

fn beer {
    my $n = $_[0]
    my $s = bottle_str($n)
    my $take = "one"
    if ($n == 1) { $take = "it" }
    
    my $res = "$s of beer on the wall, $s of beer.\n"
    if ($n > 0) {
        my $next = bottle_str($n - 1)
        $res .= "Take $take down and pass it around, $next of beer on the wall.\n"
    } else {
        $res .= "Go to the store and buy some more, 99 bottles of beer on the wall.\n"
    }
    $res
}

# Just test a few cases
assert_ok beer(99) =~ /^99 bottles/, "99 bottles"
assert_ok beer(1) =~ /1 bottle/, "1 bottle"
assert_ok beer(0) =~ /no more bottles/, "0 bottles"

test_run
