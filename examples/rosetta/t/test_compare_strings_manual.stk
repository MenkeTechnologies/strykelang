#!/usr/bin/env stryke
# Rosetta Code: Compare a list of strings (Manual)

fn Rosetta::CompareStrings::all_equal($list) {
    if (len(@$list) <= 1) { return 1 }
    val $first = $list->[0]
    for val $s (@$list) {
        if ($s ne $first) { return 0 }
    }
    1
}

fn Rosetta::CompareStrings::all_increasing($list) {
    if (len(@$list) <= 1) { return 1 }
    for val $i (0..len(@$list)-2) {
        if ($list->[$i] ge $list->[$i+1]) { return 0 }
    }
    1
}

val @eq = ("abc", "abc", "abc")
assert_ok Rosetta::CompareStrings::all_equal(\@eq), "all strings equal"

val @neq = ("abc", "abd", "abc")
assert_ok !Rosetta::CompareStrings::all_equal(\@neq), "not all equal"

val @inc = ("abc", "abd", "abe")
assert_ok Rosetta::CompareStrings::all_increasing(\@inc), "strings increasing"

val @ninc = ("abc", "abe", "abd")
assert_ok !Rosetta::CompareStrings::all_increasing(\@ninc), "not increasing"

test_run
