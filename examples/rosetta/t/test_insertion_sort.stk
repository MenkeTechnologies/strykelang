#!/usr/bin/env stryke
# Rosetta Code: Insertion Sort

fn Rosetta::InsertionSort::sort(@arr) {
    for my $i (1..$#arr) {
        my $key = $arr[$i]
        my $j = $i - 1
        while ($j >= 0 && $arr[$j] > $key) {
            $arr[$j + 1] = $arr[$j]
            $j--
        }
        $arr[$j + 1] = $key
    }
    @arr
}

my @sorted = Rosetta::InsertionSort::sort(64, 34, 25, 12, 22, 11, 90)
assert_eq join(",", @sorted), "11,12,22,25,34,64,90", "insertion sort"

my @single = Rosetta::InsertionSort::sort(42)
assert_eq join(",", @single), "42", "single element"

my @already = Rosetta::InsertionSort::sort(1, 2, 3, 4, 5)
assert_eq join(",", @already), "1,2,3,4,5", "already sorted"

my @reverse = Rosetta::InsertionSort::sort(5, 4, 3, 2, 1)
assert_eq join(",", @reverse), "1,2,3,4,5", "reverse"

my @dups = Rosetta::InsertionSort::sort(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq join(",", @dups), "1,1,2,3,4,5,6,9", "with duplicates"

my @neg = Rosetta::InsertionSort::sort(-5, 3, -1, 0, 2)
assert_eq join(",", @neg), "-5,-1,0,2,3", "with negatives"

test_run
