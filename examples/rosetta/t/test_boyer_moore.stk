#!/usr/bin/env stryke
# Rosetta Code: Boyer-Moore string search (Simplified)

fn Rosetta::BoyerMoore::find($text, $pattern) {
    val $n = length($text)
    val $m = length($pattern)
    if ($m == 0) { return 0 }
    
    # Precompute bad character shift
    var %bad_char
    val @p_chars = ~> $pattern chars
    for val $i (0:$m-1) {
        $bad_char{$p_chars[$i]} = $i
    }
    
    var $s = 0
    while ($s <= ($n - $m)) {
        var $j = $m - 1
        while ($j >= 0 && $p_chars[$j] eq substr($text, $s + $j, 1)) {
            $j--
        }
        
        if ($j < 0) {
            return $s
        } else {
            val $char = substr($text, $s + $j, 1)
            val $bc_idx = exists $bad_char{$char} ? $bad_char{$char} : -1
            val $shift = $j - $bc_idx
            $s += ($shift > 1 ? $shift : 1)
        }
    }
    -1
}

assert_eq Rosetta::BoyerMoore::find("abcabcabc", "abc"), 0, "Find abc at 0"
assert_eq Rosetta::BoyerMoore::find("abcabcabc", "bca"), 1, "Find bca at 1"
assert_eq Rosetta::BoyerMoore::find("GCAATGCCTAG", "TGC"), 4, "Find TGC at 4"
assert_eq Rosetta::BoyerMoore::find("hello world", "bye"), -1, "Not found"

test_run
