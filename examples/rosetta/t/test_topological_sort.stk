#!/usr/bin/env stryke
# Rosetta Code: Topological sort

fn Rosetta::TopologicalSort::topological_sort($graph) {
    var $in_degree = {}
    val @nodes = keys %$graph
    for val $u (@nodes) {
        $in_degree->{$u} = 0
    }
    for val $u (@nodes) {
        for val $v (@{$graph->{$u}}) {
            $in_degree->{$v} = ($in_degree->{$v} || 0) + 1
        }
    }
    
    var @queue = ()
    for val $u (@nodes) {
        if ($in_degree->{$u} == 0) { push @queue, $u }
    }
    
    var @sorted = ()
    while (len(@queue) > 0) {
        val $u = shift @queue
        push @sorted, $u
        for val $v (@{$graph->{$u}}) {
            $in_degree->{$v}--
            if ($in_degree->{$v} == 0) { push @queue, $v }
        }
    }
    
    if (len(@sorted) != len(@nodes)) {
        return undef # Cycle detected
    }
    \@sorted
}

val $graph = {
    "A" => ["C"],
    "B" => ["C", "D"],
    "C" => ["E"],
    "D" => ["F"],
    "E" => ["F"],
    "F" => []
}

val $res = Rosetta::TopologicalSort::topological_sort($graph)
assert_ok defined($res), "Topological sort exists"

# Verify order
var %pos
for val $i (0..len(@$res)-1) { $pos{$res->[$i]} = $i }
assert_ok $pos{A} < $pos{C}, "A < C"
assert_ok $pos{B} < $pos{C}, "B < C"
assert_ok $pos{C} < $pos{E}, "C < E"
assert_ok $pos{E} < $pos{F}, "E < F"

test_run
