#!/usr/bin/env stryke
# Rosetta Code: Truncatable primes

fn Rosetta::TruncatablePrime::is_left($n) {
    my $s = "$n"
    if ($s =~ /0/) { 0 }
    else {
        my $valid = 1
        while (length($s) > 0 && $valid) {
            if (!is_prime(int($s))) {
                $valid = 0
            }
            $s = substr($s, 1)
        }
        $valid
    }
}

fn Rosetta::TruncatablePrime::is_right($n) {
    my $s = "$n"
    if ($s =~ /0/) { 0 }
    else {
        my $valid = 1
        while (length($s) > 0 && $valid) {
            if (!is_prime(int($s))) {
                $valid = 0
            }
            $s = substr($s, 0, length($s) - 1)
        }
        $valid
    }
}

assert_ok Rosetta::TruncatablePrime::is_left(9137), "9137 is left-truncatable"
assert_ok Rosetta::TruncatablePrime::is_right(7393), "7393 is right-truncatable"
assert_ok Rosetta::TruncatablePrime::is_left(13), "13 is left-truncatable"
assert_ok !Rosetta::TruncatablePrime::is_left(19), "19 is not left-truncatable"

9137 |> Rosetta::TruncatablePrime::is_left |> assert_ok("pipe left-truncatable")

test_run
