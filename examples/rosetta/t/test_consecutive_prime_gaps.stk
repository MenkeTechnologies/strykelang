#!/usr/bin/env stryke
# Rosetta Code: Consecutive prime gaps

fn my_is_prime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        my $limit = sqrt($n)
        my $res = 1
        my $i = 3
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

fn my_next_prime($n) {
    my $p = $n + 1
    while (1) {
        if (my_is_prime($p)) { return $p }
        $p++
    }
}

fn prime_gap($n) {
    my $p2 = my_next_prime($n)
    $p2 - $n
}

assert_eq prime_gap(3), 2, "gap after 3 is 2 (3, 5)"
assert_eq prime_gap(7), 4, "gap after 7 is 4 (7, 11)"
assert_eq prime_gap(13), 4, "gap after 13 is 4 (13, 17)"
assert_eq prime_gap(23), 6, "gap after 23 is 6 (23, 29)"

23 |> prime_gap |> assert_eq(6, "pipe prime_gap")

test_run
