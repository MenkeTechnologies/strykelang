#!/usr/bin/env stryke
# Rosetta Code: Consecutive prime gaps

fn Rosetta::PrimeGaps::next_prime($n) {
    my $p = $n + 1
    while (1) {
        if (is_prime($p)) { return $p }
        $p++
    }
}

fn Rosetta::PrimeGaps::compute($n) {
    my $p2 = Rosetta::PrimeGaps::next_prime($n)
    $p2 - $n
}

assert_eq Rosetta::PrimeGaps::compute(3), 2, "gap after 3 is 2 (3, 5)"
assert_eq Rosetta::PrimeGaps::compute(7), 4, "gap after 7 is 4 (7, 11)"
assert_eq Rosetta::PrimeGaps::compute(13), 4, "gap after 13 is 4 (13, 17)"
assert_eq Rosetta::PrimeGaps::compute(23), 6, "gap after 23 is 6 (23, 29)"

23 |> Rosetta::PrimeGaps::compute |> assert_eq(6, "pipe prime_gap")

test_run
