#!/usr/bin/env stryke
# Rosetta Code: Word Wrap

fn Rosetta::WordWrap::solve($text, $width) {
    var @words = $text |> split /\s+/
    var @lines
    var $line = ""
    
    for val $word (@words) {
        if (len($line) == 0) {
            $line = $word
        } elsif (len($line) + 1 + len($word) <= $width) {
            $line = $line . " $word"
        } else {
            push @lines, $line
            $line = $word
        }
    }
    if (len($line) > 0) { push @lines, $line }
    join("\n", @lines)
}

val $text = "The quick brown fox jumps over the lazy dog"

val $w10 = Rosetta::WordWrap::solve($text, 10)
val @lines10 = $w10 |> split /\n/
assert_ok (grep { len(_) <= 10 } @lines10) == len(@lines10), "all lines <= 10"

val $w20 = Rosetta::WordWrap::solve($text, 20)
val @lines20 = $w20 |> split /\n/
assert_ok (grep { len(_) <= 20 } @lines20) == len(@lines20), "all lines <= 20"

val $w80 = Rosetta::WordWrap::solve($text, 80)
assert_eq $w80, $text, "width >= text keeps single line"

val $short = Rosetta::WordWrap::solve("hi", 10)
assert_eq $short, "hi", "short text"

test_run
