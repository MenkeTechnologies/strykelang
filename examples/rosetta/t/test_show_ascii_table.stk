#!/usr/bin/env stryke
# Rosetta Code: Show ASCII table — render printable ASCII (32..126) with control-name
# rendering for the special edges (32 = SPC, 127 = DEL).

fn Rosetta::Ascii::name($code) {
    return "SPC" if $code == 32
    return "DEL" if $code == 127
    chr($code)
}

fn Rosetta::Ascii::row($start, $count) {
    var @cells
    for val $i (0:$count-1) {
        val $code = $start + $i
        push @cells, sprintf("%3d: %s", $code, Rosetta::Ascii::name($code))
    }
    join(" | ", @cells)
}

fn Rosetta::Ascii::table() {
    var @rows
    # Standard layout: 6 columns x 16 rows (codes 32..127)
    for val $r (0:15) {
        var @cells
        for val $c (0:5) {
            val $code = 32 + $r + $c * 16
            next if $code > 127
            push @cells, sprintf("%3d: %s", $code, Rosetta::Ascii::name($code))
        }
        push @rows, join(" | ", @cells)
    }
    join("\n", @rows)
}

# Code-to-name behavior
assert_eq Rosetta::Ascii::name(32),  "SPC", "32 -> SPC"
assert_eq Rosetta::Ascii::name(33),  "!",   "33 -> !"
assert_eq Rosetta::Ascii::name(48),  "0",   "48 -> 0"
assert_eq Rosetta::Ascii::name(65),  "A",   "65 -> A"
assert_eq Rosetta::Ascii::name(97),  "a",   "97 -> a"
assert_eq Rosetta::Ascii::name(126), "~",   "126 -> ~"
assert_eq Rosetta::Ascii::name(127), "DEL", "127 -> DEL"

# Row rendering
val $row = Rosetta::Ascii::row(32, 4)
assert_eq $row, " 32: SPC |  33: ! |  34: \" |  35: #", "row 32:35"

# Table contains all 96 printable cells (32..127)
val $tbl = Rosetta::Ascii::table()
val @lines = split /\n/, $tbl
assert_eq len(@lines), 16, "16 rows"

# Every code 32..127 appears exactly once in the table
for val $code (32:127) {
    val $pat = sprintf("%3d:", $code)
    var $count = 0
    while ($tbl =~ /\Q$pat\E/g) { $count += 1 }
    assert_eq $count, 1, "code $code appears once"
}

test_run
