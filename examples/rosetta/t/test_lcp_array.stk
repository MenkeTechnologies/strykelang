#!/usr/bin/env stryke
# Rosetta Code: Longest Common Prefix array via Kasai's algorithm.
# Given a string and its suffix array, computes lcp[i] = length of the
# longest common prefix between the suffix at sa[i] and sa[i-1] in O(n).

# Build a suffix array via O(n² log n) sort — fine for the test sizes
# here; production would use SA-IS or DC3.
fn Rosetta::LCP::suffix_array($s) {
    val $n = length($s)
    var @suffixes
    for val $i (~> 0:$n - 1) { push @suffixes, [substr($s, $i), $i] }
    @suffixes = sort { _0->[0] cmp _1->[0] } @suffixes
    val @sa = map { _0->[1] } @suffixes
    \@sa
}

# Kasai's algorithm.
fn Rosetta::LCP::kasai($s, $sa) {
    val $n = length($s)
    var @rank = ~> 0:$n - 1 |> map { 0 }
    for val $i (~> 0:$n - 1) { $rank[$sa->[$i]] = $i }
    var @lcp = ~> 0:$n - 1 |> map { 0 }
    var $h = 0
    for val $i (~> 0:$n - 1) {
        if ($rank[$i] > 0) {
            val $j = $sa->[$rank[$i] - 1]
            while ($i + $h < $n && $j + $h < $n && substr($s, $i + $h, 1) eq substr($s, $j + $h, 1)) {
                $h++
            }
            $lcp[$rank[$i]] = $h
            $h-- if $h > 0
        } else {
            $h = 0
        }
    }
    \@lcp
}

# Naive LCP for cross-check.
fn Rosetta::LCP::common_prefix_len($a, $b) {
    var $i = 0
    val $la = length($a)
    val $lb = length($b)
    while ($i < $la && $i < $lb && substr($a, $i, 1) eq substr($b, $i, 1)) { $i++ }
    $i
}

fn Rosetta::LCP::naive($s, $sa) {
    val $n = length($s)
    var @lcp = ~> 0:$n - 1 |> map { 0 }
    for val $i (~> 1:$n - 1) {
        $lcp[$i] = Rosetta::LCP::common_prefix_len(substr($s, $sa->[$i]), substr($s, $sa->[$i - 1]))
    }
    \@lcp
}

# "banana": suffixes sorted are "a", "ana", "anana", "banana", "na", "nana"
# Indices: 5, 3, 1, 0, 4, 2
# LCP:     0, 1, 3, 0, 0, 2
val $sa1 = Rosetta::LCP::suffix_array("banana")
assert_eq join(",", @$sa1), "5,3,1,0,4,2", "banana suffix array"
val $lcp1 = Rosetta::LCP::kasai("banana", $sa1)
assert_eq join(",", @$lcp1), "0,1,3,0,0,2", "banana LCP"

# "abracadabra"
val $sa2 = Rosetta::LCP::suffix_array("abracadabra")
val $lcp2 = Rosetta::LCP::kasai("abracadabra", $sa2)
val $lcp2_naive = Rosetta::LCP::naive("abracadabra", $sa2)
assert_eq join(",", @$lcp2), join(",", @$lcp2_naive), "abracadabra LCP matches naive"

# Single-character string
val $sa3 = Rosetta::LCP::suffix_array("a")
assert_eq join(",", @$sa3), "0", "single char SA"
val $lcp3 = Rosetta::LCP::kasai("a", $sa3)
assert_eq join(",", @$lcp3), "0", "single char LCP"

# Repeated character
val $sa4 = Rosetta::LCP::suffix_array("aaaa")
val $lcp4 = Rosetta::LCP::kasai("aaaa", $sa4)
# SA of "aaaa": 3, 2, 1, 0. LCP: 0, 1, 2, 3
assert_eq join(",", @$sa4), "3,2,1,0", "aaaa SA"
assert_eq join(",", @$lcp4), "0,1,2,3", "aaaa LCP"

# "mississippi" — large enough to exercise Kasai's amortized growth/shrink
val $sa5 = Rosetta::LCP::suffix_array("mississippi")
val $lcp5_kasai = Rosetta::LCP::kasai("mississippi", $sa5)
val $lcp5_naive = Rosetta::LCP::naive("mississippi", $sa5)
assert_eq join(",", @$lcp5_kasai), join(",", @$lcp5_naive),
    "mississippi Kasai = naive"

# Cross-check: max(LCP) >= length of any repeated substring
# "mississippi" has "issi" of length 4 repeated.
var $max_lcp = 0
~> @$lcp5_kasai ep { $max_lcp = _ if _ > $max_lcp }
assert_ok $max_lcp >= 4, "max LCP >= 4 (issi appears twice)"

test_run
