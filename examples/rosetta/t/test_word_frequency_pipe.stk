#!/usr/bin/env stryke
# Rosetta Code: Word frequency (using pipes)

fn Rosetta::WordFrequency::compute($text) {
    my %freq
    $text |> lc() |> split(/\W+/) |> map {
        if (_ ne "") {
            $freq{$_}++
        }
    }
    %freq
}

my $text = "the quick brown fox jumps over the lazy dog"
my %f = Rosetta::WordFrequency::compute($text)

assert_eq $f{"the"}, 2, "word 'the' appears twice"
assert_eq $f{"fox"}, 1, "word 'fox' appears once"
assert_eq len(keys %f), 8, "8 unique words"

test_run
