#!/usr/bin/env stryke
# Rosetta Code: Sphenic numbers

fn Rosetta::PrimeFactors::prime_factors($n) {
    var @factors
    var $d = 2
    var $temp = $n
    while ($temp > 1) {
        while ($temp % $d == 0) {
            push @factors, $d
            $temp = int($temp / $d)
        }
        $d++
    }
    \@factors
}

fn Rosetta::Sphenic::check($n) {
    val $factors_ref = Rosetta::PrimeFactors::prime_factors($n)
    var @factors = @$factors_ref
    if (len(@factors) != 3) {
        0
    } else {
        var %counts
        for val $f (@factors) { $counts{$f}++ }
        len(keys %counts) == 3
    }
}

assert_ok Rosetta::Sphenic::check(30), "30 is sphenic (2*3*5)"
assert_ok Rosetta::Sphenic::check(42), "42 is sphenic (2*3*7)"
assert_ok Rosetta::Sphenic::check(66), "66 is sphenic (2*3*11)"
assert_ok !Rosetta::Sphenic::check(60), "60 is not (2*2*3*5)"
assert_ok !Rosetta::Sphenic::check(8), "8 is not (2*2*2)"
assert_ok !Rosetta::Sphenic::check(12), "12 is not (2*2*3)"

30 |> Rosetta::Sphenic::check |> assert_ok("pipe sphenic")

test_run
