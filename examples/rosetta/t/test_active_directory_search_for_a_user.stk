#!/usr/bin/env stryke
# Rosetta Code: Active Directory/Search for a user

fn Rosetta::ADSearch::directory() {
    val @users = (
        { uid => "alice", cn => "Alice Adams", mail => "alice@example.com" },
        { uid => "bob", cn => "Bob Brown", mail => "bob@example.com" },
        { uid => "alina", cn => "Alina Aster", mail => "alina@example.com" },
    )
    { users => \@users }
}

fn Rosetta::ADSearch::find_by_prefix($directory, $prefix) {
    var @matches
    for val $user (@{$directory->{users}}) {
        if (substr($user->{uid}, 0, len(split //, $prefix)) eq $prefix) { push @matches, $user }
    }
    \@matches
}

val $directory = Rosetta::ADSearch::directory()
val $matches = Rosetta::ADSearch::find_by_prefix($directory, "ali")

assert_eq len(@$matches), 2, "prefix search finds two users"
assert_eq join(",", map { $_->{uid} } @$matches), "alice,alina", "matching users preserve directory order"
assert_eq len(@{Rosetta::ADSearch::find_by_prefix($directory, "zoe")}), 0, "missing user yields no matches"

test_run
