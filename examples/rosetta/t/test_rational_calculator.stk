#!/usr/bin/env stryke
# Rosetta Code: Rational calculator

fn Rosetta::RCalc::gcd($a, $b) {
    $a = abs($a)
    $b = abs($b)
    while ($b != 0) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn Rosetta::RCalc::norm($n, $d) {
    die "division by zero" if $d == 0
    if ($d < 0) { $n = -$n; $d = -$d }
    val $g = Rosetta::RCalc::gcd($n, $d)
    [$n / $g, $d / $g]
}

fn Rosetta::RCalc::add($a, $b) { Rosetta::RCalc::norm($a->[0]*$b->[1] + $b->[0]*$a->[1], $a->[1]*$b->[1]) }
fn Rosetta::RCalc::sub($a, $b) { Rosetta::RCalc::norm($a->[0]*$b->[1] - $b->[0]*$a->[1], $a->[1]*$b->[1]) }
fn Rosetta::RCalc::mul($a, $b) { Rosetta::RCalc::norm($a->[0]*$b->[0], $a->[1]*$b->[1]) }
fn Rosetta::RCalc::div($a, $b) { Rosetta::RCalc::norm($a->[0]*$b->[1], $a->[1]*$b->[0]) }
fn Rosetta::RCalc::neg($a) { [-$a->[0], $a->[1]] }
fn Rosetta::RCalc::absrat($a) { [abs($a->[0]), $a->[1]] }
fn Rosetta::RCalc::fmt($a) { $a->[1] == 1 ? "$a->[0]" : "$a->[0]/$a->[1]" }

fn Rosetta::RCalc::factor($tokens, $pos_ref, $prev) {
    val $tok = $tokens->[$$pos_ref]
    $$pos_ref++
    return Rosetta::RCalc::neg(Rosetta::RCalc::factor($tokens, $pos_ref, $prev)) if $tok eq "-"
    return Rosetta::RCalc::factor($tokens, $pos_ref, $prev) if $tok eq "+"
    return Rosetta::RCalc::absrat(Rosetta::RCalc::factor($tokens, $pos_ref, $prev)) if $tok eq "abs"
    if ($tok eq "(") {
        val $res = Rosetta::RCalc::expr($tokens, $pos_ref, $prev)
        $$pos_ref++
        return $res
    }
    return $prev if $tok eq "@"
    [$tok + 0, 1]
}

fn Rosetta::RCalc::term($tokens, $pos_ref, $prev) {
    var $res = Rosetta::RCalc::factor($tokens, $pos_ref, $prev)
    while ($$pos_ref < len(@$tokens)) {
        val $op = $tokens->[$$pos_ref]
        last if $op ne "*" && $op ne "/"
        $$pos_ref++
        val $rhs = Rosetta::RCalc::factor($tokens, $pos_ref, $prev)
        $res = ($op eq "*" ? Rosetta::RCalc::mul($res, $rhs) : Rosetta::RCalc::div($res, $rhs))
    }
    $res
}

fn Rosetta::RCalc::expr($tokens, $pos_ref, $prev) {
    var $res = Rosetta::RCalc::term($tokens, $pos_ref, $prev)
    while ($$pos_ref < len(@$tokens)) {
        val $op = $tokens->[$$pos_ref]
        last if $op ne "+" && $op ne "-"
        $$pos_ref++
        val $rhs = Rosetta::RCalc::term($tokens, $pos_ref, $prev)
        $res = ($op eq "+" ? Rosetta::RCalc::add($res, $rhs) : Rosetta::RCalc::sub($res, $rhs))
    }
    $res
}

fn Rosetta::RCalc::solve($s, $prev) {
    val @tokens = ~> $s s/([\(\)\@\+\-\*\/])/ $1 /g |> trim |> split(/\s+/)
    val $pos = 0
    Rosetta::RCalc::expr(\@tokens, \$pos, $prev)
}

val $r1 = Rosetta::RCalc::solve("1 + (2 - 7) / 5", [0,1])
val $r2 = Rosetta::RCalc::solve("1 / 2 + 1 / 3", [0,1])
val $r3 = Rosetta::RCalc::solve("@ * 3", $r2)
val $r4 = Rosetta::RCalc::solve("abs ( -3 )", [0,1])

assert_eq Rosetta::RCalc::fmt($r1), "0", "example expression"
assert_eq Rosetta::RCalc::fmt($r2), "5/6", "exact rational addition"
assert_eq Rosetta::RCalc::fmt($r3), "5/2", "previous result token"
assert_eq Rosetta::RCalc::fmt($r4), "3", "abs and unary minus"

test_run
