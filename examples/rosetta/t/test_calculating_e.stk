#!/usr/bin/env stryke
# Rosetta Code: Calculating the value of e

fn Rosetta::ConstantE::compute($iters) {
    my $e = 1.0
    my $term = 1.0
    for my $k (1..$iters) {
        $term /= $k
        $e += $term
    }
    $e
}

fn Rosetta::ConstantE::compute_until($epsilon) {
    my $e = 1.0
    my $term = 1.0
    my $k = 1
    while ($term > $epsilon) {
        $term /= $k
        $e += $term
        $k += 1
    }
    $e
}

# 2.7182818284590452...
my $e = Rosetta::ConstantE::compute(20)
assert_ok abs($e - 2.718281828459045) < 1e-12, "20 terms reaches e"

my $e2 = Rosetta::ConstantE::compute_until(1e-15)
assert_ok abs($e2 - 2.718281828459045) < 1e-13, "epsilon-driven matches"

# pipeline form
my $approx = 15 |> Rosetta::ConstantE::compute
assert_ok abs($approx - 2.718281828) < 1e-9, "pipeline 15 terms"

test_run
