#!/usr/bin/env stryke
# Rosetta Code: Knapsack problem/0-1

fn Rosetta::Knapsack01::solve($items, $capacity) {
    my $n = len(@$items)
    my @dp
    # Initialize DP table
    for (my $i = 0; $i <= $n; $i++) {
        my @row
        for (my $j = 0; $j <= $capacity; $j++) {
            push @row, 0
        }
        push @dp, \@row
    }
    
    for (my $i = 1; $i <= $n; $i++) {
        my $item = $items->[$i-1]
        my $w = $item->{weight}
        my $v = $item->{value}
        
        for (my $j = 0; $j <= $capacity; $j++) {
            if ($w <= $j) {
                my $v1 = $dp[$i-1]->[$j]
                my $v2 = $dp[$i-1]->[$j-$w] + $v
                $dp[$i]->[$j] = $v1 > $v2 ? $v1 : $v2
            } else {
                $dp[$i]->[$j] = $dp[$i-1]->[$j]
            }
        }
    }
    
    # Backtrack to find items
    my @selected
    my $curr_w = $capacity
    for (my $i = $n; $i > 0; $i--) {
        if ($dp[$i]->[$curr_w] != $dp[$i-1]->[$curr_w]) {
            my $item = $items->[$i-1]
            push @selected, $item
            $curr_w -= $item->{weight}
        }
    }
    
    { total_value => $dp[$n]->[$capacity], items => \@selected }
}

my @items = (
    { name => "map", weight => 9, value => 150 },
    { name => "compass", weight => 13, value => 35 },
    { name => "water", weight => 153, value => 200 },
    { name => "sandwich", weight => 50, value => 160 },
    { name => "glucose", weight => 15, value => 60 },
    { name => "tin", weight => 68, value => 45 },
    { name => "banana", weight => 27, value => 60 },
    { name => "apple", weight => 39, value => 40 },
    { name => "cheese", weight => 23, value => 30 },
    { name => "beer", weight => 52, value => 10 },
    { name => "suntan cream", weight => 11, value => 70 },
    { name => "camera", weight => 32, value => 30 },
    { name => "t-shirt", weight => 24, value => 15 },
    { name => "trousers", weight => 48, value => 10 },
    { name => "umbrella", weight => 73, value => 40 },
    { name => "waterproof trousers", weight => 42, value => 70 },
    { name => "waterproof overclothes", weight => 43, value => 75 },
    { name => "note-case", weight => 22, value => 80 },
    { name => "sunglasses", weight => 7, value => 20 },
    { name => "towel", weight => 18, value => 12 },
    { name => "socks", weight => 4, value => 50 },
    { name => "book", weight => 30, value => 10 }
)

my $res = Rosetta::Knapsack01::solve(\@items, 400)
assert_eq $res->{total_value}, 1030, "Knapsack total value"

my @names = sort map { $_->{name} } @{$res->{items}}
# Verify some key items are present
my %has = map { $_ => 1 } @names
assert_ok $has{"map"}, "has map"
assert_ok $has{"suntan cream"}, "has suntan cream"
assert_ok $has{"note-case"}, "has note-case"

test_run
