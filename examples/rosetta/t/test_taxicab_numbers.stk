#!/usr/bin/env stryke
# Rosetta Code: Taxicab numbers

fn Rosetta::Taxicab::solve($limit) {
    val %sums
    for val $i (~> 1 : 100) {
        for val $j (~> $i : 100) {
            val $sum = $i**3 + $j**3
            push @{$sums{$sum}}, "$i^3 + $j^3"
        }
    }
    
    var @res
    for val $s (~> keys %sums sort { _ <=> _1 }) {
        if (len(@{$sums{$s}}) >= 2) {
            push @res, $s
            last if (len(@res) >= $limit)
        }
    }
    \@res
}

val $taxis = Rosetta::Taxicab::solve(2)
assert_eq $taxis->[0], 1729, "First taxicab is 1729"
assert_eq $taxis->[1], 4104, "Second taxicab is 4104"

test_run
