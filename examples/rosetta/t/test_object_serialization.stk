#!/usr/bin/env stryke
# Rosetta Code: Object serialization

fn Rosetta::Serialization::demo() {
    my $obj = +{
        name => "Stryke",
        features => ["parallel", "fast", "perl-compatible"],
        version => 1.0
    }
    
    # Serialize to JSON
    my $json = to_json($obj)
    
    # Deserialize from JSON
    my $recovered = from_json($json)
    
    $recovered
}

my $res = Rosetta::Serialization::demo()
assert_eq $res->{name}, "Stryke", "Name recovered"
assert_eq $res->{features}->[0], "parallel", "Feature recovered"
assert_eq $res->{version}, 1.0, "Version recovered"

test_run
