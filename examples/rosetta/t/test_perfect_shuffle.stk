#!/usr/bin/env stryke
# Rosetta Code: Perfect shuffle

fn Rosetta::PerfectShuffle::shuffle($deck) {
    val $len = len(@$deck)
    val $mid = int($len / 2)
    
    val @left = @{$deck}[0:$mid-1]
    val @right = @{$deck}[$mid:$len-1]
    var @shuffled
    
    for val $i (0:$mid-1) {
        push @shuffled, $left[$i]
        push @shuffled, $right[$i]
    }
    
    \@shuffled
}

val $deck = [1:8]
val $shuffled = Rosetta::PerfectShuffle::shuffle($deck)
assert_eq join(",", @$shuffled), "1,5,2,6,3,7,4,8", "perfect shuffle of 1:8"

val $deck2 = ["A", "B", "C", "D"]
val $shuffled2 = Rosetta::PerfectShuffle::shuffle($deck2)
assert_eq join(",", @$shuffled2), "A,C,B,D", "perfect shuffle of ABCD"

test_run
