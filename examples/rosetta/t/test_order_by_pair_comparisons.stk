#!/usr/bin/env stryke
# Rosetta Code: Order by pair comparisons

fn Rosetta::PairOrder::sort($items, $cmp) {
    var @sorted
    var $comparisons = 0

    for val $item (@$items) {
        var $lo = 0
        var $hi = len(@sorted)
        while ($lo < $hi) {
            val $mid = int(($lo + $hi) / 2)
            $comparisons++
            val $r = $cmp($item, $sorted[$mid])
            if ($r < 0) {
                $hi = $mid
            } else {
                $lo = $mid + 1
            }
        }
        splice @sorted, $lo, 0, $item
    }

    (\@sorted, $comparisons)
}

val @items = qw(violet red green indigo blue yellow orange)
val @rainbow = qw(red orange yellow green blue indigo violet)
var %rank
for val $i (0:$#rainbow) { $rank{$rainbow[$i]} = $i }

val ($sorted, $comparisons) = Rosetta::PairOrder::sort(\@items, fn ($a, $b) {
    $rank{$a} <=> $rank{$b}
})

assert_eq join(" ", @$sorted), "red orange yellow green blue indigo violet", "rainbow ordered by pair comparisons"
assert_eq $comparisons <= 14, 1, "binary insertion keeps comparisons low"

test_run
