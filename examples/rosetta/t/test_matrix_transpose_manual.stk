#!/usr/bin/env stryke
# Rosetta Code: Matrix Transpose (Manual)

fn Rosetta::MatrixTranspose::solve($m) {
    val $rows = len(@$m)
    val $cols = len(@{$m->[0]})
    var @res
    for val $j (0:$cols-1) {
        var @new_row
        for val $i (0:$rows-1) {
            push @new_row, $m->[$i]->[$j]
        }
        push @res, [@new_row]
    }
    \@res
}

val $m = [[1, 2, 3], [4, 5, 6]]
val $tr = Rosetta::MatrixTranspose::solve($m)

# Expected: [[1, 4], [2, 5], [3, 6]]
assert_eq len(@$tr), 3, "transpose rows"
assert_eq len(@{$tr->[0]}), 2, "transpose cols"
assert_eq $tr->[0]->[1], 4, "tr[0][1]"
assert_eq $tr->[2]->[0], 3, "tr[2][0]"

test_run
