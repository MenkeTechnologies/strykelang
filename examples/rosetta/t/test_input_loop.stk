#!/usr/bin/env stryke
# Rosetta Code: Input loop

fn Rosetta::InputLoop::process($input_str) {
    val @lines = $input_str |> split(/\n/)
    var @processed
    @lines |> map {
        push @processed, "Line: " . _
    }
    join("\n", @processed)
}

val $input = "first\nsecond\nthird"
val $res = Rosetta::InputLoop::process($input)

assert_eq $res, "Line: first\nLine: second\nLine: third", "input loop processing"

test_run
