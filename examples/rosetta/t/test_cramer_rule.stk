#!/usr/bin/env stryke
# Rosetta Code: Cramer's rule

fn Rosetta::Cramer::determinant($matrix) {
    # 3x3 determinant
    val $m = $matrix
    val $det = $m->[0]->[0] * ($m->[1]->[1] * $m->[2]->[2] - $m->[1]->[2] * $m->[2]->[1]) - $m->[0]->[1] * ($m->[1]->[0] * $m->[2]->[2] - $m->[1]->[2] * $m->[2]->[0]) + $m->[0]->[2] * ($m->[1]->[0] * $m->[2]->[1] - $m->[1]->[1] * $m->[2]->[0])
    $det
}

fn Rosetta::Cramer::solve($A, $B) {
    val $det_A = Rosetta::Cramer::determinant($A)
    return () if $det_A == 0
    
    var @res
    for (var $i = 0; $i < 3; $i++) {
        # Create a deep copy of A for substitution
        val @Ai = (
            [ $A->[0]->[0], $A->[0]->[1], $A->[0]->[2] ],
            [ $A->[1]->[0], $A->[1]->[1], $A->[1]->[2] ],
            [ $A->[2]->[0], $A->[2]->[1], $A->[2]->[2] ]
        )
        
        # Replace column i with vector B
        for (var $j = 0; $j < 3; $j++) {
            $Ai[$j]->[$i] = $B->[$j]
        }
        
        val $det_Ai = Rosetta::Cramer::determinant(\@Ai)
        push @res, $det_Ai / $det_A
    }
    
    # We can also use a pipeline to map these
    # but the loop is clearer for column replacement.
    @res
}

val $A = [
    [ 2, -1,  5 ],
    [ 1,  1, -3 ],
    [ 2,  4,  1 ]
]

val $B = [ 10, -2, 1 ]

val @solution = Rosetta::Cramer::solve($A, $B)
assert_eq join(",", @solution), "2,-1,1", "Cramer's rule solution for 3x3"

test_run
