#!/usr/bin/env stryke
# Rosetta Code: Leonardo numbers

fn Rosetta::Leonardo::compute($n) {
    if ($n < 2) {
        1
    } else {
        var $a = 1
        var $b = 1
        for val $i (2:$n) {
            val $c = $a + $b + 1
            ($a, $b) = ($b, $c)
        }
        $b
    }
}

assert_eq Rosetta::Leonardo::compute(0), 1, "L(0)"
assert_eq Rosetta::Leonardo::compute(1), 1, "L(1)"
assert_eq Rosetta::Leonardo::compute(2), 3, "L(2) = 1+1+1"
assert_eq Rosetta::Leonardo::compute(3), 5, "L(3) = 1+3+1"
assert_eq Rosetta::Leonardo::compute(4), 9, "L(4) = 3+5+1"
assert_eq Rosetta::Leonardo::compute(10), 177, "L(10)"

10 |> Rosetta::Leonardo::compute |> assert_eq(177, "pipe leonardo")

test_run
