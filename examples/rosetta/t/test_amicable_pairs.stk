#!/usr/bin/env stryke
# Rosetta Code: Amicable Pairs

fn Rosetta::AmicablePairs::sum_divisors($n) {
    if ($n < 2) {
        return 0
    }
    my $sum = 0
    my $limit = int($n / 2)
    for my $i (1..$limit) {
        if ($n % $i == 0) {
            $sum = $sum + $i
        }
    }
    $sum
}

fn Rosetta::AmicablePairs::check($val1, $val2) {
    if ($val1 == $val2) {
        return 0
    }
    my $sa = Rosetta::AmicablePairs::sum_divisors($val1)
    my $sb = Rosetta::AmicablePairs::sum_divisors($val2)
    ($sa == $val2 && $sb == $val1) ? 1 : 0
}

assert_ok Rosetta::AmicablePairs::check(220, 284), "220 and 284 are amicable"
assert_ok Rosetta::AmicablePairs::check(1184, 1210), "1184 and 1210 are amicable"
assert_ok !Rosetta::AmicablePairs::check(220, 220), "same numbers are not amicable"
assert_ok !Rosetta::AmicablePairs::check(100, 200), "100 and 200 are not amicable"

test_run
