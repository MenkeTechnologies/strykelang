#!/usr/bin/env stryke
# Rosetta Code: Superpermutation minimisation

fn Rosetta::Superperm::get_permutations(@items) {
    if (len(@items) == 0) { return ([]) }
    var @res
    for val $i (0 .. len(@items) - 1) {
        var @rest = @items
        val $first = splice(@rest, $i, 1)
        val @sub_perms = Rosetta::Superperm::get_permutations(@rest)
        for val $p (@sub_perms) {
            push @res, [$first, @$p]
        }
    }
    @res
}

fn Rosetta::Superperm::is_superperm($s, $n) {
    val @items = 1:$n
    val @perms = Rosetta::Superperm::get_permutations(@items)
    
    for val $p (@perms) {
        val $p_str = join("", @$p)
        if (index($s, $p_str) == -1) {
            return 0
        }
    }
    1
}

fn Rosetta::Superperm::find_short($n) {
    val @items = 1:$n
    val @perms_refs = Rosetta::Superperm::get_permutations(@items)
    var @perms
    for val $p_ref (@perms_refs) { push @perms, join("", @$p_ref) }
    
    var $res = $perms[0]
    var %seen
    $seen{$perms[0]} = 1
    var $seen_count = 1
    
    while ($seen_count < len(@perms)) {
        var $best_overlap = -1
        var $best_p = ""
        
        for val $p (@perms) {
            next if $seen{$p}
            
            # Check overlap from largest to smallest
            var $current_overlap = 0
            for (var $o = $n - 1; $o >= 1; $o--) {
                val $end = substr($res, length($res) - $o)
                val $start = substr($p, 0, $o)
                if ($end eq $start) {
                    $current_overlap = $o
                    last
                }
            }
            
            if ($current_overlap > $best_overlap) {
                $best_overlap = $current_overlap
                $best_p = $p
            }
        }
        
        $res .= substr($best_p, $best_overlap)
        $seen{$best_p} = 1
        $seen_count++
    }
    $res
}

# Test n=2
val $s2 = Rosetta::Superperm::find_short(2)
assert_eq length($s2), 3, "n=2 minimal length is 3"
assert_ok Rosetta::Superperm::is_superperm($s2, 2), "is superperm n=2"

# Test n=3
val $s3 = Rosetta::Superperm::find_short(3)
assert_eq length($s3), 9, "n=3 minimal length is 9"
assert_ok Rosetta::Superperm::is_superperm($s3, 3), "is superperm n=3"

test_run
