#!/usr/bin/env stryke
# Rosetta Code: Superpermutation minimisation

fn Rosetta::Superperm::get_permutations(@items) {
    if (len(@items) == 0) { return ([]) }
    my @res
    for my $i (0 .. len(@items) - 1) {
        my @rest = @items
        my $first = splice(@rest, $i, 1)
        my @sub_perms = Rosetta::Superperm::get_permutations(@rest)
        for my $p (@sub_perms) {
            push @res, [$first, @$p]
        }
    }
    @res
}

fn Rosetta::Superperm::is_superperm($s, $n) {
    my @items = 1:$n
    my @perms = Rosetta::Superperm::get_permutations(@items)
    
    for my $p (@perms) {
        my $p_str = join("", @$p)
        if (index($s, $p_str) == -1) {
            return 0
        }
    }
    1
}

fn Rosetta::Superperm::find_short($n) {
    my @items = 1:$n
    my @perms_refs = Rosetta::Superperm::get_permutations(@items)
    my @perms
    for my $p_ref (@perms_refs) { push @perms, join("", @$p_ref) }
    
    my $res = $perms[0]
    my %seen
    $seen{$perms[0]} = 1
    my $seen_count = 1
    
    while ($seen_count < len(@perms)) {
        my $best_overlap = -1
        my $best_p = ""
        
        for my $p (@perms) {
            next if $seen{$p}
            
            # Check overlap from largest to smallest
            my $current_overlap = 0
            for (my $o = $n - 1; $o >= 1; $o--) {
                my $end = substr($res, len($res) - $o)
                my $start = substr($p, 0, $o)
                if ($end eq $start) {
                    $current_overlap = $o
                    last
                }
            }
            
            if ($current_overlap > $best_overlap) {
                $best_overlap = $current_overlap
                $best_p = $p
            }
        }
        
        $res .= substr($best_p, $best_overlap)
        $seen{$best_p} = 1
        $seen_count++
    }
    $res
}

# Test n=2
my $s2 = Rosetta::Superperm::find_short(2)
assert_eq len($s2), 3, "n=2 minimal length is 3"
assert_ok Rosetta::Superperm::is_superperm($s2, 2), "is superperm n=2"

# Test n=3
my $s3 = Rosetta::Superperm::find_short(3)
assert_eq len($s3), 9, "n=3 minimal length is 9"
assert_ok Rosetta::Superperm::is_superperm($s3, 3), "is superperm n=3"

test_run
