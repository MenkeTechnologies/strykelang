#!/usr/bin/env stryke
# Rosetta Code: Pythagoras tree
# Recursively grow squares from an initial base square. Each square at
# depth d spawns two children rotated by ±45° at depth d+1, scaled by
# √2/2. Returns the list of squares, each as four corner points
# (counter-clockwise from bottom-left).

fn Rosetta::PythTree::build($p1, $p2, $depth) {
    return [] if $depth < 0
    # Build square on edge p1→p2 (interpreted as bottom edge of square)
    val $dx = $p2->[0] - $p1->[0]
    val $dy = $p2->[1] - $p1->[1]
    # Perpendicular (rotated 90° counter-clockwise)
    val $px = -$dy
    val $py =  $dx
    val $p3 = [$p2->[0] + $px, $p2->[1] + $py]
    val $p4 = [$p1->[0] + $px, $p1->[1] + $py]
    val @sq = ($p1, $p2, $p3, $p4)
    var @result = (\@sq)
    return \@result if $depth == 0
    # Apex of the right-angle triangle on top edge p4→p3
    val $ax = ($p4->[0] + $p3->[0]) / 2 + ($p3->[1] - $p4->[1]) / 2
    val $ay = ($p4->[1] + $p3->[1]) / 2 - ($p3->[0] - $p4->[0]) / 2
    val $apex = [$ax, $ay]
    val $left  = Rosetta::PythTree::build($p4, $apex, $depth - 1)
    val $right = Rosetta::PythTree::build($apex, $p3, $depth - 1)
    push @result, @$left
    push @result, @$right
    \@result
}

fn Rosetta::PythTree::count_at($depth) {
    # 1 + 2 + 4 + ... + 2^depth = 2^(depth+1) - 1
    (1 << ($depth + 1)) - 1
}

# Depth 0: single square
val $d0 = Rosetta::PythTree::build([0, 0], [1, 0], 0)
assert_eq len(@$d0), 1, "depth 0 → 1 square"
assert_eq Rosetta::PythTree::count_at(0), 1, "count formula d=0"

# Depth 1: 1 + 2 = 3 squares
val $d1 = Rosetta::PythTree::build([0, 0], [1, 0], 1)
assert_eq len(@$d1), 3, "depth 1 → 3 squares"
assert_eq Rosetta::PythTree::count_at(1), 3, "count formula d=1"

# Depth 5: 63 squares
val $d5 = Rosetta::PythTree::build([0, 0], [1, 0], 5)
assert_eq len(@$d5), 63, "depth 5 → 63 squares"

# Depth 7: 255 squares
val $d7 = Rosetta::PythTree::build([0, 0], [1, 0], 7)
assert_eq len(@$d7), 255, "depth 7 → 255 squares"

# Root square corners
val $root = $d5->[0]
assert_eq $root->[0][0], 0, "root corner x"
assert_eq $root->[0][1], 0, "root corner y"
assert_eq $root->[2][0], 1, "top-right x"
assert_eq $root->[2][1], 1, "top-right y"

# All sub-squares strictly smaller than the root (side ≤ 1)
var $all_small = 1
for val $i (1..len(@$d5) - 1) {
    val $sq = $d5->[$i]
    val $sx = $sq->[1][0] - $sq->[0][0]
    val $sy = $sq->[1][1] - $sq->[0][1]
    val $side = sqrt($sx * $sx + $sy * $sy)
    $all_small = 0 if $side >= 1.001
}
assert_ok $all_small, "every child square has side < 1"

# Pipe form
4 |> Rosetta::PythTree::count_at |> assert_eq(31, "pipe count(4) = 31")

test_run
