#!/usr/bin/env stryke
# Rosetta Code: Soundex

fn Rosetta::Soundex::compute($name) {
    val $s = ~> $name uc
    val @chars = ~> $s chars
    
    val $first = $chars[0]
    val %codes = (
        B=>1, F=>1, P=>1, V=>1,
        C=>2, G=>2, J=>2, K=>2, Q=>2, S=>2, X=>2, Z=>2,
        D=>3, T=>3,
        L=>4,
        M=>5, N=>5,
        R=>6
    )
    
    val $first_code = $codes{$first} ? $codes{$first} : ""
    
    var @rest_codes = ~> @chars[1:$#chars] map {
        $codes{_} ? $codes{_} : ""
    } |> grep { _ ne "" }
    
    var @unique
    var $prev = $first_code
    for val $c (@rest_codes) {
        if ($c != $prev) {
            push @unique, $c
        }
        $prev = $c
    }
    
    var $code = $first . join("", @unique)
    $code .= "000"
    substr($code, 0, 4)
}

assert_eq Rosetta::Soundex::compute("Robert"), "R163", "Soundex of Robert"
assert_eq Rosetta::Soundex::compute("Rupert"), "R163", "Soundex of Rupert"
assert_eq Rosetta::Soundex::compute("Ashcraft"), "A261", "Soundex of Ashcraft"

test_run
