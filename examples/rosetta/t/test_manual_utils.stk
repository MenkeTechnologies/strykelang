#!/usr/bin/env stryke
# Rosetta Code: Manual Math (GCD, LCM, Dedup)

fn algo_gcd($a, $b) {
    while ($b) { ($a, $b) = ($b, $a % $b) }
    $a
}

fn algo_lcm($a, $b) {
    abs($a * $b) / algo_gcd($a, $b)
}

fn algo_dedup($list) {
    my %seen; my @res
    for my $x (@$list) {
        if (!$seen{$x}) {
            push @res, $x
            $seen{$x} = 1
        }
    }
    \@res
}

assert_eq algo_gcd(48, 18), 6, "gcd(48,18)"
assert_eq algo_lcm(12, 18), 36, "lcm(12,18)"
my $d = algo_dedup([1, 2, 1, 3, 2])
assert_eq join(",", @$d), "1,2,3", "dedup [1,2,1,3,2]"
test_run
