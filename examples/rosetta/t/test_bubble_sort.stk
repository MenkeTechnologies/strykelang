#!/usr/bin/env stryke
# Rosetta Code: Bubble Sort

fn Rosetta::BubbleSort::sort(@arr) {
    my $n = len(@arr)
    for my $i (0..$n-2) {
        for my $j (0..$n-2-$i) {
            if ($arr[$j] > $arr[$j+1]) {
                ($arr[$j], $arr[$j+1]) = ($arr[$j+1], $arr[$j])
            }
        }
    }
    @arr
}

my @sorted = Rosetta::BubbleSort::sort(64, 34, 25, 12, 22, 11, 90)
assert_eq join(",", @sorted), "11,12,22,25,34,64,90", "bubble sort"

my @single = Rosetta::BubbleSort::sort(42)
assert_eq join(",", @single), "42", "single element"

my @already = Rosetta::BubbleSort::sort(1, 2, 3, 4, 5)
assert_eq join(",", @already), "1,2,3,4,5", "already sorted"

my @reverse = Rosetta::BubbleSort::sort(5, 4, 3, 2, 1)
assert_eq join(",", @reverse), "1,2,3,4,5", "reverse sorted"

my @dups = Rosetta::BubbleSort::sort(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq join(",", @dups), "1,1,2,3,4,5,6,9", "with duplicates"

test_run
