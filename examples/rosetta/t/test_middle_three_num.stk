#!/usr/bin/env stryke
# Rosetta Code: Middle three digits

fn Rosetta::MiddleThreeNum::middle_three($n) {
    val $s = abs($n) . ""
    val $len = length($s)
    if ($len < 3 || $len % 2 == 0) {
        return "error"
    }
    val $mid = int($len / 2)
    substr($s, $mid - 1, 3)
}

assert_eq Rosetta::MiddleThreeNum::middle_three(12345), "234", "12345 -> 234"
assert_eq Rosetta::MiddleThreeNum::middle_three(123), "123", "123 -> 123"
assert_eq Rosetta::MiddleThreeNum::middle_three(1234567), "345", "1234567 -> 345"
assert_eq Rosetta::MiddleThreeNum::middle_three(10), "error", "10 -> error"
assert_eq Rosetta::MiddleThreeNum::middle_three(1234), "error", "1234 -> error"

test_run
