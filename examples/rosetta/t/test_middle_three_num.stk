#!/usr/bin/env stryke
# Rosetta Code: Middle three digits

fn middle_three($n) {
    my $s = abs($n) . ""
    my $len = length($s)
    if ($len < 3 || $len % 2 == 0) {
        return "error"
    }
    my $mid = int($len / 2)
    substr($s, $mid - 1, 3)
}

assert_eq middle_three(12345), "234", "12345 -> 234"
assert_eq middle_three(123), "123", "123 -> 123"
assert_eq middle_three(1234567), "345", "1234567 -> 345"
assert_eq middle_three(10), "error", "10 -> error"
assert_eq middle_three(1234), "error", "1234 -> error"

test_run
