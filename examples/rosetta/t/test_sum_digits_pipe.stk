#!/usr/bin/env stryke
# Rosetta Code: Sum digits (using split, map, and reduce with pipes)

fn Rosetta::SumDigits::solve($n) {
    $n |> split("") |> map { int($_) } |> reduce { _0 + _1 }
}

assert_eq Rosetta::SumDigits::solve(12345), 15, "sum digits of 12345"
assert_eq Rosetta::SumDigits::solve(10101), 3, "sum digits of 10101"
assert_eq Rosetta::SumDigits::solve(999), 27, "sum digits of 999"

test_run
