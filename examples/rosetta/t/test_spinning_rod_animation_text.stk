#!/usr/bin/env stryke
# Rosetta Code: Spinning rod animation/Text

fn Rosetta::Rod::frames($count) {
    val @cycle = ("|", "/", "-", "\\")
    var @out
    for val $i (0:$count - 1) {
        push @out, $cycle[$i % 4]
    }
    \@out
}

val $frames = Rosetta::Rod::frames(8)

assert_eq join("", @$frames), "|/-\\|/-\\", "rod cycles through four orientations"
assert_eq $frames->[0], "|", "first frame is vertical"
assert_eq $frames->[3], "\\", "fourth frame is backslash"

test_run
