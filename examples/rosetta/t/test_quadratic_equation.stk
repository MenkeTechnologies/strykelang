#!/usr/bin/env stryke
# Rosetta Code: Roots of a quadratic equation

fn Rosetta::QuadraticEquation::solve($a, $b, $c) {
    my $d = $b * $b - 4 * $a * $c
    my @res
    if ($d < 0) { return \@res }
    
    my $s = sqrt($d)
    my $r1 = (0 - $b + $s) / (2 * $a)
    push @res, $r1
    
    if ($d > 0) {
        my $r2 = (0 - $b - $s) / (2 * $a)
        push @res, $r2
    }
    \@res
}

my $roots1 = Rosetta::QuadraticEquation::solve(1, -3, 2) # x^2 - 3x + 2 = 0 => (2, 1)
assert_eq scalar(@$roots1), 2, "has 2 roots"
assert_eq $roots1->[0], 2, "quadratic root 1"
assert_eq $roots1->[1], 1, "quadratic root 2"

my $roots2 = Rosetta::QuadraticEquation::solve(1, 2, 1) # x^2 + 2x + 1 = 0 => (-1)
assert_eq scalar(@$roots2), 1, "has 1 root"
assert_eq $roots2->[0], -1, "quadratic double root"

test_run
