#!/usr/bin/env stryke
# Rosetta Code: Cousin primes

fn Rosetta::CousinPrimes::check($p1, $p2) {
    is_prime($p1) && is_prime($p2) && abs($p1 - $p2) == 4
}

assert_ok Rosetta::CousinPrimes::check(3, 7), "3 and 7"
assert_ok Rosetta::CousinPrimes::check(7, 11), "7 and 11"
assert_ok Rosetta::CousinPrimes::check(13, 17), "13 and 17"
assert_ok !Rosetta::CousinPrimes::check(3, 5), "3 and 5 not"

3 |> Rosetta::CousinPrimes::check(7) |> assert_ok("pipe cousin")

test_run
