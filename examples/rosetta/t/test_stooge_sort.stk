#!/usr/bin/env stryke
# Rosetta Code: Stooge Sort

fn stooge_sort_recursive {
    my $list = $_[0]
    my $i = $_[1]
    my $j = $_[2]
    my @arr = @$list
    
    if ($arr[$i] > $arr[$j]) {
        ($arr[$i], $arr[$j]) = ($arr[$j], $arr[$i])
    }
    
    if ($j - $i + 1 > 2) {
        my $t = int(($j - $i + 1) / 3)
        my $res1 = stooge_sort_recursive([@arr], $i, $j - $t)
        @arr = @$res1
        my $res2 = stooge_sort_recursive([@arr], $i + $t, $j)
        @arr = @$res2
        my $res3 = stooge_sort_recursive([@arr], $i, $j - $t)
        @arr = @$res3
    }
    \@arr
}

fn stooge_sort {
    my $list = $_[0]
    my @data = @$list
    my $n = len(@data)
    if ($n < 2) {
        return \@data
    }
    stooge_sort_recursive([@data], 0, $n - 1)
}

my $data = [1, 4, 5, 3, -6, 3, 7, 10, -2, -5, 7, 5, 9, -3, 7]
my $sorted = stooge_sort($data)
assert_eq join(",", @$sorted), "-6,-5,-3,-2,1,3,3,4,5,5,7,7,7,9,10", "stooge sort"

test_run
