#!/usr/bin/env stryke
# Rosetta Code: Stooge Sort

fn Rosetta::StoogeSort::stooge_sort_recursive {
    val $list = _
    var $i = _1
    var $j = _2
    var @arr = @$list
    
    if ($arr[$i] > $arr[$j]) {
        ($arr[$i], $arr[$j]) = ($arr[$j], $arr[$i])
    }
    
    if ($j - $i + 1 > 2) {
        val $t = int(($j - $i + 1) / 3)
        val $res1 = Rosetta::StoogeSort::stooge_sort_recursive([@arr], $i, $j - $t)
        @arr = @$res1
        val $res2 = Rosetta::StoogeSort::stooge_sort_recursive([@arr], $i + $t, $j)
        @arr = @$res2
        val $res3 = Rosetta::StoogeSort::stooge_sort_recursive([@arr], $i, $j - $t)
        @arr = @$res3
    }
    \@arr
}

fn Rosetta::StoogeSort::stooge_sort {
    val $list = _
    val @data = @$list
    val $n = len(@data)
    if ($n < 2) {
        return \@data
    }
    Rosetta::StoogeSort::stooge_sort_recursive([@data], 0, $n - 1)
}

val $data = [1, 4, 5, 3, -6, 3, 7, 10, -2, -5, 7, 5, 9, -3, 7]
val $sorted = Rosetta::StoogeSort::stooge_sort($data)
assert_eq join(",", @$sorted), "-6,-5,-3,-2,1,3,3,4,5,5,7,7,7,9,10", "stooge sort"

test_run
