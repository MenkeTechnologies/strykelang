#!/usr/bin/env stryke
# Rosetta Code: Bitwise operations

fn Rosetta::Bitwise::bit_and($a, $b) { $a & $b }
fn Rosetta::Bitwise::bit_or($a, $b) { $a | $b }
fn Rosetta::Bitwise::bit_xor($a, $b) { $a ^ $b }
fn Rosetta::Bitwise::bit_not($a) { ~$a }
fn Rosetta::Bitwise::bit_shl($a, $b) { $a << $b }
fn Rosetta::Bitwise::bit_shr($a, $b) { $a >> $b }

assert_eq Rosetta::Bitwise::bit_and(10, 2), 2, "10 & 2"
assert_eq Rosetta::Bitwise::bit_or(10, 2), 10, "10 | 2"
assert_eq Rosetta::Bitwise::bit_xor(10, 2), 8, "10 ^ 2"
assert_eq Rosetta::Bitwise::bit_shl(10, 2), 40, "10 << 2"
assert_eq Rosetta::Bitwise::bit_shr(10, 2), 2, "10 >> 2"

# pipe and threading
10 |> Rosetta::Bitwise::bit_and(2) |> assert_eq(2, "pipe and")
~> 10 fn { Rosetta::Bitwise::bit_or(_, 2) } |> assert_eq(10, "threaded or")

test_run
