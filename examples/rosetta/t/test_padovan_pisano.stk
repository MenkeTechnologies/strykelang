#!/usr/bin/env stryke
# Rosetta Code: Padovan sequence (Pisano variant) — P(0)=P(1)=P(2)=1,
# P(n)=P(n-2)+P(n-3). OEIS A000931 starts 1, 1, 1, 2, 2, 3, 4, 5, 7, 9, 12, 16.

fn Rosetta::Padovan::nth($n) {
    return 1 if $n < 3
    my ($_0, $_1, $c) = (1, 1, 1)
    for (3 .. $n) {
        ($_0, $_1, $c) = ($_1, $c, $_0 + $_1)
    }
    $c
}

fn Rosetta::Padovan::sequence($count) {
    ~> 0:$count - 1 map { Rosetta::Padovan::nth(_) }
}

# OEIS A000931 first 12.
my @seq = Rosetta::Padovan::sequence(12)
assert_eq join(",", @seq),
    "1,1,1,2,2,3,4,5,7,9,12,16",
    "Padovan(0..11)"

# Recurrence sanity: P(n) == P(n-2) + P(n-3) for all n >= 3.
for my $n (3 .. 20) {
    my $lhs = Rosetta::Padovan::nth($n)
    my $rhs = Rosetta::Padovan::nth($n - 2) + Rosetta::Padovan::nth($n - 3)
    assert_eq $lhs, $rhs, "recurrence n=$n"
}

# Plastic-number ratio: P(n+1) / P(n) → ~1.32471795724475 (rho).
my $ratio = Rosetta::Padovan::nth(50) / Rosetta::Padovan::nth(49)
assert_ok abs($ratio - 1.32471795724475) < 1e-9, "P(n+1)/P(n) → plastic number"

test_run
