#!/usr/bin/env stryke
# Rosetta Code: Honeycombs

fn Rosetta::Honey::new_board() {
    var @letters = split //, "ABCDEFGHIJKLMNOPQRST"
    var @cells
    for val $col (0:4) {
        for val $row (0:3) {
            push @cells, {
                letter => shift(@letters),
                col => $col,
                row => $row,
                selected => 0,
            }
        }
    }
    \@cells
}

fn Rosetta::Honey::render($cells) {
    var @lines
    for val $display_row (0:4) {
        var @parts
        for val $cell (@$cells) {
            next if $cell->{row} + ($cell->{col} % 2) != $display_row
            val $ch = $cell->{selected} ? lc($cell->{letter}) : $cell->{letter}
            push @parts, "[" . $ch . "]"
        }
        push @lines, join("   ", @parts)
    }
    \@lines
}

fn Rosetta::Honey::select($cells, $picked, $history) {
    val $want = uc($picked)
    for var $cell (@$cells) {
        next if $cell->{letter} ne $want
        next if $cell->{selected}
        $cell->{selected} = 1
        push @$history, $want
        return 1
    }
    0
}

val $board = Rosetta::Honey::new_board()
val @history

assert_eq len(@$board), 20, "20 hex cells"

var %seen
for val $cell (@$board) { $seen{$cell->{letter}} = 1 }
assert_eq len(keys %seen), 20, "20 unique letters"

val $lines = Rosetta::Honey::render($board)
assert_eq len(@$lines), 5, "staggered layout uses 5 display rows"

Rosetta::Honey::select($board, "B", \@history)
Rosetta::Honey::select($board, "Q", \@history)
Rosetta::Honey::select($board, "T", \@history)

val $selected_view = join("\n", @{Rosetta::Honey::render($board)})
assert_eq join("", @history), "BQT", "selection history tracked"
assert_eq $selected_view =~ /\[b\]/, 1, "selected cells are visibly marked"

test_run
