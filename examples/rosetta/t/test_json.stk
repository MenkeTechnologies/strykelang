#!/usr/bin/env stryke
# Rosetta Code: JSON

fn Rosetta::JSON::parse($s) {
    $s |> from_json()
}

fn Rosetta::JSON::stringify($val) {
    $val |> to_json()
}

my $json_str = '{"foo": 1, "bar": [1, 2, 3], "baz": {"a": "b"}}'
my $obj = Rosetta::JSON::parse($json_str)

assert_eq $obj->{foo}, 1, "json foo"
assert_eq len(@{$obj->{bar}}), 3, "json bar size"
assert_eq $obj->{baz}->{a}, "b", "json baz a"

my $back = Rosetta::JSON::stringify($obj)
# JSON stringify might have different key order, but we can parse it back
my $obj2 = Rosetta::JSON::parse($back)
assert_eq $obj2->{foo}, 1, "round trip foo"
assert_eq $obj2->{baz}->{a}, "b", "round trip baz a"

test_run
