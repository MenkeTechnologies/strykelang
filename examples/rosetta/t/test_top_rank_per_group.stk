#!/usr/bin/env stryke
# Rosetta Code: Top rank per group
# Given a list of records with a group key and a numeric score,
# return the top-N records of each group, sorted by descending score.
# Tie-breaking: original input order.

fn Rosetta::TopRank::compute($records, $group_key, $score_key, $n) {
    val %by_group
    var $idx = 0
    for val $r (@$records) {
        val $g = $r->{$group_key}
        push @{$by_group{$g}}, [$idx, $r]
        $idx++
    }
    var %out
    for val $g (keys %by_group) {
        val @rs = @{$by_group{$g}}
        val @sorted = sort {
            ($b->[1]{$score_key} <=> $a->[1]{$score_key})
            || ($a->[0] <=> $b->[0])
        } @rs
        var @top
        val $take = $n < len(@sorted) ? $n : len(@sorted)
        for val $i (0:$take - 1) {
            push @top, $sorted[$i][1]
        }
        $out{$g} = \@top
    }
    \%out
}

# Rosetta canonical employee dataset (subset)
val @employees = (
    { name => "Tyler Bennett", id => "E10297", salary => 32000, dept => "D101" },
    { name => "John Rappl",    id => "E21437", salary => 47000, dept => "D050" },
    { name => "George Woltman",id => "E00127", salary => 53500, dept => "D101" },
    { name => "Adam Smith",    id => "E63535", salary => 18000, dept => "D202" },
    { name => "Claire Buckman",id => "E39876", salary => 27800, dept => "D202" },
    { name => "David McClellan",id => "E04242", salary => 41500, dept => "D101" },
    { name => "Rich Holcomb",  id => "E01234", salary => 49500, dept => "D202" },
    { name => "Nathan Adams",  id => "E41298", salary => 21900, dept => "D050" },
    { name => "Richard Potter",id => "E43128", salary => 15900, dept => "D101" },
    { name => "David Motsinger",id => "E27002",salary => 19250, dept => "D202" },
    { name => "Tim Sampair",   id => "E03033", salary => 27000, dept => "D101" },
    { name => "Kim Arlich",    id => "E10001", salary => 57000, dept => "D190" },
    { name => "Timothy Grove", id => "E16398", salary => 29900, dept => "D190" },
)

# Top 2 of each department by salary
val $r = Rosetta::TopRank::compute(\@employees, "dept", "salary", 2)

# D101: Woltman 53500, McClellan 41500
assert_eq len(@{$r->{D101}}), 2, "D101 has 2 entries"
assert_eq $r->{D101}[0]{name}, "George Woltman",  "D101 #1"
assert_eq $r->{D101}[1]{name}, "David McClellan", "D101 #2"

# D050: Rappl 47000, Adams 21900
assert_eq $r->{D050}[0]{name}, "John Rappl",   "D050 #1"
assert_eq $r->{D050}[1]{name}, "Nathan Adams", "D050 #2"

# D202: Holcomb 49500, Buckman 27800
assert_eq $r->{D202}[0]{name}, "Rich Holcomb",   "D202 #1"
assert_eq $r->{D202}[1]{name}, "Claire Buckman", "D202 #2"

# D190 has only 2 — top 2 returns both
assert_eq len(@{$r->{D190}}), 2, "D190 has 2 entries"

# Top 1 per group
val $top1 = Rosetta::TopRank::compute(\@employees, "dept", "salary", 1)
for val $g ("D101", "D050", "D202", "D190") {
    assert_eq len(@{$top1->{$g}}), 1, sprintf("%s has 1 entry", $g)
}

# Top 100 returns all in each group
val $all = Rosetta::TopRank::compute(\@employees, "dept", "salary", 100)
var $total = 0
for val $g (keys %$all) { $total += len(@{$all->{$g}}) }
assert_eq $total, len(@employees), "all 13 records returned"

# Pipe form
\@employees |> fn { Rosetta::TopRank::compute(_, "dept", "salary", 1) }
            |> fn { $_->{D101}[0]{name} }
            |> assert_eq("George Woltman", "pipe top D101")

test_run
