#!/usr/bin/env stryke
# Rosetta Code: Rate counter

fn Rosetta::RateCounter::demo() {
    # Task: Count occurrences of events over a period.
    my $count = 0
    my $start_time = time()
    
    # Simulate events for 1 second
    while (time() - $start_time < 1) {
        $count++
    }
    
    # Return rate per second
    $count
}

my $rate = Rosetta::RateCounter::demo()
# p "Rate: $rate events/sec"
assert_ok $rate > 0, "Measured a positive rate"

test_run
