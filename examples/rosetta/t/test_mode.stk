#!/usr/bin/env stryke
# Rosetta Code: Mode

fn Rosetta::Mode::compute($list) {
    var $result
    if (len(@$list) == 0) {
        $result = []
    } else {
        var %counts
        for val $x (@$list) { $counts{$x}++ }
        
        var $max = 0
        for val $k (keys %counts) {
            if ($counts{$k} > $max) {
                $max = $counts{$k}
            }
        }
        
        var @res
        for val $k (keys %counts) {
            if ($counts{$k} == $max) {
                push @res, $k
            }
        }
        val @sorted = sort(@res)
        $result = [@sorted]
    }
    $result
}

val $m1 = Rosetta::Mode::compute([1, 3, 6, 6, 6, 6, 7, 7, 12, 12, 17])
assert_eq join(",", @$m1), "6", "mode is 6"

val $m2 = Rosetta::Mode::compute([1, 1, 2, 4, 4])
assert_eq join(",", @$m2), "1,4", "modes are 1 and 4"

val $m3 = Rosetta::Mode::compute(["apple", "banana", "apple"])
assert_eq join(",", @$m3), "apple", "mode with strings"

test_run
