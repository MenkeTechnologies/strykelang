#!/usr/bin/env stryke
# Rosetta Code: Euclidean distance

fn my_euclidean_distance($v1, $v2) {
    my $sum_sq = 0
    for my $i (0..scalar(@$v1)-1) {
        $sum_sq += ($v1->[$i] - $v2->[$i]) ** 2
    }
    sqrt($sum_sq)
}

assert_eq my_euclidean_distance([0, 0], [3, 4]), 5, "3-4-5 triangle"
assert_ok abs(my_euclidean_distance([1, 1], [2, 2]) - 1.4142) < 0.0001, "Diagonal distance"

test_run
