#!/usr/bin/env stryke
# Rosetta Code: Pascal's triangle

fn Rosetta::PascalTriangleGen::generate($n) {
    var @res = ([1])
    for val $i (1:$n-1) {
        var @row = (1)
        val $prev = $res[$i-1]
        for val $j (1:$i-1) {
            push @row, $prev->[$j-1] + $prev->[$j]
        }
        push @row, 1
        push @res, [@row]
    }
    \@res
}

val $tri = Rosetta::PascalTriangleGen::generate(5)
assert_eq len(@$tri), 5, "5 rows"
assert_eq join(",", @{$tri->[0]}), "1", "row 0"
assert_eq join(",", @{$tri->[2]}), "1,2,1", "row 2"
assert_eq join(",", @{$tri->[4]}), "1,4,6,4,1", "row 4"

test_run
