#!/usr/bin/env stryke
# Rosetta Code: Isolated primes

fn Rosetta::IsolatedPrimes::check($p) {
    is_prime($p) && !is_prime($p - 2) && !is_prime($p + 2)
}

assert_ok Rosetta::IsolatedPrimes::check(2), "2 is isolated (0 and 4 not prime)"
assert_ok Rosetta::IsolatedPrimes::check(23), "23 is isolated (21 and 25 not prime)"
assert_ok !Rosetta::IsolatedPrimes::check(3), "3 is not (5 is prime)"
assert_ok !Rosetta::IsolatedPrimes::check(5), "5 is not (3 and 7 are prime)"
assert_ok !Rosetta::IsolatedPrimes::check(7), "5 is prime"

23 |> Rosetta::IsolatedPrimes::check |> assert_ok("pipe isolated prime")

test_run
