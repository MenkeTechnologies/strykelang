#!/usr/bin/env stryke
# Rosetta Code: Kaprekar Numbers

fn Rosetta::Kaprekar::check($n) {
    if ($n == 1) {
        1
    } else {
        my $sq = $n * $n
        my $s = "$sq"
        my $len = length($s)
        my $found = 0
        for my $i (1..$len-1) {
            my $left = substr($s, 0, $i)
            my $right = substr($s, $i)
            if ($right !~ /^0+$/) {
                if (int($left) + int($right) == $n) {
                    $found = 1
                }
            }
        }
        $found
    }
}

fn Rosetta::Kaprekar::generate($max) {
    1:$max |> grep { Rosetta::Kaprekar::check($_) }
}

assert_ok Rosetta::Kaprekar::check(1), "1 is kaprekar"
assert_ok Rosetta::Kaprekar::check(9), "9 is kaprekar (81 = 8+1)"
assert_ok Rosetta::Kaprekar::check(45), "45 is kaprekar (2025 = 20+25)"
assert_ok Rosetta::Kaprekar::check(55), "55 is kaprekar (3025 = 30+25)"
assert_ok Rosetta::Kaprekar::check(99), "99 is kaprekar (9801 = 98+01)"
assert_ok Rosetta::Kaprekar::check(297), "297 is kaprekar (88209 = 88+209)"

assert_ok !Rosetta::Kaprekar::check(2), "2 is not kaprekar"
assert_ok !Rosetta::Kaprekar::check(10), "10 is not kaprekar"

my @kap = Rosetta::Kaprekar::generate(100)
assert_eq join(",", @kap), "1,9,45,55,99", "kaprekar up to 100"

test_run
