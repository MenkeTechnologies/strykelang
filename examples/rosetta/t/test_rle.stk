#!/usr/bin/env stryke
# Rosetta Code: Run-Length Encoding

fn Rosetta::Rle::rle_encode($s) {
    if (len($s) == 0) {
        ""
    } else {
        val @chars = $s |> split //
        var @result
        var $prev = $chars[0]
        var $count = 1
        
        for val $i (1:$#chars) {
            if ($chars[$i] eq $prev) {
                $count++
            } else {
                push @result, ($count > 1 ? "$count$prev" : $prev)
                $prev = $chars[$i]
                $count = 1
            }
        }
        push @result, ($count > 1 ? "$count$prev" : $prev)
        join "", @result
    }
}

fn Rosetta::Rle::rle_decode($s) {
    var $result = ""
    while ($s =~ /(\d*)(.)/g) {
        val $count = $1 eq "" ? 1 : $1
        $result .= $2 x $count
    }
    $result
}

assert_eq Rosetta::Rle::rle_encode("WWWWWWWWWWWWBWWWWWWWWWWWWBBBWWWWWWWWWWWWWWWWWWWWWWWWB"), "12WB12W3B24WB", "encode example"
assert_eq Rosetta::Rle::rle_encode("AABBBCCCC"), "2A3B4C", "simple encode"
assert_eq Rosetta::Rle::rle_encode("ABC"), "ABC", "no runs"
assert_eq Rosetta::Rle::rle_encode(""), "", "empty"

assert_eq Rosetta::Rle::rle_decode("12WB12W3B24WB"), "WWWWWWWWWWWWBWWWWWWWWWWWWBBBWWWWWWWWWWWWWWWWWWWWWWWWB", "decode example"
assert_eq Rosetta::Rle::rle_decode("2A3B4C"), "AABBBCCCC", "simple decode"
assert_eq Rosetta::Rle::rle_decode("ABC"), "ABC", "decode no runs"

val $original = "AABBBCCCC"
assert_eq Rosetta::Rle::rle_decode(Rosetta::Rle::rle_encode($original)), $original, "roundtrip"

test_run
