#!/usr/bin/env stryke
# Rosetta Code: Bitonic sort — comparator network that recursively
# builds bitonic sequences and merges them. Length must be a power of 2.

fn Rosetta::Bitonic::compare_swap($arr, $i, $j, $up) {
    my $x = $arr->[$i]
    my $y = $arr->[$j]
    if (($x > $y) == $up) {
        $arr->[$i] = $y
        $arr->[$j] = $x
    }
}

fn Rosetta::Bitonic::merge($arr, $lo, $cnt, $up) {
    return if $cnt < 2
    my $k = int($cnt / 2)
    for my $i ($lo..$lo + $k - 1) {
        Rosetta::Bitonic::compare_swap($arr, $i, $i + $k, $up)
    }
    Rosetta::Bitonic::merge($arr, $lo,      $k, $up)
    Rosetta::Bitonic::merge($arr, $lo + $k, $k, $up)
}

fn Rosetta::Bitonic::recur($arr, $lo, $cnt, $up) {
    return if $cnt < 2
    my $k = int($cnt / 2)
    Rosetta::Bitonic::recur($arr, $lo,      $k, 1)
    Rosetta::Bitonic::recur($arr, $lo + $k, $k, 0)
    Rosetta::Bitonic::merge($arr, $lo, $cnt, $up)
}

fn Rosetta::Bitonic::sort($list) {
    my @arr = @$list
    my $n = len(@arr)
    # Round up to next power of 2 with sentinel +inf so ascending order
    # leaves the real values at the front.
    my $p = 1
    $p *= 2 while $p < $n
    my $inf = 1e18
    push @arr, $inf while len(@arr) < $p
    Rosetta::Bitonic::recur(\@arr, 0, $p, 1)
    splice @arr, $n
    \@arr
}

my $r1 = Rosetta::Bitonic::sort([3, 7, 4, 8, 6, 2, 1, 5])
assert_eq join(",", @$r1), "1,2,3,4,5,6,7,8", "power-of-2 length 8"

my $r2 = Rosetta::Bitonic::sort([4, 1, 3, 2])
assert_eq join(",", @$r2), "1,2,3,4", "length 4"

my $r3 = Rosetta::Bitonic::sort([5, 2, 9, 1, 7])
assert_eq join(",", @$r3), "1,2,5,7,9", "non-power-of-2 padded"

my $r4 = Rosetta::Bitonic::sort([])
assert_eq join(",", @$r4), "", "empty"

my $r5 = Rosetta::Bitonic::sort([42])
assert_eq join(",", @$r5), "42", "single"

my $r6 = Rosetta::Bitonic::sort([-3, 0, -1, 7, -3, 2])
assert_eq join(",", @$r6), "-3,-3,-1,0,2,7", "negatives + dups"

test_run
