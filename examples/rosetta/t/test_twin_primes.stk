#!/usr/bin/env stryke
# Rosetta Code: Twin primes

fn TwinPrimes::my_is_prime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        my $limit = sqrt($n)
        my $res = 1
        my $i = 3
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

fn TwinPrimes::are_twin_primes($p1, $p2) {
    TwinPrimes::my_is_prime($p1) && TwinPrimes::my_is_prime($p2) && abs($p1 - $p2) == 2
}

assert_ok TwinPrimes::are_twin_primes(3, 5), "3 and 5"
assert_ok TwinPrimes::are_twin_primes(11, 13), "11 and 13"
assert_ok TwinPrimes::are_twin_primes(17, 19), "17 and 19"
assert_ok !TwinPrimes::are_twin_primes(7, 11), "7 and 11 not"

3 |> TwinPrimes::are_twin_primes(5) |> assert_ok("pipe twin")

test_run
