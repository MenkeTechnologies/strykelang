#!/usr/bin/env stryke
# Rosetta Code: Ackermann Function

fn Rosetta::Ackermann::compute($m, $n) {
    if ($m == 0) {
        $n + 1
    } elsif ($n == 0) {
        Rosetta::Ackermann::compute($m - 1, 1)
    } else {
        Rosetta::Ackermann::compute($m - 1, Rosetta::Ackermann::compute($m, $n - 1))
    }
}

assert_eq Rosetta::Ackermann::compute(0, 0), 1, "ack(0,0)"
assert_eq Rosetta::Ackermann::compute(0, 5), 6, "ack(0,5)"
assert_eq Rosetta::Ackermann::compute(1, 0), 2, "ack(1,0)"
assert_eq Rosetta::Ackermann::compute(1, 5), 7, "ack(1,5)"
assert_eq Rosetta::Ackermann::compute(2, 0), 3, "ack(2,0)"
assert_eq Rosetta::Ackermann::compute(2, 3), 9, "ack(2,3)"
assert_eq Rosetta::Ackermann::compute(3, 0), 5, "ack(3,0)"
assert_eq Rosetta::Ackermann::compute(3, 3), 61, "ack(3,3)"
assert_eq Rosetta::Ackermann::compute(3, 4), 125, "ack(3,4)"

test_run
