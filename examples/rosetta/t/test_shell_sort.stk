#!/usr/bin/env stryke
# Rosetta Code: Shell sort

fn Rosetta::ShellSort::sort($list) {
    var @arr = @$list
    val $len = len(@arr)
    var @gaps = (701, 301, 132, 57, 23, 10, 4, 1)
    
    for val $gap (@gaps) {
        for val $i ($gap:$len-1) {
            val $temp = $arr[$i]
            var $j = $i
            while ($j >= $gap && $arr[$j - $gap] > $temp) {
                $arr[$j] = $arr[$j - $gap]
                $j -= $gap
            }
            $arr[$j] = $temp
        }
    }
    
    \@arr
}

val $data = [9, 8, 3, 7, 5, 6, 4, 1]
val $sorted = Rosetta::ShellSort::sort($data)
assert_eq join(",", @$sorted), "1,3,4,5,6,7,8,9", "shell sort"

val $data2 = [5, 1, 4, 2, 8]
val $sorted2 = Rosetta::ShellSort::sort($data2)
assert_eq join(",", @$sorted2), "1,2,4,5,8", "shell sort 2"

test_run
