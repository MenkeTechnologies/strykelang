#!/usr/bin/env stryke
# Rosetta Code: Animated Spinners

fn Rosetta::AnimatedSpinners::deciseconds($duration_sec) {
    val $text = "$duration_sec"
    val @parts = split /\./, $text
    val $whole = $parts[0]
    val $tenths = len(@parts) > 1 ? substr($parts[1] . "0", 0, 1) : 0
    ($whole * 10) + $tenths
}

fn Rosetta::AnimatedSpinners::spin($duration_sec) {
    val @spinners = ("|", "/", "-", "\\")
    val $frames = Rosetta::AnimatedSpinners::deciseconds($duration_sec)
    for val $i (0:$frames - 1) {
        val $char = $spinners[$i % len(@spinners)]
        print "\r$char Spinning..."
    }
    p "\rDone!       "
    return $frames
}

fn Rosetta::AnimatedSpinners::demo() {
    "Testing Animated Spinners (0.5 seconds):" |> p
    val $frames = Rosetta::AnimatedSpinners::spin(0.5)
    
    # Assertions
    assert_eq $frames, 5, "Spinner ran for exactly 5 frames"
}

Rosetta::AnimatedSpinners::demo()
test_run
