#!/usr/bin/env stryke
# Rosetta Code: Segment tree

fn Rosetta::SegmentTree::build($arr, $tree, $node, $start, $end) {
    if ($start == $end) {
        $tree->[$node] = $arr->[$start]
    } else {
        my $mid = ($start + $end) / 2 | 0
        Rosetta::SegmentTree::build($arr, $tree, 2 * $node, $start, $mid)
        Rosetta::SegmentTree::build($arr, $tree, 2 * $node + 1, $mid + 1, $end)
        $tree->[$node] = $tree->[2 * $node] + $tree->[2 * $node + 1]
    }
}

fn Rosetta::SegmentTree::query($tree, $node, $start, $end, $l, $r) {
    if ($r < $start || $end < $l) { return 0 }
    if ($l <= $start && $end <= $r) { return $tree->[$node] }
    
    my $mid = ($start + $end) / 2 | 0
    my $p1 = Rosetta::SegmentTree::query($tree, 2 * $node, $start, $mid, $l, $r)
    my $p2 = Rosetta::SegmentTree::query($tree, 2 * $node + 1, $mid + 1, $end, $l, $r)
    $p1 + $p2
}

my @data = (1, 3, 5, 7, 9, 11)
my $n = len(@data)
my @tree = map { 0 } 0..(4 * $n)
Rosetta::SegmentTree::build(\@data, \@tree, 1, 0, $n - 1)

assert_eq Rosetta::SegmentTree::query(\@tree, 1, 0, $n - 1, 1, 3), 15, "query 1..3"
assert_eq Rosetta::SegmentTree::query(\@tree, 1, 0, $n - 1, 0, 5), 36, "query 0..5"

test_run
