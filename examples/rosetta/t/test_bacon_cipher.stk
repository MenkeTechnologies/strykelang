#!/usr/bin/env stryke
# Rosetta Code: Bacon's cipher

fn Rosetta::Bacon::encode($text) {
    val $t = $text |> uc() |> { _ =~ s/[^A-Z]//gr }
    val @chars = $t |> chars()
    
    val @res = ~> @chars map {
        val $v = ord(_) - ord("A")
        var $bin = sprintf("%05b", $v)
        $bin =~ tr/01/ab/r
    }
    
    join(" ", @res)
}

fn Rosetta::Bacon::decode($text) {
    val $t = $text |> lc() |> { _ =~ s/[^ab]//gr }
    
    var @res
    for (var $i = 0; $i < length($t); $i += 5) {
        var $chunk = substr($t, $i, 5)
        val $bin = $chunk =~ tr/ab/01/r
        push @res, chr(oct("0b$bin") + ord("A"))
    }
    
    join("", @res)
}

val $t = "HELLOWORLD"
val $enc = Rosetta::Bacon::encode($t)
assert_eq $enc, "aabbb aabaa ababb ababb abbba babba abbba baaab ababb aaabb", "encode HELLO WORLD with Bacon's cipher"
assert_eq Rosetta::Bacon::decode($enc), "HELLOWORLD", "decode Bacon's cipher"

test_run
