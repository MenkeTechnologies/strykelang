#!/usr/bin/env stryke
# Rosetta Code: Random sentence from book

fn Rosetta::BookSentence::sentences($text) {
    my @parts = grep { $_ ne "" } map { s/^\s+|\s+$//gr } split /[.!?]+/, $text
    \@parts
}

fn Rosetta::BookSentence::pick($text, $seed) {
    my $sentences = Rosetta::BookSentence::sentences($text)
    $sentences->[$seed % len(@$sentences)]
}

my $book = "Call me Ishmael. Some years ago never mind how long precisely. Whenever I find myself growing grim about the mouth!"

assert_eq len(@{Rosetta::BookSentence::sentences($book)}), 3, "book text splits into sentences"
assert_eq Rosetta::BookSentence::pick($book, 4), "Some years ago never mind how long precisely", "deterministic sentence choice works"
assert_eq Rosetta::BookSentence::pick($book, 5), "Whenever I find myself growing grim about the mouth", "different seed yields different sentence"

test_run
