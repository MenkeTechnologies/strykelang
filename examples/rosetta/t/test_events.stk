#!/usr/bin/env stryke
# Rosetta Code: Events

struct RosettaEventsEmitter { listeners }

fn Rosetta::Events::init($emitter) {
    $emitter->{listeners} = +{}
}

fn Rosetta::Events::on($emitter, $event, $callback) {
    if (!exists $emitter->{listeners}->{$event}) {
        $emitter->{listeners}->{$event} = []
    }
    push @{$emitter->{listeners}->{$event}}, $callback
}

fn Rosetta::Events::emit($emitter, $event, $data) {
    if (exists $emitter->{listeners}->{$event}) {
        for val $cb (@{$emitter->{listeners}->{$event}}) {
            $cb($data)
        }
    }
}

val $emitter = RosettaEventsEmitter(+{})
var $out = +{ received => undef }
Rosetta::Events::on($emitter, "test", fn { $out->{received} = _ })
Rosetta::Events::emit($emitter, "test", "Hello Events")

assert_eq $out->{received}, "Hello Events", "Event received correctly"

test_run
