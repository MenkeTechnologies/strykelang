#!/usr/bin/env stryke
# Rosetta Code: Traveling Salesman Problem (Small)

fn Rosetta::TSP::perms($arr) {
    my $n = scalar(@$arr)
    return [[@$arr]] if $n <= 1
    my @result
    for (my $i = 0; $i < $n; $i++) {
        my @rest
        for (my $j = 0; $j < $n; $j++) {
            push @rest, $arr->[$j] if $j != $i
        }
        my $sub = Rosetta::TSP::perms(\@rest)
        for my $p (@$sub) {
            push @result, [$arr->[$i], @$p]
        }
    }
    \@result
}

fn Rosetta::TSP::solve($dist_matrix) {
    my $n = scalar(@$dist_matrix)
    my @cities = 1:($n - 1)
    my $all_perms = Rosetta::TSP::perms(\@cities)
    
    my $min_dist = 1e18
    for my $p (@$all_perms) {
        my $d = $dist_matrix->[0]->[$p->[0]]
        for (my $i = 0; $i < scalar(@$p) - 1; $i++) {
            $d += $dist_matrix->[$p->[$i]]->[$p->[$i + 1]]
        }
        $d += $dist_matrix->[$p->[-1]]->[0]
        $min_dist = min($min_dist, $d)
    }
    $min_dist
}

# Example matrix
# 0 10 15 20
# 10  0 35 25
# 15 35  0 30
# 20 25 30  0
my $mat = [
    [ 0, 10, 15, 20 ],
    [10,  0, 35, 25 ],
    [15, 35,  0, 30 ],
    [20, 25, 30,  0 ]
]

# Paths:
# 0-1-2-3-0: 10 + 35 + 30 + 20 = 95
# 0-1-3-2-0: 10 + 25 + 30 + 15 = 80
# 0-2-1-3-0: 15 + 35 + 25 + 20 = 95
# 0-2-3-1-0: 15 + 30 + 25 + 10 = 80
# 0-3-1-2-0: 20 + 25 + 35 + 15 = 95
# 0-3-2-1-0: 20 + 30 + 35 + 10 = 95

my $res = Rosetta::TSP::solve($mat)
assert_eq $res, 80, "TSP min distance for 4 cities is 80"

test_run
