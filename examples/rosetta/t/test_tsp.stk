#!/usr/bin/env stryke
# Rosetta Code: Traveling Salesman Problem (Small)

fn Rosetta::TSP::perms($arr) {
    val $n = len(@$arr)
    return [[@$arr]] if $n <= 1
    var @result
    for val $i (0:$n-1) {
        val @rest = ~> 0:$n-1 grep { _ != $i } map { $arr->[_] }
        for val $p (@{ Rosetta::TSP::perms(\@rest) }) {
            push @result, [$arr->[$i], @$p]
        }
    }
    \@result
}

fn Rosetta::TSP::solve($dist_matrix) {
    val $n = len(@$dist_matrix)
    val $all_perms = Rosetta::TSP::perms([1:$n-1])
    ~> @$all_perms map {
        val $p = _
        val $hops = ~> 0:len(@$p)-2 map { $dist_matrix->[$p->[_]]->[$p->[_+1]] } sum
        $dist_matrix->[0]->[$p->[0]] + $hops + $dist_matrix->[$p->[-1]]->[0]
    } min
}

# Example matrix
# 0 10 15 20
# 10  0 35 25
# 15 35  0 30
# 20 25 30  0
val $mat = [
    [ 0, 10, 15, 20 ],
    [10,  0, 35, 25 ],
    [15, 35,  0, 30 ],
    [20, 25, 30,  0 ]
]

# Paths:
# 0-1-2-3-0: 10 + 35 + 30 + 20 = 95
# 0-1-3-2-0: 10 + 25 + 30 + 15 = 80
# 0-2-1-3-0: 15 + 35 + 25 + 20 = 95
# 0-2-3-1-0: 15 + 30 + 25 + 10 = 80
# 0-3-1-2-0: 20 + 25 + 35 + 15 = 95
# 0-3-2-1-0: 20 + 30 + 35 + 10 = 95

val $res = Rosetta::TSP::solve($mat)
assert_eq $res, 80, "TSP min distance for 4 cities is 80"

test_run
