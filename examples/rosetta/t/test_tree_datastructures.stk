#!/usr/bin/env stryke
# Rosetta Code: Tree datastructures

class Rosetta::Tree::Node {
    value: Any = undef
    left: Any = undef
    right: Any = undef

    fn insert($val) {
        if ($val < $self->value) {
            if (defined $self->left) {
                $self->left->insert($val)
            } else {
                $self->left(Rosetta::Tree::Node(value => $val))
            }
        } else {
            if (defined $self->right) {
                $self->right->insert($val)
            } else {
                $self->right(Rosetta::Tree::Node(value => $val))
            }
        }
    }

    fn count {
        var $c = 1
        $c += $self->left->count() if defined $self->left
        $c += $self->right->count() if defined $self->right
        $c
    }

    fn to_list {
        var @res
        push @res, @{$self->left->to_list()} if defined $self->left
        push @res, $self->value
        push @res, @{$self->right->to_list()} if defined $self->right
        \@res
    }
}

# Test the tree
val $root = Rosetta::Tree::Node(value => 10)
$root->insert(5)
$root->insert(15)
$root->insert(2)
$root->insert(7)

assert_eq $root->count(), 5, "Tree has 5 nodes"
val $list = $root->to_list()
assert_eq join(",", @$list), "2,5,7,10,15", "In-order traversal produces sorted list"

test_run
