#!/usr/bin/env stryke
# Rosetta Code: ROT-13 (using pipes)

fn Rosetta::ROT13::solve($text) {
    ~> $text chars map {
        val $o = ord(_)
        if ($o >= 65 && $o <= 90) {
            chr((($o - 65 + 13) % 26) + 65)
        } elsif ($o >= 97 && $o <= 122) {
            chr((($o - 97 + 13) % 26) + 97)
        } else {
            _
        }
    } |> join("")
}

val $t1 = "Hello World!"
val $e1 = Rosetta::ROT13::solve($t1)
val $d1 = Rosetta::ROT13::solve($e1)

assert_eq $e1, "Uryyb Jbeyq!", "encrypt Hello World!"
assert_eq $d1, "Hello World!", "decrypt Uryyb Jbeyq!"

val $t2 = "abcdefghijklmnopqrstuvwxyz"
val $e2 = Rosetta::ROT13::solve($t2)
assert_eq $e2, "nopqrstuvwxyzabcdefghijklm", "encrypt alphabet"

test_run
