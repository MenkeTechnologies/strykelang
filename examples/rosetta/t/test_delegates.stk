#!/usr/bin/env stryke
# Rosetta Code: Delegates

# In Stryke, fn references and closures are the idiomatic way to implement delegates.

fn Rosetta::Delegates::execute($delegate, $value) {
    # Call the delegate with the provided value
    $delegate($value)
}

# Define a delegate (fn reference)
val $double = fn { _ * 2 }

val $res = Rosetta::Delegates::execute($double, 21)
assert_eq $res, 42, "Delegate (fn reference) executed correctly"

# Closure as a delegate
val $factor = 10
val $multiply = fn { _ * $factor }
assert_eq Rosetta::Delegates::execute($multiply, 5), 50, "Closure delegate executed correctly"

test_run
