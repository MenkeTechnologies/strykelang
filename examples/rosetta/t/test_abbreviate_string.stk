#!/usr/bin/env stryke
# Rosetta Code: Abbreviate a string

fn Rosetta::AbbreviateString::compute($s) {
    $s |> split /\s+/ |> map { substr($_, 0, 1) } |> join "" |> uc
}

assert_eq Rosetta::AbbreviateString::compute("Portable Network Graphics"), "PNG", "PNG"
assert_eq Rosetta::AbbreviateString::compute("First In First Out"), "FIFO", "FIFO"
assert_eq Rosetta::AbbreviateString::compute("GNU Image Manipulation Program"), "GIMP", "GIMP"

test_run
