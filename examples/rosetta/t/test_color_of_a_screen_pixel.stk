#!/usr/bin/env stryke
# Rosetta Code: Color of a screen pixel

fn Rosetta::ScreenPixel::screen() {
    my @rows = (
        ["#000000", "#ff0000", "#00ff00"],
        ["#0000ff", "#ffffff", "#808080"],
    )
    \@rows
}

fn Rosetta::ScreenPixel::color_at($screen, $x, $y) {
    $screen->[$y]->[$x]
}

my $screen = Rosetta::ScreenPixel::screen()

assert_eq Rosetta::ScreenPixel::color_at($screen, 0, 0), "#000000", "top-left pixel read correctly"
assert_eq Rosetta::ScreenPixel::color_at($screen, 1, 0), "#ff0000", "red pixel read correctly"
assert_eq Rosetta::ScreenPixel::color_at($screen, 2, 1), "#808080", "bottom-right pixel read correctly"

test_run
