#!/usr/bin/env stryke
# Rosetta Code: Sudoku Solver (Manual 9x9)

fn Rosetta::Sudoku9x9::is_valid($grid, $r, $c, $v) {
    for my $i (0..8) {
        if ($grid->[$r]->[$i] == $v) { return 0 }
        if ($grid->[$i]->[$c] == $v) { return 0 }
    }
    my $br = int($r / 3) * 3
    my $bc = int($c / 3) * 3
    for my $i (0..2) {
        for my $j (0..2) {
            if ($grid->[$br+$i]->[$bc+$j] == $v) { return 0 }
        }
    }
    1
}

fn Rosetta::Sudoku9x9::solve($grid) {
    for my $r (0..8) {
        for my $c (0..8) {
            if ($grid->[$r]->[$c] == 0) {
                for my $v (1..9) {
                    if (Rosetta::Sudoku9x9::is_valid($grid, $r, $c, $v)) {
                        $grid->[$r]->[$c] = $v
                        if (Rosetta::Sudoku9x9::solve($grid)) { return 1 }
                        $grid->[$r]->[$c] = 0
                    }
                }
                return 0
            }
        }
    }
    1
}

my $grid = [
    [5,3,0,0,7,0,0,0,0],
    [6,0,0,1,9,5,0,0,0],
    [0,9,8,0,0,0,0,6,0],
    [8,0,0,0,6,0,0,0,3],
    [4,0,0,8,0,3,0,0,1],
    [7,0,0,0,2,0,0,0,6],
    [0,6,0,0,0,0,2,8,0],
    [0,0,0,4,1,9,0,0,5],
    [0,0,0,0,8,0,0,7,9]
]

if (Rosetta::Sudoku9x9::solve($grid)) {
    assert_eq $grid->[0]->[2], 4, "Sudoku solved [0,2]"
    assert_eq $grid->[8]->[8], 9, "Sudoku solved [8,8]"
} else {
    assert_ok 0, "Sudoku failed"
}

test_run
