#!/usr/bin/env stryke
# Rosetta Code: Logic Puzzle (Small Zebra)

fn Rosetta::ZebraSmall::solve_logic {
    val @names = ("Alice", "Beatrice", "Carol")
    val @ages  = (10, 12, 14)
    val @sports = ("Soccer", "Tennis", "Swim")
    
    for val $a1 (@ages) {
        for val $a2 (@ages) {
            next if $a1 == $a2
            for val $a3 (@ages) {
                next if $a1 == $a3 || $a2 == $a3
                val @a = ($a1, $a2, $a3) # ages of Alice, Beatrice, Carol
                
                # Rule 1: Alice is 14
                next unless $a[0] == 14
                # Rule 4: Carol is 10
                next unless $a[2] == 10
                
                for val $s1 (@sports) {
                    for val $s2 (@sports) {
                        next if $s1 eq $s2
                        for val $s3 (@sports) {
                            next if $s1 eq $s3 || $s2 eq $s3
                            val @s = ($s1, $s2, $s3) # sports of Alice, Beatrice, Carol
                            
                            # Rule 2: The 10 year old plays Tennis
                            var $ok2 = 0
                            for val $i (0:2) { if ($a[$i] == 10 && $s[$i] eq "Tennis") { $ok2 = 1 } }
                            next unless $ok2
                            
                            # Rule 3: Beatrice doesn't play Soccer
                            next if $s[1] eq "Soccer"
                            
                            return [\@a, \@s]
                        }
                    }
                }
            }
        }
    }
}

val $res = Rosetta::ZebraSmall::solve_logic()
val $a = $res->[0]
val $s = $res->[1]

assert_eq $a->[0], 14, "Alice age"
assert_eq $a->[1], 12, "Beatrice age"
assert_eq $a->[2], 10, "Carol age"

assert_eq $s->[2], "Tennis", "Carol sport"
assert_eq $s->[1], "Swim", "Beatrice sport"
assert_eq $s->[0], "Soccer", "Alice sport"

test_run
