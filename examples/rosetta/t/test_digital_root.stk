#!/usr/bin/env stryke
# Rosetta Code: Digital Root

fn my_digital_root {
    my $n = $_[0]
    if ($n < 10) { return $n }
    my $sum = 0
    while ($n > 0) {
        $sum += $n % 10
        $n = int($n / 10)
    }
    my_digital_root($sum)
}

fn digital_root_additive_persistence {
    my $n = $_[0]
    my $persistence = 0
    while ($n >= 10) {
        my $sum = 0
        while ($n > 0) {
            $sum += $n % 10
            $n = int($n / 10)
        }
        $n = $sum
        $persistence++
    }
    ([$n, $persistence])
}

assert_eq my_digital_root(627615), 9, "dr(627615)"
assert_eq my_digital_root(39390), 6, "dr(39390)"

my $res = digital_root_additive_persistence(627615)
assert_eq $res->[0], 9, "root"
assert_eq $res->[1], 2, "persistence"

test_run
