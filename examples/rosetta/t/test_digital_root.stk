#!/usr/bin/env stryke
# Rosetta Code: Digital Root

fn Rosetta::DigitalRoot::compute($n) {
    if ($n < 10) { return $n }
    var $sum = 0
    var $curr = $n
    while ($curr > 0) {
        $sum += $curr % 10
        $curr = int($curr / 10)
    }
    Rosetta::DigitalRoot::compute($sum)
}

fn Rosetta::DigitalRoot::persistence($n) {
    var $curr = $n
    var $count = 0
    while ($curr >= 10) {
        var $sum = 0
        while ($curr > 0) {
            $sum += $curr % 10
            $curr = int($curr / 10)
        }
        $curr = $sum
        $count++
    }
    ([$curr, $count])
}

assert_eq Rosetta::DigitalRoot::compute(627615), 9, "dr(627615)"
assert_eq Rosetta::DigitalRoot::compute(39390), 6, "dr(39390)"

val $res = Rosetta::DigitalRoot::persistence(627615)
assert_eq $res->[0], 9, "root"
assert_eq $res->[1], 2, "persistence"

test_run
