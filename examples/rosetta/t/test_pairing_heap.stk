#!/usr/bin/env stryke
# Rosetta Code: Pairing heap — simple, fast meldable heap. Insert and
# meld are O(1); extract-min is O(log n) amortized via the two-pass
# pairing during deletion.
#
# Each node: { key, children = arrayref of nodes }. The heap is a
# single root holding the min; merging two heaps puts the larger root
# under the smaller.

fn Rosetta::Pairing::new() { { root => undef, count => 0 } }

fn Rosetta::Pairing::merge_nodes($a, $b) {
    return $b if !defined $a
    return $a if !defined $b
    if ($a->{key} <= $b->{key}) {
        unshift @{$a->{children}}, $b
        return $a
    } else {
        unshift @{$b->{children}}, $a
        return $b
    }
}

fn Rosetta::Pairing::insert($h, $key) {
    my $node = { key => $key, children => [] }
    $h->{root} = Rosetta::Pairing::merge_nodes($h->{root}, $node)
    $h->{count}++
}

fn Rosetta::Pairing::min($h) {
    return undef if !defined $h->{root}
    $h->{root}{key}
}

fn Rosetta::Pairing::extract_min($h) {
    return undef if !defined $h->{root}
    my $m = $h->{root}{key}
    my $children = $h->{root}{children}
    # Two-pass merge: pair from left; then merge resulting pairs from right.
    my @paired
    for (my $i = 0; $i < len(@$children); $i += 2) {
        if ($i + 1 < len(@$children)) {
            push @paired, Rosetta::Pairing::merge_nodes($children->[$i], $children->[$i + 1])
        } else {
            push @paired, $children->[$i]
        }
    }
    my $new_root
    for (my $i = len(@paired) - 1; $i >= 0; $i--) {
        $new_root = Rosetta::Pairing::merge_nodes($new_root, $paired[$i])
    }
    $h->{root} = $new_root
    $h->{count}--
    $m
}

fn Rosetta::Pairing::union($a, $b) {
    {
        root => Rosetta::Pairing::merge_nodes($a->{root}, $b->{root}),
        count => $a->{count} + $b->{count}
    }
}

# Insert and min
my $h = Rosetta::Pairing::new()
Rosetta::Pairing::insert($h, 5)
Rosetta::Pairing::insert($h, 2)
Rosetta::Pairing::insert($h, 8)
Rosetta::Pairing::insert($h, 1)
Rosetta::Pairing::insert($h, 7)
assert_eq Rosetta::Pairing::min($h), 1, "min after inserts"
assert_eq $h->{count}, 5, "count = 5"

# Extract min in sorted order
assert_eq Rosetta::Pairing::extract_min($h), 1, "extract 1"
assert_eq Rosetta::Pairing::extract_min($h), 2, "extract 2"
assert_eq Rosetta::Pairing::extract_min($h), 5, "extract 5"
assert_eq Rosetta::Pairing::extract_min($h), 7, "extract 7"
assert_eq Rosetta::Pairing::extract_min($h), 8, "extract 8"
assert_ok !defined Rosetta::Pairing::extract_min($h), "extract empty undef"
assert_eq $h->{count}, 0, "empty count = 0"

# Heap-sort
my @input = (50, 17, 23, 5, 88, 32, 11, 99, 3, 67, 41, 8, 76, 29, 14)
my $hb = Rosetta::Pairing::new()
for my $v (@input) { Rosetta::Pairing::insert($hb, $v) }
my @sorted_via_heap
while ($hb->{count} > 0) { push @sorted_via_heap, Rosetta::Pairing::extract_min($hb) }
my @native = sort { _0 <=> _1 } @input
assert_eq join(",", @sorted_via_heap), join(",", @native), "pairing heap-sort = native"

# Union
my $h1 = Rosetta::Pairing::new()
my $h2 = Rosetta::Pairing::new()
Rosetta::Pairing::insert($h1, 10)
Rosetta::Pairing::insert($h1, 4)
Rosetta::Pairing::insert($h2, 7)
Rosetta::Pairing::insert($h2, 2)
my $u = Rosetta::Pairing::union($h1, $h2)
assert_eq Rosetta::Pairing::min($u), 2, "union min = 2"
assert_eq $u->{count}, 4, "union count = 4"
my @ord
while ($u->{count} > 0) { push @ord, Rosetta::Pairing::extract_min($u) }
assert_eq join(",", @ord), "2,4,7,10", "union extracts sorted"

# Single-element
my $one = Rosetta::Pairing::new()
Rosetta::Pairing::insert($one, 42)
assert_eq Rosetta::Pairing::extract_min($one), 42, "single extract"
assert_eq $one->{count}, 0, "after extract count = 0"

# Duplicates
my $dup = Rosetta::Pairing::new()
for my $v (5, 5, 3, 3, 1, 1) { Rosetta::Pairing::insert($dup, $v) }
my @ds
while ($dup->{count} > 0) { push @ds, Rosetta::Pairing::extract_min($dup) }
assert_eq join(",", @ds), "1,1,3,3,5,5", "duplicates extracted in order"

test_run
