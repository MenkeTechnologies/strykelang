#!/usr/bin/env stryke
# Rosetta Code: Linear search

fn Rosetta::Search::linear($list, $target) {
    for (my $i = 0; $i < cnt(@$list); $i++) {
        return $i if $list->[$i] == $target
    }
    -1
}

fn Rosetta::Search::idiomatic($list, $target) {
    # Using pany (parallel any) to check for existence
    @$list |> pany { _ == $target }
}

my @data = (10, 20, 30, 40, 50)
assert_eq Rosetta::Search::linear(\@data, 30), 2, "linear search found 30 at index 2"
assert_eq Rosetta::Search::linear(\@data, 60), -1, "linear search not found 60"

assert_eq Rosetta::Search::idiomatic(\@data, 30), 1, "idiomatic search found 30"
assert_eq Rosetta::Search::idiomatic(\@data, 60), 0, "idiomatic search not found 60"

# Using first builtin to get the value
my $val = @data |> first { _ > 25 }
assert_eq $val, 30, "first element > 25 is 30"

test_run
