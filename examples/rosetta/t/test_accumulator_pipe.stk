#!/usr/bin/env stryke
# Rosetta Code: Accumulator factory (using closures and pipes)

fn Rosetta::Accumulator::make($n) {
    fn ($i) {
        $n += $i
    }
}

val $acc = Rosetta::Accumulator::make(5)
assert_eq $acc(2), 7, "acc(2) -> 7"
assert_eq $acc(3), 10, "acc(3) -> 10"

val $acc2 = Rosetta::Accumulator::make(100)
assert_eq $acc2(50), 150, "acc2(50) -> 150"

# Using pipes with accumulator
(1, 2, 3) |> map $acc |> join(",") |> assert_eq("11,13,16", "piped accumulator")

test_run
