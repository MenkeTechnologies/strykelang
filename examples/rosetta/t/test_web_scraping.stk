#!/usr/bin/env stryke
# Rosetta Code: Web scraping
#
# Hits a local in-process server (NOT example.com) so the test runs
# offline and isn't flaky on third-party outages.

fn Rosetta::WebScraping::scrape($url) {
    my $html = fetch($url)
    if ($html =~ /<title>(.*?)<\/title>/i) {
        return $1
    }
    undef
}

fn Rosetta::WebScraping::demo() {
    my $port = 9872
    my $base = "http://127.0.0.1:$port"

    # Background server that returns a small HTML doc with a known title.
    async {
        serve $port, fn {
            return +{
                status => 200,
                body   => "<html><head><title>Example Domain</title></head>"
                        . "<body><p>Hello from a local test server.</p></body></html>",
            }
        }
    }
    sleep 0.2

    "Fetching $base and scraping title..." |> p
    my $title = Rosetta::WebScraping::scrape($base)
    "Scraped title: $title" |> p

    assert_ok defined($title),               "Title should be defined"
    assert_eq $title, "Example Domain",      "Title should match local fixture"
}

Rosetta::WebScraping::demo()
test_run
