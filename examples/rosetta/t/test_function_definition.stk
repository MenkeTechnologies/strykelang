#!/usr/bin/env stryke
# Rosetta Code: Function Definition

# Basic function definition
fn greet($name) {
    "Hello, $name!" |> p
}

# Function with multiple parameters
fn add($a, $b) {
    return $a + $b
}

# Function with default parameters  
fn power($base, $exp = 2) {
    return $base ** $exp
}

# Function with variable arguments
fn sum_all(@numbers) {
    ~> @numbers sum
}

# Function returning multiple values
fn divide_with_remainder($dividend, $divisor) {
    my $quotient = int($dividend / $divisor)
    my $remainder = $dividend % $divisor
    return ($quotient, $remainder)
}

# Anonymous function (lambda)
my $square = fn ($x) { $x * $x }

# Function examples
"Function Definition Examples:" |> p

greet("World")
greet("Stryke")

("Addition: " . add(5, 3)) |> p
("Power (default): " . power(3)) |> p
("Power (specified): " . power(3, 4)) |> p

("Sum: " . sum_all(1, 2, 3, 4, 5)) |> p

my ($q, $r) = divide_with_remainder(17, 5)
"17 ÷ 5 = $q remainder $r" |> p

("Square of 7: " . $square->(7)) |> p

# Higher-order function
fn apply_twice($func, $value) {
    $func->($func->($value))
}

("Apply square twice to 3: " . apply_twice($square, 3)) |> p