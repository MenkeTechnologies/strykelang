#!/usr/bin/env stryke
# Rosetta Code: Function definition

fn Rosetta::FuncDef::multiply($a, $b) {
    $a * $b
}

assert_eq Rosetta::FuncDef::multiply(5, 4), 20, "5 * 4 = 20"
assert_eq Rosetta::FuncDef::multiply(-2, 3), -6, "-2 * 3 = -6"
assert_eq Rosetta::FuncDef::multiply(0, 100), 0, "0 * 100 = 0"

test_run
