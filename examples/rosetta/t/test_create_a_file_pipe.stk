#!/usr/bin/env stryke
# Rosetta Code: Create a file

fn Rosetta::CreateFile::create($path) {
    open val $fh, '>', $path or die "Could not create file"
    p $fh "test string for Rosetta Code"
    close $fh
}

fn Rosetta::CreateFile::check_and_cleanup($path) {
    val $exists = -e $path
    unlink $path
    $exists
}

val $tmp_file = "/tmp/stryke_test_create_file.txt"
$tmp_file |> Rosetta::CreateFile::create()
val $exists = $tmp_file |> Rosetta::CreateFile::check_and_cleanup()

$exists |> assert_ok("File was created and exists")

test_run
