#!/usr/bin/env stryke
# Rosetta Code: Bioinformatics/Global alignment

fn Bio::needleman_wunsch($s1, $s2, $match, $mismatch, $gap) {
    val $n = len($s1)
    val $m = len($s2)
    
    # Initialize DP matrix
    val @score = 0:$n |> map { val @r = 0:$m |> map { 0 }; \@r }
    
    for val $i (0:$n) { $score[$i]->[0] = $i * $gap }
    for val $j (0:$m) { $score[0]->[$j] = $j * $gap }
    
    val @chars1 = split("", $s1)
    val @chars2 = split("", $s2)
    
    for val $i (1:$n) {
        for val $j (1:$m) {
            val $s = ($chars1[$i-1] eq $chars2[$j-1] ? $match : $mismatch)
            val $diag = $score[$i-1]->[$j-1] + $s
            val $up = $score[$i-1]->[$j] + $gap
            val $left = $score[$i]->[$j-1] + $gap
            
            $score[$i]->[$j] = max($diag, $up, $left)
        }
    }
    
    # Traceback
    var $align1 = ""
    var $align2 = ""
    var $i = $n
    var $j = $m
    while ($i > 0 || $j > 0) {
        if ($i > 0 && $j > 0 && $score[$i]->[$j] == $score[$i-1]->[$j-1] + ($chars1[$i-1] eq $chars2[$j-1] ? $match : $mismatch)) {
            $align1 = $chars1[$i-1] . $align1
            $align2 = $chars2[$j-1] . $align2
            $i--
            $j--
        } elsif ($i > 0 && $score[$i]->[$j] == $score[$i-1]->[$j] + $gap) {
            $align1 = $chars1[$i-1] . $align1
            $align2 = "-" . $align2
            $i--
        } else {
            $align1 = "-" . $align1
            $align2 = $chars2[$j-1] . $align2
            $j--
        }
    }
    return [$align1, $align2, $score[$n]->[$m]]
}

fn Rosetta::GlobalAlignment::demo() {
    val $seq1 = "GAATTCAGTTA"
    val $seq2 = "GGATCGA"
    
    "Global Alignment (Needleman-Wunsch):" |> p
    "Seq 1: $seq1" |> p
    "Seq 2: $seq2" |> p
    
    val $res = Bio::needleman_wunsch($seq1, $seq2, 1, -1, -1)
    
    "Resulting Alignment:" |> p
    $res->[0] |> p
    $res->[1] |> p
    ("Score: " . $res->[2]) |> p
    
    assert_eq $res->[2], 1, "Alignment score should be 1"
    assert_eq len($res->[0]), len($res->[1]), "Alignment lengths must match"
    assert_eq $res->[0], "GAATTCAGTTA", "Alignment 1"
    assert_eq $res->[1], "GGA-TC-G--A", "Alignment 2"
}

Rosetta::GlobalAlignment::demo()
test_run
