#!/usr/bin/env stryke
# Rosetta Code: Bioinformatics/Global alignment

fn Bio::needleman_wunsch($s1, $s2, $match, $mismatch, $gap) {
    my $n = length($s1)
    my $m = length($s2)
    
    # Initialize DP matrix
    my @score = 0:$n |> map { my @r = 0:$m |> map { 0 }; \@r }
    
    for my $i (0:$n) { $score[$i]->[0] = $i * $gap }
    for my $j (0:$m) { $score[0]->[$j] = $j * $gap }
    
    my @chars1 = split("", $s1)
    my @chars2 = split("", $s2)
    
    for my $i (1:$n) {
        for my $j (1:$m) {
            my $s = ($chars1[$i-1] eq $chars2[$j-1] ? $match : $mismatch)
            my $diag = $score[$i-1]->[$j-1] + $s
            my $up = $score[$i-1]->[$j] + $gap
            my $left = $score[$i]->[$j-1] + $gap
            
            $score[$i]->[$j] = max($diag, $up, $left)
        }
    }
    
    # Traceback
    my $align1 = ""
    my $align2 = ""
    my $i = $n
    my $j = $m
    while ($i > 0 || $j > 0) {
        if ($i > 0 && $j > 0 && $score[$i]->[$j] == $score[$i-1]->[$j-1] + ($chars1[$i-1] eq $chars2[$j-1] ? $match : $mismatch)) {
            $align1 = $chars1[$i-1] . $align1
            $align2 = $chars2[$j-1] . $align2
            $i--
            $j--
        } elsif ($i > 0 && $score[$i]->[$j] == $score[$i-1]->[$j] + $gap) {
            $align1 = $chars1[$i-1] . $align1
            $align2 = "-" . $align2
            $i--
        } else {
            $align1 = "-" . $align1
            $align2 = $chars2[$j-1] . $align2
            $j--
        }
    }
    return [$align1, $align2, $score[$n]->[$m]]
}

fn Rosetta::GlobalAlignment::demo() {
    my $seq1 = "GAATTCAGTTA"
    my $seq2 = "GGATCGA"
    
    "Global Alignment (Needleman-Wunsch):" |> p
    "Seq 1: $seq1" |> p
    "Seq 2: $seq2" |> p
    
    my $res = Bio::needleman_wunsch($seq1, $seq2, 1, -1, -1)
    
    "Resulting Alignment:" |> p
    $res->[0] |> p
    $res->[1] |> p
    ("Score: " . $res->[2]) |> p
    
    assert_eq $res->[2], 1, "Alignment score should be 1"
    assert_eq length($res->[0]), length($res->[1]), "Alignment lengths must match"
    assert_eq $res->[0], "GAATTCAGTTA", "Alignment 1"
    assert_eq $res->[1], "GGA-TC-G--A", "Alignment 2"
}

Rosetta::GlobalAlignment::demo()
test_run
