#!/usr/bin/env stryke
# Rosetta Code: Sum of first n cubes

fn Rosetta::SumCubes::sum_cubes($n) {
    if ($n < 1) {
        0
    } else {
        1..$n |> map { $_**3 } |> reduce { _0 + _1 }
    }
}

fn Rosetta::SumCubes::sum_cubes_formula($n) {
    int(($n * ($n + 1) / 2)**2)
}

assert_eq Rosetta::SumCubes::sum_cubes(1), 1, "sum 1^3 = 1"
assert_eq Rosetta::SumCubes::sum_cubes(3), 36, "sum 1^3+2^3+3^3 = 1+8+27=36"
assert_eq Rosetta::SumCubes::sum_cubes(5), 225, "sum 1..5 cubes = 225"

for my $i (1..10) {
    assert_eq Rosetta::SumCubes::sum_cubes($i), Rosetta::SumCubes::sum_cubes_formula($i), "formula matches for $i"
}

5 |> Rosetta::SumCubes::sum_cubes |> assert_eq(225, "pipe sum cubes")

test_run
