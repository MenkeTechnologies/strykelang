#!/usr/bin/env stryke
# Rosetta Code: Least Common Multiple

fn Rosetta::LCM::gcd($a, $b) {
    my $aa = $a; my $bb = $b;
    while ($bb != 0) {
        ($aa, $bb) = ($bb, $aa % $bb)
    }
    $aa
}

fn Rosetta::LCM::compute($a, $b) {
    if ($a == 0 || $b == 0) {
        0
    } else {
        my $prod = $a * $b
        my $res = $prod / Rosetta::LCM::gcd($a, $b)
        ~> $res abs
    }
}

fn Rosetta::LCM::multi(@nums) {
    @nums |> reduce { Rosetta::LCM::compute($a, $b) }
}

assert_eq Rosetta::LCM::compute(12, 18), 36, "lcm(12, 18)"
assert_eq Rosetta::LCM::compute(10, 5), 10, "lcm(10, 5) is 10"
assert_eq Rosetta::LCM::compute(7, 13), 91, "lcm(7, 13) is 91"
assert_eq Rosetta::LCM::multi(2, 3, 4), 12, "lcm_multi(2, 3, 4)"

12 |> Rosetta::LCM::compute(18) |> assert_eq(36, "pipe lcm")

test_run
