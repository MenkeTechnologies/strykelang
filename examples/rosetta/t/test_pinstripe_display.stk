#!/usr/bin/env stryke
# Rosetta Code: Pinstripe/Display

fn Rosetta::PinDisplay::row($width, $stripe_w) {
    my $line = ""
    my @chars = (".", "#")
    my $i = 0
    while (len($line) < $width) {
        $line .= $chars[$i % 2] x $stripe_w
        $i++
    }
    substr($line, 0, $width)
}

fn Rosetta::PinDisplay::render($width) {
    [
        Rosetta::PinDisplay::row($width, 1),
        Rosetta::PinDisplay::row($width, 2),
        Rosetta::PinDisplay::row($width, 3),
        Rosetta::PinDisplay::row($width, 4),
    ]
}

my $rows = Rosetta::PinDisplay::render(24)
assert_eq substr($rows->[0], 0, 8), ".#.#.#.#", "first quarter 1-pixel stripes"
assert_eq substr($rows->[1], 0, 8), "..##..##", "second quarter 2-pixel stripes"
assert_eq substr($rows->[2], 0, 12), "...###...###", "third quarter 3-pixel stripes"
assert_eq substr($rows->[3], 0, 16), "....####....####", "last quarter 4-pixel stripes"

test_run
