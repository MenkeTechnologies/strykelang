#!/usr/bin/env stryke
# Rosetta Code: Comma quibbler

fn Rosetta::CommaQuibbler::quibble(@list) {
    my $len = len(@list)
    if ($len == 0) {
        "{}"
    } elsif ($len == 1) {
        "{" . $list[0] . "}"
    } else {
        my @init = @list[0..$len-2]
        my $last = $list[-1]
        "{" . join(", ", @init) . " and " . $last . "}"
    }
}

assert_eq Rosetta::CommaQuibbler::quibble(), "{}", "empty list"
assert_eq Rosetta::CommaQuibbler::quibble("ABC"), "{ABC}", "one element"
assert_eq Rosetta::CommaQuibbler::quibble("ABC", "DEF"), "{ABC and DEF}", "two elements"
assert_eq Rosetta::CommaQuibbler::quibble("ABC", "DEF", "GHI", "JKL"), "{ABC, DEF, GHI and JKL}", "four elements"

qw(one two three) |> Rosetta::CommaQuibbler::quibble |> assert_eq("{one, two and three}", "pipe quibble")

test_run
