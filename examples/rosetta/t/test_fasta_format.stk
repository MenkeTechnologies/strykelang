#!/usr/bin/env stryke
# Rosetta Code: FASTA format

fn Rosetta::Fasta::parse($text) {
    var %sequences
    val @lines = split "\n", $text
    var $current_id = undef
    
    for val $line (@lines) {
        if ($line =~ /^>(.*)/) {
            $current_id = $1
            $sequences{$current_id} = ""
        } elsif (defined $current_id) {
            # Strip whitespace
            val $seq = $line |> trim
            $sequences{$current_id} .= $seq
        }
    }
    \%sequences
}

val $data = qq{
>Rosetta_Code
MKTAYIAKQRQISFVKSHFSRQLEERLGLIEVQAPILSRVGDGTQDNLSGAEKGVVVVKN
REMEVVVELLLGAICVM
>Another_Sequence
VGDGTQDNLSGAEKGVVVVKN
}

val $res = Rosetta::Fasta::parse($data)
assert_eq exists $res->{Rosetta_Code}, 1, "Found Rosetta_Code"
assert_eq len($res->{Rosetta_Code}), 77, "Rosetta_Code length matches"
assert_eq $res->{Another_Sequence}, "VGDGTQDNLSGAEKGVVVVKN", "Another_Sequence matches"

test_run
