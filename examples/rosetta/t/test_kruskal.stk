#!/usr/bin/env stryke
# Rosetta Code: Kruskal's algorithm

fn Rosetta::Kruskal::find_set($parent, $i) {
    if ($parent->{$i} eq $i) {
        return $i
    }
    $parent->{$i} = Rosetta::Kruskal::find_set($parent, $parent->{$i})
    $parent->{$i}
}

fn Rosetta::Kruskal::union_sets($parent, $rank, $x, $y) {
    val $xroot = Rosetta::Kruskal::find_set($parent, $x)
    val $yroot = Rosetta::Kruskal::find_set($parent, $y)
    if ($rank->{$xroot} < $rank->{$yroot}) {
        $parent->{$xroot} = $yroot
    } elsif ($rank->{$xroot} > $rank->{$yroot}) {
        $parent->{$yroot} = $xroot
    } else {
        $parent->{$yroot} = $xroot
        $rank->{$xroot}++
    }
}

fn Rosetta::Kruskal::solve($n, $edges) {
    var @sorted_edges = sort { _0->[2] <=> _1->[2] } @$edges
    var $parent = {}
    var $rank = {}
    for val $i (0:$n-1) {
        $parent->{$i} = "$i"
        $rank->{$i} = 0
    }
    
    var @mst = ()
    for val $e (@sorted_edges) {
        val $u = $e->[0]
        val $v = $e->[1]
        val $root_u = Rosetta::Kruskal::find_set($parent, $u)
        val $root_v = Rosetta::Kruskal::find_set($parent, $v)
        if ($root_u ne $root_v) {
            push @mst, $e
            Rosetta::Kruskal::union_sets($parent, $rank, $root_u, $root_v)
        }
    }
    \@mst
}

val $edges = [
    [0, 1, 10],
    [0, 2, 6],
    [0, 3, 5],
    [1, 3, 15],
    [2, 3, 4]
]
val $mst = Rosetta::Kruskal::solve(4, $edges)
# MST should be [2,3,4], [0,3,5], [0,1,10]
# Total weight: 4 + 5 + 10 = 19
var $total_w = 0
~> @$mst ep { $total_w += _->[2] }
assert_eq $total_w, 19, "MST total weight"

test_run
