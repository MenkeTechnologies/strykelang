#!/usr/bin/env stryke
# Rosetta Code: Color quantization

fn Rosetta::ColorQuant::quantize($color, $bits) {
    # Simple quantization: reduce precision of each component
    val $shift = 8 - $bits
    val $r = ($color->{r} >> $shift) << $shift
    val $g = ($color->{g} >> $shift) << $shift
    val $b = ($color->{b} >> $shift) << $shift
    { r => $r, g => $g, b => $b }
}

val $color = { r => 255, g => 128, b => 64 }
val $q4 = Rosetta::ColorQuant::quantize($color, 4)

assert_eq $q4->{r}, 240, "Red quantized to 4 bits"
assert_eq $q4->{g}, 128, "Green quantized to 4 bits"
assert_eq $q4->{b}, 64, "Blue quantized to 4 bits"

val $q2 = Rosetta::ColorQuant::quantize($color, 2)
assert_eq $q2->{r}, 192, "Red quantized to 2 bits"

test_run
