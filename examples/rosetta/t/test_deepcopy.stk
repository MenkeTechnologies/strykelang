#!/usr/bin/env stryke
# Rosetta Code: Deepcopy

fn Rosetta::Deepcopy::demo() {
    my $orig = {
        a => 1,
        b => [2, 3, { c => 4 }],
        d => { e => 5 }
    }

    my $copy = deep_clone($orig)

    # Verify equality
    assert_ok deep_equal($orig, $copy), "initial copy is equal"

    # Modify copy
    $copy->{b}->[2]->{c} = 40
    $copy->{d}->{e} = 50

    # Verify original is unchanged
    assert_eq $orig->{b}->[2]->{c}, 4, "original b[2].c unchanged"
    assert_eq $orig->{d}->{e}, 5, "original d.e unchanged"

    # Verify copy is changed
    assert_eq $copy->{b}->[2]->{c}, 40, "copy b[2].c changed"
    assert_eq $copy->{d}->{e}, 50, "copy d.e changed"

    # Verify they are no longer equal
    assert_ok !deep_equal($orig, $copy), "modified copy is not equal"
}

Rosetta::Deepcopy::demo()
test_run
