#!/usr/bin/env stryke
# Rosetta Code: Pernicious numbers

fn Rosetta::Pernicious::count_bits($n) {
    my $count = 0
    my $num = $n
    while ($num > 0) {
        if ($num % 2 == 1) { $count++ }
        $num = int($num / 2)
    }
    $count
}

fn Rosetta::Pernicious::check($n) {
    my $bits = Rosetta::Pernicious::count_bits($n)
    is_prime($bits)
}

assert_ok Rosetta::Pernicious::check(3), "3 is pernicious (bits 2)"
assert_ok Rosetta::Pernicious::check(5), "5 is pernicious (bits 2)"
assert_ok Rosetta::Pernicious::check(6), "6 is pernicious (bits 2)"
assert_ok Rosetta::Pernicious::check(7), "7 is pernicious (bits 3)"
assert_ok !Rosetta::Pernicious::check(1), "1 is not (bits 1)"
assert_ok !Rosetta::Pernicious::check(8), "8 is not (bits 1)"

7 |> Rosetta::Pernicious::check |> assert_ok("pipe Pernicious")

test_run
