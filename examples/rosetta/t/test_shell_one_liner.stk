#!/usr/bin/env stryke
# Rosetta Code: Shell one-liner

fn Rosetta::ShellOneLiner::demo() {
    # Task: Execute a command from the shell that performs a simple action.
    # Use the current binary's path ($^X) so this works in CI where
    # `stryke` may not be on PATH (only `./target/release/s` exists).
    my $exe = $^X
    my $res = `'$exe' -e 'print "Hello from one-liner\n"'` |> trim
    $res
}

assert_eq Rosetta::ShellOneLiner::demo(), "Hello from one-liner", "One-liner executed via shell"

test_run
