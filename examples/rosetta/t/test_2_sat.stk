#!/usr/bin/env stryke
# Rosetta Code: 2-SAT — decide satisfiability of a conjunction of
# 2-literal disjunctions. Reduces to: build the implication graph
# (a∨b ⇒ ¬a→b and ¬b→a), find SCCs, then a satisfying assignment
# exists iff x and ¬x are not in the same SCC. Variable x is true
# iff its SCC is later in the topological order than ¬x's.

# Variables 1..n; literal +x means x, -x means ¬x.
# Encoded as node 2*(x-1) for x and 2*(x-1)+1 for ¬x.

fn Rosetta::TwoSat::lit_node($lit) {
    val $v = $lit < 0 ? -$lit : $lit
    val $base = 2 * ($v - 1)
    $lit > 0 ? $base : $base + 1
}

fn Rosetta::TwoSat::neg($node) { $node ^ 1 }

fn Rosetta::TwoSat::build_graph($n_vars, $clauses) {
    val $n = 2 * $n_vars
    var @adj
    var @rev
    for var $i (~> 1:$n) {
        push @adj, []
        push @rev, []
    }
    for val $c (@$clauses) {
        var ($a, $b) = @$c
        val $na = Rosetta::TwoSat::lit_node($a)
        val $nb = Rosetta::TwoSat::lit_node($b)
        val $not_a = Rosetta::TwoSat::neg($na)
        val $not_b = Rosetta::TwoSat::neg($nb)
        # ¬a → b and ¬b → a
        push @{$adj[$not_a]}, $nb
        push @{$rev[$nb]}, $not_a
        push @{$adj[$not_b]}, $na
        push @{$rev[$na]}, $not_b
    }
    { adj => \@adj, rev => \@rev, n => $n }
}

fn Rosetta::TwoSat::dfs1($adj, $u, $visited, $order) {
    var @stack = ([$u, 0])
    while (len(@stack) > 0) {
        val $top = $stack[-1]
        val ($v, $idx) = @$top
        if (!$visited->[$v]) { $visited->[$v] = 1 }
        val $children = $adj->[$v]
        if ($idx < len(@$children)) {
            $top->[1]++
            val $w = $children->[$idx]
            push @stack, [$w, 0] if !$visited->[$w]
        } else {
            push @$order, $v
            pop @stack
        }
    }
}

fn Rosetta::TwoSat::dfs2($rev, $u, $comp, $cid) {
    var @stack = ($u)
    while (len(@stack) > 0) {
        val $v = pop @stack
        next if defined $comp->[$v]
        $comp->[$v] = $cid
        for val $w (@{$rev->[$v]}) {
            push @stack, $w if !defined $comp->[$w]
        }
    }
}

fn Rosetta::TwoSat::scc($g) {
    val $n = $g->{n}
    val @visited = ~> 1:$n |> map { 0 }
    val @order
    for val $u (~> 0:$n - 1) {
        Rosetta::TwoSat::dfs1($g->{adj}, $u, \@visited, \@order) if !$visited[$u]
    }
    val @comp = ~> 1:$n |> map { undef }
    var $cid = 0
    for (var $i = $n - 1; $i >= 0; $i--) {
        val $u = $order[$i]
        if (!defined $comp[$u]) {
            Rosetta::TwoSat::dfs2($g->{rev}, $u, \@comp, $cid)
            $cid++
        }
    }
    \@comp
}

fn Rosetta::TwoSat::solve($n_vars, $clauses) {
    val $g = Rosetta::TwoSat::build_graph($n_vars, $clauses)
    val $comp = Rosetta::TwoSat::scc($g)
    var @assign
    for val $v (~> 1:$n_vars) {
        val $pos = 2 * ($v - 1)
        val $neg = $pos + 1
        return undef if $comp->[$pos] == $comp->[$neg]
        # Variable is true iff its positive node has a later (higher
        # number) component in the reverse topological order.
        push @assign, $comp->[$pos] > $comp->[$neg] ? 1 : 0
    }
    \@assign
}

fn Rosetta::TwoSat::satisfies($assignment, $clauses) {
    for val $c (@$clauses) {
        val ($a, $b) = @$c
        val $va = $a > 0 ? $assignment->[$a - 1] : !$assignment->[-$a - 1]
        val $vb = $b > 0 ? $assignment->[$b - 1] : !$assignment->[-$b - 1]
        return 0 if !$va && !$vb
    }
    1
}

# Satisfiable: (x1 ∨ x2) ∧ (¬x1 ∨ x2)
val $cl1 = [[1, 2], [-1, 2]]
val $r1 = Rosetta::TwoSat::solve(2, $cl1)
assert_ok defined $r1, "satisfiable case yields assignment"
assert_eq Rosetta::TwoSat::satisfies($r1, $cl1), 1, "x1∨x2 ∧ ¬x1∨x2 satisfied"

# Unsatisfiable: (x1 ∨ x1) ∧ (¬x1 ∨ ¬x1) — forces x1 ∧ ¬x1
val $cl2 = [[1, 1], [-1, -1]]
val $r2 = Rosetta::TwoSat::solve(1, $cl2)
assert_ok !defined $r2, "x ∧ ¬x is unsatisfiable"

# Larger satisfiable case
val $cl3 = [[1, 2], [-1, 3], [2, -3], [-2, 3], [3, 1]]
val $r3 = Rosetta::TwoSat::solve(3, $cl3)
assert_ok defined $r3, "5-clause/3-var case satisfiable"
assert_eq Rosetta::TwoSat::satisfies($r3, $cl3), 1, "5-clause assignment satisfies all"

# Forced assignment: (x1 ∨ x1) forces x1=true
val $cl4 = [[1, 1]]
val $r4 = Rosetta::TwoSat::solve(1, $cl4)
assert_eq $r4->[0], 1, "forced x1 = true"

# Equivalence chain: x1↔x2↔x3 all true via implications
val $cl5 = [[1, 1], [-1, 2], [-2, 3]]
val $r5 = Rosetta::TwoSat::solve(3, $cl5)
assert_eq $r5->[0], 1, "chain x1 = true"
assert_eq $r5->[1], 1, "chain x2 = true"
assert_eq $r5->[2], 1, "chain x3 = true"

# Helper sanity
assert_eq Rosetta::TwoSat::lit_node(1), 0, "lit 1 = node 0"
assert_eq Rosetta::TwoSat::lit_node(-1), 1, "lit -1 = node 1"
assert_eq Rosetta::TwoSat::lit_node(2), 2, "lit 2 = node 2"
assert_eq Rosetta::TwoSat::lit_node(-3), 5, "lit -3 = node 5"
assert_eq Rosetta::TwoSat::neg(0), 1, "neg(0) = 1"
assert_eq Rosetta::TwoSat::neg(7), 6, "neg(7) = 6"

test_run
