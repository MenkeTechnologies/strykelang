#!/usr/bin/env stryke
# Rosetta Code: Permutations

fn Rosetta::Permutations::generate($arr) {
    val $n = len(@$arr)
    return [[@$arr]] if $n <= 1
    var @result
    for val $i (0:$n-1) {
        var @rest
        for val $j (0:$n-1) {
            push @rest, $arr->[$j] if $j != $i
        }
        val $sub = Rosetta::Permutations::generate(\@rest)
        for val $p (@$sub) {
            push @result, [$arr->[$i], @$p]
        }
    }
    \@result
}

fn Rosetta::Permutations::factorial($n) {
    $n <= 1 ? 1 : $n * Rosetta::Permutations::factorial($n - 1)
}

val $p2 = Rosetta::Permutations::generate([1, 2])
assert_eq len(@$p2), 2, "2! = 2"

val $p3 = Rosetta::Permutations::generate([1, 2, 3])
assert_eq len(@$p3), 6, "3! = 6"

val $p4 = Rosetta::Permutations::generate([1, 2, 3, 4])
assert_eq len(@$p4), 24, "4! = 24"

val $p1 = Rosetta::Permutations::generate([42])
assert_eq len(@$p1), 1, "1! = 1"
assert_eq $p1->[0]->[0], 42, "single element perm"

# Empty input -> single empty permutation
val $p0 = Rosetta::Permutations::generate([])
assert_eq len(@$p0), 1, "0! = 1 (one empty permutation)"

# All p3 entries are distinct and sorted strings cover (123, 132, 213, 231, 312, 321)
val @joined = sort map { join("", @{_}) } @$p3
assert_eq join(",", @joined), "123,132,213,231,312,321", "all 3! permutations of 1,2,3"

assert_eq Rosetta::Permutations::factorial(0), 1, "0!"
assert_eq Rosetta::Permutations::factorial(1), 1, "1!"
assert_eq Rosetta::Permutations::factorial(5), 120, "5!"

# Cross-check: number of perms equals factorial
for val $n (1, 2, 3, 4, 5) {
    val @input = (1:$n)
    val $perms = Rosetta::Permutations::generate(\@input)
    val $expected = Rosetta::Permutations::factorial($n)
    assert_eq len(@$perms), $expected, "n=$n: perm count = n!"
}

test_run
