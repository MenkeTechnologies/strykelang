#!/usr/bin/env stryke
# Rosetta Code: Permutations

fn permutations(@arr) {
    return ([@arr]) if scalar(@arr) <= 1
    
    my @result
    for my $i (0..$#arr) {
        my @rest = (@arr[0..$i-1], @arr[$i+1..$#arr])
        my @sub_perms = permutations(@rest)
        for my $perm (@sub_perms) {
            push @result, [$arr[$i], @$perm]
        }
    }
    @result
}

fn factorial($n) {
    $n <= 1 ? 1 : $n * factorial($n - 1)
}

my @p2 = permutations(1, 2)
assert_eq scalar(@p2), 2, "2! = 2"

my @p3 = permutations(1, 2, 3)
assert_eq scalar(@p3), 6, "3! = 6"

my @p4 = permutations(1, 2, 3, 4)
assert_eq scalar(@p4), 24, "4! = 24"

my @p1 = permutations(42)
assert_eq scalar(@p1), 1, "1! = 1"
assert_eq $p1[0][0], 42, "single element perm"

assert_eq factorial(0), 1, "0!"
assert_eq factorial(1), 1, "1!"
assert_eq factorial(5), 120, "5!"

test_run
