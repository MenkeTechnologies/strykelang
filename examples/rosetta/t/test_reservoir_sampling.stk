#!/usr/bin/env stryke
# Rosetta Code: Reservoir sampling — Algorithm R

fn Rosetta::Reservoir::sample($stream, $k) {
    var @reservoir
    var $i = 0
    for val $x (@$stream) {
        if ($i < $k) {
            push @reservoir, $x
        } else {
            val $j = int(rand($i + 1))
            if ($j < $k) {
                $reservoir[$j] = $x
            }
        }
        $i++
    }
    \@reservoir
}

val @stream = (1:100)
val $sample = Rosetta::Reservoir::sample(\@stream, 10)

assert_eq len(@$sample), 10, "reservoir size = k"
for val $v (@$sample) {
    assert_ok($v >= 1 && $v <= 100, "sample value $v in original range")
}

# Stream smaller than k -> reservoir is the whole stream
val @small = (1, 2, 3)
val $whole = Rosetta::Reservoir::sample(\@small, 10)
assert_eq len(@$whole), 3, "stream smaller than k returns full stream"
assert_eq join(",", sort { _0 <=> _1 } @$whole), "1,2,3", "small stream contents preserved"

# k = 0 returns empty
val $empty = Rosetta::Reservoir::sample(\@stream, 0)
assert_eq len(@$empty), 0, "k=0 returns empty reservoir"

test_run
