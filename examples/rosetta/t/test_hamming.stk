#!/usr/bin/env stryke
# Rosetta Code: Hamming Numbers (Regular Numbers)

fn Rosetta::Hamming::check($n) {
    if ($n < 1) {
        0
    } else {
        my $val = $n
        while ($val % 2 == 0) { $val = $val / 2 }
        while ($val % 3 == 0) { $val = $val / 3 }
        while ($val % 5 == 0) { $val = $val / 5 }
        $val == 1
    }
}

fn Rosetta::Hamming::generate($count) {
    my @h
    my $n = 1
    while (scalar(@h) < $count) {
        if (Rosetta::Hamming::check($n)) {
            push @h, $n
        }
        $n = $n + 1
    }
    \@h
}

assert_ok Rosetta::Hamming::check(1), "1 is hamming"
assert_ok Rosetta::Hamming::check(2), "2 is hamming"
assert_ok Rosetta::Hamming::check(3), "3 is hamming"
assert_ok Rosetta::Hamming::check(5), "5 is hamming"
assert_ok Rosetta::Hamming::check(6), "6 is hamming (2*3)"
assert_ok Rosetta::Hamming::check(8), "8 is hamming (2^3)"
assert_ok Rosetta::Hamming::check(30), "30 is hamming (2*3*5)"

assert_ok !Rosetta::Hamming::check(7), "7 is not hamming"
assert_ok !Rosetta::Hamming::check(11), "11 is not hamming"
assert_ok !Rosetta::Hamming::check(14), "14 is not hamming (has 7)"

my $first20 = Rosetta::Hamming::generate(20)
assert_eq join(",", @$first20), "1,2,3,4,5,6,8,9,10,12,15,16,18,20,24,25,27,30,32,36", "first 20 hamming"

test_run
