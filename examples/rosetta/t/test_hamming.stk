#!/usr/bin/env stryke
# Rosetta Code: Hamming Numbers (Regular Numbers)
# Numbers whose only prime factors are 2, 3, and 5

fn is_hamming {
    my $n = $_[0]
    if ($n < 1) {
        0
    } else {
        my $val = $n
        while ($val % 2 == 0) { $val = $val / 2 }
        while ($val % 3 == 0) { $val = $val / 3 }
        while ($val % 5 == 0) { $val = $val / 5 }
        $val == 1
    }
}

fn hamming_numbers {
    my $count = $_[0]
    my @h
    my $n = 1
    while (scalar(@h) < $count) {
        if (is_hamming($n)) {
            push @h, $n
        }
        $n = $n + 1
    }
    \@h
}

assert_ok is_hamming(1), "1 is hamming"
assert_ok is_hamming(2), "2 is hamming"
assert_ok is_hamming(3), "3 is hamming"
assert_ok is_hamming(5), "5 is hamming"
assert_ok is_hamming(6), "6 is hamming (2*3)"
assert_ok is_hamming(8), "8 is hamming (2^3)"
assert_ok is_hamming(30), "30 is hamming (2*3*5)"

assert_ok !is_hamming(7), "7 is not hamming"
assert_ok !is_hamming(11), "11 is not hamming"
assert_ok !is_hamming(14), "14 is not hamming (has 7)"

my $first20 = hamming_numbers(20)
assert_eq join(",", @$first20), "1,2,3,4,5,6,8,9,10,12,15,16,18,20,24,25,27,30,32,36", "first 20 hamming"

test_run
