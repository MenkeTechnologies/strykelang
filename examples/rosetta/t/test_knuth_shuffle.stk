#!/usr/bin/env stryke
# Rosetta Code: Knuth Shuffle

fn Rosetta::KnuthShuffle::shuffle($list) {
    var @arr = @$list
    val $n = len(@arr)
    for var $i (~> (1:$n-1) rev) {
        var $j = int(rand($i + 1))
        ($arr[$i], $arr[$j]) = ($arr[$j], $arr[$i])
    }
    \@arr
}

val $data = [1, 2, 3, 4, 5]
val $shuffled = Rosetta::KnuthShuffle::shuffle($data)
# We can't easily test randomness, but we can test length and content
assert_eq len(@$shuffled), 5, "shuffled length"

var %counts
for val $x (@$shuffled) { $counts{$x}++ }
for val $i (1:5) {
    assert_eq $counts{$i}, 1, "contains $i"
}

test_run
