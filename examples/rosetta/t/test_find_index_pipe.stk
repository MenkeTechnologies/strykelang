#!/usr/bin/env stryke
# Rosetta Code: Find First and Last Index (Idiomatic)

fn Rosetta::FindIndex::first($haystack, $needle) {
    index_of_elem($needle, $haystack)
}

fn Rosetta::FindIndex::last($haystack, $needle) {
    last_index_of($needle, $haystack)
}

my @arr = qw(apple banana cherry banana date)
my $ref = \@arr

$ref |> Rosetta::FindIndex::first("banana") |> assert_eq(1, "first banana")
$ref |> Rosetta::FindIndex::last("banana") |> assert_eq(3, "last banana")
$ref |> Rosetta::FindIndex::first("cherry") |> assert_eq(2, "first cherry")
$ref |> Rosetta::FindIndex::first("fig") |> assert_eq(-1, "fig not found")

test_run
