#!/usr/bin/env stryke
# Rosetta Code: Prime triplets

fn my_is_prime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        my $limit = sqrt($n)
        my $res = 1
        my $i = 3
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

fn is_prime_triplet($p) {
    if (!my_is_prime($p)) {
        0
    } else {
        if (my_is_prime($p + 6)) {
            if (my_is_prime($p + 2) || my_is_prime($p + 4)) {
                1
            } else {
                0
            }
        } else {
            0
        }
    }
}

assert_ok is_prime_triplet(5), "5 is triplet (5, 7, 11)"
assert_ok is_prime_triplet(7), "7 is triplet (7, 11, 13)"
assert_ok is_prime_triplet(11), "11 is triplet (11, 13, 17)"
assert_ok !is_prime_triplet(2), "2 is not (2, 4, 8) not prime"
assert_ok !is_prime_triplet(3), "3 is not (3, 5, 9) 9 not prime"

5 |> is_prime_triplet |> assert_ok("pipe prime triplet")

test_run
