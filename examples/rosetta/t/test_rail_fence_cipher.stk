#!/usr/bin/env stryke
# Rosetta Code: Rail Fence Cipher

fn Rosetta::RailFence::encode($text, $rails) {
    return $text if $rails <= 1
    val @fence = map { [] } 1:$rails
    var $rail = 0
    var $dir = 1
    
    for val $char ($text |> chars()) {
        push @{$fence[$rail]}, $char
        $rail += $dir
        if ($rail == $rails - 1 || $rail == 0) {
            $dir *= -1
        }
    }
    
    @fence |> map { join("", @{_}) } |> join("")
}

fn Rosetta::RailFence::decode($text, $rails) {
    return $text if $rails <= 1
    val $len = length($text)
    val @fence_pattern = map { [] } 1:$rails
    var $rail = 0
    var $dir = 1
    
    # Mark the positions
    for (var $i = 0; $i < $len; $i++) {
        push @{$fence_pattern[$rail]}, $i
        $rail += $dir
        if ($rail == $rails - 1 || $rail == 0) {
            $dir *= -1
        }
    }
    
    # Map the text chars to the positions
    var @res = map { "" } 1:$len
    var $pos = 0
    for (var $r = 0; $r < $rails; $r++) {
        for val $idx (@{$fence_pattern[$r]}) {
            $res[$idx] = substr($text, $pos++, 1)
        }
    }
    
    join("", @res)
}

val $t1 = "REDDITCANBEUSEFUL"
val $e1 = Rosetta::RailFence::encode($t1, 3)
assert_eq $e1, "RINSLEDTABUEUDCEF", "encode REDDITCANBEUSEFUL with 3 rails"
assert_eq Rosetta::RailFence::decode($e1, 3), $t1, "decode REDDITCANBEUSEFUL with 3 rails"

val $t2 = "WEAREDISCOVEREDFLEEATONCE"
val $e2 = Rosetta::RailFence::encode($t2, 3)
assert_eq $e2, "WECRLTEERDSOEEFEAOCAIVDEN", "encode WEAREDISCOVEREDFLEEATONCE with 3 rails"
assert_eq Rosetta::RailFence::decode($e2, 3), $t2, "decode WEAREDISCOVEREDFLEEATONCE with 3 rails"

test_run
