#!/usr/bin/env stryke
# Rosetta Code: Recaman's sequence

fn Rosetta::Recaman::generate($n) {
    var @a = (0)
    var %used = ("0" => 1)
    for val $i (1:$n) {
        val $prev = $a[$i-1]
        var $next = $prev - $i
        if ($next > 0 && !exists $used{$next}) {
            push @a, $next
            $used{$next} = 1
        } else {
            $next = $prev + $i
            push @a, $next
            $used{$next} = 1
        }
    }
    \@a
}

val $res10 = Rosetta::Recaman::generate(10)
assert_eq join(",", @$res10), "0,1,3,6,2,7,13,20,12,21,11", "recaman 10"

10 |> Rosetta::Recaman::generate |> map { join(",", @{_}) } |> assert_eq("0,1,3,6,2,7,13,20,12,21,11", "pipe recaman")

test_run
