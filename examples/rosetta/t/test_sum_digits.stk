#!/usr/bin/env stryke
# Rosetta Code: Sum Digits of an Integer

fn Rosetta::SumDigits::compute($n) {
    var $sum = 0
    val @digits = ~> $n abs >{ sprintf("%d", _) } chars
    for val $d (@digits) { $sum = $sum + int($d) }
    $sum
}

fn Rosetta::SumDigits::compute_base($n, $base) {
    var $sum = 0
    var $curr = abs($n)
    while ($curr > 0) {
        $sum = $sum + ($curr % $base)
        $curr = int($curr / $base)
    }
    $sum
}

assert_eq Rosetta::SumDigits::compute(123), 6, "123 -> 6"
assert_eq Rosetta::SumDigits::compute(1234567890), 45, "1234567890 -> 45"
assert_eq Rosetta::SumDigits::compute(0), 0, "0 -> 0"
assert_eq Rosetta::SumDigits::compute(-123), 6, "negative handled"

assert_eq Rosetta::SumDigits::compute_base(1, 10), 1, "base 10: 1"
assert_eq Rosetta::SumDigits::compute_base(1234, 10), 10, "base 10: 1234"
assert_eq Rosetta::SumDigits::compute_base(0xfe, 16), 29, "base 16: 0xfe (15+14)"
assert_eq Rosetta::SumDigits::compute_base(0b1010, 2), 2, "base 2: 1010"

test_run
