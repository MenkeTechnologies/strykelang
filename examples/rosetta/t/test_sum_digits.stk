#!/usr/bin/env stryke
# Rosetta Code: Sum Digits of an Integer

fn sum_digits($n) {
    abs($n) |> sprintf("%d", $_) |> split // |> map { int($_) } |> reduce { $a + $b }
}

fn sum_digits_base($n, $base) {
    my $sum = 0
    $n = abs($n)
    while ($n > 0) {
        $sum += $n % $base
        $n = int($n / $base)
    }
    $sum
}

assert_eq sum_digits(123), 6, "123 -> 6"
assert_eq sum_digits(1234567890), 45, "1234567890 -> 45"
assert_eq sum_digits(0), 0, "0 -> 0"
assert_eq sum_digits(-123), 6, "negative handled"

assert_eq sum_digits_base(1, 10), 1, "base 10: 1"
assert_eq sum_digits_base(1234, 10), 10, "base 10: 1234"
assert_eq sum_digits_base(0xfe, 16), 29, "base 16: 0xfe (15+14)"
assert_eq sum_digits_base(0b1010, 2), 2, "base 2: 1010"

test_run
