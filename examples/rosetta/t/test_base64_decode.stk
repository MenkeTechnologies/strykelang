#!/usr/bin/env stryke
# Rosetta Code: Base64 decode

fn Rosetta::Base64Decode::custom($str) {
    val $alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    var %vals
    val @alpha_chars = $alphabet |> chars
    for val $i (0:63) { $vals{$alpha_chars[$i]} = $i }
    
    val @chars = $str |> chars
    var @res
    var $i = 0
    val $len = len(@chars)
    while ($i < $len) {
        if ($chars[$i] eq "=") { last }
        
        val $v1 = $vals{$chars[$i]}
        val $v2 = $vals{$chars[$i+1]}
        val $v3 = ($chars[$i+2] eq "=") ? 0 : $vals{$chars[$i+2]}
        val $v4 = ($chars[$i+3] eq "=") ? 0 : $vals{$chars[$i+3]}
        
        val $n = ($v1 << 18) | ($v2 << 12) | ($v3 << 6) | $v4
        
        push @res, chr(($n >> 16) & 255)
        if ($chars[$i+2] ne "=") { push @res, chr(($n >> 8) & 255) }
        if ($chars[$i+3] ne "=") { push @res, chr($n & 255) }
        
        $i = $i + 4
    }
    join("", @res)
}

assert_eq Rosetta::Base64Decode::custom("Zg=="), "f", "decode 'f'"
assert_eq Rosetta::Base64Decode::custom("Zm8="), "fo", "decode 'fo'"
assert_eq Rosetta::Base64Decode::custom("Zm9v"), "foo", "decode 'foo'"
assert_eq Rosetta::Base64Decode::custom("Zm9vYmFy"), "foobar", "decode 'foobar'"

test_run
