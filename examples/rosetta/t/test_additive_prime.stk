#!/usr/bin/env stryke
# Rosetta Code: Additive primes

fn Rosetta::AdditivePrime::sum_digits($n) {
    my @digits = ~> "$n" chars map { int($_) }
    if (scalar(@digits) == 0) { return 0 }
    @digits |> reduce { $a + $b }
}

fn Rosetta::AdditivePrime::check($n) {
    if (is_prime($n)) {
        is_prime(Rosetta::AdditivePrime::sum_digits($n))
    } else {
        0
    }
}

assert_ok Rosetta::AdditivePrime::check(2), "2 is additive prime (sum 2 is prime)"
assert_ok Rosetta::AdditivePrime::check(11), "11 is additive prime (sum 2 is prime)"
assert_ok Rosetta::AdditivePrime::check(29), "29 is additive prime (sum 11 is prime)"
assert_ok !Rosetta::AdditivePrime::check(13), "13 is not (sum 4 is not prime)"
assert_ok !Rosetta::AdditivePrime::check(15), "15 is not prime"

29 |> Rosetta::AdditivePrime::check |> assert_ok("pipe additive prime")

test_run
