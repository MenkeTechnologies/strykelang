#!/usr/bin/env stryke
# Rosetta Code: Central binomial coefficients

fn Rosetta::CentralBinomial::compute($n) {
    if ($n == 0) {
        1
    } else {
        my $res = 1
        for my $i (1..$n) {
            $res = $res * ($n + $i) / $i
        }
        int($res + 0.5)
    }
}

assert_eq Rosetta::CentralBinomial::compute(0), 1, "C(0)"
assert_eq Rosetta::CentralBinomial::compute(1), 2, "C(1)"
assert_eq Rosetta::CentralBinomial::compute(2), 6, "C(2)"
assert_eq Rosetta::CentralBinomial::compute(3), 20, "C(3)"
assert_eq Rosetta::CentralBinomial::compute(4), 70, "C(4)"
assert_eq Rosetta::CentralBinomial::compute(10), 184756, "C(10)"

10 |> Rosetta::CentralBinomial::compute |> assert_eq(184756, "pipe central binomial")

test_run
