#!/usr/bin/env stryke
# Rosetta Code: War card game

fn Rosetta::WarGame::play(@deck) {
    my $half = int(len(@deck) / 2)
    my @p1 = @deck[0 .. $half - 1]
    my @p2 = @deck[$half .. len(@deck) - 1]
    
    my $turns = 0
    my @pool
    
    while (len(@p1) > 0 && len(@p2) > 0 && $turns < 1000) {
        $turns++
        my $c1 = shift @p1
        my $c2 = shift @p2
        push @pool, $c1, $c2
        
        if ($c1 > $c2) {
            push @p1, @pool
            @pool = ()
        } elsif ($c2 > $c1) {
            push @p2, @pool
            @pool = ()
        } else {
            # War!
            if (len(@p1) < 4 || len(@p2) < 4) {
                # Not enough cards for war, end game
                last
            }
            # Each player puts 3 cards face down, and 1 face up
            for (1..3) { push @pool, shift @p1, shift @p2 }
        }
    }
    
    if (len(@p1) > len(@p2)) { return 1 }
    if (len(@p2) > len(@p1)) { return 2 }
    return 0
}

# Test with a simple deck (using numbers as card values)
# P1: 10, 2
# P2: 5, 8
my @deck = (10, 2, 5, 8)
my $winner = Rosetta::WarGame::play(@deck)
# Turn 1: 10 vs 5 -> P1 wins, pool (10,5) goes to P1
# P1: 2, 10, 5
# P2: 8
# Turn 2: 2 vs 8 -> P2 wins, pool (2,8) goes to P2
# P1: 10, 5
# P2: 2, 8
# Turn 3: 10 vs 2 -> P1 wins, pool (10,2) goes to P1
# P1: 5, 10, 2
# P2: 8
# Turn 4: 5 vs 8 -> P2 wins, pool (5,8) goes to P2
# P1: 10, 2
# P2: 5, 8
# This deck might loop, but the function has a 1000 turn limit.
assert_ok $winner >= 0, "Game finished"

test_run
