#!/usr/bin/env stryke
# Rosetta Code: Sørensen–Dice coefficient

fn Rosetta::DiceCoefficient::get_bigrams($s) {
    var @chars = ~> $s chars
    var $bg = {}
    if (len(@chars) < 2) { return $bg }
    for val $i (0..len(@chars)-2) {
        val $b = $chars[$i] . $chars[$i+1]
        $bg->{$b} = ($bg->{$b} || 0) + 1
    }
    $bg
}

fn Rosetta::DiceCoefficient::compute($s1, $s2) {
    if ($s1 eq $s2) { return 1.0 }
    if (len($s1) < 2 || len($s2) < 2) { return 0.0 }
    
    val $b1 = Rosetta::DiceCoefficient::get_bigrams($s1)
    val $b2 = Rosetta::DiceCoefficient::get_bigrams($s2)
    
    var $intersection = 0
    for val $k (keys %$b1) {
        if (exists $b2->{$k}) {
            $intersection += ($b1->{$k} < $b2->{$k} ? $b1->{$k} : $b2->{$k})
        }
    }
    
    val $total = (len($s1) - 1) + (len($s2) - 1)
    (2.0 * $intersection) / $total
}

assert_near Rosetta::DiceCoefficient::compute("night", "nacht"), 0.25, 0.0001, "night vs nacht"
assert_near Rosetta::DiceCoefficient::compute("context", "contact"), 0.5, 0.0001, "context vs contact"
assert_eq Rosetta::DiceCoefficient::compute("abc", "abc"), 1.0, "identical strings"

test_run
