#!/usr/bin/env stryke
# Rosetta Code: Sørensen–Dice coefficient

fn my_dice_coefficient($s1, $s2) {
    if ($s1 eq $s2) { return 1.0 }
    if (length($s1) < 2 || length($s2) < 2) { return 0.0 }
    
    fn get_bigrams($s) {
        my @chars = ~> $s chars
        my $bg = {}
        for my $i (0..scalar(@chars)-2) {
            my $b = $chars[$i] . $chars[$i+1]
            $bg->{$b} = ($bg->{$b} || 0) + 1
        }
        $bg
    }
    
    my $b1 = get_bigrams($s1)
    my $b2 = get_bigrams($s2)
    
    my $intersection = 0
    for my $k (keys %$b1) {
        if (exists $b2->{$k}) {
            $intersection += ($b1->{$k} < $b2->{$k} ? $b1->{$k} : $b2->{$k})
        }
    }
    
    my $total = (length($s1) - 1) + (length($s2) - 1)
    (2.0 * $intersection) / $total
}

assert_ok abs(my_dice_coefficient("night", "nacht") - 0.25) < 0.0001, "night vs nacht"
assert_ok abs(my_dice_coefficient("context", "contact") - 0.5) < 0.0001, "context vs contact"
assert_eq my_dice_coefficient("abc", "abc"), 1.0, "identical strings"

test_run
