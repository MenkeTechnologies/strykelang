#!/usr/bin/env stryke
# Rosetta Code: Vector Math (Magnitude and Angle)

fn Rosetta::VectorOps::algo_mag($v) {
    var $sum = 0.0
    for val $x (@$v) { $sum = $sum + $x * $x }
    sqrt($sum)
}

fn Rosetta::VectorOps::algo_dot($v1, $v2) {
    var $sum = 0.0
    for val $i (0..len(@$v1)-1) { $sum = $sum + $v1->[$i] * $v2->[$i] }
    $sum
}

fn Rosetta::VectorOps::algo_angle($v1, $v2) {
    acos(Rosetta::VectorOps::algo_dot($v1, $v2) / (Rosetta::VectorOps::algo_mag($v1) * Rosetta::VectorOps::algo_mag($v2)))
}

val $v1 = [1, 0]; val $v2 = [0, 1]
assert_eq Rosetta::VectorOps::algo_mag($v1), 1, "mag [1,0]"
assert_ok abs(Rosetta::VectorOps::algo_angle($v1, $v2) - 1.570796) < 0.0001, "angle 90 deg"
test_run
