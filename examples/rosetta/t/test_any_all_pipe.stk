#!/usr/bin/env stryke
# Rosetta Code: Any and All (using pipes)

1:10 |> all { $_ > 0 } |> assert_eq(1, "all > 0")
1:10 |> all { $_ < 5 } |> assert_eq(0, "all < 5")
1:10 |> any { $_ > 9 } |> assert_eq(1, "any > 9")
1:10 |> any { $_ < 0 } |> assert_eq(0, "any < 0")

1:100 |> grep { $_ % 10 == 0 } |> all { $_ % 5 == 0 } |> assert_eq(1, "complex pipe")

test_run
