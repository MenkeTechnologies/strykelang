#!/usr/bin/env stryke
# Rosetta Code: URL encoding

fn Rosetta::URL::encode($str) {
    # Rosetta Code task spec: percent-encode every non-alphanumeric byte
    # (matches Perl's `uri_escape($s, "^A-Za-z0-9")`). The default
    # one-arg form preserves RFC 3986 unreserved characters
    # `-`, `_`, `.`, `~`, which is the modern URI::Escape default.
    uri_escape($str, "^A-Za-z0-9")
}

fn Rosetta::URL::decode($str) {
    uri_unescape($str)
}

my $url = "http://rosettacode.org/wiki/Main Page"
my $encoded = $url |> Rosetta::URL::encode()
$encoded |> assert_eq("http%3A%2F%2Frosettacode%2Eorg%2Fwiki%2FMain%20Page", "Encoded URL")

$encoded |> Rosetta::URL::decode() |> assert_eq($url, "Decoded URL")

test_run
