#!/usr/bin/env stryke
# Rosetta Code: 100 prisoners

fn Rosetta::Prisoners::play($optimal) {
    var @boxes = 0:99
    @boxes = shuffle(@boxes)
    
    for (var $p = 0; $p < 100; $p++) {
        var $found = 0
        if ($optimal) {
            var $curr = $p
            for (var $i = 0; $i < 50; $i++) {
                if ($boxes[$curr] == $p) {
                    $found = 1
                    last
                }
                $curr = $boxes[$curr]
            }
        } else {
            var @choices = 0:99
            @choices = shuffle(@choices)
            for (var $i = 0; $i < 50; $i++) {
                if ($boxes[$choices[$i]] == $p) {
                    $found = 1
                    last
                }
            }
        }
        return 0 if !$found
    }
    1
}

# Statistics
val $num_trials = 1000

# Random strategy: extremely low probability (2^-100)
val $random_wins = ~> 1:$num_trials map { Rosetta::Prisoners::play(0) } |> reduce { _0 + _1 }
assert_eq $random_wins, 0, "Random strategy wins 0 times"

# Optimal strategy: ~31%
val $optimal_wins = ~> 1:$num_trials map { Rosetta::Prisoners::play(1) } |> reduce { _0 + _1 }
assert_ok $optimal_wins > 250 && $optimal_wins < 380, "Optimal strategy wins around 31%"

test_run
