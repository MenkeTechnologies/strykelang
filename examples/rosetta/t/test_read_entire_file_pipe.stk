#!/usr/bin/env stryke
# Rosetta Code: Read entire file

fn Rosetta::ReadEntireFile::read($path) {
    slurp($path)
}

val $tmp_file = "/tmp/stryke_test_read_entire_file.txt"
val $expected = "Line 1\nLine 2\nLine 3\n"

# Setup
open val $fh, '>', $tmp_file or die "Could not setup file"
print $fh $expected
close $fh

# Read using our function
val $actual = $tmp_file |> Rosetta::ReadEntireFile::read()
$actual |> assert_eq($expected, "Slurped content matches")

unlink $tmp_file

test_run
