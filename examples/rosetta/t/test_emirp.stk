#!/usr/bin/env stryke
# Rosetta Code: Emirp primes

fn Rosetta::Prime::is_emirp($n) {
    return 0 if !is_prime($n)
    my $r = rev("$n")
    return 0 if $r == $n # Not a palindrome
    is_prime($r)
}

my @emirps = 1:500 |> grep { Rosetta::Prime::is_emirp(_) }
my $res = join(",", @emirps)

# Expected emirps up to 500:
# 13, 17, 31, 37, 71, 73, 79, 97, 107, 113, 149, 157, 167, 179, 199, 311, 337, 347, 359, 389
assert_eq $res, "13,17,31,37,71,73,79,97,107,113,149,157,167,179,199,311,337,347,359,389", "emirps up to 500"

# Using pipeline for first 10 emirps
my @first10 = ~> 1:1000 grep { Rosetta::Prime::is_emirp(_) } |> take(10)
assert_eq join(",", @first10), "13,17,31,37,71,73,79,97,107,113", "first 10 emirps"

test_run
