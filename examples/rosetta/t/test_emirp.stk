#!/usr/bin/env stryke
# Rosetta Code: Emirp

fn Rosetta::Emirp::check($n) {
    if (is_prime($n)) {
        my $rev = int(join("", rev(chars(str($n)))))
        if ($rev != $n) {
            return is_prime($rev)
        }
    }
    0
}

assert_ok Rosetta::Emirp::check(13), "13 is emirp"
assert_ok Rosetta::Emirp::check(17), "17 is emirp"
assert_ok Rosetta::Emirp::check(31), "31 is emirp"
assert_eq Rosetta::Emirp::check(2), 0, "2 is not emirp"
assert_eq Rosetta::Emirp::check(19), 0, "19 is not emirp"

13 |> Rosetta::Emirp::check |> assert_ok("pipe emirp check")

test_run
