#!/usr/bin/env stryke
# Rosetta Code: LZ78 compression

fn Rosetta::LZ78::compress($text) {
    var @chars = $text |> chars()
    var %dict
    var @res
    var $w = ""
    var $dict_size = 1
    
    for val $c (@chars) {
        val $wc = $w . $c
        if (exists $dict{$wc}) {
            $w = $wc
        } else {
            val $index = ($w eq "") ? 0 : $dict{$w}
            push @res, [$index, $c]
            $dict{$wc} = $dict_size++
            $w = ""
        }
    }
    
    if ($w ne "") {
        # Last part
        val $last_c = substr($w, -1, 1)
        val $prefix = substr($w, 0, -1)
        val $index = ($prefix eq "") ? 0 : $dict{$prefix}
        push @res, [$index, $last_c]
    }
    
    \@res
}

fn Rosetta::LZ78::decompress($compressed) {
    var @dict = ("")
    var $res = ""
    for val $pair (@$compressed) {
        val ($index, $c) = @$pair
        val $entry = $dict[$index] . $c
        $res .= $entry
        push @dict, $entry
    }
    $res
}

val $t = "banana banda"
val $compressed = Rosetta::LZ78::compress($t)
val $back = Rosetta::LZ78::decompress($compressed)
assert_eq $back, $t, "LZ78 round trip banana banda"

val $t2 = "abracadabra"
val $compressed2 = Rosetta::LZ78::compress($t2)
assert_eq Rosetta::LZ78::decompress($compressed2), $t2, "LZ78 round trip abracadabra"

test_run
