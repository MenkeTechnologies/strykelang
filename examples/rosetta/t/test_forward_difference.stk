#!/usr/bin/env stryke
# Rosetta Code: Forward difference

fn forward_diff(@arr) {
    my $len = scalar(@arr)
    if ($len < 2) {
        ([])
    } else {
        my @res
        for my $i (1..$len-1) {
            push @res, $arr[$i] - $arr[$i-1]
        }
        \@res
    }
}

fn nth_forward_diff($n, @arr) {
    my $res = [@arr]
    for my $i (1..$n) {
        $res = forward_diff(@$res)
    }
    $res
}

my @data = (90, 47, 58, 29, 22, 32, 55, 5, 55, 73)
my $d1 = forward_diff(@data)
assert_eq join(",", @$d1), "-43,11,-29,-7,10,23,-50,50,18", "1st forward diff"

my $d2 = nth_forward_diff(2, @data)
assert_eq join(",", @$d2), "54,-40,22,17,13,-73,100,-32", "2nd forward diff"

@data |> forward_diff |> map { join(",", @$_) } |> assert_eq("-43,11,-29,-7,10,23,-50,50,18", "pipe forward diff")

test_run
