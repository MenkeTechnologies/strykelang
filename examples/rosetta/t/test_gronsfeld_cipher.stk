#!/usr/bin/env stryke
# Rosetta Code: Gronsfeld cipher

fn Rosetta::Gronsfeld::encode($text, $key) {
    val $t = $text |> uc() |> { _ =~ s/[^A-Z]//gr }
    val $k = $key |> { _ =~ s/[^0-9]//gr }
    return "" if len($k) == 0
    
    val @t_chars = $t |> chars()
    val @k_digits = $k |> chars() |> map {int}
    val $k_len = len(@k_digits)
    
    val @res = ~> 0:(len(@t_chars)-1) map {
        val $i = _
        val $p_val = ord($t_chars[$i]) - ord("A")
        val $shift = $k_digits[$i % $k_len]
        
        val $c_val = ($p_val + $shift) % 26
        chr($c_val + ord("A"))
    }
    
    join("", @res)
}

fn Rosetta::Gronsfeld::decode($text, $key) {
    val $t = $text |> uc() |> { _ =~ s/[^A-Z]//gr }
    val $k = $key |> { _ =~ s/[^0-9]//gr }
    return "" if len($k) == 0
    
    val @t_chars = $t |> chars()
    val @k_digits = $k |> chars() |> map {int}
    val $k_len = len(@k_digits)
    
    val @res = ~> 0:(len(@t_chars)-1) map {
        val $i = _
        val $c_val = ord($t_chars[$i]) - ord("A")
        val $shift = $k_digits[$i % $k_len]
        
        var $p_val = ($c_val - $shift) % 26
        if ($p_val < 0) { $p_val += 26 }
        chr($p_val + ord("A"))
    }
    
    join("", @res)
}

val $t = "GRONSFELD"
val $k = "0123"
val $enc = Rosetta::Gronsfeld::encode($t, $k)
assert_eq $enc, "GSQQSGGOD", "encode with Gronsfeld"
assert_eq Rosetta::Gronsfeld::decode($enc, $k), "GRONSFELD", "decode with Gronsfeld"

test_run
