#!/usr/bin/env stryke
# Rosetta Code: Gronsfeld cipher

fn Rosetta::Gronsfeld::encode($text, $key) {
    my $t = $text |> uc() |> { $_ =~ s/[^A-Z]//gr }
    my $k = $key |> { $_ =~ s/[^0-9]//gr }
    return "" if length($k) == 0
    
    my @t_chars = $t |> chars()
    my @k_digits = $k |> chars() |> map { int($_) }
    my $k_len = scalar(@k_digits)
    
    my @res = ~> 0:(scalar(@t_chars)-1) map {
        my $i = $_
        my $p_val = ord($t_chars[$i]) - ord("A")
        my $shift = $k_digits[$i % $k_len]
        
        my $c_val = ($p_val + $shift) % 26
        chr($c_val + ord("A"))
    }
    
    join("", @res)
}

fn Rosetta::Gronsfeld::decode($text, $key) {
    my $t = $text |> uc() |> { $_ =~ s/[^A-Z]//gr }
    my $k = $key |> { $_ =~ s/[^0-9]//gr }
    return "" if length($k) == 0
    
    my @t_chars = $t |> chars()
    my @k_digits = $k |> chars() |> map { int($_) }
    my $k_len = scalar(@k_digits)
    
    my @res = ~> 0:(scalar(@t_chars)-1) map {
        my $i = $_
        my $c_val = ord($t_chars[$i]) - ord("A")
        my $shift = $k_digits[$i % $k_len]
        
        my $p_val = ($c_val - $shift) % 26
        if ($p_val < 0) { $p_val += 26 }
        chr($p_val + ord("A"))
    }
    
    join("", @res)
}

my $t = "GRONSFELD"
my $k = "0123"
my $enc = Rosetta::Gronsfeld::encode($t, $k)
assert_eq $enc, "GSQQSGGOD", "encode with Gronsfeld"
assert_eq Rosetta::Gronsfeld::decode($enc, $k), "GRONSFELD", "decode with Gronsfeld"

test_run
