#!/usr/bin/env stryke
# Rosetta Code: Evil and odious numbers

fn Rosetta::EvilOdious::count_bits($n) {
    my $count = 0
    my $num = $n
    while ($num > 0) {
        if ($num % 2 == 1) { $count++ }
        $num = int($num / 2)
    }
    $count
}

fn Rosetta::EvilOdious::is_evil($n) {
    Rosetta::EvilOdious::count_bits($n) % 2 == 0
}

fn Rosetta::EvilOdious::is_odious($n) {
    Rosetta::EvilOdious::count_bits($n) % 2 == 1
}

assert_ok Rosetta::EvilOdious::is_evil(3), "3 is evil (binary 11, bits 2)"
assert_ok Rosetta::EvilOdious::is_evil(5), "5 is evil (binary 101, bits 2)"
assert_ok Rosetta::EvilOdious::is_odious(1), "1 is odious (binary 1, bits 1)"
assert_ok Rosetta::EvilOdious::is_odious(7), "7 is odious (binary 111, bits 3)"

3 |> Rosetta::EvilOdious::is_evil |> assert_ok("pipe evil")

test_run
