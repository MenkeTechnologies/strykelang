#!/usr/bin/env stryke
# Rosetta Code: Leyland numbers

fn is_leyland($n) {
    my $found = 0
    my $x = 2
    while ($x**2 < $n && !$found) {
        my $y = 2
        while ($x**$y + $y**$x <= $n && !$found) {
            if ($x**$y + $y**$x == $n) {
                $found = 1
            }
            $y++
        }
        $x++
    }
    $found
}

assert_ok is_leyland(8), "8 is Leyland (2^2 + 2^2)"
assert_ok is_leyland(17), "17 is Leyland (2^3 + 3^2)"
assert_ok is_leyland(32), "32 is Leyland (2^4 + 4^2)"
assert_ok is_leyland(54), "54 is Leyland (3^3 + 3^3)"
assert_ok is_leyland(57), "57 is Leyland (2^5 + 5^2)"
assert_ok !is_leyland(10), "10 is not Leyland"

17 |> is_leyland |> assert_ok("pipe Leyland")

test_run
