#!/usr/bin/env stryke
# Rosetta Code: Arithmetic coding

fn Rosetta::ArithmeticCoding::get_probs($text) {
    val @chars = $text |> chars
    var %count
    for val $c (@chars) { $count{$c} = $count{$c} + 1 }
    
    val @sorted_chars = sort(keys %count)
    var %probs
    var $curr = 0
    val $total = len(@chars)
    for val $c (@sorted_chars) {
        val $p = $count{$c} / $total
        $probs{$c} = { low => $curr, high => $curr + $p }
        $curr = $curr + $p
    }
    \%probs
}

fn Rosetta::ArithmeticCoding::encode($text, $probs) {
    var $low = 0
    var $high = 1
    val @chars = $text |> chars
    for val $c (@chars) {
        val $range = $high - $low
        val $p = $probs->{$c}
        $high = $low + $range * $p->{high}
        $low = $low + $range * $p->{low}
    }
    $low
}

fn Rosetta::ArithmeticCoding::decode($val, $probs, $len) {
    var $res = ""
    var $v = $val
    for val $i (1:$len) {
        for val $c (sort(keys %$probs)) {
            val $p = $probs->{$c}
            if ($v >= $p->{low} && $v < $p->{high}) {
                $res = $res . $c
                $v = ($v - $p->{low}) / ($p->{high} - $p->{low})
                last
            }
        }
    }
    $res
}

val $input = "WIKI"
val $probs = Rosetta::ArithmeticCoding::get_probs($input)
val $encoded = Rosetta::ArithmeticCoding::encode($input, $probs)
val $decoded = Rosetta::ArithmeticCoding::decode($encoded, $probs, 4)

assert_eq $decoded, $input, "Arithmetic encode/decode 'WIKI'"

test_run
