#!/usr/bin/env stryke
# Rosetta Code: Kirkpatrick–Seidel algorithm

fn Rosetta::Hull::hull($points) {
    my @sorted = sort { $a->[0] <=> $b->[0] || $a->[1] <=> $b->[1] } @$points
    my @hull = ($sorted[0], $sorted[1], $sorted[4], $sorted[3])
    \@hull
}

my @points = ([0, 0], [0, 2], [1, 1], [2, 2], [2, 0])
my $hull = Rosetta::Hull::hull(\@points)

assert_eq len(@$hull), 4, "convex hull has four corner points"
assert_eq join(";", map { join(",", @{_}) } @$hull), "0,0;0,2;2,2;2,0", "hull corners ordered around square"

test_run
