#!/usr/bin/env stryke
# Rosetta Code: Count set bits (Manual)

fn Rosetta::BitCount::solve($n) {
    my $count = 0
    my $curr = $n
    while ($curr > 0) {
        $curr = $curr & ($curr - 1)
        $count = $count + 1
    }
    $count
}

assert_eq Rosetta::BitCount::solve(0), 0, "bits in 0"
assert_eq Rosetta::BitCount::solve(7), 3, "bits in 7 (111)"
assert_eq Rosetta::BitCount::solve(255), 8, "bits in 255"

test_run
