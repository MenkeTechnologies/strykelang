#!/usr/bin/env stryke
# Rosetta Code: Anagrams

fn Rosetta::Anagrams::sort_chars($s) {
    ~> $s lc chars sort join("")
}

fn Rosetta::Anagrams::check($a, $b) {
    val $s1 = Rosetta::Anagrams::sort_chars($a)
    val $s2 = Rosetta::Anagrams::sort_chars($b)
    $s1 eq $s2
}

fn Rosetta::Anagrams::find($word, @words) {
    val $key = Rosetta::Anagrams::sort_chars($word)
    val @res = ~> @words grep {
        val $sc = Rosetta::Anagrams::sort_chars(_)
        $sc eq $key && lc(_) ne lc($word)
    }
    \@res
}

assert_ok Rosetta::Anagrams::check("listen", "silent"), "listen/silent"
assert_ok Rosetta::Anagrams::check("evil", "vile"), "evil/vile"
assert_ok Rosetta::Anagrams::check("Elvis", "lives"), "Elvis/lives (case insensitive)"
assert_ok !Rosetta::Anagrams::check("hello", "world"), "hello/world not anagrams"

val @words = qw(cat act tac dog god)
val $cat_anagrams = Rosetta::Anagrams::find("cat", @words)
val @sorted_cat = sort(@$cat_anagrams)
assert_eq join(",", @sorted_cat), "act,tac", "anagrams of cat"

val $dog_anagrams = Rosetta::Anagrams::find("dog", @words)
assert_eq join(",", @$dog_anagrams), "god", "anagrams of dog"

test_run
