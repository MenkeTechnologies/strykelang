#!/usr/bin/env stryke
# Rosetta Code: Luhn test of credit card numbers (using pipes)

fn Rosetta::Luhn::solve($num_str) {
    # Reverse string into digits array
    my @digits = $num_str |> chars() |> rev()
    my $len = len(@digits)
    
    # Map index 0..len-1 to doubled/adjusted values, then sum
    my $sum = ~> 0..$len-1 map {
        my $i = $_
        my $d = int($digits[$i])
        if ($i % 2 == 1) {
            $d *= 2
            if ($d > 9) { $d -= 9 }
        }
        $d
    } |> sum()
    
    $sum % 10 == 0
}

assert_eq Rosetta::Luhn::solve("49927398716"), 1, "49927398716 is valid"
assert_eq Rosetta::Luhn::solve("49927398717"), 0, "49927398717 is invalid"
assert_eq Rosetta::Luhn::solve("1234567812345678"), 0, "1234567812345678 is invalid"
assert_eq Rosetta::Luhn::solve("1234567812345670"), 1, "1234567812345670 is valid"

test_run
