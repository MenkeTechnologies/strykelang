#!/usr/bin/env stryke
# Rosetta Code: Kronecker product

fn Rosetta::KroneckerProduct::compute($a, $b) {
    val $m = len(@$a)
    val $n = len(@{$a->[0]})
    val $p = len(@$b)
    val $q = len(@{$b->[0]})
    
    var @res = ()
    for val $i (0:$m*$p-1) { $res[$i] = [] }
    
    for val $i (0:$m-1) {
        for val $j (0:$n-1) {
            for val $k (0:$p-1) {
                for val $l (0:$q-1) {
                    $res[$i*$p + $k][$j*$q + $l] = $a->[$i][$j] * $b->[$k][$l]
                }
            }
        }
    }
    \@res
}

val $a = [[1, 2], [3, 4]]
val $b = [[0, 5], [6, 7]]
val $res = Rosetta::KroneckerProduct::compute($a, $b)

# Res should be:
# 1*0 1*5 2*0 2*5 -> 0 5 0 10
# 1*6 1*7 2*6 2*7 -> 6 7 12 14
# 3*0 3*5 4*0 4*5 -> 0 15 0 20
# 3*6 3*7 4*6 4*7 -> 18 21 24 28

assert_eq join(",", @{$res->[0]}), "0,5,0,10", "row 0"
assert_eq join(",", @{$res->[3]}), "18,21,24,28", "row 3"

test_run
