#!/usr/bin/env stryke
# Rosetta Code: Move-to-front transform

fn Rosetta::MoveToFront::mtf_encode($str) {
    var @alpha = ("a" .. "z")
    var @res
    val @chars = $str |> chars
    for val $c (@chars) {
        var $idx = 0
        for val $i (0..len(@alpha)-1) {
            if ($alpha[$i] eq $c) { $idx = $i; last }
        }
        push @res, $idx
        val $val = splice(@alpha, $idx, 1)
        unshift @alpha, $val
    }
    \@res
}

fn Rosetta::MoveToFront::mtf_decode($codes_ref) {
    var @alpha = ("a" .. "z")
    val @codes = @$codes_ref
    var $res = ""
    for val $idx (@codes) {
        val $c = $alpha[$idx]
        $res = $res . $c
        val $val = splice(@alpha, $idx, 1)
        unshift @alpha, $val
    }
    $res
}

val $input = "brood"
val $encoded = Rosetta::MoveToFront::mtf_encode($input)
assert_eq join(",", @$encoded), "1,17,15,0,5", "mtf_encode 'brood'"

val $decoded = Rosetta::MoveToFront::mtf_decode($encoded)
assert_eq $decoded, $input, "mtf_decode 'brood'"

test_run
