#!/usr/bin/env stryke
# Rosetta Code: Van der Corput sequence
# v_b(n) is obtained by writing n in base b, reflecting the digits
# about the decimal point, and reading the result as a base-b fraction.
# So v_2(1) = 0.1₂ = 1/2, v_2(2) = 0.01₂ = 1/4, v_2(3) = 0.11₂ = 3/4, …

fn Rosetta::VanDerCorput::value($n, $b) {
    my $q = 0
    my $bk = 1.0
    while ($n > 0) {
        $bk = $bk * $b
        $q += ($n % $b) / $bk
        $n = int($n / $b)
    }
    $q
}

fn Rosetta::VanDerCorput::sequence($k, $b) {
    1:$k |> map { Rosetta::VanDerCorput::value(_, $b) }
}

# Base 2 first eight values
my @s2 = Rosetta::VanDerCorput::sequence(8, 2)
my @expected2 = (0.5, 0.25, 0.75, 0.125, 0.625, 0.375, 0.875, 0.0625)
for my $i (0..7) {
    assert_near $s2[$i], $expected2[$i], 1e-12, sprintf("v_2(%d)", $i + 1)
}

# Base 3 first six values
# v_3(1) = 1/3 ≈ 0.333…
# v_3(2) = 2/3 ≈ 0.666…
# v_3(3) = 1/9
# v_3(4) = 1/9 + 1/3 = 4/9
# v_3(5) = 1/9 + 2/3 = 7/9
# v_3(6) = 2/9
my @s3 = Rosetta::VanDerCorput::sequence(6, 3)
my @expected3 = (1/3, 2/3, 1/9, 4/9, 7/9, 2/9)
for my $i (0..5) {
    assert_near $s3[$i], $expected3[$i], 1e-12, sprintf("v_3(%d)", $i + 1)
}

# Every value in (0, 1)
my @s5 = Rosetta::VanDerCorput::sequence(50, 5)
my $bounded = 1
for my $v (@s5) { $bounded = 0 if $v <= 0 || $v >= 1 }
assert_ok $bounded, "every base-5 value in (0,1)"

# Pipe form
1 |> fn { Rosetta::VanDerCorput::value(_, 2) } |> assert_near(0.5, 1e-12, "pipe v_2(1)")

# Threaded
my $v3_5 = ~> 5 fn { Rosetta::VanDerCorput::value(_, 3) }
assert_near $v3_5, 7/9, 1e-12, "threaded v_3(5)"

test_run
