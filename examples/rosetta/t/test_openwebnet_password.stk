#!/usr/bin/env stryke
# Rosetta Code: OpenWebNet password

fn Rosetta::OpenWebNet::derive($passwd, $nonce) {
    # OpenWebNet HMAC-SHA256 password derivation
    # The password is the HMAC-SHA256 of the nonce using the user password as key
    # Stryke's hmac_sha256 takes (key, message)
    return hmac_sha256($passwd, $nonce)
}

fn Rosetta::OpenWebNet::demo() {
    my $passwd = "12345"
    my $nonce = "12345678901234567890123456789012"
    my $res = Rosetta::OpenWebNet::derive($passwd, $nonce)
    
    "OpenWebNet password for $passwd with nonce $nonce:" |> p
    $res |> p
    
    # Assertions
    assert_ok defined($res), "HMAC derived"
    assert_eq length($res), 64, "Result is 64 hex chars (SHA256)"
    
    # Standard derivation: hmac_sha256(key="12345", message="12345678...")
    assert_eq $res, "167882420fe544e34883ed75d516b7ace8c0fd9722e0f8d03378fc568e7ecb7e", "Matches OpenWebNet derivation"
}

Rosetta::OpenWebNet::demo()
test_run
