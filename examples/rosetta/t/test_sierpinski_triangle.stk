#!/usr/bin/env stryke
# Rosetta Code: Sierpinski Triangle

fn Rosetta::Sierpinski::generate($n) {
    var @res
    for val $i (0:$n-1) {
        var $row = ""
        for val $s (0:$n-$i-2) { $row = $row . " " }
        
        var $c = 1
        for val $j (0:$i) {
            if ($c % 2 == 1) {
                $row = $row . "* "
            } else {
                $row = $row . "  "
            }
            $c = $c * ($i - $j) / ($j + 1)
        }
        push @res, $row
    }
    \@res
}

p "Sierpinski Triangle (8 rows):"
val $rows = Rosetta::Sierpinski::generate(8)
for val $r (@$rows) { print "$r\n" }

assert_eq len(@$rows), 8, "8 rows generated"

test_run
