#!/usr/bin/env stryke
# Rosetta Code: Sierpinski Triangle

fn Rosetta::Sierpinski::generate($n) {
    my @res
    for my $i (0..$n-1) {
        my $row = ""
        for my $s (0..$n-$i-2) { $row = $row . " " }
        
        my $c = 1
        for my $j (0..$i) {
            if ($c % 2 == 1) {
                $row = $row . "* "
            } else {
                $row = $row . "  "
            }
            $c = $c * ($i - $j) / ($j + 1)
        }
        push @res, $row
    }
    \@res
}

print "Sierpinski Triangle (8 rows):\n"
my $rows = Rosetta::Sierpinski::generate(8)
for my $r (@$rows) { print "$r\n" }

assert_eq len(@$rows), 8, "8 rows generated"

test_run
