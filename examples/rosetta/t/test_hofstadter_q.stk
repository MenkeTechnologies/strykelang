#!/usr/bin/env stryke
# Rosetta Code: Hofstadter Q sequence

my %memo

fn hofstadter_q {
    my $n = $_[0]
    if (exists $memo{$n}) {
        $memo{$n}
    } else {
        my $prev1 = hofstadter_q($n - 1)
        my $prev2 = hofstadter_q($n - 2)
        my $res = hofstadter_q($n - $prev1) + hofstadter_q($n - $prev2)
        $memo{$n} = $res
        $res
    }
}

# Initialize for first test
$memo{1} = 1
$memo{2} = 1
assert_eq hofstadter_q(10), 6, "Q(10) is 6"

# Clear memoization for sequence test  
delete $memo{$_} for keys %memo
$memo{1} = 1
$memo{2} = 1
my @seq = (1..10) |> map { hofstadter_q($_) }
assert_eq join(",", @seq), "1,1,2,3,3,4,5,5,6,6", "first 10 Q numbers"

test_run
