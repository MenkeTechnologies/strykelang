#!/usr/bin/env stryke
# Rosetta Code: Hofstadter Q sequence

fn Rosetta::HofstadterQ::compute($n) {
    var @q = (0, 1, 1)
    for val $i (3:$n) {
        val $prev1 = $q[$i - 1]
        val $prev2 = $q[$i - 2]
        val $val = $q[$i - $prev1] + $q[$i - $prev2]
        push @q, $val
    }
    @q[$n]
}

assert_eq Rosetta::HofstadterQ::compute(1), 1, "Q(1)"
assert_eq Rosetta::HofstadterQ::compute(2), 1, "Q(2)"
assert_eq Rosetta::HofstadterQ::compute(3), 2, "Q(3)"
assert_eq Rosetta::HofstadterQ::compute(10), 6, "Q(10)"
assert_eq Rosetta::HofstadterQ::compute(1000), 502, "Q(1000)"

test_run
