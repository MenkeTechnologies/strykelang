#!/usr/bin/env stryke
# Rosetta Code: RIPEMD-160

fn Rosetta::RIPEMD160::hash($text) {
    ripemd160($text)
}

val $input = "Rosetta Code"
val $hash = Rosetta::RIPEMD160::hash($input)

# Known RIPEMD-160 for "Rosetta Code":
# b3be159860842cebaa7174c8fff0aa9e50a5199f
assert_eq $hash, "b3be159860842cebaa7174c8fff0aa9e50a5199f", "RIPEMD-160 of 'Rosetta Code'"

test_run
