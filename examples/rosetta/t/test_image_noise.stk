#!/usr/bin/env stryke
# Rosetta Code: Image noise

fn Rosetta::ImageNoise::generate($width, $height) {
    # Generate a grayscale noise image
    var @image
    for (var $y = 0; $y < $height; $y++) {
        var @row
        for (var $x = 0; $x < $width; $x++) {
            # Random value between 0 and 255
            val $pixel = int(rand(256))
            push @row, $pixel
        }
        push @image, \@row
    }
    \@image
}

val $width = 10
val $height = 10
val $noise = Rosetta::ImageNoise::generate($width, $height)

assert_eq len(@$noise), $height, "Image height correct"
assert_eq len(@{$noise->[0]}), $width, "Image width correct"

# Check if values are within bounds
var $valid = 1
for val $row (@$noise) {
    for val $pixel (@$row) {
        $valid = 0 if $pixel < 0 || $pixel > 255
    }
}
assert_eq $valid, 1, "All pixels are within 0-255"

test_run
