#!/usr/bin/env stryke
# Rosetta Code: Balanced Ternary

fn Rosetta::BalancedTernary::encode($n) {
    if ($n == 0) { return "0" }
    my $res = ""
    my $curr = $n
    while ($curr != 0) {
        my $rem = $curr % 3
        if ($rem < 0) { $rem += 3 }
        if ($rem == 0) {
            $res = "0" . $res
            $curr = int($curr / 3)
        } elsif ($rem == 1) {
            $res = "1" . $res
            $curr = int(($curr - 1) / 3)
        } else {
            $res = "Z" . $res
            $curr = int(($curr + 1) / 3)
        }
    }
    $res
}

fn Rosetta::BalancedTernary::decode($s) {
    my $res = 0
    my @chars = ~> $s chars
    for my $c (@chars) {
        my $val = ($c eq "Z" ? -1 : int($c))
        $res = $res * 3 + $val
    }
    $res
}

assert_eq Rosetta::BalancedTernary::encode(2), "1Z", "2 to BT"
assert_eq Rosetta::BalancedTernary::encode(8), "10Z", "8 to BT"
assert_eq Rosetta::BalancedTernary::encode(-2), "Z1", "-2 to BT"
assert_eq Rosetta::BalancedTernary::decode("1Z"), 2, "1Z to decimal"
assert_eq Rosetta::BalancedTernary::decode("Z1"), -2, "Z1 to decimal"
assert_eq Rosetta::BalancedTernary::decode("10Z"), 8, "10Z to decimal"

test_run
