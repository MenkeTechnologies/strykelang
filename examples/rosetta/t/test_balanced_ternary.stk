#!/usr/bin/env stryke
# Rosetta Code: Balanced Ternary

fn to_balanced_ternary {
    my $n = $_[0]
    if ($n == 0) { return "0" }
    my $res = ""
    while ($n != 0) {
        my $rem = $n % 3
        if ($rem < 0) { $rem += 3 }
        if ($rem == 0) {
            $res = "0" . $res
            $n = int($n / 3)
        } elsif ($rem == 1) {
            $res = "1" . $res
            $n = int(($n - 1) / 3)
        } else {
            $res = "Z" . $res
            $n = int(($n + 1) / 3)
        }
    }
    $res
}

fn from_balanced_ternary {
    my $s = $_[0]
    my $res = 0
    my @chars = ~> $s chars
    for my $c (@chars) {
        my $val = ($c eq "Z" ? -1 : int($c))
        $res = $res * 3 + $val
    }
    $res
}

assert_eq to_balanced_ternary(2), "1Z", "2 to BT"
assert_eq to_balanced_ternary(8), "10Z", "8 to BT"
assert_eq to_balanced_ternary(-2), "Z1", "-2 to BT"
assert_eq from_balanced_ternary("1Z"), 2, "1Z to decimal"
assert_eq from_balanced_ternary("Z1"), -2, "Z1 to decimal"
assert_eq from_balanced_ternary("10Z"), 8, "10Z to decimal"

test_run
