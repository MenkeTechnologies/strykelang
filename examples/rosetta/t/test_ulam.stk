#!/usr/bin/env stryke
# Rosetta Code: Ulam sequence

fn Rosetta::Ulam::generate($n) {
    var @u = (1, 2)
    while (len(@u) < $n) {
        var $next = $u[-1] + 1
        var $found = 0
        while (!$found) {
            var $ways = 0
            for val $i (0..len(@u)-2) {
                for val $j ($i+1..len(@u)-1) {
                    if ($u[$i] + $u[$j] == $next) {
                        $ways++
                    }
                }
            }
            if ($ways == 1) {
                push @u, $next
                $found = 1
            } else {
                $next++
            }
        }
    }
    \@u
}

val $res = Rosetta::Ulam::generate(10)
assert_eq join(",", @$res), "1,2,3,4,6,8,11,13,16,18", "Ulam first 10"

10 |> Rosetta::Ulam::generate |> { _->[9] } |> assert_eq(18, "pipe Ulam(10)")

test_run
