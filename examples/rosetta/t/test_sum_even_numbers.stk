#!/usr/bin/env stryke
# Rosetta Code: Sum Even Numbers

fn Rosetta::SumEven::compute($list) {
    my @evens = ~> @$list grep { $_ % 2 == 0 }
    if (scalar(@evens) == 0) {
        0
    } else {
        ~> @evens reduce { $a + $b }
    }
}

assert_eq Rosetta::SumEven::compute([1, 2, 3, 4, 5, 6]), 12, "sum even 1..6 is 12"
assert_eq Rosetta::SumEven::compute([1, 3, 5]), 0, "no evens"
assert_eq Rosetta::SumEven::compute([10, 20]), 30, "10+20 is 30"

test_run
