#!/usr/bin/env stryke
# Rosetta Code: Convex hull — Jarvis march (gift wrapping)

fn Rosetta::Jarvis::cross($o, $u, $v) {
    ($u->[0] - $o->[0]) * ($v->[1] - $o->[1]) - ($u->[1] - $o->[1]) * ($v->[0] - $o->[0])
}

fn Rosetta::Jarvis::hull($points) {
    val $n = len(@$points)
    return [@$points] if $n < 3

    var $start = 0
    for val $i (1:$n-1) {
        if ($points->[$i][0] < $points->[$start][0]
            || ($points->[$i][0] == $points->[$start][0]
                && $points->[$i][1] < $points->[$start][1])) {
            $start = $i
        }
    }

    var @hull
    var $p = $start
    var $guard = 0
    while (1) {
        last if ++$guard > $n + 1
        push @hull, $points->[$p]
        var $q = ($p + 1) % $n
        for val $i (0:$n-1) {
            if (Rosetta::Jarvis::cross($points->[$p], $points->[$i], $points->[$q]) < 0) {
                $q = $i
            }
        }
        $p = $q
        last if $p == $start
    }
    \@hull
}

val $pts = [[0,0], [1,1], [2,2], [3,0], [0,3], [3,3], [1,2]]
val $h = Rosetta::Jarvis::hull($pts)
val @sig = map { _->[0] . "," . _->[1] } @$h
val $sorted = join("|", sort @sig)
assert_eq $sorted, "0,0|0,3|3,0|3,3", "convex hull of square+interior = 4 corners"

val $tri = [[0,0], [4,0], [2,3], [2,1]]
val $h2 = Rosetta::Jarvis::hull($tri)
assert_eq len(@$h2), 3, "triangle hull excludes interior point"

val $small = [[0,0], [1,0]]
val $h3 = Rosetta::Jarvis::hull($small)
assert_eq len(@$h3), 2, "two points: hull is themselves"

test_run
