#!/usr/bin/env stryke
# Rosetta Code: Counting Sort

fn Rosetta::CountingSort::sort($list, $min, $max) {
    var @arr = @$list
    var @count = ()
    
    for val $x (@arr) {
        $count[$x - $min]++
    }
    
    var @res = ()
    for val $i (0..len(@count)-1) {
        var $c = $count[$i]
        while ($c > 0) {
            push @res, $i + $min
            $c--
        }
    }
    \@res
}

val $data = [4, 2, 2, 8, 3, 3, 1]
val $sorted = Rosetta::CountingSort::sort($data, 1, 8)
assert_eq join(",", @$sorted), "1,2,2,3,3,4,8", "counting sort"

test_run
