#!/usr/bin/env stryke
# Rosetta Code: Recamán's sequence

fn Rosetta::Recaman::generate($n) {
    my @a = (0)
    my %seen = (0 => 1)
    for my $i (1 .. $n - 1) {
        my $prev = $a[$i - 1]
        my $next = $prev - $i
        if ($next > 0 && !exists $seen{$next}) {
            push @a, $next
            $seen{$next} = 1
        } else {
            $next = $prev + $i
            push @a, $next
            $seen{$next} = 1
        }
    }
    \@a
}

my $seq = Rosetta::Recaman::generate(15)
assert_eq join(",", @$seq), "0,1,3,6,2,7,13,20,12,21,11,22,10,23,9", "Recaman(15)"

test_run
