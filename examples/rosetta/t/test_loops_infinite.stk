#!/usr/bin/env stryke
# Rosetta Code: Loops/Infinite

fn infinite_loop_demo() {
    "Infinite loop examples (commented out to prevent hanging):" |> p
    
    "1. while (1) loop:" |> p
    "   while (1) { \"looping...\" |> p }" |> p
    
    "2. for loop without condition:" |> p
    "   for (;;) { \"looping...\" |> p }" |> p
    
    "3. Perl-style infinite loop:" |> p
    "   while (true) { \"looping...\" |> p }" |> p
    
    "Note: These would run forever, so they're shown as examples only." |> p
    "Use Ctrl+C to break infinite loops in practice." |> p
    
    # Uncomment to see actual infinite loop (WARNING: will hang!)
    # while (1) {
    #     "This would loop forever!" |> p
    # }
}

infinite_loop_demo