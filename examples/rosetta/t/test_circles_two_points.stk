#!/usr/bin/env stryke
# Rosetta Code: Circles of given radius through two points
# Given P1, P2 and r, find the centers of the (≤ 2) circles passing through both points.

fn Rosetta::CirclesTP::find($p1, $p2, $r) {
    val $dx = $p2->[0] - $p1->[0]
    val $dy = $p2->[1] - $p1->[1]
    val $d  = sqrt($dx * $dx + $dy * $dy)
    if ($d == 0 && $r == 0) { return ["coincident-zero"] }
    if ($d == 0)            { return ["coincident-nonzero-no-circle"] }
    if ($d > 2 * $r)        { return ["too-far"] }
    val $mx = ($p1->[0] + $p2->[0]) / 2
    val $my = ($p1->[1] + $p2->[1]) / 2
    val $h  = sqrt($r * $r - ($d * $d) / 4)
    if ($h == 0) {
        return [[$mx, $my]]
    }
    # Perpendicular unit vector
    val $ux = -$dy / $d
    val $uy =  $dx / $d
    [
        [$mx + $h * $ux, $my + $h * $uy],
        [$mx - $h * $ux, $my - $h * $uy],
    ]
}

# (0,0) and (2,0), r=2: centers at (1, sqrt(3)) and (1, -sqrt(3))
val $r = Rosetta::CirclesTP::find([0,0], [2,0], 2)
assert_eq len(@$r), 2, "two circles"
val $c1 = $r->[0]; val $c2 = $r->[1]
# Order may flip; check both
val $upper = $c1->[1] > 0 ? $c1 : $c2
val $lower = $c1->[1] > 0 ? $c2 : $c1
assert_ok abs($upper->[0] - 1) < 1e-12,             "upper x=1"
assert_ok abs($upper->[1] - sqrt(3)) < 1e-12,        "upper y=sqrt(3)"
assert_ok abs($lower->[1] + sqrt(3)) < 1e-12,        "lower y=-sqrt(3)"

# Diametric — d == 2r, exactly one circle
val $diam = Rosetta::CirclesTP::find([0,0], [4,0], 2)
assert_eq len(@$diam), 1, "diametric -> 1 circle"
assert_eq $diam->[0]->[0], 2, "center x=2"
assert_eq $diam->[0]->[1], 0, "center y=0"

# Too far apart
val $far = Rosetta::CirclesTP::find([0,0], [10,0], 2)
assert_eq $far->[0], "too-far", "too far"

# Coincident with r=0: degenerate, infinite circles (we report a sentinel)
val $deg = Rosetta::CirclesTP::find([1,1], [1,1], 0)
assert_eq $deg->[0], "coincident-zero", "coincident with zero radius"

# Coincident with r>0: no unique circle
val $deg2 = Rosetta::CirclesTP::find([1,1], [1,1], 5)
assert_eq $deg2->[0], "coincident-nonzero-no-circle", "coincident nonzero"

test_run
