#!/usr/bin/env stryke
# Rosetta Code: Fusc sequence (Stern's diatomic series)
# fusc(0)=0, fusc(1)=1, fusc(2n)=fusc(n), fusc(2n+1)=fusc(n)+fusc(n+1)

fn Rosetta::Fusc::fusc($n) {
    my $a = 1
    my $b = 0
    while ($n > 0) {
        if ($n % 2 == 0) {
            $a += $b
        } else {
            $b += $a
        }
        $n = int($n / 2)
    }
    $b
}

fn Rosetta::Fusc::first_n($count) {
    ~> 0:$count-1 map { Rosetta::Fusc::fusc(_) }
}

# OEIS A002487: 0,1,1,2,1,3,2,3,1,4,3,5,2,5,3,4,1,...
my @first17 = Rosetta::Fusc::first_n(17)
assert_eq join(",", @first17),
    "0,1,1,2,1,3,2,3,1,4,3,5,2,5,3,4,1",
    "first 17 fusc"

assert_eq Rosetta::Fusc::fusc(50),  7,  "fusc(50)=7"
assert_eq Rosetta::Fusc::fusc(100), 7,  "fusc(100)=7"

test_run
