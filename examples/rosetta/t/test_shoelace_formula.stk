#!/usr/bin/env stryke
# Rosetta Code: Shoelace formula

fn Rosetta::Shoelace::area(@points) {
    val $n = len(@points)
    var $area = 0.0
    for val $i (0:$n - 1) {
        val $j = ($i + 1) % $n
        $area += $points[$i][0] * $points[$j][1]
        $area -= $points[$j][0] * $points[$i][1]
    }
    abs($area) / 2.0
}

val @p = ([3,4], [5,11], [12,8], [9,5], [5,6])
assert_eq Rosetta::Shoelace::area(@p), 30, "Area of polygon"

test_run
