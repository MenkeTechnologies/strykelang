#!/usr/bin/env stryke
# Rosetta Code: Fork

fn Rosetta::Fork::demo() {
    val $pid = fork()
    if (!defined $pid) {
        die "Fork failed"
    }
    
    if ($pid == 0) {
        # Child process
        # p "Child: Hello from child!"
        exit 0
    } else {
        # Parent process
        # p "Parent: Child PID is $pid"
        waitpid($pid, 0)
        return "Success"
    }
}

# Since we are in a test environment, let's just assert we can call it.
# Note: fork might be restricted in some environments, but stryke has it.
val $res = Rosetta::Fork::demo()
assert_eq $res, "Success", "Fork and wait worked"

test_run
