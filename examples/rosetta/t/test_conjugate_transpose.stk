#!/usr/bin/env stryke
# Rosetta Code: Conjugate transpose
# Each cell is [real, imag]. Conjugate transpose = transpose + complex conjugation.

fn Rosetta::ConjT::conj($z) { [$z->[0], -$z->[1]] }

fn Rosetta::ConjT::transpose($m) {
    my $rows = len(@$m)
    my $cols = len(@{$m->[0]})
    my @out
    for my $j (0..$cols-1) {
        my @row
        for my $i (0..$rows-1) {
            push @row, $m->[$i]->[$j]
        }
        push @out, \@row
    }
    \@out
}

fn Rosetta::ConjT::ctrans($m) {
    my $t = Rosetta::ConjT::transpose($m)
    my @out
    for my $row (@$t) {
        my @r = ~> @$row map { Rosetta::ConjT::conj(_) }
        push @out, \@r
    }
    \@out
}

fn Rosetta::ConjT::is_hermitian($m) {
    my $c = Rosetta::ConjT::ctrans($m)
    for my $i (0..len(@$m)-1) {
        for my $j (0..len(@{$m->[$i]})-1) {
            return 0 if $m->[$i]->[$j]->[0] != $c->[$i]->[$j]->[0]
            return 0 if $m->[$i]->[$j]->[1] != $c->[$i]->[$j]->[1]
        }
    }
    1
}

# Hermitian: M = M*
my $H = [
    [ [1, 0],  [2, 1]  ],
    [ [2, -1], [3, 0]  ],
]
assert_ok Rosetta::ConjT::is_hermitian($H), "Hermitian matrix"

# Non-Hermitian
my $N = [
    [ [1, 0],  [2, 1]  ],
    [ [2, 1],  [3, 0]  ],
]
assert_ok !Rosetta::ConjT::is_hermitian($N), "non-Hermitian (sign mismatch)"

# Spot-check ctrans of a 2x2
my $A = [
    [ [1, 2],  [3, 4]  ],
    [ [5, -1], [0, 0]  ],
]
my $C = Rosetta::ConjT::ctrans($A)
assert_eq $C->[0]->[0]->[0], 1,  "C[0,0].re"
assert_eq $C->[0]->[0]->[1], -2, "C[0,0].im"
assert_eq $C->[1]->[0]->[0], 3,  "C[1,0].re"
assert_eq $C->[1]->[0]->[1], -4, "C[1,0].im"
assert_eq $C->[0]->[1]->[0], 5,  "C[0,1].re"
assert_eq $C->[0]->[1]->[1], 1,  "C[0,1].im (-(-1)=1)"

test_run
