#!/usr/bin/env stryke
# Rosetta Code: Gauss-Jordan elimination

fn Rosetta::GaussJordan::solve($matrix, $vector) {
    val $n = len(@$matrix)
    # Augmented matrix
    var @m = ~> 0:$n-1 map { [ @{$matrix->[_]}, $vector->[_] ] }
    
    for var $i (0:$n-1) {
        # Pivot
        var $max = $i
        for val $j ($i+1 : $n-1) {
            if (abs($m[$j]->[$i]) > abs($m[$max]->[$i])) {
                $max = $j
            }
        }
        # Swap rows
        ($m[$i], $m[$max]) = ($m[$max], $m[$i])
        
        val $pivot = $m[$i]->[$i]
        
        for val $j (0:$n-1) {
            if ($i != $j) {
                val $factor = $m[$j]->[$i] / $pivot
                for val $k ($i : $n) {
                    $m[$j]->[$k] -= $factor * $m[$i]->[$k]
                }
            }
        }
    }
    
    ~> 0:$n-1 map { $m[_]->[$n] / $m[_]->[_] }
}

val $M = [
    [ 2,  1, -1],
    [-3, -1,  2],
    [-2,  1,  2]
]
val $V = [ 8, -11, -3 ]

val @sol = Rosetta::GaussJordan::solve($M, $V)
assert_eq join(",", ~> @sol map {round}), "2,3,-1", "Gauss-Jordan solution"

test_run
