#!/usr/bin/env stryke
# Rosetta Code: Closures/Value capture
# Create a list of 10 functions that return their index when called — capturing the value of i,
# not a reference to a shared variable.

fn Rosetta::Closures::make_squarers() {
    var @fns
    for val $i (0:9) {
        val $captured = $i  # local binding so each closure captures its own value
        push @fns, fn { $captured * $captured }
    }
    @fns
}

fn Rosetta::Closures::make_adders($base) {
    var @fns
    for val $k (1:5) {
        val $b = $base
        val $kk = $k
        push @fns, fn { val $x = _; $b + $kk + $x }
    }
    @fns
}

val @squarers = Rosetta::Closures::make_squarers()
assert_eq len(@squarers), 10, "10 closures"
assert_eq $squarers[0](),  0,  "f0 -> 0"
assert_eq $squarers[3](),  9,  "f3 -> 9"
assert_eq $squarers[7](),  49, "f7 -> 49"
assert_eq $squarers[9](),  81, "f9 -> 81"

val @adders = Rosetta::Closures::make_adders(100)
# adder[k] = 100 + (k+1) + arg  (k 0..4 => 101..105 base)
assert_eq $adders[0](0),  101, "100+1+0"
assert_eq $adders[2](50), 153, "100+3+50"
assert_eq $adders[4](10), 115, "100+5+10"

# pipeline form
val @results = ~> (1:5) map { $squarers[_]() }
assert_eq join(",", @results), "1,4,9,16,25", "map closures over indices"

test_run
