#!/usr/bin/env stryke
# Rosetta Code: Kaprekar numbers

fn Rosetta::KaprekarNumbers::check($n) {
    if ($n == 1) { return 1 }
    my $sq = $n * $n
    my $s = "$sq"
    my $len = length($s)
    for my $i (1..$len-1) {
        my $left = substr($s, 0, $i)
        my $right = substr($s, $i)
        if (int($right) > 0 && int($left) + int($right) == $n) {
            return 1
        }
    }
    0
}

assert_ok Rosetta::KaprekarNumbers::check(1), "1 is Kaprekar"
assert_ok Rosetta::KaprekarNumbers::check(9), "9 is Kaprekar (81 -> 8+1=9)"
assert_ok Rosetta::KaprekarNumbers::check(45), "45 is Kaprekar (2025 -> 20+25=45)"
assert_ok Rosetta::KaprekarNumbers::check(297), "297 is Kaprekar (88209 -> 88+209=297)"
assert_ok !Rosetta::KaprekarNumbers::check(10), "10 is not"

test_run
