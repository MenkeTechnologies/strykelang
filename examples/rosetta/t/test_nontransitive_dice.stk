#!/usr/bin/env stryke
# Rosetta Code: Non-transitive Dice

fn Rosetta::NonTransitiveDice::win_prob($d1, $d2) {
    var $wins = 0
    var $total = 0
    for val $v1 (@$d1) {
        for val $v2 (@$d2) {
            if ($v1 > $v2) { $wins = $wins + 1 }
            $total = $total + 1
        }
    }
    $wins / $total
}

val $A = [4, 4, 4, 4, 0, 0]
val $B = [3, 3, 3, 3, 3, 3]
val $C = [6, 6, 2, 2, 2, 2]
val $D = [5, 5, 5, 1, 1, 1]

# P(A>B) = 4*6 / 36 = 24/36 = 2/3
assert_eq Rosetta::NonTransitiveDice::win_prob($A, $B), 2/3, "P(A>B)"

# P(B>C) = 6*4 / 36 = 24/36 = 2/3
assert_eq Rosetta::NonTransitiveDice::win_prob($B, $C), 2/3, "P(B>C)"

# P(C>D) = 2*6 + 4*3 / 36 = 24/36 = 2/3
assert_eq Rosetta::NonTransitiveDice::win_prob($C, $D), 2/3, "P(C>D)"

# P(D>A) = 3*6 + 3*2 / 36 = 24/36 = 2/3
assert_eq Rosetta::NonTransitiveDice::win_prob($D, $A), 2/3, "P(D>A)"

test_run
