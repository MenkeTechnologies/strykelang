#!/usr/bin/env stryke
# Rosetta Code: Pascal's triangle/Row (using map and pipes)

fn Rosetta::PascalsTriangleRow::solve($n) {
    if ($n == 0) {
        return (1)
    }
    my @prev = Rosetta::PascalsTriangleRow::solve($n - 1)
    
    # Pipeline to construct the row: zip shifted arrays, sum pairs, prepend 1, append 1
    my @left = @prev
    push @left, 0
    my @right = (0)
    for my $v (@prev) { push @right, $v }

    ~> zip(\@left, \@right) map { $_->[0] + $_->[1] }
}

assert_eq join(",", Rosetta::PascalsTriangleRow::solve(0)), "1", "row 0"
assert_eq join(",", Rosetta::PascalsTriangleRow::solve(1)), "1,1", "row 1"
assert_eq join(",", Rosetta::PascalsTriangleRow::solve(2)), "1,2,1", "row 2"
assert_eq join(",", Rosetta::PascalsTriangleRow::solve(3)), "1,3,3,1", "row 3"
assert_eq join(",", Rosetta::PascalsTriangleRow::solve(4)), "1,4,6,4,1", "row 4"

test_run
