#!/usr/bin/env stryke
# Rosetta Code: Median

fn Rosetta::Median::median {
    if (len(@$_) == 0) {
        0
    } else {
        val @sorted = sort { _0 <=> _1 } @$_
        val $len = len(@sorted)
        val $mid = int($len / 2)
        if ($len % 2 == 0) {
            ($sorted[$mid - 1] + $sorted[$mid]) / 2
        } else {
            $sorted[$mid]
        }
    }
}

val $data1 = [4, 1, 3, 2, 5]
assert_eq Rosetta::Median::median($data1), 3, "median of odd length"

val $data2 = [1, 2, 3, 4]
assert_eq Rosetta::Median::median($data2), 2.5, "median of even length"

val $data3 = [10]
assert_eq Rosetta::Median::median($data3), 10, "median of single element"

test_run
