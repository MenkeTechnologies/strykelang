#!/usr/bin/env stryke
# Rosetta Code: Strip Whitespace

fn Rosetta::Strip::strip_left($s) {
    ~> $s s/^\s+//r
}

fn Rosetta::Strip::strip_right($s) {
    ~> $s s/\s+$//r
}

fn Rosetta::Strip::strip_both($s) {
    ~> $s s/^\s+|\s+$//gr
}

fn Rosetta::CollapseWhitespace::collapse_whitespace($s) {
    ~> $s s/\s+/ /gr s/^\s+|\s+$//gr
}

assert_eq Rosetta::Strip::strip_left("  hello"), "hello", "strip left"
assert_eq Rosetta::Strip::strip_right("hello  "), "hello", "strip right"
assert_eq Rosetta::Strip::strip_both("  hello  "), "hello", "strip both"
assert_eq Rosetta::Strip::strip_both("\t\nhello\t\n"), "hello", "strip tabs/newlines"

assert_eq Rosetta::CollapseWhitespace::collapse_whitespace("  hello   world  "), "hello world", "collapse whitespace"
assert_eq Rosetta::CollapseWhitespace::collapse_whitespace("a  b  c"), "a b c", "multiple spaces"

assert_eq Rosetta::Strip::strip_both("hello"), "hello", "nothing to strip"
assert_eq Rosetta::Strip::strip_both("   "), "", "all whitespace"

test_run
