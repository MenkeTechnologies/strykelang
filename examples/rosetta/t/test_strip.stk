#!/usr/bin/env stryke
# Rosetta Code: Strip Whitespace

fn strip_left($s) {
    $s =~ s/^\s+//r
}

fn strip_right($s) {
    $s =~ s/\s+$//r
}

fn strip_both($s) {
    $s =~ s/^\s+|\s+$//gr
}

fn my_collapse_whitespace($s) {
    $s =~ s/\s+/ /gr |> strip_both
}

assert_eq strip_left("  hello"), "hello", "strip left"
assert_eq strip_right("hello  "), "hello", "strip right"
assert_eq strip_both("  hello  "), "hello", "strip both"
assert_eq strip_both("\t\nhello\t\n"), "hello", "strip tabs/newlines"

assert_eq my_collapse_whitespace("  hello   world  "), "hello world", "collapse whitespace"
assert_eq my_collapse_whitespace("a  b  c"), "a b c", "multiple spaces"

assert_eq strip_both("hello"), "hello", "nothing to strip"
assert_eq strip_both("   "), "", "all whitespace"

test_run
