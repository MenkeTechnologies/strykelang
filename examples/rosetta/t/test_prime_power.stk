#!/usr/bin/env stryke
# Rosetta Code: Prime power

fn Rosetta::PrimePower::check($n) {
    if ($n < 2) {
        0
    } else {
        my @f = prime_factors($n)
        if (scalar(@f) == 0) {
            0
        } else {
            my $p = $f[0]
            my $all_same = 1
            for my $x (@f) {
                if ($x != $p) { $all_same = 0 }
            }
            $all_same
        }
    }
}

assert_ok Rosetta::PrimePower::check(2), "2 is prime power (2^1)"
assert_ok Rosetta::PrimePower::check(4), "4 is prime power (2^2)"
assert_ok Rosetta::PrimePower::check(8), "8 is prime power (2^3)"
assert_ok Rosetta::PrimePower::check(9), "9 is prime power (3^2)"
assert_ok Rosetta::PrimePower::check(27), "27 is prime power (3^3)"
assert_ok !Rosetta::PrimePower::check(6), "6 is not (2*3)"
assert_ok !Rosetta::PrimePower::check(10), "10 is not (2*5)"
assert_ok !Rosetta::PrimePower::check(12), "12 is not (2^2 * 3)"

27 |> Rosetta::PrimePower::check |> assert_ok("pipe prime power")

test_run
