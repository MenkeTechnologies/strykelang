#!/usr/bin/env stryke
# Rosetta Code: Prime power

fn my_prime_factors($n) {
    my @factors
    my $d = 2
    my $temp = $n
    while ($temp > 1 && $d * $d <= $temp) {
        while ($temp % $d == 0) {
            push @factors, $d
            $temp = int($temp / $d)
        }
        $d++
    }
    push @factors, $temp if $temp > 1
    @factors
}

fn is_prime_power($n) {
    if ($n < 2) {
        0
    } else {
        my @f = my_prime_factors($n)
        if (scalar(@f) == 0) {
            0
        } else {
            my $p = $f[0]
            my $all_same = 1
            for my $x (@f) {
                if ($x != $p) { $all_same = 0 }
            }
            $all_same
        }
    }
}

assert_ok is_prime_power(2), "2 is prime power (2^1)"
assert_ok is_prime_power(4), "4 is prime power (2^2)"
assert_ok is_prime_power(8), "8 is prime power (2^3)"
assert_ok is_prime_power(9), "9 is prime power (3^2)"
assert_ok is_prime_power(27), "27 is prime power (3^3)"
assert_ok !is_prime_power(6), "6 is not (2*3)"
assert_ok !is_prime_power(10), "10 is not (2*5)"
assert_ok !is_prime_power(12), "12 is not (2^2 * 3)"

27 |> is_prime_power |> assert_ok("pipe prime power")

test_run
