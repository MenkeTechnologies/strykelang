#!/usr/bin/env stryke
# Rosetta Code: Determine if a string is numeric

fn Rosetta::IsNumeric::check($s) {
    # Simple check for integer or decimal
    $s =~ /^-?\d+(\.\d+)?$/
}

assert_ok Rosetta::IsNumeric::check("123"), "123 is numeric"
assert_ok Rosetta::IsNumeric::check("-123.456"), "-123.456 is numeric"
assert_ok !Rosetta::IsNumeric::check("abc"), "abc is not"
assert_ok !Rosetta::IsNumeric::check("12.34.56"), "12.34.56 is not"

"42" |> Rosetta::IsNumeric::check |> assert_ok("pipe numeric")

test_run
