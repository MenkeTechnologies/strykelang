#!/usr/bin/env stryke
# Rosetta Code: Number reversal game

fn Rosetta::NumberReversal::solve(@items) {
    val $start = join("", @items)
    
    val @target_arr = sort { _ <=> _1 } @items
    val $target = join("", @target_arr)
    
    return 0 if $start eq $target
    
    var @queue = ( { state => $start, moves => 0 } )
    var %visited
    $visited{$start} = 1
    
    var $head = 0
    while ($head < len(@queue)) {
        val $curr = $queue[$head]
        $head++
        
        val $state = $curr->{state}
        val $moves = $curr->{moves}
        
        for val $i (2 .. length($state)) {
            val $prefix = substr($state, 0, $i)
            val $suffix = substr($state, $i)
            
            # Reverse prefix
            var @p_chars = split("", $prefix)
            var @p_rev
            for val $c (@p_chars) { unshift @p_rev, $c }
            
            val $next_state = join("", @p_rev) . $suffix
            
            if ($next_state eq $target) {
                return $moves + 1
            }
            
            if (!exists $visited{$next_state}) {
                $visited{$next_state} = 1
                push @queue, { state => $next_state, moves => $moves + 1 }
            }
        }
    }
    return -1
}

# Test with a small list
val @jumbled = (2, 1, 4, 3, 5)
val $moves = Rosetta::NumberReversal::solve(@jumbled)

assert_ok $moves > 0, "Found a solution in $moves moves"

# Another test
val @jumbled2 = (5, 4, 3, 2, 1)
val $moves2 = Rosetta::NumberReversal::solve(@jumbled2)
assert_eq $moves2, 1, "Reversing all takes 1 move"

# Test 3
val @jumbled3 = (3, 1, 2)
# target 1, 2, 3
# 3 1 2 -> rev 2 -> 1 3 2 -> rev 3 -> 2 3 1 -> rev 2 -> 3 2 1 -> rev 3 -> 1 2 3 (Wait, 3 1 2 -> rev 3 -> 2 1 3 -> rev 2 -> 1 2 3 = 2 moves)
val $moves3 = Rosetta::NumberReversal::solve(@jumbled3)
assert_eq $moves3, 2, "3 1 2 takes 2 moves"

test_run
