#!/usr/bin/env stryke
# Rosetta Code: Permutations - Derangements

fn Rosetta::Derangements::perms(@list) {
    if (len(@list) <= 1) { return [\@list] }
    var @res
    for val $i (0..len(@list)-1) {
        var @rest = @list
        val $item = splice(@rest, $i, 1)
        val $sub_ref = Rosetta::Derangements::perms(@rest)
        for val $s (@$sub_ref) {
            push @res, [$item, @$s]
        }
    }
    \@res
}

fn Rosetta::Derangements::solve($n) {
    val @items = (0:$n-1)
    val $all = Rosetta::Derangements::perms(@items)
    var @res
    for val $p (@$all) {
        var $ok = 1
        for val $i (0:$n-1) {
            if ($p->[$i] == $i) { $ok = 0; last }
        }
        if ($ok) { push @res, $p }
    }
    \@res
}

val $d3 = Rosetta::Derangements::solve(3)
assert_eq len(@$d3), 2, "derangements(3) count"

val $d4 = Rosetta::Derangements::solve(4)
assert_eq len(@$d4), 9, "derangements(4) count"

test_run
