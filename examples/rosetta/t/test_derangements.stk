#!/usr/bin/env stryke
# Rosetta Code: Permutations - Derangements

fn Rosetta::Derangements::perms(@list) {
    if (scalar(@list) <= 1) { return [\@list] }
    my @res
    for my $i (0..scalar(@list)-1) {
        my @rest = @list
        my $item = splice(@rest, $i, 1)
        my $sub_ref = Rosetta::Derangements::perms(@rest)
        for my $s (@$sub_ref) {
            push @res, [$item, @$s]
        }
    }
    \@res
}

fn Rosetta::Derangements::solve($n) {
    my @items = (0..$n-1)
    my $all = Rosetta::Derangements::perms(@items)
    my @res
    for my $p (@$all) {
        my $ok = 1
        for my $i (0..$n-1) {
            if ($p->[$i] == $i) { $ok = 0; last }
        }
        if ($ok) { push @res, $p }
    }
    \@res
}

my $d3 = Rosetta::Derangements::solve(3)
assert_eq scalar(@$d3), 2, "derangements(3) count"

my $d4 = Rosetta::Derangements::solve(4)
assert_eq scalar(@$d4), 9, "derangements(4) count"

test_run
