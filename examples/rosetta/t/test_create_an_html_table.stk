#!/usr/bin/env stryke
# Rosetta Code: Create an HTML table

fn Rosetta::HtmlTable::create(@data) {
    my $html = "<table>\n"
    $html .= "  <thead><tr><th>X</th><th>Y</th></tr></thead>\n"
    $html .= "  <tbody>\n"
    for my $row (@data) {
        $html .= "    <tr><td>" . $row->[0] . "</td><td>" . $row->[1] . "</td></tr>\n"
    }
    $html .= "  </tbody>\n"
    $html .= "</table>"
    $html
}

my @data = ([1, 2], [3, 4], [5, 6])
my $html = Rosetta::HtmlTable::create(@data)
assert_eq index($html, "<tr><td>3</td><td>4</td></tr>") != -1, 1, "Contains row"

test_run
