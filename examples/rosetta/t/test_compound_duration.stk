#!/usr/bin/env stryke
# Rosetta Code: Compound Duration

fn Rosetta::CompoundDuration::fmt($seconds) {
    my $curr_s = $seconds
    my $d = int($curr_s / 86400)
    $curr_s = $curr_s % 86400
    my $h = int($curr_s / 3600)
    $curr_s = $curr_s % 3600
    my $m = int($curr_s / 60)
    $curr_s = $curr_s % 60
    
    my @parts
    if ($d > 0) { push @parts, "$d d" }
    if ($h > 0) { push @parts, "$h hr" }
    if ($m > 0) { push @parts, "$m min" }
    if ($curr_s > 0) { push @parts, "$curr_s sec" }
    
    if (len(@parts) == 0) { return "0 sec" }
    join(", ", @parts)
}

assert_eq Rosetta::CompoundDuration::fmt(7259), "2 hr, 59 sec", "duration 7259s"
assert_eq Rosetta::CompoundDuration::fmt(86400 + 3600 + 60 + 1), "1 d, 1 hr, 1 min, 1 sec", "all units"

# Builtin check (if signature is similar)
assert_ok length(format_duration(3600)) > 0, "builtin format_duration"

test_run
