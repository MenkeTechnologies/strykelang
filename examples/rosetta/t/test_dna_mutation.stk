#!/usr/bin/env stryke
# Rosetta Code: Bioinformatics/Sequence mutator

fn Rosetta::DNAMutation::mutate($dna, $prob) {
    val @bases = ("A", "C", "G", "T")
    var @seq = ~> $dna chars
    for val $i (0..len(@seq)-1) {
        if (rand() < $prob) {
            val $new_base = $bases[int(rand(4))]
            $seq[$i] = $new_base
        }
    }
    join("", @seq)
}

val $dna = "AAAAA"
val $mutated = Rosetta::DNAMutation::mutate($dna, 0.5)
assert_eq len($mutated), 5, "Length preserved"
assert_ok $mutated =~ /^[ACGT]+$/, "Only valid bases"

test_run
