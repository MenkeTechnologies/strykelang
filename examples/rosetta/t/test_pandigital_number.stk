#!/usr/bin/env stryke
# Rosetta Code: Pandigital number

fn is_pandigital($n) {
    my $s = "$n"
    my %digits
    my @c = chars($s)
    for my $d (@c) {
        if ($d =~ /[0-9]/) { $digits{$d} = 1 }
    }
    scalar(keys %digits) == 10
}

assert_ok is_pandigital(1023456789), "1023456789 is pandigital"
assert_ok is_pandigital(1234567890), "1234567890 is pandigital"
assert_ok !is_pandigital(123456789), "123456789 is not (missing 0)"
assert_ok !is_pandigital(102345678), "102345678 is not (missing 9)"

1234567890 |> is_pandigital |> assert_ok("pipe pandigital")

test_run
