#!/usr/bin/env stryke
# Rosetta Code: Permutations with repetitions

fn Rosetta::PermutationsWithRep::perms_with_rep($list, $k) {
    if ($k == 0) {
        return [[]]
    }
    var @res
    val $sub = Rosetta::PermutationsWithRep::perms_with_rep($list, $k - 1)
    for val $item (@$list) {
        for val $s (@$sub) {
            val @c = ($item, @$s)
            push @res, \@c
        }
    }
    \@res
}

val @input = (1, 2)
val $res = Rosetta::PermutationsWithRep::perms_with_rep(\@input, 2)

# Expected: (1,1), (1,2), (2,1), (2,2)
assert_eq len(@$res), 4, "perms with rep count"
assert_eq join(",", @{$res->[0]}), "1,1", "perms with rep[0]"
assert_eq join(",", @{$res->[1]}), "1,2", "perms with rep[1]"
assert_eq join(",", @{$res->[2]}), "2,1", "perms with rep[2]"
assert_eq join(",", @{$res->[3]}), "2,2", "perms with rep[3]"

test_run
