#!/usr/bin/env stryke
# Rosetta Code: Perlin noise

fn Rosetta::Perlin::fade($t) {
    $t * $t * $t * ($t * ($t * 6 - 15) + 10)
}

fn Rosetta::Perlin::lerp($a, $b, $t) {
    $a + (($b - $a) * $t)
}

fn Rosetta::Perlin::grad($hash, $x) {
    ($hash % 2 == 0 ? 1 : -1) * $x
}

fn Rosetta::Perlin::noise1d($x) {
    val @perm = (151, 160)
    val $x0 = int($x)
    val $xf = $x - $x0
    val $u = Rosetta::Perlin::fade($xf)
    val $g0 = Rosetta::Perlin::grad($perm[$x0 % 2], $xf)
    val $g1 = Rosetta::Perlin::grad($perm[($x0 + 1) % 2], $xf - 1)
    Rosetta::Perlin::lerp($g0, $g1, $u)
}

val $n0 = Rosetta::Perlin::noise1d(0.25)
val $n1 = Rosetta::Perlin::noise1d(0.75)

assert_eq int($n0 * 1000), -301, "first sample is stable"
assert_eq int($n1 * 1000), -301, "second sample is stable"

test_run
