#!/usr/bin/env stryke
# Rosetta Code: Pancake Sort

fn Rosetta::PancakeSort::flip {
    var @arr = @$_
    val @sub = @arr[0:_1]
    val @flipped = ~> @sub rev
    for val $i (0:_1) {
        $arr[$i] = $flipped[$i]
    }
    \@arr
}

fn Rosetta::PancakeSort::pancake_sort {
    var @arr = @$_
    val $n = len(@arr)
    
    if ($n < 2) {
        return \@arr
    }
    
    for val $curr (~> (1:$n) rev) {
        # find index of max in 0..$curr-1
        var $max_idx = 0
        for val $i (1:$curr-1) {
            if ($arr[$i] > $arr[$max_idx]) {
                $max_idx = $i
            }
        }
        
        if ($max_idx != $curr - 1) {
            if ($max_idx != 0) {
                val $res = Rosetta::PancakeSort::flip([@arr], $max_idx)
                @arr = @$res
            }
            val $res2 = Rosetta::PancakeSort::flip([@arr], $curr - 1)
            @arr = @$res2
        }
    }
    \@arr
}

val $data = [6, 7, 2, 1, 8, 9, 5, 3, 4]
val $sorted = Rosetta::PancakeSort::pancake_sort($data)
assert_eq join(",", @$sorted), "1,2,3,4,5,6,7,8,9", "pancake sort"

val $small = [3, 1, 2]
val $sorted_small = Rosetta::PancakeSort::pancake_sort($small)
assert_eq join(",", @$sorted_small), "1,2,3", "pancake sort small"

test_run
