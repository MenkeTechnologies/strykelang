#!/usr/bin/env stryke
# Rosetta Code: Johnson's algorithm

fn Rosetta::Johnson::bellman_ford($nodes, $edges, $source) {
    var %dist
    for val $n (@$nodes) { $dist{$n} = 1e15 }
    $dist{$source} = 0

    for val $iter (1 .. len(@$nodes) - 1) {
        for val $e (@$edges) {
            var ($u, $v, $w) = @$e
            if ($dist{$u} < 1e15 && $dist{$u} + $w < $dist{$v}) {
                $dist{$v} = $dist{$u} + $w
            }
        }
    }

    for val $e (@$edges) {
        var ($u, $v, $w) = @$e
        return undef if $dist{$u} < 1e15 && $dist{$u} + $w < $dist{$v}
    }
    \%dist
}

fn Rosetta::Johnson::dijkstra($graph, $start) {
    var %dist
    var @q = keys %$graph
    for val $n (@q) { $dist{$n} = 1e15 }
    $dist{$start} = 0

    while (len(@q) > 0) {
        var $best = 0
        for val $i (1 .. len(@q) - 1) {
            $best = $i if $dist{$q[$i]} < $dist{$q[$best]}
        }
        val $u = splice(@q, $best, 1)
        last if $dist{$u} >= 1e15
        for val $edge (@{$graph->{$u}}) {
            var ($v, $w) = @$edge
            val $alt = $dist{$u} + $w
            $dist{$v} = $alt if $alt < $dist{$v}
        }
    }
    \%dist
}

fn Rosetta::Johnson::solve($nodes, $edges) {
    val @aug_nodes = (@$nodes, "__q")
    var @aug_edges = @$edges
    for val $n (@$nodes) { push @aug_edges, ["__q", $n, 0] }

    val $h = Rosetta::Johnson::bellman_ford(\@aug_nodes, \@aug_edges, "__q")
    return undef if !defined $h

    var $graph = {}
    for val $n (@$nodes) { $graph->{$n} = [] }
    for val $e (@$edges) {
        val ($u, $v, $w) = @$e
        push @{$graph->{$u}}, [$v, $w + $h->{$u} - $h->{$v}]
    }

    var $all = {}
    for val $u (@$nodes) {
        val $d = Rosetta::Johnson::dijkstra($graph, $u)
        var $row = {}
        for val $v (@$nodes) {
            $row->{$v} = $d->{$v} >= 1e15 ? 1e15 : $d->{$v} - $h->{$u} + $h->{$v}
        }
        $all->{$u} = $row
    }
    $all
}

val @nodes = qw(a b c d)
val @edges = (
    ["a", "b", 1],
    ["a", "c", 4],
    ["b", "c", -2],
    ["b", "d", 2],
    ["c", "d", 3],
    ["d", "b", 1],
)

val $dist = Rosetta::Johnson::solve(\@nodes, \@edges)

assert_eq $dist->{a}{a}, 0, "distance a->a"
assert_eq $dist->{a}{c}, -1, "distance a->c"
assert_eq $dist->{a}{d}, 2, "distance a->d"
assert_eq $dist->{d}{c}, -1, "distance d->c"

test_run
