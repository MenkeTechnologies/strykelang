#!/usr/bin/env stryke
# Rosetta Code: LZW Compression

fn Rosetta::LZW::encode($text) {
    var %dict
    for val $i (0:255) { $dict{chr($i)} = $i }
    
    val @chars = $text |> chars
    var @result
    var $w = ""
    var $dict_size = 256
    
    for val $c (@chars) {
        val $wc = $w . $c
        if (exists $dict{$wc}) {
            $w = $wc
        } else {
            push @result, $dict{$w}
            $dict{$wc} = $dict_size
            $dict_size = $dict_size + 1
            $w = $c
        }
    }
    if ($w ne "") { push @result, $dict{$w} }
    \@result
}

fn Rosetta::LZW::decode($codes_ref) {
    var @codes = @$codes_ref
    var %dict
    for val $i (0:255) { $dict{$i} = chr($i) }
    
    var $dict_size = 256
    var $w = $dict{shift @codes}
    var $result = $w
    
    for val $k (@codes) {
        var $entry = ""
        if (exists $dict{$k}) {
            $entry = $dict{$k}
        } elsif ($k == $dict_size) {
            $entry = $w . substr($w, 0, 1)
        }
        
        $result = $result . $entry
        $dict{$dict_size} = $w . substr($entry, 0, 1)
        $dict_size = $dict_size + 1
        $w = $entry
    }
    $result
}

val $input = "TOBEORNOTTOBEORTOBEORNOT"
val $encoded = Rosetta::LZW::encode($input)
assert_eq join(",", @$encoded), "84,79,66,69,79,82,78,79,84,256,258,260,265,259,261,263", "LZW encode"

val $decoded = Rosetta::LZW::decode($encoded)
assert_eq $decoded, $input, "LZW decode"

test_run
