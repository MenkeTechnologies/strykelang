#!/usr/bin/env stryke
# Rosetta Code: Colour pinstripe/Printer

fn Rosetta::ColourPinstripe::palette() { qw(K R G B M C Y W) }

fn Rosetta::ColourPinstripe::row($width, $stripe_w) {
    my @colors = Rosetta::ColourPinstripe::palette()
    my $line = ""
    my $i = 0
    while (len($line) < $width) {
        $line .= $colors[$i % len(@colors)] x $stripe_w
        $i++
    }
    substr($line, 0, $width)
}

fn Rosetta::ColourPinstripe::render($width, $max_w) {
    my @rows = ~> 1:$max_w map { Rosetta::ColourPinstripe::row($width, _) }
    \@rows
}

my $rows = Rosetta::ColourPinstripe::render(32, 4)

assert_eq len(@$rows), 4, "four stripe widths rendered"
assert_eq substr($rows->[0], 0, 8), "KRGBMCYW", "1-point pattern cycles palette"
assert_eq substr($rows->[1], 0, 16), "KKRRGGBBMMCCYYWW", "2-point pattern widens stripes"
assert_eq len($rows->[3]), 32, "rows span printer width"

test_run
