#!/usr/bin/env stryke
# Rosetta Code: Natural sort — split strings into alternating non-digit and
# digit chunks, compare digit chunks numerically. So "img2" < "img10".

fn Rosetta::NatSort::tokens($s) {
    var @parts
    var $cur = ""
    var $is_digit = 0
    for val $c ($s |> chars) {
        val $cd = ($c =~ /\d/) ? 1 : 0
        if (len($cur) > 0 && $cd != $is_digit) {
            push @parts, $is_digit ? [$cur + 0, "n"] : [$cur, "s"]
            $cur = ""
        }
        $cur .= $c
        $is_digit = $cd
    }
    push @parts, $is_digit ? [$cur + 0, "n"] : [$cur, "s"] if len($cur) > 0
    \@parts
}

fn Rosetta::NatSort::compare(_0, _1) {
    val $ta = Rosetta::NatSort::tokens(_0)
    val $tb = Rosetta::NatSort::tokens(_1)
    val $len = len(@$ta) < len(@$tb) ? len(@$ta) : len(@$tb)
    for val $i (0:$len - 1) {
        val ($va, $ka) = ($ta->[$i][0], $ta->[$i][1])
        val ($vb, $kb) = ($tb->[$i][0], $tb->[$i][1])
        if ($ka eq "n" && $kb eq "n") {
            return -1 if $va < $vb
            return 1 if $va > $vb
        } else {
            val $c = $va cmp $vb
            return $c if $c != 0
        }
    }
    len(@$ta) <=> len(@$tb)
}

fn Rosetta::NatSort::sort(@xs) {
    sort { Rosetta::NatSort::compare(_0, _1) } @xs
}

# Canonical Rosetta example: ["img12", "img10", "img2", "img1"] → img1, img2, img10, img12.
val @sorted = Rosetta::NatSort::sort("img12", "img10", "img2", "img1")
assert_eq join(",", @sorted), "img1,img2,img10,img12", "image filenames"

# Lexicographic sort would give a different (wrong) order:
val @lex = sort qw(img12 img10 img2 img1)
assert_eq join(",", @lex), "img1,img10,img12,img2", "lex sort differs"

# Pure-numeric strings sort numerically.
val @nums = Rosetta::NatSort::sort("100", "9", "21", "5")
assert_eq join(",", @nums), "5,9,21,100", "numeric strings"

# Mixed: prefix changes win over digit value.
val @mix = Rosetta::NatSort::sort("v1.10", "v1.2", "v1.9", "v2.0")
assert_eq join(",", @mix), "v1.2,v1.9,v1.10,v2.0", "version-like strings"

test_run
