#!/usr/bin/env stryke
# Rosetta Code: Jewels and Stones

fn Rosetta::JewelsAndStones::count($jewels, $stones) {
    var %j_map
    var @j_chars = chars($jewels)
    for val $j (@j_chars) { $j_map{$j} = 1 }
    
    var $count = 0
    var @s_chars = chars($stones)
    for val $s (@s_chars) {
        if (exists $j_map{$s}) { $count++ }
    }
    $count
}

assert_eq Rosetta::JewelsAndStones::count("aA", "aAAbbbb"), 3, "2 jewels in stones"
assert_eq Rosetta::JewelsAndStones::count("z", "ZZ"), 0, "no jewels (case sensitive)"

# Chaining
"aA" |> Rosetta::JewelsAndStones::count("aAAbbbb") |> assert_eq(3, "pipe jewels")

test_run
