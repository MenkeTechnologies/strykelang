#!/usr/bin/env stryke
# Rosetta Code: Vampire number

fn Rosetta::Vampire::sort_digits($n) {
    ~> $n chars sort join("")
}

fn Rosetta::Vampire::check($n) {
    val $s = sprintf("%d", $n)
    val $len = len($s)
    if ($len % 2 != 0) {
        0
    } else {
        val $target = Rosetta::Vampire::sort_digits($n)
        var $found = 0
        val $half = $len / 2
        val $start = 10**($half - 1)
        val $end = 10**$half - 1
        
        for val $a ($start:$end) {
            if ($n % $a == 0) {
                val $b = $n / $a
                if ($b >= $start && $b <= $end) {
                    if (!($a % 10 == 0 && $b % 10 == 0)) {
                        if (Rosetta::Vampire::sort_digits($a . $b) eq $target) {
                            $found = 1
                        }
                    }
                }
            }
        }
        $found
    }
}

assert_ok Rosetta::Vampire::check(1260), "1260 is vampire (21 * 60)"
assert_ok Rosetta::Vampire::check(1395), "1395 is vampire (15 * 93)"
assert_ok !Rosetta::Vampire::check(1000), "1000 is not vampire"

1260 |> Rosetta::Vampire::check |> assert_ok("pipe vampire check")

test_run
