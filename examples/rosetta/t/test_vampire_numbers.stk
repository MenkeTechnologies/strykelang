#!/usr/bin/env stryke
# Rosetta Code: Vampire number

fn sort_digits($n) {
    ~> $n chars sort join("")
}

fn is_vampire($n) {
    my $s = sprintf("%d", $n)
    my $len = length($s)
    if ($len % 2 != 0) {
        0
    } else {
        my $target = sort_digits($n)
        my $found = 0
        my $half = $len / 2
        my $start = 10**($half - 1)
        my $end = 10**$half - 1
        
        for my $a ($start..$end) {
            if ($n % $a == 0) {
                my $b = $n / $a
                if ($b >= $start && $b <= $end) {
                    if (!($a % 10 == 0 && $b % 10 == 0)) {
                        if (sort_digits($a . $b) eq $target) {
                            $found = 1
                        }
                    }
                }
            }
        }
        $found
    }
}

assert_ok is_vampire(1260), "1260 is vampire (21 * 60)"
assert_ok is_vampire(1395), "1395 is vampire (15 * 93)"
assert_ok !is_vampire(1000), "1000 is not vampire"

1260 |> is_vampire |> assert_ok("pipe vampire check")

test_run
