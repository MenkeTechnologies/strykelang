#!/usr/bin/env stryke
# Rosetta Code: Eban numbers — when spelled in English, no letter 'e'.
# Eban set under 1000 is exactly: {2,4,6,30,32,34,36,40,42,44,46,50,52,54,56,60,62,64,66}.

fn Rosetta::Eban::spell($n) {
    return "zero" if $n == 0
    my @units = ("", "one", "two", "three", "four", "five",
                 "six", "seven", "eight", "nine",
                 "ten", "eleven", "twelve", "thirteen", "fourteen",
                 "fifteen", "sixteen", "seventeen", "eighteen", "nineteen")
    my @tens  = ("", "", "twenty", "thirty", "forty", "fifty",
                 "sixty", "seventy", "eighty", "ninety")
    my $name = ""
    my $x = $n
    if ($x >= 1000) {
        $name .= $units[int($x / 1000)] . "thousand"
        $x %= 1000
    }
    if ($x >= 100) {
        $name .= $units[int($x / 100)] . "hundred"
        $x %= 100
    }
    if ($x >= 20) {
        $name .= $tens[int($x / 10)]
        $x %= 10
        $name .= $units[$x] if $x > 0
    } elsif ($x > 0) {
        $name .= $units[$x]
    }
    $name
}

fn Rosetta::Eban::is_eban($n) {
    Rosetta::Eban::spell($n) !~ /e/
}

fn Rosetta::Eban::list($lo, $hi) {
    $lo:$hi |> grep { Rosetta::Eban::is_eban($_) }
}

my @under_100 = Rosetta::Eban::list(1, 99)
assert_eq join(",", @under_100),
    "2,4,6,30,32,34,36,40,42,44,46,50,52,54,56,60,62,64,66",
    "eban numbers under 100"

my @under_1000 = Rosetta::Eban::list(1, 999)
# Same set as under 100 — there are NO eban numbers in [100..999] because every
# hundreds-name contains "hundred", which contains 'e'.
assert_eq scalar(@under_1000), 19, "still 19 eban numbers under 1000"

assert_ok Rosetta::Eban::is_eban(2),  "2 is eban"
assert_ok Rosetta::Eban::is_eban(66), "66 is eban"
assert_ok !Rosetta::Eban::is_eban(1), "1 (one) contains 'e'"
assert_ok !Rosetta::Eban::is_eban(7), "7 (seven) contains 'e'"
assert_ok !Rosetta::Eban::is_eban(100), "100 (hundred) contains 'e'"

test_run
