#!/usr/bin/env stryke
# Rosetta Code: Ethiopian multiplication

fn Rosetta::EthiopianMult::is_even($n) { $n % 2 == 0 }

fn Rosetta::EthiopianMult::solve($a, $b) {
    my $curr_a = $a
    my $curr_b = $b
    my $sum = 0
    while ($curr_a >= 1) {
        if (!Rosetta::EthiopianMult::is_even($curr_a)) {
            $sum += $curr_b
        }
        $curr_a = int($curr_a / 2)
        $curr_b *= 2
    }
    $sum
}

assert_eq Rosetta::EthiopianMult::solve(17, 34), 578, "17 * 34"
assert_eq Rosetta::EthiopianMult::solve(25, 12), 300, "25 * 12"

test_run
