#!/usr/bin/env stryke
# Rosetta Code: Balanced primes

fn Rosetta::BalancedPrimes::prev_prime($n) {
    my $p = $n - 1
    while ($p > 1) {
        if (is_prime($p)) { return $p }
        $p--
    }
    0
}

fn Rosetta::BalancedPrimes::next_prime($n) {
    my $p = $n + 1
    while (1) {
        if (is_prime($p)) { return $p }
        $p++
    }
}

fn Rosetta::BalancedPrimes::check($n) {
    if (!is_prime($n)) {
        0
    } else {
        my $prev = Rosetta::BalancedPrimes::prev_prime($n)
        if ($prev == 0) {
            0
        } else {
            my $next = Rosetta::BalancedPrimes::next_prime($n)
            $n * 2 == $prev + $next
        }
    }
}

assert_ok Rosetta::BalancedPrimes::check(5), "5 is balanced (3, 5, 7 gaps 2,2)"
assert_ok Rosetta::BalancedPrimes::check(53), "53 is balanced (47, 53, 59 gaps 6,6)"
assert_ok !Rosetta::BalancedPrimes::check(7), "7 is not (5, 7, 11 gaps 2,4)"

5 |> Rosetta::BalancedPrimes::check |> assert_ok("pipe balanced prime")

test_run
