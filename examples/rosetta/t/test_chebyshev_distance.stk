#!/usr/bin/env stryke
# Rosetta Code: Chebyshev (L-infinity) distance — chess king metric

fn Rosetta::Chebyshev::distance($u, $v) {
    my $n = len(@$u)
    my $best = 0
    for my $i (0..$n-1) {
        my $d = abs($u->[$i] - $v->[$i])
        $best = $d if $d > $best
    }
    $best
}

# Pure 2-D
assert_eq Rosetta::Chebyshev::distance([0,0], [3,4]), 4, "(0,0)->(3,4) = max(3,4) = 4"
assert_eq Rosetta::Chebyshev::distance([1,1], [1,1]), 0, "self distance = 0"
assert_eq Rosetta::Chebyshev::distance([-2, 5], [3, -1]), 6, "negatives -> 6"

# Higher dimensions
assert_eq Rosetta::Chebyshev::distance([1,2,3,4], [5,3,7,4]), 4, "4-D max diff = 4"
assert_eq Rosetta::Chebyshev::distance([0,0,0,0,0], [-3,1,2,-7,4]), 7, "5-D max abs = 7"

# 1-D collapses to abs diff
assert_eq Rosetta::Chebyshev::distance([10], [3]), 7, "1-D = |10-3|"

# Chess king from a1 to h8 = 7 moves
assert_eq Rosetta::Chebyshev::distance([0,0], [7,7]), 7, "king a1->h8 = 7 moves"
assert_eq Rosetta::Chebyshev::distance([0,0], [7,0]), 7, "king a1->h1 = 7 moves"

# Pipe form
[0, 0] |> Rosetta::Chebyshev::distance([5, 12]) |> assert_eq(12, "pipe (0,0)->(5,12) = 12")

test_run
