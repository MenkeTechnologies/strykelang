#!/usr/bin/env stryke
# Rosetta Code: Proper Divisors

fn Rosetta::ProperDivisors::get($n) {
    if ($n < 2) {
        ([])
    } else {
        val $limit = int($n / 2)
        val @divs = ~> 1:$limit grep { $n % _ == 0 }
        \@divs
    }
}

# sum of proper divisors
fn Rosetta::ProperDivisors::sum($n) {
    val $divs = Rosetta::ProperDivisors::get($n)
    if (len(@$divs) == 0) { return 0 }
    ~> @$divs reduce { _0 + _1 }
}

val $d6 = Rosetta::ProperDivisors::get(6)
assert_eq join(",", @$d6), "1,2,3", "proper divisors 6"

val $d10 = Rosetta::ProperDivisors::get(10)
assert_eq join(",", @$d10), "1,2,5", "proper divisors 10"

assert_eq Rosetta::ProperDivisors::sum(6), 6, "sum proper divisors 6"
assert_eq Rosetta::ProperDivisors::sum(12), 16, "sum proper divisors 12"

test_run
