#!/usr/bin/env stryke
# Rosetta Code: Longest Common Subsequence

fn lcs($a, $b) {
    my @a = $a |> split //
    my @b = $b |> split //
    my $m = scalar(@a)
    my $n = scalar(@b)
    
    my @dp
    for my $i (0..$m) {
        my @row
        push @row, 0 for 0..$n
        push @dp, \@row
    }
    
    for my $i (1..$m) {
        for my $j (1..$n) {
            if ($a[$i-1] eq $b[$j-1]) {
                $dp[$i][$j] = $dp[$i-1][$j-1] + 1
            } else {
                $dp[$i][$j] = $dp[$i-1][$j] > $dp[$i][$j-1] ? $dp[$i-1][$j] : $dp[$i][$j-1]
            }
        }
    }
    
    my $result = ""
    my ($i, $j) = ($m, $n)
    while ($i > 0 && $j > 0) {
        if ($a[$i-1] eq $b[$j-1]) {
            $result = $a[$i-1] . $result
            $i--
            $j--
        } elsif ($dp[$i-1][$j] > $dp[$i][$j-1]) {
            $i--
        } else {
            $j--
        }
    }
    $result
}

assert_eq lcs("AGCAT", "GAC"), "GAC", "lcs AGCAT/GAC"
assert_eq lcs("XMJYAUZ", "MZJAWXU"), "MJAU", "lcs longer"
assert_eq lcs("", "ABC"), "", "lcs with empty"
assert_eq lcs("ABC", "ABC"), "ABC", "lcs identical"
assert_eq lcs("ABC", "DEF"), "", "lcs no common"

test_run
