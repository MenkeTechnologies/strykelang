#!/usr/bin/env stryke
# Rosetta Code: Longest common subsequence

fn Rosetta::LCS::compute($s1, $s2) {
    if (length($s1) == 0 || length($s2) == 0) {
        ""
    } else {
        my $c1 = substr($s1, 0, 1)
        my $c2 = substr($s2, 0, 1)
        if ($c1 eq $c2) {
            my $rest = Rosetta::LCS::compute(substr($s1, 1), substr($s2, 1))
            $c1 . $rest
        } else {
            my $res1 = Rosetta::LCS::compute(substr($s1, 1), $s2)
            my $res2 = Rosetta::LCS::compute($s1, substr($s2, 1))
            length($res1) > length($res2) ? $res1 : $res2
        }
    }
}

assert_eq Rosetta::LCS::compute("1234", "1224533324"), "1234", "LCS(1234, 1224533324)"
assert_eq Rosetta::LCS::compute("thisisatest", "testing123testing"), "tsitest", "LCS(thisisatest, testing123testing)"

"abcde" |> Rosetta::LCS::compute("ace") |> assert_eq("ace", "pipe LCS")

test_run
