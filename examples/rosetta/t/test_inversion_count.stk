#!/usr/bin/env stryke
# Rosetta Code: Count inversions in an array — pairs (i, j) with i < j
# but arr[i] > arr[j]. O(n log n) via merge sort: each merge step
# counts how many later elements were dragged past current ones.

fn Rosetta::Inv::merge_count($arr, $aux, $lo, $mid, $hi) {
    for val $k ($lo:$hi) { $aux->[$k] = $arr->[$k] }
    var ($i, $j, $k) = ($lo, $mid + 1, $lo)
    var $count = 0
    while ($i <= $mid && $j <= $hi) {
        if ($aux->[$i] <= $aux->[$j]) {
            $arr->[$k++] = $aux->[$i++]
        } else {
            $arr->[$k++] = $aux->[$j++]
            $count += $mid - $i + 1
        }
    }
    while ($i <= $mid) { $arr->[$k++] = $aux->[$i++] }
    while ($j <= $hi)  { $arr->[$k++] = $aux->[$j++] }
    $count
}

fn Rosetta::Inv::sort_count($arr, $aux, $lo, $hi) {
    return 0 if $lo >= $hi
    val $mid = int(($lo + $hi) / 2)
    val $left  = Rosetta::Inv::sort_count($arr, $aux, $lo, $mid)
    val $right = Rosetta::Inv::sort_count($arr, $aux, $mid + 1, $hi)
    val $merge = Rosetta::Inv::merge_count($arr, $aux, $lo, $mid, $hi)
    $left + $right + $merge
}

fn Rosetta::Inv::count($input) {
    val @arr = @$input
    val $n = len(@arr)
    return 0 if $n < 2
    val @aux = ~> 1:$n |> map { 0 }
    Rosetta::Inv::sort_count(\@arr, \@aux, 0, $n - 1)
}

fn Rosetta::Inv::naive($input) {
    val $n = len(@$input)
    var $count = 0
    for val $i (~> 0:$n - 2) {
        for val $j ($i + 1:$n - 1) {
            $count++ if $input->[$i] > $input->[$j]
        }
    }
    $count
}

# Sorted ascending: 0 inversions.
assert_eq Rosetta::Inv::count([1, 2, 3, 4, 5]), 0, "ascending = 0"

# Sorted descending: max inversions n*(n-1)/2 = 10 for n=5.
assert_eq Rosetta::Inv::count([5, 4, 3, 2, 1]), 10, "descending n*(n-1)/2"

# Empty / single
assert_eq Rosetta::Inv::count([]), 0, "empty = 0"
assert_eq Rosetta::Inv::count([42]), 0, "single = 0"

# Hand-checked
assert_eq Rosetta::Inv::count([2, 4, 1, 3, 5]), 3, "[2,4,1,3,5] = 3"
assert_eq Rosetta::Inv::count([1, 3, 5, 2, 4, 6]), 3, "[1,3,5,2,4,6] = 3"

# Equal elements: not inversions.
assert_eq Rosetta::Inv::count([2, 2, 2, 2]), 0, "all equal = 0"

# Cross-check vs naive on random-ish input.
srand(11)
for val $n (5, 10, 20, 50) {
    var @arr
    for (~> 1:$n) { push @arr, int(rand() * 100) }
    assert_eq Rosetta::Inv::count(\@arr), Rosetta::Inv::naive(\@arr),
        "merge = naive on n=$n"
}

# Original input must not be mutated.
val @orig = (4, 2, 7, 1, 3)
val @copy = @orig
Rosetta::Inv::count(\@copy)
assert_eq join(",", @copy), join(",", @orig), "input is preserved"

# Large input — no inversions when already sorted.
val @big = ~> 1:1000
assert_eq Rosetta::Inv::count(\@big), 0, "1:1000 sorted = 0"

# Reverse 1..100 — n*(n-1)/2 = 4950
val @rev_100 = rev @big[0:99]
assert_eq Rosetta::Inv::count(\@rev_100), 4950, "reverse 100 = 4950"

test_run
