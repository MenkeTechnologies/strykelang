#!/usr/bin/env stryke
# Rosetta Code: Balanced brackets

fn are_balanced($s) {
    my $count = 0
    my $balanced = 1
    my @chars = chars($s)
    for my $c (@chars) {
        if ($c eq "[") {
            $count++
        } elsif ($c eq "]") {
            $count--
            if ($count < 0) { $balanced = 0 }
        }
    }
    if ($count != 0) { $balanced = 0 }
    $balanced
}

assert_ok are_balanced(""), "empty is balanced"
assert_ok are_balanced("[]"), "[] is balanced"
assert_ok are_balanced("[[][]]"), "[[ ] []] is balanced"
assert_ok !are_balanced("["), "[ is not"
assert_ok !are_balanced("]"), "] is not"
assert_ok !are_balanced("]["), "][ is not"
assert_ok !are_balanced("[]]"), "[]] is not"

"[[[]]]" |> are_balanced |> assert_ok("pipe balanced")

test_run
