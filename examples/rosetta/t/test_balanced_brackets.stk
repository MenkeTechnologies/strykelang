#!/usr/bin/env stryke
# Rosetta Code: Balanced brackets

fn Rosetta::BalancedBrackets::check($s) {
    my $count = 0
    my $balanced = 1
    my @chars = chars($s)
    for my $c (@chars) {
        if ($c eq "[") {
            $count++
        } elsif ($c eq "]") {
            $count--
            if ($count < 0) { $balanced = 0 }
        }
    }
    if ($count != 0) { $balanced = 0 }
    $balanced
}

assert_ok Rosetta::BalancedBrackets::check(""), "empty is balanced"
assert_ok Rosetta::BalancedBrackets::check("[]"), "[] is balanced"
assert_ok Rosetta::BalancedBrackets::check("[[][]]"), "[[ ] []] is balanced"
assert_ok !Rosetta::BalancedBrackets::check("["), "[ is not"
assert_ok !Rosetta::BalancedBrackets::check("]"), "] is not"
assert_ok !Rosetta::BalancedBrackets::check("]["), "][ is not"
assert_ok !Rosetta::BalancedBrackets::check("[]]"), "[]] is not"

"[[[]]]" |> Rosetta::BalancedBrackets::check |> assert_ok("pipe balanced")

test_run
