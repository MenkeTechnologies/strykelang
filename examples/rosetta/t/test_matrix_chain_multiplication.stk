#!/usr/bin/env stryke
# Rosetta Code: Matrix chain multiplication

fn Rosetta::MatrixChain::solve($dims) {
    my $n = scalar(@$dims) - 1
    my @m
    for (my $i = 0; $i < $n; $i++) {
        my @row
        for (my $j = 0; $j < $n; $j++) {
            push @row, 0
        }
        push @m, \@row
    }
    
    for (my $len = 2; $len <= $n; $len++) {
        for (my $i = 0; $i < $n - $len + 1; $i++) {
            my $j = $i + $len - 1
            $m[$i]->[$j] = 1e18 # Infinity
            for (my $k = $i; $k < $j; $k++) {
                my $q = $m[$i]->[$k] + $m[$k+1]->[$j] + $dims->[$i] * $dims->[$k+1] * $dims->[$j+1]
                if ($q < $m[$i]->[$j]) {
                    $m[$i]->[$j] = $q
                }
            }
        }
    }
    $m[0]->[$n-1]
}

# Matrices: 10x30, 30x5, 5x60
# Dims: 10, 30, 5, 60
my @dims = (10, 30, 5, 60)
my $res = Rosetta::MatrixChain::solve(\@dims)
# (10x30x5) + (10x5x60) = 1500 + 3000 = 4500
# (30x5x60) + (10x30x60) = 9000 + 18000 = 27000
assert_eq $res, 4500, "Matrix chain multiplication cost"

my @dims2 = (10, 20, 30, 40, 30)
my $res2 = Rosetta::MatrixChain::solve(\@dims2)
assert_eq $res2, 30000, "Matrix chain multiplication cost 2"

test_run
