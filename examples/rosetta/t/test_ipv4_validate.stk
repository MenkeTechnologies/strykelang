#!/usr/bin/env stryke
# Rosetta Code: IPv4 dotted-quad validation

fn Rosetta::IPv4::valid($s) {
    return 0 unless defined $s
    return 0 if length($s) == 0
    my @parts = split(/\./, $s, -1)
    return 0 unless len(@parts) == 4
    for my $p (@parts) {
        return 0 unless length($p) > 0 && length($p) <= 3
        return 0 if $p =~ /\D/
        return 0 if $p ne "0" && $p =~ /^0/      # no leading zeros (except "0")
        my $n = int($p)
        return 0 if $n > 255
    }
    1
}

fn Rosetta::IPv4::octets($s) {
    return undef unless Rosetta::IPv4::valid($s)
    [map { int(_) } split(/\./, $s)]
}

# Valid
for my $ip ("0.0.0.0", "127.0.0.1", "192.168.1.1", "8.8.8.8",
            "255.255.255.255", "10.0.0.1", "172.16.0.1") {
    assert_ok Rosetta::IPv4::valid($ip), "$ip valid"
}

# Invalid
for my $bad ("256.1.1.1", "1.1.1.256", "1.2.3", "1.2.3.4.5",
             "1.2.3.4.", ".1.2.3.4", "01.2.3.4", "1.02.3.4",
             "abc.def.ghi.jkl", "1..2.3", "1.2.-1.4", "999.999.999.999",
             "", " ", "1 .2.3.4", "10.0.0.1 ", "2001:db8::1") {
    assert_ok !Rosetta::IPv4::valid($bad), "'$bad' invalid"
}

# Octets
my $oc = Rosetta::IPv4::octets("8.8.4.4")
assert_eq join(",", @$oc), "8,8,4,4", "octets of 8.8.4.4"

assert_ok !defined(Rosetta::IPv4::octets("999.0.0.0")), "invalid -> undef octets"

test_run
