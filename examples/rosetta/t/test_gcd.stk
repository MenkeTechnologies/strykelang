#!/usr/bin/env stryke
# Rosetta Code: Greatest Common Divisor

fn Rosetta::GCD::compute($a, $b) {
    var $aa = $a; var $bb = $b
    while ($bb != 0) {
        ($aa, $bb) = ($bb, $aa % $bb)
    }
    $aa
}

# gcd of multiple numbers
fn Rosetta::GCD::multi(@nums) {
    if (len(@nums) == 0) { return 0 }
    var $res = shift @nums
    ~> @nums ep {
        $res = Rosetta::GCD::compute($res, _)
    }
    $res
}

assert_eq Rosetta::GCD::compute(12, 18), 6, "gcd(12, 18)"
assert_eq Rosetta::GCD::compute(10, 5), 5, "gcd(10, 5)"
assert_eq Rosetta::GCD::compute(7, 13), 1, "gcd(7, 13)"
assert_eq Rosetta::GCD::multi(12, 18, 24), 6, "gcd_multi(12, 18, 24)"

# Use pipe and threading
12 |> Rosetta::GCD::compute(18) |> assert_eq(6, "pipe gcd")
val $args = [12, 18, 24]
val $res = Rosetta::GCD::multi(@$args)
assert_eq $res, 6, "manual check"

test_run
