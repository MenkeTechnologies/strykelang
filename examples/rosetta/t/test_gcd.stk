#!/usr/bin/env stryke
# Rosetta Code: Greatest Common Divisor

fn my_gcd {
    my $a = $_[0]
    my $b = $_[1]
    if ($b == 0) {
        $a
    } else {
        my_gcd($b, $a % $b)
    }
}

assert_eq my_gcd(12, 8), 4, "gcd(12, 8)"
assert_eq my_gcd(14, 7), 7, "gcd(14, 7)"
assert_eq my_gcd(13, 1), 1, "gcd(13, 1)"
assert_eq my_gcd(0, 5), 5, "gcd(0, 5)"
assert_eq my_gcd(100, 10), 10, "gcd(100, 10)"

test_run
