#!/usr/bin/env stryke
# Rosetta Code: CSV to HTML translation

fn Rosetta::CsvToHtml::convert($csv) {
    var $html = "<table>\n"
    val @lines = split "\n", $csv
    for val $line (@lines) {
        $html .= "  <tr>"
        val @cols = split ",", $line
        for val $col (@cols) {
            $html .= "<td>" . $col . "</td>"
        }
        $html .= "</tr>\n"
    }
    $html .= "</table>"
    $html
}

val $csv = "Character,Speech\n\"Theyp, theyp\",He's dead\n\"Theyp, theyp\",He's still dead"
# Simple split for the task
val $html = Rosetta::CsvToHtml::convert("A,B,C\n1,2,3")

assert_eq index($html, "<tr><td>A</td><td>B</td><td>C</td></tr>") != -1, 1, "Header row"
assert_eq index($html, "<tr><td>1</td><td>2</td><td>3</td></tr>") != -1, 1, "Data row"

test_run
