#!/usr/bin/env stryke
# Rosetta Code: Matrix rank

fn Rosetta::Matrix::rank($m) {
    my @mat = map { [ @$_ ] } @$m
    my $rows = cnt(@mat)
    return 0 if $rows == 0
    my $cols = cnt(@{$mat[0]})
    
    my $rank = 0
    my @row_selected = (0) x $rows
    
    for (my $j = 0; $j < $cols; $j++) {
        my $piv = -1
        for (my $i = 0; $i < $rows; $i++) {
            if (!$row_selected[$i] && abs($mat[$i]->[$j]) > 1e-9) {
                if ($piv == -1 || abs($mat[$i]->[$j]) > abs($mat[$piv]->[$j])) {
                    $piv = $i
                }
            }
        }
        
        if ($piv != -1) {
            $rank++
            $row_selected[$piv] = 1
            for (my $i = 0; $i < $rows; $i++) {
                if ($i != $piv && abs($mat[$i]->[$j]) > 1e-9) {
                    my $factor = $mat[$i]->[$j] / $mat[$piv]->[$j]
                    for (my $k = $j; $k < $cols; $k++) {
                        $mat[$i]->[$k] -= $factor * $mat[$piv]->[$k]
                    }
                }
            }
        }
    }
    $rank
}

my $m1 = [
    [1, 2, 1],
    [-2, -3, 1],
    [3, 5, 0]
]
# R3 = R1 - R2 -> Row 3 is dependent. Rank 2.
assert_eq Rosetta::Matrix::rank($m1), 2, "rank of 3x3 singular matrix"

my $m2 = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]
# 7,8,9 = 2*(4,5,6) - (1,2,3). Rank 2.
assert_eq Rosetta::Matrix::rank($m2), 2, "rank of 3x3 arithmetic progression matrix"

my $m3 = [
    [1, 1, 0],
    [0, 1, 1],
    [1, 0, 1]
]
# Independent. Rank 3.
assert_eq Rosetta::Matrix::rank($m3), 3, "rank of 3x3 identity-like matrix"

my $m4 = [
    [1, 2, 1, 2],
    [2, 4, 2, 4],
    [3, 6, 3, 6]
]
# All rows proportional. Rank 1.
assert_eq Rosetta::Matrix::rank($m4), 1, "rank of 3x4 matrix with proportional rows"

test_run
