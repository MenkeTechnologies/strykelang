#!/usr/bin/env stryke
# Rosetta Code: Odd word problem

fn Rosetta::OddWordProblem::reverse($s) {
    ~> $s chars rev |> join ""
}

fn Rosetta::OddWordProblem::process($s) {
    my $clean = $s =~ s/\.$//r
    my @words = split /\s+/, $clean
    my @res
    for my $i (0..scalar(@words)-1) {
        if ($i % 2 == 1) {
            push @res, Rosetta::OddWordProblem::reverse($words[$i])
        } else {
            push @res, $words[$i]
        }
    }
    join(" ", @res) . "."
}

assert_eq Rosetta::OddWordProblem::process("whats the matter with kansas."), "whats eht matter htiw kansas.", "odd word kansas"
assert_eq Rosetta::OddWordProblem::process("apple banana orange."), "apple ananab orange.", "odd word fruits"

"hello world." |> Rosetta::OddWordProblem::process |> assert_eq("hello dlrow.", "pipe odd word")

test_run
