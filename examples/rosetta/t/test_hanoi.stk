#!/usr/bin/env stryke
# Rosetta Code: Towers of Hanoi

my @MOVES

fn Rosetta::Hanoi::solve($n, $from, $to, $via) {
    if ($n > 0) {
        Rosetta::Hanoi::solve($n - 1, $from, $via, $to)
        push @MOVES, "$from->$to"
        Rosetta::Hanoi::solve($n - 1, $via, $to, $from)
    }
}

fn Rosetta::Hanoi::count_moves($n) {
    (2 ** $n) - 1
}

@MOVES = ()
Rosetta::Hanoi::solve(1, "A", "C", "B")
assert_eq len(@MOVES), 1, "1 disk = 1 move"
assert_eq $MOVES[0], "A->C", "move disk from A to C"

@MOVES = ()
Rosetta::Hanoi::solve(2, "A", "C", "B")
assert_eq len(@MOVES), 3, "2 disks = 3 moves"

@MOVES = ()
Rosetta::Hanoi::solve(3, "A", "C", "B")
assert_eq len(@MOVES), 7, "3 disks = 7 moves"
assert_eq $MOVES[0], "A->C", "first move"
assert_eq $MOVES[6], "A->C", "last move"

@MOVES = ()
Rosetta::Hanoi::solve(4, "A", "C", "B")
assert_eq len(@MOVES), 15, "4 disks = 15 moves"

assert_eq Rosetta::Hanoi::count_moves(1), 1, "formula: 1 disk"
assert_eq Rosetta::Hanoi::count_moves(3), 7, "formula: 3 disks"
assert_eq Rosetta::Hanoi::count_moves(10), 1023, "formula: 10 disks"

test_run
