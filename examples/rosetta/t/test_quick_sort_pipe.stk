#!/usr/bin/env stryke
# Rosetta Code: Quick Sort (using pipes)

fn Rosetta::QuickSort::sort(@arr) {
    if (len(@arr) <= 1) {
        return @arr
    }
    my $pivot = shift(@arr)
    my @less = @arr |> grep { $_ <= $pivot }
    my @greater = @arr |> grep { $_ > $pivot }
    
    (Rosetta::QuickSort::sort(@less), $pivot, Rosetta::QuickSort::sort(@greater))
}

my @sorted = Rosetta::QuickSort::sort(64, 34, 25, 12, 22, 11, 90)
assert_eq join(",", @sorted), "11,12,22,25,34,64,90", "quick sort"

my @single = Rosetta::QuickSort::sort(42)
assert_eq join(",", @single), "42", "single element"

my @already = Rosetta::QuickSort::sort(1, 2, 3, 4, 5)
assert_eq join(",", @already), "1,2,3,4,5", "already sorted"

my @reverse = Rosetta::QuickSort::sort(5, 4, 3, 2, 1)
assert_eq join(",", @reverse), "1,2,3,4,5", "reverse sorted"

my @dups = Rosetta::QuickSort::sort(3, 1, 4, 1, 5, 9, 2, 6)
assert_eq join(",", @dups), "1,1,2,3,4,5,6,9", "with duplicates"

test_run
