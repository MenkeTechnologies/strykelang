#!/usr/bin/env stryke
# Rosetta Code: Zeckendorf number representation

fn Rosetta::Rev::rev(@arr) {
    var @reversed
    var $i = $#arr
    while ($i >= 0) {
        push @reversed, $arr[$i]
        $i = $i - 1
    }
    @reversed
}

fn Rosetta::Zeckendorf::fib_seq_until($max) {
    var @fibs
    var ($a, $b) = (1, 2)
    while ($a <= $max) {
        push @fibs, $a
        ($a, $b) = ($b, $a + $b)
    }
    @fibs
}

fn Rosetta::Zeckendorf::zeckendorf($n) {
    if ($n == 0) {
        return ()
    }
    val @fibs = Rosetta::Rev::rev(Rosetta::Zeckendorf::fib_seq_until($n))
    var @result
    for val $fib (@fibs) {
        if ($n >= $fib) {
            push @result, $fib
            $n = $n - $fib
        }
    }
    val @rev_res = Rosetta::Rev::rev(@result)
    @rev_res
}

val @z100 = Rosetta::Zeckendorf::zeckendorf(100)
join(",", @z100) |> assert_eq("3,8,89", "Rosetta::Zeckendorf::zeckendorf(100)")

val @z20 = Rosetta::Zeckendorf::zeckendorf(20)
join(",", @z20) |> assert_eq("2,5,13", "Rosetta::Zeckendorf::zeckendorf(20)")

val @z0 = Rosetta::Zeckendorf::zeckendorf(0)
assert_eq(len(@z0), 0, "Rosetta::Zeckendorf::zeckendorf(0)")

val @z8 = Rosetta::Zeckendorf::zeckendorf(8)
join(",", @z8) |> assert_eq("8", "Rosetta::Zeckendorf::zeckendorf(8)")

test_run
