#!/usr/bin/env stryke
# Rosetta Code: Tau function — number of positive divisors of n (OEIS A000005).

fn Rosetta::Tau::count($n) {
    return 0 if $n < 1
    my $c = 0
    my $i = 1
    while ($i * $i <= $n) {
        if ($n % $i == 0) {
            $c += ($i * $i == $n ? 1 : 2)
        }
        $i += 1
    }
    $c
}

# OEIS A000005: 1, 2, 2, 3, 2, 4, 2, 4, 3, 4, 2, 6, 2, 4, 4, 5, 2, 6, 2, 6
my @first20 = ~> 1:20 map { Rosetta::Tau::count($_) }
assert_eq join(",", @first20),
    "1,2,2,3,2,4,2,4,3,4,2,6,2,4,4,5,2,6,2,6",
    "tau(1..20)"

assert_eq Rosetta::Tau::count(1), 1, "tau(1) = 1"
assert_eq Rosetta::Tau::count(60), 12, "tau(60) = 12 (highly composite)"
assert_eq Rosetta::Tau::count(100), 9, "tau(100) = 9"
assert_eq Rosetta::Tau::count(0), 0, "tau(0) = 0 (undefined → 0)"

test_run
