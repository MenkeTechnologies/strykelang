#!/usr/bin/env stryke
# Rosetta Code: Sequence: nth number with exactly n divisors

fn Rosetta::NthNumberWithNDivisors::count_divisors($n) {
    my $count = 0
    for my $i (1..$n) {
        if ($n % $i == 0) { $count++ }
    }
    $count
}

fn Rosetta::NthNumberWithNDivisors::solve($n) {
    my $i = 1
    my $found = 0
    my $res = 0
    while (!$found) {
        if (Rosetta::NthNumberWithNDivisors::count_divisors($i) == $n) {
            $res = $i
            $found = 1
        }
        $i++
    }
    $res
}

assert_eq Rosetta::NthNumberWithNDivisors::solve(1), 1, "a(1) = 1"
assert_eq Rosetta::NthNumberWithNDivisors::solve(2), 2, "a(2) = 2"
assert_eq Rosetta::NthNumberWithNDivisors::solve(3), 4, "a(3) = 4"
assert_eq Rosetta::NthNumberWithNDivisors::solve(4), 6, "a(4) = 6"
assert_eq Rosetta::NthNumberWithNDivisors::solve(5), 16, "a(5) = 16"
assert_eq Rosetta::NthNumberWithNDivisors::solve(6), 12, "a(6) = 12"

6 |> Rosetta::NthNumberWithNDivisors::solve |> assert_eq(12, "pipe nth_div")

test_run
