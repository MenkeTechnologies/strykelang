#!/usr/bin/env stryke
# Rosetta Code: Get system command output

fn Rosetta::SysOut::get_uptime() {
    # Using qx{} to capture output
    val $out = qx{uptime}
    $out |> trim
}

fn Rosetta::SysOut::get_echo($msg) {
    # Using pipe syntax with qx
    val $out = qx{echo "$msg"}
    $out |> trim
}

val $u = Rosetta::SysOut::get_uptime()
assert_ok len($u) > 0, "Uptime output is not empty"

val $e = Rosetta::SysOut::get_echo("hello world")
assert_eq $e, "hello world", "Echo output matches"

test_run
