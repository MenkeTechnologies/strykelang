#!/usr/bin/env stryke
# Rosetta Code: Pig Latin

fn Rosetta::PigLatin::translate($word) {
    if ($word =~ /^[aeiou]/i) {
        $word . "way"
    } else {
        my $res = $word
        if ($word =~ /^([^aeiou]+)(.*)$/i) {
            $res = $2 . $1 . "ay"
        }
        $res
    }
}

assert_eq Rosetta::PigLatin::translate("apple"), "appleway", "apple -> appleway"
assert_eq Rosetta::PigLatin::translate("pig"), "igpay", "pig -> igpay"
assert_eq Rosetta::PigLatin::translate("latin"), "atinlay", "latin -> latinay"
assert_eq Rosetta::PigLatin::translate("smile"), "ilesmay", "smile -> ilesmay"

"hello" |> Rosetta::PigLatin::translate |> assert_eq("ellohay", "pipe pig latin")

test_run
