#!/usr/bin/env stryke
# Rosetta Code: Radix Sort

fn Rosetta::RadixSort::sort($list) {
    var @arr = @$list
    val $n = len(@arr)
    if ($n < 2) { return \@arr }
    
    var $max = $arr[0]
    for val $x (@arr) {
        if ($x > $max) { $max = $x }
    }
    
    var $exp = 1
    while (int($max / $exp) > 0) {
        val @buckets = ([], [], [], [], [], [], [], [], [], [])
        for val $x (@arr) {
            val $digit = int($x / $exp) % 10
            push @{$buckets[$digit]}, $x
        }
        @arr = ()
        for val $i (0:9) {
            push @arr, @{$buckets[$i]}
        }
        $exp *= 10
    }
    \@arr
}

val $data = [170, 45, 75, 90, 802, 24, 2, 66]
val $sorted = Rosetta::RadixSort::sort($data)
assert_eq join(",", @$sorted), "2,24,45,66,75,90,170,802", "radix sort"

test_run
