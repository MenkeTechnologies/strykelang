#!/usr/bin/env stryke
# Rosetta Code: Water collected between towers

fn Rosetta::WaterCollected::solve($towers_ref) {
    val @towers = @$towers_ref
    val $n = len(@towers)
    if ($n < 3) { return 0 }
    
    var @left_max = ()
    var $curr_left = 0
    for val $i (0:$n-1) {
        if ($towers[$i] > $curr_left) { $curr_left = $towers[$i] }
        push @left_max, $curr_left
    }
    
    var @right_max = ()
    var $curr_right = 0
    for val $i (0:$n-1) {
        val $idx = $n - 1 - $i
        if ($towers[$idx] > $curr_right) { $curr_right = $towers[$idx] }
        $right_max[$idx] = $curr_right
    }
    
    var $total = 0
    for val $i (0:$n-1) {
        val $min_h = $left_max[$i] < $right_max[$i] ? $left_max[$i] : $right_max[$i]
        $total += $min_h - $towers[$i]
    }
    $total
}

assert_eq Rosetta::WaterCollected::solve([1, 5, 3, 7, 2]), 2, "water in [1,5,3,7,2]"
assert_eq Rosetta::WaterCollected::solve([5, 3, 7, 2, 6, 4, 5, 9, 1, 2]), 14, "water in longer sequence"
assert_eq Rosetta::WaterCollected::solve([1, 2, 3, 4, 5]), 0, "no water in ascending"

test_run
