#!/usr/bin/env stryke
# Rosetta Code: Breadth-first search

fn Rosetta::BFS::solve($graph, $start) {
    var @queue = ($start)
    var %visited = ($start => 1)
    var @order = ()
    
    while (len(@queue) > 0) {
        val $u = shift @queue
        push @order, $u
        for val $v (@{$graph->{$u}}) {
            if (!exists $visited{$v}) {
                $visited{$v} = 1
                push @queue, $v
            }
        }
    }
    \@order
}

val $graph = {
    "A" => ["B", "C"],
    "B" => ["D", "E"],
    "C" => ["F"],
    "D" => [],
    "E" => ["F"],
    "F" => []
}

val $res = Rosetta::BFS::solve($graph, "A")
assert_eq join(",", @$res), "A,B,C,D,E,F", "BFS order from A"

test_run
