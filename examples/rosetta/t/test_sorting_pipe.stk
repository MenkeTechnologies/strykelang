#!/usr/bin/env stryke
# Rosetta Code: Sort an array

fn Rosetta::Sort::string(@arr) {
    sort(@arr)
}

fn Rosetta::Sort::numeric(@arr) {
    sort { $a <=> $b } @arr
}

my @strings = qw(banana apple cherry date)
@strings |> Rosetta::Sort::string() |> join(",") |> assert_eq("apple,banana,cherry,date", "String sort")

my @nums = (10, 2, 5, 1, 9)
@nums |> Rosetta::Sort::numeric() |> join(",") |> assert_eq("1,2,5,9,10", "Numeric sort")

test_run
