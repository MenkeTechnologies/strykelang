#!/usr/bin/env stryke
# Rosetta Code: Tarjan offline LCA — answer all (u,v) lowest-common-
# ancestor queries in O((n + q) α(n)) by combining a DFS with union-
# find. For each query (u,v), once both endpoints have been visited
# in the DFS, the LCA is find(v) (or find(u)) at the moment of the
# second visit.

fn Rosetta::TLCA::find($parent, $u) {
    while ($parent->[$u] != $u) {
        $parent->[$u] = $parent->[$parent->[$u]]
        $u = $parent->[$u]
    }
    $u
}

fn Rosetta::TLCA::union($parent, $u, $v, $ancestor) {
    val $ru = Rosetta::TLCA::find($parent, $u)
    val $rv = Rosetta::TLCA::find($parent, $v)
    return if $ru == $rv
    $parent->[$ru] = $rv
    $ancestor->[$rv] = $ancestor->[$ru]
}

fn Rosetta::TLCA::dfs($adj, $u, $par, $parent, $ancestor, $visited, $queries_by, $answers) {
    $ancestor->[$u] = $u
    for val $v (@{$adj->[$u]}) {
        next if $v == $par
        Rosetta::TLCA::dfs($adj, $v, $u, $parent, $ancestor, $visited, $queries_by, $answers)
        Rosetta::TLCA::union($parent, $u, $v, $ancestor)
    }
    $visited->[$u] = 1
    for val $q (@{$queries_by->[$u]}) {
        val ($other, $idx) = @$q
        if ($visited->[$other]) {
            $answers->[$idx] = $ancestor->[Rosetta::TLCA::find($parent, $other)]
        }
    }
}

fn Rosetta::TLCA::solve($n, $edges, $root, $queries) {
    var @adj
    for val $i (~> 1:$n) { push @adj, [] }
    for val $e (@$edges) {
        var ($u, $v) = @$e
        push @{$adj[$u]}, $v
        push @{$adj[$v]}, $u
    }
    val @parent = ~> 0:$n - 1
    val @ancestor = ~> 1:$n |> map { -1 }
    val @visited = ~> 1:$n |> map { 0 }
    var @queries_by
    for val $i (~> 1:$n) { push @queries_by, [] }
    for val $i (~> 0:len(@$queries) - 1) {
        val ($u, $v) = @{$queries->[$i]}
        push @{$queries_by[$u]}, [$v, $i]
        push @{$queries_by[$v]}, [$u, $i]
    }
    val @answers = ~> 0:len(@$queries) - 1 |> map { -1 }
    Rosetta::TLCA::dfs(\@adj, $root, -1, \@parent, \@ancestor, \@visited, \@queries_by, \@answers)
    \@answers
}

# Tree:
#         0
#        / \
#       1   2
#      / \   \
#     3   4   5
#        / \
#       6   7
val $edges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 5], [4, 6], [4, 7]]

# (3, 4) → 1 (both under 1)
# (3, 7) → 1 (3 under 1, 7 under 4 under 1)
# (6, 7) → 4
# (3, 5) → 0 (cross subtrees)
# (5, 5) → 5 (self)
# (2, 5) → 2 (5's parent)
# (6, 5) → 0
# (1, 4) → 1 (ancestor)
val $queries = [
    [3, 4], [3, 7], [6, 7], [3, 5],
    [5, 5], [2, 5], [6, 5], [1, 4]
]
val $ans = Rosetta::TLCA::solve(8, $edges, 0, $queries)
assert_eq join(",", @$ans), "1,1,4,0,5,2,0,1", "8 LCA queries"

# Path tree: 0-1-2-3-4 (chain)
val $chain_edges = [[0, 1], [1, 2], [2, 3], [3, 4]]
val $chain_q = [[0, 4], [2, 4], [1, 3]]
val $chain_ans = Rosetta::TLCA::solve(5, $chain_edges, 0, $chain_q)
assert_eq join(",", @$chain_ans), "0,2,1", "chain LCAs"

# Star centered at 0
val $star_edges = [[0, 1], [0, 2], [0, 3], [0, 4]]
val $star_q = [[1, 2], [3, 4], [1, 4], [2, 3]]
val $star_ans = Rosetta::TLCA::solve(5, $star_edges, 0, $star_q)
assert_eq join(",", @$star_ans), "0,0,0,0", "star LCAs all 0"

# Single-vertex tree
val $tiny = Rosetta::TLCA::solve(1, [], 0, [[0, 0]])
assert_eq $tiny->[0], 0, "single vertex LCA = self"

test_run
