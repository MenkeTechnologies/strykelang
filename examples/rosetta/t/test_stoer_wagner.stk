#!/usr/bin/env stryke
# Rosetta Code: Stoer-Wagner global minimum cut. Repeatedly performs a
# max-adjacency ordering and merges the last two vertices, tracking the
# cut-of-the-phase as a candidate global min-cut. O(V³).

fn Rosetta::SW::min_cut($n, $edge_weights) {
    # edge_weights is an n×n adjacency matrix (symmetric).
    my @w
    for my $i (~> 0:$n - 1) {
        my @row = @{$edge_weights->[$i]}
        push @w, \@row
    }
    my @vertices = ~> 0:$n - 1
    my $best = 1e18
    while (len(@vertices) > 1) {
        my $m = len(@vertices)
        my @added = ~> 1:$m |> map { 0 }
        my @adj = ~> 1:$m |> map { 0 }
        my $prev = -1
        my $last = -1
        for my $i (~> 1:$m) {
            # Pick unadded vertex with max adjacency.
            my $sel = -1
            my $best_a = -1
            for my $j (~> 0:$m - 1) {
                next if $added[$j]
                if ($adj[$j] > $best_a) { $best_a = $adj[$j]; $sel = $j }
            }
            $added[$sel] = 1
            if ($i == $m - 1) {
                $prev = $sel
            }
            if ($i == $m) {
                $last = $sel
                $best = $best_a if $best_a < $best
            } else {
                for my $j (~> 0:$m - 1) {
                    if (!$added[$j]) {
                        $adj[$j] += $w[$vertices[$sel]][$vertices[$j]]
                    }
                }
            }
        }
        # Merge last into prev.
        my $vp = $vertices[$prev]
        my $vl = $vertices[$last]
        for my $k (~> 0:$n - 1) {
            $w[$vp][$k] += $w[$vl][$k]
            $w[$k][$vp] += $w[$k][$vl]
        }
        $w[$vp][$vp] = 0
        # Remove $last from vertex list.
        my @new_v
        for my $v (@vertices) { push @new_v, $v if $v != $vl }
        @vertices = @new_v
    }
    $best
}

fn Rosetta::SW::matrix_from_edges($n, $edges) {
    my @m
    for my $i (~> 0:$n - 1) {
        my @row = ~> 1:$n |> map { 0 }
        push @m, \@row
    }
    for my $e (@$edges) {
        my ($u, $v, $w) = @$e
        $m[$u][$v] += $w
        $m[$v][$u] += $w
    }
    \@m
}

# Wikipedia 8-node example: min cut = 4.
# Vertices 1..8, but we use 0..7.
# Edges: (1,2)=2, (1,5)=3, (2,3)=3, (2,5)=2, (2,6)=2, (3,4)=4, (3,7)=2,
# (4,7)=2, (4,8)=2, (5,6)=3, (6,7)=1, (7,8)=3
my $wp = Rosetta::SW::matrix_from_edges(8, [
    [0, 1, 2], [0, 4, 3],
    [1, 2, 3], [1, 4, 2], [1, 5, 2],
    [2, 3, 4], [2, 6, 2],
    [3, 6, 2], [3, 7, 2],
    [4, 5, 3],
    [5, 6, 1],
    [6, 7, 3]
])
assert_eq Rosetta::SW::min_cut(8, $wp), 4, "Wikipedia 8-node min cut = 4"

# Triangle with weights — cut isolates the lightest vertex.
my $tri = Rosetta::SW::matrix_from_edges(3, [[0, 1, 5], [1, 2, 3], [0, 2, 4]])
assert_eq Rosetta::SW::min_cut(3, $tri), 7, "triangle min cut"

# Bridge graph: two triangles connected by one edge of weight 1.
my $bridge_g = Rosetta::SW::matrix_from_edges(6, [
    [0, 1, 5], [1, 2, 5], [0, 2, 5],
    [3, 4, 5], [4, 5, 5], [3, 5, 5],
    [2, 3, 1]
])
assert_eq Rosetta::SW::min_cut(6, $bridge_g), 1, "bridge min cut = 1"

# Path graph: cut at any single edge.
my $path = Rosetta::SW::matrix_from_edges(4, [[0, 1, 7], [1, 2, 3], [2, 3, 9]])
assert_eq Rosetta::SW::min_cut(4, $path), 3, "path min cut = lightest edge"

# K4 with unit weights: min cut is 3 (any vertex isolated).
my $k4 = Rosetta::SW::matrix_from_edges(4,
    [[0, 1, 1], [0, 2, 1], [0, 3, 1], [1, 2, 1], [1, 3, 1], [2, 3, 1]])
assert_eq Rosetta::SW::min_cut(4, $k4), 3, "K4 unit-weight min cut = 3"

# Two-vertex graph
my $two = Rosetta::SW::matrix_from_edges(2, [[0, 1, 9]])
assert_eq Rosetta::SW::min_cut(2, $two), 9, "trivial 2-vertex cut"

test_run
