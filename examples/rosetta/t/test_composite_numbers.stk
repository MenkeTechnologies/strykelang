#!/usr/bin/env stryke
# Rosetta Code: Composite numbers

fn Rosetta::Composite::check($n) {
    if ($n < 4) { 0 }
    else {
        !is_prime($n)
    }
}

assert_ok Rosetta::Composite::check(4), "4 is composite"
assert_ok Rosetta::Composite::check(6), "6 is composite"
assert_ok Rosetta::Composite::check(9), "9 is composite"
assert_ok !Rosetta::Composite::check(2), "2 is not"
assert_ok !Rosetta::Composite::check(7), "7 is not"

4 |> Rosetta::Composite::check |> assert_ok("pipe composite")

test_run
