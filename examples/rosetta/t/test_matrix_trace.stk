#!/usr/bin/env stryke
# Rosetta Code: Matrix Trace

fn Rosetta::MatrixTrace::algo_trace($m) {
    var $sum = 0.0
    for val $i (0..len(@$m)-1) { $sum = $sum + $m->[$i]->[$i] }
    $sum
}

val $m = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
assert_eq Rosetta::MatrixTrace::algo_trace($m), 15, "trace is 15"
test_run
