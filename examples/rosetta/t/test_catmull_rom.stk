#!/usr/bin/env stryke
# Rosetta Code: Catmull-Rom spline. Centripetal/uniform/chordal variant
# selectable by alpha (0=uniform, 0.5=centripetal, 1=chordal). Returns
# samples along the spline through control points P1..Pn-1 using P0..Pn
# as the surrounding tangent context.

fn Rosetta::CatmullRom::tj($ti, $pi, $pj, $alpha) {
    val $dx = $pj->[0] - $pi->[0]
    val $dy = $pj->[1] - $pi->[1]
    val $d2 = $dx * $dx + $dy * $dy
    $ti + ($d2 ** ($alpha / 2))
}

fn Rosetta::CatmullRom::segment($p0, $p1, $p2, $p3, $alpha, $samples) {
    val $t0 = 0
    val $t1 = Rosetta::CatmullRom::tj($t0, $p0, $p1, $alpha)
    val $t2 = Rosetta::CatmullRom::tj($t1, $p1, $p2, $alpha)
    val $t3 = Rosetta::CatmullRom::tj($t2, $p2, $p3, $alpha)
    var @out
    for val $k (~> 0:$samples - 1) {
        val $t = $t1 + ($t2 - $t1) * ($k / ($samples - 1))
        var @a1
        var @a2
        var @a3
        $a1[0] = ($t1 - $t) / ($t1 - $t0) * $p0->[0] + ($t - $t0) / ($t1 - $t0) * $p1->[0]
        $a1[1] = ($t1 - $t) / ($t1 - $t0) * $p0->[1] + ($t - $t0) / ($t1 - $t0) * $p1->[1]
        $a2[0] = ($t2 - $t) / ($t2 - $t1) * $p1->[0] + ($t - $t1) / ($t2 - $t1) * $p2->[0]
        $a2[1] = ($t2 - $t) / ($t2 - $t1) * $p1->[1] + ($t - $t1) / ($t2 - $t1) * $p2->[1]
        $a3[0] = ($t3 - $t) / ($t3 - $t2) * $p2->[0] + ($t - $t2) / ($t3 - $t2) * $p3->[0]
        $a3[1] = ($t3 - $t) / ($t3 - $t2) * $p2->[1] + ($t - $t2) / ($t3 - $t2) * $p3->[1]
        var @b1
        var @b2
        $b1[0] = ($t2 - $t) / ($t2 - $t0) * $a1[0] + ($t - $t0) / ($t2 - $t0) * $a2[0]
        $b1[1] = ($t2 - $t) / ($t2 - $t0) * $a1[1] + ($t - $t0) / ($t2 - $t0) * $a2[1]
        $b2[0] = ($t3 - $t) / ($t3 - $t1) * $a2[0] + ($t - $t1) / ($t3 - $t1) * $a3[0]
        $b2[1] = ($t3 - $t) / ($t3 - $t1) * $a2[1] + ($t - $t1) / ($t3 - $t1) * $a3[1]
        val $cx = ($t2 - $t) / ($t2 - $t1) * $b1[0] + ($t - $t1) / ($t2 - $t1) * $b2[0]
        val $cy = ($t2 - $t) / ($t2 - $t1) * $b1[1] + ($t - $t1) / ($t2 - $t1) * $b2[1]
        push @out, [$cx, $cy]
    }
    \@out
}

fn Rosetta::CatmullRom::close($x, $y) { abs($x - $y) < 1e-9 }

# Endpoints of a centripetal Catmull-Rom segment must equal P1 and P2.
val $p0 = [0, 0]
val $p1 = [1, 1]
val $p2 = [3, 2]
val $p3 = [4, 4]
val $seg = Rosetta::CatmullRom::segment($p0, $p1, $p2, $p3, 0.5, 11)
assert_eq len(@$seg), 11, "11 samples"
assert_ok Rosetta::CatmullRom::close($seg->[0][0], 1), "first sample at P1.x"
assert_ok Rosetta::CatmullRom::close($seg->[0][1], 1), "first sample at P1.y"
assert_ok Rosetta::CatmullRom::close($seg->[10][0], 3), "last sample at P2.x"
assert_ok Rosetta::CatmullRom::close($seg->[10][1], 2), "last sample at P2.y"

# Collinear points should yield linear interpolation between P1 and P2 regardless of alpha.
val $cl0 = [0, 0]
val $cl1 = [1, 1]
val $cl2 = [2, 2]
val $cl3 = [3, 3]
val $linseg = Rosetta::CatmullRom::segment($cl0, $cl1, $cl2, $cl3, 0.5, 5)
for val $i (~> 0:4) {
    val $t = $i / 4
    val $expected_x = 1 + 1 * $t
    val $expected_y = 1 + 1 * $t
    assert_ok Rosetta::CatmullRom::close($linseg->[$i][0], $expected_x), "collinear x sample $i"
    assert_ok Rosetta::CatmullRom::close($linseg->[$i][1], $expected_y), "collinear y sample $i"
}

# Symmetric S-curve: alpha=0 uniform variant
val $sym0 = [-1, 0]
val $sym1 = [0, 1]
val $sym2 = [1, 1]
val $sym3 = [2, 0]
val $u = Rosetta::CatmullRom::segment($sym0, $sym1, $sym2, $sym3, 0, 5)
assert_eq len(@$u), 5, "uniform 5 samples"
assert_ok Rosetta::CatmullRom::close($u->[0][0], 0), "uniform start x"
assert_ok Rosetta::CatmullRom::close($u->[4][0], 1), "uniform end x"

test_run
