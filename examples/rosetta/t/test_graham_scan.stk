#!/usr/bin/env stryke
# Rosetta Code: Convex hull — Graham scan

fn Rosetta::Graham::cross($o, $u, $v) {
    ($u->[0] - $o->[0]) * ($v->[1] - $o->[1]) - ($u->[1] - $o->[1]) * ($v->[0] - $o->[0])
}

fn Rosetta::Graham::hull($points) {
    val $n = len(@$points)
    return [@$points] if $n < 3

    # Pivot: lowest y, then lowest x
    var $piv = 0
    for val $i (1:$n-1) {
        if ($points->[$i][1] < $points->[$piv][1]
            || ($points->[$i][1] == $points->[$piv][1]
                && $points->[$i][0] < $points->[$piv][0])) {
            $piv = $i
        }
    }
    val $px = $points->[$piv][0]
    val $py = $points->[$piv][1]

    # Sort remaining by polar angle around pivot, ties broken by distance
    val @rest = grep { _->[0] != $px || _->[1] != $py } @$points
    val @sorted = sort {
        val $cx = (_0->[0] - $px) * (_1->[1] - $py) - (_0->[1] - $py) * (_1->[0] - $px)
        if ($cx == 0) {
            ((_0->[0]-$px)**2 + (_0->[1]-$py)**2)
                <=> ((_1->[0]-$px)**2 + (_1->[1]-$py)**2)
        } else {
            $cx > 0 ? -1 : 1
        }
    } @rest

    var @stack = ([$px, $py])
    ~> @sorted ep {
        while (len(@stack) >= 2
                && Rosetta::Graham::cross($stack[-2], $stack[-1], _) <= 0) {
            pop @stack
        }
        push @stack, _
    }
    \@stack
}

val $pts = [[0,0], [3,0], [3,3], [0,3], [1,1], [2,2], [1,2]]
val $h = Rosetta::Graham::hull($pts)
val @sig = map { _->[0] . "," . _->[1] } @$h
val $sorted = join("|", sort @sig)
assert_eq $sorted, "0,0|0,3|3,0|3,3", "Graham hull of 7 pts = 4 corners"

val $tri = [[0,0], [4,0], [2,3], [2,1]]
val $h2 = Rosetta::Graham::hull($tri)
assert_eq len(@$h2), 3, "triangle hull = 3 vertices"

val $tiny = [[0,0], [1,1]]
val $h3 = Rosetta::Graham::hull($tiny)
assert_eq len(@$h3), 2, "two points: returned as-is"

test_run
