#!/usr/bin/env stryke
# Rosetta Code: Cyclops numbers

fn Rosetta::Cyclops::check($n) {
    my $s = sprintf("%d", $n)
    my @c = chars($s)
    my $len = len(@c)
    if ($len % 2 == 0) {
        return 0
    }
    
    my $mid = int($len / 2)
    if ($c[$mid] ne "0") {
        return 0
    }
    
    for my $i (0..$len-1) {
        if ($i != $mid && $c[$i] eq "0") {
            return 0
        }
    }
    1
}

assert_ok Rosetta::Cyclops::check(0), "0 is cyclops"
assert_ok Rosetta::Cyclops::check(101), "101 is cyclops"
assert_ok Rosetta::Cyclops::check(12034), "12034 is cyclops"
assert_ok !Rosetta::Cyclops::check(1001), "1001 is not (even digits)"
assert_ok !Rosetta::Cyclops::check(123), "123 is not (mid not 0)"
assert_ok !Rosetta::Cyclops::check(10203), "10203 is not (multiple zeros)"

101 |> Rosetta::Cyclops::check |> assert_ok("pipe cyclops check")

test_run
