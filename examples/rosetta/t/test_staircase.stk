#!/usr/bin/env stryke
# Rosetta Code: Staircase problem

fn Rosetta::Staircase::staircase($n) {
    if ($n < 2) {
        1
    } else {
        my $a = 1
        my $b = 1
        for my $i (2..$n) {
            ($a, $b) = ($b, $a + $b)
        }
        $b
    }
}

assert_eq Rosetta::Staircase::staircase(1), 1, "Rosetta::Staircase::staircase(1) = 1"
assert_eq Rosetta::Staircase::staircase(2), 2, "Rosetta::Staircase::staircase(2) = 2 (1+1, 2)"
assert_eq Rosetta::Staircase::staircase(3), 3, "Rosetta::Staircase::staircase(3) = 3 (1+1+1, 1+2, 2+1)"
assert_eq Rosetta::Staircase::staircase(4), 5, "Rosetta::Staircase::staircase(4) = 5"
assert_eq Rosetta::Staircase::staircase(10), 89, "Rosetta::Staircase::staircase(10) = 89"

10 |> Rosetta::Staircase::staircase |> assert_eq(89, "pipe Rosetta::Staircase::staircase")

test_run
