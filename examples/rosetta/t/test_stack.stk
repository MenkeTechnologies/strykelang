#!/usr/bin/env stryke
# Rosetta Code: Stack

fn Rosetta::Stack::new {
    ([])
}

fn Rosetta::Stack::push($stack, $val) {
    push @$stack, $val
    $stack
}

fn Rosetta::Stack::pop($stack) {
    pop @$stack
}

fn Rosetta::Stack::peek($stack) {
    $stack->[-1]
}

fn Rosetta::Stack::empty($stack) {
    len(@$stack) == 0
}

my $s = Rosetta::Stack::new()
$s |> Rosetta::Stack::push(10) |> Rosetta::Stack::push(20)

assert_eq Rosetta::Stack::peek($s), 20, "peek stack"
assert_eq Rosetta::Stack::pop($s), 20, "pop 20"
assert_eq Rosetta::Stack::pop($s), 10, "pop 10"
assert_ok Rosetta::Stack::empty($s), "stack is empty"

# Threading with stack
~> Rosetta::Stack::new() Rosetta::Stack::push(1) Rosetta::Stack::push(2) Rosetta::Stack::push(3) |> Rosetta::Stack::pop |> assert_eq(3, "threaded stack pop")

test_run
