#!/usr/bin/env stryke
# Rosetta Code: Factorions

fn my_factorial($n) {
    if ($n < 2) { 1 }
    else { 1..$n |> reduce { $a * $b } }
}

fn is_factorion($n) {
    my $sum = 0
    my @digits = ~> "$n" chars
    for my $d (@digits) {
        $sum += my_factorial(int($d))
    }
    $sum == $n
}

assert_ok is_factorion(1), "1 is factorion"
assert_ok is_factorion(2), "2 is factorion"
assert_ok is_factorion(145), "145 is factorion (1!+4!+5! = 1+24+120)"
assert_ok !is_factorion(10), "10 is not"

145 |> is_factorion |> assert_ok("pipe factorion")

test_run
