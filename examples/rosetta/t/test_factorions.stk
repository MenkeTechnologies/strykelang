#!/usr/bin/env stryke
# Rosetta Code: Factorions

my @FACS = (1, 1, 2, 6, 24, 120, 720, 5040, 40320, 362880)

fn Rosetta::Factorions::check($n) {
    my $sum = 0
    my @digits = "$n" |> chars
    ~> @digits ep {
        $sum = $sum + $FACS[int(_)]
    }
    $sum == $n
}

assert_ok Rosetta::Factorions::check(1), "1 is factorion"
assert_ok Rosetta::Factorions::check(2), "2 is factorion"
assert_ok Rosetta::Factorions::check(145), "145 is factorion (1!+4!+5! = 1+24+120)"
assert_ok !Rosetta::Factorions::check(10), "10 is not"

145 |> Rosetta::Factorions::check |> assert_ok("pipe factorion")

test_run
