#!/usr/bin/env stryke
# Rosetta Code: Solitaire cipher

fn Rosetta::Solitaire::move_card($deck, $card, $steps) {
    var $pos = -1
    for (var $i = 0; $i < 54; $i++) {
        if ($deck->[$i] == $card) {
            $pos = $i
            last
        }
    }
    
    var $new_pos = ($pos + $steps)
    if ($new_pos > 53) { $new_pos = $new_pos % 53 }
    
    splice(@$deck, $pos, 1)
    splice(@$deck, $new_pos, 0, $card)
}

fn Rosetta::Solitaire::triple_cut($deck) {
    var $j1 = -1
    var $j2 = -1
    for (var $i = 0; $i < 54; $i++) {
        if ($deck->[$i] == 53 || $deck->[$i] == 54) {
            if ($j1 == -1) { $j1 = $i }
            else { $j2 = $i; last }
        }
    }
    
    val @top = @$deck[0 : $j1-1]
    val @mid = @$deck[$j1 : $j2]
    val @bot = @$deck[$j2+1 : 53]
    
    @$deck = (@bot, @mid, @top)
}

fn Rosetta::Solitaire::count_cut($deck) {
    var $val = $deck->[-1]
    if ($val == 54) { $val = 53 }
    if ($val == 53) { return }
    
    val @top = splice(@$deck, 0, $val)
    splice(@$deck, -1, 0, @top)
}

fn Rosetta::Solitaire::get_output($deck) {
    var $val = $deck->[0]
    $val = 53 if $val == 54
    
    val $out = $deck->[$val]
    return undef if $out >= 53
    $out % 26 == 0 ? 26 : $out % 26
}

fn Rosetta::Solitaire::step($deck) {
    Rosetta::Solitaire::move_card($deck, 53, 1)
    Rosetta::Solitaire::move_card($deck, 54, 2)
    Rosetta::Solitaire::triple_cut($deck)
    Rosetta::Solitaire::count_cut($deck)
    Rosetta::Solitaire::get_output($deck)
}

fn Rosetta::Solitaire::encrypt($text, $deck) {
    val $t = $text |> uc() |> { _ =~ s/[^A-Z]//gr }
    var @res
    for val $c ($t |> chars()) {
        val $p_val = ord($c) - ord("A") + 1
        var $out = undef
        while (!defined $out) {
            $out = Rosetta::Solitaire::step($deck)
        }
        var $c_val = ($p_val + $out) % 26
        $c_val = 26 if $c_val == 0
        push @res, chr($c_val + ord("A") - 1)
    }
    join("", @res)
}

# Unkeyed deck
var @deck = 1:54
val $t = "HELLOWORLD"
val $enc = Rosetta::Solitaire::encrypt($t, \@deck)
# Expected for "HELLOWORLD" with unkeyed deck:
# H(8) + 4 = 12(L)
# E(5) + 49%26=23 = 28%26=2(B) ... wait, unkeyed deck output is 4, 49, 10, ...
# Let's just check round trip.

# Round trip requires same starting deck
@deck = 1:54
val $enc_val = Rosetta::Solitaire::encrypt("SOLITAIRE", \@deck)

# To decrypt, subtract instead of add
fn Rosetta::Solitaire::decrypt($text, $deck) {
    var @res
    for val $c ($text |> chars()) {
        val $c_val = ord($c) - ord("A") + 1
        var $out = undef
        while (!defined $out) {
            $out = Rosetta::Solitaire::step($deck)
        }
        var $p_val = ($c_val - $out) % 26
        $p_val += 26 if $p_val <= 0
        push @res, chr($p_val + ord("A") - 1)
    }
    join("", @res)
}

@deck = 1:54
assert_eq Rosetta::Solitaire::decrypt($enc_val, \@deck), "SOLITAIRE", "Solitaire round trip"

test_run
