#!/usr/bin/env stryke
# Rosetta Code: Mode (using pipes)

fn Rosetta::Mode::compute(@list) {
    if (len(@list) == 0) { return [] }
    
    my %counts
    ~> @list map { $counts{$_}++ }
    
    my $max = ~> (values %counts) max()
    
    ~> (keys %counts) grep { $counts{$_} == $max } |> sort()
}

my @m1 = Rosetta::Mode::compute(1, 3, 6, 6, 6, 6, 7, 7, 12, 12, 17)
assert_eq join(",", @m1), "6", "mode is 6"

my @m2 = Rosetta::Mode::compute(1, 1, 2, 4, 4)
assert_eq join(",", @m2), "1,4", "modes are 1 and 4"

my @m3 = Rosetta::Mode::compute("apple", "banana", "apple")
assert_eq join(",", @m3), "apple", "mode with strings"

test_run
