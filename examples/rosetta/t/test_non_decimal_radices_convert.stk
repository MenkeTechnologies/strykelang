#!/usr/bin/env stryke
# Rosetta Code: Non-decimal radices/Convert
# Convert between bases 2..36. Negatives carry a leading "-".

fn Rosetta::Radix::digit_to_char($d) {
    return chr(ord("0") + $d)         if $d < 10
    return chr(ord("a") + $d - 10)
}

fn Rosetta::Radix::char_to_digit($c) {
    return ord($c) - ord("0")            if $c =~ /[0-9]/
    return ord(lc($c)) - ord("a") + 10  if $c =~ /[A-Za-z]/
    -1
}

fn Rosetta::Radix::to_base($n, $base) {
    return undef if $base < 2 || $base > 36
    return "0" if $n == 0
    my $sign = $n < 0 ? "-" : ""
    my $x = abs($n)
    my $s = ""
    while ($x > 0) {
        $s = Rosetta::Radix::digit_to_char($x % $base) . $s
        $x = int($x / $base)
    }
    "$sign$s"
}

fn Rosetta::Radix::from_base($s, $base) {
    return undef if $base < 2 || $base > 36
    my $sign = 1
    my $i = 0
    if (substr($s, 0, 1) eq "-") { $sign = -1; $i = 1 }
    if (substr($s, 0, 1) eq "+") { $i = 1 }
    my $v = 0
    while ($i < length($s)) {
        my $d = Rosetta::Radix::char_to_digit(substr($s, $i, 1))
        return undef if $d < 0 || $d >= $base
        $v = $v * $base + $d
        $i++
    }
    $sign * $v
}

fn Rosetta::Radix::convert($s, $from_base, $to_base) {
    Rosetta::Radix::to_base(Rosetta::Radix::from_base($s, $from_base), $to_base)
}

# Helpers
assert_eq Rosetta::Radix::digit_to_char(0),  "0",  "0 → '0'"
assert_eq Rosetta::Radix::digit_to_char(9),  "9",  "9 → '9'"
assert_eq Rosetta::Radix::digit_to_char(10), "a",  "10 → 'a'"
assert_eq Rosetta::Radix::digit_to_char(35), "z",  "35 → 'z'"
assert_eq Rosetta::Radix::char_to_digit("F"),15,   "F → 15"

# Encoding
assert_eq Rosetta::Radix::to_base(255, 16),  "ff",     "255 in hex"
assert_eq Rosetta::Radix::to_base(1024, 2),  "10000000000", "1024 in binary"
assert_eq Rosetta::Radix::to_base(7, 8),     "7",      "7 in octal"
assert_eq Rosetta::Radix::to_base(0, 16),    "0",      "0 in hex"
assert_eq Rosetta::Radix::to_base(-42, 16),  "-2a",    "-42 in hex"

# Decoding
assert_eq Rosetta::Radix::from_base("ff", 16),     255,  "ff → 255"
assert_eq Rosetta::Radix::from_base("100", 16),    256,  "100 hex"
assert_eq Rosetta::Radix::from_base("-FF", 16),    -255, "negative hex"

# Round-trip across bases
my $rt = 1
for my $n (-1000, -1, 0, 1, 42, 65535, 1000000) {
    for my $b (2, 8, 10, 16, 36) {
        my $back = Rosetta::Radix::from_base(Rosetta::Radix::to_base($n, $b), $b)
        $rt = 0 if $back != $n
    }
}
assert_ok $rt, "round-trip across bases preserves values"

# Cross-base conversion
assert_eq Rosetta::Radix::convert("FF", 16, 10), "255",  "FF hex → 255 dec"
assert_eq Rosetta::Radix::convert("11111111", 2, 16), "ff", "binary → hex"

# Invalid inputs
assert_ok !defined(Rosetta::Radix::from_base("hello", 10)), "alpha rejected base 10"
assert_ok !defined(Rosetta::Radix::to_base(10, 1)),         "base 1 rejected"
assert_ok !defined(Rosetta::Radix::to_base(10, 37)),        "base 37 rejected"

# Pipe form
255 |> fn { Rosetta::Radix::to_base(_, 16) } |> assert_eq("ff", "pipe 255→ff")

test_run
