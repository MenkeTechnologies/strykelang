#!/usr/bin/env stryke
# Rosetta Code: Linear regression

fn Rosetta::LinearRegression::solve($points) {
    val $n = len(@$points)
    val $sum_x = ~> @$points map { _->[0] } |> reduce { _0 + _1 }
    val $sum_y = ~> @$points map { _->[1] } |> reduce { _0 + _1 }
    val $avg_x = $sum_x / $n
    val $avg_y = $sum_y / $n
    
    val $num = ~> @$points map { (_->[0] - $avg_x) * (_->[1] - $avg_y) } |> reduce { _0 + _1 }
    val $den = ~> @$points map { (_->[0] - $avg_x) ** 2 } |> reduce { _0 + _1 }
    
    val $m = $num / $den
    val $c = $avg_y - $m * $avg_x
    ($m, $c)
}

val $pts = [
    [1, 1],
    [2, 3],
    [3, 3],
    [4, 5],
    [5, 5]
]

val ($m, $c) = Rosetta::LinearRegression::solve($pts)
assert_eq $m, 1.0, "slope m"
assert_eq $c, 0.4, "intercept c"

test_run
