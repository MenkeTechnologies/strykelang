#!/usr/bin/env stryke
# Rosetta Code: Ulam numbers

fn Rosetta::Ulam::generate($count) {
    var @ulams = (1, 2)
    var %is_ulam = (1 => 1, 2 => 1)
    var $next = 3
    
    while (len(@ulams) < $count) {
        var $ways = 0
        for val $u1 (@ulams) {
            last if 2 * $u1 >= $next
            val $u2 = $next - $u1
            if (exists $is_ulam{$u2} && $u1 != $u2) {
                $ways++
                last if $ways > 1
            }
        }
        
        if ($ways == 1) {
            push @ulams, $next
            $is_ulam{$next} = 1
        }
        $next++
    }
    \@ulams
}

val $ulams = Rosetta::Ulam::generate(10)
assert_eq join(",", @$ulams), "1,2,3,4,6,8,11,13,16,18", "first 10 Ulam numbers"

val $u25 = Rosetta::Ulam::generate(25)
assert_eq $u25->[-1], 97, "25th Ulam number is 97"

test_run
