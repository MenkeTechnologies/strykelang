#!/usr/bin/env stryke
# Rosetta Code: Bitmap/Read an image through a pipe

# We'll reuse the logic from test_bitmap_ppm but reading from /dev/stdin
fn Rosetta::BitmapPipe::read() {
    # In a real use case: val $str = slurp("/dev/stdin")
    # For testing, we simulate the pipe input
    val $ppm = "P3\n1 1\n255\n255 0 0\n"
    
    var @tokens
    for val $line (split("\n", $ppm)) {
        next if $line =~ /^#/
        for val $t (split(/\s+/, $line)) {
            if ($t ne "") { push @tokens, $t }
        }
    }
    
    val $magic = shift @tokens
    val $w = int(shift @tokens)
    val $h = int(shift @tokens)
    val $max = int(shift @tokens)
    
    var @pixels
    for val $i (1:$h) {
        var @row
        for val $j (1:$w) {
            val $r = shift @tokens
            val $g = shift @tokens
            val $b = shift @tokens
            push @row, { r => int($r), g => int($g), b => int($b) }
        }
        push @pixels, \@row
    }
    
    "Read 1x1 image through mock pipe" |> p
    "Pixel 0,0: R=" . $pixels[0]->[0]->{r} |> p
    
    # Assertions
    assert_eq len(@pixels), 1, "Height 1"
    assert_eq $pixels[0]->[0]->{r}, 255, "Red 255"
}

Rosetta::BitmapPipe::read()
test_run
