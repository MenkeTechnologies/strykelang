#!/usr/bin/env stryke
# Rosetta Code: Goldbach's conjecture

fn Rosetta::GoldbachConjecture::solve($n) {
    my @res
    if ($n % 2 == 0 && $n > 2) {
        for my $i (2..int($n/2)) {
            if (is_prime($i) && is_prime($n - $i)) {
                push @res, "$i + " . ($n - $i)
            }
        }
    }
    \@res
}

assert_eq Rosetta::GoldbachConjecture::solve(4)->[0], "2 + 2", "Goldbach(4)"
assert_eq Rosetta::GoldbachConjecture::solve(10)->[0], "3 + 7", "Goldbach(10) first"
my $res10 = Rosetta::GoldbachConjecture::solve(10)
assert_eq join(",", @$res10), "3 + 7,5 + 5", "Goldbach(10) all"

10 |> Rosetta::GoldbachConjecture::solve |> map { join(",", @$_) } |> assert_eq("3 + 7,5 + 5", "pipe goldbach")

test_run
