#!/usr/bin/env stryke
# Rosetta Code: Minesweeper (Generating)

fn Rosetta::MinesweeperGen::generate($w, $h, $num) {
    my @board
    for my $i (0..$h-1) {
        my @row
        for my $j (0..$w-1) { push @row, 0 }
        push @board, \@row
    }
    
    my $placed = 0
    while ($placed < $num) {
        my $r = int(rand($h))
        my $c = int(rand($w))
        if ($board[$r]->[$c] != -1) {
            $board[$r]->[$c] = -1
            $placed = $placed + 1
        }
    }
    
    for my $r (0..$h-1) {
        for my $c (0..$w-1) {
            if ($board[$r]->[$c] == -1) { next }
            my $count = 0
            for my $dr (-1..1) {
                for my $dc (-1..1) {
                    my $nr = $r + $dr
                    my $nc = $c + $dc
                    if ($nr >= 0 && $nr < $h && $nc >= 0 && $nc < $w) {
                        if ($board[$nr]->[$nc] == -1) { $count = $count + 1 }
                    }
                }
            }
            $board[$r]->[$c] = $count
        }
    }
    \@board
}

my $b = Rosetta::MinesweeperGen::generate(5, 5, 5)
assert_eq scalar(@$b), 5, "board height"
assert_eq scalar(@{$b->[0]}), 5, "board width"

# Verify mine count
my $m_count = 0
for my $row (@$b) {
    for my $val (@$row) {
        if ($val == -1) { $m_count = $m_count + 1 }
    }
}
assert_eq $m_count, 5, "correct mine count"

test_run
