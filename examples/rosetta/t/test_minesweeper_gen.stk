#!/usr/bin/env stryke
# Rosetta Code: Minesweeper (Generating)

fn Rosetta::MinesweeperGen::generate($w, $h, $num) {
    var @board
    for val $i (0:$h-1) {
        var @row
        for val $j (0:$w-1) { push @row, 0 }
        push @board, \@row
    }
    
    var $placed = 0
    while ($placed < $num) {
        val $r = int(rand($h))
        val $c = int(rand($w))
        if ($board[$r]->[$c] != -1) {
            $board[$r]->[$c] = -1
            $placed = $placed + 1
        }
    }
    
    for val $r (0:$h-1) {
        for val $c (0:$w-1) {
            if ($board[$r]->[$c] == -1) { next }
            var $count = 0
            for val $dr (-1:1) {
                for val $dc (-1:1) {
                    val $nr = $r + $dr
                    val $nc = $c + $dc
                    if ($nr >= 0 && $nr < $h && $nc >= 0 && $nc < $w) {
                        if ($board[$nr]->[$nc] == -1) { $count = $count + 1 }
                    }
                }
            }
            $board[$r]->[$c] = $count
        }
    }
    \@board
}

val $b = Rosetta::MinesweeperGen::generate(5, 5, 5)
assert_eq len(@$b), 5, "board height"
assert_eq len(@{$b->[0]}), 5, "board width"

# Verify mine count
var $m_count = 0
for val $row (@$b) {
    for val $val (@$row) {
        if ($val == -1) { $m_count = $m_count + 1 }
    }
}
assert_eq $m_count, 5, "correct mine count"

test_run
