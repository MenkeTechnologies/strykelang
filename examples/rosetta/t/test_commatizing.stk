#!/usr/bin/env stryke
# Rosetta Code: Commatizing numbers

fn Rosetta::Commatize::insert($n) {
    var $s = "$n"
    var $sign = ""
    if (substr($s, 0, 1) eq "-") {
        $sign = "-"
        $s = substr($s, 1)
    }
    val $dot = index($s, ".")
    val $int_part = $dot < 0 ? $s : substr($s, 0, $dot)
    val $rest = $dot < 0 ? "" : substr($s, $dot)
    val @rev = rev split("", $int_part)
    var @grouped
    for val $i (0..len(@rev)-1) {
        push @grouped, "," if $i > 0 && $i % 3 == 0
        push @grouped, $rev[$i]
    }
    $sign . join("", rev @grouped) . $rest
}

assert_eq Rosetta::Commatize::insert(1),         "1",         "single"
assert_eq Rosetta::Commatize::insert(123),       "123",       "no comma"
assert_eq Rosetta::Commatize::insert(1234),      "1,234",     "1 comma"
assert_eq Rosetta::Commatize::insert(1000000),   "1,000,000", "1M"
assert_eq Rosetta::Commatize::insert(-1234567),  "-1,234,567","negative"
assert_eq Rosetta::Commatize::insert(1234.567),  "1,234.567", "decimal"

# pipeline of formatting
val @fmts = (1234, 56, 9876543, 100) |> map {Rosetta::Commatize::insert}
assert_eq join(";", @fmts), "1,234;56;9,876,543;100", "map commatize"

test_run
