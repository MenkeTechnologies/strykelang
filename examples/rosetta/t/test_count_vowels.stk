#!/usr/bin/env stryke
# Rosetta Code: Count Vowels

fn Rosetta::CountVowels::solve($s) {
    ~> $s chars grep { $_ =~ /[aeiouAEIOU]/ } len
}

assert_eq Rosetta::CountVowels::solve("alphabet"), 3, "alphabet has 3 vowels"
assert_eq Rosetta::CountVowels::solve("Stryke"), 1, "Stryke has 1 vowel"
assert_eq Rosetta::CountVowels::solve("AEIOU"), 5, "AEIOU has 5 vowels"
assert_eq Rosetta::CountVowels::solve("bcdfg"), 0, "no vowels"

test_run
