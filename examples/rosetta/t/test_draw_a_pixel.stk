#!/usr/bin/env stryke
# Rosetta Code: Draw a pixel

fn Rosetta::Bitmap::create($w, $h) {
    my @grid
    for (my $i = 0; $i < $h; $i++) {
        my @row
        for (my $j = 0; $j < $w; $j++) {
            push @row, { r => 0, g => 0, b => 0 }
        }
        push @grid, \@row
    }
    \@grid
}

fn Rosetta::Bitmap::set_pixel($img, $x, $y, $color) {
    $img->[$y]->[$x] = $color
}

my $img = Rosetta::Bitmap::create(10, 10)
Rosetta::Bitmap::set_pixel($img, 5, 5, { r => 255, g => 255, b => 255 })

assert_eq $img->[5]->[5]->{r}, 255, "Red set"
assert_eq $img->[5]->[5]->{g}, 255, "Green set"
assert_eq $img->[5]->[5]->{b}, 255, "Blue set"
assert_eq $img->[0]->[0]->{r}, 0, "Origin pixel remains black"

test_run
