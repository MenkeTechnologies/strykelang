#!/usr/bin/env stryke
# Rosetta Code: Caesar Cipher

fn caesar_encode($str, $shift) {
    my @res
    my @chars = $str |> chars
    for my $c (@chars) {
        if ($c =~ /[A-Z]/) {
            push @res, chr((ord($c) - 65 + $shift) % 26 + 65)
        } elsif ($c =~ /[a-z]/) {
            push @res, chr((ord($c) - 97 + $shift) % 26 + 97)
        } else {
            push @res, $c
        }
    }
    join("", @res)
}

fn my_rot13($str) {
    caesar_encode($str, 13)
}

assert_eq caesar_encode("ABC", 1), "BCD", "shift ABC by 1"
assert_eq caesar_encode("XYZ", 3), "ABC", "shift XYZ wraps"
assert_eq caesar_encode("Hello, World!", 13), "Uryyb, Jbeyq!", "rot13 hello"

assert_eq my_rot13("Hello"), "Uryyb", "rot13 encode"
assert_eq my_rot13(my_rot13("Test")), "Test", "rot13 is self-inverse"

test_run
