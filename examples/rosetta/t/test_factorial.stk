#!/usr/bin/env stryke
# Rosetta Code: Factorial

fn Rosetta::Factorial::compute($n) {
    $n <= 1 ? 1 : $n * Rosetta::Factorial::compute($n - 1)
}

fn Rosetta::Factorial::compute_iter($n) {
    $n < 1 ? 1 : (~> 1:$n reduce { _0 * _1 })
}

assert_eq Rosetta::Factorial::compute(0), 1, "factorial(0)"
assert_eq Rosetta::Factorial::compute(1), 1, "factorial(1)"
assert_eq Rosetta::Factorial::compute(5), 120, "factorial(5)"
assert_eq Rosetta::Factorial::compute(10), 3628800, "factorial(10)"

assert_eq Rosetta::Factorial::compute_iter(0), 1, "factorial_iter(0)"
assert_eq Rosetta::Factorial::compute_iter(5), 120, "factorial_iter(5)"

test_run
