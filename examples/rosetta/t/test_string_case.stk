#!/usr/bin/env stryke
# Rosetta Code: String Case

fn to_upper {
    my $s = $_[0]
    uc($s)
}

fn to_lower {
    my $s = $_[0]
    lc($s)
}

fn to_title {
    my $s = $_[0]
    my @parts = split /\s+/, $s
    my @res = @parts |> map { ucfirst(lc($_)) }
    join(" ", @res)
}

fn my_swap_case {
    my $s = $_[0]
    my @chars = ~> $s chars
    my @res = @chars |> map {
        if ($_ eq uc($_)) {
            lc($_)
        } else {
            uc($_)
        }
    }
    join("", @res)
}

assert_eq to_upper("hello"), "HELLO", "upper"
assert_eq to_lower("HELLO"), "hello", "lower"
assert_eq to_upper("Hello World"), "HELLO WORLD", "upper phrase"
assert_eq to_lower("Hello World"), "hello world", "lower phrase"

assert_eq to_title("hello world"), "Hello World", "title case"
assert_eq to_title("THE QUICK BROWN FOX"), "The Quick Brown Fox", "title from upper"

assert_eq my_swap_case("Hello"), "hELLO", "swap case hello"
assert_eq my_swap_case("HeLLo WoRLD"), "hEllO wOrld", "swap mixed"

assert_eq ucfirst("hello"), "Hello", "ucfirst"
assert_eq lcfirst("HELLO"), "hELLO", "lcfirst"

test_run
