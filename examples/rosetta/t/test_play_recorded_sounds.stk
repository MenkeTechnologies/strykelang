#!/usr/bin/env stryke
# Rosetta Code: Play recorded sounds

fn Rosetta::Playback::player() {
    val @history
    { history => \@history }
}

fn Rosetta::Playback::play($player, $clip) {
    push @{$player->{history}}, $clip->{name}
    len(@{$player->{history}})
}

val $player = Rosetta::Playback::player()
val $clip = { name => "beep.wav", samples => [1, 0, -1, 0] }

assert_eq Rosetta::Playback::play($player, $clip), 1, "clip playback recorded"
assert_eq join(",", @{$player->{history}}), "beep.wav", "played clip name stored"

test_run
