#!/usr/bin/env stryke
# Rosetta Code: Arithmetic Mean

fn my_arithmetic_mean(@nums) {
    if (!@nums) {
        0
    } else {
        (@nums |> reduce { $a + $b }) / scalar(@nums)
    }
}

fn my_geometric_mean(@nums) {
    if (!@nums) {
        0
    } else {
        my $product = @nums |> reduce { $a * $b }
        $product ** (1 / scalar(@nums))
    }
}

fn my_harmonic_mean(@nums) {
    if (!@nums) {
        0
    } else {
        my $sum = @nums |> map { 1 / $_ } |> reduce { $a + $b }
        scalar(@nums) / $sum
    }
}

assert_eq my_arithmetic_mean(1, 2, 3, 4, 5), 3, "mean 1..5"
assert_eq my_arithmetic_mean(10, 20, 30), 20, "mean 10,20,30"
assert_eq my_arithmetic_mean(5), 5, "mean single"

my $gm = my_geometric_mean(1, 2, 4, 8)
assert_ok abs($gm - 2.828) < 0.01, "geometric mean"

my $hm = my_harmonic_mean(1, 2, 4)
assert_ok abs($hm - 1.714) < 0.01, "harmonic mean"

test_run
