#!/usr/bin/env stryke
# Rosetta Code: Multisplit
# Split a string by *any* of a list of separator strings, taking the
# longest match at each position. Return the list of pieces in order.

fn Rosetta::Multisplit::split($s, $seps) {
    var @parts
    val @sep_sorted = sort { length(_1) <=> length(_) } @$seps
    var $i = 0
    var $start = 0
    val $n = length($s)
    while ($i < $n) {
        var $matched = 0
        for val $sep (@sep_sorted) {
            val $sl = length($sep)
            if ($sl > 0 && $i + $sl <= $n && substr($s, $i, $sl) eq $sep) {
                push @parts, substr($s, $start, $i - $start)
                $i += $sl
                $start = $i
                $matched = 1
                last
            }
        }
        $i++ if !$matched
    }
    push @parts, substr($s, $start, $n - $start)
    @parts
}

# Rosetta canonical: split "a!===b=!=c" on ["==", "!=", "="]
# Longest-match-first eats "!=" then "==", giving 5 pieces with two empties.
val @r = Rosetta::Multisplit::split("a!===b=!=c", ["==", "!=", "="])
assert_eq join("|", @r), "a||b||c", "rosetta canonical sample"

# Single delimiter
val @r2 = Rosetta::Multisplit::split("a,b,c,d", [","])
assert_eq join("|", @r2), "a|b|c|d", "csv-like"

# Multiple non-overlapping
val @r3 = Rosetta::Multisplit::split("foo--bar++baz", ["--", "++"])
assert_eq join("|", @r3), "foo|bar|baz", "two delimiters"

# Longest-match priority: "==" beats "=" at same offset
val @r4 = Rosetta::Multisplit::split("==", ["=", "=="])
assert_eq join("|", @r4), "|", "== consumed as single"

# Empty haystack
val @r5 = Rosetta::Multisplit::split("", [","])
assert_eq join("|", @r5), "", "empty input → single empty piece"

# No matches
val @r6 = Rosetta::Multisplit::split("hello", [",", ";"])
assert_eq join("|", @r6), "hello", "no separators present"

# Pipe form
"x:y;z" |> fn { Rosetta::Multisplit::split(_, [":", ";"]) } |> join("|") |> assert_eq("x|y|z", "pipe split")

test_run
