#!/usr/bin/env stryke
# Rosetta Code: Tree Sort

fn Rosetta::TreeSort::insert_node($n, $v) {
    if (!defined $n) { return { val => $v, left => undef, right => undef } }
    if ($v < $n->{val}) {
        $n->{left} = Rosetta::TreeSort::insert_node($n->{left}, $v)
    } else {
        $n->{right} = Rosetta::TreeSort::insert_node($n->{right}, $v)
    }
    $n
}

fn Rosetta::TreeSort::inorder($n, $res) {
    if (!$n) { return }
    Rosetta::TreeSort::inorder($n->{left}, $res)
    push @$res, $n->{val}
    Rosetta::TreeSort::inorder($n->{right}, $res)
}

fn Rosetta::TreeSort::tree_sort($list) {
    my $root = undef
    for my $v (@$list) {
        $root = Rosetta::TreeSort::insert_node($root, $v)
    }
    my @res
    my $r = \@res
    Rosetta::TreeSort::inorder($root, $r)
    $r
}

my @input = (5, 3, 8, 1, 9, 2, 7, 4, 6)
my $sorted = Rosetta::TreeSort::tree_sort(\@input)
assert_eq join(",", @$sorted), "1,2,3,4,5,6,7,8,9", "tree sort"

test_run
