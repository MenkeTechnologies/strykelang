#!/usr/bin/env stryke
# Rosetta Code: 3SUM — find every unique triple (a, b, c) in an array
# such that a + b + c == target. Sort + two-pointer gives O(n²).

fn Rosetta::ThreeSum::find($nums, $target) {
    val @sorted = sort { _0 <=> _1 } @$nums
    val $n = len(@sorted)
    var @triples
    for val $i (~> 0:$n - 3) {
        next if $i > 0 && $sorted[$i] == $sorted[$i - 1]
        var ($l, $r) = ($i + 1, $n - 1)
        while ($l < $r) {
            val $sum = $sorted[$i] + $sorted[$l] + $sorted[$r]
            if ($sum == $target) {
                push @triples, [$sorted[$i], $sorted[$l], $sorted[$r]]
                $l++
                $r--
                while ($l < $r && $sorted[$l] == $sorted[$l - 1]) { $l++ }
                while ($l < $r && $sorted[$r] == $sorted[$r + 1]) { $r-- }
            } elsif ($sum < $target) { $l++ }
            else                     { $r-- }
        }
    }
    \@triples
}

fn Rosetta::ThreeSum::format_triples($t) {
    var @rows
    for val $triple (@$t) { push @rows, join(",", @$triple) }
    @rows = sort { _0 cmp _1 } @rows
    join(";", @rows)
}

# LeetCode 15 canonical case: [-1, 0, 1, 2, -1, -4], target=0
# Expected triples: (-1, -1, 2), (-1, 0, 1)
val $r1 = Rosetta::ThreeSum::find([-1, 0, 1, 2, -1, -4], 0)
assert_eq Rosetta::ThreeSum::format_triples($r1), "-1,-1,2;-1,0,1",
    "LC 15 example"

# All zeros: only one triple (0, 0, 0).
val $r2 = Rosetta::ThreeSum::find([0, 0, 0, 0], 0)
assert_eq Rosetta::ThreeSum::format_triples($r2), "0,0,0", "all zeros"

# No triple sums to target
val $r3 = Rosetta::ThreeSum::find([1, 2, 3, 4, 5], 100)
assert_eq len(@$r3), 0, "no triples for unreachable target"

# Non-zero target
val $r4 = Rosetta::ThreeSum::find([1, 2, 3, 4, 5, 6, 7, 8, 9], 12)
assert_eq Rosetta::ThreeSum::format_triples($r4),
    "1,2,9;1,3,8;1,4,7;1,5,6;2,3,7;2,4,6;3,4,5", "target=12"

# Negative target
val $r5 = Rosetta::ThreeSum::find([-5, -4, -3, -2, -1, 0, 1, 2, 3], -6)
# Triples summing to -6: (-5,-4,3), (-5,-3,2), (-5,-2,1), (-5,-1,0),
# (-4,-3,1), (-4,-2,0), (-3,-2,-1). Sorted lexicographically.
val $expected = "-3,-2,-1;-4,-2,0;-4,-3,1;-5,-1,0;-5,-2,1;-5,-3,2;-5,-4,3"
assert_eq Rosetta::ThreeSum::format_triples($r5), $expected, "target=-6"

# Duplicates in input — output stays unique.
val $r6 = Rosetta::ThreeSum::find([2, 2, 2, 2, 2], 6)
assert_eq Rosetta::ThreeSum::format_triples($r6), "2,2,2", "duplicate-only"

# Triples must be distinct: don't double-count.
val $r7 = Rosetta::ThreeSum::find([-2, 0, 0, 2, 2], 0)
assert_eq Rosetta::ThreeSum::format_triples($r7), "-2,0,2", "dedup with multiple zeros"

# Insufficient input
assert_eq len(@{Rosetta::ThreeSum::find([], 0)}), 0, "empty"
assert_eq len(@{Rosetta::ThreeSum::find([1], 0)}), 0, "n=1"
assert_eq len(@{Rosetta::ThreeSum::find([1, 2], 0)}), 0, "n=2"

# Single-triple input
val $r8 = Rosetta::ThreeSum::find([1, 2, 3], 6)
assert_eq Rosetta::ThreeSum::format_triples($r8), "1,2,3", "exact n=3 match"
val $r9 = Rosetta::ThreeSum::find([1, 2, 3], 7)
assert_eq len(@$r9), 0, "n=3 no match"

test_run
