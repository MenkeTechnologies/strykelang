#!/usr/bin/env stryke
# Rosetta Code: Tarjan's strongly connected components

fn Rosetta::Tarjan::run($graph) {
    var $state = {
        index    => 0,
        stack    => [],
        on_stack => {},
        idx      => {},
        lowlink  => {},
        sccs     => []
    }
    for val $node (sort keys %$graph) {
        if (!exists $state->{idx}->{$node}) {
            Rosetta::Tarjan::strongconnect($graph, $node, $state)
        }
    }
    $state->{sccs}
}

fn Rosetta::Tarjan::strongconnect($graph, $v, $state) {
    $state->{idx}->{$v}     = $state->{index}
    $state->{lowlink}->{$v} = $state->{index}
    $state->{index}        += 1
    push @{$state->{stack}}, $v
    $state->{on_stack}->{$v} = 1

    val $neighbors = $graph->{$v}
    if (defined $neighbors) {
        for val $w (@$neighbors) {
            if (!exists $state->{idx}->{$w}) {
                Rosetta::Tarjan::strongconnect($graph, $w, $state)
                val $a = $state->{lowlink}->{$v}
                val $b = $state->{lowlink}->{$w}
                $state->{lowlink}->{$v} = $a < $b ? $a : $b
            } elsif ($state->{on_stack}->{$w}) {
                val $a = $state->{lowlink}->{$v}
                val $b = $state->{idx}->{$w}
                $state->{lowlink}->{$v} = $a < $b ? $a : $b
            }
        }
    }

    if ($state->{lowlink}->{$v} == $state->{idx}->{$v}) {
        var @scc
        while (1) {
            val $w = pop @{$state->{stack}}
            $state->{on_stack}->{$w} = 0
            push @scc, $w
            last if $w eq $v
        }
        push @{$state->{sccs}}, [sort @scc]
    }
}

# Wikipedia example
val $g = {
    "1" => ["2"],
    "2" => ["3"],
    "3" => ["1"],
    "4" => ["2", "3", "5"],
    "5" => ["4", "6"],
    "6" => ["3", "7"],
    "7" => ["6"],
    "8" => ["5", "7", "8"]
}

val $sccs = Rosetta::Tarjan::run($g)
val @sorted = sort { join(",", @{_0}) cmp join(",", @{_1}) } @$sccs
val @flat = map { join(",", @{_}) } @sorted
assert_eq join("|", @flat), "1,2,3|4,5|6,7|8", "Wikipedia SCCs"

# Single-node graph
val $single = { "x" => [] }
val $r1 = Rosetta::Tarjan::run($single)
assert_eq len(@$r1), 1, "single node = 1 SCC"
assert_eq $r1->[0]->[0], "x", "the node"

# Disconnected pair: each its own SCC
val $disc = { "a" => [], "b" => [] }
val $r2 = Rosetta::Tarjan::run($disc)
assert_eq len(@$r2), 2, "disconnected = 2 SCCs"

# Cycle of 4: one SCC of 4
val $cycle = { "a" => ["b"], "b" => ["c"], "c" => ["d"], "d" => ["a"] }
val $r3 = Rosetta::Tarjan::run($cycle)
assert_eq len(@$r3), 1, "cycle = 1 SCC"
assert_eq len(@{$r3->[0]}), 4, "cycle SCC has 4 members"

test_run
