#!/usr/bin/env stryke
# Rosetta Code: Increment a numerical string

fn Rosetta::IncrementString::demo() {
    "Increment Numerical String Examples:" |> p
    
    # Basic string to number conversion and increment
    val $str1 = "42"
    val $num1 = $str1 + 1
    "String '$str1' incremented: $num1" |> p
    
    # Decimal numbers
    val $str2 = "3.14159"
    val $num2 = $str2 + 0.1
    "String '$str2' + 0.1: $num2" |> p
    
    # Leading zeros preservation
    val $str3 = "0042"
    val $incremented = sprintf("%04d", $str3 + 1)
    "String '$str3' incremented (preserving format): $incremented" |> p
    
    # Negative numbers
    val $str4 = "-15"
    val $num4 = $str4 + 1
    "String '$str4' incremented: $num4" |> p
    
    # Large numbers
    val $str5 = "999999999999999"
    val $num5 = $str5 + 1
    "Large string '$str5' incremented: $num5" |> p
    
    # Hexadecimal (if supported)
    val $hex_str = "FF"
    val $hex_num = hex($hex_str) + 1
    "Hex '$hex_str' incremented: $hex_num (decimal)" |> p
    
    # Array of string numbers
    var @str_numbers = ("1", "10", "100", "1000")
    "Array increment:" |> p
    for val $s (@str_numbers) {
        val $inc = $s + 1
        "  '$s' -> $inc" |> p
    }
    
    # Threading example
    val $result = ~> "2023" >{ _ + 1 }
}

Rosetta::IncrementString::demo()
test_run
