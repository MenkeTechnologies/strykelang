#!/usr/bin/env stryke
# Rosetta Code: Stable marriage problem

fn Rosetta::StableMarriage::solve($guys_pref, $girls_pref) {
    var $guys_match = {}
    var $girls_match = {}
    var @free_guys = keys %$guys_pref
    
    var $girls_rank = {}
    for val $girl (keys %$girls_pref) {
        $girls_rank->{$girl} = {}
        var $rank = 0
        for val $guy (@{$girls_pref->{$girl}}) {
            $girls_rank->{$girl}{$guy} = $rank++
        }
    }
    
    var $proposals = {}
    while (len(@free_guys) > 0) {
        val $guy = shift @free_guys
        val $pref_list = $guys_pref->{$guy}
        val $idx = $proposals->{$guy} || 0
        val $girl = $pref_list->[$idx]
        $proposals->{$guy} = $idx + 1
        
        if (!exists $girls_match->{$girl}) {
            $girls_match->{$girl} = $guy
            $guys_match->{$guy} = $girl
        } else {
            val $current_guy = $girls_match->{$girl}
            if ($girls_rank->{$girl}{$guy} < $girls_rank->{$girl}{$current_guy}) {
                $girls_match->{$girl} = $guy
                $guys_match->{$guy} = $girl
                push @free_guys, $current_guy
                # Clean up old match
                delete $guys_match->{$current_guy}
            } else {
                push @free_guys, $guy
            }
        }
    }
    $guys_match
}

val $guys = {
    "abe" => ["abi", "eve", "ivon"],
    "bob" => ["eve", "abi", "ivon"],
    "col" => ["abi", "eve", "ivon"]
}
val $girls = {
    "abi" => ["bob", "abe", "col"],
    "eve" => ["abe", "bob", "col"],
    "ivon" => ["abe", "bob", "col"]
}

val $res = Rosetta::StableMarriage::solve($guys, $girls)
assert_eq $res->{abe}, "abi", "abe matched with abi"
assert_eq $res->{bob}, "eve", "bob matched with eve"
assert_eq $res->{col}, "ivon", "col matched with ivon"

test_run
