#!/usr/bin/env stryke
# Rosetta Code: Ray-casting algorithm

fn Rosetta::RayCasting::is_inside($point, $polygon) {
    my $x = $point->[0]
    my $y = $point->[1]
    
    my $inside = 0
    my $n = len(@$polygon)
    
    my $p1 = $polygon->[0]
    for my $i (1:$n) {
        my $p2 = $polygon->[$i % $n]
        
        my $y_min = $p1->[1] < $p2->[1] ? $p1->[1] : $p2->[1]
        my $y_max = $p1->[1] > $p2->[1] ? $p1->[1] : $p2->[1]
        
        if ($y > $y_min && $y <= $y_max) {
            my $x_min = $p1->[0] < $p2->[0] ? $p1->[0] : $p2->[0]
            my $x_max = $p1->[0] > $p2->[0] ? $p1->[0] : $p2->[0]
            
            if ($x <= $x_max) {
                if ($p1->[1] != $p2->[1]) {
                    my $x_intersect = ($y - $p1->[1]) * ($p2->[0] - $p1->[0]) / ($p2->[1] - $p1->[1]) + $p1->[0]
                    if ($p1->[0] == $p2->[0] || $x <= $x_intersect) {
                        $inside = !$inside
                    }
                }
            }
        }
        $p1 = $p2
    }
    $inside
}

my $square = [[0, 0], [10, 0], [10, 10], [0, 10]]
my $p_in = [5, 5]
my $p_out = [15, 5]

assert_ok Rosetta::RayCasting::is_inside($p_in, $square), "Point is inside square"
assert_ok !Rosetta::RayCasting::is_inside($p_out, $square), "Point is outside square"

test_run
