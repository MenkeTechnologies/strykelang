#!/usr/bin/env stryke
# Rosetta Code: Ray-casting algorithm

fn Rosetta::RayCasting::is_inside($point, $polygon) {
    val $x = $point->[0]
    val $y = $point->[1]
    
    var $inside = 0
    val $n = len(@$polygon)
    
    var $p1 = $polygon->[0]
    for val $i (1:$n) {
        val $p2 = $polygon->[$i % $n]
        
        val $y_min = $p1->[1] < $p2->[1] ? $p1->[1] : $p2->[1]
        val $y_max = $p1->[1] > $p2->[1] ? $p1->[1] : $p2->[1]
        
        if ($y > $y_min && $y <= $y_max) {
            val $x_min = $p1->[0] < $p2->[0] ? $p1->[0] : $p2->[0]
            val $x_max = $p1->[0] > $p2->[0] ? $p1->[0] : $p2->[0]
            
            if ($x <= $x_max) {
                if ($p1->[1] != $p2->[1]) {
                    val $x_intersect = ($y - $p1->[1]) * ($p2->[0] - $p1->[0]) / ($p2->[1] - $p1->[1]) + $p1->[0]
                    if ($p1->[0] == $p2->[0] || $x <= $x_intersect) {
                        $inside = !$inside
                    }
                }
            }
        }
        $p1 = $p2
    }
    $inside
}

val $square = [[0, 0], [10, 0], [10, 10], [0, 10]]
val $p_in = [5, 5]
val $p_out = [15, 5]

assert_ok Rosetta::RayCasting::is_inside($p_in, $square), "Point is inside square"
assert_ok !Rosetta::RayCasting::is_inside($p_out, $square), "Point is outside square"

test_run
