#!/usr/bin/env stryke
# Rosetta Code: Cuban primes

fn Rosetta::CubanPrimes::formula($y) {
    3 * $y * $y + 3 * $y + 1
}

fn Rosetta::CubanPrimes::generate($count) {
    my @res
    my $y = 1
    while (len(@res) < $count) {
        my $p = Rosetta::CubanPrimes::formula($y)
        if (is_prime($p)) {
            push @res, $p
        }
        $y++
    }
    \@res
}

assert_eq join(",", @{ Rosetta::CubanPrimes::generate(5) }), "7,19,37,61,127", "first 5 cuban primes"

5 |> Rosetta::CubanPrimes::generate |> map { join(",", @$_) } |> assert_eq("7,19,37,61,127", "pipe cuban")

test_run
