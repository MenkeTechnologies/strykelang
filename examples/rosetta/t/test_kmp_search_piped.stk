#!/usr/bin/env stryke
# Rosetta Code: Knuth-Morris-Pratt string search (piped)

fn Rosetta::KMP::compute_lps($p) {
    val @chars = $p |> chars
    val $m = len(@chars)
    var @lps = ~> 0:$m-1 map { 0 }
    var $len = 0
    var $i = 1
    
    while ($i < $m) {
        if ($chars[$i] eq $chars[$len]) {
            $len++
            $lps[$i] = $len
            $i++
        } else {
            if ($len != 0) {
                $len = $lps[$len - 1]
            } else {
                $lps[$i] = 0
                $i++
            }
        }
    }
    \@lps
}

fn Rosetta::KMP::search($text, $pattern) {
    val @t = $text |> chars
    val @p = $pattern |> chars
    val $n = len(@t)
    val $m = len(@p)
    return 0 if $m == 0
    
    val $lps = Rosetta::KMP::compute_lps($pattern)
    var @indices
    
    var $i = 0
    var $j = 0
    while ($i < $n) {
        if ($p[$j] eq $t[$i]) {
            $i++; $j++
        }
        if ($j == $m) {
            push @indices, $i - $j
            $j = $lps->[$j - 1]
        } elsif ($i < $n && $p[$j] ne $t[$i]) {
            if ($j != 0) {
                $j = $lps->[$j - 1]
            } else {
                $i++
            }
        }
    }
    \@indices
}

val $res = Rosetta::KMP::search("ABABDABACDABABCABAB", "ABABCABAB")
assert_eq join(",", @$res), "10", "found pattern at 10"

val $res2 = Rosetta::KMP::search("aaaaa", "aa")
assert_eq join(",", @$res2), "0,1,2,3", "found all overlapping aa"

val $res3 = Rosetta::KMP::search("abc", "def")
assert_eq len(@$res3), 0, "not found"

test_run
