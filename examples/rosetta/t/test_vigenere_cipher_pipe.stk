#!/usr/bin/env stryke
# Rosetta Code: Vigenère cipher (using pipes)

fn Rosetta::Vigenere::solve($text, $key, $mode) {
    my @text_chars = $text |> uc() |> chars() |> grep { $_ =~ /[A-Z]/ }
    my @key_chars  = $key |> uc() |> chars() |> grep { $_ =~ /[A-Z]/ }
    my $key_len = scalar(@key_chars)
    
    ~> 0:$#text_chars map {
        my $i = $_
        my $p = ord($text_chars[$i]) - 65
        my $k = ord($key_chars[$i % $key_len]) - 65
        my $c
        if ($mode eq "encrypt") {
            $c = ($p + $k) % 26
        } else {
            $c = ($p - $k + 26) % 26
        }
        chr($c + 65)
    } |> join("")
}

my $t = "Beware the Jabberwock, my son! The jaws that bite, the claws that catch!"
my $k = "VIGENERECIPHER"
my $enc = Rosetta::Vigenere::solve($t, $k, "encrypt")
my $dec = Rosetta::Vigenere::solve($enc, $k, "decrypt")

assert_eq $enc, "WMCEEIKLGRPIFVMEUGXQPWQVIOIAVEYXUEKFKBTALVXTGAFXYEVKPAGY", "encrypt"
assert_eq $dec, "BEWARETHEJABBERWOCKMYSONTHEJAWSTHATBITETHECLAWSTHATCATCH", "decrypt"

test_run
