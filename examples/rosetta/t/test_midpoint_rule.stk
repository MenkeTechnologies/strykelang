#!/usr/bin/env stryke
# Rosetta Code: Midpoint-rule numerical integration.
# Approximates integral f(x) dx on [a, b] with n equal-width strips,
# evaluating f at each strip's midpoint.

fn Rosetta::Midpoint::integrate($f, $lo, $hi, $n) {
    my $h   = ($hi - $lo) / $n
    my $sum = 0.0
    for my $i (0 .. $n - 1) {
        my $x = $lo + $h * ($i + 0.5)
        $sum += $f->($x)
    }
    $h * $sum
}

# integral_0^1 x^2 dx = 1/3 (exactly 0.3333...)
my $r1 = Rosetta::Midpoint::integrate(fn ($x) { $x * $x }, 0, 1, 1000)
assert_ok abs($r1 - 1.0/3.0) < 1e-6, "x^2 on [0,1] → 1/3"

# integral_0^pi sin(x) dx = 2.
my $pi = 3.141592653589793
my $r2 = Rosetta::Midpoint::integrate(fn ($x) { sin($x) }, 0, $pi, 1000)
assert_ok abs($r2 - 2.0) < 1e-6, "sin on [0, pi] → 2"

# integral_1^e (1/x) dx = 1.
my $e = 2.718281828459045
my $r3 = Rosetta::Midpoint::integrate(fn ($x) { 1.0 / $x }, 1, $e, 1000)
assert_ok abs($r3 - 1.0) < 1e-6, "1/x on [1, e] → 1"

# Constant integrand → exact (h * sum of 1s, all rectangles align).
my $r4 = Rosetta::Midpoint::integrate(fn ($x) { 7 }, 0, 5, 100)
assert_ok abs($r4 - 35.0) < 1e-12, "constant 7 on [0, 5] → 35"

test_run
