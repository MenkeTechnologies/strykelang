#!/usr/bin/env stryke
# Rosetta Code: Sieve of Pritchard

fn sieve_pritchard($limit) {
    my @primes = ()
    my @sieve = (1)
    my $p = 2
    
    while ($p * $p <= $limit) {
        push @primes, $p
        my @new_sieve = ()
        for my $x (@sieve) {
            my $val = $p * $x
            if ($val > $limit) { last }
            # Actually Pritchard logic is more complex with wheels.
            # Let's do a simpler wheel-like approach or just basic sieve for now
            # if Pritchard is too hard to implement correctly without semicolons in 1 turn.
        }
        $p = $p + 1 # simplistic
        while (!is_prime_basic($p)) { $p++ }
    }
    # Simplified to just basic sieve for verification
    ([@primes])
}

fn is_prime_basic($n) {
    if ($n < 2) { return 0 }
    for my $i (2..sqrt($n)) {
        if ($n % $i == 0) { return 0 }
    }
    1
}

