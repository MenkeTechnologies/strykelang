#!/usr/bin/env stryke
# Rosetta Code: Mastermind

fn Rosetta::Mastermind::score($secret, $guess) {
    var @s = @$secret
    val @g = @$guess
    var $bulls = 0
    var $cows = 0
    
    var @s_remaining
    var @g_remaining
    
    for (var $i = 0; $i < len(@s); $i++) {
        if ($s[$i] eq $g[$i]) {
            $bulls++
        } else {
            push @s_remaining, $s[$i]
            push @g_remaining, $g[$i]
        }
    }
    
    var %s_counts
    $s_counts{_}++ for @s_remaining
    
    for val $char (@g_remaining) {
        if ($s_counts{$char} > 0) {
            $cows++
            $s_counts{$char}--
        }
    }
    
    { bulls => $bulls, cows => $cows }
}

val $s1 = ["R", "G", "B", "Y"]
val $g1 = ["R", "B", "G", "W"]
val $res1 = Rosetta::Mastermind::score($s1, $g1)
assert_eq $res1->{bulls}, 1, "1 bull"
assert_eq $res1->{cows}, 2, "2 cows"

val $s2 = ["R", "R", "G", "G"]
val $g2 = ["G", "G", "R", "R"]
val $res2 = Rosetta::Mastermind::score($s2, $g2)
assert_eq $res2->{bulls}, 0, "0 bulls"
assert_eq $res2->{cows}, 4, "4 cows"

val $s3 = ["A", "B", "C", "D"]
val $g3 = ["A", "B", "C", "D"]
val $res3 = Rosetta::Mastermind::score($s3, $g3)
assert_eq $res3->{bulls}, 4, "4 bulls"
assert_eq $res3->{cows}, 0, "0 cows"

test_run
