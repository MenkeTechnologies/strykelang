#!/usr/bin/env stryke
# Rosetta Code: Sastry numbers

fn Rosetta::SastryNumbers::is_sastry($n) {
    val $m = $n + 1
    val $s = "$n" . "$m"
    val $val = int($s)
    val $root = int(sqrt($val))
    $root * $root == $val
}

assert_ok Rosetta::SastryNumbers::is_sastry(183), "183 is Sastry (183184 = 428^2)"
assert_ok Rosetta::SastryNumbers::is_sastry(328), "328 is Sastry (328329 = 573^2)"
assert_ok !Rosetta::SastryNumbers::is_sastry(1), "1 is not (12 is not square)"

183 |> Rosetta::SastryNumbers::is_sastry |> assert_ok("pipe Sastry")

test_run
