#!/usr/bin/env stryke
# Rosetta Code: Horner's Method and Polynomial Eval

fn algo_horner($coeffs, $x) {
    my $res = 0.0
    for my $c (rev @$coeffs) {
        $res = $res * $x + $c
    }
    $res
}

# 3x^2 + 2x + 1 at x=3 => 3(9) + 2(3) + 1 = 27 + 6 + 1 = 34
my $poly = [1, 2, 3] # low to high
assert_eq algo_horner($poly, 3), 34, "horner 3x^2+2x+1 at x=3"
test_run
