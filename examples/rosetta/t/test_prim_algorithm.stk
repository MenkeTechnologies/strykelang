#!/usr/bin/env stryke
# Rosetta Code: Prim's algorithm

fn Rosetta::Prim::solve($n, $edges) {
    var $adj = {}
    for val $i (0:$n-1) { $adj->{$i} = [] }
    for val $e (@$edges) {
        var ($u, $v, $w) = @$e
        push @{$adj->{$u}}, [$v, $w]
        push @{$adj->{$v}}, [$u, $w]
    }
    
    var %visited = (0 => 1)
    var @mst = ()
    var $total_w = 0
    
    while (len(keys %visited) < $n) {
        var $min_edge = undef
        var $min_w = 1e18
        
        for val $u (keys %visited) {
            for val $v_ref (@{$adj->{$u}}) {
                val ($v, $w) = @$v_ref
                if (!exists $visited{$v} && $w < $min_w) {
                    $min_w = $w
                    $min_edge = [$u, $v, $w]
                }
            }
        }
        
        if (!defined($min_edge)) { last }
        
        push @mst, $min_edge
        $total_w += $min_edge->[2]
        $visited{$min_edge->[1]} = 1
    }
    [$total_w, [@mst]]
}

val $edges = [
    [0, 1, 10],
    [0, 2, 6],
    [0, 3, 5],
    [1, 3, 15],
    [2, 3, 4]
]
val $res = Rosetta::Prim::solve(4, $edges)
assert_eq $res->[0], 19, "Prim MST total weight is 19"

test_run
