#!/usr/bin/env stryke
# Rosetta Code: Repunit primes

fn Rosetta::Repunit::isPrime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        val $limit = sqrt($n)
        var $res = 1
        var $i = 3
        while ($i <= $limit) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
            $i += 2
        }
        $res
    }
}

fn Rosetta::Repunit::repunit($n) {
    var $r = 0
    var $i = 0
    while ($i < $n) {
        $r = $r * 10 + 1
        $i++
    }
    $r
}

fn Rosetta::RepunitPrime::is_repunit_prime($n) {
    if (!Rosetta::Repunit::isPrime($n)) {
        0
    } else {
        val $r = Rosetta::Repunit::repunit($n)
        Rosetta::Repunit::isPrime($r)
    }
}

assert_ok Rosetta::RepunitPrime::is_repunit_prime(2), "R2 = 11 is prime"
assert_ok !Rosetta::RepunitPrime::is_repunit_prime(3), "R3 = 111 is not (3*37)"
assert_ok !Rosetta::RepunitPrime::is_repunit_prime(5), "R5 = 11111 is not (41*271)"

2 |> Rosetta::RepunitPrime::is_repunit_prime |> assert_ok("pipe Rosetta::Repunit::repunit prime")

test_run
