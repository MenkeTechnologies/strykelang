#!/usr/bin/env stryke
# Rosetta Code: Deceptive numbers — composite repunit-divisors (n divides R_{n-1})

fn Rosetta::Deceptive::is_prime($n) {
    return 0 if $n < 2
    return 1 if $n == 2
    return 0 if $n % 2 == 0
    my $i = 3
    while ($i * $i <= $n) {
        return 0 if $n % $i == 0
        $i += 2
    }
    1
}

# n is deceptive iff n is composite AND 10^(n-1) ≡ 1 (mod 9n) — equivalently
# (10^(n-1) - 1) / 9, the repunit R_{n-1}, is divisible by n.
fn Rosetta::Deceptive::is_deceptive($n) {
    return 0 if $n < 4 || Rosetta::Deceptive::is_prime($n)
    return 0 if $n % 2 == 0 || $n % 5 == 0
    # Compute 10^(n-1) mod 9n via fast exponentiation.
    my $m = 9 * $n
    my $base = 10 % $m
    my $exp = $n - 1
    my $r = 1 % $m
    while ($exp > 0) {
        if ($exp % 2 == 1) { $r = ($r * $base) % $m }
        $base = ($base * $base) % $m
        $exp = int($exp / 2)
    }
    $r == 1
}

fn Rosetta::Deceptive::first_n($count) {
    my @res
    my $n = 9
    while (len(@res) < $count) {
        push @res, $n if Rosetta::Deceptive::is_deceptive($n)
        $n += 2
    }
    @res
}

# OEIS A000864: 91, 259, 451, 481, 703, 1729, 2821, 2981, 3367, 4141, ...
my @first10 = Rosetta::Deceptive::first_n(10)
assert_eq join(",", @first10),
    "91,259,451,481,703,1729,2821,2981,3367,4141",
    "first 10 deceptive numbers"

assert_ok  Rosetta::Deceptive::is_deceptive(91),  "91 deceptive"
assert_ok  Rosetta::Deceptive::is_deceptive(703), "703 deceptive"
assert_ok !Rosetta::Deceptive::is_deceptive(7),   "7 prime"

test_run
