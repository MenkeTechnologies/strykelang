#!/usr/bin/env stryke
# Rosetta Code: File size distribution

fn Rosetta::FileSize::distribution($bucket_size, @sizes) {
    var %dist
    for val $size (@sizes) {
        val $bucket = int($size / $bucket_size) * $bucket_size
        $dist{$bucket}++
    }
    \%dist
}

val @sizes = (10, 15, 25, 45, 105, 120, 500)
val $dist = Rosetta::FileSize::distribution(100, @sizes)

assert_eq $dist->{0}, 4, "4 files < 100"
assert_eq $dist->{100}, 2, "2 files 100-199"
assert_eq $dist->{500}, 1, "1 file 500-599"

test_run
