#!/usr/bin/env stryke
# Rosetta Code: Reverse a String

fn Rosetta::ReverseString::string($s) {
    ~> $s chars rev |> join ""
}

fn Rosetta::ReverseString::words($s) {
    ~> $s >{split /\s+/, $_} rev |> join " "
}

fn Rosetta::ReverseString::each_word($s) {
    $s |> split /\s+/ |> map { Rosetta::ReverseString::string($_) } |> join " "
}

assert_eq Rosetta::ReverseString::string("hello"), "olleh", "reverse hello"
assert_eq Rosetta::ReverseString::string("racecar"), "racecar", "palindrome unchanged"
assert_eq Rosetta::ReverseString::string("a"), "a", "single char"
assert_eq Rosetta::ReverseString::string(""), "", "empty string"
assert_eq Rosetta::ReverseString::string("12345"), "54321", "reverse digits"

assert_eq Rosetta::ReverseString::words("hello world"), "world hello", "reverse words"
assert_eq Rosetta::ReverseString::words("one two three"), "three two one", "reverse 3 words"

assert_eq Rosetta::ReverseString::each_word("hello world"), "olleh dlrow", "reverse each word"

test_run
