#!/usr/bin/env stryke
# Rosetta Code: Gapful numbers

fn Rosetta::Gapful::check($n) {
    my $s = "$n"
    my $len = length($s)
    if ($len < 3) {
        0
    } else {
        my @c = chars($s)
        my $divisor = int($c[0] . $c[$len-1])
        $n % $divisor == 0
    }
}

assert_ok Rosetta::Gapful::check(187), "187 is gapful (187 % 17 == 0)"
assert_ok Rosetta::Gapful::check(100), "100 is gapful (100 % 10 == 0)"
assert_ok !Rosetta::Gapful::check(188), "188 is not gapful"
assert_ok !Rosetta::Gapful::check(10), "10 is too short"

187 |> Rosetta::Gapful::check |> assert_ok("pipe gapful")

test_run
