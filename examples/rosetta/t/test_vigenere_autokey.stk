#!/usr/bin/env stryke
# Rosetta Code: Vigenère cipher with autokey — key = primer + plaintext

fn Rosetta::VigAuto::clean($s) {
    var $r = uc($s)
    $r =~ s/[^A-Z]//g
    $r
}

fn Rosetta::VigAuto::encrypt($plain, $primer) {
    val $p = Rosetta::VigAuto::clean($plain)
    val $k = Rosetta::VigAuto::clean($primer) . $p
    val @pc = ~> $p chars
    val @kc = ~> $k chars
    var $out = ""
    for val $i (0..len(@pc)-1) {
        val $shift = ord($kc[$i]) - ord("A")
        val $base  = ord($pc[$i]) - ord("A")
        $out .= chr(ord("A") + ($base + $shift) % 26)
    }
    $out
}

fn Rosetta::VigAuto::decrypt($cipher, $primer) {
    val $c = Rosetta::VigAuto::clean($cipher)
    var $k = Rosetta::VigAuto::clean($primer)
    val @cc = ~> $c chars
    var $out = ""
    for val $i (0..len(@cc)-1) {
        val @kc = ~> $k chars
        val $shift = ord($kc[$i]) - ord("A")
        val $base  = ord($cc[$i]) - ord("A")
        val $p_char = chr(ord("A") + (($base - $shift) % 26 + 26) % 26)
        $out .= $p_char
        $k .= $p_char
    }
    $out
}

# Wikipedia Vigenère-autokey worked example: plaintext "ATTACKATDAWN" with primer "QUEENLY"
# yields ciphertext "QNXEPVYTWTWP" under (P+K) mod 26 with K = primer + plaintext.
assert_eq Rosetta::VigAuto::encrypt("ATTACKATDAWN", "QUEENLY"),
    "QNXEPVYTWTWP", "Wikipedia worked example"

assert_eq Rosetta::VigAuto::decrypt("QNXEPVYTWTWP", "QUEENLY"),
    "ATTACKATDAWN", "decrypt Wikipedia example"

# Round-trip
val @primers = ("KILT", "STRIKE", "RUST", "ZEBRA")
val @messages = (
    "ATTACKATDAWN",
    "RUNAWAYNOWWHILEYOUSTILLCAN",
    "THISISATESTOFTHEAUTOKEYVIGENERECIPHER",
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
)
for val $primer (@primers) {
    for val $msg (@messages) {
        val $clean = Rosetta::VigAuto::clean($msg)
        val $enc = Rosetta::VigAuto::encrypt($msg, $primer)
        val $dec = Rosetta::VigAuto::decrypt($enc, $primer)
        assert_eq $dec, $clean, "round-trip ($primer) on '$clean'"
    }
}

# Encryption with no plaintext-letter input is empty
assert_eq Rosetta::VigAuto::encrypt("!!!", "KEY"), "", "non-letters strip away"

test_run
