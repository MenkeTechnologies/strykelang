#!/usr/bin/env stryke
# Rosetta Code: Longest increasing subsequence

fn Rosetta::LIS::solve($arr_ref) {
    var @arr = @$arr_ref
    val $n = len(@arr)
    if ($n == 0) { return 0 }
    var @tails = (0) x $n
    var $size = 0
    for val $x (@arr) {
        var $i = 0
        var $j = $size
        while ($i != $j) {
            val $m = int(($i + $j) / 2)
            if ($tails[$m] < $x) {
                $i = $m + 1
            } else {
                $j = $m
            }
        }
        $tails[$i] = $x
        if ($i == $size) { $size++ }
    }
    $size
}

assert_eq Rosetta::LIS::solve([0, 8, 4, 12, 2, 10, 6, 14, 1, 9, 5, 13, 3, 11, 7, 15]), 6, "LIS length is 6"
assert_eq Rosetta::LIS::solve([1, 2, 3, 4, 5]), 5, "LIS of sorted"
assert_eq Rosetta::LIS::solve([5, 4, 3, 2, 1]), 1, "LIS of reverse sorted"

test_run
