#!/usr/bin/env stryke
# Rosetta Code: Find missing permutation

fn Rosetta::Permutations::generate($arr) {
    val $n = len(@$arr)
    return [[@$arr]] if $n <= 1
    var @result
    for val $i (0:$n-1) {
        var @rest
        for val $j (0:$n-1) {
            push @rest, $arr->[$j] if $j != $i
        }
        val $sub = Rosetta::Permutations::generate(\@rest)
        for val $p (@$sub) {
            push @result, [$arr->[$i], @$p]
        }
    }
    \@result
}

fn Rosetta::MissingPermutation::solve(@perms) {
    var %given
    $given{_} = 1 for @perms
    
    val @chars = sort(chars($perms[0]))
    val $all = Rosetta::Permutations::generate(\@chars)
    
    var @res
    for val $p (@$all) {
        val $s = join("", @$p)
        push @res, $s if !$given{$s}
    }
    @res
}

val @input = qw(
    ABCD ABDC ACBD ACDB ADBC ADCB
    BACD BADC BCAD BCDA BDAC BDCA
    CABD CADB CBAD CBDA CDAB CDBA
    DABC DACB DBAC DBCA DCAB
)

val @missing = Rosetta::MissingPermutation::solve(@input)
assert_eq join(",", @missing), "DCBA", "missing permutation is DCBA"

val @input2 = qw(ABC ACB BAC BCA CBA)
val @missing2 = Rosetta::MissingPermutation::solve(@input2)
assert_eq join(",", @missing2), "CAB", "missing from ABC"

test_run
