#!/usr/bin/env stryke
# Rosetta Code: Polygon centroid via signed area (works for non-self-intersecting polygons)

fn Rosetta::Centroid::compute($poly) {
    val $n = len(@$poly)
    var $cx = 0.0
    var $cy = 0.0
    var $area = 0.0
    for val $i (0:$n - 1) {
        val $j = ($i + 1) % $n
        val $cross = $poly->[$i][0] * $poly->[$j][1] - $poly->[$j][0] * $poly->[$i][1]
        $area += $cross
        $cx += ($poly->[$i][0] + $poly->[$j][0]) * $cross
        $cy += ($poly->[$i][1] + $poly->[$j][1]) * $cross
    }
    $area /= 2.0
    return [0, 0] if $area == 0
    [$cx / (6 * $area), $cy / (6 * $area)]
}

fn Rosetta::Centroid::close($x, $y) { abs($x - $y) < 1e-9 }

# Unit square centered at origin
val $sq = [[-1, -1], [1, -1], [1, 1], [-1, 1]]
val $c = Rosetta::Centroid::compute($sq)
assert_ok Rosetta::Centroid::close($c->[0], 0), "centered square cx = 0"
assert_ok Rosetta::Centroid::close($c->[1], 0), "centered square cy = 0"

# Square with corner at origin
val $off = [[0, 0], [4, 0], [4, 4], [0, 4]]
val $co = Rosetta::Centroid::compute($off)
assert_ok Rosetta::Centroid::close($co->[0], 2), "0:4 square cx = 2"
assert_ok Rosetta::Centroid::close($co->[1], 2), "0:4 square cy = 2"

# Right triangle: centroid = (sum_x/3, sum_y/3)
val $tri = [[0, 0], [3, 0], [0, 3]]
val $ct = Rosetta::Centroid::compute($tri)
assert_ok Rosetta::Centroid::close($ct->[0], 1), "tri cx = 1"
assert_ok Rosetta::Centroid::close($ct->[1], 1), "tri cy = 1"

# Pentagon
val $pent = [[0, 0], [4, 0], [5, 3], [2, 5], [-1, 3]]
val $cp = Rosetta::Centroid::compute($pent)
assert_ok($cp->[0] > 1.5 && $cp->[0] < 2.5, "pentagon cx in interior x-range")
assert_ok($cp->[1] > 1.5 && $cp->[1] < 2.5, "pentagon cy in interior y-range")

# CW polygon yields the same centroid (sign cancels)
val $cw = [[0, 0], [0, 4], [4, 4], [4, 0]]
val $cc = Rosetta::Centroid::compute($cw)
assert_ok Rosetta::Centroid::close($cc->[0], 2), "CW square cx = 2"
assert_ok Rosetta::Centroid::close($cc->[1], 2), "CW square cy = 2"

test_run
