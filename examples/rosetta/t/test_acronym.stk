#!/usr/bin/env stryke
# Rosetta Code: Acronym

fn Rosetta::Acronym::compute($s) {
    $s |> split /[\s-]+/ |> map { substr(_, 0, 1) } |> join "" |> uc
}

assert_eq Rosetta::Acronym::compute("Portable Network Graphics"), "PNG", "PNG"
assert_eq Rosetta::Acronym::compute("First In, First Out"), "FIFO", "FIFO"
assert_eq Rosetta::Acronym::compute("GNU Image Manipulation Program"), "GIMP", "GIMP"
assert_eq Rosetta::Acronym::compute("Complementary metal-oxide-semiconductor"), "CMOS", "CMOS"

test_run
