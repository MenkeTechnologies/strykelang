#!/usr/bin/env stryke
# Rosetta Code: Acronym

fn my_acronym {
    my $s = $_[0]
    $s |> split /[\s-]+/ |> map { substr($_, 0, 1) } |> join "" |> uc
}

assert_eq my_acronym("Portable Network Graphics"), "PNG", "PNG"
assert_eq my_acronym("First In, First Out"), "FIFO", "FIFO"
assert_eq my_acronym("GNU Image Manipulation Program"), "GIMP", "GIMP"
assert_eq my_acronym("Complementary metal-oxide-semiconductor"), "CMOS", "CMOS"

test_run
