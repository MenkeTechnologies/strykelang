#!/usr/bin/env stryke
# Rosetta Code: Rosetta Code/Count examples

fn Rosetta::Count::run($file_path) {
    val $content = slurp($file_path)
    var @lines = split "\n", $content
    
    var $done = 0
    var $total = 0
    
    for val $line (@lines) {
        if ($line =~ /^\[[x ]\]/) {
            $total++
            $done++ if $line =~ /^\[x\]/
        }
    }
    
    ($done, $total)
}

# list.txt lives at rosetta/list.txt (sibling of this t/ dir).
val $list_path = dirname(dirname(__FILE__)) . "/list.txt"
val ($done, $total) = Rosetta::Count::run($list_path)

assert_ok $done > 0, "At least some examples are done"
assert_ok $total >= $done, "Total is greater than done"

test_run
