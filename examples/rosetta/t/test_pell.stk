#!/usr/bin/env stryke
# Rosetta Code: Pell numbers

fn Rosetta::Pell::compute($n) {
    if ($n == 0) {
        0
    } elsif ($n == 1) {
        1
    } else {
        my $p0 = 0
        my $p1 = 1
        for my $i (2..$n) {
            my $p2 = 2 * $p1 + $p0
            ($p0, $p1) = ($p1, $p2)
        }
        $p1
    }
}

fn Rosetta::Pell::list($max) {
    ~> 0:$max map { Rosetta::Pell::compute(_) }
}

assert_eq Rosetta::Pell::compute(0), 0, "P0"
assert_eq Rosetta::Pell::compute(1), 1, "P1"
assert_eq Rosetta::Pell::compute(2), 2, "P2"
assert_eq Rosetta::Pell::compute(3), 5, "P3"
assert_eq Rosetta::Pell::compute(4), 12, "P4"
assert_eq Rosetta::Pell::compute(10), 2378, "P10"

my @list = Rosetta::Pell::list(5)
assert_eq join(",", @list), "0,1,2,5,12,29", "Pell list first 6"

10 |> Rosetta::Pell::compute |> assert_eq(2378, "pipe pell 10")

test_run
