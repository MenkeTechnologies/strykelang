#!/usr/bin/env stryke
# Rosetta Code: Pell numbers

fn my_pell($n) {
    if ($n == 0) {
        0
    } elsif ($n == 1) {
        1
    } else {
        my $p0 = 0
        my $p1 = 1
        for my $i (2..$n) {
            my $p2 = 2 * $p1 + $p0
            ($p0, $p1) = ($p1, $p2)
        }
        $p1
    }
}

fn pell_list($max) {
    ~> 0..$max map { my_pell($_) }
}

assert_eq my_pell(0), 0, "P0"
assert_eq my_pell(1), 1, "P1"
assert_eq my_pell(2), 2, "P2"
assert_eq my_pell(3), 5, "P3"
assert_eq my_pell(4), 12, "P4"
assert_eq my_pell(10), 2378, "P10"

my @list = pell_list(5)
assert_eq join(",", @list), "0,1,2,5,12,29", "Pell list first 6"

10 |> my_pell |> assert_eq(2378, "pipe pell 10")

test_run
