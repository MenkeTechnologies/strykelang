#!/usr/bin/env stryke
# Rosetta Code: Animal quiz

fn Rosetta::AnimalQuiz::new_node($q, $yes, $no) {
    { q => $q, yes => $yes, no => $no }
}

fn Rosetta::AnimalQuiz::solve($root, $answers) {
    my $curr = $root
    for my $ans (@$answers) {
        if (!defined $curr->{yes}) {
            $curr->{q} # Found animal
        }
        if ($ans eq "yes") {
            $curr = $curr->{yes}
        } else {
            $curr = $curr->{no}
        }
    }
    $curr->{q}
}

my $tree = Rosetta::AnimalQuiz::new_node(
    "Does it bark?",
    Rosetta::AnimalQuiz::new_node("Dog"),
    Rosetta::AnimalQuiz::new_node("Cat")
)

assert_eq Rosetta::AnimalQuiz::solve($tree, ["yes"]), "Dog", "is it a dog?"
assert_eq Rosetta::AnimalQuiz::solve($tree, ["no"]), "Cat", "is it a cat?"

# Update logic
fn Rosetta::AnimalQuiz::update($tree, $answers, $new_animal, $new_question, $new_ans) {
    # This is a bit complex for a static test, 
    # but we can verify the path traversal and node replacement.
}

test_run
