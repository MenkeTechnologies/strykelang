#!/usr/bin/env stryke
# Rosetta Code: Power Set

fn Rosetta::PowerSet::compute(@set) {
    my @result = ([])
    for my $elem (@set) {
        my @new_subsets
        for my $subset (@result) {
            push @new_subsets, [@$subset, $elem]
        }
        push @result, @new_subsets
    }
    @result
}

my @ps = Rosetta::PowerSet::compute(1, 2, 3)
assert_eq len(@ps), 8, "power set of 3 elements has 8 subsets"

my @ps2 = Rosetta::PowerSet::compute("a", "b")
assert_eq len(@ps2), 4, "power set of 2 elements has 4 subsets"

my @ps4 = Rosetta::PowerSet::compute(1, 2, 3, 4)
assert_eq len(@ps4), 16, "power set of 4 elements has 16 subsets"

test_run
