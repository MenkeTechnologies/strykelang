#!/usr/bin/env stryke
# Rosetta Code: Power Set

fn power_set(@set) {
    my @result = ([])
    for my $elem (@set) {
        my @new_subsets
        for my $subset (@result) {
            push @new_subsets, [@$subset, $elem]
        }
        push @result, @new_subsets
    }
    @result
}

my @ps = power_set(1, 2, 3)
assert_eq scalar(@ps), 8, "power set of 3 elements has 8 subsets"

my @ps_empty = power_set()
assert_eq scalar(@ps_empty), 1, "power set of empty is 1 (empty set)"

my @ps2 = power_set("a", "b")
assert_eq scalar(@ps2), 4, "power set of 2 elements has 4 subsets"

my @ps4 = power_set(1, 2, 3, 4)
assert_eq scalar(@ps4), 16, "power set of 4 elements has 16 subsets"

test_run
