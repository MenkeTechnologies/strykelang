#!/usr/bin/env stryke
# Rosetta Code: Numerical integration/Simpson's rule

fn Rosetta::SimpsonsRule::integrate($f, $a, $b, $n) {
    if ($n % 2 != 0) { $n++ }
    val $h = ($b - $a) / $n
    val $half_n = $n / 2
    val @odds  = ~> 1:$half_n   map { $a + (2*_ - 1) * $h }
    val @evens = ~> 1:$half_n-1 map { $a + 2*_ * $h }
    val $sum_odds  = @odds  |> map $f |> sum
    val $sum_evens = @evens |> map $f |> sum
    val $sum_ends  = $f($a) + $f($b)
    ($h / 3) * ($sum_ends + 4 * $sum_odds + 2 * $sum_evens)
}

val $f1 = fn($x) { $x ** 3 }
val $res1 = Rosetta::SimpsonsRule::integrate($f1, 0, 1, 100)
assert_ok abs($res1 - 0.25) < 0.0001, "integral of x^3 from 0 to 1 is 1/4"

val $f2 = fn($x) { 3 * $x ** 2 + 2 * $x + 1 }
val $res2 = Rosetta::SimpsonsRule::integrate($f2, 0, 2, 100)
assert_ok abs($res2 - 14.0) < 0.0001, "integral of 3x^2+2x+1 from 0 to 2 is 14"

test_run
