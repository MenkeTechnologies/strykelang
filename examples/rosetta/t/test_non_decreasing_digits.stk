#!/usr/bin/env stryke
# Rosetta Code: Non-decreasing digits

fn Rosetta::NonDecreasingDigits::is_non_decreasing($n) {
    var @digits = ~> "$n" chars map {int}
    var $valid = 1
    for var $i (1..len(@digits)-1) {
        if ($digits[$i] < $digits[$i-1]) {
            $valid = 0
            $i = len(@digits) # break
        }
    }
    $valid
}

assert_ok Rosetta::NonDecreasingDigits::is_non_decreasing(123), "123 is non-decreasing"
assert_ok Rosetta::NonDecreasingDigits::is_non_decreasing(111), "111 is non-decreasing"
assert_ok Rosetta::NonDecreasingDigits::is_non_decreasing(13579), "13579 is non-decreasing"
assert_ok !Rosetta::NonDecreasingDigits::is_non_decreasing(121), "121 is not"
assert_ok !Rosetta::NonDecreasingDigits::is_non_decreasing(321), "321 is not"

123 |> Rosetta::NonDecreasingDigits::is_non_decreasing |> assert_ok("pipe non-decreasing")

test_run
