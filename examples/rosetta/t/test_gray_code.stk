#!/usr/bin/env stryke
# Rosetta Code: Gray code

fn Rosetta::GrayCode::encode($n) {
    $n ^ ($n >> 1)
}

fn Rosetta::GrayCode::decode($n) {
    my $res = $n
    my $mask = $res >> 1
    while ($mask != 0) {
        $res = $res ^ $mask
        $mask = $mask >> 1
    }
    $res
}

# Test a few values
assert_eq Rosetta::GrayCode::encode(0b1010), 0b1111, "gray of 1010 is 1111"
assert_eq Rosetta::GrayCode::decode(0b1111), 0b1010, "from_gray of 1111 is 1010"

assert_eq Rosetta::GrayCode::encode(5), 7, "to_gray(5) is 7"
assert_eq Rosetta::GrayCode::decode(7), 5, "from_gray(7) is 5"

# Print first 10 gray codes
my @grays = 0:9 |> map { Rosetta::GrayCode::encode($_) }
assert_eq join(",", @grays), "0,1,3,2,6,7,5,4,12,13", "first 10 gray codes"

test_run
