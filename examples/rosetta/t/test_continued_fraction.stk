#!/usr/bin/env stryke
# Rosetta Code: Continued fraction

fn Rosetta::ContinuedFraction::compute($gen, $n) {
    my $res = 0
    my $i = $n
    while ($i >= 1) {
        my $ab = $gen->($i)
        my $a = $ab->[0]; my $b = $ab->[1]
        $res = $b / ($a + $res)
        $i = $i - 1
    }
    my $ab0 = $gen->(0)
    $ab0->[0] + $res
}

# sqrt(2): [1; 2, 2, 2, ...]
my $sqrt2_gen = fn ($i) {
    if ($i == 0) { return [1, 1] }
    [2, 1]
}

# e: [2; 1, 2, 1, 1, 4, 1, 1, 6, ...]
my $e_gen = fn ($i) {
    if ($i == 0) { return [2, 1] }
    if ($i % 3 == 2) { return [2 * ($i + 1) / 3, 1] }
    [1, 1]
}

my $v_sqrt2 = Rosetta::ContinuedFraction::compute($sqrt2_gen, 20)
assert_near $v_sqrt2, 1.414213, 0.000001, "Continued fraction sqrt(2)"

my $v_e = Rosetta::ContinuedFraction::compute($e_gen, 20)
assert_near $v_e, 2.718281, 0.000001, "Continued fraction e"

test_run
