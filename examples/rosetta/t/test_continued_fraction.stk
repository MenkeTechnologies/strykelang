#!/usr/bin/env stryke
# Rosetta Code: Continued fraction

fn calc_cf($gen, $n) {
    my $res = 0
    my $i = $n
    while ($i >= 1) {
        my ($a, $b) = $gen->($i)
        $res = $b / ($a + $res)
        $i = $i - 1
    }
    my ($a, $b) = $gen->(0)
    return $a + $res
}

# sqrt(2): [1; 2, 2, 2, ...]
my $sqrt2_gen = fn ($i) {
    if ($i == 0) { return (1, 1) }
    return (2, 1)
}

# e: [2; 1, 2, 1, 1, 4, 1, 1, 6, ...]
my $e_gen = fn ($i) {
    if ($i == 0) { return (2, 1) }
    if ($i % 3 == 2) { return (2 * ($i + 1) / 3, 1) }
    return (1, 1)
}

# pi: [3; 7, 15, 1, 292, ...] (using a simpler formula: 4 / (1 + 1^2 / (2 + 3^2 / (2 + 5^2 / ...))))
# Actually let's use the one for pi: a0=3, b0=0; ai=6, bi=(2i-1)^2
my $pi_gen = fn ($i) {
    if ($i == 0) { return (3, 1) }
    my $bi = (2 * $i - 1) * (2 * $i - 1)
    return (6, $bi)
}

my $v_sqrt2 = calc_cf($sqrt2_gen, 20)
assert_ok abs($v_sqrt2 - 1.414213) < 0.000001, "Continued fraction sqrt(2)"

my $v_e = calc_cf($e_gen, 20)
assert_ok abs($v_e - 2.718281) < 0.000001, "Continued fraction e"

test_run
