#!/usr/bin/env stryke
# Rosetta Code: Binary Digits

fn Rosetta::BinaryDigits::encode($n) {
    if ($n == 0) {
        "0"
    } else {
        my @bits
        my $num = $n
        while ($num > 0) {
            unshift @bits, $num % 2
            $num = int($num / 2)
        }
        join("", @bits)
    }
}

fn Rosetta::BinaryDigits::decode($s) {
    my $result = 0
    my @bits = split //, $s
    for my $bit (@bits) {
        if ($bit =~ /[01]/) {
            $result = $result * 2 + int($bit)
        }
    }
    $result
}

fn Rosetta::BinaryDigits::count_ones($n) {
    my $bin = Rosetta::BinaryDigits::encode($n)
    my @ones = grep { $_ eq "1" } chars($bin)
    scalar(@ones)
}

assert_eq Rosetta::BinaryDigits::encode(0), "0", "binary 0"
assert_eq Rosetta::BinaryDigits::encode(1), "1", "binary 1"
assert_eq Rosetta::BinaryDigits::encode(5), "101", "binary 5"
assert_eq Rosetta::BinaryDigits::encode(50), "110010", "binary 50"
assert_eq Rosetta::BinaryDigits::encode(255), "11111111", "binary 255"

assert_eq Rosetta::BinaryDigits::decode("0"), 0, "from binary 0"
assert_eq Rosetta::BinaryDigits::decode("101"), 5, "from binary 101"
assert_eq Rosetta::BinaryDigits::decode("110010"), 50, "from binary 110010"
assert_eq Rosetta::BinaryDigits::decode("11111111"), 255, "from binary 11111111"

assert_eq Rosetta::BinaryDigits::count_ones(5), 2, "5 has 2 ones"
assert_eq Rosetta::BinaryDigits::count_ones(255), 8, "255 has 8 ones"
assert_eq Rosetta::BinaryDigits::count_ones(0), 0, "0 has 0 ones"

test_run
