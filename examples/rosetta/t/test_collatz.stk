#!/usr/bin/env stryke
# Rosetta Code: Collatz Conjecture (Hailstone Sequence)

fn Rosetta::Collatz::step($n) {
    $n % 2 == 0 ? $n / 2 : 3 * $n + 1
}

fn Rosetta::Collatz::sequence($n) {
    var @seq = ($n)
    var $curr = $n
    while ($curr != 1) {
        $curr = Rosetta::Collatz::step($curr)
        push @seq, $curr
    }
    @seq
}

fn Rosetta::Collatz::len($n) {
    var $len = 1
    var $curr = $n
    while ($curr != 1) {
        $curr = Rosetta::Collatz::step($curr)
        $len++
    }
    $len
}

assert_eq Rosetta::Collatz::len(1), 1, "collatz_len(1)"
assert_eq Rosetta::Collatz::len(2), 2, "collatz_len(2)"
assert_eq Rosetta::Collatz::len(27), 112, "collatz_len(27)"

val @seq = Rosetta::Collatz::sequence(6)
assert_eq join(",", @seq), "6,3,10,5,16,8,4,2,1", "collatz_seq(6)"

test_run
