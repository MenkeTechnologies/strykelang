#!/usr/bin/env stryke
# Rosetta Code: Collatz Conjecture (Hailstone Sequence)

fn collatz_step {
    my $n = $_[0]
    if ($n % 2 == 0) { $n / 2 } else { 3 * $n + 1 }
}

fn collatz_seq {
    my $n = $_[0]
    my @seq = ($n)
    my $curr = $n
    while ($curr != 1) {
        $curr = collatz_step($curr)
        push @seq, $curr
    }
    [@seq]
}

fn collatz_len {
    my $n = $_[0]
    my $len = 1
    my $curr = $n
    while ($curr != 1) {
        $curr = collatz_step($curr)
        $len++
    }
    $len
}

assert_eq collatz_len(1), 1, "collatz_len(1)"
assert_eq collatz_len(2), 2, "collatz_len(2)"
assert_eq collatz_len(27), 112, "collatz_len(27)"

my $seq = collatz_seq(6)
assert_eq join(",", @$seq), "6,3,10,5,16,8,4,2,1", "collatz_seq(6)"

test_run
