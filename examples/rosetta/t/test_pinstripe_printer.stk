#!/usr/bin/env stryke
# Rosetta Code: Pinstripe/Printer

fn Rosetta::Pinstripe::row($width, $stripe_w) {
    var $line = ""
    val @chars = (".", "#")
    var $i = 0
    while (len($line) < $width) {
        $line .= $chars[$i % 2] x $stripe_w
        $i++
    }
    substr($line, 0, $width)
}

fn Rosetta::Pinstripe::render($width, $max_w) {
    val @rows = ~> 1:$max_w map { Rosetta::Pinstripe::row($width, _) }
    \@rows
}

val $rows = Rosetta::Pinstripe::render(24, 4)

assert_eq len(@$rows), 4, "four stripe widths rendered"
assert_eq substr($rows->[0], 0, 8), ".#.#.#.#", "1-point alternating stripes"
assert_eq substr($rows->[1], 0, 8), "..##..##", "2-point alternating stripes"
assert_eq len($rows->[3]), 24, "rows span printer width"

test_run
