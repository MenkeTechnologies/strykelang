#!/usr/bin/env stryke
# Rosetta Code: Earley parser — recognizes any context-free grammar in
# O(n³) (cubic in input length, linear for unambiguous grammars).
# Three operations: predict, scan, complete; chart cells indexed by
# end position.

# Grammar representation:
#   { rules => [ ["LHS", ["RHS_sym1", "RHS_sym2", ...]], ... ],
#     start => "S",
#     terminals => { sym => 1, ... } }

fn Rosetta::Earley::is_terminal($grammar, $sym) {
    exists $grammar->{terminals}{$sym}
}

fn Rosetta::Earley::item_key($rule_idx, $dot, $start) {
    "$rule_idx:$dot:$start"
}

fn Rosetta::Earley::parse($grammar, $tokens) {
    my $n = len(@$tokens)
    my $rules = $grammar->{rules}
    # chart[$i] = list of (rule_idx, dot, origin)
    my @chart
    for my $i (~> 0:$n) { push @chart, [] }
    my @seen
    for my $i (~> 0:$n) { push @seen, {} }
    # Seed: every rule with LHS == start at position 0.
    for my $i (~> 0:len(@$rules) - 1) {
        if ($rules->[$i][0] eq $grammar->{start}) {
            my $key = Rosetta::Earley::item_key($i, 0, 0)
            push @{$chart[0]}, [$i, 0, 0]
            $seen[0]{$key} = 1
        }
    }
    for my $pos (~> 0:$n) {
        my $idx = 0
        while ($idx < len(@{$chart[$pos]})) {
            my $item = $chart[$pos][$idx]
            my ($r, $dot, $orig) = @$item
            my $rule = $rules->[$r]
            my $rhs = $rule->[1]
            if ($dot >= len(@$rhs)) {
                # Completer: copy items from chart[$orig] that expect $rule->[0].
                for my $other (@{$chart[$orig]}) {
                    my ($r2, $d2, $o2) = @$other
                    my $rhs2 = $rules->[$r2][1]
                    if ($d2 < len(@$rhs2) && $rhs2->[$d2] eq $rule->[0]) {
                        my $key = Rosetta::Earley::item_key($r2, $d2 + 1, $o2)
                        if (!exists $seen[$pos]{$key}) {
                            push @{$chart[$pos]}, [$r2, $d2 + 1, $o2]
                            $seen[$pos]{$key} = 1
                        }
                    }
                }
            } else {
                my $next = $rhs->[$dot]
                if (Rosetta::Earley::is_terminal($grammar, $next)) {
                    # Scanner: if $tokens[$pos] matches, advance into chart[$pos+1].
                    if ($pos < $n && $tokens->[$pos] eq $next) {
                        my $key = Rosetta::Earley::item_key($r, $dot + 1, $orig)
                        if (!exists $seen[$pos + 1]{$key}) {
                            push @{$chart[$pos + 1]}, [$r, $dot + 1, $orig]
                            $seen[$pos + 1]{$key} = 1
                        }
                    }
                } else {
                    # Predictor: add every rule for $next starting here.
                    for my $i2 (~> 0:len(@$rules) - 1) {
                        if ($rules->[$i2][0] eq $next) {
                            my $key = Rosetta::Earley::item_key($i2, 0, $pos)
                            if (!exists $seen[$pos]{$key}) {
                                push @{$chart[$pos]}, [$i2, 0, $pos]
                                $seen[$pos]{$key} = 1
                            }
                        }
                    }
                }
            }
            $idx++
        }
    }
    # Accept iff chart[n] contains a completed rule with LHS = start and origin 0.
    for my $item (@{$chart[$n]}) {
        my ($r, $dot, $orig) = @$item
        next if $orig != 0
        my $rule = $rules->[$r]
        if ($rule->[0] eq $grammar->{start} && $dot == len(@{$rule->[1]})) {
            return 1
        }
    }
    0
}

# Grammar: arithmetic with +, *, parens, digit
#   S → S "+" T | T
#   T → T "*" F | F
#   F → "(" S ")" | digit
my $arith = {
    start => "S",
    terminals => { "+" => 1, "*" => 1, "(" => 1, ")" => 1,
                   "0" => 1, "1" => 1, "2" => 1, "3" => 1, "4" => 1,
                   "5" => 1, "6" => 1, "7" => 1, "8" => 1, "9" => 1 },
    rules => [
        ["S", ["S", "+", "T"]],
        ["S", ["T"]],
        ["T", ["T", "*", "F"]],
        ["T", ["F"]],
        ["F", ["(", "S", ")"]],
        ["F", ["1"]],
        ["F", ["2"]],
        ["F", ["3"]],
        ["F", ["4"]],
        ["F", ["5"]],
        ["F", ["6"]],
        ["F", ["7"]],
        ["F", ["8"]],
        ["F", ["9"]]
    ]
}

assert_eq Rosetta::Earley::parse($arith, ["1"]), 1, "single digit"
assert_eq Rosetta::Earley::parse($arith, ["1", "+", "2"]), 1, "1+2"
assert_eq Rosetta::Earley::parse($arith, ["1", "+", "2", "*", "3"]), 1, "1+2*3"
assert_eq Rosetta::Earley::parse($arith, ["(", "1", "+", "2", ")", "*", "3"]), 1, "(1+2)*3"
assert_eq Rosetta::Earley::parse($arith, ["1", "+"]), 0, "trailing +"
assert_eq Rosetta::Earley::parse($arith, ["+", "1"]), 0, "leading +"
assert_eq Rosetta::Earley::parse($arith, ["(", "1"]), 0, "unclosed paren"
assert_eq Rosetta::Earley::parse($arith, []), 0, "empty rejected"

# Ambiguous grammar (Earley handles them too).
#   S → S S | "a"
my $ambi = {
    start => "S",
    terminals => { "a" => 1 },
    rules => [
        ["S", ["S", "S"]],
        ["S", ["a"]]
    ]
}
assert_eq Rosetta::Earley::parse($ambi, ["a"]), 1, "ambi: a"
assert_eq Rosetta::Earley::parse($ambi, ["a", "a"]), 1, "ambi: aa"
assert_eq Rosetta::Earley::parse($ambi, ["a", "a", "a"]), 1, "ambi: aaa"
assert_eq Rosetta::Earley::parse($ambi, ["b"]), 0, "ambi: b rejected"

# Left-recursive: Earley handles directly without grammar transformation.
#   S → S "x" | "y"
my $left_rec = {
    start => "S",
    terminals => { "x" => 1, "y" => 1 },
    rules => [
        ["S", ["S", "x"]],
        ["S", ["y"]]
    ]
}
assert_eq Rosetta::Earley::parse($left_rec, ["y"]), 1, "left-rec: y"
assert_eq Rosetta::Earley::parse($left_rec, ["y", "x"]), 1, "left-rec: yx"
assert_eq Rosetta::Earley::parse($left_rec, ["y", "x", "x", "x"]), 1, "left-rec: yxxx"
assert_eq Rosetta::Earley::parse($left_rec, ["x"]), 0, "left-rec: x alone"

test_run
