#!/usr/bin/env stryke
# Rosetta Code: Graph colouring (Greedy algorithm)

fn Rosetta::GraphColoring::solve($adj) {
    my $num_nodes = len(@$adj)
    my %colors
    
    # Iterate through nodes and assign the first available color
    for my $i (0 .. $num_nodes - 1) {
        my %used_neighbor_colors
        for my $neighbor (@{$adj->[$i]}) {
            if (exists $colors{$neighbor}) {
                $used_neighbor_colors{$colors{$neighbor}} = 1
            }
        }
        
        my $color = 0
        while ($used_neighbor_colors{$color}) {
            $color++
        }
        $colors{$i} = $color
    }
    \%colors
}

# Test with a simple triangle graph (K3)
# 0-1, 1-2, 2-0
my $k3 = [[1, 2], [0, 2], [0, 1]]
my $res_k3 = Rosetta::GraphColoring::solve($k3)

assert_eq $res_k3->{0}, 0, "Node 0 color"
assert_eq $res_k3->{1}, 1, "Node 1 color"
assert_eq $res_k3->{2}, 2, "Node 2 color (needs 3rd color for K3)"

# Test with a square graph (C4)
# 0-1, 1-2, 2-3, 3-0
my $c4 = [[1, 3], [0, 2], [1, 3], [0, 2]]
my $res_c4 = Rosetta::GraphColoring::solve($c4)

# 0 -> 0
# 1 -> 1
# 2 -> 0 (neighbor 1 has color 1)
# 3 -> 1 (neighbors 0 and 2 have color 0)
assert_eq $res_c4->{0}, 0, "C4 Node 0 color"
assert_eq $res_c4->{1}, 1, "C4 Node 1 color"
assert_eq $res_c4->{2}, 0, "C4 Node 2 color"
assert_eq $res_c4->{3}, 1, "C4 Node 3 color"

test_run
