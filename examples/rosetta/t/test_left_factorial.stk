#!/usr/bin/env stryke
# Rosetta Code: Left factorials

fn Rosetta::LeftFactorial::factorial($n) {
    if ($n < 2) { 1 }
    else { 1:$n |> reduce { $a * $b } }
}

fn Rosetta::LeftFactorial::compute($n) {
    if ($n == 0) {
        0
    } else {
        my $sum = 0
        for my $i (0..$n-1) {
            $sum += Rosetta::LeftFactorial::factorial($i)
        }
        $sum
    }
}

assert_eq Rosetta::LeftFactorial::compute(0), 0, "!0 (left)"
assert_eq Rosetta::LeftFactorial::compute(1), 1, "!1 (left) = 0!"
assert_eq Rosetta::LeftFactorial::compute(2), 2, "!2 (left) = 0!+1!"
assert_eq Rosetta::LeftFactorial::compute(3), 4, "!3 (left) = 0!+1!+2!"
assert_eq Rosetta::LeftFactorial::compute(10), 409114, "!10 (left)"

10 |> Rosetta::LeftFactorial::compute |> assert_eq(409114, "pipe left factorial")

test_run
