#!/usr/bin/env stryke
# Rosetta Code: Palindrome detection

fn Rosetta::IsPalindrome::is_palindrome($s) {
    my $clean = ~> $s lc s/[^a-z0-9]//gr
    my $rev = ~> $clean >{split //, $_} rev |> join ""
    $clean eq $rev
}

assert_ok Rosetta::IsPalindrome::is_palindrome("racecar"), "racecar is palindrome"
assert_ok Rosetta::IsPalindrome::is_palindrome("A man, a plan, a canal: Panama"), "Panama palindrome"
assert_ok !Rosetta::IsPalindrome::is_palindrome("hello"), "hello is not palindrome"

"madam" |> Rosetta::IsPalindrome::is_palindrome |> assert_ok("madam is palindrome")

test_run
