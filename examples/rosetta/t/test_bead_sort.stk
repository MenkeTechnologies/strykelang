#!/usr/bin/env stryke
# Rosetta Code: Bead Sort

fn Rosetta::BeadSort::sort($list) {
    val @arr = @$list
    var $max = 0
    for val $x (@arr) {
        if ($x > $max) { $max = $x }
    }
    
    var @beads = ()
    for val $i (0..len(@arr)-1) {
        $beads[$i] = []
        for val $j (0:$arr[$i]-1) {
            $beads[$i][$j] = 1
        }
    }
    
    for val $j (0:$max-1) {
        var $sum = 0
        for val $i (0..len(@arr)-1) {
            if ($beads[$i][$j]) {
                $sum++
                $beads[$i][$j] = 0
            }
        }
        if ($sum > 0) {
            for val $i (len(@arr)-$sum .. len(@arr)-1) {
                $beads[$i][$j] = 1
            }
        }
    }
    
    var @res = ()
    for val $i (0..len(@arr)-1) {
        var $sum = 0
        for val $j (0:$max-1) {
            if ($beads[$i][$j]) { $sum++ }
        }
        push @res, $sum
    }
    \@res
}

val $data = [5, 3, 1, 7, 4, 1, 1]
val $sorted = Rosetta::BeadSort::sort($data)
assert_eq join(",", @$sorted), "1,1,1,3,4,5,7", "bead sort"

test_run
