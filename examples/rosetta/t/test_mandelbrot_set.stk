#!/usr/bin/env stryke
# Rosetta Code: Mandelbrot Set

fn mandelbrot_iter($c_real, $c_imag, $max_iter) {
    my $z_real = 0
    my $z_imag = 0
    
    my $result = $max_iter
    for my $i (0..$max_iter-1) {
        my $z_real_sq = $z_real * $z_real
        my $z_imag_sq = $z_imag * $z_imag
        
        if ($z_real_sq + $z_imag_sq > 4) {
            $result = $i
            last
        }
        
        my $new_real = $z_real_sq - $z_imag_sq + $c_real
        my $new_imag = 2 * $z_real * $z_imag + $c_imag
        
        $z_real = $new_real
        $z_imag = $new_imag
    }
    
    $result
}

fn draw_mandelbrot($width, $height, $max_iter) {
    my $x_min = -2.5
    my $x_max = 1.5
    my $y_min = -2.0
    my $y_max = 2.0
    
    my $x_scale = ($x_max - $x_min) / $width
    my $y_scale = ($y_max - $y_min) / $height
    
    for my $y (0..$height-1) {
        for my $x (0..$width-1) {
            my $c_real = $x_min + $x * $x_scale
            my $c_imag = $y_min + $y * $y_scale
            
            my $iterations = mandelbrot_iter($c_real, $c_imag, $max_iter)
            
            if ($iterations == $max_iter) {
                print "*"
            } elsif ($iterations > $max_iter * 0.8) {
                print "+"
            } elsif ($iterations > $max_iter * 0.6) {
                print "o"
            } elsif ($iterations > $max_iter * 0.4) {
                print "-"
            } elsif ($iterations > $max_iter * 0.2) {
                print "."
            } else {
                print " "
            }
        }
        print "\n"
    }
}

print "Mandelbrot Set (40x20):\n"
draw_mandelbrot(40, 20, 50)