#!/usr/bin/env stryke
# Rosetta Code: Mandelbrot set

fn Rosetta::Mandelbrot::iterations($c_re, $c_im, $max_iter) {
    my $z_re = 0.0
    my $z_im = 0.0
    my $iter = 0
    
    while ($iter < $max_iter) {
        my $z_re_sq = $re * $re
        my $z_im_sq = $im * $im
        
        if ($z_re_sq + $z_im_sq > 4.0) { return $iter }
        
        my $next_re = $z_re_sq - $z_im_sq + $c_re
        my $next_im = 2.0 * $z_re * $z_im + $c_im
        
        $z_re = $next_re
        $z_im = $next_im
        $iter++
    }
    $max_iter
}

fn Rosetta::Mandelbrot::render($width, $height, $max_iter) {
    my $x_min = -2.5
    my $x_max = 1.5
    my $y_min = -2.0
    my $y_max = 2.0
    
    my $x_scale = ($x_max - $x_min) / $width
    my $y_scale = ($y_max - $y_min) / $height
    
    my $output = ""
    for my $y (0..$height-1) {
        for my $x (0..$width-1) {
            my $c_real = $x_min + $x * $x_scale
            my $c_imag = $y_min + $y * $y_scale
            
            my $iterations = Rosetta::Mandelbrot::iterations($c_real, $c_imag, $max_iter)
            
            if ($iterations == $max_iter) { $output .= "*" }
            elsif ($iterations > $max_iter * 0.8) { $output .= "+"; }
            elsif ($iterations > $max_iter * 0.6) { $output .= "o"; }
            elsif ($iterations > $max_iter * 0.4) { $output .= "-"; }
            elsif ($iterations > $max_iter * 0.2) { $output .= "."; }
            else { $output .= " " }
        }
        $output .= "
"
    }
    $output
}

print "Mandelbrot Set (40x20):
"
print Rosetta::Mandelbrot::render(40, 20, 50)

test_run
