#!/usr/bin/env stryke
# Rosetta Code: Mandelbrot set

fn Rosetta::Mandelbrot::iterations($c_re, $c_im, $max_iter) {
    var $z_re = 0.0
    var $z_im = 0.0
    var $iter = 0
    
    while ($iter < $max_iter) {
        val $z_re_sq = $re * $re
        val $z_im_sq = $im * $im
        
        if ($z_re_sq + $z_im_sq > 4.0) { return $iter }
        
        val $next_re = $z_re_sq - $z_im_sq + $c_re
        val $next_im = 2.0 * $z_re * $z_im + $c_im
        
        $z_re = $next_re
        $z_im = $next_im
        $iter++
    }
    $max_iter
}

fn Rosetta::Mandelbrot::render($width, $height, $max_iter) {
    val $x_min = -2.5
    val $x_max = 1.5
    val $y_min = -2.0
    val $y_max = 2.0
    
    val $x_scale = ($x_max - $x_min) / $width
    val $y_scale = ($y_max - $y_min) / $height
    
    var $output = ""
    for val $y (0:$height-1) {
        for val $x (0:$width-1) {
            val $c_real = $x_min + $x * $x_scale
            val $c_imag = $y_min + $y * $y_scale
            
            val $iterations = Rosetta::Mandelbrot::iterations($c_real, $c_imag, $max_iter)
            
            if ($iterations == $max_iter) { $output .= "*" }
            elsif ($iterations > $max_iter * 0.8) { $output .= "+"; }
            elsif ($iterations > $max_iter * 0.6) { $output .= "o"; }
            elsif ($iterations > $max_iter * 0.4) { $output .= "-"; }
            elsif ($iterations > $max_iter * 0.2) { $output .= "."; }
            else { $output .= " " }
        }
        $output .= "
"
    }
    $output
}

print "Mandelbrot Set (40x20):
"
print Rosetta::Mandelbrot::render(40, 20, 50)

test_run
