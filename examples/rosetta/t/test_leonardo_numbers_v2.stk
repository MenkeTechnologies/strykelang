#!/usr/bin/env stryke
# Rosetta Code: Leonardo numbers

fn Rosetta::LeonardoV2::compute($n) {
    if ($n == 0 || $n == 1) {
        1
    } else {
        Rosetta::LeonardoV2::compute($n - 1) + Rosetta::LeonardoV2::compute($n - 2) + 1
    }
}

fn Rosetta::LeonardoV2::list($max) {
    ~> 0:$max map { Rosetta::LeonardoV2::compute($_) }
}

assert_eq Rosetta::LeonardoV2::compute(0), 1, "L(0)"
assert_eq Rosetta::LeonardoV2::compute(1), 1, "L(1)"
assert_eq Rosetta::LeonardoV2::compute(2), 3, "L(2)"
assert_eq Rosetta::LeonardoV2::compute(3), 5, "L(3)"
assert_eq Rosetta::LeonardoV2::compute(4), 9, "L(4)"

my @list = Rosetta::LeonardoV2::list(5)
assert_eq join(",", @list), "1,1,3,5,9,15", "Leonardo list up to 5"

test_run
