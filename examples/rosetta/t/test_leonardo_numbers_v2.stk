#!/usr/bin/env stryke
# Rosetta Code: Leonardo numbers

fn leonardo($n) {
    if ($n == 0 || $n == 1) {
        1
    } else {
        leonardo($n - 1) + leonardo($n - 2) + 1
    }
}

fn leonardo_list($max) {
    ~> 0..$max map { leonardo($_) }
}

assert_eq leonardo(0), 1, "L(0)"
assert_eq leonardo(1), 1, "L(1)"
assert_eq leonardo(2), 3, "L(2)"
assert_eq leonardo(3), 5, "L(3)"
assert_eq leonardo(4), 9, "L(4)"

my @list = leonardo_list(5)
assert_eq join(",", @list), "1,1,3,5,9,15", "Leonardo list up to 5"

test_run
