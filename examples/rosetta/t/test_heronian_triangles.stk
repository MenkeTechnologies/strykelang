#!/usr/bin/env stryke
# Rosetta Code: Heronian triangles

fn Rosetta::Heronian::gcd($a, $b) {
    while ($b != 0) {
        ($a, $b) = ($b, $a % $b)
    }
    $a
}

fn Rosetta::Heronian::generate($max_p) {
    my @triangles
    
    for my $c (1..$max_p) {
        for my $b (1..$c) {
            for my $a (1..$b) {
                if ($a + $b > $c) {
                    my $s = ($a + $b + $c) / 2
                    if ($s > $a && $s > $b && $s > $c) {
                        my $area_sq = $s * ($s - $a) * ($s - $b) * ($s - $c)
                        if ($area_sq > 0) {
                            my $area = sqrt($area_sq)
                            if ($area == int($area)) {
                                my $g = Rosetta::Heronian::gcd($a, Rosetta::Heronian::gcd($b, $c))
                                if ($g == 1) {
                                    push @triangles, [$a, $b, $c]
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    
    \@triangles
}

# Just a small check as this is computationally intensive
my $res = Rosetta::Heronian::generate(25)
assert_ok len(@$res) > 0, "found at least one Heronian triangle"

test_run
