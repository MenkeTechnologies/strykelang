#!/usr/bin/env stryke
# Rosetta Code: Dynamic variable names
# Build/read variables whose names come from runtime data.

# Best stryke approach: use a hash as the namespace.
fn Rosetta::DynVar::set_in($scope, $name, $value) {
    $scope->{$name} = $value
}

fn Rosetta::DynVar::get_in($scope, $name) {
    $scope->{$name}
}

my %scope
for my $name ("foo", "bar", "baz") {
    Rosetta::DynVar::set_in(\%scope, $name, length($name))
}
assert_eq Rosetta::DynVar::get_in(\%scope, "foo"), 3, "foo->3"
assert_eq Rosetta::DynVar::get_in(\%scope, "bar"), 3, "bar->3"
assert_eq Rosetta::DynVar::get_in(\%scope, "baz"), 3, "baz->3"

# Build N variables from indices
my %dyn
for my $i (1..5) {
    $dyn{"var_$i"} = $i * 10
}
assert_eq $dyn{"var_3"}, 30, "var_3 = 30"
assert_eq $dyn{"var_5"}, 50, "var_5 = 50"

# Read at runtime by computed key
my $which = "var_" . 4
assert_eq $dyn{$which}, 40, "computed-key access"

# pipeline form: list of names -> map to lengths into a hash
my @names = ("alpha", "beta", "gamma")
my %h = (~> @names map { (_, length(_)) })
assert_eq $h{"alpha"}, 5,  "alpha length"
assert_eq $h{"gamma"}, 5,  "gamma length"
assert_eq $h{"beta"},  4,  "beta length"

test_run
