#!/usr/bin/env stryke
# Rosetta Code: Bitmap/Read a PPM file

fn Rosetta::BitmapPPM::parse($str) {
    var @tokens
    for val $line (split("\n", $str)) {
        next if $line =~ /^#/
        for val $t (split(/\s+/, $line)) {
            if ($t ne "") { push @tokens, $t }
        }
    }
    
    val $magic = shift @tokens
    val $w = int(shift @tokens)
    val $h = int(shift @tokens)
    val $max = int(shift @tokens)
    
    var @pixels
    for val $i (1:$h) {
        var @row
        for val $j (1:$w) {
            val $r = shift @tokens
            val $g = shift @tokens
            val $b = shift @tokens
            push @row, { r => int($r), g => int($g), b => int($b) }
        }
        push @pixels, \@row
    }
    \@pixels
}

val $ppm = "P3\n# comment\n2 2\n255\n255 0 0 0 255 0\n0 0 255 255 255 255\n"
val $img = Rosetta::BitmapPPM::parse($ppm)

assert_eq len(@$img), 2, "img height"
assert_eq len(@{$img->[0]}), 2, "img width"
assert_eq $img->[0]->[0]->{r}, 255, "pixel 0,0 red"
assert_eq $img->[0]->[1]->{g}, 255, "pixel 0,1 green"
assert_eq $img->[1]->[0]->{b}, 255, "pixel 1,0 blue"

test_run
