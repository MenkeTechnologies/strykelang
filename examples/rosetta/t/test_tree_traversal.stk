#!/usr/bin/env stryke
# Rosetta Code: Tree Traversal

fn Rosetta::TreeTraversal::preorder($n) {
    if (!$n) { return () }
    ($n->{val}, Rosetta::TreeTraversal::preorder($n->{left}), Rosetta::TreeTraversal::preorder($n->{right}))
}

fn Rosetta::TreeTraversal::inorder($n) {
    if (!$n) { return () }
    (Rosetta::TreeTraversal::inorder($n->{left}), $n->{val}, Rosetta::TreeTraversal::inorder($n->{right}))
}

fn Rosetta::TreeTraversal::postorder($n) {
    if (!$n) { return () }
    (Rosetta::TreeTraversal::postorder($n->{left}), Rosetta::TreeTraversal::postorder($n->{right}), $n->{val})
}

fn Rosetta::TreeTraversal::levelorder($n) {
    my $q = [$n]
    my $res = []
    while (scalar(@$q)) {
        my $c = shift @$q
        push @$res, $c->{val}
        if ($c->{left}) { push @$q, $c->{left} }
        if ($c->{right}) { push @$q, $c->{right} }
    }
    $res
}

my $tree = {
    val => 1,
    left => {
        val => 2,
        left => { val => 4 },
        right => { val => 5 }
    },
    right => { val => 3 }
}

assert_eq join(",", flatten(Rosetta::TreeTraversal::preorder($tree))), "1,2,4,5,3", "preorder"
assert_eq join(",", flatten(Rosetta::TreeTraversal::inorder($tree))), "4,2,5,1,3", "inorder"
assert_eq join(",", flatten(Rosetta::TreeTraversal::postorder($tree))), "4,5,2,3,1", "postorder"
my $lo = Rosetta::TreeTraversal::levelorder($tree)
assert_eq join(",", @$lo), "1,2,3,4,5", "levelorder"

test_run
