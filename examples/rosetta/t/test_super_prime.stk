#!/usr/bin/env stryke
# Rosetta Code: Super-prime numbers

fn Rosetta::IsPrime::is_prime($n) {
    if ($n < 2) { 0 }
    elsif ($n == 2) { 1 }
    elsif ($n % 2 == 0) { 0 }
    else {
        val $limit = sqrt($n)
        var $res = 1
        for var $i (3..int($limit)) {
            if ($n % $i == 0) {
                $res = 0
                $i = $n
            }
        }
        $res
    }
}

fn Rosetta::NthPrime::nth_prime($n) {
    var $count = 0
    var $candidate = 1
    while ($count < $n) {
        $candidate++
        if (Rosetta::IsPrime::is_prime($candidate)) { $count++ }
    }
    $candidate
}

fn Rosetta::SuperPrime::is_super_prime($n) {
    # Check if n is the i-th prime where i is also prime
    if (!Rosetta::IsPrime::is_prime($n)) {
        0
    } else {
        # Find which prime n is
        var $count = 0
        var $p = 1
        while ($p < $n) {
            $p++
            if (Rosetta::IsPrime::is_prime($p)) { $count++ }
        }
        Rosetta::IsPrime::is_prime($count)
    }
}

assert_ok Rosetta::SuperPrime::is_super_prime(3), "3 is 2nd prime, 2 is prime"
assert_ok Rosetta::SuperPrime::is_super_prime(5), "5 is 3rd prime, 3 is prime"
assert_ok Rosetta::SuperPrime::is_super_prime(11), "11 is 5th prime, 5 is prime"
assert_ok !Rosetta::SuperPrime::is_super_prime(2), "2 is 1st prime, 1 is not prime"
assert_ok !Rosetta::SuperPrime::is_super_prime(7), "7 is 4th prime, 4 is not prime"

11 |> Rosetta::SuperPrime::is_super_prime |> assert_ok("pipe Super-prime")

test_run
