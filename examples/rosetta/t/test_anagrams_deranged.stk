#!/usr/bin/env stryke
# Rosetta Code: Anagrams/Deranged anagrams

fn Rosetta::AnagramsDeranged::is_derangement($s1, $s2) {
    if (len($s1) != len($s2)) { return 0 }
    var @a1 = ~> $s1 chars
    val @a2 = ~> $s2 chars
    for val $i (0..len(@a1)-1) {
        if ($a1[$i] eq $a2[$i]) { return 0 }
    }
    1
}

fn Rosetta::AnagramsDeranged::sort_str($s) {
    ~> $s chars sort |> join ""
}

fn Rosetta::AnagramsDeranged::solve($words) {
    var %groups
    for val $w (@$words) {
        val $key = Rosetta::AnagramsDeranged::sort_str($w)
        if (!exists $groups{$key}) {
            $groups{$key} = []
        }
        push @{$groups{$key}}, $w
    }
    
    var $max_len = 0
    var @best = ()
    
    for val $key (keys %groups) {
        var @list = @{$groups{$key}}
        if (len(@list) > 1) {
            for val $i (0..len(@list)-2) {
                for val $j ($i+1..len(@list)-1) {
                    if (Rosetta::AnagramsDeranged::is_derangement($list[$i], $list[$j])) {
                        val $len = len($list[$i])
                        if ($len >= $max_len) {
                            $max_len = $len
                            @best = ($list[$i], $list[$j])
                        }
                    }
                }
            }
        }
    }
    \@best
}

val $words = [qw(dots stod stop pots tops post spot)]
val $res = Rosetta::AnagramsDeranged::solve($words)
# dots and stod are deranged anagrams (length 4)
assert_eq len($res->[0]), 4, "max length deranged anagram"

assert_ok Rosetta::AnagramsDeranged::is_derangement("dots", "stod"), "dots/stod is derangement"
assert_ok !Rosetta::AnagramsDeranged::is_derangement("abc", "acb"), "abc/acb is not (a matches)"

test_run
