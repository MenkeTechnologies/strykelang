#!/usr/bin/env stryke
# Rosetta Code: Perrin numbers

fn Rosetta::Perrin::compute($n) {
    if ($n == 0) { 3 }
    elsif ($n == 1) { 0 }
    elsif ($n == 2) { 2 }
    else {
        my $p0 = 3
        my $p1 = 0
        my $p2 = 2
        for my $i (3..$n) {
            my $p3 = $p1 + $p0
            ($p0, $p1, $p2) = ($p1, $p2, $p3)
        }
        $p2
    }
}

fn Rosetta::Perrin::list($max) {
    ~> 0:$max map { Rosetta::Perrin::compute(_) }
}

assert_eq Rosetta::Perrin::compute(0), 3, "P0"
assert_eq Rosetta::Perrin::compute(1), 0, "P1"
assert_eq Rosetta::Perrin::compute(2), 2, "P2"
assert_eq Rosetta::Perrin::compute(3), 3, "P3 (0+3)"
assert_eq Rosetta::Perrin::compute(4), 2, "P4 (2+0)"
assert_eq Rosetta::Perrin::compute(5), 5, "P5 (3+2)"
assert_eq Rosetta::Perrin::compute(10), 17, "P10"

my @list = Rosetta::Perrin::list(6)
assert_eq join(",", @list), "3,0,2,3,2,5,5", "Perrin list"

10 |> Rosetta::Perrin::compute |> assert_eq(17, "pipe perrin")

test_run
