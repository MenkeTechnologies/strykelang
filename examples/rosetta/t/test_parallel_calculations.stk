#!/usr/bin/env stryke
# Rosetta Code: Parallel calculations

fn check_prime($n) {
    if ($n < 2) { return 0 }
    if ($n < 4) { return 1 }
    if ($n % 2 == 0) { return 0 }
    my $i = 3
    while ($i * $i <= $n) {
        if ($n % $i == 0) { return 0 }
        $i += 2
    }
    1
}

# 1. Using pgrep (Parallel Filter)
fn parallel_prime_count($max) {
    my @primes = pgrep { check_prime($_) } (1..$max)
    scalar(@primes)
}

# 2. Using pmap (Parallel Map)
fn parallel_factorials {
    my @nums = @_
    pmap {
        my $n = $_
        my $fact = 1
        for my $i (1..$n) { $fact *= $i }
        $fact
    } @nums
}

# 3. Using mysync for parallel accumulation
fn parallel_sum($max) {
    mysync $total = 0
    pfor { $total += $_ } (1..$max)
    $total
}

# 4. Using par_pipeline
fn parallel_pipeline_demo($max) {
    # par_pipeline_stream |> collect returns a list; capture it in @res
    my @res = (1..$max) |> par_pipeline_stream |> filter { $_ % 2 == 0 } |> map { $_ * $_ } |> collect
    \@res
}

# Test Parallel Prime Count
assert_eq parallel_prime_count(100), 25, "Parallel prime count to 100"

# Test Parallel Factorials
my @facts = parallel_factorials(1, 2, 3, 4, 5)
assert_eq join(",", @facts), "1,2,6,24,120", "Parallel factorials"

# Test Parallel Sum with mysync
assert_eq parallel_sum(100), 5050, "Parallel sum with mysync"

# Test Parallel Pipeline
my $res = parallel_pipeline_demo(10)
assert_eq join(",", @$res), "4,16,36,64,100", "Parallel pipeline"

test_run
