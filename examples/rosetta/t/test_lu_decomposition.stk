#!/usr/bin/env stryke
# Rosetta Code: LU Decomposition

fn Rosetta::LUDecomposition::solve($A) {
    val $n = len(@$A)
    var @L; var @U
    for val $i (0:$n-1) {
        var @l_row; var @u_row
        for val $j (0:$n-1) {
            push @l_row, ($i == $j ? 1.0 : 0.0)
            push @u_row, 0.0
        }
        push @L, \@l_row
        push @U, \@u_row
    }
    
    for val $j (0:$n-1) {
        for val $i (0:$j) {
            var $sum = 0.0
            for val $k (0:$i-1) { $sum = $sum + $L[$i]->[$k] * $U[$k]->[$j] }
            $U[$i]->[$j] = $A->[$i]->[$j] - $sum
        }
        for val $i ($j+1:$n-1) {
            var $sum = 0.0
            for val $k (0:$j-1) { $sum = $sum + $L[$i]->[$k] * $U[$k]->[$j] }
            $L[$i]->[$j] = ($A->[$i]->[$j] - $sum) / $U[$j]->[$j]
        }
    }
    (\@L, \@U)
}

val $A = [[1, 3, 5], [2, 4, 7], [1, 1, 0]]
val ($L, $U) = Rosetta::LUDecomposition::solve($A)

# A = LU =>
# L[1][0] should be 2.0
# U[0][0] should be 1.0
assert_eq $L->[1]->[0], 2, "L[1][0] is 2"
assert_eq $U->[0]->[0], 1, "U[0][0] is 1"
assert_eq $U->[1]->[1], -2, "U[1][1] is -2"

test_run
