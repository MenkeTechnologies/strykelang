#!/usr/bin/env stryke
# Rosetta Code: Heap Sort

fn Rosetta::HeapSort::sift_down($arr_ref, $start, $end) {
    my $root = $start
    while ($root * 2 + 1 <= $end) {
        my $child = $root * 2 + 1
        my $swap = $root
        
        if ($arr_ref->[$swap] < $arr_ref->[$child]) {
            $swap = $child
        }
        if ($child + 1 <= $end && $arr_ref->[$swap] < $arr_ref->[$child + 1]) {
            $swap = $child + 1
        }
        if ($swap == $root) {
            return
        } else {
            ($arr_ref->[$root], $arr_ref->[$swap]) = ($arr_ref->[$swap], $arr_ref->[$root])
            $root = $swap
        }
    }
}

fn Rosetta::HeapSort::heapify($arr_ref) {
    my $count = len(@$arr_ref)
    my $start = int(($count - 2) / 2)
    while ($start >= 0) {
        Rosetta::HeapSort::sift_down($arr_ref, $start, $count - 1)
        $start--
    }
}

fn Rosetta::HeapSort::sort($list) {
    my @arr = @$list
    my $count = len(@arr)
    if ($count < 2) { return \@arr }
    
    Rosetta::HeapSort::heapify(\@arr)
    
    my $end = $count - 1
    while ($end > 0) {
        ($arr[$end], $arr[0]) = ($arr[0], $arr[$end])
        $end--
        Rosetta::HeapSort::sift_down(\@arr, 0, $end)
    }
    \@arr
}

my $data = [4, 10, 3, 5, 1]
my $sorted = Rosetta::HeapSort::sort($data)
assert_eq join(",", @$sorted), "1,3,4,5,10", "heap sort"

my $data2 = [1, 6, 3, 2, 1, 7, 5, 22, 58, 0, 9, 3, 4]
my $sorted2 = Rosetta::HeapSort::sort($data2)
assert_eq join(",", @$sorted2), "0,1,1,2,3,3,4,5,6,7,9,22,58", "heap sort 2"

test_run
