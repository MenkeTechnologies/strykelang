#!/usr/bin/env stryke
# Rosetta Code: Halt and catch fire

fn Rosetta::HCF::run() {
    # In some contexts, HCF is implemented as an infinite loop or a system crash.
    # In Stryke, we can simulate a 'halt' by exiting the process.
    # For the purpose of this test, we'll just return a status.
    "HCF Simulation"
}

my $res = Rosetta::HCF::run()
assert_eq $res, "HCF Simulation", "HCF simulation"

test_run
