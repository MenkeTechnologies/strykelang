#!/usr/bin/env stryke
# Rosetta Code: Roots of a function (False Position Method)

fn Rosetta::FalsePosition::solve($f, $a, $b, $tol) {
    var $fa = $f($a)
    var $fb = $f($b)
    
    for val $i (1:100) {
        val $c = ($a * $fb - $b * $fa) / ($fb - $fa)
        val $fc = $f($c)
        if (abs($fc) < $tol) { return $c }
        
        if ($fa * $fc < 0) {
            $b = $c; $fb = $fc
        } else {
            $a = $c; $fa = $fc
        }
    }
    undef
}

# x^2 - 2 = 0 in [1, 2]
val $f = fn { _ * _ - 2 }
val $root = Rosetta::FalsePosition::solve($f, 1.0, 2.0, 0.0001)
assert_near $root, sqrt(2), 0.001, "False position root of x^2-2"

test_run
