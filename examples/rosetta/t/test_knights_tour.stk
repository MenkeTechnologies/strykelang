#!/usr/bin/env stryke
# Rosetta Code: Knight's Tour

fn Rosetta::KnightsTour::backtrack($x, $y, $count, $board, $n, $dx, $dy) {
    $board->[$x]->[$y] = $count
    if ($count == $n * $n) { return 1 }

    for val $i (0:7) {
        val $nx = $x + $dx->[$i]
        val $ny = $y + $dy->[$i]
        if ($nx >= 0 && $nx < $n && $ny >= 0 && $ny < $n && $board->[$nx]->[$ny] == 0) {
            if (Rosetta::KnightsTour::backtrack($nx, $ny, $count + 1, $board, $n, $dx, $dy)) { return 1 }
        }
    }
    $board->[$x]->[$y] = 0
    0
}

fn Rosetta::KnightsTour::solve($n) {
    val $board = []
    for val $i (0:$n-1) {
        val $row = []
        for val $j (0:$n-1) { push @$row, 0 }
        push @$board, $row
    }

    val $dx = [2, 1, -1, -2, -2, -1, 1, 2]
    val $dy = [1, 2, 2, 1, -1, -2, -2, -1]

    if (Rosetta::KnightsTour::backtrack(0, 0, 1, $board, $n, $dx, $dy)) { return $board }
    undef
}

# 5x5 board is small enough for fast testing
val $tour = Rosetta::KnightsTour::solve(5)
assert_ok defined($tour), "Knight's tour 5x5 exists"

# Verify all squares are visited
var $visited_count = 0
for val $row (@$tour) {
    for val $val (@$row) {
        if ($val > 0) { $visited_count = $visited_count + 1 }
    }
}
assert_eq $visited_count, 25, "Knight's tour visited all 25 squares"

test_run
