#!/usr/bin/env stryke
# Rosetta Code: Random Latin squares

fn Rosetta::LatinSquares::generate($n) {
    # Generate a simple shifted Latin square
    my @square
    for my $r (0 .. $n - 1) {
        my @row
        for my $c (0 .. $n - 1) {
            push @row, ($r + $c) % $n
        }
        push @square, \@row
    }
    
    # Shuffle rows
    @square = @{Rosetta::LatinSquares::shuffle(\@square)}
    
    # Shuffle columns
    # We can transpose, shuffle rows, and transpose back.
    my $t1 = Rosetta::LatinSquares::transpose(\@square)
    my $t2 = Rosetta::LatinSquares::shuffle($t1)
    Rosetta::LatinSquares::transpose($t2)
}

fn Rosetta::LatinSquares::shuffle($array) {
    my @a = @$array
    for (my $i = len(@a) - 1; $i > 0; $i--) {
        my $j = int(rand($i + 1))
        ($a[$i], $a[$j]) = ($a[$j], $a[$i])
    }
    \@a
}

fn Rosetta::LatinSquares::transpose($matrix) {
    my $n = len(@$matrix)
    my @res
    for my $c (0 .. $n - 1) {
        my @row
        for my $r (0 .. $n - 1) {
            push @row, $matrix->[$r][$c]
        }
        push @res, \@row
    }
    \@res
}

fn Rosetta::LatinSquares::is_latin($matrix) {
    my $n = len(@$matrix)
    # Check rows
    for my $r (@$matrix) {
        my %seen
        for my $val (@$r) { $seen{$val} = 1 }
        return 0 if len(keys %seen) != $n
    }
    # Check columns
    for my $c (0 .. $n - 1) {
        my %seen
        for my $r (0 .. $n - 1) {
            $seen{$matrix->[$r][$c]} = 1
        }
        return 0 if len(keys %seen) != $n
    }
    1
}

my $square3 = Rosetta::LatinSquares::generate(3)
assert_ok Rosetta::LatinSquares::is_latin($square3), "Generated 3x3 Latin Square"

my $square5 = Rosetta::LatinSquares::generate(5)
assert_ok Rosetta::LatinSquares::is_latin($square5), "Generated 5x5 Latin Square"

test_run
