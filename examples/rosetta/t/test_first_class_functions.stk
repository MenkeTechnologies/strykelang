#!/usr/bin/env stryke
# Rosetta Code: First-class functions

fn Math::Funcs::cube($x)        { $x ** 3 }
fn Math::Funcs::cube_root($x)   { $x ** (1/3) }
fn Math::Funcs::compose($f, $g) { fn { val $x = _; $f($g($x)) } }

# Functions as values: assign, store in arrays, pass around.
val $f = \&Math::Funcs::cube
assert_eq $f(2), 8, "store in scalar"

val @fns  = (\&Math::Funcs::cube, \&Math::Funcs::cube_root)
val @inv  = (\&Math::Funcs::cube_root, \&Math::Funcs::cube)

# composed[i] = f[i] ∘ inv[i] should be identity
for val $i (0:1) {
    val $h = Math::Funcs::compose($fns[$i], $inv[$i])
    val $r = $h(8.0)
    assert_ok abs($r - 8.0) < 1e-9, "composed[$i] is identity"
}

# pass-as-arg
fn Rosetta::FCFunc::apply($fn, $x) { $fn($x) }
assert_eq Rosetta::FCFunc::apply(\&Math::Funcs::cube, 4),    64,  "apply cube"

# pipeline
val $r = 27 |> Math::Funcs::cube_root
assert_ok abs($r - 3) < 1e-9, "pipe cbrt"

# coderefs through map
val @vals = (1, 2, 3, 4) |> map {Math::Funcs::cube}
assert_eq join(",", @vals), "1,8,27,64", "map coderef"

test_run
