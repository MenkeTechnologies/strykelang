#!/usr/bin/env stryke
# Rosetta Code: Statistics/Basic

fn Rosetta::Statistics::mean(@nums) {
    if (len(@nums) == 0) {
        0
    } else {
        var $sum = 0
        for val $x (@nums) { $sum += $x }
        $sum / len(@nums)
    }
}

fn Rosetta::Statistics::variance(@nums) {
    if (len(@nums) < 1) {
        0
    } else {
        val $m = Rosetta::Statistics::mean(@nums)
        var $sum_sq_diff = 0
        for val $x (@nums) { 
            val $diff = $x - $m
            $sum_sq_diff += $diff * $diff
        }
        $sum_sq_diff / len(@nums)
    }
}

fn Rosetta::Statistics::std_dev(@nums) {
    sqrt(Rosetta::Statistics::variance(@nums))
}

val @data = (15, 12, 8, 8, 7, 7, 7, 6, 5, 3)
assert_near Rosetta::Statistics::mean(@data), 7.8, 0.0001, "mean is 7.8"
assert_near Rosetta::Statistics::variance(@data), 10.56, 0.0001, "variance is 10.56"
assert_near Rosetta::Statistics::std_dev(@data), 3.2496, 0.001, "std dev is 3.2496"

@data |> Rosetta::Statistics::mean |> assert_near(7.8, 0.0001, "pipe mean")

test_run
