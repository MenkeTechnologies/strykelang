#!/usr/bin/env stryke
# Rosetta Code: Cocktail Sort

fn Rosetta::CocktailSort::sort($list) {
    var @arr = @$list
    val $n = len(@arr)
    var $swapped = 1
    var $start = 0
    var $end = $n - 1
    
    while ($swapped) {
        $swapped = 0
        for var $i ($start:$end - 1) {
            if ($arr[$i] > $arr[$i + 1]) {
                ($arr[$i], $arr[$i + 1]) = ($arr[$i + 1], $arr[$i])
                $swapped = 1
            }
        }
        
        if ($swapped) {
            $swapped = 0
            $end--
            for var $i (~> ($start:$end - 1) rev) {
                if ($arr[$i] > $arr[$i + 1]) {
                    ($arr[$i], $arr[$i + 1]) = ($arr[$i + 1], $arr[$i])
                    $swapped = 1
                }
            }
            $start++
        }
    }
    \@arr
}

val $data = [5, 1, 4, 2, 8, 0, 2]
val $sorted = Rosetta::CocktailSort::sort($data)
assert_eq join(",", @$sorted), "0,1,2,2,4,5,8", "cocktail sort"

test_run
