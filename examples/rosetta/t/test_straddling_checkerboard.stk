#!/usr/bin/env stryke
# Rosetta Code: Straddling checkerboard

fn Rosetta::Checkerboard::encode($msg, $alphabet, $sp1, $sp2) {
    var %map
    val @alpha_chars = split("", $alphabet)
    
    # 1. Fill map
    var $char_idx = 0
    for val $i (0:9) {
        if ($i == $sp1 || $i == $sp2) {
            next
        }
        $map{$alpha_chars[$char_idx]} = "$i"
        $char_idx++
    }
    
    # 2. Fill rows for $sp1 and $sp2
    for val $i (0:9) {
        $map{$alpha_chars[$char_idx]} = "$sp1$i"
        $char_idx++
        if ($char_idx >= len(@alpha_chars)) { last }
    }
    for val $i (0:9) {
        if ($char_idx >= len(@alpha_chars)) { last }
        $map{$alpha_chars[$char_idx]} = "$sp2$i"
        $char_idx++
    }
    
    # 3. Encode
    var $encoded = ""
    for val $c (split("", uc($msg))) {
        if (exists $map{$c}) {
            $encoded .= $map{$c}
        }
    }
    $encoded
}

# Values from Wikipedia / Rosetta Code example
val $alphabet = "ET ONRISHDLFCUMGPYBWVKXJQZ./"
val $sp1 = 2
val $sp2 = 6

val $msg = "CHECK"
val $enc = Rosetta::Checkerboard::encode($msg, $alphabet, $sp1, $sp2)
# p "Encoded: $enc"

# E (0), T (1), SPACE (3), O (4), N (5), R (7), I (8), S (9)
# Row 2 (sp1): H (20), D (21), L (22), F (23), C (24)...
assert_ok len($enc) > 0, "Encoded message"
assert_ok $enc =~ /^24/, "C starts with 24"

# Full check for CHECK
# C (24), H (20), E (0), C (24), K (63)
assert_eq $enc, "242002463", "CHECK encoded correctly"

test_run
