#!/usr/bin/env stryke
# Rosetta Code: Lychrel numbers

fn my_is_palindrome($s) {
    my $rev = ~> $s chars rev |> join ""
    $s eq $rev
}

fn my_is_lychrel($n, $max_iter) {
    my $curr = $n
    for my $i (1..$max_iter) {
        my $rev = ~> "$curr" chars rev |> join ""
        $curr = $curr + $rev
        if (my_is_palindrome("$curr")) {
            return 0
        }
    }
    1
}

assert_ok !my_is_lychrel(121, 50), "121 is not Lychrel"
assert_ok !my_is_lychrel(47, 50), "47 is not Lychrel (47+74=121)"
assert_ok my_is_lychrel(196, 50), "196 is likely Lychrel"

test_run
