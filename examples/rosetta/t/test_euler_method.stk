#!/usr/bin/env stryke
# Rosetta Code: Euler Method

fn Rosetta::EulerMethod::solve($f, $y0, $h, $n) {
    var $y = $y0
    var $t = 0
    for val $i (1:$n) {
        $y = $y + $h * $f($t, $y)
        $t = $t + $h
    }
    $y
}

# Solve y' = y, y(0) = 1. Result at t=1 should be approx e.
val $f = fn ($t, $y) { $y }
val $res = Rosetta::EulerMethod::solve($f, 1, 0.001, 1000)
val $e = 2.718281828
assert_near $res, $e, 0.01, "my_euler method approximation of e"

# Solve y' = 2t, y(0) = 0. Result at t=1 should be approx 1.
val $f2 = fn ($t, $y) { 2 * $t }
val $res2 = Rosetta::EulerMethod::solve($f2, 0, 0.001, 1000)
assert_near $res2, 1.0, 0.01, "my_euler method approximation of t^2"

test_run
