#!/usr/bin/env stryke
# Rosetta Code: Longest Common Subsequence

fn Rosetta::LCS::solve($s1, $s2) {
    val @c1 = $s1 |> chars
    val @c2 = $s2 |> chars
    val $m = len(@c1)
    val $n = len(@c2)
    
    # Initialize DP table
    val @dp = ~> 0:$m map { [~> 0:$n map { 0 }] }
    
    for val $i (~> 1:$m) {
        for val $j (~> 1:$n) {
            if ($c1[$i-1] eq $c2[$j-1]) {
                $dp[$i][$j] = $dp[$i-1][$j-1] + 1
            } else {
                $dp[$i][$j] = max($dp[$i-1][$j], $dp[$i][$j-1])
            }
        }
    }
    
    # Backtrack to find the string
    var $res = ""
    var $i = $m
    var $j = $n
    while ($i > 0 && $j > 0) {
        if ($c1[$i-1] eq $c2[$j-1]) {
            $res = $c1[$i-1] . $res
            $i--
            $j--
        } elsif ($dp[$i-1][$j] > $dp[$i][$j-1]) {
            $i--
        } else {
            $j--
        }
    }
    $res
}

assert_eq Rosetta::LCS::solve("thisisatest", "testing123testing"), "tsitest", "LCS of thisisatest and testing123testing"
assert_eq Rosetta::LCS::solve("1234", "1224533324"), "1234", "LCS of 1234 and 1224533324"
assert_eq Rosetta::LCS::solve("abc", "def"), "", "no common subsequence"
assert_eq Rosetta::LCS::solve("ABCDEFG", "BCDGK"), "BCDG", "LCS of ABCDEFG and BCDGK"

test_run
