#!/usr/bin/env stryke
# Rosetta Code: 2D orientation predicate
# Returns 1 (ccw / left turn), -1 (cw / right turn), 0 (collinear)

fn Rosetta::Orient::orient($a, $b, $c) {
    val $cx = ($b->[0] - $a->[0]) * ($c->[1] - $a->[1]) - ($b->[1] - $a->[1]) * ($c->[0] - $a->[0])
    return 0 if $cx == 0
    $cx > 0 ? 1 : -1
}

# Counter-clockwise triangle
assert_eq Rosetta::Orient::orient([0,0], [1,0], [0,1]), 1, "(0,0)(1,0)(0,1) is CCW"

# Clockwise triangle
assert_eq Rosetta::Orient::orient([0,0], [0,1], [1,0]), -1, "(0,0)(0,1)(1,0) is CW"

# Collinear
assert_eq Rosetta::Orient::orient([0,0], [1,1], [2,2]), 0, "collinear diagonal"
assert_eq Rosetta::Orient::orient([0,0], [3,0], [5,0]), 0, "collinear on x-axis"
assert_eq Rosetta::Orient::orient([0,0], [0,3], [0,5]), 0, "collinear on y-axis"

# Three collinear with intervening point
assert_eq Rosetta::Orient::orient([1,1], [2,2], [3,3]), 0, "collinear off-origin"

# Negative coords
assert_eq Rosetta::Orient::orient([-2, 0], [0, 0], [0, 2]), 1, "L-shape CCW"
assert_eq Rosetta::Orient::orient([-2, 0], [0, 0], [0, -2]), -1, "mirrored CW"

# Reversing the order flips sign
val $a = [1, 1]
val $b = [4, 5]
val $c = [7, 2]
val $abc = Rosetta::Orient::orient($a, $b, $c)
val $cba = Rosetta::Orient::orient($c, $b, $a)
assert_eq $abc + $cba, 0, "swapping a/c flips sign"

# Cyclic permutation preserves sign (for non-collinear)
val $bca = Rosetta::Orient::orient($b, $c, $a)
assert_eq $abc, $bca, "cyclic permutation preserves orientation"

test_run
