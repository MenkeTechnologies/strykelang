#!/usr/bin/env stryke
# Rosetta Code: Secretary problem (1/e rule) — Monte Carlo simulation
# Optimal stopping: reject first n/e candidates, then accept first one beating
# the best of those rejected. Theoretical success probability ~ 1/e ~ 0.368.

fn Rosetta::Secretary::shuffled($n) {
    var @a = (1:$n)
    for var $i (~> 1:($n - 1) rev) {
        var $j = int(rand($i + 1))
        ($a[$i], $a[$j]) = ($a[$j], $a[$i])
    }
    \@a
}

fn Rosetta::Secretary::trial($candidates, $cutoff) {
    val $n = len(@$candidates)
    var $best_seen = 0
    for val $i (0:$cutoff - 1) {
        $best_seen = $candidates->[$i] if $candidates->[$i] > $best_seen
    }
    for val $i ($cutoff:$n - 1) {
        return $candidates->[$i] if $candidates->[$i] > $best_seen
    }
    $candidates->[$n - 1]
}

fn Rosetta::Secretary::strategy($n, $cutoff, $trials) {
    var $wins = 0
    for val $t (1:$trials) {
        val $cands = Rosetta::Secretary::shuffled($n)
        val $picked = Rosetta::Secretary::trial($cands, $cutoff)
        $wins++ if $picked == $n
    }
    $wins / $trials
}

srand(42)
val $n = 30
# 1/e rule: cutoff = n/e ~ 11
val $opt = int($n / 2.71828)
val $rate = Rosetta::Secretary::strategy($n, $opt, 5000)
val $expected = 1.0 / 2.71828

# Theory says ~0.368, allow 5% wiggle for stochasticity
assert_ok abs($rate - $expected) < 0.05, "1/e rule wins ~37% (got $rate)"

# Compare alternatives: cutoff=0 (always pick first) loses except by chance
val $no_skip = Rosetta::Secretary::strategy($n, 0, 5000)
assert_ok $no_skip < 0.1, "skip 0 -> ~1/n win rate (got $no_skip)"

# cutoff = n-1 (skip everything but last) -> win iff last is the best (1/n)
val $skip_all = Rosetta::Secretary::strategy($n, $n - 1, 5000)
assert_ok abs($skip_all - 1.0/$n) < 0.05, "skip n-1 -> ~1/n (got $skip_all)"

# Optimal cutoff strictly beats both extremes
assert_ok($rate > $no_skip + 0.1, "1/e beats no-skip by margin")
assert_ok($rate > $skip_all + 0.1, "1/e beats skip-all by margin")

# Trial returns a candidate, never undef
val $c = Rosetta::Secretary::shuffled(10)
val $picked = Rosetta::Secretary::trial($c, 4)
assert_ok($picked >= 1 && $picked <= 10, "trial returns a real candidate")

test_run
