#!/usr/bin/env stryke
# Rosetta Code: Binary Search

fn my_binary_search {
    my $list = $_[0]
    my $target = $_[1]
    my @arr = @$list
    my $low = 0
    my $high = scalar(@arr) - 1
    
    while ($low <= $high) {
        my $mid = int(($low + $high) / 2)
        if ($arr[$mid] == $target) {
            return $mid
        } elsif ($arr[$mid] < $target) {
            $low = $mid + 1
        } else {
            $high = $mid - 1
        }
    }
    -1
}

my $data = [1, 3, 5, 7, 9, 11, 13]
assert_eq my_binary_search($data, 7), 3, "found 7 at 3"
assert_eq my_binary_search($data, 1), 0, "found 1 at 0"
assert_eq my_binary_search($data, 13), 6, "found 13 at 6"
assert_eq my_binary_search($data, 8), -1, "8 not found"

test_run
