#!/usr/bin/env stryke
# Rosetta Code: Binary Search

fn bin_search($aref, $target) {
    my @arr = @$aref
    my ($lo, $hi) = (0, $#arr)
    my $res = -1
    while ($lo <= $hi) {
        my $mid = int(($lo + $hi) / 2)
        if ($arr[$mid] == $target) {
            $res = $mid
            $lo = $hi + 1
        } elsif ($arr[$mid] < $target) {
            $lo = $mid + 1
        } else {
            $hi = $mid - 1
        }
    }
    $res
}

my @arr = (1, 3, 5, 7, 9, 11, 13, 15)

assert_eq bin_search(\@arr, 7), 3, "find 7 at index 3"
assert_eq bin_search(\@arr, 1), 0, "find 1 at index 0"
assert_eq bin_search(\@arr, 15), 7, "find 15 at index 7"
assert_eq bin_search(\@arr, 4), -1, "4 not found"
assert_eq bin_search(\@arr, 0), -1, "0 not found"

test_run
