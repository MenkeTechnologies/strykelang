#!/usr/bin/env stryke
# Rosetta Code: Bitmap/Histogram

fn Rosetta::BitmapHistogram::calculate($img) {
    var %hist = ( r => {}, g => {}, b => {} )
    
    for val $row (@$img) {
        for val $pixel (@$row) {
            $hist{r}->{$pixel->{r}}++
            $hist{g}->{$pixel->{g}}++
            $hist{b}->{$pixel->{b}}++
        }
    }
    return \%hist
}

fn Rosetta::BitmapHistogram::demo() {
    # Simple 2x2 image
    val $img = [
        [ {r=>255, g=>0, b=>0}, {r=>0, g=>255, b=>0} ],
        [ {r=>0, g=>0, b=>255}, {r=>255, g=>255, b=>255} ]
    ]
    
    val $h = Rosetta::BitmapHistogram::calculate($img)
    
    "Bitmap Histogram (Color Counts):" |> p
    "Red channel counts:" |> p
    for val $val (sort { _ <=> _1 } keys %{$h->{r}}) {
        p "  $val: " . $h->{r}->{$val}
    }
    
    # Assertions
    assert_eq $h->{r}->{255}, 2, "Red value 255 appears twice"
    assert_eq $h->{r}->{0}, 2, "Red value 0 appears twice"
    assert_eq $h->{g}->{255}, 2, "Green value 255 appears twice"
    assert_eq $h->{b}->{255}, 2, "Blue value 255 appears twice"
}

Rosetta::BitmapHistogram::demo()
test_run
