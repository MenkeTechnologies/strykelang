#!/usr/bin/env stryke
# Rosetta Code: Keyboard input/Keypress check

fn Rosetta::KeyCheck::pressed($buffer) {
    len(@$buffer) > 0 ? 1 : 0
}

assert_eq Rosetta::KeyCheck::pressed([]), 0, "no keypress available"
assert_eq Rosetta::KeyCheck::pressed(["X"]), 1, "keypress detected"
assert_eq Rosetta::KeyCheck::pressed(["X", "Y"]), 1, "non-blocking check only cares if any key exists"

test_run
