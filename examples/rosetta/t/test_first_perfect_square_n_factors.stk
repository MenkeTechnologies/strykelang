#!/usr/bin/env stryke
# Rosetta Code: First perfect square with N or more unique factors

fn Rosetta::FirstSquareNFactors::factor_count($n) {
    my $count = 0
    my $i = 1
    while ($i * $i <= $n) {
        if ($n % $i == 0) {
            $count += 1
            $count += 1 if $i * $i != $n
        }
        $i += 1
    }
    $count
}

fn Rosetta::FirstSquareNFactors::find($k) {
    my $i = 1
    while (1) {
        my $sq = $i * $i
        return $sq if Rosetta::FirstSquareNFactors::factor_count($sq) >= $k
        $i += 1
    }
}

assert_eq Rosetta::FirstSquareNFactors::find(1),  1,   "n=1 => 1"
assert_eq Rosetta::FirstSquareNFactors::find(2),  4,   "n=2 => 4 (1,2,4)"
assert_eq Rosetta::FirstSquareNFactors::find(3),  4,   "n=3 => 4 (3 divisors)"
assert_eq Rosetta::FirstSquareNFactors::find(4),  16,  "n=4 => 16 (5 divisors)"
assert_eq Rosetta::FirstSquareNFactors::find(5),  16,  "n=5 => 16"
assert_eq Rosetta::FirstSquareNFactors::find(6),  36,  "n=6 => 36 (9 divisors)"
assert_eq Rosetta::FirstSquareNFactors::find(9),  36,  "n=9 => 36"
assert_eq Rosetta::FirstSquareNFactors::find(10), 144, "n=10 => 144 (15 divisors)"
assert_eq Rosetta::FirstSquareNFactors::find(15), 144, "n=15 => 144"
assert_eq Rosetta::FirstSquareNFactors::find(16), 576, "n=16 => 576 (576 = 24^2 has 21 divisors)"

test_run
