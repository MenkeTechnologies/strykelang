#!/usr/bin/env stryke
# Rosetta Code: Special variables

fn Rosetta::SpecialVars::check() {
    var @vars
    push @vars, defined($0)
    push @vars, defined(%ENV)
    push @vars, defined(@ARGV)
    \@vars
}

val $res = Rosetta::SpecialVars::check()
assert_eq $res->[0], 1, "0 is defined"
assert_eq $res->[1], 1, "ENV is defined"
assert_eq $res->[2], 1, "ARGV is defined"

test_run
