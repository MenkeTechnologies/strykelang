#!/usr/bin/env stryke
# Rosetta Code: Prime conspiracy

fn Rosetta::PrimeConspiracy::is_prime {
    if (_ < 2) { return 0 }
    if (_ == 2 || _ == 3) { return 1 }
    if (_ % 2 == 0 || _ % 3 == 0) { return 0 }
    var $i = 5
    while ($i * $i <= _) {
        if (_ % $i == 0 || _ % ($i + 2) == 0) { return 0 }
        $i += 6
    }
    1
}

fn Rosetta::PrimeConspiracy::next_prime($n) {
    var $p = $n + 1
    while (!Rosetta::PrimeConspiracy::is_prime($p)) {
        $p++
    }
    $p
}

fn PrimeConspiracy::last_digit($n) {
    $n % 10
}

var $p = 2
var $p_next = Rosetta::PrimeConspiracy::next_prime($p)
val $d1 = PrimeConspiracy::last_digit($p)
val $d2 = PrimeConspiracy::last_digit($p_next)

assert_eq $d1, 2, "last digit of 2 is 2"
assert_eq $d2, 3, "last digit of next prime (3) is 3"

$p = 7
$p_next = Rosetta::PrimeConspiracy::next_prime($p)
val $d3 = PrimeConspiracy::last_digit($p)
val $d4 = PrimeConspiracy::last_digit($p_next)

assert_eq $d3, 7, "last digit of 7 is 7"
assert_eq $d4, 1, "last digit of next prime (11) is 1"

test_run
