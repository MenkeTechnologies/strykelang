#!/usr/bin/env stryke
# Rosetta Code: Reciprocal step function

fn Rosetta::ReciprocalStep::compute($n) {
    if ($n == 0) { return 0 }
    1.0 / $n
}

assert_eq Rosetta::ReciprocalStep::compute(2), 0.5, "step 2"
assert_eq Rosetta::ReciprocalStep::compute(4), 0.25, "step 4"
assert_eq Rosetta::ReciprocalStep::compute(0), 0, "step 0"

test_run
