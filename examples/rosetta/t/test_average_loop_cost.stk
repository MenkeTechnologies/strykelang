#!/usr/bin/env stryke
# Rosetta Code: Average loop cost

fn Rosetta::LoopCost::compute($n) {
    var $sum = 0
    var $i = 0
    while ($i < $n) {
        $sum += $i
        $i++
    }
    $sum
}

assert_eq Rosetta::LoopCost::compute(10), 45, "loop cost 10"
assert_eq Rosetta::LoopCost::compute(100), 4950, "loop cost 100"

# pipe check
1000 |> Rosetta::LoopCost::compute |> assert_eq(499500, "pipe loop cost")

test_run
