#!/usr/bin/env stryke
# Rosetta Code: Pseudo-random numbers/PCG32

fn Rosetta::PCG32::new($seed, $seq) {
    my $h = +{
        state => 0,
        inc => ($seq << 1) | 1
    }
    Rosetta::PCG32::next($h)
    $h->{state} += $seed
    Rosetta::PCG32::next($h)
    $h
}

fn Rosetta::PCG32::next($h) {
    my $oldstate = $h->{state}
    $h->{state} = ($oldstate * 6364136223846793005 + $h->{inc}) & ~0
    
    my $xorshifted = ((($oldstate >> 18) ^ $oldstate) >> 27) & 0xFFFFFFFF
    my $rot = ($oldstate >> 59) & 31
    
    my $res = (($xorshifted >> $rot) | ($xorshifted << ((-$rot) & 31))) & 0xFFFFFFFF
    $res
}

# Test with a specific seed
my $rng = Rosetta::PCG32::new(42, 54)
my @nums
for my $i (1:5) {
    push @nums, Rosetta::PCG32::next($rng)
}

# PCG32 values with seed 42, seq 54:
# 1st: 2707161783
# 2nd: 2068313097
# 3rd: 3122482380

assert_ok $nums[0] > 0, "Generated positive number"
assert_ok $nums[1] != $nums[0], "Numbers are different"

# Verify values
assert_eq $nums[0], 2707161783, "First PCG32 value"
assert_eq $nums[1], 2068313097, "Second PCG32 value"
assert_eq $nums[2], 3122482380, "Third PCG32 value"

test_run
