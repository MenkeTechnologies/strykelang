#!/usr/bin/env stryke
# Rosetta Code: Lucas numbers

fn my_lucas($n) {
    if ($n == 0) {
        2
    } elsif ($n == 1) {
        1
    } else {
        my $a = 2
        my $b = 1
        for my $i (1..$n-1) {
            ($a, $b) = ($b, $a + $b)
        }
        $b
    }
}

assert_eq my_lucas(0), 2, "L0"
assert_eq my_lucas(1), 1, "L1"
assert_eq my_lucas(2), 3, "L2"
assert_eq my_lucas(3), 4, "L3"
assert_eq my_lucas(4), 7, "L4"
assert_eq my_lucas(10), 123, "L10"

10 |> my_lucas |> assert_eq(123, "pipe lucas 10")

test_run
