#!/usr/bin/env stryke
# Rosetta Code: Lucas numbers

fn Rosetta::Lucas::compute($n) {
    if ($n == 0) {
        2
    } elsif ($n == 1) {
        1
    } else {
        my $a = 2
        my $b = 1
        for my $i (2..$n) {
            my $c = $a + $b
            ($a, $b) = ($b, $c)
        }
        $b
    }
}

assert_eq Rosetta::Lucas::compute(0), 2, "L(0)"
assert_eq Rosetta::Lucas::compute(1), 1, "L(1)"
assert_eq Rosetta::Lucas::compute(2), 3, "L(2)"
assert_eq Rosetta::Lucas::compute(3), 4, "L(3)"
assert_eq Rosetta::Lucas::compute(4), 7, "L(4)"
assert_eq Rosetta::Lucas::compute(10), 123, "L(10)"

10 |> Rosetta::Lucas::compute |> assert_eq(123, "pipe lucas 10")

test_run
