#!/usr/bin/env stryke
# Rosetta Code: Shoelace Formula

fn Shoelace::algo_area($p) {
    var $sum = 0.0
    val $n = len(@$p)
    for val $i (0:$n-1) {
        val $j = ($i + 1) % $n
        $sum = $sum + $p->[$i]->[0] * $p->[$j]->[1]
        $sum = $sum - $p->[$j]->[0] * $p->[$i]->[1]
    }
    abs($sum) / 2.0
}

val $sq = [[0,0], [2,0], [2,2], [0,2]]
assert_eq Shoelace::algo_area($sq), 4, "area square"
test_run
