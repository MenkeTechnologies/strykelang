#!/usr/bin/env stryke
# Rosetta Code: Terminal control/Dimensions

fn Rosetta::TerminalDimensions::get() {
    # Using system commands to get dimensions is a common fallback
    var $cols = qx{tput cols} |> trim
    var $rows = qx{tput lines} |> trim
    
    # Fallback for headless environments
    $cols = 80 if !defined($cols) || len($cols) == 0
    $rows = 24 if !defined($rows) || len($rows) == 0
    
    ($cols, $rows)
}

val ($c, $r) = Rosetta::TerminalDimensions::get()
assert_ok defined($c), "Columns defined"
assert_ok defined($r), "Rows defined"

test_run
