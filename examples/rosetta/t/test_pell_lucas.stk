#!/usr/bin/env stryke
# Rosetta Code: Pell-Lucas numbers

fn pell_lucas($n) {
    if ($n == 0) {
        2
    } elsif ($n == 1) {
        2
    } else {
        my $a = 2
        my $b = 2
        for my $i (2..$n) {
            my $c = 2 * $b + $a
            ($a, $b) = ($b, $c)
        }
        $b
    }
}

assert_eq pell_lucas(0), 2, "Q(0)"
assert_eq pell_lucas(1), 2, "Q(1)"
assert_eq pell_lucas(2), 6, "Q(2)"
assert_eq pell_lucas(3), 14, "Q(3)"
assert_eq pell_lucas(4), 34, "Q(4)"
assert_eq pell_lucas(10), 6726, "Q(10)"

10 |> pell_lucas |> assert_eq(6726, "pipe pell-lucas")

test_run
