#!/usr/bin/env stryke
# Rosetta Code: Pell-Lucas numbers

fn Rosetta::PellLucas::compute($n) {
    if ($n == 0) {
        2
    } elsif ($n == 1) {
        2
    } else {
        my $a = 2
        my $b = 2
        for my $i (2..$n) {
            my $c = 2 * $b + $a
            ($a, $b) = ($b, $c)
        }
        $b
    }
}

assert_eq Rosetta::PellLucas::compute(0), 2, "Q(0)"
assert_eq Rosetta::PellLucas::compute(1), 2, "Q(1)"
assert_eq Rosetta::PellLucas::compute(2), 6, "Q(2)"
assert_eq Rosetta::PellLucas::compute(3), 14, "Q(3)"
assert_eq Rosetta::PellLucas::compute(4), 34, "Q(4)"
assert_eq Rosetta::PellLucas::compute(10), 6726, "Q(10)"

10 |> Rosetta::PellLucas::compute |> assert_eq(6726, "pipe pell-lucas")

test_run
