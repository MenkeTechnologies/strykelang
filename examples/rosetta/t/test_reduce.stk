#!/usr/bin/env stryke
# Rosetta Code: Reduce (Fold)

fn Rosetta::Reduce::sum(@nums) {
    @nums |> reduce { _0 + _1 }
}

fn Rosetta::Reduce::product(@nums) {
    @nums |> reduce { _0 * _1 }
}

fn Rosetta::Reduce::max(@nums) {
    @nums |> reduce { _0 > _1 ? _0 : _1 }
}

fn Rosetta::Reduce::min(@nums) {
    @nums |> reduce { _0 < _1 ? _0 : _1 }
}

fn Rosetta::Reduce::concat_strings(@strs) {
    @strs |> reduce { _0 . _1 }
}

assert_eq Rosetta::Reduce::sum(1, 2, 3, 4, 5), 15, "sum 1..5"
assert_eq Rosetta::Reduce::sum(10), 10, "sum single"

assert_eq Rosetta::Reduce::product(1, 2, 3, 4, 5), 120, "product 1..5"
assert_eq Rosetta::Reduce::product(2, 3), 6, "product 2,3"

assert_eq Rosetta::Reduce::max(3, 1, 4, 1, 5, 9), 9, "max"
assert_eq Rosetta::Reduce::min(3, 1, 4, 1, 5, 9), 1, "min"

assert_eq Rosetta::Reduce::concat_strings("a", "b", "c"), "abc", "concat strings"

my $sum_sq = 1..5 |> map { _ * _ } |> reduce { _0 + _1 }
assert_eq $sum_sq, 55, "sum of squares 1..5"

test_run
