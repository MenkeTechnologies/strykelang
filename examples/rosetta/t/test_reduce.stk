#!/usr/bin/env stryke
# Rosetta Code: Reduce (Fold)

fn my_sum {
    my @nums = @_
    if (!@nums) { 0 }
    else { @nums |> reduce { $a + $b } }
}

fn my_product {
    my @nums = @_
    if (!@nums) { 1 }
    else { @nums |> reduce { $a * $b } }
}

fn my_max {
    my @nums = @_
    @nums |> reduce {
        if ($a > $b) { $a }
        else { $b }
    }
}

fn my_min {
    my @nums = @_
    @nums |> reduce {
        if ($a < $b) { $a }
        else { $b }
    }
}

fn concat_strings {
    my @strs = @_
    @strs |> reduce { "$a$b" }
}

assert_eq my_sum(1, 2, 3, 4, 5), 15, "sum 1..5"
assert_eq my_sum(10), 10, "sum single"

assert_eq my_product(1, 2, 3, 4, 5), 120, "product 1..5"
assert_eq my_product(2, 3), 6, "product 2,3"

assert_eq my_max(3, 1, 4, 1, 5, 9), 9, "max"
assert_eq my_min(3, 1, 4, 1, 5, 9), 1, "min"

assert_eq concat_strings("a", "b", "c"), "abc", "concat strings"

my $sum_sq = 1..5 |> map { $_ * $_ } |> reduce { $a + $b }
assert_eq $sum_sq, 55, "sum of squares 1..5"

test_run
