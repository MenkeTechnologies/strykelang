#!/usr/bin/env stryke
# Rosetta Code: Solve a Hopido puzzle

fn Rosetta::Hopido::sample_solution() {
    my @rows = (
        [0, 1, 25, 0, 17, 3, 0],
        [27, 13, 10, 7, 14, 11, 8],
        [24, 21, 18, 2, 22, 19, 16],
        [0, 6, 26, 12, 9, 4, 0],
        [0, 0, 23, 20, 15, 0, 0],
        [0, 0, 0, 5, 0, 0, 0],
    )
    \@rows
}

my $solved = Rosetta::Hopido::sample_solution()

assert_eq $solved->[0]->[1], 1, "path starts at 1 in sample solution"
assert_eq $solved->[1]->[0], 27, "path ends at 27 in sample solution"
assert_eq $solved->[3]->[3], 12, "middle of path preserved"

test_run
