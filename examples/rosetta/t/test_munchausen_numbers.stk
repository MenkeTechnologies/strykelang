#!/usr/bin/env stryke
# Rosetta Code: Munchausen numbers

fn Rosetta::Munchausen::is_munchausen($n) {
    fn Rosetta::Munchausen::pow($d) {
        if ($d == 0) { 0 } else { $d ** $d }
    }

    my $sum = ~> "$n" chars 
              |> map { Rosetta::Munchausen::pow(int(_)) } 
              |> reduce { $_0 + $_1 }
    
    $sum == $n
}

assert_ok Rosetta::Munchausen::is_munchausen(1), "1 is Munchausen"
assert_ok Rosetta::Munchausen::is_munchausen(3435), "3435 is Munchausen"
assert_ok !Rosetta::Munchausen::is_munchausen(100), "100 is not Munchausen"

test_run
