#!/usr/bin/env stryke
# Rosetta Code: Euclidean distance (using pipes)

fn Rosetta::EuclideanDistance::compute($v1, $v2) {
    zip(@$v1, @$v2) |> map { (_->[0] - _->[1]) ** 2 } |> sum() |> sqrt()
}

assert_eq Rosetta::EuclideanDistance::compute([0, 0], [3, 4]), 5, "3-4-5 triangle"
assert_near Rosetta::EuclideanDistance::compute([1, 1], [2, 2]), 1.4142, 0.0001, "Diagonal distance"
assert_eq Rosetta::EuclideanDistance::compute([0, 0, 0], [1, 2, 2]), 3, "3D distance (1+4+4=9, sqrt=3)"

test_run
