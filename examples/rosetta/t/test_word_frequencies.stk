#!/usr/bin/env stryke
# Rosetta Code: Word frequency

fn Rosetta::WordFrequencies::word_frequency {
    var $counts = {}
    val @words = split(/[^a-z]+/, lc(_))
    ~> @words grep { _ ne "" } map { $counts->{_} = $counts->{_} + 1 }
    $counts
}

val $text = "The quick brown fox jumps over the lazy dog. The dog was not amused."
val $f = Rosetta::WordFrequencies::word_frequency($text)
assert_eq $f->{the}, 3, "frequency of 'the'"
assert_eq $f->{dog}, 2, "frequency of 'dog'"
assert_eq $f->{fox}, 1, "frequency of 'fox'"

test_run
