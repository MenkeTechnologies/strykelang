#!/usr/bin/env stryke
# Rosetta Code: Find First and Last Index

fn find_first($needle, @haystack) {
    for my $i (0..$#haystack) {
        return $i if $haystack[$i] eq $needle
    }
    -1
}

fn find_last($needle, @haystack) {
    for (my $i = $#haystack; $i >= 0; $i--) {
        return $i if $haystack[$i] eq $needle
    }
    -1
}

fn find_all($needle, @haystack) {
    my @indices
    for my $i (0..$#haystack) {
        push @indices, $i if $haystack[$i] eq $needle
    }
    @indices
}

my @arr = qw(a b c d b e b)

assert_eq find_first("b", @arr), 1, "first b at 1"
assert_eq find_last("b", @arr), 6, "last b at 6"
assert_eq find_first("d", @arr), 3, "first d at 3"
assert_eq find_first("x", @arr), -1, "x not found"

my @all_b = find_all("b", @arr)
assert_eq join(",", @all_b), "1,4,6", "all indices of b"

my @nums = (1, 2, 3, 2, 4, 2, 5)
assert_eq find_first(2, @nums), 1, "first 2"
assert_eq find_last(2, @nums), 5, "last 2"

test_run
