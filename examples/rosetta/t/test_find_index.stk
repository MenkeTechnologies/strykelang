#!/usr/bin/env stryke
# Rosetta Code: Find First and Last Index

fn Rosetta::FindIndex::first($needle, @haystack) {
    my $found = -1
    for my $i (0..$#haystack) {
        if ($found == -1 && $haystack[$i] eq $needle) {
            $found = $i
        }
    }
    $found
}

fn Rosetta::FindIndex::last($needle, @haystack) {
    my $found = -1
    for my $i (0..$#haystack) {
        if ($haystack[$i] eq $needle) {
            $found = $i
        }
    }
    $found
}

fn Rosetta::FindIndex::all($needle, @haystack) {
    my @indices
    for my $i (0..$#haystack) {
        push @indices, $i if $haystack[$i] eq $needle
    }
    @indices
}

my @arr = qw(a b c d b e b)

assert_eq Rosetta::FindIndex::first("b", @arr), 1, "first b at 1"
assert_eq Rosetta::FindIndex::last("b", @arr), 6, "last b at 6"
assert_eq Rosetta::FindIndex::first("d", @arr), 3, "first d at 3"
assert_eq Rosetta::FindIndex::first("x", @arr), -1, "x not found"

my @all_b = Rosetta::FindIndex::all("b", @arr)
assert_eq join(",", @all_b), "1,4,6", "all indices of b"

my @nums = (1, 2, 3, 2, 4, 2, 5)
assert_eq Rosetta::FindIndex::first(2, @nums), 1, "first 2"
assert_eq Rosetta::FindIndex::last(2, @nums), 5, "last 2"

test_run
