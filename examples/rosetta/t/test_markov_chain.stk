#!/usr/bin/env stryke
# Rosetta Code: Markov Chain Text Generator

fn Rosetta::MarkovChain::build($text) {
    val @words = split(" ", $text)
    var %chain
    for val $i (0..len(@words)-2) {
        val $w1 = $words[$i]
        val $w2 = $words[$i+1]
        if (!exists $chain{$w1}) { $chain{$w1} = [] }
        push @{$chain{$w1}}, $w2
    }
    \%chain
}

fn Rosetta::MarkovChain::generate($chain, $start, $len) {
    var $curr = $start
    var @res = ($curr)
    for val $i (1:$len-1) {
        if (!exists $chain->{$curr}) { last }
        val $opts = $chain->{$curr}
        $curr = $opts->[int(rand(len(@$opts)))]
        push @res, $curr
    }
    join(" ", @res)
}

val $input = "the quick brown fox jumps over the lazy dog and the quick cat the quick brown"
val $chain = Rosetta::MarkovChain::build($input)

val $gen = Rosetta::MarkovChain::generate($chain, "the", 5)
assert_ok len(split(" ", $gen)) >= 3, "generated some words"
assert_ok $gen =~ /^the/, "starts with the"

test_run
