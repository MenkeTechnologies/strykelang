#!/usr/bin/env stryke
# Rosetta Code: Kahan summation — compensated summation reducing FP rounding error

fn Rosetta::Kahan::sum(@nums) {
    my $s = 0.0
    my $c = 0.0
    for my $x (@nums) {
        my $y = $x - $c
        my $t = $s + $y
        $c = ($t - $s) - $y
        $s = $t
    }
    $s
}

fn Rosetta::Kahan::naive(@nums) {
    my $s = 0.0
    for my $x (@nums) { $s += $x }
    $s
}

# Pathological: 1.0 plus many small numbers
my @arr = (1.0, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16, 1e-16)
my $kahan = Rosetta::Kahan::sum(@arr)
my $naive = Rosetta::Kahan::naive(@arr)
# Kahan should be closer to 1 + 1e-15 = 1.000_000_000_000_001
my $err_k = abs($kahan - (1.0 + 10 * 1e-16))
my $err_n = abs($naive - (1.0 + 10 * 1e-16))
assert_ok $err_k <= $err_n, "Kahan no worse than naive on pathological case"

# Both correct on simple cases
assert_eq Rosetta::Kahan::sum(1, 2, 3, 4),  10, "1+2+3+4"
assert_eq Rosetta::Kahan::sum(),            0,  "empty sum is 0"
assert_eq Rosetta::Kahan::sum(0.5, 0.5),    1,  "halves"

# Random-ish values: result matches naive within FP precision
my @data = (10000.0, 3.14159, 2.71828, 0.0, -100.0, 0.5)
my $k = Rosetta::Kahan::sum(@data)
my $n = Rosetta::Kahan::naive(@data)
assert_ok abs($k - $n) < 1e-9, "matches naive on tame data"

# Specific Kahan demo: 1 + 1e-100 + ... + 1e-100 (1e10 of them)
# (Skipped at scale; verify shape on smaller version)
my @demo = (1.0)
for my $i (1..1000) { push @demo, 1e-15 }
my $ks = Rosetta::Kahan::sum(@demo)
my $expected = 1.0 + 1000 * 1e-15
my $rel_err = abs($ks - $expected) / $expected
assert_ok $rel_err < 1e-12, "Kahan keeps relative error tiny"

test_run
