#!/usr/bin/env stryke
# Rosetta Code: Balanced numbers

fn sum_digits($n) {
    my @digits = ~> "$n" chars map { int($_) }
    if (scalar(@digits) == 0) {
        0
    } else {
        @digits |> reduce { $a + $b }
    }
}

fn is_balanced($n) {
    my $s = "$n"
    my $len = length($s)
    my $half = int($len / 2)
    if ($half == 0) {
        1
    } else {
        my $s1 = substr($s, 0, $half)
        my $s2 = substr($s, $len - $half)
        sum_digits($s1) == sum_digits($s2)
    }
}

assert_ok is_balanced(1221), "1221 is balanced (1+2 = 2+1)"
assert_ok is_balanced(1230), "1230 is balanced (1+2 = 3+0)"
assert_ok is_balanced(121), "121 is balanced (1 = 1)"
assert_ok is_balanced(7), "7 is balanced (0 = 0)"
assert_ok !is_balanced(1234), "1234 not (3 != 7)"

1221 |> is_balanced |> assert_ok("pipe balanced")

test_run
