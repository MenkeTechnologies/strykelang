#!/usr/bin/env stryke
# Rosetta Code: Haversine formula

fn Rosetta::Haversine::compute($lat1, $lon1, $lat2, $lon2) {
    val $r = 6371 # Earth radius in km
    val $dlat = ($lat2 - $lat1) * (3.14159265 / 180)
    val $dlon = ($lon2 - $lon1) * (3.14159265 / 180)
    
    val $a = (sin($dlat / 2) ** 2) + cos($lat1 * (3.14159265 / 180)) * cos($lat2 * (3.14159265 / 180)) * (sin($dlon / 2) ** 2)
    val $c = 2 * atan2(sqrt($a), sqrt(1 - $a))
    $r * $c
}

# Nashville: 36.12, -86.67
# LAX: 33.94, -118.40
val $dist = Rosetta::Haversine::compute(36.12, -86.67, 33.94, -118.40)
assert_near $dist, 2887.25, 1.0, "Nashville to LAX is approx 2887km"

test_run
