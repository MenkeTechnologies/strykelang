#!/usr/bin/env stryke
# Rosetta Code: Check Machin-like formulas
# Sum of k_i * arctan(1/n_i) ?= pi/4. Use the tan-addition identity over rationals.

# We work with rational pairs [num, den] reduced.
fn Math::Rat::gcd($a, $b) {
    $a = abs($a); $b = abs($b)
    while ($b != 0) { my $t = $b; $b = $a % $b; $a = $t }
    $a
}

fn Math::Rat::reduce($r) {
    my $g = Math::Rat::gcd(abs($r->[0]), abs($r->[1]))
    return [0, 1] if $r->[0] == 0
    [int($r->[0] / $g), int($r->[1] / $g)]
}

fn Math::Rat::add($a, $b) {
    Math::Rat::reduce([$a->[0] * $b->[1] + $b->[0] * $a->[1], $a->[1] * $b->[1]])
}

fn Math::Rat::neg($a) { [-$a->[0], $a->[1]] }

# tan(A+B) = (tA + tB) / (1 - tA*tB)
fn Math::Rat::tan_sum($a, $b) {
    my $num = [$a->[0] * $b->[1] + $b->[0] * $a->[1], $a->[1] * $b->[1]]
    my $den = [$a->[1] * $b->[1] - $a->[0] * $b->[0], $a->[1] * $b->[1]]
    # ratio = num / den = (n1/d1) / (n2/d2) = n1*d2 / d1*n2
    Math::Rat::reduce([$num->[0] * $den->[1], $num->[1] * $den->[0]])
}

# tan(k * arctan(1/n)) for integer k.
fn Rosetta::Machin::tan_k_atan($k, $n) {
    my $base = [1, $n]
    my $sign = $k < 0 ? -1 : 1
    $k = abs($k)
    return [0, 1] if $k == 0
    my $r = $base
    for my $i (2..$k) {
        $r = Math::Rat::tan_sum($r, $base)
    }
    [$sign * $r->[0], $r->[1]]
}

# sum_i k_i * arctan(1/n_i) == pi/4 iff tan(LHS) == 1.
fn Rosetta::Machin::check(@terms) {
    # @terms is flat list k1,n1,k2,n2,...
    my $acc = [0, 1]
    for (my $i = 0; $i < len(@terms); $i += 2) {
        my $k = $terms[$i]
        my $n = $terms[$i + 1]
        my $t = Rosetta::Machin::tan_k_atan($k, $n)
        $acc = Math::Rat::tan_sum($acc, $t)
    }
    # Want acc == 1/1
    $acc->[0] == $acc->[1]
}

# Machin's original: 4*atan(1/5) - atan(1/239) = pi/4
assert_ok Rosetta::Machin::check(4, 5, -1, 239), "Machin (4*atan 1/5 - atan 1/239)"

# Euler 1738: atan(1/2) + atan(1/3) = pi/4
assert_ok Rosetta::Machin::check(1, 2, 1, 3), "Euler (atan 1/2 + atan 1/3)"

# Hermann: 2*atan(1/2) - atan(1/7) = pi/4
assert_ok Rosetta::Machin::check(2, 2, -1, 7), "Hermann (2*atan 1/2 - atan 1/7)"

# Negative case: 1*atan(1/5) ≠ pi/4
assert_ok !Rosetta::Machin::check(1, 5), "1*atan(1/5) is NOT pi/4"

test_run
