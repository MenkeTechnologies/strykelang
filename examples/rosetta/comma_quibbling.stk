#!/usr/bin/env stryke
# Rosetta Code: Comma Quibbling

fn quibble(@words) {
    return "{}" if @words == 0
    return "{$words[0]}" if @words == 1
    "{" . join(", ", @words[0..$#words-1]) . " and $words[-1]}"
}

my @tests = (
    [],
    ["ABC"],
    ["ABC", "DEF"],
    ["ABC", "DEF", "G", "H"]
)

for my $t (@tests) {
    p quibble(@$t)
}
