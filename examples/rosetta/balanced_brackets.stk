#!/usr/bin/env stryke
# Rosetta Code: Balanced Brackets

fn is_balanced($s) {
    my $d = 0
    ~> { $s } split // fore {
        $d += $_ eq '[' ? 1 : $_ eq ']' ? -1 : 0
        return 0 if $d < 0
    }
    $d == 0
}

~> { ("", "[]", "[][]", "[[][]]", "][", "][][", "[]][[]") } fore {
    p "'$_' → " . (is_balanced($_) ? "balanced" : "unbalanced")
}
