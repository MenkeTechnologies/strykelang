#!/usr/bin/env stryke
# Rosetta Code: Pascal's Triangle

fn pascal($rows) {
    my @tri = ([1])
    ~> { 1..$rows-1 } fore {
        my @prev = @{$tri[-1]}
        my @row = (1, (~> { 1..$#prev } map { $prev[$_-1] + $prev[$_] }), 1)
        push @tri, \@row
    }
    @tri
}

p "Pascal's Triangle (10 rows):"
~> { pascal(10) } fore {
    my $pad = " " x (25 - @$_ * 2)
    p $pad . (~> { @$_ } join " ")
}
