#!/usr/bin/env stryke
# Rosetta Code: Anagrams

fn sorted_chars($s) { ~> { $s } lc split // sort join "" }

fn find_anagrams(@words) {
    my %g
    ~> { @words } fore { push @{$g{sorted_chars($_)}}, $_ }
    ~> { values %g } grep { @$_ > 1 }
}

my @words = qw(evil vile live veil opts tops stop pots spot cat act tac dog)
p "Anagram groups:"
~> { find_anagrams(@words) } fore { p "  " . (~> { @$_ } join ", ") }
