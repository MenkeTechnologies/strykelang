#!/usr/bin/env stryke
# Rosetta Code: Anagrams

fn are_anagrams($s1, $s2) {
    my $normalize = fn ($s) {
        join("", sort split("", lc($s =~ s/\s//gr)))
    };
    return $normalize->($s1) eq $normalize->($s2);
}

printf "'Listen' and 'Silent' are anagrams: %d\n", are_anagrams("Listen", "Silent");
printf "'Hello' and 'World' are anagrams: %d\n", are_anagrams("Hello", "World");
