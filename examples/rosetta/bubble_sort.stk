#!/usr/bin/env stryke
# Rosetta Code: Bubble Sort

fn bubble_sort(@list) {
    my $n = scalar(@list);
    for (my $i = 0; $i < $n - 1; $i++) {
        for (my $j = 0; $j < $n - $i - 1; $j++) {
            if ($list[$j] > $list[$j + 1]) {
                ($list[$j], $list[$j+1]) = ($list[$j+1], $list[$j]);
            }
        }
    }
    return @list;
}

my @unsorted = (5, 1, 4, 2, 8, -3, 0);
my @sorted = bubble_sort(@unsorted);
print "Bubble Sort: " . join(", ", @sorted) . "\n";
