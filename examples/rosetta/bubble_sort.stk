#!/usr/bin/env stryke
# Rosetta Code: Bubble Sort

fn bubble(@a) {
    for my $i (0..$#a-1) {
        for my $j (0..$#a-$i-1) {
            ($a[$j], $a[$j+1]) = ($a[$j+1], $a[$j]) if $a[$j] > $a[$j+1]
        }
    }
    @a
}

my @u = (64, 34, 25, 12, 22, 11, 90)
p "Original: " . (~> { @u } join ", ")
p "Sorted:   " . (~> { bubble(@u) } join ", ")
