#!/usr/bin/env stryke
# Rosetta Code: Merge Sort

fn merge(\@l, \@r) {
    my @res
    while (@l && @r) {
        push @res, $l[0] <= $r[0] ? shift @l : shift @r
    }
    (@res, @l, @r)
}

fn msort(@a) {
    return @a if @a <= 1
    my $m = int(@a / 2)
    my @l = msort(@a[0..$m-1])
    my @r = msort(@a[$m..$#a])
    merge(\@l, \@r)
}

my @u = (38, 27, 43, 3, 9, 82, 10)
p "Original: " . (~> { @u } join ", ")
p "Sorted:   " . (~> { msort(@u) } join ", ")
