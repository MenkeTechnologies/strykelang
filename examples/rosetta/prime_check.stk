#!/usr/bin/env stryke
# Rosetta Code: Primality by Trial Division

fn prime_check($n) {
    return 0 if $n < 2
    return 1 if $n < 4
    return 0 if $n % 2 == 0
    my $i = 3
    while ($i * $i <= $n) {
        return 0 if $n % $i == 0
        $i += 2
    }
    1
}

fn list_primes($max) {
    2..$max |> filter { prime_check($_) }
}
