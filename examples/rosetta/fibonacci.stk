#!/usr/bin/env stryke
# Rosetta Code: Fibonacci Sequence (Recursive with Memoization)

my %memo;

fn fib($n) {
    return $n if $n <= 1;
    return $memo{$n} if exists $memo{$n};
    
    $memo{$n} = fib($n - 1) + fib($n - 2);
    return $memo{$n};
}

for my $i (0..20) {
    printf "fib(%d) = %d\n", $i, fib($i);
}
