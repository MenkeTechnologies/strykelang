#!/usr/bin/env stryke
# Rosetta Code: Regular Expressions

my $t = "The quick brown fox jumps over the lazy dog"
p "Text: $t\n"

p "Contains 'fox': " . ($t =~ /fox/ ? "yes" : "no")
$t =~ /(\w+) fox/ && p "Word before 'fox': $1"

p "4-letter words: " . (~> { $t =~ /\b\w{4}\b/g } join ", ")
p "After s/fox/cat/: " . ($t =~ s/fox/cat/r)
