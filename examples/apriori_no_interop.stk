#!/usr/bin/env stryke

# apriori_no_interop.stk — Apriori frequent-itemset mining.
#
# Bottom-up level-wise: build L1 (singletons that meet min-support),
# then at each level k self-join Lk to candidates of size k+1 (only
# pairs whose first k-1 items match — the "apriori property"), drop
# any candidate below min-support, repeat until Lk is empty.
# Parses clean under `--no-interop`.
#
# Idiomatic stryke per docs/STYLE_GUIDE.md:
#   * implicit return on tail (rule 7)
#   * `~>` thread macro chains (rule 7.2)
#   * `len`, colon ranges (rules 4, 5)
#
# Namespaced UDFs `Apriori::*`.
#
# Run: stryke --no-interop examples/apriori_no_interop.stk

# L1: every singleton item with support >= min_support, sorted lex.
fn Apriori::l1($transactions, $min_support) {
    my %counts
    for my $t (@$transactions) {
        for my $item (@$t) {
            $counts{$item} = ($counts{$item} // 0) + 1
        }
    }
    my @l1
    for my $item (keys %counts) {
        push @l1, [$item] if $counts{$item} >= $min_support
    }
    my @sorted = ~> @l1 sort { _0->[0] cmp _1->[0] }
    \@sorted
}

# Apriori self-join: candidate Lk+1 = pairs (s1, s2) in Lk where the
# first k-1 items match. Resulting set is sorted + deduped by key.
fn Apriori::join($lk, $k) {
    my @candidates
    my %seen
    my $n = len @$lk
    for my $i (0:$n - 1) {
        for my $j ($i + 1 : $n - 1) {
            my $s1 = $lk->[$i]
            my $s2 = $lk->[$j]
            my $match = 1
            for my $idx (0 : $k - 3) {
                if ($s1->[$idx] ne $s2->[$idx]) { $match = 0; last }
            }
            next unless $match
            my @new_set = @$s1
            push @new_set, $s2->[-1]
            my @sorted_set = ~> @new_set sort { _0 cmp _1 }
            my $key = join(",", @sorted_set)
            if (!$seen{$key}) {
                $seen{$key} = 1
                push @candidates, \@sorted_set
            }
        }
    }
    \@candidates
}

# Support count: how many transactions contain every item of each
# candidate. Hash key is the candidate's index in $candidates.
fn Apriori::support($candidates, $transactions) {
    my %support
    for my $t (@$transactions) {
        my %in_t
        for my $item (@$t) { $in_t{$item} = 1 }
        for my $i (0 : len(@$candidates) - 1) {
            my $c = $candidates->[$i]
            my $all = 1
            for my $item (@$c) {
                if (!$in_t{$item}) { $all = 0; last }
            }
            $support{$i} = ($support{$i} // 0) + 1 if $all
        }
    }
    \%support
}

# Drive the level-wise loop until Lk is empty. Returns arrayref of
# Lk arrayrefs: $result->[0] = L1, $result->[1] = L2, …
fn Apriori::solve($transactions, $min_support) {
    my @result
    my $lk = Apriori::l1($transactions, $min_support)
    push @result, $lk
    my $k = 2
    while (len(@$lk) > 0) {
        my $candidates = Apriori::join($lk, $k)
        my $counts = Apriori::support($candidates, $transactions)
        my @next
        for my $i (0 : len(@$candidates) - 1) {
            my $cnt = $counts->{$i} // 0
            push @next, $candidates->[$i] if $cnt >= $min_support
        }
        last if len(@next) == 0
        push @result, \@next
        $lk = \@next
        $k++
    }
    \@result
}

p "── Apriori demo ──"

my @transactions = (
    ["apple", "beer", "rice", "chicken"],
    ["apple", "beer", "rice"],
    ["apple", "beer"],
    ["apple", "mango"],
    ["milk", "beer", "rice", "chicken"],
    ["milk", "beer", "rice"],
    ["milk", "beer"],
    ["milk", "mango"],
)

my $min_support = 3
p "Transactions: #{len @transactions}, min support: #{$min_support}"

my $res = Apriori::solve(\@transactions, $min_support)
for my $k_idx (0 : len(@$res) - 1) {
    my $itemsets = $res->[$k_idx]
    p "\nFrequent #{$k_idx + 1}-itemsets:"
    for my $set (@$itemsets) {
        p "  [#{join ', ', @$set}]"
    }
}

p "Done."
