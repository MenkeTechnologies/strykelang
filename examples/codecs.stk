#!/usr/bin/env stryke

# Stryke codec roundtrips — JSON / YAML / TOML / CSV all share the
# `to_X` / `from_X` naming convention.

val $config = {
    name    => "stryke",
    version => "0.14.2",
    paths   => ["bin", "lib", "examples"],
    flags   => { jit => 1, strict => 1, parallel => 1 },
    weights => [0.1, 0.2, 0.3, 0.4],
}

p "── JSON roundtrip ─────────────────────────────────────"
val $j = to_json($config)
val $j_back = from_json($j)
p "  pretty:"
p "    $_" for split(/\n/, $j)
p "  name == ", $j_back->{name}, "  (roundtrip ok: ",
    ($j_back->{name} eq $config->{name}) ? "yes" : "no", ")"

p ""
p "── YAML roundtrip ─────────────────────────────────────"
val $y = to_yaml($config)
val $y_back = from_yaml($y)
p "  yaml:"
p "    $_" for split(/\n/, $y)
p "  roundtrip ok: ",
    ($y_back->{flags}->{jit} == 1) ? "yes" : "no"

p ""
p "── TOML roundtrip ─────────────────────────────────────"
val $t = to_toml($config)
val $t_back = from_toml($t)
p "  toml:"
p "    $_" for split(/\n/, $t)
p "  roundtrip ok: ",
    ($t_back->{name} eq $config->{name}) ? "yes" : "no"

p ""
p "── CSV — array-of-hashes / array-of-arrays ────────────"
val @rows = (
    { name => "alice", age => 30, role => "admin" },
    { name => "bob",   age => 28, role => "user"  },
    { name => "carol", age => 41, role => "user"  },
)
val $csv = to_csv(\@rows)
p "  csv:"
p "    $_" for split(/\n/, $csv)
val $back = from_csv($csv)
p "  parsed back: ", len(@$back), " rows"
p "  first row : ", to_json($back->[0])

p ""
p "── Cross-format: JSON → YAML → TOML ───────────────────"
val $multi = from_json($j)
val $as_yaml = to_yaml($multi)
val $as_toml = to_toml($multi)
p "  json → yaml lines: ", len([split(/\n/, $as_yaml)])
p "  json → toml lines: ", len([split(/\n/, $as_toml)])

p ""
p "── Compose with KV — config persistence ───────────────"
val $path = "/tmp/stryke_codec_demo.rkyv"
unlink($path)
val $db = kv_open($path)
kv_put($db, "config", $config)
kv_put($db, "config:json", to_json($config))
kv_put($db, "config:yaml", to_yaml($config))
kv_commit($db)

val $db2 = kv_open($path)
p "  reopened, keys: ", join(", ", kv_keys($db2))
val $back_cfg = kv_get($db2, "config")
p "  config->name : ", $back_cfg->{name}
p "  flags->jit   : ", $back_cfg->{flags}->{jit}
unlink($path)
