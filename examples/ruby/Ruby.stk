rb_test "array empty?",   "[].empty?",                      "true"
rb_test "array push",     "a = [1]; a.push(2, 3); a",       "[1, 2, 3]"
rb_test "array first",    "[10, 20, 30].first",             "10"
rb_test "array last",     "[10, 20, 30].last",              "30"
rb_test "array index",    "[10, 20, 30][1]",                "20"
rb_test "array neg idx",  "[10, 20, 30][-1]",               "30"
rb_test "array assign",   "a = [0,0,0]; a[1] = 99; a",      "[0, 99, 0]"
rb_test "array reverse",  "[1, 2, 3].reverse",              "[3, 2, 1]"
rb_test "array include?", "[1, 2, 3].include?(2)",          "true"
rb_test "array join",     "[1, 2, 3].join(\"-\")",          "\"1-2-3\""
rb_test "array sort",     "[3, 1, 2].sort",                 "[1, 2, 3]"
rb_test "array uniq",     "[1, 2, 1, 3, 2].uniq",           "[1, 2, 3]"
rb_test "array sum",      "[1, 2, 3, 4].sum",               "10"
rb_test "array map",      "[1, 2, 3].map { |x| x * 2 }",    "[2, 4, 6]"
rb_test "array select",   "[1, 2, 3, 4].select { |x| x > 2 }", "[3, 4]"
rb_test "array reject",   "[1, 2, 3, 4].reject { |x| x > 2 }", "[1, 2]"
rb_test "array find",     "[1, 2, 3, 4].find { |x| x > 2 }",   "3"
rb_test "array reduce",   "[1, 2, 3, 4].reduce(0) { |a, x| a + x }", "10"
rb_test "array reduce no init", "[1, 2, 3, 4].reduce { |a, x| a + x }", "10"
rb_test "array any?",     "[1, 2, 3].any? { |x| x > 2 }",   "true"
rb_test "array all?",     "[1, 2, 3].all? { |x| x > 0 }",   "true"
rb_test "array all? false","[1, 2, 3].all? { |x| x > 1 }",   "false"
rb_test "array each side effect",
    "x = 0; [1, 2, 3].each { |n| x += n }; x",                   "6"

