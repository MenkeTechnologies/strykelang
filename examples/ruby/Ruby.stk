#!/usr/bin/env stryke
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                  RUBY-SUBSET INTERPRETER IN STRYKE                        ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║ A Ruby interpreter implemented in pure stryke. Single file.              ║
# ║ MVP scope (more in Ruby.stk.wip — not yet polished):                      ║
# ║   - Integers, Floats, Strings, Symbols, Arrays, Hashes, Ranges, nil,    ║
# ║     true, false                                                            ║
# ║   - Arithmetic, comparison, logical (== != < > <= >= && || ! and or not) ║
# ║   - Variables, if/elsif/else, while, until, for-in, case/when            ║
# ║   - String interpolation #{...}                                           ║
# ║   - def name(args) ... end, return, blocks (each/map/select/reduce),    ║
# ║     yield, &block param                                                   ║
# ║   - Array methods: length push pop each map select reduce sort first    ║
# ║     last reverse include? join                                            ║
# ║   - String methods: length upcase downcase reverse chars split           ║
# ║   - Hash methods: keys values each [] []=                                 ║
# ║   - Integer methods: times upto downto                                    ║
# ║   - Range methods: each map to_a                                          ║
# ║   - Classes: class C; def m; ... end; end with @ivars and inheritance   ║
# ║   - Embedded test suite covering everything above                        ║
# ║                                                                            ║
# ║ Run all tests: stryke examples/ruby/Ruby.stk                              ║
# ║ Eval one expr: stryke examples/ruby/Ruby.stk -- -e '1 + 2'                ║
# ╚══════════════════════════════════════════════════════════════════════════╝

package Rb

# ── VALUE MODEL ────────────────────────────────────────────────────────────
#
# Tagged hashrefs. Every value has a `type` field. Uniform, debuggable, and
# works transparently with stryke's hashref machinery.

fn Rb::v_int($n)        { +{ type => "int",   val => $n } }
fn Rb::v_float($f)      { +{ type => "float", val => $f } }
fn Rb::v_str($s)        { +{ type => "str",   val => $s } }
fn Rb::v_sym($s)        { +{ type => "sym",   val => $s } }
fn Rb::v_bool($b)       { +{ type => "bool",  val => ($b ? 1 : 0) } }
fn Rb::v_nil()          { +{ type => "nil" } }
fn Rb::v_array($items)  { +{ type => "array", items => $items } }
fn Rb::v_hash($pairs)   { +{ type => "hash",  pairs => $pairs } }
fn Rb::v_range($lo, $hi, $exclusive) {
    +{ type => "range", lo => $lo, hi => $hi, exclusive => $exclusive }
}
fn Rb::v_proc($params, $body, $env) {
    +{ type => "proc", params => $params, body => $body, env => $env }
}
fn Rb::v_class($name, $parent) {
    +{
        type     => "class",
        name     => $name,
        parent   => $parent,
        methods  => +{},
        cmethods => +{},      # class-side (singleton) methods — `def self.foo`
        includes => [],       # mixed-in modules
    }
}
fn Rb::v_module($name) {
    +{ type => "module", name => $name, methods => +{} }
}
fn Rb::v_instance($klass) {
    +{ type => "instance", klass => $klass, ivars => +{} }
}
fn Rb::v_exception($klass, $msg) {
    +{ type => "exception", klass => $klass, message => $msg }
}

fn Rb::is_int($v)      { ref($v) eq "HASH" && $v->{type} eq "int" }
fn Rb::is_float($v)    { ref($v) eq "HASH" && $v->{type} eq "float" }
fn Rb::is_num($v)      { Rb::is_int($v) || Rb::is_float($v) }
fn Rb::is_str($v)      { ref($v) eq "HASH" && $v->{type} eq "str" }
fn Rb::is_sym($v)      { ref($v) eq "HASH" && $v->{type} eq "sym" }
fn Rb::is_bool($v)     { ref($v) eq "HASH" && $v->{type} eq "bool" }
fn Rb::is_nil($v)      { ref($v) eq "HASH" && $v->{type} eq "nil" }
fn Rb::is_array($v)    { ref($v) eq "HASH" && $v->{type} eq "array" }
fn Rb::is_hash($v)     { ref($v) eq "HASH" && $v->{type} eq "hash" }
fn Rb::is_range($v)    { ref($v) eq "HASH" && $v->{type} eq "range" }
fn Rb::is_proc($v)     { ref($v) eq "HASH" && $v->{type} eq "proc" }
fn Rb::is_class($v)    { ref($v) eq "HASH" && $v->{type} eq "class" }
fn Rb::is_module($v)   { ref($v) eq "HASH" && $v->{type} eq "module" }
fn Rb::is_instance($v) { ref($v) eq "HASH" && $v->{type} eq "instance" }
fn Rb::is_exception($v){ ref($v) eq "HASH" && $v->{type} eq "exception" }

# Ruby truthiness: only nil and false are falsy; 0, "", [] are TRUTHY.
fn Rb::is_truthy($v) {
    return 0 if Rb::is_nil($v)
    return 0 if Rb::is_bool($v) && $v->{val} == 0
    1
}

# Numeric extraction (works for int and float).
fn Rb::nv($v) {
    return $v->{val} if Rb::is_num($v)
    return 0
}

# Ruby-equality: structural for arrays/hashes, numeric for nums (1 == 1.0).
fn Rb::v_eq($a, $b) {
    return 1 if Rb::is_nil($a) && Rb::is_nil($b)
    return $a->{val} == $b->{val}     if Rb::is_num($a)  && Rb::is_num($b)
    return $a->{val} eq $b->{val}     if Rb::is_str($a)  && Rb::is_str($b)
    return $a->{val} eq $b->{val}     if Rb::is_sym($a)  && Rb::is_sym($b)
    return $a->{val} == $b->{val}     if Rb::is_bool($a) && Rb::is_bool($b)
    if (Rb::is_array($a) && Rb::is_array($b)) {
        val $ai = $a->{items}; val $bi = $b->{items}
        return 0 if len(@$ai) != len(@$bi)
        for (var $i = 0; $i < len(@$ai); $i++) {
            return 0 unless Rb::v_eq($ai->[$i], $bi->[$i])
        }
        return 1
    }
    0
}

fn Rb::v_cmp($a, $b) {
    if (Rb::is_num($a) && Rb::is_num($b)) {
        val $av = $a->{val}; val $bv = $b->{val}
        return $av < $bv ? -1 : ($av > $bv ? 1 : 0)
    }
    if (Rb::is_str($a) && Rb::is_str($b)) {
        return $a->{val} lt $b->{val} ? -1 : ($a->{val} gt $b->{val} ? 1 : 0)
    }
    if ($a->{type} eq "sym" && $b->{type} eq "sym") {
        return $a->{val} lt $b->{val} ? -1 : ($a->{val} gt $b->{val} ? 1 : 0)
    }
    0
}

# ── INSPECT / TO_S ─────────────────────────────────────────────────────────

fn Rb::inspect($v) {
    return "nil"                          if Rb::is_nil($v)
    return ($v->{val} ? "true" : "false") if Rb::is_bool($v)
    return $v->{val} . ""                 if Rb::is_int($v)
    if (Rb::is_float($v)) {
        val $s = $v->{val} . ""
        return $s . ".0" unless $s =~ /[.eE]/
        return $s
    }
    if (Rb::is_str($v)) {
        var $out = "\""
        for val $c (split //, $v->{val}) {
            if    ($c eq "\\") { $out .= "\\\\" }
            elsif ($c eq "\"") { $out .= "\\\"" }
            elsif ($c eq "\n") { $out .= "\\n" }
            elsif ($c eq "\t") { $out .= "\\t" }
            else               { $out .= $c }
        }
        return $out . "\""
    }
    return ":" . $v->{val} if Rb::is_sym($v)
    if (Rb::is_array($v)) {
        return "[" . join(", ", map {Rb::inspect} @{$v->{items}}) . "]"
    }
    if (Rb::is_hash($v)) {
        var @parts
        for val $p (@{$v->{pairs}}) {
            if (Rb::is_sym($p->[0])) {
                push @parts, $p->[0]{val} . ": " . Rb::inspect($p->[1])
            } else {
                push @parts, Rb::inspect($p->[0]) . " => " . Rb::inspect($p->[1])
            }
        }
        return "{" . join(", ", @parts) . "}"
    }
    if (Rb::is_range($v)) {
        val $sep = $v->{exclusive} ? "..." : ".."
        return Rb::inspect($v->{lo}) . $sep . Rb::inspect($v->{hi})
    }
    return "#<Proc>"  if Rb::is_proc($v)
    return $v->{name} if Rb::is_class($v)
    if (Rb::is_instance($v)) {
        var @parts
        for val $k (sort keys %{$v->{ivars}}) {
            push @parts, "@" . $k . "=" . Rb::inspect($v->{ivars}{$k})
        }
        val $body = len(@parts) ? " " . join(", ", @parts) : ""
        return "#<" . $v->{klass}{name} . $body . ">"
    }
    if (Rb::is_exception($v)) {
        # Ruby's `e.inspect` formats as `#<Class: message>`; Stryke tests for
        # bare `e` without `.inspect` so we keep the message-only short form.
        val $m = $v->{message} // $v->{klass}{name}
        return "\"" . $m . "\""
    }
    "#<unknown>"
}

fn Rb::to_s($v) {
    return $v->{val} if Rb::is_str($v) || Rb::is_sym($v)
    return ""        if Rb::is_nil($v)
    return $v->{message} // $v->{klass}{name} if Rb::is_exception($v)
    Rb::inspect($v)
}

# ── TOKENIZER ──────────────────────────────────────────────────────────────
#
# Splits Ruby source into tokens. Each token is +{ kind, val, line }.
# Newlines are significant (Ruby statement separator).

fn Rb::tokenize($src) {
    var @toks
    var $i = 0
    var $line = 1
    val $n = length($src)

    while ($i < $n) {
        val $c = substr($src, $i, 1)

        if ($c eq " " || $c eq "\t" || $c eq "\r") { $i++; next }
        if ($c eq "\n") {
            push @toks, +{ kind => "NL", val => "", line => $line }
            $line++; $i++; next
        }
        # Line continuation
        if ($c eq "\\" && substr($src, $i + 1, 1) eq "\n") {
            $line++; $i += 2; next
        }
        # Comment
        if ($c eq "#") {
            while ($i < $n && substr($src, $i, 1) ne "\n") { $i++ }
            next
        }

        # Numbers
        if ($c =~ /[0-9]/) {
            val $start = $i
            var $is_float = 0
            while ($i < $n && substr($src, $i, 1) =~ /[0-9_]/) { $i++ }
            if ($i < $n && substr($src, $i, 1) eq "."
                && $i + 1 < $n && substr($src, $i + 1, 1) =~ /[0-9]/) {
                $is_float = 1
                $i++
                while ($i < $n && substr($src, $i, 1) =~ /[0-9_]/) { $i++ }
            }
            var $text = substr($src, $start, $i - $start)
            $text =~ s/_//g
            if ($is_float) {
                push @toks, +{ kind => "FLOAT", val => $text + 0, line => $line }
            } else {
                push @toks, +{ kind => "INT", val => int($text), line => $line }
            }
            next
        }

        # %w[...] / %i[...] / %w(...) / %w{...} word arrays.
        # Splits on whitespace, emits LBRACK <STR|SYM> COMMA ... RBRACK so the
        # array-literal parser builds an Array AST node.
        if ($c eq "%" && $i + 1 < $n && substr($src, $i + 1, 1) =~ /[wi]/) {
            val $kind = substr($src, $i + 1, 1)
            val $opener = $i + 2 < $n ? substr($src, $i + 2, 1) : ""
            val %close = ("[" => "]", "(" => ")", "{" => "}", "<" => ">")
            if (exists $close{$opener}) {
                $i += 3
                val $closer = $close{$opener}
                push @toks, +{ kind => "LBRACK", val => "[", line => $line }
                var $first = 1
                while ($i < $n && substr($src, $i, 1) ne $closer) {
                    while ($i < $n && substr($src, $i, 1) =~ /\s/) {
                        $line++ if substr($src, $i, 1) eq "\n"
                        $i++
                    }
                    last if $i >= $n || substr($src, $i, 1) eq $closer
                    val $start = $i
                    while ($i < $n && substr($src, $i, 1) ne $closer && substr($src, $i, 1) !~ /\s/) { $i++ }
                    val $word = substr($src, $start, $i - $start)
                    push @toks, +{ kind => "COMMA", val => ",", line => $line } unless $first
                    $first = 0
                    if ($kind eq "w") {
                        push @toks, +{ kind => "STR", val => $word, line => $line }
                    } else {
                        push @toks, +{ kind => "SYM", val => $word, line => $line }
                    }
                }
                $i++ if $i < $n
                push @toks, +{ kind => "RBRACK", val => "]", line => $line }
                next
            }
        }

        # Single-quoted string
        if ($c eq "'") {
            $i++
            var $s = ""
            while ($i < $n && substr($src, $i, 1) ne "'") {
                if (substr($src, $i, 1) eq "\\" && $i + 1 < $n) {
                    val $nx = substr($src, $i + 1, 1)
                    if ($nx eq "\\") { $s .= "\\"; $i += 2; next }
                    if ($nx eq "'")  { $s .= "'";  $i += 2; next }
                    $s .= "\\"; $i++; next
                }
                $line++ if substr($src, $i, 1) eq "\n"
                $s .= substr($src, $i, 1)
                $i++
            }
            $i++ if $i < $n
            push @toks, +{ kind => "STR", val => $s, line => $line }
            next
        }

        # Double-quoted string with #{} interpolation. The interpolation
        # produces a STRINTERP token whose `val` is an arrayref of mixed
        # ["lit", text] / ["expr", text] entries.
        if ($c eq "\"") {
            $i++
            var @parts = (["lit", ""])
            while ($i < $n && substr($src, $i, 1) ne "\"") {
                val $cur = substr($src, $i, 1)
                if ($cur eq "\\" && $i + 1 < $n) {
                    val $nx = substr($src, $i + 1, 1)
                    val $esc =
                        $nx eq "n"  ? "\n" :
                        $nx eq "t"  ? "\t" :
                        $nx eq "r"  ? "\r" :
                        $nx eq "\\" ? "\\" :
                        $nx eq "\"" ? "\"" :
                        $nx eq "0"  ? "\0" :
                        $nx eq "#"  ? "#"  :
                        $nx
                    $parts[-1][1] .= $esc
                    $i += 2
                    next
                }
                if ($cur eq "#" && $i + 1 < $n && substr($src, $i + 1, 1) eq "{") {
                    $i += 2
                    var $depth = 1
                    var $expr = ""
                    while ($i < $n && $depth > 0) {
                        val $ch = substr($src, $i, 1)
                        if    ($ch eq "{") { $depth++ }
                        elsif ($ch eq "}") { $depth--; last if $depth == 0 }
                        $line++ if $ch eq "\n"
                        $expr .= $ch
                        $i++
                    }
                    $i++ if $i < $n
                    push @parts, ["expr", $expr]
                    push @parts, ["lit", ""]
                    next
                }
                $line++ if $cur eq "\n"
                $parts[-1][1] .= $cur
                $i++
            }
            $i++ if $i < $n
            if (len(@parts) == 1) {
                push @toks, +{ kind => "STR", val => $parts[0][1], line => $line }
            } else {
                push @toks, +{ kind => "STRINTERP", val => \@parts, line => $line }
            }
            next
        }

        # Symbol — :name (also :"..." but skipped for MVP)
        if ($c eq ":" && $i + 1 < $n && substr($src, $i + 1, 1) =~ /[a-zA-Z_]/) {
            $i++
            val $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            push @toks, +{ kind => "SYM", val => substr($src, $start, $i - $start), line => $line }
            next
        }

        # Instance val @x
        if ($c eq "@") {
            $i++
            val $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            push @toks, +{ kind => "IVAR", val => substr($src, $start, $i - $start), line => $line }
            next
        }

        # Identifiers / keywords / constants
        if ($c =~ /[a-zA-Z_]/) {
            val $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            if ($i < $n && substr($src, $i, 1) =~ /[?!]/) { $i++ }
            val $word = substr($src, $start, $i - $start)
            var $kind
            if (Rb::is_keyword($word))  { $kind = "KW" }
            elsif ($word =~ /^[A-Z]/)   { $kind = "CONST" }
            else                        { $kind = "IDENT" }
            push @toks, +{ kind => $kind, val => $word, line => $line }
            next
        }

        # Multi-char operators (longest first). Set `$matched` so the outer
        # loop can `next` past the trailing single-char fallback.
        var $matched = 0
        for val $op ("<=>", "===", "...", "..", "**", "==", "!=", "<=", ">=",
                    "<<", ">>", "&&", "||", "+=", "-=", "*=", "/=", "%=",
                    "->", "=>", "::") {
            val $L = length($op)
            if ($i + $L <= $n && substr($src, $i, $L) eq $op) {
                push @toks, +{ kind => "OP", val => $op, line => $line }
                $i += $L
                $matched = 1
                last
            }
        }
        next if $matched

        if ($c eq "(") { push @toks, +{ kind => "LPAREN", val => "(", line => $line }; $i++; next }
        if ($c eq ")") { push @toks, +{ kind => "RPAREN", val => ")", line => $line }; $i++; next }
        if ($c eq "[") { push @toks, +{ kind => "LBRACK", val => "[", line => $line }; $i++; next }
        if ($c eq "]") { push @toks, +{ kind => "RBRACK", val => "]", line => $line }; $i++; next }
        if ($c eq "{") { push @toks, +{ kind => "LBRACE", val => "{", line => $line }; $i++; next }
        if ($c eq "}") { push @toks, +{ kind => "RBRACE", val => "}", line => $line }; $i++; next }
        if ($c eq ",") { push @toks, +{ kind => "COMMA",  val => ",", line => $line }; $i++; next }
        if ($c eq ";") { push @toks, +{ kind => "NL",     val => ";", line => $line }; $i++; next }
        if ($c eq "|") { push @toks, +{ kind => "OP",     val => "|", line => $line }; $i++; next }

        # Single-char operators
        if (index("+-*/%=<>!?:.&^~", $c) >= 0) {
            push @toks, +{ kind => "OP", val => $c, line => $line }
            $i++
            next
        }

        die "Rb::tokenize: unexpected char `" . $c . "` at line " . $line
    }
    push @toks, +{ kind => "EOF", val => "", line => $line }
    \@toks
}

fn Rb::is_keyword($w) {
    val %kw = map { $_ => 1 } qw(
        def end if elsif else unless while until for in do return yield
        nil true false class module self begin rescue raise ensure case when
        then and or not puts print p pp break next lambda proc new super
        attr_accessor attr_reader attr_writer include extend
    )
    exists $kw{$w} ? 1 : 0
}

# ── PARSER ─────────────────────────────────────────────────────────────────
#
# Recursive descent; AST nodes are tagged hashrefs.
# Parser state: +{ toks, pos }. Operations: peek, advance, eat, skip_nl.

fn Rb::p_new($toks) { +{ toks => $toks, pos => 0 } }
fn Rb::p_at($p)     { $p->{toks}->[$p->{pos}] }
fn Rb::p_at1($p)    { $p->{toks}->[$p->{pos} + 1] }
fn Rb::p_adv($p)    { val $t = $p->{toks}->[$p->{pos}]; $p->{pos}++; $t }
fn Rb::p_kind($p, $k)  { Rb::p_at($p)->{kind} eq $k }
fn Rb::p_op($p, $op)   { Rb::p_at($p)->{kind} eq "OP" && Rb::p_at($p)->{val} eq $op }
fn Rb::p_kw($p, $w)    { Rb::p_at($p)->{kind} eq "KW" && Rb::p_at($p)->{val} eq $w }
fn Rb::p_eat_kind($p, $k) {
    if (Rb::p_kind($p, $k)) { Rb::p_adv($p); return 1 }
    0
}
fn Rb::p_eat_op($p, $op) {
    if (Rb::p_op($p, $op)) { Rb::p_adv($p); return 1 }
    0
}
fn Rb::p_eat_kw($p, $w) {
    if (Rb::p_kw($p, $w)) { Rb::p_adv($p); return 1 }
    0
}
fn Rb::p_skip_nl($p) {
    while (Rb::p_kind($p, "NL")) { Rb::p_adv($p) }
}
fn Rb::p_expect_kind($p, $k) {
    unless (Rb::p_eat_kind($p, $k)) {
        val $t = Rb::p_at($p)
        die "Rb::parse: expected " . $k . ", got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}
fn Rb::p_expect_kw($p, $w) {
    unless (Rb::p_eat_kw($p, $w)) {
        val $t = Rb::p_at($p)
        die "Rb::parse: expected `" . $w . "`, got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}
fn Rb::p_expect_op($p, $op) {
    unless (Rb::p_eat_op($p, $op)) {
        val $t = Rb::p_at($p)
        die "Rb::parse: expected `" . $op . "`, got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}

fn Rb::parse($src) {
    val $toks = Rb::tokenize($src)
    val $p = Rb::p_new($toks)
    Rb::p_skip_nl($p)
    var @stmts
    while (!Rb::p_kind($p, "EOF")) {
        push @stmts, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    \@stmts
}

# Statement: an expression with optional postfix `if`/`unless`/`while`.
fn Rb::parse_stmt($p) {
    val $e = Rb::parse_expr($p)
    if (Rb::p_kw($p, "if")) {
        Rb::p_adv($p)
        val $c = Rb::parse_expr($p)
        return +{ kind => "If", cond => $c, then => [$e], elsifs => [], else => undef, line => $e->{line} }
    }
    if (Rb::p_kw($p, "unless")) {
        Rb::p_adv($p)
        val $c = Rb::parse_expr($p)
        return +{ kind => "Unless", cond => $c, then => [$e], else => undef, line => $e->{line} }
    }
    if (Rb::p_kw($p, "while")) {
        Rb::p_adv($p)
        val $c = Rb::parse_expr($p)
        return +{ kind => "While", cond => $c, body => [$e], line => $e->{line} }
    }
    $e
}

fn Rb::parse_expr($p) { Rb::parse_assign($p) }

fn Rb::parse_assign($p) {
    val $lhs = Rb::parse_ternary_op($p)
    if (Rb::p_op($p, "=")) {
        Rb::p_adv($p)
        val $rhs = Rb::parse_assign($p)
        return +{ kind => "Assign", target => $lhs, value => $rhs, line => $lhs->{line} }
    }
    for val $op ("+=", "-=", "*=", "/=", "%=") {
        if (Rb::p_op($p, $op)) {
            Rb::p_adv($p)
            val $rhs = Rb::parse_assign($p)
            val $bare = substr($op, 0, length($op) - 1)
            return +{ kind => "OpAssign", target => $lhs, op => $bare, value => $rhs, line => $lhs->{line} }
        }
    }
    $lhs
}

fn Rb::parse_ternary_op($p) {
    val $cond = Rb::parse_or($p)
    if (Rb::p_op($p, "?")) {
        Rb::p_adv($p)
        val $then = Rb::parse_or($p)
        Rb::p_expect_op($p, ":")
        val $else = Rb::parse_or($p)
        return +{ kind => "Ternary", cond => $cond, then => $then, else => $else, line => $cond->{line} }
    }
    $cond
}

fn Rb::parse_or($p) {
    var $left = Rb::parse_and($p)
    while (Rb::p_op($p, "||") || Rb::p_kw($p, "or")) {
        Rb::p_adv($p)
        val $right = Rb::parse_and($p)
        $left = +{ kind => "Or", left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_and($p) {
    var $left = Rb::parse_not($p)
    while (Rb::p_op($p, "&&") || Rb::p_kw($p, "and")) {
        Rb::p_adv($p)
        val $right = Rb::parse_not($p)
        $left = +{ kind => "And", left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_not($p) {
    if (Rb::p_kw($p, "not") || Rb::p_op($p, "!")) {
        Rb::p_adv($p)
        val $operand = Rb::parse_not($p)
        return +{ kind => "Not", operand => $operand, line => $operand->{line} }
    }
    Rb::parse_range($p)
}

fn Rb::parse_range($p) {
    val $left = Rb::parse_eq($p)
    if (Rb::p_op($p, "..") || Rb::p_op($p, "...")) {
        val $excl = Rb::p_at($p)->{val} eq "..."
        Rb::p_adv($p)
        val $right = Rb::parse_eq($p)
        return +{ kind => "Range", lo => $left, hi => $right, exclusive => $excl, line => $left->{line} }
    }
    $left
}

fn Rb::parse_eq($p) {
    var $left = Rb::parse_cmp($p)
    while (Rb::p_op($p, "==") || Rb::p_op($p, "!=") || Rb::p_op($p, "<=>") || Rb::p_op($p, "===")) {
        val $op = Rb::p_adv($p)->{val}
        val $right = Rb::parse_cmp($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_cmp($p) {
    var $left = Rb::parse_add($p)
    while (Rb::p_op($p, "<") || Rb::p_op($p, ">") || Rb::p_op($p, "<=") || Rb::p_op($p, ">=")) {
        val $op = Rb::p_adv($p)->{val}
        val $right = Rb::parse_add($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_add($p) {
    var $left = Rb::parse_shift($p)
    while (Rb::p_op($p, "+") || Rb::p_op($p, "-")) {
        val $op = Rb::p_adv($p)->{val}
        val $right = Rb::parse_shift($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_shift($p) {
    var $left = Rb::parse_mul($p)
    while (Rb::p_op($p, "<<") || Rb::p_op($p, ">>")) {
        val $op = Rb::p_adv($p)->{val}
        val $right = Rb::parse_mul($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_mul($p) {
    var $left = Rb::parse_pow($p)
    while (Rb::p_op($p, "*") || Rb::p_op($p, "/") || Rb::p_op($p, "%")) {
        val $op = Rb::p_adv($p)->{val}
        val $right = Rb::parse_pow($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_pow($p) {
    val $left = Rb::parse_unary($p)
    if (Rb::p_op($p, "**")) {
        Rb::p_adv($p)
        val $right = Rb::parse_pow($p)
        return +{ kind => "BinOp", op => "**", left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_unary($p) {
    if (Rb::p_op($p, "-")) {
        Rb::p_adv($p)
        val $operand = Rb::parse_unary($p)
        return +{ kind => "Neg", operand => $operand, line => $operand->{line} }
    }
    if (Rb::p_op($p, "+")) {
        Rb::p_adv($p)
        return Rb::parse_unary($p)
    }
    Rb::parse_postfix($p)
}

# Postfix chain: `.method(args) [block]` and `[index]`.
fn Rb::parse_postfix($p) {
    var $e = Rb::parse_primary($p)
    while (1) {
        if (Rb::p_op($p, ".")) {
            Rb::p_adv($p)
            val $t = Rb::p_adv($p)
            val $name = $t->{val}
            var @args
            var $block = undef
            if (Rb::p_kind($p, "LPAREN")) {
                Rb::p_adv($p)
                Rb::p_skip_nl($p)
                while (!Rb::p_kind($p, "RPAREN")) {
                    push @args, Rb::parse_expr($p)
                    if (!Rb::p_eat_kind($p, "COMMA")) { last }
                    Rb::p_skip_nl($p)
                }
                Rb::p_expect_kind($p, "RPAREN")
            }
            $block = Rb::try_block($p)
            $e = +{ kind => "Call", recv => $e, name => $name, args => \@args, block => $block, line => $e->{line} }
            next
        }
        if (Rb::p_kind($p, "LBRACK")) {
            Rb::p_adv($p)
            var @idx
            while (!Rb::p_kind($p, "RBRACK")) {
                push @idx, Rb::parse_expr($p)
                if (!Rb::p_eat_kind($p, "COMMA")) { last }
            }
            Rb::p_expect_kind($p, "RBRACK")
            if (Rb::p_op($p, "=")) {
                Rb::p_adv($p)
                val $val = Rb::parse_assign($p)
                $e = +{ kind => "IdxAssign", recv => $e, indices => \@idx, value => $val, line => $e->{line} }
            } else {
                $e = +{ kind => "Index", recv => $e, indices => \@idx, line => $e->{line} }
            }
            next
        }
        last
    }
    $e
}

# Block: { |args| ... } or do |args| ... end. Only recognized AFTER a Call.
fn Rb::try_block($p) {
    if (Rb::p_kind($p, "LBRACE")) { return Rb::parse_brace_block($p) }
    if (Rb::p_kw($p, "do"))       { return Rb::parse_do_block($p) }
    undef
}

fn Rb::parse_brace_block($p) {
    val $line = Rb::p_at($p)->{line}
    Rb::p_adv($p)
    val $params = Rb::parse_block_params($p)
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kind($p, "RBRACE")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kind($p, "RBRACE")
    +{ kind => "Block", params => $params, body => \@body, line => $line }
}

fn Rb::parse_do_block($p) {
    val $line = Rb::p_at($p)->{line}
    Rb::p_adv($p)
    val $params = Rb::parse_block_params($p)
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Block", params => $params, body => \@body, line => $line }
}

fn Rb::parse_block_params($p) {
    Rb::p_skip_nl($p)
    return [] unless Rb::p_op($p, "|")
    Rb::p_adv($p)
    var @params
    while (!Rb::p_op($p, "|")) {
        val $t = Rb::p_adv($p)
        push @params, $t->{val}
        last unless Rb::p_eat_kind($p, "COMMA")
    }
    Rb::p_expect_op($p, "|")
    \@params
}

fn Rb::parse_primary($p) {
    val $t = Rb::p_at($p)
    val $line = $t->{line}
    val $k = $t->{kind}

    if ($k eq "INT")   { Rb::p_adv($p); return +{ kind => "Int",   val => $t->{val}, line => $line } }
    if ($k eq "FLOAT") { Rb::p_adv($p); return +{ kind => "Float", val => $t->{val}, line => $line } }
    if ($k eq "STR")   { Rb::p_adv($p); return +{ kind => "Str",   val => $t->{val}, line => $line } }
    if ($k eq "SYM")   { Rb::p_adv($p); return +{ kind => "Sym",   val => $t->{val}, line => $line } }
    if ($k eq "STRINTERP") {
        Rb::p_adv($p)
        var @parts
        for val $part (@{$t->{val}}) {
            if ($part->[0] eq "lit") {
                push @parts, +{ kind => "Str", val => $part->[1], line => $line }
            } else {
                val $sub_p = Rb::p_new(Rb::tokenize($part->[1]))
                Rb::p_skip_nl($sub_p)
                push @parts, Rb::parse_expr($sub_p)
            }
        }
        return +{ kind => "StrInterp", parts => \@parts, line => $line }
    }
    if ($k eq "IVAR")  { Rb::p_adv($p); return +{ kind => "IVar",  name => $t->{val}, line => $line } }
    if ($k eq "CONST") { Rb::p_adv($p); return +{ kind => "Const", name => $t->{val}, line => $line } }
    if ($k eq "LPAREN") {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        val $e = Rb::parse_expr($p)
        Rb::p_skip_nl($p)
        Rb::p_expect_kind($p, "RPAREN")
        return $e
    }
    if ($k eq "LBRACK") {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @items
        while (!Rb::p_kind($p, "RBRACK")) {
            push @items, Rb::parse_expr($p)
            if (!Rb::p_eat_kind($p, "COMMA")) { last }
            Rb::p_skip_nl($p)
        }
        Rb::p_expect_kind($p, "RBRACK")
        return +{ kind => "Array", elems => \@items, line => $line }
    }
    if ($k eq "LBRACE") {
        # Hash literal — `{ k => v, sym: v }`.
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @pairs
        while (!Rb::p_kind($p, "RBRACE")) {
            var $key
            # `name:` shorthand for symbol keys.
            if (Rb::p_kind($p, "IDENT") && Rb::p_at1($p)->{kind} eq "OP" && Rb::p_at1($p)->{val} eq ":") {
                val $tn = Rb::p_adv($p)
                Rb::p_adv($p)
                $key = +{ kind => "Sym", val => $tn->{val}, line => $line }
            } else {
                $key = Rb::parse_expr($p)
                Rb::p_expect_op($p, "=>")
            }
            val $val = Rb::parse_expr($p)
            push @pairs, [$key, $val]
            if (!Rb::p_eat_kind($p, "COMMA")) { last }
            Rb::p_skip_nl($p)
        }
        Rb::p_expect_kind($p, "RBRACE")
        return +{ kind => "Hash", pairs => \@pairs, line => $line }
    }
    if ($k eq "KW") {
        var $w = $t->{val}
        if ($w eq "nil")    { Rb::p_adv($p); return +{ kind => "Nil",   line => $line } }
        if ($w eq "true")   { Rb::p_adv($p); return +{ kind => "True",  line => $line } }
        if ($w eq "false")  { Rb::p_adv($p); return +{ kind => "False", line => $line } }
        if ($w eq "self")   { Rb::p_adv($p); return +{ kind => "Self",  line => $line } }
        if ($w eq "if")     { return Rb::parse_if($p) }
        if ($w eq "unless") { return Rb::parse_unless($p) }
        if ($w eq "while")  { return Rb::parse_while($p) }
        if ($w eq "until")  { return Rb::parse_until($p) }
        if ($w eq "case")   { return Rb::parse_case($p) }
        if ($w eq "for")    { return Rb::parse_for($p) }
        if ($w eq "def")    { return Rb::parse_def($p) }
        if ($w eq "class")  { return Rb::parse_class($p) }
        if ($w eq "module") { return Rb::parse_module($p) }
        if ($w eq "begin")  { return Rb::parse_begin($p) }
        if ($w eq "return") { return Rb::parse_return($p) }
        if ($w eq "yield")  { return Rb::parse_yield($p) }
        if ($w eq "break")  { Rb::p_adv($p); return +{ kind => "Break", line => $line } }
        if ($w eq "next")   { Rb::p_adv($p); return +{ kind => "Next",  line => $line } }
        if ($w eq "raise")  { return Rb::parse_implicit_call($p, "raise") }
        if ($w eq "puts")   { return Rb::parse_implicit_call($p, "puts") }
        if ($w eq "print")  { return Rb::parse_implicit_call($p, "print") }
        if ($w eq "p")      { return Rb::parse_implicit_call($p, "p") }
        if ($w eq "pp")     { return Rb::parse_implicit_call($p, "pp") }
        if ($w eq "lambda") { return Rb::parse_lambda_or_proc($p, 1) }
        if ($w eq "proc")   { return Rb::parse_lambda_or_proc($p, 0) }
        if ($w eq "super") {
            Rb::p_adv($p)
            var @args
            var $explicit = 0
            if (Rb::p_kind($p, "LPAREN")) {
                Rb::p_adv($p)
                $explicit = 1
                while (!Rb::p_kind($p, "RPAREN")) {
                    push @args, Rb::parse_expr($p)
                    last unless Rb::p_eat_kind($p, "COMMA")
                }
                Rb::p_expect_kind($p, "RPAREN")
            }
            return +{ kind => "Super", args => \@args, explicit => $explicit, line => $line }
        }
        if ($w eq "attr_accessor" || $w eq "attr_reader" || $w eq "attr_writer") {
            return Rb::parse_implicit_call($p, $w)
        }
        if ($w eq "include" || $w eq "extend") {
            return Rb::parse_implicit_call($p, $w)
        }
    }
    if ($k eq "IDENT") {
        Rb::p_adv($p)
        val $name = $t->{val}
        if (Rb::p_kind($p, "LPAREN")) {
            Rb::p_adv($p)
            Rb::p_skip_nl($p)
            var @args
            while (!Rb::p_kind($p, "RPAREN")) {
                push @args, Rb::parse_expr($p)
                if (!Rb::p_eat_kind($p, "COMMA")) { last }
                Rb::p_skip_nl($p)
            }
            Rb::p_expect_kind($p, "RPAREN")
            val $block = Rb::try_block($p)
            return +{ kind => "Call", recv => undef, name => $name, args => \@args, block => $block, line => $line }
        }
        # Bareword followed by block (`thrice { |x| … }` or `thrice do … end`)
        # is a no-arg call with a block — common for yielding methods.
        if (Rb::p_kind($p, "LBRACE") || Rb::p_kw($p, "do")) {
            val $block = Rb::try_block($p)
            return +{ kind => "Call", recv => undef, name => $name, args => [], block => $block, line => $line }
        }
        return +{ kind => "Ident", name => $name, line => $line }
    }
    die "Rb::parse: unexpected " . $k . " `" . $t->{val} . "` at line " . $line
}

fn Rb::parse_implicit_call($p, $name) {
    val $line = Rb::p_adv($p)->{line}
    var @args
    if (Rb::p_kind($p, "NL") || Rb::p_kind($p, "EOF")) {
        return +{ kind => "Call", recv => undef, name => $name, args => \@args, block => undef, line => $line }
    }
    if (Rb::p_kind($p, "LPAREN")) {
        Rb::p_adv($p)
        while (!Rb::p_kind($p, "RPAREN")) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_kind($p, "COMMA")
        }
        Rb::p_expect_kind($p, "RPAREN")
    } else {
        while (1) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_kind($p, "COMMA")
        }
    }
    +{ kind => "Call", recv => undef, name => $name, args => \@args, block => undef, line => $line }
}

fn Rb::parse_lambda_or_proc($p, $is_lambda) {
    val $line = Rb::p_adv($p)->{line}
    val $blk = Rb::try_block($p)
    die "lambda/proc requires a block at line " . $line unless defined $blk
    +{ kind => "Lambda", params => $blk->{params}, body => $blk->{body}, line => $line }
}

fn Rb::parse_if($p) {
    val $line = Rb::p_adv($p)->{line}
    val $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "then")
    Rb::p_skip_nl($p)
    var @then; var @elsifs; var $else_body = undef
    while (!Rb::p_kw($p, "end") && !Rb::p_kw($p, "elsif") && !Rb::p_kw($p, "else")) {
        push @then, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    while (Rb::p_kw($p, "elsif")) {
        Rb::p_adv($p)
        val $ec = Rb::parse_expr($p)
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_nl($p)
        var @eb
        while (!Rb::p_kw($p, "end") && !Rb::p_kw($p, "elsif") && !Rb::p_kw($p, "else")) {
            push @eb, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        push @elsifs, [$ec, \@eb]
    }
    if (Rb::p_kw($p, "else")) {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @e
        while (!Rb::p_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "If", cond => $cond, then => \@then, elsifs => \@elsifs, else => $else_body, line => $line }
}

fn Rb::parse_unless($p) {
    val $line = Rb::p_adv($p)->{line}
    val $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "then")
    Rb::p_skip_nl($p)
    var @body; var $else_body = undef
    while (!Rb::p_kw($p, "end") && !Rb::p_kw($p, "else")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    if (Rb::p_kw($p, "else")) {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @e
        while (!Rb::p_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Unless", cond => $cond, then => \@body, else => $else_body, line => $line }
}

fn Rb::parse_while($p) {
    val $line = Rb::p_adv($p)->{line}
    val $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "While", cond => $cond, body => \@body, line => $line }
}

fn Rb::parse_until($p) {
    val $line = Rb::p_adv($p)->{line}
    val $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Until", cond => $cond, body => \@body, line => $line }
}

fn Rb::parse_case($p) {
    val $line = Rb::p_adv($p)->{line}
    var $subject = undef
    unless (Rb::p_kw($p, "when") || Rb::p_kind($p, "NL")) {
        $subject = Rb::parse_expr($p)
    }
    Rb::p_skip_nl($p)
    var @whens
    while (Rb::p_kw($p, "when")) {
        Rb::p_adv($p)
        var @pats
        push @pats, Rb::parse_expr($p)
        while (Rb::p_eat_kind($p, "COMMA")) {
            push @pats, Rb::parse_expr($p)
        }
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_nl($p)
        var @body
        while (!Rb::p_kw($p, "when") && !Rb::p_kw($p, "else") && !Rb::p_kw($p, "end")) {
            push @body, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        push @whens, [\@pats, \@body]
    }
    var $else_body = undef
    if (Rb::p_kw($p, "else")) {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @e
        while (!Rb::p_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Case", subject => $subject, whens => \@whens, else => $else_body, line => $line }
}

fn Rb::parse_for($p) {
    val $line = Rb::p_adv($p)->{line}
    val $var_t = Rb::p_adv($p)
    Rb::p_expect_kw($p, "in")
    val $iter = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "For", var => $var_t->{val}, iter => $iter, body => \@body, line => $line }
}

fn Rb::parse_def($p) {
    val $line = Rb::p_adv($p)->{line}
    # `def self.foo` → class method (singleton on the class).
    var $is_self = 0
    if (Rb::p_kw($p, "self")) {
        Rb::p_adv($p)
        Rb::p_expect_op($p, ".")
        $is_self = 1
    }
    val $name_t = Rb::p_adv($p)
    var $name = $name_t->{val}
    # `def foo=` setter — accept the trailing `=`.
    if (Rb::p_op($p, "=")) {
        Rb::p_adv($p)
        $name = $name . "="
    }
    var @params
    var $rest = undef                # `*args` slurp
    var $block_param = undef         # `&block`
    if (Rb::p_kind($p, "LPAREN")) {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        while (!Rb::p_kind($p, "RPAREN")) {
            if (Rb::p_op($p, "*")) {
                Rb::p_adv($p)
                $rest = Rb::p_adv($p)->{val}
            } elsif (Rb::p_op($p, "&")) {
                Rb::p_adv($p)
                $block_param = Rb::p_adv($p)->{val}
            } else {
                push @params, Rb::p_adv($p)->{val}
            }
            last unless Rb::p_eat_kind($p, "COMMA")
            Rb::p_skip_nl($p)
        }
        Rb::p_expect_kind($p, "RPAREN")
    } elsif (Rb::p_kind($p, "IDENT") || Rb::p_op($p, "*")) {
        while (!Rb::p_kind($p, "NL") && !Rb::p_kind($p, "EOF")) {
            if (Rb::p_op($p, "*")) {
                Rb::p_adv($p)
                $rest = Rb::p_adv($p)->{val}
            } else {
                push @params, Rb::p_adv($p)->{val}
            }
            last unless Rb::p_eat_kind($p, "COMMA")
        }
    }
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{
        kind        => "Def",
        name        => $name,
        params      => \@params,
        rest        => $rest,
        block_param => $block_param,
        is_self     => $is_self,
        body        => \@body,
        line        => $line,
    }
}

fn Rb::parse_class($p) {
    val $line = Rb::p_adv($p)->{line}
    val $name = Rb::p_adv($p)->{val}
    var $parent = undef
    if (Rb::p_op($p, "<")) {
        Rb::p_adv($p)
        $parent = Rb::p_adv($p)->{val}
    }
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Class", name => $name, parent => $parent, body => \@body, line => $line }
}

fn Rb::parse_module($p) {
    val $line = Rb::p_adv($p)->{line}
    val $name = Rb::p_adv($p)->{val}
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Module", name => $name, body => \@body, line => $line }
}

fn Rb::parse_begin($p) {
    val $line = Rb::p_adv($p)->{line}
    Rb::p_skip_nl($p)
    var @body
    while (!Rb::p_kw($p, "rescue") && !Rb::p_kw($p, "ensure") && !Rb::p_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_nl($p)
    }
    var @rescues
    while (Rb::p_kw($p, "rescue")) {
        Rb::p_adv($p)
        var $klass = undef
        var $var = undef
        if (Rb::p_kind($p, "CONST")) { $klass = Rb::p_adv($p)->{val} }
        if (Rb::p_op($p, "=>")) {
            Rb::p_adv($p)
            $var = Rb::p_adv($p)->{val}
        }
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_nl($p)
        var @rb
        while (!Rb::p_kw($p, "rescue") && !Rb::p_kw($p, "ensure") && !Rb::p_kw($p, "end")) {
            push @rb, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        push @rescues, +{ klass => $klass, var => $var, body => \@rb }
    }
    var $ensure = undef
    if (Rb::p_kw($p, "ensure")) {
        Rb::p_adv($p)
        Rb::p_skip_nl($p)
        var @eb
        while (!Rb::p_kw($p, "end")) {
            push @eb, Rb::parse_stmt($p)
            Rb::p_skip_nl($p)
        }
        $ensure = \@eb
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Begin", body => \@body, rescues => \@rescues, ensure => $ensure, line => $line }
}

fn Rb::parse_return($p) {
    val $line = Rb::p_adv($p)->{line}
    var $val = undef
    unless (Rb::p_kind($p, "NL") || Rb::p_kind($p, "EOF")) {
        $val = Rb::parse_expr($p)
    }
    +{ kind => "Return", value => $val, line => $line }
}

fn Rb::parse_yield($p) {
    val $line = Rb::p_adv($p)->{line}
    var @args
    if (Rb::p_kind($p, "LPAREN")) {
        Rb::p_adv($p)
        while (!Rb::p_kind($p, "RPAREN")) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_kind($p, "COMMA")
        }
        Rb::p_expect_kind($p, "RPAREN")
    } elsif (!Rb::p_kind($p, "NL") && !Rb::p_kind($p, "EOF")) {
        while (1) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_kind($p, "COMMA")
        }
    }
    +{ kind => "Yield", args => \@args, line => $line }
}

# ── EVALUATOR ──────────────────────────────────────────────────────────────
#
# Environment: arrayref of frames (innermost last). Lookups walk back; sets
# write to the innermost frame containing the name (or innermost if new).
# Context: hashref carrying env + self + current block + class registry.

fn Rb::env_new()              { [+{}] }
fn Rb::env_lookup($env, $name) {
    for val $frame (rev @$env) {
        return $frame->{$name} if exists $frame->{$name}
    }
    undef
}
fn Rb::env_has($env, $name) {
    for val $frame (@$env) {
        return 1 if exists $frame->{$name}
    }
    0
}
fn Rb::env_set($env, $name, $val) {
    for var $frame (rev @$env) {
        if (exists $frame->{$name}) { $frame->{$name} = $val; return $val }
    }
    $env->[-1]{$name} = $val
    $val
}
fn Rb::env_define($env, $name, $val) {
    $env->[-1]{$name} = $val
    $val
}

fn Rb::ctx_new() {
    +{
        env       => Rb::env_new(),
        self      => Rb::v_nil(),
        block     => undef,           # current method's &block
        cur_klass => undef,           # innermost open class
        classes   => +{},             # class registry (built-in + user)
    }
}

# Invoke a block: bind params, eval body, restore env. Used for `yield`,
# `.each { ... }`, `lambda { ... }.call`, etc.
fn Rb::call_block($block, $args, $ctx) {
    val $saved = $ctx->{env}
    val @new   = (@{$block->{env}}, +{})
    $ctx->{env} = \@new
    val $params = $block->{params}
    val $n = len(@$params)
    # Auto-splat: `[k, v]` block param against pair argument.
    if ($n > 1 && len(@$args) == 1 && Rb::is_array($args->[0])) {
        $args = $args->[0]{items}
    }
    for (var $i = 0; $i < $n; $i++) {
        Rb::env_define($ctx->{env}, $params->[$i], $args->[$i] // Rb::v_nil())
    }
    val $r = eval { Rb::eval_body($block->{body}, $ctx) }
    val $err = $@
    $ctx->{env} = $saved
    if ($err) {
        if (ref($err) eq "HASH" && $err->{flow} eq "next") {
            return $err->{value} // Rb::v_nil()
        }
        if (ref($err) eq "HASH" && $err->{flow} eq "return") {
            return $err->{value} // Rb::v_nil()
        }
        die $err
    }
    $r
}

# Run a list of statements; return the last value.
fn Rb::eval_body($body, $ctx) {
    var $r = Rb::v_nil()
    for val $s (@$body) {
        $r = Rb::eval_node($s, $ctx)
    }
    $r
}

# Top-level eval entry.
fn Rb::run($src, $ctx) {
    val $stmts = Rb::parse($src)
    Rb::eval_body($stmts, $ctx)
}

# Single-AST-node evaluator. ~30 node kinds; each branch ≤ a few lines.
fn Rb::eval_node($n, $ctx) {
    val $k = $n->{kind}

    return Rb::v_int($n->{val})    if $k eq "Int"
    return Rb::v_float($n->{val})  if $k eq "Float"
    return Rb::v_str($n->{val})    if $k eq "Str"
    return Rb::v_sym($n->{val})    if $k eq "Sym"
    return Rb::v_nil()             if $k eq "Nil"
    return Rb::v_bool(1)           if $k eq "True"
    return Rb::v_bool(0)           if $k eq "False"

    if ($k eq "StrInterp") {
        var $out = ""
        for val $part (@{$n->{parts}}) {
            $out .= Rb::to_s(Rb::eval_node($part, $ctx))
        }
        return Rb::v_str($out)
    }
    if ($k eq "Array") {
        return Rb::v_array([map { Rb::eval_node($_, $ctx) } @{$n->{elems}}])
    }
    if ($k eq "Hash") {
        var @pairs
        for val $p (@{$n->{pairs}}) {
            push @pairs, [Rb::eval_node($p->[0], $ctx), Rb::eval_node($p->[1], $ctx)]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($k eq "Range") {
        return Rb::v_range(Rb::eval_node($n->{lo}, $ctx),
                           Rb::eval_node($n->{hi}, $ctx),
                           $n->{exclusive})
    }
    if ($k eq "Self")  { return $ctx->{self} }

    if ($k eq "Ident") {
        val $name = $n->{name}
        if (Rb::env_has($ctx->{env}, $name)) {
            return Rb::env_lookup($ctx->{env}, $name)
        }
        # No-arg method call on self — most useful for instance methods.
        return Rb::dispatch($ctx->{self}, $name, [], undef, $ctx, 1)
    }
    if ($k eq "IVar") {
        val $self = $ctx->{self}
        return Rb::v_nil() unless Rb::is_instance($self)
        return $self->{ivars}{$n->{name}} // Rb::v_nil()
    }
    if ($k eq "Const") {
        val $name = $n->{name}
        return $ctx->{classes}{$name} if exists $ctx->{classes}{$name}
        die "Rb::eval: uninitialized constant " . $name
    }

    if ($k eq "Assign") {
        val $val = Rb::eval_node($n->{value}, $ctx)
        Rb::do_assign($n->{target}, $val, $ctx)
        return $val
    }
    if ($k eq "OpAssign") {
        val $cur = Rb::eval_node($n->{target}, $ctx)
        val $rhs = Rb::eval_node($n->{value}, $ctx)
        val $new = Rb::apply_op($n->{op}, $cur, $rhs)
        Rb::do_assign($n->{target}, $new, $ctx)
        return $new
    }
    if ($k eq "Index") {
        val $recv = Rb::eval_node($n->{recv}, $ctx)
        val @idx  = map { Rb::eval_node($_, $ctx) } @{$n->{indices}}
        return Rb::dispatch($recv, "[]", \@idx, undef, $ctx, 0)
    }
    if ($k eq "IdxAssign") {
        val $recv = Rb::eval_node($n->{recv}, $ctx)
        val @idx  = map { Rb::eval_node($_, $ctx) } @{$n->{indices}}
        val $val = Rb::eval_node($n->{value}, $ctx)
        val @args = (@idx, $val)
        return Rb::dispatch($recv, "[]=", \@args, undef, $ctx, 0)
    }

    if ($k eq "BinOp") {
        val $l = Rb::eval_node($n->{left}, $ctx)
        val $r = Rb::eval_node($n->{right}, $ctx)
        return Rb::apply_op($n->{op}, $l, $r)
    }
    if ($k eq "Neg") {
        val $v = Rb::eval_node($n->{operand}, $ctx)
        return Rb::v_int(-$v->{val})   if Rb::is_int($v)
        return Rb::v_float(-$v->{val}) if Rb::is_float($v)
        die "no `-` for " . $v->{type}
    }
    if ($k eq "Not") {
        return Rb::v_bool(Rb::is_truthy(Rb::eval_node($n->{operand}, $ctx)) ? 0 : 1)
    }
    if ($k eq "And") {
        val $l = Rb::eval_node($n->{left}, $ctx)
        return $l unless Rb::is_truthy($l)
        return Rb::eval_node($n->{right}, $ctx)
    }
    if ($k eq "Or") {
        var $l = Rb::eval_node($n->{left}, $ctx)
        return $l if Rb::is_truthy($l)
        return Rb::eval_node($n->{right}, $ctx)
    }

    if ($k eq "Ternary") {
        return Rb::eval_node(Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx)) ? $n->{then} : $n->{else}, $ctx)
    }
    if ($k eq "If") {
        if (Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            return Rb::eval_body($n->{then}, $ctx)
        }
        for val $eif (@{$n->{elsifs}}) {
            if (Rb::is_truthy(Rb::eval_node($eif->[0], $ctx))) {
                return Rb::eval_body($eif->[1], $ctx)
            }
        }
        return Rb::eval_body($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }
    if ($k eq "Unless") {
        unless (Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            return Rb::eval_body($n->{then}, $ctx)
        }
        return Rb::eval_body($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }
    if ($k eq "While") {
        var $r = Rb::v_nil()
        while (Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            val $v = eval { Rb::eval_body($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") { return $@->{value} // Rb::v_nil() }
                if (ref($@) eq "HASH" && $@->{flow} eq "next")  { next }
                die $@
            }
            $r = $v
        }
        return $r
    }
    if ($k eq "Until") {
        var $r = Rb::v_nil()
        while (!Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            val $v = eval { Rb::eval_body($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") { return $@->{value} // Rb::v_nil() }
                if (ref($@) eq "HASH" && $@->{flow} eq "next")  { next }
                die $@
            }
            $r = $v
        }
        return $r
    }
    if ($k eq "For") {
        val $iter = Rb::eval_node($n->{iter}, $ctx)
        val $items = Rb::iter_items($iter)
        var $r = Rb::v_nil()
        for val $item (@$items) {
            Rb::env_set($ctx->{env}, $n->{var}, $item)
            $r = eval { Rb::eval_body($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") { return $@->{value} // Rb::v_nil() }
                if (ref($@) eq "HASH" && $@->{flow} eq "next")  { next }
                die $@
            }
        }
        return $r
    }
    if ($k eq "Case") {
        val $subj = defined $n->{subject} ? Rb::eval_node($n->{subject}, $ctx) : undef
        for val $w (@{$n->{whens}}) {
            for val $pat (@{$w->[0]}) {
                val $pv = Rb::eval_node($pat, $ctx)
                if (defined $subj) {
                    return Rb::eval_body($w->[1], $ctx) if Rb::case_match($pv, $subj)
                } else {
                    return Rb::eval_body($w->[1], $ctx) if Rb::is_truthy($pv)
                }
            }
        }
        return Rb::eval_body($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }
    if ($k eq "Begin") {
        var $r = eval { Rb::eval_body($n->{body}, $ctx) }
        var $err = $@
        # Skip control-flow unwinds (return/break/next) — they propagate.
        if ($err && ref($err) eq "HASH" && exists($err->{flow})) {
            Rb::eval_body($n->{ensure}, $ctx) if defined $n->{ensure}
            die $err
        }
        if ($err) {
            # Coerce non-exception err (string die from internals, plain hashref) into an exception.
            var $exc
            if (Rb::is_exception($err)) {
                $exc = $err
            } else {
                val $msg = ref($err) eq "HASH" && exists($err->{message}) ? $err->{message} : "" . $err
                $exc = Rb::v_exception($ctx->{classes}{RuntimeError}, $msg)
            }
            for val $rs (@{$n->{rescues}}) {
                # Class filter: bare rescue matches StandardError + RuntimeError-like errors.
                var $matches = 1
                if (defined $rs->{klass}) {
                    val $cls = $ctx->{classes}{$rs->{klass}}
                    $matches = (defined($cls) && Rb::value_is_a($exc, $cls, $ctx)) ? 1 : 0
                } else {
                    val $std = $ctx->{classes}{StandardError}
                    $matches = (defined($std) && Rb::value_is_a($exc, $std, $ctx)) ? 1 : 0
                }
                next unless $matches
                if (defined $rs->{var}) {
                    Rb::env_define($ctx->{env}, $rs->{var}, $exc)
                }
                $r = Rb::eval_body($rs->{body}, $ctx)
                $err = undef
                last
            }
        }
        Rb::eval_body($n->{ensure}, $ctx) if defined $n->{ensure}
        die $err if $err
        return $r
    }
    if ($k eq "Return") {
        val $v = defined $n->{value} ? Rb::eval_node($n->{value}, $ctx) : Rb::v_nil()
        die +{ flow => "return", value => $v }
    }
    if ($k eq "Break")  { die +{ flow => "break",  value => Rb::v_nil() } }
    if ($k eq "Next")   { die +{ flow => "next",   value => Rb::v_nil() } }
    if ($k eq "Yield") {
        val $blk = $ctx->{block}
        die "no block given (yield)" unless defined $blk
        val @args = map { Rb::eval_node($_, $ctx) } @{$n->{args}}
        return Rb::call_block($blk, \@args, $ctx)
    }
    if ($k eq "Block" || $k eq "Lambda") {
        val @frames = @{$ctx->{env}}
        return Rb::v_proc($n->{params}, $n->{body}, \@frames)
    }
    if ($k eq "Def") {
        var $proc = Rb::v_proc($n->{params}, $n->{body}, [@{$ctx->{env}}])
        # Carry through optional rest / block-param markers for richer dispatch.
        $proc->{rest}        = $n->{rest}        if defined $n->{rest}
        $proc->{block_param} = $n->{block_param} if defined $n->{block_param}
        $proc->{name}        = $n->{name}
        val $owner = $ctx->{cur_klass}
        if (defined $owner) {
            if ($n->{is_self} && Rb::is_class($owner)) {
                # `def self.foo` — class-side method.
                $owner->{cmethods}{$n->{name}} = $proc
            } else {
                $owner->{methods}{$n->{name}} = $proc
            }
        } else {
            Rb::env_define($ctx->{env}, $n->{name}, $proc)
        }
        return Rb::v_sym($n->{name})
    }
    if ($k eq "Class") {
        val $name = $n->{name}
        var $klass
        if (exists $ctx->{classes}{$name}) {
            $klass = $ctx->{classes}{$name}
        } else {
            val $parent = defined($n->{parent}) ? $ctx->{classes}{$n->{parent}} : $ctx->{classes}{Object}
            $klass = Rb::v_class($name, $parent)
            $ctx->{classes}{$name} = $klass
        }
        val $saved = $ctx->{cur_klass}
        $ctx->{cur_klass} = $klass
        eval { Rb::eval_body($n->{body}, $ctx) }
        val $err = $@
        $ctx->{cur_klass} = $saved
        die $err if $err
        return $klass
    }
    if ($k eq "Module") {
        var $name = $n->{name}
        var $mod
        if (exists $ctx->{classes}{$name}) {
            $mod = $ctx->{classes}{$name}
        } else {
            $mod = Rb::v_module($name)
            $ctx->{classes}{$name} = $mod
        }
        val $saved = $ctx->{cur_klass}
        $ctx->{cur_klass} = $mod
        eval { Rb::eval_body($n->{body}, $ctx) }
        val $err = $@
        $ctx->{cur_klass} = $saved
        die $err if $err
        return $mod
    }
    if ($k eq "Super") {
        # `super` calls the same-named method on the parent class.
        val $klass = Rb::is_instance($ctx->{self}) ? $ctx->{self}{klass} : undef
        die "super outside method" unless defined $klass
        val $parent = $klass->{parent}
        die "super: no parent" unless defined $parent
        # Find the current method's name from `__method__` env binding (best-effort).
        val $mname = Rb::env_lookup($ctx->{env}, "__method__")
        val $mn = Rb::is_str($mname) ? $mname->{val} : (Rb::is_sym($mname) ? $mname->{val} : "?")
        val $proc = Rb::class_method($parent, $mn)
        die "super: method `" . $mn . "` not in parent" unless defined $proc
        var @args = map { Rb::eval_node($_, $ctx) } @{$n->{args}}
        # `super` (no parens) forwards the current method's args.
        unless ($n->{explicit}) {
            @args = ()
            for val $p (@{$ctx->{cur_method_params} // []}) {
                val $v = Rb::env_lookup($ctx->{env}, $p)
                push @args, defined($v) ? $v : Rb::v_nil()
            }
        }
        return Rb::call_method($proc, $ctx->{self}, \@args, $ctx->{block}, $ctx, $mn)
    }

    if ($k eq "Call") {
        var @args = map { Rb::eval_node($_, $ctx) } @{$n->{args}}
        var $blk = undef
        if (defined $n->{block}) {
            val @frames = @{$ctx->{env}}
            $blk = Rb::v_proc($n->{block}{params}, $n->{block}{body}, \@frames)
        }
        if (defined $n->{recv}) {
            val $recv = Rb::eval_node($n->{recv}, $ctx)
            return Rb::dispatch($recv, $n->{name}, \@args, $blk, $ctx, 0)
        }
        return Rb::dispatch_implicit($n->{name}, \@args, $blk, $ctx)
    }

    die "Rb::eval: unhandled " . $k
}

fn Rb::do_assign($target, $val, $ctx) {
    val $k = $target->{kind}
    if ($k eq "Ident") { Rb::env_set($ctx->{env}, $target->{name}, $val); return $val }
    if ($k eq "IVar") {
        val $self = $ctx->{self}
        $self->{ivars}{$target->{name}} = $val if Rb::is_instance($self)
        return $val
    }
    if ($k eq "Const") {
        $ctx->{classes}{$target->{name}} = $val
        return $val
    }
    # `obj.foo = val` desugars to `obj.foo=(val)` setter dispatch.
    if ($k eq "Call" && defined($target->{recv}) && !len(@{$target->{args}})) {
        var $recv = Rb::eval_node($target->{recv}, $ctx)
        return Rb::dispatch($recv, $target->{name} . "=", [$val], undef, $ctx, 0)
    }
    die "cannot assign to " . $k
}

fn Rb::apply_op($op, $l, $r) {
    if ($op eq "+") {
        return Rb::v_str($l->{val} . $r->{val})              if Rb::is_str($l) && Rb::is_str($r)
        return Rb::v_array([@{$l->{items}}, @{$r->{items}}]) if Rb::is_array($l) && Rb::is_array($r)
        if (Rb::is_num($l) && Rb::is_num($r)) {
            return Rb::is_float($l) || Rb::is_float($r)
                ? Rb::v_float($l->{val} + $r->{val})
                : Rb::v_int($l->{val} + $r->{val})
        }
    }
    if ($op eq "-") {
        if (Rb::is_num($l) && Rb::is_num($r)) {
            return Rb::is_float($l) || Rb::is_float($r)
                ? Rb::v_float($l->{val} - $r->{val})
                : Rb::v_int($l->{val} - $r->{val})
        }
    }
    if ($op eq "*") {
        return Rb::v_str($l->{val} x $r->{val}) if Rb::is_str($l) && Rb::is_int($r)
        if (Rb::is_num($l) && Rb::is_num($r)) {
            return Rb::is_float($l) || Rb::is_float($r)
                ? Rb::v_float($l->{val} * $r->{val})
                : Rb::v_int($l->{val} * $r->{val})
        }
    }
    if ($op eq "/") {
        if (Rb::is_int($l) && Rb::is_int($r)) {
            var $q = int($l->{val} / $r->{val})
            $q-- if (($l->{val} % $r->{val}) != 0) && (($l->{val} < 0) != ($r->{val} < 0))
            return Rb::v_int($q)
        }
        return Rb::v_float($l->{val} / $r->{val})
    }
    if ($op eq "%") {
        if (Rb::is_int($l) && Rb::is_int($r)) {
            var $m = $l->{val} % $r->{val}
            $m += $r->{val} if $m != 0 && (($m < 0) != ($r->{val} < 0))
            return Rb::v_int($m)
        }
        # `"fmt" % args` — sprintf-style formatting with %d, %s, %f, %x, etc.
        if (Rb::is_str($l)) {
            val @argv = Rb::is_array($r) ? @{$r->{items}} : ($r)
            val @raw = map { Rb::is_str($_) || Rb::is_sym($_) ? $_->{val} : Rb::is_num($_) ? $_->{val} : Rb::to_s($_) } @argv
            return Rb::v_str(sprintf($l->{val}, @raw))
        }
    }
    if ($op eq "**") {
        if (Rb::is_int($l) && Rb::is_int($r) && $r->{val} >= 0) {
            var $a = 1
            for (1 .. $r->{val}) { $a *= $l->{val} }
            return Rb::v_int($a)
        }
        return Rb::v_float($l->{val} ** $r->{val})
    }
    if ($op eq "==")  { return Rb::v_bool(Rb::v_eq($l, $r) ? 1 : 0) }
    if ($op eq "!=")  { return Rb::v_bool(Rb::v_eq($l, $r) ? 0 : 1) }
    if ($op eq "<=>") { return Rb::v_int(Rb::v_cmp($l, $r)) }
    if ($op eq "<")   { return Rb::v_bool(Rb::v_cmp($l, $r) <  0 ? 1 : 0) }
    if ($op eq ">")   { return Rb::v_bool(Rb::v_cmp($l, $r) >  0 ? 1 : 0) }
    if ($op eq "<=")  { return Rb::v_bool(Rb::v_cmp($l, $r) <= 0 ? 1 : 0) }
    if ($op eq ">=")  { return Rb::v_bool(Rb::v_cmp($l, $r) >= 0 ? 1 : 0) }
    if ($op eq "===") {
        return Rb::v_bool(Rb::case_match($l, $r) ? 1 : 0)
    }
    if ($op eq "<<") {
        # Array#<< appends in-place and returns the array; String#<< concats; Int#<< is left-shift.
        if (Rb::is_array($l)) { push @{$l->{items}}, $r; return $l }
        if (Rb::is_str($l))   { $l->{val} .= Rb::to_s($r); return $l }
        if (Rb::is_int($l) && Rb::is_int($r)) { return Rb::v_int($l->{val} << $r->{val}) }
    }
    if ($op eq ">>") {
        if (Rb::is_int($l) && Rb::is_int($r)) { return Rb::v_int($l->{val} >> $r->{val}) }
    }
    die "Rb::eval: unhandled op `" . $op . "`"
}

fn Rb::case_match($pat, $subj) {
    if (Rb::is_class($pat)) {
        val $kls = Rb::is_instance($subj) ? $subj->{klass} : undef
        var $c = $kls
        while (defined $c) {
            return 1 if $c->{name} eq $pat->{name}
            $c = $c->{parent}
        }
        return 0
    }
    if (Rb::is_range($pat)) {
        val $vn = Rb::nv($subj)
        val $lo = Rb::nv($pat->{lo})
        val $hi = Rb::nv($pat->{hi})
        return 0 if $vn < $lo
        return $pat->{exclusive} ? $vn < $hi : $vn <= $hi
    }
    Rb::v_eq($pat, $subj)
}

fn Rb::iter_items($it) {
    return $it->{items} if Rb::is_array($it)
    if (Rb::is_range($it)) {
        var @out
        val $lo = Rb::nv($it->{lo})
        val $hi = Rb::nv($it->{hi})
        val $end = $it->{exclusive} ? $hi : $hi + 1
        for (var $i = $lo; $i < $end; $i++) {
            push @out, Rb::v_int($i)
        }
        return \@out
    }
    if (Rb::is_hash($it)) {
        return [map { Rb::v_array([$_->[0], $_->[1]]) } @{$it->{pairs}}]
    }
    if (Rb::is_str($it)) {
        return [map {Rb::v_str} split //, $it->{val}]
    }
    die "cannot iterate " . $it->{type}
}

# ── DISPATCH ───────────────────────────────────────────────────────────────

fn Rb::dispatch_implicit($name, $args, $block, $ctx) {
    if ($name eq "puts") {
        if (len(@$args) == 0) { print "\n"; return Rb::v_nil() }
        for val $a (@$args) {
            if (Rb::is_array($a)) {
                for val $e (@{$a->{items}}) { print Rb::to_s($e), "\n" }
            } else {
                val $s = Rb::to_s($a)
                print $s
                print "\n" unless substr($s, -1) eq "\n"
            }
        }
        return Rb::v_nil()
    }
    if ($name eq "print") {
        print Rb::to_s($_) for @$args
        return Rb::v_nil()
    }
    if ($name eq "p") {
        print Rb::inspect($_), "\n" for @$args
        return len(@$args) == 1 ? $args->[0] : Rb::v_array($args)
    }
    if ($name eq "raise") {
        # raise                       — bare re-raise / RuntimeError
        # raise "msg"                 — RuntimeError with message
        # raise Class                 — instance of Class
        # raise Class, "msg"          — instance of Class with message
        # raise instance              — re-raise instance
        var $exc
        if (!len(@$args)) {
            $exc = Rb::v_exception($ctx->{classes}{RuntimeError}, "RuntimeError")
        } elsif (Rb::is_exception($args->[0])) {
            $exc = $args->[0]
        } elsif (Rb::is_class($args->[0])) {
            val $msg = len(@$args) > 1 ? Rb::to_s($args->[1]) : $args->[0]{name}
            $exc = Rb::v_exception($args->[0], $msg)
        } else {
            $exc = Rb::v_exception($ctx->{classes}{RuntimeError}, Rb::to_s($args->[0]))
        }
        die $exc
    }
    if ($name eq "pp") {
        print Rb::inspect($_), "\n" for @$args
        return len(@$args) == 1 ? $args->[0] : Rb::v_array($args)
    }
    if ($name eq "Integer") { return Rb::v_int(int(Rb::nv($args->[0]))) }
    if ($name eq "Float")   { return Rb::v_float(Rb::nv($args->[0]) + 0.0) }
    if ($name eq "String")  { return Rb::v_str(Rb::to_s($args->[0])) }
    if ($name eq "Array") {
        return Rb::v_array([])    if len(@$args) == 0 || Rb::is_nil($args->[0])
        return $args->[0]         if Rb::is_array($args->[0])
        return Rb::v_array([$args->[0]])
    }
    if ($name eq "attr_accessor" || $name eq "attr_reader" || $name eq "attr_writer") {
        val $klass = $ctx->{cur_klass}
        die $name . " outside class" unless defined $klass
        val $reader = ($name eq "attr_writer") ? 0 : 1
        val $writer = ($name eq "attr_reader") ? 0 : 1
        for val $sym (@$args) {
            val $attr = Rb::is_sym($sym) ? $sym->{val} : Rb::to_s($sym)
            if ($reader) {
                val $body = [+{ kind => "IVar", name => $attr, line => 0 }]
                $klass->{methods}{$attr} = Rb::v_proc([], $body, [+{}])
            }
            if ($writer) {
                val $body = [+{
                    kind   => "Assign",
                    target => +{ kind => "IVar", name => $attr, line => 0 },
                    value  => +{ kind => "Ident", name => "v", line => 0 },
                    line   => 0,
                }]
                $klass->{methods}{$attr . "="} = Rb::v_proc(["v"], $body, [+{}])
            }
        }
        return Rb::v_nil()
    }
    if ($name eq "include") {
        val $klass = $ctx->{cur_klass}
        die "include outside class/module" unless defined $klass
        for val $mod (@$args) {
            push @{$klass->{includes}}, $mod
        }
        return Rb::v_nil()
    }
    if ($name eq "extend") {
        val $klass = $ctx->{cur_klass}
        die "extend outside class/module" unless defined $klass
        for val $mod (@$args) {
            for val $mname (keys %{$mod->{methods}}) {
                $klass->{cmethods}{$mname} = $mod->{methods}{$mname}
            }
        }
        return Rb::v_nil()
    }
    if ($name eq "lambda" || $name eq "proc") {
        die "lambda/proc requires a block" unless defined $block
        return $block
    }
    # Fallback — `name` as a local variable holding a proc, or method on self.
    if (Rb::env_has($ctx->{env}, $name)) {
        val $v = Rb::env_lookup($ctx->{env}, $name)
        if (Rb::is_proc($v)) {
            # Top-level def: install caller's block so `yield` inside the body
            # finds it. Use call_method so `return` flow unwinds correctly.
            return Rb::call_method($v, $ctx->{self}, $args, $block, $ctx, $name)
        }
        return $v
    }
    return Rb::dispatch($ctx->{self}, $name, $args, $block, $ctx, 1)
}

fn Rb::dispatch($recv, $name, $args, $block, $ctx, $is_implicit) {
    # Universal methods.
    if ($name eq "class") {
        return $ctx->{classes}{Integer} if Rb::is_int($recv)
        return $ctx->{classes}{Float}   if Rb::is_float($recv)
        return $ctx->{classes}{String}  if Rb::is_str($recv)
        return $ctx->{classes}{Symbol}  if Rb::is_sym($recv)
        return $ctx->{classes}{Array}   if Rb::is_array($recv)
        return $ctx->{classes}{Hash}    if Rb::is_hash($recv)
        return $ctx->{classes}{Range}   if Rb::is_range($recv)
        return $ctx->{classes}{NilClass} if Rb::is_nil($recv)
        return $recv->{klass}           if Rb::is_instance($recv)
        return Rb::v_str("Object")
    }
    if ($name eq "inspect") { return Rb::v_str(Rb::inspect($recv)) }
    if ($name eq "to_s")    { return Rb::v_str(Rb::to_s($recv)) }
    if ($name eq "nil?")    { return Rb::v_bool(Rb::is_nil($recv) ? 1 : 0) }
    if ($name eq "==")      { return Rb::v_bool(Rb::v_eq($recv, $args->[0]) ? 1 : 0) }
    if ($name eq "!=")      { return Rb::v_bool(Rb::v_eq($recv, $args->[0]) ? 0 : 1) }

    # Exception accessors.
    if (Rb::is_exception($recv)) {
        return Rb::v_str($recv->{message} // "") if $name eq "message";
        return $recv->{klass}                    if $name eq "class";
        return Rb::v_str($recv->{message} // "") if $name eq "to_s";
    }

    # Class method `Klass.new` builds an instance and runs `initialize`.
    if (Rb::is_class($recv)) {
        if ($name eq "new") {
            val $inst = Rb::v_instance($recv)
            val $init = Rb::class_method($recv, "initialize")
            if (defined $init) {
                Rb::call_method($init, $inst, $args, $block, $ctx, "initialize")
            }
            return $inst
        }
        if ($name eq "name" || $name eq "to_s" || $name eq "inspect") {
            return Rb::v_str($recv->{name})
        }
        if ($name eq "ancestors") {
            var @a; var $c = $recv
            while (defined $c) {
                push @a, $c
                push @a, $_ for @{$c->{includes} // []}
                $c = $c->{parent}
            }
            return Rb::v_array(\@a)
        }
        # `def self.foo` is a class-side method; lookup via cmethods.
        val $cm = $recv->{cmethods}{$name}
        if (defined $cm) {
            return Rb::call_method($cm, $recv, $args, $block, $ctx, $name)
        }
    }
    if (Rb::is_module($recv)) {
        if ($name eq "name" || $name eq "to_s" || $name eq "inspect") {
            return Rb::v_str($recv->{name})
        }
        val $m = $recv->{methods}{$name}
        if (defined $m) {
            return Rb::call_method($m, $recv, $args, $block, $ctx, $name)
        }
    }

    # Type-specific built-ins.
    val $r = Rb::call_builtin_method($recv, $name, $args, $block, $ctx)
    return $r if defined $r

    # User-defined method on instance: walk the class chain.
    if (Rb::is_instance($recv)) {
        val $m = Rb::class_method($recv->{klass}, $name)
        if (defined $m) {
            return Rb::call_method($m, $recv, $args, $block, $ctx, $name)
        }
    }

    # Universal `is_a?` / `kind_of?` / `instance_of?` against a class arg.
    if (($name eq "is_a?" || $name eq "kind_of?") && len(@$args) > 0 && Rb::is_class($args->[0])) {
        return Rb::v_bool(Rb::value_is_a($recv, $args->[0], $ctx) ? 1 : 0)
    }
    if ($name eq "instance_of?" && len(@$args) > 0 && Rb::is_class($args->[0])) {
        val $cls = Rb::value_class($recv, $ctx)
        return Rb::v_bool(defined($cls) && $cls->{name} eq $args->[0]{name} ? 1 : 0)
    }
    if ($name eq "respond_to?" && len(@$args) > 0) {
        var $sym = Rb::is_sym($args->[0]) ? $args->[0]{val} : Rb::to_s($args->[0])
        # Check built-in dispatch first.
        val $tries = Rb::call_builtin_method($recv, $sym, [], undef, $ctx)
        return Rb::v_bool(1) if defined $tries
        if (Rb::is_instance($recv)) {
            return Rb::v_bool(defined(Rb::class_method($recv->{klass}, $sym)) ? 1 : 0)
        }
        return Rb::v_bool(0)
    }
    if ($name eq "tap") {
        Rb::call_block($block, [$recv], $ctx) if defined $block
        return $recv
    }
    if ($name eq "then" || $name eq "yield_self") {
        return defined($block) ? Rb::call_block($block, [$recv], $ctx) : $recv
    }
    if ($name eq "freeze")  { return $recv }
    if ($name eq "frozen?") { return Rb::v_bool(1) }   # simplified
    if ($name eq "object_id" || $name eq "__id__") { return Rb::v_int(0) }
    if ($name eq "send" || $name eq "__send__" || $name eq "public_send") {
        val $msg = shift @$args
        val $mname = Rb::is_sym($msg) ? $msg->{val} : Rb::to_s($msg)
        return Rb::dispatch($recv, $mname, $args, $block, $ctx, 0)
    }

    return Rb::v_nil() if $is_implicit
    die "undefined method `" . $name . "' for " . Rb::inspect($recv)
}

# Lookup a value's class without going through Universal dispatch.
fn Rb::value_class($v, $ctx) {
    return $ctx->{classes}{Integer}    if Rb::is_int($v)
    return $ctx->{classes}{Float}      if Rb::is_float($v)
    return $ctx->{classes}{String}     if Rb::is_str($v)
    return $ctx->{classes}{Symbol}     if Rb::is_sym($v)
    return $ctx->{classes}{Array}      if Rb::is_array($v)
    return $ctx->{classes}{Hash}       if Rb::is_hash($v)
    return $ctx->{classes}{Range}      if Rb::is_range($v)
    return $ctx->{classes}{Proc}       if Rb::is_proc($v)
    return $ctx->{classes}{NilClass}   if Rb::is_nil($v)
    return Rb::is_truthy($v) ? $ctx->{classes}{TrueClass} : $ctx->{classes}{FalseClass} if Rb::is_bool($v)
    return $v->{klass}                 if Rb::is_instance($v)
    return $v->{klass}                 if Rb::is_exception($v)
    return $v                          if Rb::is_class($v)
    undef
}

# Walk class chain (including mixins) checking for a target class.
fn Rb::value_is_a($v, $target, $ctx) {
    var $c = Rb::value_class($v, $ctx)
    while (defined $c) {
        return 1 if $c->{name} eq $target->{name}
        for val $mod (@{$c->{includes} // []}) {
            return 1 if $mod->{name} eq $target->{name}
        }
        $c = $c->{parent}
    }
    0
}

fn Rb::class_method($klass, $name) {
    var $c = $klass
    while (defined $c) {
        return $c->{methods}{$name} if exists $c->{methods}{$name}
        # Mixed-in modules: most-recently-included takes precedence (matches MRI's MRO).
        for val $mod (rev @{$c->{includes} // []}) {
            return $mod->{methods}{$name} if exists $mod->{methods}{$name}
        }
        $c = $c->{parent}
    }
    undef
}

# Bind a proc as a method on `recv`. Sets `self` and `block`, runs body,
# unwinds on `Return`. The proc's body runs in its captured env + a fresh
# frame — local vars don't leak out.
fn Rb::call_method($proc, $recv, $args, $block, $ctx, $mname) {
    val $saved_env    = $ctx->{env}
    val $saved_self   = $ctx->{self}
    val $saved_block  = $ctx->{block}
    val $saved_params = $ctx->{cur_method_params}
    val @new_frames = (@{$proc->{env}}, +{})
    $ctx->{env}   = \@new_frames
    $ctx->{self}  = $recv
    $ctx->{block} = $block
    val $params = $proc->{params}
    $ctx->{cur_method_params} = $params
    Rb::env_define($ctx->{env}, "__method__", Rb::v_sym($mname)) if defined $mname
    for (var $i = 0; $i < len(@$params); $i++) {
        Rb::env_define($ctx->{env}, $params->[$i], $args->[$i] // Rb::v_nil())
    }
    val $r = eval { Rb::eval_body($proc->{body}, $ctx) }
    val $err = $@
    $ctx->{env}              = $saved_env
    $ctx->{self}             = $saved_self
    $ctx->{block}            = $saved_block
    $ctx->{cur_method_params} = $saved_params
    if ($err) {
        if (ref($err) eq "HASH" && $err->{flow} eq "return") { return $err->{value} }
        die $err
    }
    $r
}

# ── BUILT-IN METHODS ───────────────────────────────────────────────────────

fn Rb::call_builtin_method($recv, $name, $args, $block, $ctx) {
    return Rb::array_m($recv, $name, $args, $block, $ctx)  if Rb::is_array($recv)
    return Rb::str_m($recv, $name, $args, $block, $ctx)    if Rb::is_str($recv)
    return Rb::hash_m($recv, $name, $args, $block, $ctx)   if Rb::is_hash($recv)
    return Rb::int_m($recv, $name, $args, $block, $ctx)    if Rb::is_int($recv)
    return Rb::float_m($recv, $name, $args, $block, $ctx)  if Rb::is_float($recv)
    return Rb::range_m($recv, $name, $args, $block, $ctx)  if Rb::is_range($recv)
    return Rb::proc_m($recv, $name, $args, $block, $ctx)   if Rb::is_proc($recv)
    return Rb::sym_m($recv, $name, $args, $block, $ctx)    if Rb::is_sym($recv)
    return Rb::nil_m($recv, $name, $args, $block, $ctx)    if Rb::is_nil($recv)
    return Rb::bool_m($recv, $name, $args, $block, $ctx)   if Rb::is_bool($recv)
    undef
}

fn Rb::array_m($a, $name, $args, $block, $ctx) {
    var $items = $a->{items}
    if ($name eq "[]") {
        val $idx = $args->[0]
        if (Rb::is_int($idx)) {
            # [start, length] form: arr[1, 2]
            if (len(@$args) >= 2 && Rb::is_int($args->[1])) {
                var $s = $idx->{val}
                $s += len(@$items) if $s < 0
                val $len = $args->[1]{val}
                return Rb::v_nil() if $s < 0 || $s > len(@$items) || $len < 0
                var $e = $s + $len - 1
                $e = len(@$items) - 1 if $e >= len(@$items)
                return Rb::v_array([]) if $e < $s
                return Rb::v_array([@$items[$s..$e]])
            }
            var $i = $idx->{val}
            $i += len(@$items) if $i < 0
            return ($i < 0 || $i >= len(@$items)) ? Rb::v_nil() : $items->[$i]
        }
        if (Rb::is_range($idx)) {
            var $lo = Rb::nv($idx->{lo})
            var $hi = Rb::nv($idx->{hi})
            $lo += len(@$items) if $lo < 0
            $hi += len(@$items) if $hi < 0
            $hi-- if $idx->{exclusive}
            return Rb::v_nil() if $lo < 0 || $lo > len(@$items)
            $hi = len(@$items) - 1 if $hi >= len(@$items)
            return Rb::v_array([]) if $hi < $lo
            return Rb::v_array([@$items[$lo..$hi]])
        }
        return Rb::v_nil()
    }
    if ($name eq "[]=") {
        val $i = $args->[0]{val}
        $items->[$i] = $args->[1]
        return $args->[1]
    }
    if ($name eq "length" || $name eq "size") {
        return Rb::v_int(len(@$items))
    }
    if ($name eq "count" && !defined($block) && !len(@$args)) {
        return Rb::v_int(len(@$items))
    }
    if ($name eq "empty?") { return Rb::v_bool(len(@$items) == 0 ? 1 : 0) }
    if ($name eq "first") {
        if (len(@$args) && Rb::is_int($args->[0])) {
            var $n = $args->[0]{val}
            $n = len(@$items) if $n > len(@$items)
            return Rb::v_array([]) if $n <= 0
            return Rb::v_array([@$items[0..$n - 1]])
        }
        return $items->[0]  // Rb::v_nil()
    }
    if ($name eq "last") {
        if (len(@$args) && Rb::is_int($args->[0])) {
            var $n = $args->[0]{val}
            $n = len(@$items) if $n > len(@$items)
            return Rb::v_array([]) if $n <= 0
            val $start = len(@$items) - $n
            return Rb::v_array([@$items[$start..len(@$items) - 1]])
        }
        return $items->[-1] // Rb::v_nil()
    }
    if ($name eq "push" || $name eq "append") { push @$items, @$args; return $a }
    if ($name eq "pop")    { return len(@$items) ? pop(@$items)   : Rb::v_nil() }
    if ($name eq "shift")  { return len(@$items) ? shift(@$items) : Rb::v_nil() }
    if ($name eq "unshift") { unshift @$items, @$args; return $a }
    if ($name eq "reverse") { return Rb::v_array([rev @$items]) }
    if ($name eq "include?") {
        for val $e (@$items) { return Rb::v_bool(1) if Rb::v_eq($e, $args->[0]) }
        return Rb::v_bool(0)
    }
    if ($name eq "join") {
        val $sep = len(@$args) ? $args->[0]{val} : ""
        return Rb::v_str(join($sep, map {Rb::to_s} @$items))
    }
    if ($name eq "sort") {
        if (defined $block) {
            val @s = sort {
                val $r = Rb::call_block($block, [_, _1], $ctx)
                Rb::is_int($r) ? $r->{val} : 0
            } @$items
            return Rb::v_array(\@s)
        }
        val @s = sort { Rb::v_cmp(_, _1) } @$items
        return Rb::v_array(\@s)
    }
    if ($name eq "uniq") {
        var @seen
        var @out
        for val $e (@$items) {
            var $dup = 0
            for val $s (@seen) { if (Rb::v_eq($e, $s)) { $dup = 1; last } }
            unless ($dup) { push @seen, $e; push @out, $e }
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "each") {
        for val $e (@$items) {
            val $r = eval { Rb::call_block($block, [$e], $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") { return $@->{value} // Rb::v_nil() }
                die $@ if ref($@) ne "HASH"
            }
        }
        return $a
    }
    if ($name eq "each_with_index") {
        for (var $i = 0; $i < len(@$items); $i++) {
            Rb::call_block($block, [$items->[$i], Rb::v_int($i)], $ctx)
        }
        return $a
    }
    if ($name eq "map" || $name eq "collect") {
        var @out
        for val $e (@$items) { push @out, Rb::call_block($block, [$e], $ctx) }
        return Rb::v_array(\@out)
    }
    if ($name eq "select" || $name eq "filter") {
        var @out
        for val $e (@$items) {
            push @out, $e if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "reject") {
        var @out
        for val $e (@$items) {
            push @out, $e unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "find" || $name eq "detect") {
        for val $e (@$items) {
            return $e if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_nil()
    }
    if ($name eq "any?") {
        for val $e (@$items) {
            if (defined $block) {
                return Rb::v_bool(1) if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            } else {
                return Rb::v_bool(1) if Rb::is_truthy($e)
            }
        }
        return Rb::v_bool(0)
    }
    if ($name eq "all?") {
        for val $e (@$items) {
            if (defined $block) {
                return Rb::v_bool(0) unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            } else {
                return Rb::v_bool(0) unless Rb::is_truthy($e)
            }
        }
        return Rb::v_bool(1)
    }
    if ($name eq "reduce" || $name eq "inject") {
        var @rest = @$items
        var $acc
        if (len(@$args)) { $acc = $args->[0] }
        else                { return Rb::v_nil() unless len(@rest); $acc = shift @rest }
        for val $e (@rest) {
            $acc = Rb::call_block($block, [$acc, $e], $ctx)
        }
        return $acc
    }
    if ($name eq "min") {
        return Rb::v_nil() unless len(@$items)
        var $m = $items->[0]
        if (defined $block) {
            for val $e (@$items) {
                val $r = Rb::call_block($block, [$e, $m], $ctx)
                val $cmp = Rb::is_int($r) ? $r->{val} : 0
                $m = $e if $cmp < 0
            }
            return $m
        }
        for val $e (@$items) { $m = $e if Rb::v_cmp($e, $m) < 0 }
        return $m
    }
    if ($name eq "max") {
        return Rb::v_nil() unless len(@$items)
        var $m = $items->[0]
        if (defined $block) {
            for val $e (@$items) {
                val $r = Rb::call_block($block, [$e, $m], $ctx)
                val $cmp = Rb::is_int($r) ? $r->{val} : 0
                $m = $e if $cmp > 0
            }
            return $m
        }
        for val $e (@$items) { $m = $e if Rb::v_cmp($e, $m) > 0 }
        return $m
    }
    if ($name eq "sum") {
        val $init = len(@$args) ? Rb::nv($args->[0]) : 0
        var $s = $init
        var $is_float = (defined($args->[0]) && Rb::is_float($args->[0])) ? 1 : 0
        for val $e (@$items) {
            val $v = defined($block) ? Rb::call_block($block, [$e], $ctx) : $e
            $is_float = 1 if Rb::is_float($v)
            $s += Rb::nv($v)
        }
        return $is_float ? Rb::v_float($s) : Rb::v_int($s)
    }
    if ($name eq "filter_map") {
        var @out
        for val $e (@$items) {
            val $r = Rb::call_block($block, [$e], $ctx)
            push @out, $r if Rb::is_truthy($r)
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "find_index") {
        if (defined $block) {
            for (var $i = 0; $i < len(@$items); $i++) {
                return Rb::v_int($i) if Rb::is_truthy(Rb::call_block($block, [$items->[$i]], $ctx))
            }
            return Rb::v_nil()
        }
        for (var $i = 0; $i < len(@$items); $i++) {
            return Rb::v_int($i) if Rb::v_eq($items->[$i], $args->[0])
        }
        return Rb::v_nil()
    }
    if ($name eq "to_a")    { return $a }
    if ($name eq "compact") { return Rb::v_array([grep { !Rb::is_nil(_) } @$items]) }
    if ($name eq "none?") {
        for val $e (@$items) {
            if (defined $block) {
                return Rb::v_bool(0) if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            } else {
                return Rb::v_bool(0) if Rb::is_truthy($e)
            }
        }
        return Rb::v_bool(1)
    }
    # `count` with a predicate or value argument (no-arg case handled at top).
    if ($name eq "count") {
        if (defined $block) {
            var $n = 0
            for val $e (@$items) {
                $n++ if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            }
            return Rb::v_int($n)
        }
        var $n = 0
        for val $e (@$items) {
            $n++ if Rb::v_eq($e, $args->[0])
        }
        return Rb::v_int($n)
    }
    if ($name eq "index") {
        if (defined $block) {
            for (var $i = 0; $i < len(@$items); $i++) {
                return Rb::v_int($i) if Rb::is_truthy(Rb::call_block($block, [$items->[$i]], $ctx))
            }
            return Rb::v_nil()
        }
        for (var $i = 0; $i < len(@$items); $i++) {
            return Rb::v_int($i) if Rb::v_eq($items->[$i], $args->[0])
        }
        return Rb::v_nil()
    }
    if ($name eq "take") {
        var $n = $args->[0]{val}
        $n = len(@$items) if $n > len(@$items)
        return Rb::v_array([@$items[0..$n - 1]]) if $n > 0
        return Rb::v_array([])
    }
    if ($name eq "drop") {
        val $n = $args->[0]{val}
        return Rb::v_array([]) if $n >= len(@$items)
        return Rb::v_array([@$items[$n..len(@$items) - 1]])
    }
    if ($name eq "take_while") {
        var @out
        for val $e (@$items) {
            last unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            push @out, $e
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "drop_while") {
        var @out
        var $dropping = 1
        for val $e (@$items) {
            $dropping = 0 unless $dropping && Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            push @out, $e unless $dropping
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "partition") {
        var @yes; var @no
        for val $e (@$items) {
            if (Rb::is_truthy(Rb::call_block($block, [$e], $ctx))) {
                push @yes, $e
            } else {
                push @no, $e
            }
        }
        return Rb::v_array([Rb::v_array(\@yes), Rb::v_array(\@no)])
    }
    if ($name eq "group_by") {
        var @keys; var @groups
        for val $e (@$items) {
            val $k = Rb::call_block($block, [$e], $ctx)
            var $found = 0
            for (var $i = 0; $i < len(@keys); $i++) {
                if (Rb::v_eq($keys[$i], $k)) {
                    push @{$groups[$i]}, $e
                    $found = 1
                    last
                }
            }
            unless ($found) {
                push @keys, $k
                push @groups, [$e]
            }
        }
        var @pairs
        for (var $i = 0; $i < len(@keys); $i++) {
            push @pairs, [$keys[$i], Rb::v_array($groups[$i])]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "tally") {
        var @keys; var @counts
        for val $e (@$items) {
            var $found = 0
            for (var $i = 0; $i < len(@keys); $i++) {
                if (Rb::v_eq($keys[$i], $e)) {
                    $counts[$i]++
                    $found = 1
                    last
                }
            }
            unless ($found) {
                push @keys, $e
                push @counts, 1
            }
        }
        var @pairs
        for (var $i = 0; $i < len(@keys); $i++) {
            push @pairs, [$keys[$i], Rb::v_int($counts[$i])]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "to_h") {
        var @pairs
        for val $e (@$items) {
            die "to_h requires pair" unless Rb::is_array($e) && len(@{$e->{items}}) == 2
            push @pairs, [$e->{items}[0], $e->{items}[1]]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "zip") {
        var @result
        for (var $i = 0; $i < len(@$items); $i++) {
            var @row = ($items->[$i])
            for val $other (@$args) {
                push @row, ($other->{items}[$i] // Rb::v_nil())
            }
            push @result, Rb::v_array(\@row)
        }
        return Rb::v_array(\@result)
    }
    if ($name eq "min_by") {
        return Rb::v_nil() unless len(@$items)
        var $best = $items->[0]
        var $bk = Rb::call_block($block, [$best], $ctx)
        for (var $i = 1; $i < len(@$items); $i++) {
            val $e = $items->[$i]
            val $k = Rb::call_block($block, [$e], $ctx)
            if (Rb::v_cmp($k, $bk) < 0) { $best = $e; $bk = $k }
        }
        return $best
    }
    if ($name eq "max_by") {
        return Rb::v_nil() unless len(@$items)
        var $best = $items->[0]
        var $bk = Rb::call_block($block, [$best], $ctx)
        for (var $i = 1; $i < len(@$items); $i++) {
            val $e = $items->[$i]
            val $k = Rb::call_block($block, [$e], $ctx)
            if (Rb::v_cmp($k, $bk) > 0) { $best = $e; $bk = $k }
        }
        return $best
    }
    if ($name eq "sort_by") {
        val @decorated = map { [Rb::call_block($block, [$_], $ctx), $_] } @$items
        val @sorted = sort { Rb::v_cmp(_->[0], _1->[0]) } @decorated
        return Rb::v_array([map { $_->[1] } @sorted])
    }
    if ($name eq "flat_map" || $name eq "collect_concat") {
        var @out
        for val $e (@$items) {
            val $r = Rb::call_block($block, [$e], $ctx)
            if (Rb::is_array($r)) { push @out, @{$r->{items}} } else { push @out, $r }
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "flatten") {
        var $depth = len(@$args) ? $args->[0]{val} : -1
        return Rb::v_array(Rb::array_flatten($items, $depth))
    }
    if ($name eq "concat") {
        for val $arg (@$args) {
            push @$items, @{$arg->{items}} if Rb::is_array($arg)
        }
        return $a
    }
    if ($name eq "dup" || $name eq "clone") {
        return Rb::v_array([@$items])
    }
    if ($name eq "rotate") {
        var $by = len(@$args) ? $args->[0]{val} : 1
        val $n = len(@$items)
        return $a if $n == 0
        $by = (($by % $n) + $n) % $n
        return Rb::v_array([@$items[$by..$n - 1], @$items[0..$by - 1]])
    }
    if ($name eq "sample") {
        return Rb::v_nil() unless len(@$items)
        return $items->[int(rand(len(@$items)))]
    }
    if ($name eq "shuffle") {
        var @out = @$items
        for (var $i = len(@out) - 1; $i > 0; $i--) {
            var $j = int(rand($i + 1))
            ($out[$i], $out[$j]) = ($out[$j], $out[$i])
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "minmax") {
        return Rb::v_array([Rb::v_nil(), Rb::v_nil()]) unless len(@$items)
        var $min = $items->[0]; var $max = $items->[0]
        for val $e (@$items) {
            $min = $e if Rb::v_cmp($e, $min) < 0
            $max = $e if Rb::v_cmp($e, $max) > 0
        }
        return Rb::v_array([$min, $max])
    }
    if ($name eq "each_with_object") {
        val $memo = $args->[0]
        for val $e (@$items) {
            Rb::call_block($block, [$e, $memo], $ctx)
        }
        return $memo
    }
    if ($name eq "chunk_while") {
        var @groups
        return Rb::v_array(\@groups) unless len(@$items)
        var @cur = ($items->[0])
        for (var $i = 1; $i < len(@$items); $i++) {
            if (Rb::is_truthy(Rb::call_block($block, [$items->[$i - 1], $items->[$i]], $ctx))) {
                push @cur, $items->[$i]
            } else {
                push @groups, Rb::v_array([@cur])
                @cur = ($items->[$i])
            }
        }
        push @groups, Rb::v_array([@cur])
        return Rb::v_array(\@groups)
    }
    if ($name eq "each_slice") {
        val $n = $args->[0]{val}
        var @out
        for (var $i = 0; $i < len(@$items); $i += $n) {
            var $end = $i + $n - 1
            $end = len(@$items) - 1 if $end >= len(@$items)
            push @out, Rb::v_array([@$items[$i..$end]])
        }
        if (defined $block) {
            for val $g (@out) { Rb::call_block($block, [$g], $ctx) }
            return $a
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "each_cons") {
        val $n = $args->[0]{val}
        var @out
        for (var $i = 0; $i + $n <= len(@$items); $i++) {
            push @out, Rb::v_array([@$items[$i..$i + $n - 1]])
        }
        if (defined $block) {
            for val $g (@out) { Rb::call_block($block, [$g], $ctx) }
            return $a
        }
        return Rb::v_array(\@out)
    }
    undef
}

# Recursive helper for `flatten` — `$depth = -1` means infinite.
fn Rb::array_flatten($items, $depth) {
    var @out
    for val $e (@$items) {
        if (Rb::is_array($e) && $depth != 0) {
            push @out, @{Rb::array_flatten($e->{items}, $depth - 1)}
        } else {
            push @out, $e
        }
    }
    \@out
}

fn Rb::str_m($s, $name, $args, $block, $ctx) {
    val $v = $s->{val}
    if ($name eq "length" || $name eq "size") { return Rb::v_int(length($v)) }
    if ($name eq "empty?")    { return Rb::v_bool(length($v) == 0 ? 1 : 0) }
    if ($name eq "upcase")    { return Rb::v_str(uc($v)) }
    if ($name eq "downcase")  { return Rb::v_str(lc($v)) }
    if ($name eq "capitalize"){ return Rb::v_str(uc(substr($v, 0, 1)) . lc(substr($v, 1))) }
    if ($name eq "reverse")   { return Rb::v_str(rev $v) }
    if ($name eq "chars")     { return Rb::v_array([map {Rb::v_str} split //, $v]) }
    if ($name eq "split") {
        # Bare split / split(" ") — split on runs of whitespace, drop leading empties.
        if (!len(@$args) || (Rb::is_str($args->[0]) && $args->[0]{val} eq " ")) {
            var $r = $v
            $r =~ s/^\s+//
            return Rb::v_array([map {Rb::v_str} split /\s+/, $r])
        }
        val $sep = $args->[0]{val}
        return Rb::v_array([map {Rb::v_str} split /\Q$sep\E/, $v])
    }
    if ($name eq "index") {
        val $needle = $args->[0]{val}
        val $i = index($v, $needle)
        return $i < 0 ? Rb::v_nil() : Rb::v_int($i)
    }
    if ($name eq "include?") { return Rb::v_bool(index($v, $args->[0]{val}) >= 0 ? 1 : 0) }
    if ($name eq "start_with?") { return Rb::v_bool(substr($v, 0, length($args->[0]{val})) eq $args->[0]{val} ? 1 : 0) }
    if ($name eq "end_with?")   { val $L = length($args->[0]{val}); return Rb::v_bool($L <= length($v) && substr($v, -$L) eq $args->[0]{val} ? 1 : 0) }
    if ($name eq "to_i")  { return Rb::v_int($v + 0) }
    if ($name eq "to_f")  { return Rb::v_float($v + 0.0) }
    if ($name eq "to_sym"){ return Rb::v_sym($v) }
    if ($name eq "[]") {
        val $idx = $args->[0]
        if (Rb::is_int($idx)) {
            if (len(@$args) >= 2 && Rb::is_int($args->[1])) {
                var $s = $idx->{val}
                $s += length($v) if $s < 0
                val $len = $args->[1]{val}
                return Rb::v_nil() if $s < 0 || $s > length($v) || $len < 0
                return Rb::v_str(substr($v, $s, $len))
            }
            var $i = $idx->{val}
            $i += length($v) if $i < 0
            return Rb::v_nil() if $i < 0 || $i >= length($v)
            return Rb::v_str(substr($v, $i, 1))
        }
        if (Rb::is_range($idx)) {
            var $lo = Rb::nv($idx->{lo})
            var $hi = Rb::nv($idx->{hi})
            $lo += length($v) if $lo < 0
            $hi += length($v) if $hi < 0
            $hi-- if $idx->{exclusive}
            return Rb::v_nil() if $lo < 0 || $lo > length($v)
            $hi = length($v) - 1 if $hi >= length($v)
            return Rb::v_str("") if $hi < $lo
            return Rb::v_str(substr($v, $lo, $hi - $lo + 1))
        }
        if (Rb::is_str($idx)) {
            return index($v, $idx->{val}) >= 0 ? Rb::v_str($idx->{val}) : Rb::v_nil()
        }
        return Rb::v_nil()
    }
    if ($name eq "+")     { return Rb::v_str($v . $args->[0]{val}) }
    if ($name eq "*")     { return Rb::v_str($v x $args->[0]{val}) }
    if ($name eq "swapcase") {
        var $r = ""
        for val $c (split //, $v) {
            if ($c =~ /[A-Z]/) { $r .= lc($c) }
            elsif ($c =~ /[a-z]/) { $r .= uc($c) }
            else { $r .= $c }
        }
        return Rb::v_str($r)
    }
    if ($name eq "bytes") {
        var @b
        for val $c (split //, $v) { push @b, Rb::v_int(ord($c)) }
        return Rb::v_array(\@b)
    }
    if ($name eq "lines") {
        return Rb::v_array([map {Rb::v_str} split /(?<=\n)/, $v])
    }
    if ($name eq "strip" || $name eq "trim") {
        var $r = $v
        $r =~ s/^\s+//
        $r =~ s/\s+$//
        return Rb::v_str($r)
    }
    if ($name eq "lstrip") {
        var $r = $v; $r =~ s/^\s+//
        return Rb::v_str($r)
    }
    if ($name eq "rstrip") {
        var $r = $v; $r =~ s/\s+$//
        return Rb::v_str($r)
    }
    if ($name eq "chomp") {
        var $r = $v; $r =~ s/\r?\n$//
        return Rb::v_str($r)
    }
    if ($name eq "chop") {
        return Rb::v_str(length($v) > 0 ? substr($v, 0, -1) : "")
    }
    if ($name eq "sub") {
        val $pat = $args->[0]{val}
        val $rep = $args->[1]{val}
        var $r = $v
        $r =~ s/\Q$pat\E/$rep/
        return Rb::v_str($r)
    }
    if ($name eq "gsub") {
        val $pat = $args->[0]{val}
        val $rep = $args->[1]{val}
        var $r = $v
        $r =~ s/\Q$pat\E/$rep/g
        return Rb::v_str($r)
    }
    if ($name eq "replace") {
        $s->{val} = $args->[0]{val}
        return $s
    }
    if ($name eq "concat" || $name eq "<<") {
        $s->{val} = $v . Rb::to_s($args->[0])
        return $s
    }
    if ($name eq "tr") {
        val $from = $args->[0]{val}
        val $to = $args->[1]{val}
        var $r = ""
        for val $c (split //, $v) {
            val $idx = index($from, $c)
            if ($idx >= 0 && $idx < length($to)) {
                $r .= substr($to, $idx, 1)
            } elsif ($idx >= 0) {
                # Pad with last char of $to (Ruby semantics).
                $r .= length($to) > 0 ? substr($to, -1, 1) : ""
            } else {
                $r .= $c
            }
        }
        return Rb::v_str($r)
    }
    if ($name eq "delete") {
        val $del = $args->[0]{val}
        var $r = ""
        for val $c (split //, $v) {
            $r .= $c unless index($del, $c) >= 0
        }
        return Rb::v_str($r)
    }
    if ($name eq "squeeze") {
        var $r = ""; var $prev = ""
        for val $c (split //, $v) {
            $r .= $c unless $c eq $prev
            $prev = $c
        }
        return Rb::v_str($r)
    }
    if ($name eq "center") {
        val $w = $args->[0]{val}
        val $pad = len(@$args) > 1 ? $args->[1]{val} : " "
        val $deficit = $w - length($v)
        return $s if $deficit <= 0
        val $left = int($deficit / 2)
        val $right = $deficit - $left
        return Rb::v_str(($pad x $left) . $v . ($pad x $right))
    }
    if ($name eq "ljust") {
        val $w = $args->[0]{val}
        val $pad = len(@$args) > 1 ? $args->[1]{val} : " "
        return Rb::v_str(length($v) >= $w ? $v : $v . ($pad x ($w - length($v))))
    }
    if ($name eq "rjust") {
        val $w = $args->[0]{val}
        val $pad = len(@$args) > 1 ? $args->[1]{val} : " "
        return Rb::v_str(length($v) >= $w ? $v : ($pad x ($w - length($v))) . $v)
    }
    if ($name eq "match?") {
        val $pat = $args->[0]{val}
        return Rb::v_bool($v =~ /$pat/ ? 1 : 0)
    }
    if ($name eq "match") {
        val $pat = $args->[0]{val}
        return $v =~ /$pat/ ? Rb::v_str($&) : Rb::v_nil()
    }
    if ($name eq "scan") {
        val $pat = $args->[0]{val}
        val @hits = ($v =~ /$pat/g)
        return Rb::v_array([map {Rb::v_str} @hits])
    }
    if ($name eq "count") {
        var $n = 0
        val $needle = $args->[0]{val}
        $n++ for $v =~ /\Q$needle\E/g
        return Rb::v_int($n)
    }
    if ($name eq "each_char") {
        for val $c (split //, $v) {
            Rb::call_block($block, [Rb::v_str($c)], $ctx)
        }
        return $s
    }
    if ($name eq "each_line") {
        for val $line (split /(?<=\n)/, $v) {
            Rb::call_block($block, [Rb::v_str($line)], $ctx)
        }
        return $s
    }
    if ($name eq "intern")  { return Rb::v_sym($v) }
    if ($name eq "to_str")  { return $s }
    if ($name eq "freeze" || $name eq "dup" || $name eq "clone") {
        return Rb::v_str($v)
    }
    if ($name eq "succ" || $name eq "next") {
        # Just bump last char (simplified).
        return Rb::v_str("") if length($v) == 0
        val $last = substr($v, -1, 1)
        val $rest = substr($v, 0, length($v) - 1)
        return Rb::v_str($rest . chr(ord($last) + 1))
    }
    if ($name eq "ord")     { return Rb::v_int(ord(substr($v, 0, 1))) }
    if ($name eq "hex")     { return Rb::v_int(hex($v)) }
    if ($name eq "oct")     { return Rb::v_int(oct($v)) }
    undef
}

fn Rb::hash_m($h, $name, $args, $block, $ctx) {
    val $pairs = $h->{pairs}
    if ($name eq "[]") {
        for val $p (@$pairs) {
            return $p->[1] if Rb::v_eq($p->[0], $args->[0])
        }
        return Rb::v_nil()
    }
    if ($name eq "[]=") {
        for var $p (@$pairs) {
            if (Rb::v_eq($p->[0], $args->[0])) { $p->[1] = $args->[1]; return $args->[1] }
        }
        push @$pairs, [$args->[0], $args->[1]]
        return $args->[1]
    }
    if ($name eq "length" || $name eq "size" || $name eq "count") {
        return Rb::v_int(len(@$pairs))
    }
    if ($name eq "keys")     { return Rb::v_array([map { $_->[0] } @$pairs]) }
    if ($name eq "values")   { return Rb::v_array([map { $_->[1] } @$pairs]) }
    if ($name eq "empty?")   { return Rb::v_bool(len(@$pairs) == 0 ? 1 : 0) }
    if ($name eq "has_key?" || $name eq "key?" || $name eq "include?") {
        for val $p (@$pairs) { return Rb::v_bool(1) if Rb::v_eq($p->[0], $args->[0]) }
        return Rb::v_bool(0)
    }
    if ($name eq "each" || $name eq "each_pair") {
        for val $p (@$pairs) { Rb::call_block($block, [$p->[0], $p->[1]], $ctx) }
        return $h
    }
    if ($name eq "map") {
        var @out
        for val $p (@$pairs) { push @out, Rb::call_block($block, [$p->[0], $p->[1]], $ctx) }
        return Rb::v_array(\@out)
    }
    if ($name eq "merge") {
        var @m = map { [$_->[0], $_->[1]] } @$pairs
        for val $other (@$args) {
            for val $p (@{$other->{pairs}}) {
                var $found = 0
                for var $mp (@m) {
                    if (Rb::v_eq($mp->[0], $p->[0])) { $mp->[1] = $p->[1]; $found = 1; last }
                }
                push @m, [$p->[0], $p->[1]] unless $found
            }
        }
        return Rb::v_hash(\@m)
    }
    if ($name eq "delete") {
        for (var $i = 0; $i < len(@$pairs); $i++) {
            if (Rb::v_eq($pairs->[$i][0], $args->[0])) {
                val $val = $pairs->[$i][1]
                splice @$pairs, $i, 1
                return $val
            }
        }
        return Rb::v_nil()
    }
    if ($name eq "fetch") {
        for val $p (@$pairs) {
            return $p->[1] if Rb::v_eq($p->[0], $args->[0])
        }
        return $args->[1] if len(@$args) > 1
        return Rb::call_block($block, [$args->[0]], $ctx) if defined $block
        die "key not found"
    }
    if ($name eq "invert") {
        return Rb::v_hash([map { [$_->[1], $_->[0]] } @$pairs])
    }
    if ($name eq "has_value?" || $name eq "value?") {
        for val $p (@$pairs) {
            return Rb::v_bool(1) if Rb::v_eq($p->[1], $args->[0])
        }
        return Rb::v_bool(0)
    }
    if ($name eq "to_a") {
        return Rb::v_array([map { Rb::v_array([$_->[0], $_->[1]]) } @$pairs])
    }
    if ($name eq "to_h" || $name eq "dup" || $name eq "clone") {
        return Rb::v_hash([map { [$_->[0], $_->[1]] } @$pairs])
    }
    if ($name eq "each_key") {
        for val $p (@$pairs) { Rb::call_block($block, [$p->[0]], $ctx) }
        return $h
    }
    if ($name eq "each_value") {
        for val $p (@$pairs) { Rb::call_block($block, [$p->[1]], $ctx) }
        return $h
    }
    if ($name eq "select" || $name eq "filter") {
        var @kept
        for val $p (@$pairs) {
            if (Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))) {
                push @kept, [$p->[0], $p->[1]]
            }
        }
        return Rb::v_hash(\@kept)
    }
    if ($name eq "reject") {
        var @kept
        for val $p (@$pairs) {
            unless (Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))) {
                push @kept, [$p->[0], $p->[1]]
            }
        }
        return Rb::v_hash(\@kept)
    }
    if ($name eq "any?") {
        for val $p (@$pairs) {
            if (defined $block) {
                return Rb::v_bool(1)
                    if Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))
            } else {
                return Rb::v_bool(len(@$pairs) > 0 ? 1 : 0)
            }
        }
        return Rb::v_bool(0)
    }
    if ($name eq "all?") {
        for val $p (@$pairs) {
            unless (Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))) {
                return Rb::v_bool(0)
            }
        }
        return Rb::v_bool(1)
    }
    if ($name eq "min_by") {
        return Rb::v_nil() unless len(@$pairs)
        var $best = $pairs->[0]
        var $bk = Rb::call_block($block, [$best->[0], $best->[1]], $ctx)
        for (var $i = 1; $i < len(@$pairs); $i++) {
            val $k = Rb::call_block($block, [$pairs->[$i][0], $pairs->[$i][1]], $ctx)
            if (Rb::v_cmp($k, $bk) < 0) { $best = $pairs->[$i]; $bk = $k }
        }
        return Rb::v_array([$best->[0], $best->[1]])
    }
    if ($name eq "max_by") {
        return Rb::v_nil() unless len(@$pairs)
        var $best = $pairs->[0]
        var $bk = Rb::call_block($block, [$best->[0], $best->[1]], $ctx)
        for (var $i = 1; $i < len(@$pairs); $i++) {
            val $k = Rb::call_block($block, [$pairs->[$i][0], $pairs->[$i][1]], $ctx)
            if (Rb::v_cmp($k, $bk) > 0) { $best = $pairs->[$i]; $bk = $k }
        }
        return Rb::v_array([$best->[0], $best->[1]])
    }
    if ($name eq "transform_values") {
        var @out
        for val $p (@$pairs) {
            push @out, [$p->[0], Rb::call_block($block, [$p->[1]], $ctx)]
        }
        return Rb::v_hash(\@out)
    }
    if ($name eq "transform_keys") {
        var @out
        for val $p (@$pairs) {
            push @out, [Rb::call_block($block, [$p->[0]], $ctx), $p->[1]]
        }
        return Rb::v_hash(\@out)
    }
    if ($name eq "count") {
        return Rb::v_int(len(@$pairs))
    }
    if ($name eq "min") {
        return Rb::v_nil() unless len(@$pairs)
        var $best = $pairs->[0]
        for val $p (@$pairs) {
            $best = $p if Rb::v_cmp($p->[0], $best->[0]) < 0
        }
        return Rb::v_array([$best->[0], $best->[1]])
    }
    if ($name eq "max") {
        return Rb::v_nil() unless len(@$pairs)
        var $best = $pairs->[0]
        for val $p (@$pairs) {
            $best = $p if Rb::v_cmp($p->[0], $best->[0]) > 0
        }
        return Rb::v_array([$best->[0], $best->[1]])
    }
    if ($name eq "store") {
        return Rb::hash_m($h, "[]=", $args, $block, $ctx)
    }
    if ($name eq "default") { return Rb::v_nil() }
    if ($name eq "freeze")  { return $h }
    undef
}

fn Rb::int_m($n, $name, $args, $block, $ctx) {
    val $v = $n->{val}
    if ($name eq "to_s")  { return Rb::v_str("" . $v) }
    if ($name eq "to_i" || $name eq "to_int") { return $n }
    if ($name eq "to_f")  { return Rb::v_float($v + 0.0) }
    if ($name eq "abs")   { return Rb::v_int(abs($v)) }
    if ($name eq "zero?") { return Rb::v_bool($v == 0 ? 1 : 0) }
    if ($name eq "even?") { return Rb::v_bool(($v % 2 == 0) ? 1 : 0) }
    if ($name eq "odd?")  { return Rb::v_bool(($v % 2 != 0) ? 1 : 0) }
    if ($name eq "succ" || $name eq "next") { return Rb::v_int($v + 1) }
    if ($name eq "pred")  { return Rb::v_int($v - 1) }
    if ($name eq "times") {
        for (var $i = 0; $i < $v; $i++) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
        }
        return $n
    }
    if ($name eq "upto") {
        val $hi = $args->[0]{val}
        for (var $i = $v; $i <= $hi; $i++) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
        }
        return $n
    }
    if ($name eq "downto") {
        val $lo = $args->[0]{val}
        for (var $i = $v; $i >= $lo; $i--) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
        }
        return $n
    }
    if ($name eq "step") {
        val $hi = $args->[0]{val}
        val $step = len(@$args) > 1 ? $args->[1]{val} : 1
        if ($step > 0) {
            for (var $i = $v; $i <= $hi; $i += $step) {
                Rb::call_block($block, [Rb::v_int($i)], $ctx)
            }
        } elsif ($step < 0) {
            for (var $i = $v; $i >= $hi; $i += $step) {
                Rb::call_block($block, [Rb::v_int($i)], $ctx)
            }
        }
        return $n
    }
    if ($name eq "gcd") {
        var $a = abs($v); var $b = abs($args->[0]{val})
        while ($b) { ($a, $b) = ($b, $a % $b) }
        return Rb::v_int($a)
    }
    if ($name eq "lcm") {
        val $a = abs($v); val $b = abs($args->[0]{val})
        return Rb::v_int(0) if $a == 0 || $b == 0
        var $x = $a; var $y = $b
        while ($y) { ($x, $y) = ($y, $x % $y) }
        return Rb::v_int(int($a * $b / $x))
    }
    if ($name eq "divmod") {
        val $b = $args->[0]{val}
        var $q = int($v / $b)
        $q-- if ($v % $b != 0) && (($v < 0) != ($b < 0))
        val $r = $v - $q * $b
        return Rb::v_array([Rb::v_int($q), Rb::v_int($r)])
    }
    if ($name eq "digits") {
        val $base = len(@$args) ? $args->[0]{val} : 10
        var @d
        var $x = abs($v)
        if ($x == 0) { @d = (0) }
        while ($x > 0) { push @d, $x % $base; $x = int($x / $base) }
        return Rb::v_array([map {Rb::v_int} @d])
    }
    if ($name eq "bit_length") {
        var $x = $v < 0 ? ~$v : $v
        var $bits = 0
        while ($x > 0) { $bits++; $x = $x >> 1 }
        return Rb::v_int($bits)
    }
    if ($name eq "to_r")    { return $n }   # Rational not implemented; identity for ints.
    if ($name eq "ceil" || $name eq "floor" || $name eq "round" || $name eq "truncate") {
        return $n
    }
    if ($name eq "positive?") { return Rb::v_bool($v > 0 ? 1 : 0) }
    if ($name eq "negative?") { return Rb::v_bool($v < 0 ? 1 : 0) }
    if ($name eq "chr")       { return Rb::v_str(chr($v)) }
    if ($name eq "**")        { return Rb::v_int($v ** $args->[0]{val}) }
    if ($name eq "coerce")    { return Rb::v_array([$args->[0], $n]) }
    if ($name eq "between?") {
        val $lo = Rb::nv($args->[0])
        val $hi = Rb::nv($args->[1])
        return Rb::v_bool(($v >= $lo && $v <= $hi) ? 1 : 0)
    }
    if ($name eq "clamp") {
        val $lo = Rb::nv($args->[0])
        val $hi = Rb::nv($args->[1])
        return Rb::v_int($lo) if $v < $lo
        return Rb::v_int($hi) if $v > $hi
        return $n
    }
    undef
}

fn Rb::float_m($f, $name, $args, $block, $ctx) {
    val $v = $f->{val}
    if ($name eq "to_s") {
        val $s = $v . ""
        return Rb::v_str($s . ".0") unless $s =~ /[.eE]/
        return Rb::v_str($s)
    }
    if ($name eq "to_i" || $name eq "to_int" || $name eq "truncate") {
        return Rb::v_int(int($v))
    }
    if ($name eq "to_f")    { return $f }
    if ($name eq "abs")     { return Rb::v_float(abs($v)) }
    if ($name eq "zero?")     { return Rb::v_bool($v == 0 ? 1 : 0) }
    if ($name eq "positive?") { return Rb::v_bool($v > 0  ? 1 : 0) }
    if ($name eq "negative?") { return Rb::v_bool($v < 0  ? 1 : 0) }
    if ($name eq "round") {
        val $digits = len(@$args) ? $args->[0]{val} : 0
        if ($digits > 0) {
            val $f10 = 10 ** $digits
            return Rb::v_float(int($v * $f10 + ($v >= 0 ? 0.5 : -0.5)) / $f10)
        }
        return Rb::v_int(int($v + ($v >= 0 ? 0.5 : -0.5)))
    }
    if ($name eq "floor") {
        return Rb::v_int(int($v) - ($v < 0 && $v != int($v) ? 1 : 0))
    }
    if ($name eq "ceil") {
        return Rb::v_int(int($v) + ($v > 0 && $v != int($v) ? 1 : 0))
    }
    if ($name eq "nan?")      { return Rb::v_bool($v != $v ? 1 : 0) }
    if ($name eq "infinite?") {
        return Rb::v_int($v > 0 ? 1 : -1) if ($v - $v) != 0 && $v == $v
        return Rb::v_nil()
    }
    if ($name eq "finite?") { return Rb::v_bool(($v == $v && ($v - $v) == 0) ? 1 : 0) }
    undef
}

fn Rb::range_m($r, $name, $args, $block, $ctx) {
    val $items = Rb::iter_items($r)
    if ($name eq "to_a")    { return Rb::v_array($items) }
    if ($name eq "first")   { return $r->{lo} }
    if ($name eq "last")    { return $r->{hi} }
    if ($name eq "min")     { return $r->{lo} }
    if ($name eq "max")     { return $r->{exclusive} ? Rb::v_int(Rb::nv($r->{hi}) - 1) : $r->{hi} }
    if ($name eq "size" || $name eq "length" || $name eq "count") { return Rb::v_int(len(@$items)) }
    if ($name eq "include?" || $name eq "cover?") {
        return Rb::v_bool(Rb::case_match($r, $args->[0]) ? 1 : 0)
    }
    if ($name eq "each") {
        for val $e (@$items) { Rb::call_block($block, [$e], $ctx) }
        return $r
    }
    if ($name eq "step") {
        val $stride = len(@$args) ? Rb::nv($args->[0]) : 1
        val $lo = Rb::nv($r->{lo})
        var $hi = Rb::nv($r->{hi})
        $hi-- if $r->{exclusive}
        var @out
        for (var $i = $lo; $i <= $hi; $i += $stride) {
            if (defined $block) {
                Rb::call_block($block, [Rb::v_int($i)], $ctx)
            } else {
                push @out, Rb::v_int($i)
            }
        }
        return $r if defined $block
        return Rb::v_array(\@out)
    }
    if ($name eq "map") {
        var @out
        for val $e (@$items) { push @out, Rb::call_block($block, [$e], $ctx) }
        return Rb::v_array(\@out)
    }
    if ($name eq "sum") {
        var $s = 0
        for val $e (@$items) { $s += Rb::nv($e) }
        return Rb::v_int($s)
    }
    undef
}

fn Rb::proc_m($p, $name, $args, $block, $ctx) {
    if ($name eq "call" || $name eq "[]" || $name eq "()") {
        return Rb::call_block($p, $args, $ctx)
    }
    if ($name eq "arity")    { return Rb::v_int(len(@{$p->{params}})) }
    if ($name eq "lambda?")  { return Rb::v_bool(0) }   # all are non-lambda for now
    if ($name eq "curry")    { return $p }              # simplified
    if ($name eq "to_proc")  { return $p }
    undef
}

fn Rb::sym_m($s, $name, $args, $block, $ctx) {
    var $v = $s->{val}
    if ($name eq "to_s")     { return Rb::v_str($v) }
    if ($name eq "to_sym")   { return $s }
    if ($name eq "length" || $name eq "size") { return Rb::v_int(length($v)) }
    if ($name eq "upcase")   { return Rb::v_sym(uc($v)) }
    if ($name eq "downcase") { return Rb::v_sym(lc($v)) }
    if ($name eq "capitalize"){ return Rb::v_sym(uc(substr($v, 0, 1)) . lc(substr($v, 1))) }
    if ($name eq "empty?")   { return Rb::v_bool(length($v) == 0 ? 1 : 0) }
    if ($name eq "to_proc") {
        # `&:method` — turns a symbol into a one-arg block calling that method.
        val $body = [+{
            kind  => "Call",
            recv  => +{ kind => "Ident", name => "x", line => 0 },
            name  => $v,
            args  => [],
            block => undef,
            line  => 0,
        }]
        return Rb::v_proc(["x"], $body, [+{}])
    }
    undef
}

fn Rb::nil_m($v, $name, $args, $block, $ctx) {
    if ($name eq "to_a")    { return Rb::v_array([]) }
    if ($name eq "to_s")    { return Rb::v_str("") }
    if ($name eq "to_i")    { return Rb::v_int(0) }
    if ($name eq "to_f")    { return Rb::v_float(0.0) }
    if ($name eq "to_h")    { return Rb::v_hash([]) }
    if ($name eq "inspect") { return Rb::v_str("nil") }
    if ($name eq "nil?")    { return Rb::v_bool(1) }
    if ($name eq "!")       { return Rb::v_bool(1) }
    if ($name eq "&")       { return Rb::v_bool(0) }
    if ($name eq "|")       { return Rb::v_bool(Rb::is_truthy($args->[0]) ? 1 : 0) }
    if ($name eq "^")       { return Rb::v_bool(Rb::is_truthy($args->[0]) ? 1 : 0) }
    if ($name eq "==")      { return Rb::v_bool(Rb::is_nil($args->[0]) ? 1 : 0) }
    undef
}

fn Rb::bool_m($v, $name, $args, $block, $ctx) {
    val $b = $v->{val}
    if ($name eq "to_s")    { return Rb::v_str($b ? "true" : "false") }
    if ($name eq "inspect") { return Rb::v_str($b ? "true" : "false") }
    if ($name eq "!")       { return Rb::v_bool($b ? 0 : 1) }
    if ($name eq "&")       { return Rb::v_bool($b && Rb::is_truthy($args->[0]) ? 1 : 0) }
    if ($name eq "|")       { return Rb::v_bool($b || Rb::is_truthy($args->[0]) ? 1 : 0) }
    if ($name eq "^")       { return Rb::v_bool(($b ? 1 : 0) != (Rb::is_truthy($args->[0]) ? 1 : 0) ? 1 : 0) }
    undef
}

# Bootstrap the class registry with the named built-ins. Includes a small
# exception hierarchy so `rescue`-by-class works.
fn Rb::bootstrap_classes($ctx) {
    val $obj = Rb::v_class("Object", undef)
    $ctx->{classes}{Object} = $obj
    val $num = Rb::v_class("Numeric", $obj)
    $ctx->{classes}{Numeric} = $num
    $ctx->{classes}{Integer} = Rb::v_class("Integer", $num)
    $ctx->{classes}{Float}   = Rb::v_class("Float",   $num)
    for var $name (qw(String Symbol Array Hash Range
                      TrueClass FalseClass NilClass Proc Class Module
                      Comparable Enumerable)) {
        $ctx->{classes}{$name} = Rb::v_class($name, $obj)
    }
    val $exc = Rb::v_class("Exception", $obj)
    $ctx->{classes}{Exception} = $exc
    val $std = Rb::v_class("StandardError", $exc)
    $ctx->{classes}{StandardError} = $std
    val $rt = Rb::v_class("RuntimeError", $std)
    $ctx->{classes}{RuntimeError} = $rt
    for val $sub (qw(ArgumentError TypeError NameError NoMethodError
                     ZeroDivisionError IndexError KeyError IOError
                     StopIteration FrozenError NotImplementedError
                     RangeError FloatDomainError)) {
        $ctx->{classes}{$sub} = Rb::v_class($sub, $std)
    }
}

# ── EMBEDDED TEST SUITE ────────────────────────────────────────────────────
#
# `Rb::eval_str(src)` parses + runs a Ruby snippet and returns the result
# as an inspected string (one-shot helper, fresh context per call).

fn Rb::eval_str($src) {
    val $ctx = Rb::ctx_new()
    Rb::bootstrap_classes($ctx)
    val $r = Rb::run($src, $ctx)
    Rb::inspect($r)
}

package main

fn rb_test($desc, $src, $expected) {
    val $got = eval { Rb::eval_str($src) }
    if ($@) {
        assert_ok 0, $desc . " — error: " . $@
        return
    }
    assert_eq $got, $expected, $desc
}

# ── ARITHMETIC ─────────────────────────────────────────────────────────────
rb_test "int add",        "1 + 2",                          "3"
rb_test "int sub",        "10 - 3",                         "7"
rb_test "int mul",        "6 * 7",                          "42"
rb_test "int div floor",  "7 / 2",                          "3"
rb_test "int mod",        "10 % 3",                         "1"
rb_test "int pow",        "2 ** 10",                        "1024"
rb_test "neg",            "-5 + 10",                        "5"
rb_test "float arith",    "1.5 + 2.5",                      "4.0"
rb_test "mixed promo",    "1 + 2.5",                        "3.5"
rb_test "paren prec",     "(1 + 2) * 3",                    "9"
rb_test "compare lt",     "3 < 5",                          "true"
rb_test "compare eq",     "3 == 3",                         "true"
rb_test "compare neq",    "3 != 4",                         "true"
rb_test "spaceship",      "5 <=> 3",                        "1"

# ── STRINGS ────────────────────────────────────────────────────────────────
rb_test "str literal",    '"hello"',                        "\"hello\""
