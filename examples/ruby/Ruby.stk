    'module Greet
       def hello
         "hi"
       end
     end
     class Person
       include Greet
     end
     Person.new.hello',
    "\"hi\""

rb_test "ancestors includes module",
    'module Walkable
       def walk; "walking"; end
     end
     class Pet
       include Walkable
     end
     Pet.new.walk',
    "\"walking\""

