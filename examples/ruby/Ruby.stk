rb_test "str repeat",     '"ab" * 3',                       "\"ababab\""
rb_test "str length",     '"hello".length',                 "5"
rb_test "str upcase",     '"hello".upcase',                 "\"HELLO\""
rb_test "str downcase",   '"HELLO".downcase',               "\"hello\""
rb_test "str reverse",    '"abc".reverse',                  "\"cba\""
rb_test "str chars",      '"abc".chars',                    "[\"a\", \"b\", \"c\"]"
rb_test "str split",      '"a,b,c".split(",")',             "[\"a\", \"b\", \"c\"]"
rb_test "str include?",   '"hello".include?("ell")',        "true"
rb_test "str interp",     'x = 7; "n=#{x}"',                "\"n=7\""
rb_test "str interp expr",'"sum=#{1+2*3}"',                 "\"sum=7\""

# ── ARRAYS ─────────────────────────────────────────────────────────────────
rb_test "array literal",  "[1, 2, 3]",                      "[1, 2, 3]"
