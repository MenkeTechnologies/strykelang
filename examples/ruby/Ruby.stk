    "[[0, 10], [1, 20], [2, 30]]"

# ── STRING SPLIT / FORMAT ──────────────────────────────────────────────────
rb_test "string format %",    '"x = %d, y = %s" % [42, "hi"]',  "\"x = 42, y = hi\""
rb_test "string * repeat",    '"ab" * 3',                       "\"ababab\""
rb_test "string * 0",         '"x" * 0',                        "\"\""

# ── STRING TESTS / PREDICATES ──────────────────────────────────────────────
rb_test "str start_with?",     '"hello".start_with?("hel")',     "true"
rb_test "str end_with?",       '"hello".end_with?("llo")',       "true"
rb_test "str start_with? false",'"hello".start_with?("foo")',     "false"
rb_test "str empty?",          '"".empty?',                      "true"
rb_test "str empty? false",    '"x".empty?',                     "false"
rb_test "str index",           '"hello".index("l")',             "2"
rb_test "str []",              '"hello"[1]',                     "\"e\""
rb_test "str slice range",     '"hello"[1..3]',                  "\"ell\""
rb_test "str * literal",       '"a" * 5',                        "\"aaaaa\""
rb_test "str to_i",            '"42abc".to_i',                   "42"
rb_test "str to_f",            '"3.14".to_f',                    "3.14"
rb_test "str to_sym",          '"foo".to_sym',                   ":foo"
rb_test "str split default",   '"a b  c\td".split',              "[\"a\", \"b\", \"c\", \"d\"]"
rb_test "str length unicode",  '"hi".length',                    "2"

# ── ARRAY << OPERATOR / FLATTEN! / DUP ─────────────────────────────────────
rb_test "array push <<",       'a = [1, 2]; a << 3; a',          "[1, 2, 3]"
rb_test "array dup independent",
    'a = [1, 2]; b = a.dup; b.push(3); a',                         "[1, 2]"
rb_test "array sum with block",
    "[1, 2, 3].sum(0) { |x| x * x }",                               "14"

# ── RANGE STEP / LAZY-ish ──────────────────────────────────────────────────
rb_test "range step block",
    "out = []; (1..10).step(3) { |i| out.push(i) }; out",         "[1, 4, 7, 10]"
rb_test "range step to_a",     "(1..10).step(2).to_a",           "[1, 3, 5, 7, 9]"

# ── FILTER_MAP / FIND_INDEX / EACH_WITH_OBJECT ─────────────────────────────
rb_test "array filter_map",
    "[1, 2, 3, 4].filter_map { |x| x * 2 if x.even? }",            "[4, 8]"
rb_test "array find_index pred",
    "[1, 2, 3, 4].find_index { |x| x > 2 }",                       "2"
rb_test "array each_with_object",
    "[1, 2, 3].each_with_object([]) { |x, acc| acc.push(x * 10) }", "[10, 20, 30]"

# ── COMPARABLE-LIKE: BETWEEN / CLAMP ───────────────────────────────────────
rb_test "int between?",        "5.between?(1, 10)",              "true"
rb_test "int between? false",  "15.between?(1, 10)",             "false"
rb_test "int clamp",           "15.clamp(1, 10)",                "10"
rb_test "int clamp low",       "(-5).clamp(0, 10)",              "0"

# ── %w / %i WORD ARRAYS ────────────────────────────────────────────────────
rb_test "%w bracket",       "%w[apple pear plum]",            "[\"apple\", \"pear\", \"plum\"]"
rb_test "%w paren",         "%w(red green blue)",             "[\"red\", \"green\", \"blue\"]"
rb_test "%w brace",         "%w{a b c}",                      "[\"a\", \"b\", \"c\"]"
rb_test "%i bracket",       "%i[foo bar baz]",                "[:foo, :bar, :baz]"
rb_test "%w with newlines", "%w[
  one
  two
  three
]",                                                            "[\"one\", \"two\", \"three\"]"

# ── EXCEPTION CLASSES ──────────────────────────────────────────────────────
rb_test "rescue named class",
    'begin
       raise ArgumentError, "bad arg"
     rescue ArgumentError => e
       e.message
     end',
    "\"bad arg\""

rb_test "rescue base catches subclass",
    'begin
       raise ArgumentError, "x"
     rescue StandardError => e
       "caught"
     end',
    "\"caught\""

# ── FINAL SUMMARY ──────────────────────────────────────────────────────────

p ""
p "╔══════════════════════════════════════════════════════════════════╗"
p "║              RUBY-IN-STRYKE — TEST SUITE COMPLETE                 ║"
p "╚══════════════════════════════════════════════════════════════════╝"

test_run
