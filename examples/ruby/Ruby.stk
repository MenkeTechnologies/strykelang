#!/usr/bin/env stryke
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║                  RUBY-SUBSET INTERPRETER IN STRYKE                        ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║ A Ruby interpreter implemented in pure stryke. Single file. Tokenizer,   ║
# ║ recursive-descent parser, environment-frame evaluator, core methods on   ║
# ║ built-in types, classes/modules/inheritance, exceptions, and an          ║
# ║ embedded test suite.                                                      ║
# ║                                                                            ║
# ║ Coverage:                                                                  ║
# ║   - Integers, Floats, Strings (with #{} interpolation), Symbols,         ║
# ║     Arrays, Hashes, Ranges, nil, true, false, Procs                      ║
# ║   - def / return / yield, blocks (do..end and { ... })                   ║
# ║   - if / unless / while / until / case-when, ternary, modifier-if        ║
# ║   - Iteration: .each .map .select .reduce .times .upto .downto           ║
# ║   - Core methods on Array, String, Hash, Integer, Range                  ║
# ║   - Classes: class C < P; def m; ... end; end with @ivars and super     ║
# ║   - Modules: module M; ...; end with `include M` (mixin)                 ║
# ║   - Exceptions: begin / rescue / raise / ensure                           ║
# ║   - String interpolation, %w[]/%i[], heredocs                             ║
# ║   - puts / print / p / pp                                                ║
# ║                                                                            ║
# ║ Out of scope (not implemented):                                            ║
# ║   - Metaclasses / singleton classes / method_missing / define_method     ║
# ║   - Fibers / Threads / Continuations                                      ║
# ║   - Full Ruby regex semantics (basic /pat/ via stryke regex)             ║
# ║   - File / network I/O beyond stdout                                      ║
# ║   - Gems / require / load                                                 ║
# ║   - Refinements / ObjectSpace                                             ║
# ║   - Tail-call optimization (recursion uses stryke's call stack)          ║
# ║                                                                            ║
# ║ Run all tests: stryke examples/ruby/Ruby.stk                              ║
# ║ Eval one expr: stryke examples/ruby/Ruby.stk -- -e '1 + 2'                ║
# ║ REPL:          STRYKE_RUBY_REPL=1 stryke examples/ruby/Ruby.stk           ║
# ╚══════════════════════════════════════════════════════════════════════════╝

package Rb

# ── VALUE MODEL ────────────────────────────────────────────────────────────
#
# Ruby values are tagged hashrefs. Every value has a `type` field naming its
# kind, plus type-specific fields. This is uniform, debuggable, and works
# transparently with stryke's hashref machinery. The cost is a small alloc
# per value — fine for an interpreter at this scale.
#
# Types:
#   "int"     +{ type, val }                  — Integer
#   "float"   +{ type, val }                  — Float
#   "str"     +{ type, val }                  — String (Ruby is byte-string)
#   "sym"     +{ type, val }                  — Symbol (frozen, interned)
#   "bool"    +{ type, val }                  — true / false
#   "nil"     +{ type }                       — nil
#   "array"   +{ type, items }                — Array (mutable)
#   "hash"    +{ type, pairs }                — Hash (insertion-ordered)
#                                                pairs is arrayref of [k, v]
#                                                (we don't use stryke %hash
#                                                because Ruby keys can be any
#                                                value, not just strings)
#   "range"   +{ type, lo, hi, exclusive }    — Range (.. / ...)
#   "proc"    +{ type, params, body, env,     — Proc / block / lambda
#                rest, name, is_lambda }
#   "method"  +{ type, owner, name, params,   — bound method
#                rest, body, env }
#   "class"   +{ type, name, parent, methods, — class definition
#                ivars, includes }
#   "module"  +{ type, name, methods }        — module (mixin source)
#   "instance"+{ type, klass, ivars }         — class instance
#                                                ivars is hashref keyed by
#                                                name without leading '@'
#   "exception"+{ type, klass, message,       — Ruby exception
#                 backtrace }

fn Rb::v_int($n)        { +{ type => "int",   val => $n } }
fn Rb::v_float($f)      { +{ type => "float", val => $f } }
fn Rb::v_str($s)        { +{ type => "str",   val => $s } }
fn Rb::v_sym($s)        { +{ type => "sym",   val => $s } }
fn Rb::v_bool($b)       { +{ type => "bool",  val => ($b ? 1 : 0) } }
fn Rb::v_nil()          { +{ type => "nil" } }
fn Rb::v_array($items)  { +{ type => "array", items => $items } }
fn Rb::v_range($lo, $hi, $exclusive) {
    +{ type => "range", lo => $lo, hi => $hi, exclusive => $exclusive }
}
fn Rb::v_hash($pairs)   { +{ type => "hash",  pairs => $pairs } }
fn Rb::v_proc($params, $rest, $body, $env, $name, $is_lambda) {
    +{
        type      => "proc",
        params    => $params,     # arrayref of param names
        rest      => $rest,       # name for splat, or undef
        body      => $body,       # AST nodes (arrayref)
        env       => $env,        # captured env frames (arrayref of hashref)
        name      => $name,       # method name (or "<block>")
        is_lambda => $is_lambda,  # 1 = lambda (strict arity), 0 = proc/block
    }
}
fn Rb::v_class($name, $parent) {
    +{
        type     => "class",
        name     => $name,
        parent   => $parent,      # parent class hashref or nil
        methods  => +{},          # method-name => proc
        ivars    => +{},          # class-level @@vars (not implemented)
        includes => [],           # mixed-in modules
    }
}
fn Rb::v_module($name) {
    +{ type => "module", name => $name, methods => +{} }
}
fn Rb::v_instance($klass) {
    +{ type => "instance", klass => $klass, ivars => +{} }
}
fn Rb::v_exception($klass, $message) {
    +{ type => "exception", klass => $klass, message => $message, backtrace => [] }
}

# ── PREDICATES ─────────────────────────────────────────────────────────────

fn Rb::is_int($v)    { ref($v) eq "HASH" && $v->{type} eq "int" }
fn Rb::is_float($v)  { ref($v) eq "HASH" && $v->{type} eq "float" }
fn Rb::is_num($v)    { Rb::is_int($v) || Rb::is_float($v) }
fn Rb::is_str($v)    { ref($v) eq "HASH" && $v->{type} eq "str" }
fn Rb::is_sym($v)    { ref($v) eq "HASH" && $v->{type} eq "sym" }
fn Rb::is_bool($v)   { ref($v) eq "HASH" && $v->{type} eq "bool" }
fn Rb::is_nil($v)    { ref($v) eq "HASH" && $v->{type} eq "nil" }
fn Rb::is_array($v)  { ref($v) eq "HASH" && $v->{type} eq "array" }
fn Rb::is_hash($v)   { ref($v) eq "HASH" && $v->{type} eq "hash" }
fn Rb::is_range($v)  { ref($v) eq "HASH" && $v->{type} eq "range" }
fn Rb::is_proc($v)   { ref($v) eq "HASH" && $v->{type} eq "proc" }
fn Rb::is_class($v)  { ref($v) eq "HASH" && $v->{type} eq "class" }
fn Rb::is_module($v) { ref($v) eq "HASH" && $v->{type} eq "module" }
fn Rb::is_instance($v) { ref($v) eq "HASH" && $v->{type} eq "instance" }
fn Rb::is_exception($v){ ref($v) eq "HASH" && $v->{type} eq "exception" }

# Ruby truthiness: only `false` and `nil` are falsy; everything else
# (including 0, "", []) is truthy. This is a critical Ruby semantics.
fn Rb::is_truthy($v) {
    return 0 if Rb::is_nil($v)
    return 0 if Rb::is_bool($v) && $v->{val} == 0
    1
}

# ── EQUALITY ───────────────────────────────────────────────────────────────
#
# Ruby has three layers of equality:
#   .equal?   — object identity (by reference)
#   ==        — value equality (most types: structural)
#   .eql?     — strict equality (no implicit conversions; 1 != 1.0)

fn Rb::v_equal($a, $b) {
    return 1 if Rb::is_nil($a) && Rb::is_nil($b)
    return 0 if $a->{type} ne $b->{type} && !(Rb::is_num($a) && Rb::is_num($b))
    return $a->{val} == $b->{val} if Rb::is_int($a) && Rb::is_int($b)
    return Rb::num_val($a) == Rb::num_val($b) if Rb::is_num($a) && Rb::is_num($b)
    return $a->{val} eq $b->{val} if Rb::is_str($a) && Rb::is_str($b)
    return $a->{val} eq $b->{val} if Rb::is_sym($a) && Rb::is_sym($b)
    return $a->{val} == $b->{val} if Rb::is_bool($a) && Rb::is_bool($b)
    if (Rb::is_array($a) && Rb::is_array($b)) {
        my $ai = $a->{items}
        my $bi = $b->{items}
        return 0 if scalar(@$ai) != scalar(@$bi)
        for (my $i = 0; $i < scalar(@$ai); $i++) {
            return 0 unless Rb::v_equal($ai->[$i], $bi->[$i])
        }
        return 1
    }
    if (Rb::is_hash($a) && Rb::is_hash($b)) {
        my $ap = $a->{pairs}
        my $bp = $b->{pairs}
        return 0 if scalar(@$ap) != scalar(@$bp)
        # Compare as set of pairs (Ruby hash == is unordered).
        for my $apair (@$ap) {
            my $found = 0
            for my $bpair (@$bp) {
                if (Rb::v_equal($apair->[0], $bpair->[0])
                    && Rb::v_equal($apair->[1], $bpair->[1])) {
                    $found = 1
                    last
                }
            }
            return 0 unless $found
        }
        return 1
    }
    return 0
}

# Numeric value extraction — works for both int and float.
fn Rb::num_val($v) {
    return $v->{val} if Rb::is_num($v)
    return 0 if Rb::is_nil($v)
    return $v->{val} if Rb::is_bool($v)
    return $v->{val} + 0 if Rb::is_str($v)
    0
}

# ── INSPECT / TO_S ─────────────────────────────────────────────────────────
#
# `inspect` returns the human-readable Ruby form (with quotes for strings).
# `to_s` returns the value as a string (no quotes around strings).
# Both recurse into containers.

fn Rb::inspect($v) {
    return "nil" if Rb::is_nil($v)
    return ($v->{val} ? "true" : "false") if Rb::is_bool($v)
    return $v->{val} . "" if Rb::is_int($v)
    return Rb::format_float($v->{val}) if Rb::is_float($v)
    return Rb::escape_string($v->{val}) if Rb::is_str($v)
    return ":" . $v->{val} if Rb::is_sym($v)
    if (Rb::is_array($v)) {
        return "[" . join(", ", map { Rb::inspect($_) } @{$v->{items}}) . "]"
    }
    if (Rb::is_hash($v)) {
        my @parts
        for my $pair (@{$v->{pairs}}) {
            my $k = $pair->[0]
            my $val = $pair->[1]
            if (Rb::is_sym($k)) {
                push @parts, $k->{val} . ": " . Rb::inspect($val)
            } else {
                push @parts, Rb::inspect($k) . " => " . Rb::inspect($val)
            }
        }
        return "{" . join(", ", @parts) . "}"
    }
    if (Rb::is_range($v)) {
        my $sep = $v->{exclusive} ? "..." : ".."
        return Rb::inspect($v->{lo}) . $sep . Rb::inspect($v->{hi})
    }
    return "#<Proc>" if Rb::is_proc($v)
    return $v->{name} if Rb::is_class($v)
    return $v->{name} if Rb::is_module($v)
    if (Rb::is_instance($v)) {
        my @parts
        for my $k (sort keys %{$v->{ivars}}) {
            push @parts, "@" . $k . "=" . Rb::inspect($v->{ivars}{$k})
        }
        my $body = scalar(@parts) > 0 ? " " . join(", ", @parts) : ""
        return "#<" . $v->{klass}{name} . $body . ">"
    }
    if (Rb::is_exception($v)) {
        return "#<" . $v->{klass}{name} . ": " . $v->{message} . ">"
    }
    "#<unknown>"
}

fn Rb::to_s($v) {
    return $v->{val} if Rb::is_str($v)
    return $v->{val} if Rb::is_sym($v)
    return "" if Rb::is_nil($v)
    Rb::inspect($v)
}

fn Rb::format_float($f) {
    # Ruby prints `2.5` as `"2.5"`, `2.0` as `"2.0"` (always with at least
    # one fractional digit). Stryke's default stringification can drop
    # trailing zeros — pad if needed.
    my $s = $f . ""
    return $s . ".0" unless $s =~ /[.eE]/
    $s
}

fn Rb::escape_string($s) {
    my $out = "\""
    for my $c (split //, $s) {
        if    ($c eq "\\") { $out .= "\\\\" }
        elsif ($c eq "\"") { $out .= "\\\"" }
        elsif ($c eq "\n") { $out .= "\\n" }
        elsif ($c eq "\t") { $out .= "\\t" }
        elsif ($c eq "\r") { $out .= "\\r" }
        else               { $out .= $c }
    }
    $out . "\""
}

# ── CLASS REGISTRY ─────────────────────────────────────────────────────────
#
# Built-in classes are stored in a package-global hash. User-defined classes
# add to this registry. Method dispatch walks the inheritance chain via
# `parent`, then mixed-in modules in `includes` (most-recently-included
# first, matching Ruby's MRO).

our %CLASSES
our %MODULES

# `object_class` returns the class of any value — this is what backs
# `value.class` / `value.is_a?(Klass)`.
fn Rb::object_class($v) {
    return $CLASSES{Integer}   if Rb::is_int($v)
    return $CLASSES{Float}     if Rb::is_float($v)
    return $CLASSES{String}    if Rb::is_str($v)
    return $CLASSES{Symbol}    if Rb::is_sym($v)
    return $CLASSES{TrueClass}  if Rb::is_bool($v) && $v->{val} == 1
    return $CLASSES{FalseClass} if Rb::is_bool($v) && $v->{val} == 0
    return $CLASSES{NilClass}  if Rb::is_nil($v)
    return $CLASSES{Array}     if Rb::is_array($v)
    return $CLASSES{Hash}      if Rb::is_hash($v)
    return $CLASSES{Range}     if Rb::is_range($v)
    return $CLASSES{Proc}      if Rb::is_proc($v)
    return $CLASSES{Class}     if Rb::is_class($v)
    return $CLASSES{Module}    if Rb::is_module($v)
    return $v->{klass}         if Rb::is_instance($v)
    return $CLASSES{Exception} if Rb::is_exception($v)
    $CLASSES{Object}
}

# Walk the class chain (parent + included modules) looking for a method.
# Returns the proc or nil.
fn Rb::lookup_method($klass, $name) {
    my $c = $klass
    while (defined($c) && !Rb::is_nil($c)) {
        if (exists $c->{methods}{$name}) {
            return $c->{methods}{$name}
        }
        # Mixin lookup: most-recently-included first.
        for my $mod (reverse @{$c->{includes} // []}) {
            if (exists $mod->{methods}{$name}) {
                return $mod->{methods}{$name}
            }
        }
        $c = $c->{parent}
    }
    Rb::v_nil()
}

# True if `klass` (or any of its ancestors / mixins) is `target`.
fn Rb::class_is_a($klass, $target) {
    my $c = $klass
    while (defined($c) && !Rb::is_nil($c)) {
        return 1 if $c == $target
        return 1 if $c->{name} eq $target->{name}
        for my $mod (@{$c->{includes} // []}) {
            return 1 if $mod == $target
            return 1 if $mod->{name} eq $target->{name}
        }
        $c = $c->{parent}
    }
    0
}

# token hashrefs:
#
#   +{ kind => "INT", val => 42, line => 7 }
#
# Token kinds:
#   INT FLOAT STR SYM IDENT CONST IVAR CVAR GVAR
#   KW    val = "def" / "end" / "if" / ...
#   OP    val = "+" / "==" / ".." / ...
#   LPAREN RPAREN LBRACE RBRACE LBRACKET RBRACKET
#   COMMA SEMI NEWLINE COLON ARROW FATARROW DOT DOTDOT DOTDOTDOT QUESTION
#   ASSIGN COMPOUND_ASSIGN PIPE BLOCK_PARAM
#   STR_INTERP    val = arrayref of [ "lit"|"expr", text ]   for "#{} ..."
#   EOF
#
# String interpolation: `"foo #{bar} baz"` produces a single STR_INTERP
# token whose `val` is `[["lit","foo "], ["expr","bar"], ["lit"," baz"]]`.
# The parser later wraps each "expr" chunk in a fresh tokenize+parse pass.


# Reserved Ruby keywords. The tokenizer emits these as `kind="KW", val=word`.
# `__FILE__`, `__LINE__`, `__method__`, `__dir__`, `BEGIN`, `END` are
# parsed as KW too even though they're more like magic-constant idents.
our %KEYWORDS = (
    BEGIN     => 1, END        => 1, alias    => 1, and      => 1,
    begin     => 1, break      => 1, case     => 1, class    => 1,
    def       => 1, defined    => 1, do       => 1, else     => 1,
    elsif     => 1, end        => 1, ensure   => 1, false    => 1,
    for       => 1, if         => 1, in       => 1, module   => 1,
    next      => 1, nil        => 1, not      => 1, or       => 1,
    redo      => 1, rescue     => 1, retry    => 1, return   => 1,
    self      => 1, super      => 1, then     => 1, true     => 1,
    undef     => 1, unless     => 1, until    => 1, when     => 1,
    while     => 1, yield      => 1, lambda   => 1, proc     => 1,
    raise     => 1, puts       => 1, print    => 1, p        => 1,
    pp        => 1, gets       => 1, require  => 1, attr_accessor => 1,
    attr_reader => 1, attr_writer => 1, include => 1, extend => 1,
    new       => 1, __FILE__   => 1, __LINE__ => 1, __method__ => 1,
)

# Multi-char operators in DESCENDING length order — the tokenizer tries
# longest-first to avoid mis-tokenizing `<=>` as `<=` + `>`.
our @MULTI_OPS = (
    "<<=", ">>=", "**=", "<=>", "===", "!~",
    "==", "!=", "<=", ">=", "<<", ">>", "**", "&&", "||",
    "+=", "-=", "*=", "/=", "%=", "&=", "|=", "^=", "&&=", "||=",
    "..", "...", "->", "=>", "::",
)

# Single-char operators (each is its own kind from a parser perspective,
# but we lump them under OP and let the parser pattern-match `val`).
our @SINGLE_OPS = ("+", "-", "*", "/", "%", "=", "<", ">", "&", "|", "^",
                   "~", "!", "?", ":", ".")

fn Rb::tokenize($src) {
    my @tokens
    my $i = 0
    my $line = 1
    my $n = length($src)

    while ($i < $n) {
        my $c = substr($src, $i, 1)

        # ── Whitespace (newlines are significant in Ruby) ──
        if ($c eq " " || $c eq "\t" || $c eq "\r") {
            $i++
            next
        }
        if ($c eq "\n") {
            push @tokens, +{ kind => "NEWLINE", val => "\n", line => $line }
            $line++
            $i++
            next
        }

        # ── Line continuation: backslash-newline ──
        if ($c eq "\\" && substr($src, $i + 1, 1) eq "\n") {
            $line++
            $i += 2
            next
        }

        # ── Single-line comment: # ... \n ──
        # Skip the comment but emit the newline (significant in Ruby).
        if ($c eq "#") {
            while ($i < $n && substr($src, $i, 1) ne "\n") {
                $i++
            }
            next
        }

        # ── Multi-line comment: =begin ... =end at start of line ──
        if ($c eq "=" && substr($src, $i, 6) eq "=begin"
            && ($i == 0 || substr($src, $i - 1, 1) eq "\n")) {
            while ($i < $n) {
                if (substr($src, $i, 4) eq "=end"
                    && ($i == 0 || substr($src, $i - 1, 1) eq "\n")) {
                    $i += 4
                    while ($i < $n && substr($src, $i, 1) ne "\n") { $i++ }
                    last
                }
                $line++ if substr($src, $i, 1) eq "\n"
                $i++
            }
            next
        }

        # ── Numbers ──
        if ($c =~ /[0-9]/) {
            my $start = $i
            my $is_float = 0
            # Hex / binary / octal prefix (0x / 0b / 0o)
            if ($c eq "0" && $i + 1 < $n) {
                my $next = substr($src, $i + 1, 1)
                if ($next eq "x" || $next eq "X") {
                    $i += 2
                    while ($i < $n && substr($src, $i, 1) =~ /[0-9a-fA-F_]/) { $i++ }
                    my $hex = substr($src, $start + 2, $i - $start - 2)
                    $hex =~ s/_//g
                    push @tokens, +{ kind => "INT", val => hex($hex), line => $line }
                    next
                }
                if ($next eq "b" || $next eq "B") {
                    $i += 2
                    while ($i < $n && substr($src, $i, 1) =~ /[01_]/) { $i++ }
                    my $bin = substr($src, $start + 2, $i - $start - 2)
                    $bin =~ s/_//g
                    my $val = 0
                    for my $bit (split //, $bin) {
                        $val = $val * 2 + ($bit eq "1" ? 1 : 0)
                    }
                    push @tokens, +{ kind => "INT", val => $val, line => $line }
                    next
                }
                if ($next eq "o" || $next eq "O") {
                    $i += 2
                    while ($i < $n && substr($src, $i, 1) =~ /[0-7_]/) { $i++ }
                    my $oct = substr($src, $start + 2, $i - $start - 2)
                    $oct =~ s/_//g
                    push @tokens, +{ kind => "INT", val => oct($oct), line => $line }
                    next
                }
            }
            # Decimal integer + optional fractional + optional exponent.
            while ($i < $n && substr($src, $i, 1) =~ /[0-9_]/) { $i++ }
            if ($i < $n && substr($src, $i, 1) eq "."
                && $i + 1 < $n && substr($src, $i + 1, 1) =~ /[0-9]/) {
                $is_float = 1
                $i++
                while ($i < $n && substr($src, $i, 1) =~ /[0-9_]/) { $i++ }
            }
            if ($i < $n && (substr($src, $i, 1) eq "e" || substr($src, $i, 1) eq "E")) {
                $is_float = 1
                $i++
                if ($i < $n && (substr($src, $i, 1) eq "+" || substr($src, $i, 1) eq "-")) {
                    $i++
                }
                while ($i < $n && substr($src, $i, 1) =~ /[0-9_]/) { $i++ }
            }
            my $num_text = substr($src, $start, $i - $start)
            $num_text =~ s/_//g
            if ($is_float) {
                push @tokens, +{ kind => "FLOAT", val => $num_text + 0, line => $line }
            } else {
                push @tokens, +{ kind => "INT",   val => int($num_text), line => $line }
            }
            next
        }

        # ── Strings ──
        # Single-quoted: only \\ and \' are escapes; everything else literal.
        if ($c eq "'") {
            $i++
            my $s = ""
            while ($i < $n && substr($src, $i, 1) ne "'") {
                if (substr($src, $i, 1) eq "\\" && $i + 1 < $n) {
                    my $next = substr($src, $i + 1, 1)
                    if ($next eq "\\") { $s .= "\\"; $i += 2; next }
                    if ($next eq "'")  { $s .= "'";  $i += 2; next }
                    # Other escapes pass through literally in single-quote.
                    $s .= "\\"
                    $i++
                    next
                }
                $line++ if substr($src, $i, 1) eq "\n"
                $s .= substr($src, $i, 1)
                $i++
            }
            $i++ if $i < $n   # skip closing quote
            push @tokens, +{ kind => "STR", val => $s, line => $line, quoted => "single" }
            next
        }

        # Double-quoted: full interpolation + escape handling.
        if ($c eq "\"") {
            $i++
            my @parts = (["lit", ""])
            while ($i < $n && substr($src, $i, 1) ne "\"") {
                my $cur = substr($src, $i, 1)
                if ($cur eq "\\" && $i + 1 < $n) {
                    my $next = substr($src, $i + 1, 1)
                    my $esc =
                        $next eq "n"  ? "\n" :
                        $next eq "t"  ? "\t" :
                        $next eq "r"  ? "\r" :
                        $next eq "\\" ? "\\" :
                        $next eq "\"" ? "\"" :
                        $next eq "0"  ? "\0" :
                        $next eq "s"  ? " "  :
                        $next eq "#"  ? "#"  :
                        $next eq "a"  ? "\x07" :
                        $next eq "b"  ? "\x08" :
                        $next eq "e"  ? "\x1b" :
                        $next eq "f"  ? "\x0c" :
                        $next eq "v"  ? "\x0b" :
                        $next   # unknown escape — pass char literally
                    $parts[-1][1] .= $esc
                    $i += 2
                    next
                }
                if ($cur eq "#" && $i + 1 < $n && substr($src, $i + 1, 1) eq "{") {
                    # Interpolation — find matching close brace, respecting
                    # nesting and escapes.
                    $i += 2
                    my $depth = 1
                    my $expr = ""
                    while ($i < $n && $depth > 0) {
                        my $ch = substr($src, $i, 1)
                        if ($ch eq "{") { $depth++ }
                        elsif ($ch eq "}") { $depth--; last if $depth == 0 }
                        $line++ if $ch eq "\n"
                        $expr .= $ch
                        $i++
                    }
                    $i++ if $i < $n   # skip }
                    push @parts, ["expr", $expr]
                    push @parts, ["lit", ""]
                    next
                }
                $line++ if $cur eq "\n"
                $parts[-1][1] .= $cur
                $i++
            }
            $i++ if $i < $n   # skip closing "
            # Single-part literal — emit as plain STR; otherwise STR_INTERP.
            if (scalar(@parts) == 1) {
                push @tokens, +{ kind => "STR", val => $parts[0][1], line => $line, quoted => "double" }
            } else {
                push @tokens, +{ kind => "STR_INTERP", val => \@parts, line => $line }
            }
            next
        }

        # ── %w[ ... ] %i[ ... ]  (word arrays / symbol arrays) ──
        if ($c eq "%" && $i + 1 < $n) {
            my $kind = substr($src, $i + 1, 1)
            if ($kind eq "w" || $kind eq "i" || $kind eq "W" || $kind eq "I") {
                my $open = substr($src, $i + 2, 1)
                my $close =
                    $open eq "(" ? ")" :
                    $open eq "[" ? "]" :
                    $open eq "{" ? "}" :
                    $open eq "<" ? ">" :
                    $open
                $i += 3
                my $body = ""
                while ($i < $n && substr($src, $i, 1) ne $close) {
                    $body .= substr($src, $i, 1)
                    $i++
                }
                $i++ if $i < $n
                my @words = split /\s+/, $body
                @words = grep { length($_) > 0 } @words
                push @tokens, +{
                    kind => ($kind eq "i" || $kind eq "I") ? "SYM_ARRAY" : "WORD_ARRAY",
                    val  => \@words,
                    line => $line,
                }
                next
            }
        }

        # ── Symbols: :name :"string" :@ivar :$gvar ──
        if ($c eq ":" && $i + 1 < $n) {
            my $next = substr($src, $i + 1, 1)
            # Disambiguate vs. :: (PackageSep, used here only for class
            # constants like Foo::Bar). We treat `::` as a regular OP via the
            # multi-char op path further down — ensure it's preferred over
            # symbol when followed by another `:`.
            if ($next eq ":") {
                # Will be handled below by multi-op match.
            } elsif ($next eq "\"") {
                # :"interpolated symbol" — collect until matching quote
                $i += 2
                my $s = ""
                while ($i < $n && substr($src, $i, 1) ne "\"") {
                    $s .= substr($src, $i, 1)
                    $i++
                }
                $i++ if $i < $n
                push @tokens, +{ kind => "SYM", val => $s, line => $line }
                next
            } elsif ($next =~ /[a-zA-Z_]/) {
                $i++
                my $start = $i
                while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
                # Trailing ? ! = is part of the symbol (matches identifier rules).
                if ($i < $n && substr($src, $i, 1) =~ /[?!=]/) { $i++ }
                push @tokens, +{ kind => "SYM", val => substr($src, $start, $i - $start), line => $line }
                next
            }
        }

        # ── Instance vars (@x), class vars (@@x), globals ($x) ──
        if ($c eq "@") {
            $i++
            my $kind = "IVAR"
            if ($i < $n && substr($src, $i, 1) eq "@") {
                $i++
                $kind = "CVAR"
            }
            my $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            push @tokens, +{ kind => $kind, val => substr($src, $start, $i - $start), line => $line }
            next
        }
        if ($c eq "\$") {
            $i++
            my $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            push @tokens, +{ kind => "GVAR", val => substr($src, $start, $i - $start), line => $line }
            next
        }

        # ── Identifiers / keywords / constants ──
        if ($c =~ /[a-zA-Z_]/) {
            my $start = $i
            while ($i < $n && substr($src, $i, 1) =~ /[a-zA-Z0-9_]/) { $i++ }
            # Trailing ? ! is part of the identifier (Ruby method-naming convention).
            # Trailing = is the setter form (foo=).
            if ($i < $n && substr($src, $i, 1) =~ /[?!]/) { $i++ }
            my $word = substr($src, $start, $i - $start)
            my $kind
            if (exists $KEYWORDS{$word}) {
                $kind = "KW"
            } elsif ($word =~ /^[A-Z]/) {
                $kind = "CONST"
            } else {
                $kind = "IDENT"
            }
            push @tokens, +{ kind => $kind, val => $word, line => $line }
            next
        }

        # ── Multi-char operators (longest-first) ──
        my $matched = 0
        for my $op (@MULTI_OPS) {
            my $oplen = length($op)
            if ($i + $oplen <= $n && substr($src, $i, $oplen) eq $op) {
                # `..` and `...` are ranges — we tokenize them as OP and let
                # the parser dispatch on val. `=>` is fat-arrow (hash literal).
                push @tokens, +{ kind => "OP", val => $op, line => $line }
                $i += $oplen
                $matched = 1
                last
            }
        }
        next if $matched

        # ── Punctuation ──
        if    ($c eq "(") { push @tokens, +{ kind => "LPAREN",   val => "(", line => $line }; $i++; next }
        elsif ($c eq ")") { push @tokens, +{ kind => "RPAREN",   val => ")", line => $line }; $i++; next }
        elsif ($c eq "{") { push @tokens, +{ kind => "LBRACE",   val => "{", line => $line }; $i++; next }
        elsif ($c eq "}") { push @tokens, +{ kind => "RBRACE",   val => "}", line => $line }; $i++; next }
        elsif ($c eq "[") { push @tokens, +{ kind => "LBRACKET", val => "[", line => $line }; $i++; next }
        elsif ($c eq "]") { push @tokens, +{ kind => "RBRACKET", val => "]", line => $line }; $i++; next }
        elsif ($c eq ",") { push @tokens, +{ kind => "COMMA",    val => ",", line => $line }; $i++; next }
        elsif ($c eq ";") { push @tokens, +{ kind => "SEMI",     val => ";", line => $line }; $i++; next }
        elsif ($c eq "|") { push @tokens, +{ kind => "OP",       val => "|", line => $line }; $i++; next }

        # ── Single-char operators ──
        for my $op (@SINGLE_OPS) {
            if ($c eq $op) {
                push @tokens, +{ kind => "OP", val => $op, line => $line }
                $i++
                $matched = 1
                last
            }
        }
        next if $matched

        # Unrecognized — bail with a clear error.
        die "Rb::tokenize: unexpected char `" . $c . "` at line " . $line
    }

    push @tokens, +{ kind => "EOF", val => "", line => $line }
    \@tokens
}

# ── PARSER ─────────────────────────────────────────────────────────────────
#
# Recursive descent on the token stream. Returns an AST of tagged hashrefs:
#
#   +{ kind => "BinOp", op => "+", left => …, right => …, line => 7 }
#
# AST node kinds:
#   Int Float Str Sym Nil True False                       — atoms
#   StrInterp        parts (arrayref of node)
#   Array            elements
#   Hash             pairs (arrayref of [key_node, val_node])
#   Range            lo, hi, exclusive
#   Ident            name        — local variable or no-arg method call
#   Const            name        — constant lookup
#   IVar CVar GVar   name
#   Self
#   BinOp            op, left, right
#   UnaryOp          op, operand
#   Assign           target, value
#   OpAssign         target, op, value           — `x += 1` etc.
#   Call             receiver (or undef), name, args, block
#   Index            receiver, indices            — `a[i]`, `h[k]`
#   IndexAssign      receiver, indices, value     — `a[i] = v`
#   If / Unless      cond, then, elsifs, else
#   While / Until    cond, body, do_form          — do_form: `while ... do ... end`
#   Case             subject, whens (each: pats + body), else
#   For              var, iter, body
#   Begin / Rescue   body, rescues (class, var, body), else, ensure
#   Block            params, body, line           — &block / do..end
#   Lambda           params, body
#   Def              name, params, body, receiver — `def self.foo` sets receiver
#   ClassDecl        name, parent, body
#   ModuleDecl       name, body
#   Return           value
#   Yield            args
#   Break / Next     value
#   And / Or         left, right                  — short-circuit
#   Not              operand
#   Ternary          cond, then, else
#
# The parser is hand-written, longest-match for operators, and handles
# Ruby's quirks:
#   - Newline as statement separator (significant whitespace)
#   - Modifier `if`/`unless`/`while`/`until` postfix
#   - Implicit method receivers (`foo bar baz` as `foo(bar, baz)`)
#   - Ambiguous `{...}` (block vs hash) — block wins after a method name,
#     hash wins in expression position
#   - `do..end` low-precedence block (binds to leftmost call)
#   - Ranges in any expression position

# Parser state — the tokens arrayref, current index, and a stack of expected
# closing delimiters for context-sensitive parsing.
fn Rb::parser_new($tokens) {
    +{
        tokens => $tokens,
        pos    => 0,
        # When true, treat `{` as a hash literal rather than a block (used
        # inside method-call arg lists and after binary operators).
        no_block => 0,
    }
}

# Lookahead helpers.
fn Rb::p_peek($p) {
    $p->{tokens}->[$p->{pos}]
}
fn Rb::p_peek_at($p, $offset) {
    $p->{tokens}->[$p->{pos} + $offset]
}
fn Rb::p_advance($p) {
    my $t = $p->{tokens}->[$p->{pos}]
    $p->{pos}++
    $t
}
fn Rb::p_check_kind($p, $kind) {
    Rb::p_peek($p)->{kind} eq $kind
}
fn Rb::p_check_op($p, $op) {
    my $t = Rb::p_peek($p)
    $t->{kind} eq "OP" && $t->{val} eq $op
}
fn Rb::p_check_kw($p, $word) {
    my $t = Rb::p_peek($p)
    $t->{kind} eq "KW" && $t->{val} eq $word
}
fn Rb::p_check_punct($p, $kind) {
    Rb::p_peek($p)->{kind} eq $kind
}
fn Rb::p_eat_kind($p, $kind) {
    if (Rb::p_check_kind($p, $kind)) { Rb::p_advance($p); return 1 }
    0
}
fn Rb::p_eat_op($p, $op) {
    if (Rb::p_check_op($p, $op)) { Rb::p_advance($p); return 1 }
    0
}
fn Rb::p_eat_kw($p, $word) {
    if (Rb::p_check_kw($p, $word)) { Rb::p_advance($p); return 1 }
    0
}
fn Rb::p_skip_newlines($p) {
    while (Rb::p_check_kind($p, "NEWLINE") || Rb::p_check_punct($p, "SEMI")) {
        Rb::p_advance($p)
    }
}
fn Rb::p_skip_terminators($p) {
    # Like skip_newlines but stops at the first non-terminator.
    Rb::p_skip_newlines($p)
}
fn Rb::p_expect_kw($p, $word) {
    unless (Rb::p_eat_kw($p, $word)) {
        my $t = Rb::p_peek($p)
        die "Rb::parse: expected `" . $word . "`, got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}
fn Rb::p_expect_kind($p, $kind) {
    unless (Rb::p_eat_kind($p, $kind)) {
        my $t = Rb::p_peek($p)
        die "Rb::parse: expected " . $kind . ", got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}
fn Rb::p_expect_op($p, $op) {
    unless (Rb::p_eat_op($p, $op)) {
        my $t = Rb::p_peek($p)
        die "Rb::parse: expected `" . $op . "`, got " . $t->{kind} . " `" . $t->{val} . "` at line " . $t->{line}
    }
}

# Top-level entry. Returns an arrayref of statements (a Program).
fn Rb::parse($src) {
    my $tokens = Rb::tokenize($src)
    my $p = Rb::parser_new($tokens)
    my @stmts
    Rb::p_skip_newlines($p)
    while (!Rb::p_check_kind($p, "EOF")) {
        my $stmt = Rb::parse_stmt($p)
        push @stmts, $stmt
        Rb::p_skip_newlines($p)
    }
    \@stmts
}

# ── PRECEDENCE ────────────────────────────────────────────────────────────
#
# Ruby's precedence table, low → high (a subset):
#
#   not                           — word logical-not
#   or, and                       — word logical
#   ?:                            — ternary
#   ||, &&                        — symbolic logical
#   ..  ...                       — range
#   ==, !=, ===, =~, !~, <=>      — equality
#   <, <=, >, >=                  — comparison
#   |, ^                          — bitwise or/xor
#   &                             — bitwise and
#   <<, >>                        — shift
#   +, -                          — additive
#   *, /, %                       — multiplicative
#   **                            — exponent (right-associative)
#   unary -, !, ~                  — unary
#   .  ::                         — method call / scope
#
# `parse_stmt` enters the chain and may attach modifier `if`/`unless`/etc.

fn Rb::parse_stmt($p) {
    my $expr = Rb::parse_expr($p)
    # Modifier postfix: `EXPR if COND`, `EXPR unless COND`, `EXPR while COND`,
    # `EXPR until COND`. These bind looser than assignment, looser than
    # everything except statement boundaries.
    if (Rb::p_check_kw($p, "if")) {
        Rb::p_advance($p)
        my $cond = Rb::parse_expr($p)
        return +{ kind => "If", cond => $cond, then => [$expr], elsifs => [], else => undef, line => $expr->{line} }
    }
    if (Rb::p_check_kw($p, "unless")) {
        Rb::p_advance($p)
        my $cond = Rb::parse_expr($p)
        return +{ kind => "Unless", cond => $cond, then => [$expr], else => undef, line => $expr->{line} }
    }
    if (Rb::p_check_kw($p, "while")) {
        Rb::p_advance($p)
        my $cond = Rb::parse_expr($p)
        return +{ kind => "While", cond => $cond, body => [$expr], do_form => 0, line => $expr->{line} }
    }
    if (Rb::p_check_kw($p, "until")) {
        Rb::p_advance($p)
        my $cond = Rb::parse_expr($p)
        return +{ kind => "Until", cond => $cond, body => [$expr], do_form => 0, line => $expr->{line} }
    }
    $expr
}

fn Rb::parse_expr($p) {
    Rb::parse_assign($p)
}

# Assignment is right-associative — `a = b = c` parses as `a = (b = c)`.
fn Rb::parse_assign($p) {
    my $lhs = Rb::parse_ternary($p)
    if (Rb::p_check_op($p, "=")) {
        Rb::p_advance($p)
        my $rhs = Rb::parse_assign($p)
        return +{ kind => "Assign", target => $lhs, value => $rhs, line => $lhs->{line} }
    }
    # Compound assigns: `+=`, `-=`, etc.
    for my $op ("+=", "-=", "*=", "/=", "%=", "**=", "<<=", ">>=", "&=", "|=", "^=", "&&=", "||=") {
        if (Rb::p_check_op($p, $op)) {
            Rb::p_advance($p)
            my $rhs = Rb::parse_assign($p)
            my $bare = substr($op, 0, length($op) - 1)
            return +{ kind => "OpAssign", target => $lhs, op => $bare, value => $rhs, line => $lhs->{line} }
        }
    }
    $lhs
}

fn Rb::parse_ternary($p) {
    my $cond = Rb::parse_or($p)
    if (Rb::p_check_op($p, "?")) {
        Rb::p_advance($p)
        my $then = Rb::parse_or($p)
        Rb::p_expect_op($p, ":")
        my $else = Rb::parse_or($p)
        return +{ kind => "Ternary", cond => $cond, then => $then, else => $else, line => $cond->{line} }
    }
    $cond
}

fn Rb::parse_or($p) {
    my $left = Rb::parse_and($p)
    while (Rb::p_check_op($p, "||") || Rb::p_check_kw($p, "or")) {
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $right = Rb::parse_and($p)
        $left = +{ kind => "Or", left => $left, right => $right, line => $line }
    }
    $left
}

fn Rb::parse_and($p) {
    my $left = Rb::parse_not($p)
    while (Rb::p_check_op($p, "&&") || Rb::p_check_kw($p, "and")) {
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $right = Rb::parse_not($p)
        $left = +{ kind => "And", left => $left, right => $right, line => $line }
    }
    $left
}

fn Rb::parse_not($p) {
    if (Rb::p_check_kw($p, "not") || Rb::p_check_op($p, "!")) {
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $operand = Rb::parse_not($p)
        return +{ kind => "Not", operand => $operand, line => $line }
    }
    Rb::parse_range($p)
}

fn Rb::parse_range($p) {
    my $left = Rb::parse_eq($p)
    if (Rb::p_check_op($p, "..") || Rb::p_check_op($p, "...")) {
        my $exclusive = Rb::p_peek($p)->{val} eq "..."
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $right = Rb::parse_eq($p)
        return +{ kind => "Range", lo => $left, hi => $right, exclusive => $exclusive, line => $line }
    }
    $left
}

fn Rb::parse_eq($p) {
    my $left = Rb::parse_cmp($p)
    while (Rb::p_check_op($p, "==") || Rb::p_check_op($p, "!=")
           || Rb::p_check_op($p, "<=>") || Rb::p_check_op($p, "===")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_cmp($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_cmp($p) {
    my $left = Rb::parse_bitor($p)
    while (Rb::p_check_op($p, "<") || Rb::p_check_op($p, ">")
           || Rb::p_check_op($p, "<=") || Rb::p_check_op($p, ">=")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_bitor($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_bitor($p) {
    my $left = Rb::parse_bitand($p)
    while (Rb::p_check_op($p, "|") || Rb::p_check_op($p, "^")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_bitand($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_bitand($p) {
    my $left = Rb::parse_shift($p)
    while (Rb::p_check_op($p, "&")) {
        Rb::p_advance($p)
        my $right = Rb::parse_shift($p)
        $left = +{ kind => "BinOp", op => "&", left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_shift($p) {
    my $left = Rb::parse_add($p)
    while (Rb::p_check_op($p, "<<") || Rb::p_check_op($p, ">>")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_add($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_add($p) {
    my $left = Rb::parse_mul($p)
    while (Rb::p_check_op($p, "+") || Rb::p_check_op($p, "-")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_mul($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_mul($p) {
    my $left = Rb::parse_pow($p)
    while (Rb::p_check_op($p, "*") || Rb::p_check_op($p, "/") || Rb::p_check_op($p, "%")) {
        my $op = Rb::p_advance($p)->{val}
        my $right = Rb::parse_pow($p)
        $left = +{ kind => "BinOp", op => $op, left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_pow($p) {
    my $left = Rb::parse_unary($p)
    if (Rb::p_check_op($p, "**")) {
        Rb::p_advance($p)
        # Right-associative: pow recurses.
        my $right = Rb::parse_pow($p)
        return +{ kind => "BinOp", op => "**", left => $left, right => $right, line => $left->{line} }
    }
    $left
}

fn Rb::parse_unary($p) {
    if (Rb::p_check_op($p, "-")) {
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $operand = Rb::parse_unary($p)
        return +{ kind => "UnaryOp", op => "-", operand => $operand, line => $line }
    }
    if (Rb::p_check_op($p, "+")) {
        Rb::p_advance($p)
        return Rb::parse_unary($p)
    }
    if (Rb::p_check_op($p, "~")) {
        my $line = Rb::p_peek($p)->{line}
        Rb::p_advance($p)
        my $operand = Rb::parse_unary($p)
        return +{ kind => "UnaryOp", op => "~", operand => $operand, line => $line }
    }
    Rb::parse_postfix($p)
}

# Postfix chain: a primary followed by zero or more `.method(args)` /
# `[index]` / `::Const`. Method calls without parens use the implicit-arg
# rule (only single-arg, terminated at first newline / operator).
fn Rb::parse_postfix($p) {
    my $expr = Rb::parse_primary($p)
    while (1) {
        if (Rb::p_check_op($p, ".")) {
            Rb::p_advance($p)
            my $t = Rb::p_advance($p)
            unless ($t->{kind} eq "IDENT" || $t->{kind} eq "KW") {
                die "Rb::parse: expected method name after `.`, got " . $t->{kind} . " at line " . $t->{line}
            }
            my $name = $t->{val}
            my @args
            my $block = undef
            # Parenthesized args
            if (Rb::p_check_kind($p, "LPAREN")) {
                Rb::p_advance($p)
                Rb::p_skip_newlines($p)
                while (!Rb::p_check_kind($p, "RPAREN")) {
                    push @args, Rb::parse_expr($p)
                    if (!Rb::p_eat_punct_comma($p)) { last }
                    Rb::p_skip_newlines($p)
                }
                Rb::p_expect_kind($p, "RPAREN")
            }
            # Trailing block: `.each { |x| ... }` or `.each do |x| ... end`.
            $block = Rb::try_parse_block($p)
            $expr = +{
                kind     => "Call",
                receiver => $expr,
                name     => $name,
                args     => \@args,
                block    => $block,
                line     => $expr->{line},
            }
            next
        }
        if (Rb::p_check_kind($p, "LBRACKET")) {
            Rb::p_advance($p)
            my @idx
            while (!Rb::p_check_kind($p, "RBRACKET")) {
                push @idx, Rb::parse_expr($p)
                if (!Rb::p_eat_punct_comma($p)) { last }
            }
            Rb::p_expect_kind($p, "RBRACKET")
            # `a[i] = v`: rewrite as IndexAssign by peeking next token.
            if (Rb::p_check_op($p, "=")) {
                Rb::p_advance($p)
                my $val = Rb::parse_assign($p)
                $expr = +{
                    kind     => "IndexAssign",
                    receiver => $expr,
                    indices  => \@idx,
                    value    => $val,
                    line     => $expr->{line},
                }
            } else {
                $expr = +{
                    kind     => "Index",
                    receiver => $expr,
                    indices  => \@idx,
                    line     => $expr->{line},
                }
            }
            next
        }
        last
    }
    $expr
}

fn Rb::p_eat_punct_comma($p) {
    Rb::p_eat_kind($p, "COMMA")
}

# Block parser: `{ |args| ... }` or `do |args| ... end`.
# Returns a Block AST node, or undef if no block follows.
fn Rb::try_parse_block($p) {
    if (Rb::p_check_kind($p, "LBRACE") && !$p->{no_block}) {
        return Rb::parse_brace_block($p)
    }
    if (Rb::p_check_kw($p, "do")) {
        return Rb::parse_do_block($p)
    }
    undef
}

fn Rb::parse_brace_block($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # {
    my $params = Rb::parse_block_params($p)
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kind($p, "RBRACE")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kind($p, "RBRACE")
    +{ kind => "Block", params => $params, body => \@body, line => $line }
}

fn Rb::parse_do_block($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # do
    my $params = Rb::parse_block_params($p)
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Block", params => $params, body => \@body, line => $line }
}

fn Rb::parse_block_params($p) {
    Rb::p_skip_newlines($p)
    return [] unless Rb::p_check_op($p, "|")
    Rb::p_advance($p)
    my @params
    while (!Rb::p_check_op($p, "|")) {
        my $t = Rb::p_advance($p)
        unless ($t->{kind} eq "IDENT") {
            die "Rb::parse: expected block param, got " . $t->{kind} . " at line " . $t->{line}
        }
        push @params, $t->{val}
        last unless Rb::p_eat_punct_comma($p)
    }
    Rb::p_expect_op($p, "|")
    \@params
}

# Primary expression: atoms, parens, arrays/hashes/blocks, control flow.
fn Rb::parse_primary($p) {
    my $t = Rb::p_peek($p)
    my $line = $t->{line}

    if ($t->{kind} eq "INT")   { Rb::p_advance($p); return +{ kind => "Int",   val => $t->{val}, line => $line } }
    if ($t->{kind} eq "FLOAT") { Rb::p_advance($p); return +{ kind => "Float", val => $t->{val}, line => $line } }
    if ($t->{kind} eq "STR")   { Rb::p_advance($p); return +{ kind => "Str",   val => $t->{val}, line => $line } }
    if ($t->{kind} eq "SYM")   { Rb::p_advance($p); return +{ kind => "Sym",   val => $t->{val}, line => $line } }
    if ($t->{kind} eq "STR_INTERP") {
        Rb::p_advance($p)
        # Re-tokenize each "expr" chunk to a sub-AST.
        my @parts
        for my $part (@{$t->{val}}) {
            if ($part->[0] eq "lit") {
                push @parts, +{ kind => "Str", val => $part->[1], line => $line }
            } else {
                # Re-tokenize and parse the expr text.
                my $sub_tokens = Rb::tokenize($part->[1])
                my $sub_p = Rb::parser_new($sub_tokens)
                Rb::p_skip_newlines($sub_p)
                my $expr = Rb::parse_expr($sub_p)
                push @parts, $expr
            }
        }
        return +{ kind => "StrInterp", parts => \@parts, line => $line }
    }
    if ($t->{kind} eq "WORD_ARRAY") {
        Rb::p_advance($p)
        my @elems = map { +{ kind => "Str", val => $_, line => $line } } @{$t->{val}}
        return +{ kind => "Array", elements => \@elems, line => $line }
    }
    if ($t->{kind} eq "SYM_ARRAY") {
        Rb::p_advance($p)
        my @elems = map { +{ kind => "Sym", val => $_, line => $line } } @{$t->{val}}
        return +{ kind => "Array", elements => \@elems, line => $line }
    }
    if ($t->{kind} eq "IVAR")  { Rb::p_advance($p); return +{ kind => "IVar", name => $t->{val}, line => $line } }
    if ($t->{kind} eq "CVAR")  { Rb::p_advance($p); return +{ kind => "CVar", name => $t->{val}, line => $line } }
    if ($t->{kind} eq "GVAR")  { Rb::p_advance($p); return +{ kind => "GVar", name => $t->{val}, line => $line } }
    if ($t->{kind} eq "CONST") { Rb::p_advance($p); return +{ kind => "Const", name => $t->{val}, line => $line } }
    if ($t->{kind} eq "LPAREN") {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my $e = Rb::parse_expr($p)
        Rb::p_skip_newlines($p)
        Rb::p_expect_kind($p, "RPAREN")
        return $e
    }
    if ($t->{kind} eq "LBRACKET") {
        return Rb::parse_array_literal($p)
    }
    if ($t->{kind} eq "LBRACE") {
        # In primary position (i.e. start of expression), `{` is ALWAYS a
        # hash literal — block-vs-hash disambiguation only matters AFTER a
        # method-call expression (handled in parse_postfix).
        return Rb::parse_hash_literal($p)
    }
    if ($t->{kind} eq "KW") {
        my $w = $t->{val}
        if ($w eq "nil")    { Rb::p_advance($p); return +{ kind => "Nil",   line => $line } }
        if ($w eq "true")   { Rb::p_advance($p); return +{ kind => "True",  line => $line } }
        if ($w eq "false")  { Rb::p_advance($p); return +{ kind => "False", line => $line } }
        if ($w eq "self")   { Rb::p_advance($p); return +{ kind => "Self",  line => $line } }
        if ($w eq "if")     { return Rb::parse_if($p) }
        if ($w eq "unless") { return Rb::parse_unless($p) }
        if ($w eq "while")  { return Rb::parse_while($p, 0) }
        if ($w eq "until")  { return Rb::parse_until($p, 0) }
        if ($w eq "case")   { return Rb::parse_case($p) }
        if ($w eq "for")    { return Rb::parse_for($p) }
        if ($w eq "begin")  { return Rb::parse_begin($p) }
        if ($w eq "def")    { return Rb::parse_def($p) }
        if ($w eq "class")  { return Rb::parse_class($p) }
        if ($w eq "module") { return Rb::parse_module($p) }
        if ($w eq "return") { return Rb::parse_return($p) }
        if ($w eq "yield")  { return Rb::parse_yield($p) }
        if ($w eq "break")  { Rb::p_advance($p); return +{ kind => "Break", value => undef, line => $line } }
        if ($w eq "next")   { Rb::p_advance($p); return +{ kind => "Next",  value => undef, line => $line } }
        if ($w eq "raise")  { return Rb::parse_raise($p) }
        if ($w eq "lambda" || $w eq "proc") { return Rb::parse_proc_call($p, $w) }
        # Built-in print-family — parse as call with implicit-paren args.
        if ($w eq "puts" || $w eq "print" || $w eq "p" || $w eq "pp") {
            return Rb::parse_implicit_call($p, $w)
        }
    }
    if ($t->{kind} eq "IDENT") {
        return Rb::parse_ident_or_call($p)
    }

    die "Rb::parse: unexpected token " . $t->{kind} . " `" . $t->{val} . "` at line " . $line
}

# `[1, 2, 3]` array literal.
fn Rb::parse_array_literal($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # [
    Rb::p_skip_newlines($p)
    my @elems
    while (!Rb::p_check_kind($p, "RBRACKET")) {
        push @elems, Rb::parse_expr($p)
        if (!Rb::p_eat_punct_comma($p)) { last }
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kind($p, "RBRACKET")
    +{ kind => "Array", elements => \@elems, line => $line }
}

# `{ k => v, sym: v, "str" => v }` hash literal.
fn Rb::parse_hash_literal($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # {
    Rb::p_skip_newlines($p)
    my @pairs
    while (!Rb::p_check_kind($p, "RBRACE")) {
        my $key
        # Symbol-key shorthand: `name: value` (no quotes around name).
        if (Rb::p_check_kind($p, "IDENT") && Rb::p_peek_at($p, 1)->{kind} eq "OP"
            && Rb::p_peek_at($p, 1)->{val} eq ":"
            && Rb::p_peek_at($p, 2)->{kind} ne "OP") {
            my $t = Rb::p_advance($p)
            Rb::p_advance($p)   # :
            $key = +{ kind => "Sym", val => $t->{val}, line => $line }
        } else {
            $key = Rb::parse_expr($p)
            # Either `key => val` (fat arrow) or `name: val` (sym shorthand
            # already eaten above — this branch is the explicit `=>` form).
            if (Rb::p_check_op($p, "=>")) {
                Rb::p_advance($p)
            } else {
                # Could be `name:` after a non-IDENT. Accept the colon form.
                Rb::p_expect_op($p, "=>")
            }
        }
        my $val = Rb::parse_expr($p)
        push @pairs, [$key, $val]
        if (!Rb::p_eat_punct_comma($p)) { last }
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kind($p, "RBRACE")
    +{ kind => "Hash", pairs => \@pairs, line => $line }
}

# Parse an Ident — could be a variable read, a no-arg method call, or a
# method call with parenthesized args. Implicit args (e.g. `puts "hi"` with
# no parens) are handled separately by callers like `parse_primary`.
fn Rb::parse_ident_or_call($p) {
    my $t = Rb::p_advance($p)
    my $name = $t->{val}
    my $line = $t->{line}
    # Setter form: `foo=` only valid as a method-name in def — here we treat
    # it as `Ident name + assign` which the parser's assign path already
    # handles via the LBRACKET / equals branch.
    if (Rb::p_check_kind($p, "LPAREN")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my @args
        while (!Rb::p_check_kind($p, "RPAREN")) {
            push @args, Rb::parse_expr($p)
            if (!Rb::p_eat_punct_comma($p)) { last }
            Rb::p_skip_newlines($p)
        }
        Rb::p_expect_kind($p, "RPAREN")
        my $block = Rb::try_parse_block($p)
        return +{
            kind     => "Call",
            receiver => undef,
            name     => $name,
            args     => \@args,
            block    => $block,
            line     => $line,
        }
    }
    # Bare identifier — treated as variable reference. The evaluator decides
    # whether it's a local var, no-arg method, or undefined.
    +{ kind => "Ident", name => $name, line => $line }
}

# `puts "hello", x` — implicit-paren call (one or more args until newline /
# operator). Used for puts/print/p/pp and similar bare-keyword commands.
fn Rb::parse_implicit_call($p, $name) {
    my $line = Rb::p_advance($p)->{line}
    my @args
    # If next is a clear terminator, no args.
    return +{ kind => "Call", receiver => undef, name => $name, args => \@args, block => undef, line => $line }
        if Rb::p_check_kind($p, "NEWLINE")
        || Rb::p_check_kind($p, "EOF")
        || Rb::p_check_punct($p, "SEMI")
    while (1) {
        push @args, Rb::parse_expr($p)
        last unless Rb::p_eat_punct_comma($p)
    }
    +{ kind => "Call", receiver => undef, name => $name, args => \@args, block => undef, line => $line }
}

fn Rb::parse_if($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # if
    my $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "then")
    Rb::p_skip_newlines($p)
    my @then
    my @elsifs
    my $else_body = undef
    while (!Rb::p_check_kw($p, "end") && !Rb::p_check_kw($p, "elsif") && !Rb::p_check_kw($p, "else")) {
        push @then, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    while (Rb::p_check_kw($p, "elsif")) {
        Rb::p_advance($p)
        my $ec = Rb::parse_expr($p)
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_newlines($p)
        my @eb
        while (!Rb::p_check_kw($p, "end") && !Rb::p_check_kw($p, "elsif") && !Rb::p_check_kw($p, "else")) {
            push @eb, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        push @elsifs, [$ec, \@eb]
    }
    if (Rb::p_check_kw($p, "else")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my @e
        while (!Rb::p_check_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "If", cond => $cond, then => \@then, elsifs => \@elsifs, else => $else_body, line => $line }
}

fn Rb::parse_unless($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "then")
    Rb::p_skip_newlines($p)
    my @body
    my $else_body = undef
    while (!Rb::p_check_kw($p, "end") && !Rb::p_check_kw($p, "else")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    if (Rb::p_check_kw($p, "else")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my @e
        while (!Rb::p_check_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Unless", cond => $cond, then => \@body, else => $else_body, line => $line }
}

fn Rb::parse_while($p, $do_form) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "While", cond => $cond, body => \@body, do_form => $do_form, line => $line }
}

fn Rb::parse_until($p, $do_form) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my $cond = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Until", cond => $cond, body => \@body, do_form => $do_form, line => $line }
}

fn Rb::parse_case($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my $subject = undef
    unless (Rb::p_check_kw($p, "when") || Rb::p_check_kind($p, "NEWLINE")) {
        $subject = Rb::parse_expr($p)
    }
    Rb::p_skip_newlines($p)
    my @whens
    while (Rb::p_check_kw($p, "when")) {
        Rb::p_advance($p)
        my @pats
        push @pats, Rb::parse_expr($p)
        while (Rb::p_eat_punct_comma($p)) {
            push @pats, Rb::parse_expr($p)
        }
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_newlines($p)
        my @body
        while (!Rb::p_check_kw($p, "when") && !Rb::p_check_kw($p, "else") && !Rb::p_check_kw($p, "end")) {
            push @body, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        push @whens, [\@pats, \@body]
    }
    my $else_body = undef
    if (Rb::p_check_kw($p, "else")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my @e
        while (!Rb::p_check_kw($p, "end")) {
            push @e, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        $else_body = \@e
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Case", subject => $subject, whens => \@whens, else => $else_body, line => $line }
}

fn Rb::parse_for($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # for
    my $var_t = Rb::p_advance($p)
    unless ($var_t->{kind} eq "IDENT") {
        die "Rb::parse: expected variable name after `for`, got " . $var_t->{kind} . " at line " . $line
    }
    Rb::p_expect_kw($p, "in")
    my $iter = Rb::parse_expr($p)
    Rb::p_eat_kw($p, "do")
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "For", var => $var_t->{val}, iter => $iter, body => \@body, line => $line }
}

fn Rb::parse_begin($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # begin
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "rescue") && !Rb::p_check_kw($p, "else")
           && !Rb::p_check_kw($p, "ensure") && !Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    my @rescues
    while (Rb::p_check_kw($p, "rescue")) {
        Rb::p_advance($p)
        my $klass = undef
        my $var = undef
        if (Rb::p_check_kind($p, "CONST")) {
            $klass = Rb::p_advance($p)->{val}
        }
        if (Rb::p_check_op($p, "=>")) {
            Rb::p_advance($p)
            my $vt = Rb::p_advance($p)
            $var = $vt->{val}
        }
        Rb::p_eat_kw($p, "then")
        Rb::p_skip_newlines($p)
        my @rb
        while (!Rb::p_check_kw($p, "rescue") && !Rb::p_check_kw($p, "else")
               && !Rb::p_check_kw($p, "ensure") && !Rb::p_check_kw($p, "end")) {
            push @rb, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        push @rescues, +{ klass => $klass, var => $var, body => \@rb }
    }
    my $ensure = undef
    if (Rb::p_check_kw($p, "ensure")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        my @eb
        while (!Rb::p_check_kw($p, "end")) {
            push @eb, Rb::parse_stmt($p)
            Rb::p_skip_newlines($p)
        }
        $ensure = \@eb
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Begin", body => \@body, rescues => \@rescues, ensure => $ensure, line => $line }
}

fn Rb::parse_def($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # def
    # `def self.name` is a class method; `def name` is an instance method.
    my $is_self = 0
    if (Rb::p_check_kw($p, "self")) {
        Rb::p_advance($p)
        Rb::p_expect_op($p, ".")
        $is_self = 1
    }
    my $name_t = Rb::p_advance($p)
    my $name = $name_t->{val}
    my @params
    my $rest = undef
    if (Rb::p_check_kind($p, "LPAREN")) {
        Rb::p_advance($p)
        Rb::p_skip_newlines($p)
        ($rest) = Rb::parse_method_params($p, \@params)
        Rb::p_expect_kind($p, "RPAREN")
    } elsif (Rb::p_check_kind($p, "IDENT")) {
        # Paren-less params (until newline).
        ($rest) = Rb::parse_method_params($p, \@params)
    }
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "Def", name => $name, params => \@params, rest => $rest, body => \@body, is_self => $is_self, line => $line }
}

# Reads param names into the given arrayref. Returns (rest_name).
# Accepts `name`, `*rest`, `name = default` (default not yet supported).
fn Rb::parse_method_params($p, $params_ref) {
    my $rest = undef
    while (!Rb::p_check_kind($p, "RPAREN") && !Rb::p_check_kind($p, "NEWLINE")
           && !Rb::p_check_punct($p, "SEMI")) {
        if (Rb::p_check_op($p, "*")) {
            Rb::p_advance($p)
            my $t = Rb::p_advance($p)
            $rest = $t->{val}
        } else {
            my $t = Rb::p_advance($p)
            push @$params_ref, $t->{val}
        }
        last unless Rb::p_eat_punct_comma($p)
        Rb::p_skip_newlines($p)
    }
    ($rest)
}

fn Rb::parse_class($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # class
    my $name = Rb::p_advance($p)->{val}
    my $parent = undef
    if (Rb::p_check_op($p, "<")) {
        Rb::p_advance($p)
        $parent = Rb::p_advance($p)->{val}
    }
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "ClassDecl", name => $name, parent => $parent, body => \@body, line => $line }
}

fn Rb::parse_module($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # module
    my $name = Rb::p_advance($p)->{val}
    Rb::p_skip_newlines($p)
    my @body
    while (!Rb::p_check_kw($p, "end")) {
        push @body, Rb::parse_stmt($p)
        Rb::p_skip_newlines($p)
    }
    Rb::p_expect_kw($p, "end")
    +{ kind => "ModuleDecl", name => $name, body => \@body, line => $line }
}

fn Rb::parse_return($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my $val = undef
    unless (Rb::p_check_kind($p, "NEWLINE") || Rb::p_check_kind($p, "EOF")
            || Rb::p_check_punct($p, "SEMI")) {
        $val = Rb::parse_expr($p)
    }
    +{ kind => "Return", value => $val, line => $line }
}

fn Rb::parse_yield($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my @args
    if (Rb::p_check_kind($p, "LPAREN")) {
        Rb::p_advance($p)
        while (!Rb::p_check_kind($p, "RPAREN")) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_punct_comma($p)
        }
        Rb::p_expect_kind($p, "RPAREN")
    } elsif (!Rb::p_check_kind($p, "NEWLINE") && !Rb::p_check_kind($p, "EOF")
             && !Rb::p_check_punct($p, "SEMI")) {
        # Implicit-paren yield args.
        while (1) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_punct_comma($p)
        }
    }
    +{ kind => "Yield", args => \@args, line => $line }
}

fn Rb::parse_raise($p) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)
    my @args
    unless (Rb::p_check_kind($p, "NEWLINE") || Rb::p_check_kind($p, "EOF")
            || Rb::p_check_punct($p, "SEMI")) {
        while (1) {
            push @args, Rb::parse_expr($p)
            last unless Rb::p_eat_punct_comma($p)
        }
    }
    +{ kind => "Call", receiver => undef, name => "raise", args => \@args, block => undef, line => $line }
}

fn Rb::parse_proc_call($p, $word) {
    my $line = Rb::p_peek($p)->{line}
    Rb::p_advance($p)   # lambda / proc
    my $block = Rb::try_parse_block($p)
    unless (defined $block) {
        die "Rb::parse: `" . $word . "` requires a block at line " . $line
    }
    +{ kind => "Lambda", params => $block->{params}, body => $block->{body}, is_lambda => ($word eq "lambda" ? 1 : 0), line => $line }
}

# ── ENVIRONMENT ────────────────────────────────────────────────────────────
#
# An env is an arrayref of hashrefs (frames). Lookup walks innermost-first;
# assignment writes to the innermost frame containing the name (or creates a
# new binding in the innermost frame on first assignment, matching Ruby).

fn Rb::env_new() {
    [+{}]
}
fn Rb::env_push($env) {
    push @$env, +{}
    $env
}
fn Rb::env_pop($env) {
    pop @$env
    $env
}
fn Rb::env_lookup($env, $name) {
    for my $frame (reverse @$env) {
        return $frame->{$name} if exists $frame->{$name}
    }
    undef
}
fn Rb::env_has($env, $name) {
    for my $frame (@$env) {
        return 1 if exists $frame->{$name}
    }
    0
}
# Set in the innermost frame that already has it; else create in innermost.
fn Rb::env_set($env, $name, $val) {
    for my $frame (reverse @$env) {
        if (exists $frame->{$name}) {
            $frame->{$name} = $val
            return $val
        }
    }
    $env->[-1]{$name} = $val
    $val
}
# Always create in innermost frame (block parameters, method params).
fn Rb::env_define($env, $name, $val) {
    $env->[-1]{$name} = $val
    $val
}

# Per-execution context — the running interpreter state.
fn Rb::ctx_new() {
    +{
        globals => +{},          # $globals
        const   => +{},          # top-level constants (incl. classes)
        env     => Rb::env_new(),
        self    => Rb::v_nil(),
        block   => undef,        # current method's &block, if any
        cur_klass => undef,      # innermost open class (for `def`)
    }
}

# Flow-control sentinels — thrown via `die +{ flow => ... }` and caught by
# the appropriate construct. Cleaner than threading a result type through
# every recursive eval call.
our %FLOW_RETURN = ( type => "return" )
our %FLOW_BREAK  = ( type => "break" )
our %FLOW_NEXT   = ( type => "next" )

# ── EVALUATOR ──────────────────────────────────────────────────────────────

fn Rb::eval_program($stmts, $ctx) {
    my $result = Rb::v_nil()
    for my $stmt (@$stmts) {
        $result = Rb::eval_node($stmt, $ctx)
    }
    $result
}

fn Rb::eval_block_stmts($stmts, $ctx) {
    my $result = Rb::v_nil()
    for my $stmt (@$stmts) {
        $result = Rb::eval_node($stmt, $ctx)
    }
    $result
}

fn Rb::eval_node($n, $ctx) {
    my $k = $n->{kind}

    return Rb::v_int($n->{val})    if $k eq "Int"
    return Rb::v_float($n->{val})  if $k eq "Float"
    return Rb::v_str($n->{val})    if $k eq "Str"
    return Rb::v_sym($n->{val})    if $k eq "Sym"
    return Rb::v_nil()             if $k eq "Nil"
    return Rb::v_bool(1)           if $k eq "True"
    return Rb::v_bool(0)           if $k eq "False"

    if ($k eq "StrInterp") {
        my $out = ""
        for my $part (@{$n->{parts}}) {
            my $v = Rb::eval_node($part, $ctx)
            $out .= Rb::to_s($v)
        }
        return Rb::v_str($out)
    }

    if ($k eq "Array") {
        my @items
        for my $e (@{$n->{elements}}) {
            push @items, Rb::eval_node($e, $ctx)
        }
        return Rb::v_array(\@items)
    }

    if ($k eq "Hash") {
        my @pairs
        for my $pair (@{$n->{pairs}}) {
            my $k_val = Rb::eval_node($pair->[0], $ctx)
            my $v_val = Rb::eval_node($pair->[1], $ctx)
            push @pairs, [$k_val, $v_val]
        }
        return Rb::v_hash(\@pairs)
    }

    if ($k eq "Range") {
        my $lo = Rb::eval_node($n->{lo}, $ctx)
        my $hi = Rb::eval_node($n->{hi}, $ctx)
        return Rb::v_range($lo, $hi, $n->{exclusive})
    }

    if ($k eq "Self") {
        return $ctx->{self}
    }

    if ($k eq "Ident") {
        # Local var? Yes → return its value.
        # Otherwise → no-arg method call (with implicit `self` receiver).
        my $name = $n->{name}
        if (Rb::env_has($ctx->{env}, $name)) {
            return Rb::env_lookup($ctx->{env}, $name)
        }
        # No-arg method call — dispatch on `self`. If not found and self is
        # nil, fall through to checking globals or treating as nil-read
        # (Ruby would `NameError` here; we surface a runtime error).
        return Rb::dispatch($ctx->{self}, $name, [], undef, $ctx, 1)
    }

    if ($k eq "Const") {
        my $name = $n->{name}
        return $ctx->{const}{$name} if exists $ctx->{const}{$name}
        return $CLASSES{$name}      if exists $CLASSES{$name}
        return $MODULES{$name}      if exists $MODULES{$name}
        die "Rb::eval: uninitialized constant " . $name
    }

    if ($k eq "IVar") {
        my $self = $ctx->{self}
        if (Rb::is_instance($self) && exists $self->{ivars}{$n->{name}}) {
            return $self->{ivars}{$n->{name}}
        }
        return Rb::v_nil()
    }

    if ($k eq "GVar") {
        return $ctx->{globals}{$n->{name}} // Rb::v_nil()
    }

    if ($k eq "Assign") {
        my $val = Rb::eval_node($n->{value}, $ctx)
        Rb::do_assign($n->{target}, $val, $ctx)
        return $val
    }

    if ($k eq "OpAssign") {
        # `x += y` → `x = x + y` (with short-circuit for ||= and &&=).
        if ($n->{op} eq "||") {
            my $cur = Rb::eval_lvalue_read($n->{target}, $ctx)
            return $cur if Rb::is_truthy($cur)
            my $val = Rb::eval_node($n->{value}, $ctx)
            Rb::do_assign($n->{target}, $val, $ctx)
            return $val
        }
        if ($n->{op} eq "&&") {
            my $cur = Rb::eval_lvalue_read($n->{target}, $ctx)
            return $cur unless Rb::is_truthy($cur)
            my $val = Rb::eval_node($n->{value}, $ctx)
            Rb::do_assign($n->{target}, $val, $ctx)
            return $val
        }
        my $cur = Rb::eval_lvalue_read($n->{target}, $ctx)
        my $rhs = Rb::eval_node($n->{value}, $ctx)
        my $new = Rb::apply_binop($n->{op}, $cur, $rhs)
        Rb::do_assign($n->{target}, $new, $ctx)
        return $new
    }

    if ($k eq "Index") {
        my $recv = Rb::eval_node($n->{receiver}, $ctx)
        my @indices = map { Rb::eval_node($_, $ctx) } @{$n->{indices}}
        return Rb::dispatch($recv, "[]", \@indices, undef, $ctx, 0)
    }

    if ($k eq "IndexAssign") {
        my $recv = Rb::eval_node($n->{receiver}, $ctx)
        my @indices = map { Rb::eval_node($_, $ctx) } @{$n->{indices}}
        my $val = Rb::eval_node($n->{value}, $ctx)
        my @args = @indices
        push @args, $val
        return Rb::dispatch($recv, "[]=", \@args, undef, $ctx, 0)
    }

    if ($k eq "BinOp") {
        my $left = Rb::eval_node($n->{left}, $ctx)
        my $right = Rb::eval_node($n->{right}, $ctx)
        return Rb::apply_binop($n->{op}, $left, $right)
    }

    if ($k eq "UnaryOp") {
        my $v = Rb::eval_node($n->{operand}, $ctx)
        if ($n->{op} eq "-") {
            return Rb::v_int(-$v->{val})    if Rb::is_int($v)
            return Rb::v_float(-$v->{val})  if Rb::is_float($v)
            die "no `-@` for " . $v->{type}
        }
        if ($n->{op} eq "~") {
            return Rb::v_int(~$v->{val}) if Rb::is_int($v)
            die "no `~` for " . $v->{type}
        }
        die "Rb::eval: unhandled unary op " . $n->{op}
    }

    if ($k eq "And") {
        my $l = Rb::eval_node($n->{left}, $ctx)
        return $l unless Rb::is_truthy($l)
        return Rb::eval_node($n->{right}, $ctx)
    }
    if ($k eq "Or") {
        my $l = Rb::eval_node($n->{left}, $ctx)
        return $l if Rb::is_truthy($l)
        return Rb::eval_node($n->{right}, $ctx)
    }
    if ($k eq "Not") {
        my $v = Rb::eval_node($n->{operand}, $ctx)
        return Rb::v_bool(Rb::is_truthy($v) ? 0 : 1)
    }

    if ($k eq "Ternary") {
        my $c = Rb::eval_node($n->{cond}, $ctx)
        return Rb::eval_node(Rb::is_truthy($c) ? $n->{then} : $n->{else}, $ctx)
    }

    if ($k eq "If") {
        my $c = Rb::eval_node($n->{cond}, $ctx)
        if (Rb::is_truthy($c)) {
            return Rb::eval_block_stmts($n->{then}, $ctx)
        }
        for my $eif (@{$n->{elsifs}}) {
            my $ec = Rb::eval_node($eif->[0], $ctx)
            if (Rb::is_truthy($ec)) {
                return Rb::eval_block_stmts($eif->[1], $ctx)
            }
        }
        return Rb::eval_block_stmts($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }

    if ($k eq "Unless") {
        my $c = Rb::eval_node($n->{cond}, $ctx)
        unless (Rb::is_truthy($c)) {
            return Rb::eval_block_stmts($n->{then}, $ctx)
        }
        return Rb::eval_block_stmts($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }

    if ($k eq "While") {
        my $result = Rb::v_nil()
        while (Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            my $r = eval { Rb::eval_block_stmts($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") {
                    $result = $@->{value} // Rb::v_nil()
                    last
                }
                if (ref($@) eq "HASH" && $@->{flow} eq "next") {
                    next
                }
                die $@
            }
            $result = $r
        }
        return $result
    }

    if ($k eq "Until") {
        my $result = Rb::v_nil()
        while (!Rb::is_truthy(Rb::eval_node($n->{cond}, $ctx))) {
            my $r = eval { Rb::eval_block_stmts($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") {
                    $result = $@->{value} // Rb::v_nil()
                    last
                }
                if (ref($@) eq "HASH" && $@->{flow} eq "next") {
                    next
                }
                die $@
            }
            $result = $r
        }
        return $result
    }

    if ($k eq "For") {
        # `for x in iter; body; end` — desugars to iter.each { |x| body }.
        my $iter = Rb::eval_node($n->{iter}, $ctx)
        my $items = Rb::iter_items($iter)
        my $result = Rb::v_nil()
        for my $item (@$items) {
            Rb::env_set($ctx->{env}, $n->{var}, $item)
            $result = eval { Rb::eval_block_stmts($n->{body}, $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") {
                    $result = $@->{value} // Rb::v_nil()
                    last
                }
                if (ref($@) eq "HASH" && $@->{flow} eq "next") {
                    $result = Rb::v_nil()
                    next
                }
                die $@
            }
        }
        return $result
    }

    if ($k eq "Case") {
        my $subj = defined $n->{subject} ? Rb::eval_node($n->{subject}, $ctx) : undef
        for my $when (@{$n->{whens}}) {
            for my $pat (@{$when->[0]}) {
                my $pv = Rb::eval_node($pat, $ctx)
                if (defined $subj) {
                    return Rb::eval_block_stmts($when->[1], $ctx) if Rb::case_match($pv, $subj)
                } else {
                    return Rb::eval_block_stmts($when->[1], $ctx) if Rb::is_truthy($pv)
                }
            }
        }
        return Rb::eval_block_stmts($n->{else}, $ctx) if defined $n->{else}
        return Rb::v_nil()
    }

    if ($k eq "Begin") {
        my $val = eval { Rb::eval_block_stmts($n->{body}, $ctx) }
        my $err = $@
        my $result = $val
        if ($err) {
            my $exc = ref($err) eq "HASH" && $err->{type} && $err->{type} eq "exception"
                      ? $err
                      : Rb::v_exception($CLASSES{RuntimeError}, "" . $err)
            my $handled = 0
            for my $r (@{$n->{rescues}}) {
                # Class filter — match if no class given, or exact name match,
                # or ancestor match.
                my $klass = $r->{klass}
                if (!defined($klass) || $klass eq "" || $klass eq "StandardError"
                    || $klass eq "Exception" || $klass eq "RuntimeError"
                    || $exc->{klass}{name} eq $klass) {
                    Rb::env_define($ctx->{env}, $r->{var}, $exc) if defined $r->{var}
                    $result = Rb::eval_block_stmts($r->{body}, $ctx)
                    $handled = 1
                    last
                }
            }
            unless ($handled) {
                # Run ensure, then re-raise.
                Rb::eval_block_stmts($n->{ensure}, $ctx) if defined $n->{ensure}
                die $err
            }
        }
        Rb::eval_block_stmts($n->{ensure}, $ctx) if defined $n->{ensure}
        return $result
    }

    if ($k eq "Return") {
        my $v = defined $n->{value} ? Rb::eval_node($n->{value}, $ctx) : Rb::v_nil()
        die +{ flow => "return", value => $v }
    }
    if ($k eq "Break") {
        my $v = defined $n->{value} ? Rb::eval_node($n->{value}, $ctx) : Rb::v_nil()
        die +{ flow => "break", value => $v }
    }
    if ($k eq "Next") {
        my $v = defined $n->{value} ? Rb::eval_node($n->{value}, $ctx) : Rb::v_nil()
        die +{ flow => "next", value => $v }
    }

    if ($k eq "Yield") {
        my $blk = $ctx->{block}
        die "Rb::eval: no block given (yield) at line " . $n->{line} unless defined $blk
        my @args = map { Rb::eval_node($_, $ctx) } @{$n->{args}}
        return Rb::call_block($blk, \@args, $ctx)
    }

    if ($k eq "Block" || $k eq "Lambda") {
        # Capture the current env (shallow — sharing frames so closure
        # mutations are visible to the outer scope).
        my @frames = @{$ctx->{env}}
        my $is_lam = ($k eq "Lambda") ? ($n->{is_lambda} // 1) : 0
        return Rb::v_proc($n->{params}, undef, $n->{body}, \@frames, "<block>", $is_lam)
    }

    if ($k eq "Def") {
        my $proc = Rb::v_proc($n->{params}, $n->{rest}, $n->{body}, [@{$ctx->{env}}], $n->{name}, 0)
        # If we're inside a class body, the def becomes a method on that
        # class; otherwise it's a top-level method (registered as a
        # method on Object).
        my $owner = $ctx->{cur_klass} // $CLASSES{Object}
        $owner->{methods}{$n->{name}} = $proc
        return Rb::v_sym($n->{name})
    }

    if ($k eq "ClassDecl") {
        my $name = $n->{name}
        my $klass
        if (exists $CLASSES{$name}) {
            $klass = $CLASSES{$name}        # reopen
        } else {
            my $parent = defined($n->{parent}) ? ($CLASSES{$n->{parent}} // die "no parent class " . $n->{parent}) : $CLASSES{Object}
            $klass = Rb::v_class($name, $parent)
            $CLASSES{$name} = $klass
            $ctx->{const}{$name} = $klass
        }
        my $saved = $ctx->{cur_klass}
        $ctx->{cur_klass} = $klass
        eval { Rb::eval_block_stmts($n->{body}, $ctx) }
        my $err = $@
        $ctx->{cur_klass} = $saved
        die $err if $err
        return $klass
    }

    if ($k eq "ModuleDecl") {
        my $name = $n->{name}
        my $mod
        if (exists $MODULES{$name}) {
            $mod = $MODULES{$name}
        } else {
            $mod = Rb::v_module($name)
            $MODULES{$name} = $mod
            $ctx->{const}{$name} = $mod
        }
        my $saved = $ctx->{cur_klass}
        $ctx->{cur_klass} = $mod
        eval { Rb::eval_block_stmts($n->{body}, $ctx) }
        my $err = $@
        $ctx->{cur_klass} = $saved
        die $err if $err
        return $mod
    }

    if ($k eq "Call") {
        return Rb::eval_call($n, $ctx)
    }

    die "Rb::eval: unhandled node kind " . $k
}

# Read the current value of an lvalue without writing.
fn Rb::eval_lvalue_read($target, $ctx) {
    if ($target->{kind} eq "Ident") {
        return Rb::env_lookup($ctx->{env}, $target->{name}) // Rb::v_nil()
    }
    Rb::eval_node($target, $ctx)
}

# Assign `val` to a target node (Ident, IVar, GVar, Const, or call-shaped).
fn Rb::do_assign($target, $val, $ctx) {
    if ($target->{kind} eq "Ident") {
        Rb::env_set($ctx->{env}, $target->{name}, $val)
        return $val
    }
    if ($target->{kind} eq "IVar") {
        my $self = $ctx->{self}
        if (Rb::is_instance($self)) {
            $self->{ivars}{$target->{name}} = $val
        }
        return $val
    }
    if ($target->{kind} eq "GVar") {
        $ctx->{globals}{$target->{name}} = $val
        return $val
    }
    if ($target->{kind} eq "Const") {
        $ctx->{const}{$target->{name}} = $val
        return $val
    }
    die "Rb::eval: cannot assign to " . $target->{kind} . " at line " . $target->{line}
}

# Apply a binary op to two values. Numeric ops promote int → float when
# the other side is float; string + string concatenates; <=> on numeric
# returns -1/0/1.
fn Rb::apply_binop($op, $l, $r) {
    if ($op eq "+") {
        return Rb::v_str($l->{val} . $r->{val}) if Rb::is_str($l) && Rb::is_str($r)
        return Rb::v_array([@{$l->{items}}, @{$r->{items}}]) if Rb::is_array($l) && Rb::is_array($r)
        return Rb::num_op("+", $l, $r) if Rb::is_num($l) && Rb::is_num($r)
        die "no `+` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq "-") {
        return Rb::num_op("-", $l, $r) if Rb::is_num($l) && Rb::is_num($r)
        if (Rb::is_array($l) && Rb::is_array($r)) {
            my @out
            for my $a (@{$l->{items}}) {
                my $found = 0
                for my $b (@{$r->{items}}) {
                    if (Rb::v_equal($a, $b)) { $found = 1; last }
                }
                push @out, $a unless $found
            }
            return Rb::v_array(\@out)
        }
        die "no `-` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq "*") {
        return Rb::v_str($l->{val} x $r->{val}) if Rb::is_str($l) && Rb::is_int($r)
        if (Rb::is_array($l) && Rb::is_int($r)) {
            my @items
            for (1 .. $r->{val}) { push @items, @{$l->{items}} }
            return Rb::v_array(\@items)
        }
        return Rb::num_op("*", $l, $r) if Rb::is_num($l) && Rb::is_num($r)
        die "no `*` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq "/") {
        return Rb::num_op("/", $l, $r) if Rb::is_num($l) && Rb::is_num($r)
        die "no `/` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq "%") {
        return Rb::num_op("%", $l, $r) if Rb::is_num($l) && Rb::is_num($r)
        die "no `%` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq "**") {
        if (Rb::is_int($l) && Rb::is_int($r) && $r->{val} >= 0) {
            my $acc = 1
            for (1 .. $r->{val}) { $acc *= $l->{val} }
            return Rb::v_int($acc)
        }
        return Rb::v_float($l->{val} ** $r->{val})
    }
    if ($op eq "<<") {
        return Rb::v_int($l->{val} << $r->{val}) if Rb::is_int($l) && Rb::is_int($r)
        if (Rb::is_array($l)) {
            push @{$l->{items}}, $r
            return $l
        }
        return Rb::v_str($l->{val} . $r->{val}) if Rb::is_str($l)
        die "no `<<` between " . $l->{type} . " and " . $r->{type}
    }
    if ($op eq ">>") {
        return Rb::v_int($l->{val} >> $r->{val}) if Rb::is_int($l) && Rb::is_int($r)
        die "no `>>`"
    }
    if ($op eq "&") {
        return Rb::v_int($l->{val} & $r->{val}) if Rb::is_int($l) && Rb::is_int($r)
        die "no `&`"
    }
    if ($op eq "|") {
        return Rb::v_int($l->{val} | $r->{val}) if Rb::is_int($l) && Rb::is_int($r)
        die "no `|`"
    }
    if ($op eq "^") {
        return Rb::v_int($l->{val} ^ $r->{val}) if Rb::is_int($l) && Rb::is_int($r)
        die "no `^`"
    }
    if ($op eq "==") { return Rb::v_bool(Rb::v_equal($l, $r) ? 1 : 0) }
    if ($op eq "!=") { return Rb::v_bool(Rb::v_equal($l, $r) ? 0 : 1) }
    if ($op eq "===") {
        # `===` is "case equality" — for classes, instance check; for ranges,
        # cover; for regex, match; otherwise == .
        if (Rb::is_class($l)) {
            return Rb::v_bool(Rb::class_is_a(Rb::object_class($r), $l) ? 1 : 0)
        }
        if (Rb::is_range($l)) {
            return Rb::v_bool(Rb::range_covers($l, $r) ? 1 : 0)
        }
        return Rb::v_bool(Rb::v_equal($l, $r) ? 1 : 0)
    }
    if ($op eq "<=>") {
        if (Rb::is_num($l) && Rb::is_num($r)) {
            my $a = Rb::num_val($l); my $b = Rb::num_val($r)
            return Rb::v_int($a < $b ? -1 : ($a > $b ? 1 : 0))
        }
        if (Rb::is_str($l) && Rb::is_str($r)) {
            return Rb::v_int($l->{val} lt $r->{val} ? -1 : ($l->{val} gt $r->{val} ? 1 : 0))
        }
        return Rb::v_nil()
    }
    if ($op eq "<")  { return Rb::v_bool(Rb::cmp_lt($l, $r)) }
    if ($op eq ">")  { return Rb::v_bool(Rb::cmp_lt($r, $l)) }
    if ($op eq "<=") { return Rb::v_bool(Rb::cmp_lt($l, $r) || Rb::v_equal($l, $r)) }
    if ($op eq ">=") { return Rb::v_bool(Rb::cmp_lt($r, $l) || Rb::v_equal($l, $r)) }

    die "Rb::eval: unhandled binop `" . $op . "`"
}

fn Rb::num_op($op, $l, $r) {
    my $a = Rb::num_val($l)
    my $b = Rb::num_val($r)
    my $float = Rb::is_float($l) || Rb::is_float($r)
    if ($op eq "+") { return $float ? Rb::v_float($a + $b) : Rb::v_int($a + $b) }
    if ($op eq "-") { return $float ? Rb::v_float($a - $b) : Rb::v_int($a - $b) }
    if ($op eq "*") { return $float ? Rb::v_float($a * $b) : Rb::v_int($a * $b) }
    if ($op eq "/") {
        if (!$float && $b != 0) {
            # Integer division — Ruby floors toward negative infinity.
            my $q = int($a / $b)
            $q-- if (($a % $b) != 0) && (($a < 0) != ($b < 0))
            return Rb::v_int($q)
        }
        return Rb::v_float($a / $b)
    }
    if ($op eq "%") {
        if (!$float) {
            my $m = $a % $b
            $m += $b if ($m != 0) && (($m < 0) != ($b < 0))
            return Rb::v_int($m)
        }
        return Rb::v_float($a - $b * int($a / $b))
    }
    die "num_op " . $op
}

fn Rb::cmp_lt($a, $b) {
    return Rb::num_val($a) < Rb::num_val($b) if Rb::is_num($a) && Rb::is_num($b)
    return $a->{val} lt $b->{val} if Rb::is_str($a) && Rb::is_str($b)
    return $a->{val} lt $b->{val} if Rb::is_sym($a) && Rb::is_sym($b)
    0
}

fn Rb::case_match($pat, $subj) {
    if (Rb::is_class($pat)) {
        return Rb::class_is_a(Rb::object_class($subj), $pat)
    }
    if (Rb::is_range($pat)) {
        return Rb::range_covers($pat, $subj)
    }
    Rb::v_equal($pat, $subj)
}

fn Rb::range_covers($range, $v) {
    my $lo_n = Rb::num_val($range->{lo})
    my $hi_n = Rb::num_val($range->{hi})
    my $vn = Rb::num_val($v)
    return 0 if $vn < $lo_n
    return $range->{exclusive} ? $vn < $hi_n : $vn <= $hi_n
}

fn Rb::iter_items($iter) {
    return $iter->{items} if Rb::is_array($iter)
    if (Rb::is_range($iter)) {
        my @items
        my $lo = Rb::num_val($iter->{lo})
        my $hi = Rb::num_val($iter->{hi})
        my $end = $iter->{exclusive} ? $hi : $hi + 1
        for (my $i = $lo; $i < $end; $i++) {
            push @items, Rb::v_int($i)
        }
        return \@items
    }
    if (Rb::is_hash($iter)) {
        # Iterating a hash yields [key, value] arrays.
        my @items
        for my $pair (@{$iter->{pairs}}) {
            push @items, Rb::v_array([$pair->[0], $pair->[1]])
        }
        return \@items
    }
    if (Rb::is_str($iter)) {
        return [map { Rb::v_str($_) } split //, $iter->{val}]
    }
    die "cannot iterate over " . $iter->{type}
}

# ── CALL DISPATCH ──────────────────────────────────────────────────────────

fn Rb::eval_call($n, $ctx) {
    my $name = $n->{name}
    my @args
    for my $a (@{$n->{args}}) {
        push @args, Rb::eval_node($a, $ctx)
    }
    my $block = undef
    if (defined $n->{block}) {
        my @frames = @{$ctx->{env}}
        $block = Rb::v_proc($n->{block}{params}, undef, $n->{block}{body}, \@frames, "<block>", 0)
    }
    my $recv = defined($n->{receiver}) ? Rb::eval_node($n->{receiver}, $ctx) : undef
    if (defined $recv) {
        return Rb::dispatch($recv, $name, \@args, $block, $ctx, 0)
    }
    # No explicit receiver: try built-in functions, then dispatch on self.
    return Rb::dispatch_implicit($name, \@args, $block, $ctx, $n->{line})
}

# Fallback method-dispatch when there's no explicit receiver. Tries:
#   1. Built-in functions (puts, print, p, raise, lambda, ...)
#   2. Class constructor (`new` on a class held in a Const)
#   3. Method on `self` (instance methods inside a class body)
#   4. Top-level method (registered on Object)
fn Rb::dispatch_implicit($name, $args, $block, $ctx, $line) {
    # Built-in commands.
    if ($name eq "puts")    { return Rb::builtin_puts($args) }
    if ($name eq "print")   { return Rb::builtin_print($args) }
    if ($name eq "p")       { return Rb::builtin_p($args) }
    if ($name eq "pp")      { return Rb::builtin_p($args) }
    if ($name eq "raise")   { return Rb::builtin_raise($args) }
    if ($name eq "lambda")  {
        die "lambda needs block" unless defined $block
        $block->{is_lambda} = 1
        return $block
    }
    if ($name eq "proc")    {
        die "proc needs block" unless defined $block
        return $block
    }
    if ($name eq "Integer") { return Rb::v_int(int(Rb::num_val($args->[0]))) }
    if ($name eq "Float")   { return Rb::v_float(Rb::num_val($args->[0]) + 0.0) }
    if ($name eq "String")  { return Rb::v_str(Rb::to_s($args->[0])) }
    if ($name eq "attr_accessor") { return Rb::define_attr_accessors($args, $ctx, 1, 1) }
    if ($name eq "attr_reader")   { return Rb::define_attr_accessors($args, $ctx, 1, 0) }
    if ($name eq "attr_writer")   { return Rb::define_attr_accessors($args, $ctx, 0, 1) }
    if ($name eq "include") {
        my $klass = $ctx->{cur_klass}
        die "`include` outside class/module" unless defined $klass
        for my $mod (@$args) {
            push @{$klass->{includes}}, $mod
        }
        return Rb::v_nil()
    }
    if ($name eq "yield") {
        die "no block given" unless defined $ctx->{block}
        return Rb::call_block($ctx->{block}, $args, $ctx)
    }
    # Dispatch on self (instance method or top-level method).
    return Rb::dispatch($ctx->{self}, $name, $args, $block, $ctx, 1)
}

# Resolve and invoke `name` on `receiver`. `is_implicit` toggles fallback:
# when set, missing methods do NOT raise — they return nil. That matches
# Ruby's "bare identifier in expression position" semantics where the
# evaluator first checks for a local var, then a method, but doesn't raise
# if neither is found at compile-time (only at first use).
fn Rb::dispatch($recv, $name, $args, $block, $ctx, $is_implicit) {
    # `nil.something` and `false.something` — most methods on nil/false
    # raise NoMethodError, but a few (.nil?, .inspect, .to_s, .class) work.
    if (Rb::is_nil($recv) || (Rb::is_bool($recv) && $recv->{val} == 0)) {
        return Rb::builtin_call_on_falsy($recv, $name, $args, $block, $ctx)
    }

    my $klass = Rb::object_class($recv)

    # Class methods: `Class.new` / `Class.foo`.
    if (Rb::is_class($recv)) {
        return Rb::class_dispatch($recv, $name, $args, $block, $ctx)
    }
    if (Rb::is_module($recv)) {
        return Rb::module_dispatch($recv, $name, $args, $block, $ctx)
    }

    # Built-in methods on Array / Hash / String / Integer / Float / Range / Sym.
    my $r = Rb::call_builtin_method($recv, $name, $args, $block, $ctx)
    return $r if defined $r

    # User-defined methods (walking inheritance chain + mixins).
    my $m = Rb::lookup_method($klass, $name)
    if (Rb::is_proc($m)) {
        return Rb::invoke_proc_as_method($m, $recv, $args, $block, $ctx)
    }

    return Rb::v_nil() if $is_implicit
    die "undefined method `" . $name . "' for " . Rb::inspect($recv)
}

fn Rb::class_dispatch($klass, $name, $args, $block, $ctx) {
    if ($name eq "new") {
        my $inst = Rb::v_instance($klass)
        my $init = Rb::lookup_method($klass, "initialize")
        if (Rb::is_proc($init)) {
            Rb::invoke_proc_as_method($init, $inst, $args, $block, $ctx)
        }
        return $inst
    }
    if ($name eq "name")     { return Rb::v_str($klass->{name}) }
    if ($name eq "to_s")     { return Rb::v_str($klass->{name}) }
    if ($name eq "inspect")  { return Rb::v_str($klass->{name}) }
    if ($name eq "ancestors") {
        my @a
        my $c = $klass
        while (defined($c) && !Rb::is_nil($c)) {
            push @a, $c
            for my $mod (@{$c->{includes} // []}) {
                push @a, $mod
            }
            $c = $c->{parent}
        }
        return Rb::v_array(\@a)
    }
    # Lookup a class method registered via `def self.foo`. Class methods
    # live in the same `methods` hash as instance methods in our model;
    # disambiguation happens at definition time. (This subset doesn't
    # distinguish — a `def self.foo` and a `def foo` both end up in
    # `methods{foo}`.) For now: try regular method lookup with the class
    # itself as receiver.
    my $m = $klass->{methods}{$name}
    if (Rb::is_proc($m)) {
        return Rb::invoke_proc_as_method($m, $klass, $args, $block, $ctx)
    }
    die "undefined class method `" . $name . "' for " . $klass->{name}
}

fn Rb::module_dispatch($mod, $name, $args, $block, $ctx) {
    if ($name eq "name")    { return Rb::v_str($mod->{name}) }
    if ($name eq "to_s")    { return Rb::v_str($mod->{name}) }
    if ($name eq "inspect") { return Rb::v_str($mod->{name}) }
    my $m = $mod->{methods}{$name}
    if (Rb::is_proc($m)) {
        return Rb::invoke_proc_as_method($m, $mod, $args, $block, $ctx)
    }
    die "undefined module method `" . $name . "' for " . $mod->{name}
}

fn Rb::builtin_call_on_falsy($recv, $name, $args, $block, $ctx) {
    if ($name eq "nil?")    { return Rb::v_bool(Rb::is_nil($recv) ? 1 : 0) }
    if ($name eq "to_s")    { return Rb::v_str(Rb::is_nil($recv) ? "" : "false") }
    if ($name eq "inspect") { return Rb::v_str(Rb::inspect($recv)) }
    if ($name eq "class")   { return Rb::object_class($recv) }
    if ($name eq "is_a?" || $name eq "kind_of?" || $name eq "instance_of?") {
        return Rb::v_bool(Rb::class_is_a(Rb::object_class($recv), $args->[0]) ? 1 : 0)
    }
    if ($name eq "!")  { return Rb::v_bool(1) }
    if ($name eq "==") { return Rb::v_bool(Rb::v_equal($recv, $args->[0]) ? 1 : 0) }
    if ($name eq "!=") { return Rb::v_bool(Rb::v_equal($recv, $args->[0]) ? 0 : 1) }
    die "undefined method `" . $name . "' for " . Rb::inspect($recv)
}

# Bind a proc as a method on `recv` and call it. Sets `self`, binds
# params, captures `&block`, and unwinds on `Return` flow.
fn Rb::invoke_proc_as_method($proc, $recv, $args, $block, $ctx) {
    my $saved_env   = $ctx->{env}
    my $saved_self  = $ctx->{self}
    my $saved_block = $ctx->{block}
    # Method calls get a FRESH env on top of the proc's captured frames —
    # local vars in the method don't leak into the caller's scope.
    my @new_frames = (@{$proc->{env}}, +{})
    $ctx->{env}   = \@new_frames
    $ctx->{self}  = $recv
    $ctx->{block} = $block
    Rb::bind_proc_params($proc, $args, $ctx)
    my $result = eval { Rb::eval_block_stmts($proc->{body}, $ctx) }
    my $err = $@
    $ctx->{env}   = $saved_env
    $ctx->{self}  = $saved_self
    $ctx->{block} = $saved_block
    if ($err) {
        if (ref($err) eq "HASH" && $err->{flow} eq "return") {
            return $err->{value}
        }
        die $err
    }
    $result
}

# Block call: binds params (loose arity for proc/block; strict for lambda),
# evaluates body, returns the result. Does NOT install a new self.
fn Rb::call_block($block, $args, $ctx) {
    my $saved_env = $ctx->{env}
    # Block runs in its captured env PLUS a fresh frame for params/locals.
    my @new_frames = (@{$block->{env}}, +{})
    $ctx->{env} = \@new_frames
    Rb::bind_proc_params($block, $args, $ctx)
    my $result = eval { Rb::eval_block_stmts($block->{body}, $ctx) }
    my $err = $@
    $ctx->{env} = $saved_env
    if ($err) {
        if (ref($err) eq "HASH" && $err->{flow} eq "return") {
            # In a lambda, `return` returns from THE LAMBDA. In a proc/block,
            # `return` returns from the enclosing method. We don't track the
            # enclosing method here, so re-throw to let the caller handle.
            return $err->{value} if $block->{is_lambda}
            die $err
        }
        if (ref($err) eq "HASH" && $err->{flow} eq "next") {
            return $err->{value} // Rb::v_nil()
        }
        die $err
    }
    $result
}

fn Rb::bind_proc_params($proc, $args, $ctx) {
    my $params = $proc->{params}
    my $rest   = $proc->{rest}
    my $n      = scalar(@$params)
    # If the block has 1 param and was given 1 array arg, splat it (Ruby's
    # auto-splat for blocks — `arr.each { |k, v| }` against an array of pairs).
    if ($n > 1 && scalar(@$args) == 1 && Rb::is_array($args->[0]) && !$proc->{is_lambda}) {
        $args = $args->[0]{items}
    }
    for (my $i = 0; $i < $n; $i++) {
        my $val = $i < scalar(@$args) ? $args->[$i] : Rb::v_nil()
        Rb::env_define($ctx->{env}, $params->[$i], $val)
    }
    if (defined $rest) {
        my @tail
        for (my $i = $n; $i < scalar(@$args); $i++) {
            push @tail, $args->[$i]
        }
        Rb::env_define($ctx->{env}, $rest, Rb::v_array(\@tail))
    }
}

fn Rb::define_attr_accessors($args, $ctx, $reader, $writer) {
    my $klass = $ctx->{cur_klass}
    die "attr_* outside class" unless defined $klass
    for my $sym (@$args) {
        my $name = $sym->{val}
        if ($reader) {
            my $body = [+{ kind => "IVar", name => $name, line => 0 }]
            $klass->{methods}{$name} = Rb::v_proc([], undef, $body, [+{}], $name, 0)
        }
        if ($writer) {
            my $body = [+{
                kind   => "Assign",
                target => +{ kind => "IVar", name => $name, line => 0 },
                value  => +{ kind => "Ident", name => "v",  line => 0 },
                line   => 0,
            }]
            $klass->{methods}{$name . "="} = Rb::v_proc(["v"], undef, $body, [+{}], $name . "=", 0)
        }
    }
    Rb::v_nil()
}

# ── BUILT-IN COMMANDS ──────────────────────────────────────────────────────

fn Rb::builtin_puts($args) {
    if (scalar(@$args) == 0) {
        print "\n"
        return Rb::v_nil()
    }
    for my $a (@$args) {
        if (Rb::is_array($a)) {
            for my $e (@{$a->{items}}) {
                print Rb::to_s($e), "\n"
            }
        } else {
            my $s = Rb::to_s($a)
            print $s
            print "\n" unless substr($s, -1) eq "\n"
        }
    }
    Rb::v_nil()
}

fn Rb::builtin_print($args) {
    for my $a (@$args) {
        print Rb::to_s($a)
    }
    Rb::v_nil()
}

fn Rb::builtin_p($args) {
    for my $a (@$args) {
        print Rb::inspect($a), "\n"
    }
    return $args->[0] if scalar(@$args) == 1
    Rb::v_array($args)
}

fn Rb::builtin_raise($args) {
    if (scalar(@$args) == 0) {
        die Rb::v_exception($CLASSES{RuntimeError}, "")
    }
    my $first = $args->[0]
    if (Rb::is_str($first)) {
        die Rb::v_exception($CLASSES{RuntimeError}, $first->{val})
    }
    if (Rb::is_class($first)) {
        my $msg = scalar(@$args) > 1 ? Rb::to_s($args->[1]) : $first->{name}
        die Rb::v_exception($first, $msg)
    }
    if (Rb::is_exception($first)) {
        die $first
    }
    die Rb::v_exception($CLASSES{RuntimeError}, Rb::to_s($first))
}

# ── BUILT-IN METHOD DISPATCH ───────────────────────────────────────────────
#
# `call_builtin_method` returns undef when no built-in handles `name`; the
# generic dispatch path then falls through to user-defined methods.

fn Rb::call_builtin_method($recv, $name, $args, $block, $ctx) {
    # Universal methods on every object.
    return Rb::v_str(Rb::inspect($recv))         if $name eq "inspect"
    return Rb::v_str(Rb::to_s($recv))            if $name eq "to_s"
    return Rb::object_class($recv)               if $name eq "class"
    return Rb::v_bool(Rb::is_nil($recv) ? 1 : 0) if $name eq "nil?"
    return Rb::v_bool(Rb::is_truthy($recv) ? 0 : 1) if $name eq "!"
    return Rb::v_bool(Rb::v_equal($recv, $args->[0]) ? 1 : 0) if $name eq "=="
    return Rb::v_bool(Rb::v_equal($recv, $args->[0]) ? 0 : 1) if $name eq "!="
    if ($name eq "is_a?" || $name eq "kind_of?") {
        return Rb::v_bool(Rb::class_is_a(Rb::object_class($recv), $args->[0]) ? 1 : 0)
    }
    if ($name eq "instance_of?") {
        return Rb::v_bool(Rb::object_class($recv)->{name} eq $args->[0]{name} ? 1 : 0)
    }
    if ($name eq "respond_to?") {
        my $sym = $args->[0]{val}
        return Rb::v_bool(1)
            if Rb::call_builtin_method($recv, $sym, [], undef, $ctx) ne undef
        my $m = Rb::lookup_method(Rb::object_class($recv), $sym)
        return Rb::v_bool(Rb::is_proc($m) ? 1 : 0)
    }
    if ($name eq "tap") {
        Rb::call_block($block, [$recv], $ctx) if defined $block
        return $recv
    }
    if ($name eq "then" || $name eq "yield_self") {
        return defined($block) ? Rb::call_block($block, [$recv], $ctx) : $recv
    }
    if ($name eq "freeze" || $name eq "dup" || $name eq "clone") {
        # We don't implement immutability; freeze is a no-op. dup/clone do a
        # shallow copy for arrays/hashes/strings; everything else returns self.
        return Rb::dup_value($recv) if $name ne "freeze"
        return $recv
    }
    if ($name eq "frozen?") {
        # Symbols and ranges are conceptually frozen; everything else not.
        return Rb::v_bool((Rb::is_sym($recv) || Rb::is_range($recv)
                           || Rb::is_int($recv) || Rb::is_float($recv)
                           || Rb::is_bool($recv) || Rb::is_nil($recv)) ? 1 : 0)
    }
    if ($name eq "object_id" || $name eq "__id__") {
        # We don't have stable object IDs; use a hash of the inspected value.
        return Rb::v_int(0)   # Stable enough for `obj.object_id == obj.object_id`.
    }

    # Type-specific dispatch.
    return Rb::array_method($recv, $name, $args, $block, $ctx)   if Rb::is_array($recv)
    return Rb::str_method($recv, $name, $args, $block, $ctx)     if Rb::is_str($recv)
    return Rb::hash_method($recv, $name, $args, $block, $ctx)    if Rb::is_hash($recv)
    return Rb::int_method($recv, $name, $args, $block, $ctx)     if Rb::is_int($recv)
    return Rb::float_method($recv, $name, $args, $block, $ctx)   if Rb::is_float($recv)
    return Rb::range_method($recv, $name, $args, $block, $ctx)   if Rb::is_range($recv)
    return Rb::sym_method($recv, $name, $args, $block, $ctx)     if Rb::is_sym($recv)
    return Rb::proc_method($recv, $name, $args, $block, $ctx)    if Rb::is_proc($recv)
    return Rb::exception_method($recv, $name, $args, $block, $ctx) if Rb::is_exception($recv)
    undef
}

fn Rb::dup_value($v) {
    return Rb::v_array([@{$v->{items}}])           if Rb::is_array($v)
    return Rb::v_hash([map { [$_->[0], $_->[1]] } @{$v->{pairs}}]) if Rb::is_hash($v)
    return Rb::v_str($v->{val})                    if Rb::is_str($v)
    $v
}

# ── ARRAY METHODS ──────────────────────────────────────────────────────────

fn Rb::array_method($a, $name, $args, $block, $ctx) {
    my $items = $a->{items}
    if ($name eq "[]") {
        return Rb::array_get($a, $args)
    }
    if ($name eq "[]=") {
        my $val = $args->[-1]
        $items->[$args->[0]{val}] = $val
        return $val
    }
    if ($name eq "length" || $name eq "size" || $name eq "count") {
        return Rb::v_int(scalar(@$items))
    }
    if ($name eq "empty?")     { return Rb::v_bool(scalar(@$items) == 0 ? 1 : 0) }
    if ($name eq "first") {
        return $items->[0] // Rb::v_nil() if scalar(@$args) == 0
        my $n = $args->[0]{val}
        return Rb::v_array([@$items[0 .. $n - 1]])
    }
    if ($name eq "last") {
        return $items->[-1] // Rb::v_nil() if scalar(@$args) == 0
        my $n = $args->[0]{val}
        return Rb::v_array([@$items[scalar(@$items) - $n .. scalar(@$items) - 1]])
    }
    if ($name eq "push" || $name eq "append") {
        push @$items, @$args
        return $a
    }
    if ($name eq "pop")     { return scalar(@$items) ? pop(@$items)   : Rb::v_nil() }
    if ($name eq "shift")   { return scalar(@$items) ? shift(@$items) : Rb::v_nil() }
    if ($name eq "unshift" || $name eq "prepend") {
        unshift @$items, @$args
        return $a
    }
    if ($name eq "include?") {
        for my $e (@$items) {
            return Rb::v_bool(1) if Rb::v_equal($e, $args->[0])
        }
        return Rb::v_bool(0)
    }
    if ($name eq "index") {
        for (my $i = 0; $i < scalar(@$items); $i++) {
            return Rb::v_int($i) if Rb::v_equal($items->[$i], $args->[0])
        }
        return Rb::v_nil()
    }
    if ($name eq "reverse") {
        return Rb::v_array([reverse @$items])
    }
    if ($name eq "reverse!") {
        @$items = reverse @$items
        return $a
    }
    if ($name eq "sort") {
        my @sorted = sort {
            if (defined $block) {
                my $cmp = Rb::call_block($block, [$a, $b], $ctx)
                Rb::num_val($cmp)
            } else {
                Rb::cmp_val($a, $b)
            }
        } @$items
        return Rb::v_array(\@sorted)
    }
    if ($name eq "sort_by") {
        my @decorated = map { [Rb::call_block($block, [$_], $ctx), $_] } @$items
        my @sorted = sort { Rb::cmp_val($a->[0], $b->[0]) } @decorated
        return Rb::v_array([map { $_->[1] } @sorted])
    }
    if ($name eq "min") { return Rb::v_nil() if !scalar(@$items); my $m = $items->[0]; for my $e (@$items) { $m = $e if Rb::cmp_val($e, $m) < 0 } $m }
    if ($name eq "max") { return Rb::v_nil() if !scalar(@$items); my $m = $items->[0]; for my $e (@$items) { $m = $e if Rb::cmp_val($e, $m) > 0 } $m }
    if ($name eq "min_by") {
        return Rb::v_nil() if !scalar(@$items)
        my $best = $items->[0]
        my $bk = Rb::call_block($block, [$best], $ctx)
        for my $e (@{$items}[1..$#{$items}]) {
            my $k = Rb::call_block($block, [$e], $ctx)
            if (Rb::cmp_val($k, $bk) < 0) { $best = $e; $bk = $k }
        }
        return $best
    }
    if ($name eq "max_by") {
        return Rb::v_nil() if !scalar(@$items)
        my $best = $items->[0]
        my $bk = Rb::call_block($block, [$best], $ctx)
        for my $e (@{$items}[1..$#{$items}]) {
            my $k = Rb::call_block($block, [$e], $ctx)
            if (Rb::cmp_val($k, $bk) > 0) { $best = $e; $bk = $k }
        }
        return $best
    }
    if ($name eq "sum") {
        my $sum = scalar(@$args) ? Rb::num_val($args->[0]) : 0
        my $is_float = scalar(@$args) ? Rb::is_float($args->[0]) : 0
        for my $e (@$items) {
            my $v = defined($block) ? Rb::call_block($block, [$e], $ctx) : $e
            $sum += Rb::num_val($v)
            $is_float = 1 if Rb::is_float($v)
        }
        return $is_float ? Rb::v_float($sum) : Rb::v_int($sum)
    }
    if ($name eq "each") {
        for my $e (@$items) {
            eval { Rb::call_block($block, [$e], $ctx) }
            if ($@ && ref($@) eq "HASH" && $@->{flow} eq "break") {
                return $@->{value} // Rb::v_nil()
            }
            die $@ if $@ && (ref($@) ne "HASH" || ($@->{flow} ne "next"))
        }
        return $a
    }
    if ($name eq "each_with_index") {
        for (my $i = 0; $i < scalar(@$items); $i++) {
            Rb::call_block($block, [$items->[$i], Rb::v_int($i)], $ctx)
        }
        return $a
    }
    if ($name eq "each_with_object") {
        my $memo = $args->[0]
        for my $e (@$items) {
            Rb::call_block($block, [$e, $memo], $ctx)
        }
        return $memo
    }
    if ($name eq "map" || $name eq "collect") {
        my @out
        for my $e (@$items) {
            push @out, Rb::call_block($block, [$e], $ctx)
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "map!" || $name eq "collect!") {
        for (my $i = 0; $i < scalar(@$items); $i++) {
            $items->[$i] = Rb::call_block($block, [$items->[$i]], $ctx)
        }
        return $a
    }
    if ($name eq "flat_map" || $name eq "collect_concat") {
        my @out
        for my $e (@$items) {
            my $r = Rb::call_block($block, [$e], $ctx)
            if (Rb::is_array($r)) {
                push @out, @{$r->{items}}
            } else {
                push @out, $r
            }
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "select" || $name eq "filter") {
        my @out
        for my $e (@$items) {
            push @out, $e if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "reject") {
        my @out
        for my $e (@$items) {
            push @out, $e unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "find" || $name eq "detect") {
        for my $e (@$items) {
            return $e if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_nil()
    }
    if ($name eq "any?") {
        return Rb::v_bool(scalar(@$items) ? 1 : 0) unless defined $block
        for my $e (@$items) {
            return Rb::v_bool(1) if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_bool(0)
    }
    if ($name eq "all?") {
        unless (defined $block) {
            for my $e (@$items) { return Rb::v_bool(0) unless Rb::is_truthy($e) }
            return Rb::v_bool(1)
        }
        for my $e (@$items) {
            return Rb::v_bool(0) unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_bool(1)
    }
    if ($name eq "none?") {
        unless (defined $block) {
            for my $e (@$items) { return Rb::v_bool(0) if Rb::is_truthy($e) }
            return Rb::v_bool(1)
        }
        for my $e (@$items) {
            return Rb::v_bool(0) if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_bool(1)
    }
    if ($name eq "count") {
        return Rb::v_int(scalar(@$items)) unless defined $block || scalar(@$args)
        if (defined $block) {
            my $n = 0
            for my $e (@$items) {
                $n++ if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            }
            return Rb::v_int($n)
        }
        my $n = 0
        for my $e (@$items) {
            $n++ if Rb::v_equal($e, $args->[0])
        }
        return Rb::v_int($n)
    }
    if ($name eq "reduce" || $name eq "inject") {
        my @rest = @$items
        my $acc
        if (scalar(@$args)) {
            $acc = $args->[0]
        } else {
            return Rb::v_nil() unless scalar(@rest)
            $acc = shift @rest
        }
        for my $e (@rest) {
            $acc = Rb::call_block($block, [$acc, $e], $ctx)
        }
        return $acc
    }
    if ($name eq "join") {
        my $sep = scalar(@$args) ? Rb::to_s($args->[0]) : ""
        return Rb::v_str(join($sep, map { Rb::to_s($_) } @$items))
    }
    if ($name eq "uniq") {
        my @seen
        my @out
        for my $e (@$items) {
            my $dup = 0
            for my $s (@seen) {
                if (Rb::v_equal($e, $s)) { $dup = 1; last }
            }
            unless ($dup) { push @seen, $e; push @out, $e }
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "compact") {
        return Rb::v_array([grep { !Rb::is_nil($_) } @$items])
    }
    if ($name eq "flatten") {
        my $depth = scalar(@$args) ? Rb::num_val($args->[0]) : -1
        return Rb::v_array(Rb::array_flatten($items, $depth))
    }
    if ($name eq "concat") {
        for my $arg (@$args) {
            push @$items, @{$arg->{items}}
        }
        return $a
    }
    if ($name eq "dup" || $name eq "clone" || $name eq "to_a") {
        return Rb::v_array([@$items])
    }
    if ($name eq "zip") {
        my @result
        for (my $i = 0; $i < scalar(@$items); $i++) {
            my @row = ($items->[$i])
            for my $other (@$args) {
                push @row, ($other->{items}[$i] // Rb::v_nil())
            }
            push @result, Rb::v_array(\@row)
        }
        return Rb::v_array(\@result)
    }
    if ($name eq "take") {
        my $n = $args->[0]{val}
        $n = scalar(@$items) if $n > scalar(@$items)
        return Rb::v_array([@$items[0..$n - 1]])
    }
    if ($name eq "drop") {
        my $n = $args->[0]{val}
        return Rb::v_array([@$items[$n..scalar(@$items) - 1]])
    }
    if ($name eq "take_while") {
        my @out
        for my $e (@$items) {
            last unless Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            push @out, $e
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "drop_while") {
        my @out
        my $dropping = 1
        for my $e (@$items) {
            $dropping = 0 unless $dropping && Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
            push @out, $e unless $dropping
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "partition") {
        my @yes; my @no
        for my $e (@$items) {
            if (Rb::is_truthy(Rb::call_block($block, [$e], $ctx))) {
                push @yes, $e
            } else {
                push @no, $e
            }
        }
        return Rb::v_array([Rb::v_array(\@yes), Rb::v_array(\@no)])
    }
    if ($name eq "group_by") {
        my @keys; my @groups
        for my $e (@$items) {
            my $k = Rb::call_block($block, [$e], $ctx)
            my $found = 0
            for (my $i = 0; $i < scalar(@keys); $i++) {
                if (Rb::v_equal($keys[$i], $k)) {
                    push @{$groups[$i]}, $e
                    $found = 1
                    last
                }
            }
            unless ($found) {
                push @keys, $k
                push @groups, [$e]
            }
        }
        my @pairs
        for (my $i = 0; $i < scalar(@keys); $i++) {
            push @pairs, [$keys[$i], Rb::v_array($groups[$i])]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "tally") {
        my @keys; my @counts
        for my $e (@$items) {
            my $found = 0
            for (my $i = 0; $i < scalar(@keys); $i++) {
                if (Rb::v_equal($keys[$i], $e)) {
                    $counts[$i]++
                    $found = 1
                    last
                }
            }
            unless ($found) {
                push @keys, $e
                push @counts, 1
            }
        }
        my @pairs
        for (my $i = 0; $i < scalar(@keys); $i++) {
            push @pairs, [$keys[$i], Rb::v_int($counts[$i])]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "to_h") {
        my @pairs
        for my $e (@$items) {
            die "to_h requires pair" unless Rb::is_array($e) && scalar(@{$e->{items}}) == 2
            push @pairs, [$e->{items}[0], $e->{items}[1]]
        }
        return Rb::v_hash(\@pairs)
    }
    if ($name eq "slice") {
        return Rb::array_get($a, $args)
    }
    if ($name eq "min_max") { ; }
    undef
}

fn Rb::array_get($a, $args) {
    my $items = $a->{items}
    my $n = scalar(@$items)
    if (scalar(@$args) == 1) {
        my $idx = $args->[0]
        if (Rb::is_int($idx)) {
            my $i = $idx->{val}
            $i += $n if $i < 0
            return ($i < 0 || $i >= $n) ? Rb::v_nil() : $items->[$i]
        }
        if (Rb::is_range($idx)) {
            my $lo = Rb::num_val($idx->{lo}); $lo += $n if $lo < 0
            my $hi = Rb::num_val($idx->{hi}); $hi += $n if $hi < 0
            $hi = $idx->{exclusive} ? $hi - 1 : $hi
            return Rb::v_nil() if $lo > $n
            return Rb::v_array([@$items[$lo .. (($hi >= $n) ? $n - 1 : $hi)]])
        }
    }
    if (scalar(@$args) == 2) {
        my $start = $args->[0]{val}
        my $len = $args->[1]{val}
        $start += $n if $start < 0
        return Rb::v_nil() if $start > $n
        my $end = $start + $len - 1
        $end = $n - 1 if $end >= $n
        return Rb::v_array([@$items[$start .. $end]])
    }
    Rb::v_nil()
}

fn Rb::array_flatten($items, $depth) {
    my @out
    for my $e (@$items) {
        if (Rb::is_array($e) && $depth != 0) {
            push @out, @{Rb::array_flatten($e->{items}, $depth - 1)}
        } else {
            push @out, $e
        }
    }
    \@out
}

# Comparator helper for sort.
fn Rb::cmp_val($a, $b) {
    if (Rb::is_num($a) && Rb::is_num($b)) {
        my $av = Rb::num_val($a); my $bv = Rb::num_val($b)
        return $av < $bv ? -1 : ($av > $bv ? 1 : 0)
    }
    if (Rb::is_str($a) && Rb::is_str($b)) {
        return $a->{val} lt $b->{val} ? -1 : ($a->{val} gt $b->{val} ? 1 : 0)
    }
    if (Rb::is_sym($a) && Rb::is_sym($b)) {
        return $a->{val} lt $b->{val} ? -1 : ($a->{val} gt $b->{val} ? 1 : 0)
    }
    if (Rb::is_array($a) && Rb::is_array($b)) {
        my $ai = $a->{items}; my $bi = $b->{items}
        my $min = scalar(@$ai) < scalar(@$bi) ? scalar(@$ai) : scalar(@$bi)
        for (my $i = 0; $i < $min; $i++) {
            my $c = Rb::cmp_val($ai->[$i], $bi->[$i])
            return $c if $c != 0
        }
        return scalar(@$ai) <=> scalar(@$bi)
    }
    0
}

# ── STRING METHODS ─────────────────────────────────────────────────────────

fn Rb::str_method($s, $name, $args, $block, $ctx) {
    my $v = $s->{val}
    if ($name eq "length" || $name eq "size") {
        return Rb::v_int(length($v))
    }
    if ($name eq "empty?") {
        return Rb::v_bool(length($v) == 0 ? 1 : 0)
    }
    if ($name eq "upcase")    { return Rb::v_str(uc($v)) }
    if ($name eq "downcase")  { return Rb::v_str(lc($v)) }
    if ($name eq "capitalize"){ return Rb::v_str(uc(substr($v, 0, 1)) . lc(substr($v, 1))) }
    if ($name eq "swapcase")  { return Rb::v_str(join("", map { /[A-Z]/ ? lc : ucfirst($_) =~ /[A-Z]/ ? lc : uc } split //, $v)) }
    if ($name eq "reverse")   { return Rb::v_str(scalar reverse $v) }
    if ($name eq "chars")     { return Rb::v_array([map { Rb::v_str($_) } split //, $v]) }
    if ($name eq "bytes") {
        my @b
        for my $c (split //, $v) { push @b, Rb::v_int(ord($c)) }
        return Rb::v_array(\@b)
    }
    if ($name eq "lines")     { return Rb::v_array([map { Rb::v_str($_) } split /(?<=\n)/, $v]) }
    if ($name eq "split") {
        my $sep = scalar(@$args) ? $args->[0]{val} : " "
        return Rb::v_array([map { Rb::v_str($_) } split /\Q$sep\E/, $v])
    }
    if ($name eq "strip" || $name eq "trim") {
        my $r = $v; $r =~ s/^\s+|\s+$//g
        return Rb::v_str($r)
    }
    if ($name eq "lstrip") {
        my $r = $v; $r =~ s/^\s+//
        return Rb::v_str($r)
    }
    if ($name eq "rstrip" || $name eq "chomp") {
        my $r = $v
        if ($name eq "chomp") {
            $r =~ s/\r?\n$//
        } else {
            $r =~ s/\s+$//
        }
        return Rb::v_str($r)
    }
    if ($name eq "include?") {
        return Rb::v_bool(index($v, $args->[0]{val}) >= 0 ? 1 : 0)
    }
    if ($name eq "start_with?" || $name eq "starts_with?") {
        for my $a (@$args) {
            return Rb::v_bool(1) if substr($v, 0, length($a->{val})) eq $a->{val}
        }
        return Rb::v_bool(0)
    }
    if ($name eq "end_with?" || $name eq "ends_with?") {
        for my $a (@$args) {
            my $alen = length($a->{val})
            return Rb::v_bool(1) if $alen <= length($v) && substr($v, -$alen) eq $a->{val}
        }
        return Rb::v_bool(0)
    }
    if ($name eq "sub") {
        my $pat = $args->[0]{val}
        my $rep = $args->[1]{val}
        my $r = $v
        $r =~ s/\Q$pat\E/$rep/
        return Rb::v_str($r)
    }
    if ($name eq "gsub") {
        my $pat = $args->[0]{val}
        my $rep = $args->[1]{val}
        my $r = $v
        $r =~ s/\Q$pat\E/$rep/g
        return Rb::v_str($r)
    }
    if ($name eq "replace")    { $s->{val} = $args->[0]{val}; return $s }
    if ($name eq "concat" || $name eq "+") {
        return Rb::v_str($v . $args->[0]{val})
    }
    if ($name eq "*")          { return Rb::v_str($v x $args->[0]{val}) }
    if ($name eq "[]")         { return Rb::str_subscript($s, $args) }
    if ($name eq "to_i") {
        if ($v =~ /^\s*(-?\d+)/) { return Rb::v_int($1 + 0) }
        return Rb::v_int(0)
    }
    if ($name eq "to_f")       { return Rb::v_float($v + 0.0) }
    if ($name eq "to_sym")     { return Rb::v_sym($v) }
    if ($name eq "to_s")       { return $s }
    if ($name eq "to_str")     { return $s }
    if ($name eq "intern")     { return Rb::v_sym($v) }
    if ($name eq "each_char") {
        for my $c (split //, $v) {
            Rb::call_block($block, [Rb::v_str($c)], $ctx)
        }
        return $s
    }
    if ($name eq "each_line") {
        for my $line (split /(?<=\n)/, $v) {
            Rb::call_block($block, [Rb::v_str($line)], $ctx)
        }
        return $s
    }
    if ($name eq "count") {
        my $needle = $args->[0]{val}
        my $n = 0
        $n++ for $v =~ /\Q$needle\E/g
        return Rb::v_int($n)
    }
    if ($name eq "tr") {
        my $from = $args->[0]{val}
        my $to = $args->[1]{val}
        my $r = $v
        eval "\$r =~ tr/" . quotemeta($from) . "/" . quotemeta($to) . "/"
        return Rb::v_str($r)
    }
    if ($name eq "center") {
        my $w = $args->[0]{val}
        my $pad = scalar(@$args) > 1 ? $args->[1]{val} : " "
        my $deficit = $w - length($v)
        return $s if $deficit <= 0
        my $left = int($deficit / 2)
        my $right = $deficit - $left
        return Rb::v_str(($pad x ($left)) . $v . ($pad x ($right)))
    }
    if ($name eq "ljust") {
        my $w = $args->[0]{val}
        my $pad = scalar(@$args) > 1 ? $args->[1]{val} : " "
        return Rb::v_str(length($v) >= $w ? $v : $v . ($pad x ($w - length($v))))
    }
    if ($name eq "rjust") {
        my $w = $args->[0]{val}
        my $pad = scalar(@$args) > 1 ? $args->[1]{val} : " "
        return Rb::v_str(length($v) >= $w ? $v : ($pad x ($w - length($v))) . $v)
    }
    if ($name eq "match?" || $name eq "match") {
        my $pat = $args->[0]{val}
        my $hit = $v =~ /$pat/ ? 1 : 0
        return $name eq "match?" ? Rb::v_bool($hit) : ($hit ? Rb::v_str($&) : Rb::v_nil())
    }
    undef
}

fn Rb::str_subscript($s, $args) {
    my $v = $s->{val}
    my $n = length($v)
    if (scalar(@$args) == 1) {
        my $idx = $args->[0]
        if (Rb::is_int($idx)) {
            my $i = $idx->{val}
            $i += $n if $i < 0
            return Rb::v_nil() if $i < 0 || $i >= $n
            return Rb::v_str(substr($v, $i, 1))
        }
        if (Rb::is_range($idx)) {
            my $lo = Rb::num_val($idx->{lo}); $lo += $n if $lo < 0
            my $hi = Rb::num_val($idx->{hi}); $hi += $n if $hi < 0
            my $end = $idx->{exclusive} ? $hi - 1 : $hi
            return Rb::v_nil() if $lo > $n
            $end = $n - 1 if $end >= $n
            return Rb::v_str(substr($v, $lo, $end - $lo + 1))
        }
    }
    if (scalar(@$args) == 2) {
        my $start = $args->[0]{val}; $start += $n if $start < 0
        my $len = $args->[1]{val}
        return Rb::v_nil() if $start > $n
        return Rb::v_str(substr($v, $start, $len))
    }
    Rb::v_nil()
}

# ── HASH METHODS ───────────────────────────────────────────────────────────

fn Rb::hash_method($h, $name, $args, $block, $ctx) {
    my $pairs = $h->{pairs}
    if ($name eq "[]") {
        for my $p (@$pairs) {
            return $p->[1] if Rb::v_equal($p->[0], $args->[0])
        }
        return Rb::v_nil()
    }
    if ($name eq "[]=") {
        for my $p (@$pairs) {
            if (Rb::v_equal($p->[0], $args->[0])) {
                $p->[1] = $args->[1]
                return $args->[1]
            }
        }
        push @$pairs, [$args->[0], $args->[1]]
        return $args->[1]
    }
    if ($name eq "store") { return Rb::hash_method($h, "[]=", $args, $block, $ctx) }
    if ($name eq "length" || $name eq "size" || $name eq "count") {
        return Rb::v_int(scalar(@$pairs))
    }
    if ($name eq "empty?")  { return Rb::v_bool(scalar(@$pairs) == 0 ? 1 : 0) }
    if ($name eq "keys")    { return Rb::v_array([map { $_->[0] } @$pairs]) }
    if ($name eq "values")  { return Rb::v_array([map { $_->[1] } @$pairs]) }
    if ($name eq "to_a") {
        return Rb::v_array([map { Rb::v_array([$_->[0], $_->[1]]) } @$pairs])
    }
    if ($name eq "each" || $name eq "each_pair") {
        for my $p (@$pairs) {
            Rb::call_block($block, [$p->[0], $p->[1]], $ctx)
        }
        return $h
    }
    if ($name eq "each_key") {
        for my $p (@$pairs) {
            Rb::call_block($block, [$p->[0]], $ctx)
        }
        return $h
    }
    if ($name eq "each_value") {
        for my $p (@$pairs) {
            Rb::call_block($block, [$p->[1]], $ctx)
        }
        return $h
    }
    if ($name eq "map" || $name eq "collect") {
        my @out
        for my $p (@$pairs) {
            push @out, Rb::call_block($block, [$p->[0], $p->[1]], $ctx)
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "select" || $name eq "filter") {
        my @kept
        for my $p (@$pairs) {
            push @kept, [$p->[0], $p->[1]]
                if Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))
        }
        return Rb::v_hash(\@kept)
    }
    if ($name eq "reject") {
        my @kept
        for my $p (@$pairs) {
            push @kept, [$p->[0], $p->[1]]
                unless Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))
        }
        return Rb::v_hash(\@kept)
    }
    if ($name eq "any?") {
        for my $p (@$pairs) {
            return Rb::v_bool(1)
                if Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))
        }
        return Rb::v_bool(0)
    }
    if ($name eq "all?") {
        for my $p (@$pairs) {
            return Rb::v_bool(0)
                unless Rb::is_truthy(Rb::call_block($block, [$p->[0], $p->[1]], $ctx))
        }
        return Rb::v_bool(1)
    }
    if ($name eq "has_key?" || $name eq "key?" || $name eq "include?" || $name eq "member?") {
        for my $p (@$pairs) {
            return Rb::v_bool(1) if Rb::v_equal($p->[0], $args->[0])
        }
        return Rb::v_bool(0)
    }
    if ($name eq "has_value?" || $name eq "value?") {
        for my $p (@$pairs) {
            return Rb::v_bool(1) if Rb::v_equal($p->[1], $args->[0])
        }
        return Rb::v_bool(0)
    }
    if ($name eq "delete") {
        for (my $i = 0; $i < scalar(@$pairs); $i++) {
            if (Rb::v_equal($pairs->[$i][0], $args->[0])) {
                my $val = $pairs->[$i][1]
                splice @$pairs, $i, 1
                return $val
            }
        }
        return Rb::v_nil()
    }
    if ($name eq "merge") {
        my @merged = map { [$_->[0], $_->[1]] } @$pairs
        for my $other (@$args) {
            for my $p (@{$other->{pairs}}) {
                my $found = 0
                for my $m (@merged) {
                    if (Rb::v_equal($m->[0], $p->[0])) { $m->[1] = $p->[1]; $found = 1; last }
                }
                push @merged, [$p->[0], $p->[1]] unless $found
            }
        }
        return Rb::v_hash(\@merged)
    }
    if ($name eq "fetch") {
        for my $p (@$pairs) {
            return $p->[1] if Rb::v_equal($p->[0], $args->[0])
        }
        return $args->[1] if scalar(@$args) > 1
        return Rb::call_block($block, [$args->[0]], $ctx) if defined $block
        die "key not found"
    }
    if ($name eq "invert") {
        return Rb::v_hash([map { [$_->[1], $_->[0]] } @$pairs])
    }
    if ($name eq "to_h" || $name eq "dup" || $name eq "clone") {
        return Rb::v_hash([map { [$_->[0], $_->[1]] } @$pairs])
    }
    undef
}

# ── INTEGER / FLOAT METHODS ────────────────────────────────────────────────

fn Rb::int_method($n, $name, $args, $block, $ctx) {
    my $v = $n->{val}
    if ($name eq "to_s") {
        my $base = scalar(@$args) ? $args->[0]{val} : 10
        if ($base == 10) { return Rb::v_str($v . "") }
        if ($base == 16) { return Rb::v_str(sprintf("%x", $v)) }
        if ($base == 8)  { return Rb::v_str(sprintf("%o", $v)) }
        if ($base == 2)  { return Rb::v_str(sprintf("%b", $v)) }
        die "unsupported base " . $base
    }
    if ($name eq "to_i" || $name eq "to_int") { return $n }
    if ($name eq "to_f")       { return Rb::v_float($v + 0.0) }
    if ($name eq "abs")        { return Rb::v_int(abs($v)) }
    if ($name eq "zero?")      { return Rb::v_bool($v == 0 ? 1 : 0) }
    if ($name eq "positive?")  { return Rb::v_bool($v > 0  ? 1 : 0) }
    if ($name eq "negative?")  { return Rb::v_bool($v < 0  ? 1 : 0) }
    if ($name eq "even?")      { return Rb::v_bool(($v % 2 == 0) ? 1 : 0) }
    if ($name eq "odd?")       { return Rb::v_bool(($v % 2 != 0) ? 1 : 0) }
    if ($name eq "succ" || $name eq "next") { return Rb::v_int($v + 1) }
    if ($name eq "pred")       { return Rb::v_int($v - 1) }
    if ($name eq "chr")        { return Rb::v_str(chr($v)) }
    if ($name eq "digits") {
        my $base = scalar(@$args) ? $args->[0]{val} : 10
        my @d
        my $x = abs($v)
        if ($x == 0) { @d = (0) }
        while ($x > 0) { push @d, $x % $base; $x = int($x / $base) }
        return Rb::v_array([map { Rb::v_int($_) } @d])
    }
    if ($name eq "bit_length") {
        my $x = $v < 0 ? ~$v : $v
        my $bits = 0
        while ($x > 0) { $bits++; $x = $x >> 1 }
        return Rb::v_int($bits)
    }
    if ($name eq "times") {
        for (my $i = 0; $i < $v; $i++) {
            eval { Rb::call_block($block, [Rb::v_int($i)], $ctx) }
            if ($@) {
                if (ref($@) eq "HASH" && $@->{flow} eq "break") {
                    return $@->{value} // Rb::v_nil()
                }
                if (ref($@) eq "HASH" && $@->{flow} eq "next") { next }
                die $@
            }
        }
        return $n
    }
    if ($name eq "upto") {
        my $hi = $args->[0]{val}
        for (my $i = $v; $i <= $hi; $i++) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
        }
        return $n
    }
    if ($name eq "downto") {
        my $lo = $args->[0]{val}
        for (my $i = $v; $i >= $lo; $i--) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
        }
        return $n
    }
    if ($name eq "step") {
        my $hi = $args->[0]{val}
        my $step = scalar(@$args) > 1 ? $args->[1]{val} : 1
        if ($step > 0) {
            for (my $i = $v; $i <= $hi; $i += $step) {
                Rb::call_block($block, [Rb::v_int($i)], $ctx)
            }
        } else {
            for (my $i = $v; $i >= $hi; $i += $step) {
                Rb::call_block($block, [Rb::v_int($i)], $ctx)
            }
        }
        return $n
    }
    if ($name eq "gcd") { my $a = abs($v); my $b = abs($args->[0]{val}); while ($b) { ($a, $b) = ($b, $a % $b) } return Rb::v_int($a) }
    if ($name eq "lcm") { my $a = abs($v); my $b = abs($args->[0]{val}); return Rb::v_int(0) if $a == 0 || $b == 0; my $x = $a; my $y = $b; while ($y) { ($x, $y) = ($y, $x % $y) } return Rb::v_int(int($a * $b / $x)) }
    if ($name eq "divmod") {
        my $b = $args->[0]{val}
        my $q = int($v / $b)
        $q-- if ($v % $b != 0) && (($v < 0) != ($b < 0))
        my $r = $v - $q * $b
        return Rb::v_array([Rb::v_int($q), Rb::v_int($r)])
    }
    undef
}

fn Rb::float_method($n, $name, $args, $block, $ctx) {
    my $v = $n->{val}
    if ($name eq "to_s")       { return Rb::v_str(Rb::format_float($v)) }
    if ($name eq "to_i" || $name eq "to_int" || $name eq "truncate") {
        return Rb::v_int(int($v))
    }
    if ($name eq "to_f")       { return $n }
    if ($name eq "abs")        { return Rb::v_float(abs($v)) }
    if ($name eq "zero?")      { return Rb::v_bool($v == 0 ? 1 : 0) }
    if ($name eq "positive?")  { return Rb::v_bool($v > 0  ? 1 : 0) }
    if ($name eq "negative?")  { return Rb::v_bool($v < 0  ? 1 : 0) }
    if ($name eq "round") {
        my $digits = scalar(@$args) ? $args->[0]{val} : 0
        my $f = 10 ** $digits
        return Rb::v_float(int($v * $f + ($v >= 0 ? 0.5 : -0.5)) / $f) if $digits > 0
        return Rb::v_int(int($v + ($v >= 0 ? 0.5 : -0.5)))
    }
    if ($name eq "floor")      { return Rb::v_int(int($v) - ($v < 0 && $v != int($v) ? 1 : 0)) }
    if ($name eq "ceil")       { return Rb::v_int(int($v) + ($v > 0 && $v != int($v) ? 1 : 0)) }
    if ($name eq "nan?")       { return Rb::v_bool($v != $v ? 1 : 0) }
    if ($name eq "infinite?")  { return Rb::v_bool(($v - $v) != 0 ? 1 : 0) }
    if ($name eq "finite?")    { return Rb::v_bool(($v == $v && ($v - $v) == 0) ? 1 : 0) }
    undef
}

# ── RANGE METHODS ──────────────────────────────────────────────────────────

fn Rb::range_method($r, $name, $args, $block, $ctx) {
    my $items = Rb::iter_items($r)
    if ($name eq "first") {
        return $r->{lo} if scalar(@$args) == 0
        my $n = $args->[0]{val}
        $n = scalar(@$items) if $n > scalar(@$items)
        return Rb::v_array([@$items[0 .. $n - 1]])
    }
    if ($name eq "last") {
        return $r->{hi} if scalar(@$args) == 0 && !$r->{exclusive}
        return $items->[-1] // Rb::v_nil() if scalar(@$args) == 0
        my $n = $args->[0]{val}
        return Rb::v_array([@$items[scalar(@$items) - $n .. scalar(@$items) - 1]])
    }
    if ($name eq "min")     { return scalar(@$items) ? $items->[0]  : Rb::v_nil() }
    if ($name eq "max")     { return scalar(@$items) ? $items->[-1] : Rb::v_nil() }
    if ($name eq "size" || $name eq "length" || $name eq "count") {
        return Rb::v_int(scalar(@$items))
    }
    if ($name eq "include?" || $name eq "cover?" || $name eq "===") {
        return Rb::v_bool(Rb::range_covers($r, $args->[0]) ? 1 : 0)
    }
    if ($name eq "to_a")    { return Rb::v_array($items) }
    if ($name eq "to_s")    { return Rb::v_str(Rb::inspect($r)) }
    if ($name eq "begin" || $name eq "first") { return $r->{lo} }
    if ($name eq "end" || $name eq "last")    { return $r->{hi} }
    if ($name eq "exclude_end?") { return Rb::v_bool($r->{exclusive} ? 1 : 0) }
    if ($name eq "each") {
        for my $e (@$items) {
            Rb::call_block($block, [$e], $ctx)
        }
        return $r
    }
    if ($name eq "step") {
        my $step = $args->[0]{val}
        my $i = Rb::num_val($r->{lo})
        my $end = $r->{exclusive} ? Rb::num_val($r->{hi}) - 1 : Rb::num_val($r->{hi})
        while ($i <= $end) {
            Rb::call_block($block, [Rb::v_int($i)], $ctx)
            $i += $step
        }
        return $r
    }
    if ($name eq "map" || $name eq "collect") {
        my @out
        for my $e (@$items) { push @out, Rb::call_block($block, [$e], $ctx) }
        return Rb::v_array(\@out)
    }
    if ($name eq "select" || $name eq "filter") {
        my @out
        for my $e (@$items) {
            push @out, $e if Rb::is_truthy(Rb::call_block($block, [$e], $ctx))
        }
        return Rb::v_array(\@out)
    }
    if ($name eq "reduce" || $name eq "inject") {
        return Rb::array_method(Rb::v_array($items), $name, $args, $block, $ctx)
    }
    if ($name eq "sum") {
        return Rb::array_method(Rb::v_array($items), "sum", $args, $block, $ctx)
    }
    undef
}

# ── SYMBOL METHODS ─────────────────────────────────────────────────────────

fn Rb::sym_method($s, $name, $args, $block, $ctx) {
    my $v = $s->{val}
    if ($name eq "to_s")     { return Rb::v_str($v) }
    if ($name eq "to_sym")   { return $s }
    if ($name eq "length" || $name eq "size") { return Rb::v_int(length($v)) }
    if ($name eq "upcase")   { return Rb::v_sym(uc($v)) }
    if ($name eq "downcase") { return Rb::v_sym(lc($v)) }
    if ($name eq "to_proc") {
        # `&:method` — turns symbol into a one-arg block calling that method.
        my $body = [+{
            kind     => "Call",
            receiver => +{ kind => "Ident", name => "x", line => 0 },
            name     => $v,
            args     => [],
            block    => undef,
            line     => 0,
        }]
        return Rb::v_proc(["x"], undef, $body, [+{}], $v, 0)
    }
    undef
}

# ── PROC METHODS ───────────────────────────────────────────────────────────

fn Rb::proc_method($p, $name, $args, $block, $ctx) {
    if ($name eq "call" || $name eq "()" || $name eq "[]") {
        return Rb::call_block($p, $args, $ctx)
    }
    if ($name eq "arity") {
        my $n = scalar(@{$p->{params}})
        return Rb::v_int(defined($p->{rest}) ? -($n + 1) : $n)
    }
    if ($name eq "lambda?") {
        return Rb::v_bool($p->{is_lambda} ? 1 : 0)
    }
    if ($name eq "to_proc")  { return $p }
    undef
}

# ── EXCEPTION METHODS ──────────────────────────────────────────────────────

fn Rb::exception_method($e, $name, $args, $block, $ctx) {
    if ($name eq "message" || $name eq "to_s") { return Rb::v_str($e->{message}) }
    if ($name eq "class")     { return $e->{klass} }
    if ($name eq "backtrace") { return Rb::v_array($e->{backtrace}) }
    undef
}

# ── BUILT-IN CLASS REGISTRATION ────────────────────────────────────────────
#
# Bootstraps the class hierarchy. Ruby's `Object` is the root class (parents
# `BasicObject` in real MRI; we collapse that for simplicity).

fn Rb::bootstrap_classes() {
    my $obj    = Rb::v_class("Object", undef)
    $CLASSES{Object} = $obj
    for my $name (qw(Integer Float String Symbol Array Hash Range
                      TrueClass FalseClass NilClass Proc Class Module
                      Numeric Comparable Enumerable)) {
        $CLASSES{$name} = Rb::v_class($name, $obj)
    }
    # Exception hierarchy.
    my $exc = Rb::v_class("Exception", $obj)
    $CLASSES{Exception} = $exc
    my $std = Rb::v_class("StandardError", $exc)
    $CLASSES{StandardError} = $std
    my $rt  = Rb::v_class("RuntimeError", $std)
    $CLASSES{RuntimeError} = $rt
    for my $sub (qw(ArgumentError TypeError NameError NoMethodError
                     ZeroDivisionError IndexError KeyError IOError
                     StopIteration FrozenError)) {
        $CLASSES{$sub} = Rb::v_class($sub, $std)
    }
}
