rb_test "5.times collect",
    "out = []; 5.times { |i| out.push(i) }; out",                "[0, 1, 2, 3, 4]"
rb_test "1.upto(5) sum",
    "s = 0; 1.upto(5) { |i| s += i }; s",                        "15"
rb_test "5.downto(1) collect",
    "out = []; 5.downto(1) { |i| out.push(i) }; out",            "[5, 4, 3, 2, 1]"
rb_test "abs",            "(-7).abs",                       "7"
rb_test "even?",          "10.even?",                       "true"
rb_test "odd?",           "11.odd?",                        "true"

