rb_test "class with method",
    'class Greeter
       def hi
         "hello"
       end
     end
     Greeter.new.hi',
    "\"hello\""

rb_test "class with @ivar + initialize",
    'class Counter
       def initialize
         @n = 0
       end
       def bump
         @n = @n + 1
       end
       def n
         @n
       end
     end
     c = Counter.new
     c.bump
     c.bump
     c.bump
     c.n',
    "3"

rb_test "class inheritance",
    'class Animal
       def initialize(name)
         @name = name
       end
       def name
         @name
       end
     end
     class Dog < Animal
       def speak
         "Woof! Im " + @name
       end
     end
     Dog.new("Rex").speak',
    "\"Woof! Im Rex\""

