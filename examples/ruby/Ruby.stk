    'sum = 0; {a: 1, b: 2}.each { |k, v| sum += v }; sum',       "3"

# ── RANGES ─────────────────────────────────────────────────────────────────
rb_test "range to_a",     "(1..5).to_a",                    "[1, 2, 3, 4, 5]"
rb_test "range exclusive","(1...5).to_a",                   "[1, 2, 3, 4]"
rb_test "range size",     "(1..10).size",                   "10"
rb_test "range each sum", "s = 0; (1..5).each { |i| s += i }; s", "15"
rb_test "range map",      "(1..3).map { |i| i * i }",       "[1, 4, 9]"
rb_test "range include?", "(1..5).include?(3)",             "true"

# ── CONTROL FLOW ───────────────────────────────────────────────────────────
rb_test "if true",        "if true then 1 else 2 end",      "1"
rb_test "if false",       "if false then 1 else 2 end",     "2"
rb_test "elsif",
    "x = 5; if x < 0 then \"neg\" elsif x == 0 then \"z\" else \"pos\" end",
    "\"pos\""
rb_test "unless",         "unless false then 1 end",        "1"
rb_test "while",
    "i = 0; n = 0; while i < 5 do n += i; i += 1 end; n",        "10"
rb_test "until",
    "i = 0; while i < 3 do i += 1 end; i",                       "3"
rb_test "for in range",
    "s = 0; for i in 1..5 do s += i end; s",                     "15"
rb_test "case",
    'x = 2; case x; when 1 then "one"; when 2 then "two"; else "many"; end',
    "\"two\""
rb_test "case range",
    'x = 25; case x; when 0..10 then "small"; when 11..50 then "med"; else "big"; end',
    "\"med\""
rb_test "modifier if",    "x = 5; x = 10 if true; x",       "10"
rb_test "modifier unless","x = 5; x = 10 unless true; x",    "5"
rb_test "ternary",        "true ? 1 : 2",                   "1"
rb_test "and short-circuit", "false && raise(\"boom\")",     "false"
rb_test "or short-circuit",  "true || raise(\"boom\")",      "true"
rb_test "not",            "!false",                          "true"

# ── METHODS ────────────────────────────────────────────────────────────────
rb_test "def + call",
    "def add(a, b); a + b; end; add(3, 4)",                      "7"
rb_test "def + return early",
    "def f(x); return -1 if x < 0; x * 2; end; f(-5)",           "-1"
rb_test "def + recursion",
    "def fib(n); n < 2 ? n : fib(n-1) + fib(n-2); end; fib(10)", "55"
rb_test "yield",
    "def thrice; yield 1; yield 2; yield 3; end; sum = 0; thrice { |x| sum += x }; sum",
    "6"
rb_test "lambda call",
    "f = lambda { |x| x * 3 }; f.call(7)",                       "21"
rb_test "proc call",
    "p1 = proc { |x| x + 1 }; p1.call(10)",                      "11"

