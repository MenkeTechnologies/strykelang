    'class Box
       attr_accessor :v
     end
     b = Box.new
     b.v = 42
     b.v',
    "42"

rb_test "attr_reader get",
    'class Box
       def initialize(v); @v = v; end
       attr_reader :v
     end
     Box.new(7).v',
    "7"

rb_test "def self.classmethod",
    'class Counter
       def self.zero
         0
       end
     end
     Counter.zero',
    "0"

rb_test "super calls parent",
    'class A
       def hi
         "A"
       end
     end
     class B < A
       def hi
         super + "B"
       end
     end
     B.new.hi',
    "\"AB\""

