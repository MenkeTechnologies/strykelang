#!/usr/bin/env stryke
#
# Distributed wordcount — MapReduce over the congregation API.
#
# Each worker counts words in its copy of the text; master gathers
# per-worker counts and verifies they agree. Demonstrates the scatter-
# gather shape (every worker runs identical compute, master reduces
# the answers).
#
# Real shard-distribution would split input across workers using
# bestow(per-worker-shard, @workers) and per-worker indexed prayers —
# kept out of this demo to focus on the core scatter+gather+reduce.
#
# CI-safe: pure loopback fork, no network. Clean under --no-interop.

val $n = $ARGV[0] // 2
val $text = $ARGV[1] // "the quick brown fox jumped over the lazy dog the dog slept"

printf "── distributed_wordcount: N=%d text=%s ──\n", $n, $text

val @workers = congregation($n)
printf "spawned %d workers\n", len(@workers)

# Each worker counts words in the text (passed inline in the prayer).
val $text_escaped = $text
val $code = "my \$t = q{$text_escaped}; var %counts; for my \$w (split /\\s+/, \$t) { \$counts{\$w}++ } to_json(\\%counts)"
val $div = pray $code, @workers
val %replies = annex $div

# Each worker computed the SAME counts (they all saw the same text),
# so take any one worker's hash as the answer. Rank by count desc,
# ties alphabetical.
val $first_sid = (sort { _ <=> _1 } keys %replies)[0]
val $h = from_json($replies{$first_sid})

p "── word counts (each worker independently computed) ──"
val @keys = sort { $h->{_1} <=> $h->{_} || _ cmp _1 } keys %$h
for val $k (@keys) {
    printf "  %-12s %d\n", $k, $h->{$k}
}

# Verify all workers agree.
var $all_agree = 1
for val $sid (keys %replies) {
    val $other = from_json($replies{$sid})
    for val $k (keys %$h) {
        $all_agree = 0 unless ($other->{$k} // -1) == $h->{$k}
    }
}
p $all_agree ? "✓ all $n workers computed identical counts" : "✗ workers diverged"

excommunicate(@workers)
printf "done — %d distinct words\n", len(@keys)
