#!/usr/bin/env stryke

# Pinning batch Native-K (2026-05-10): Parity Deep Dive (from BUGS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Vec Lvalue ─────────────────────────────────────────────────────────────

var $s_v = ""
vec($s_v, 0, 8) = 65
$s_v |> aeq "A", "vec 8-bit lvalue"

# ── Overload ───────────────────────────────────────────────────────────────

package Box
# Use ->{ } for hashref access in strict mode
# fn defined inside `package Box` are auto-namespaced as Box::as_string / Box::add.
fn as_string = "Box(" . _->{val} . ")"
fn add = bless({ val => _->{val} + _1->{val} }, "Box")

use overload
    '""' => "as_string",
    '+'  => "add"

package main
val $bx1 = bless({ val => 10 }, "Box")
val $bx2 = bless({ val => 20 }, "Box")
"$bx1" |> aeq "Box(10)", "overload stringify"
val $bx3 = $bx1 + $bx2
"$bx3" |> aeq "Box(30)", "overload +"

# Verify anonymous fn in overload behavior
package BoxAnon
use overload '""' => fn { "Anon(" . _->{val} . ")" }
package main
val $ba = bless({ val => 99 }, "BoxAnon")
"$ba" |> aeq "Anon(99)", "overload anonymous fn"

# ── Caller ─────────────────────────────────────────────────────────────────

# caller(0)[3] (FIXED): now returns the fully-qualified callee name —
# matches stock Perl. Was returning undef.
fn Pin::ParityDeep::call_inner = (caller(0))[3]
fn Pin::ParityDeep::call_outer = Pin::ParityDeep::call_inner()
Pin::ParityDeep::call_outer() |> aeq "Pin::ParityDeep::call_inner", "caller(0)[3] (FIXED): returns callee sub name"

# ── Bless Arrayref Tag ─────────────────────────────────────────────────────

val $o_bless = bless [1,2], "MyClass"
"$o_bless" =~ /MyClass=HASH/ |> aok "bless arrayref HASH (pinned bug)"

# ── Pipe Auto-deref ────────────────────────────────────────────────────────

[1:5] |> sum |> aeq 15, "pipe arrayref auto-derefs (FIXED): sum(1..5) = 15"

# ── Chomp Array ────────────────────────────────────────────────────────────

var @lines_chomp = ("a\n", "b\n")
chomp(@lines_chomp) |> aeq 2, 'chomp @array returns element count'
join("|", @lines_chomp) |> aeq "a|b", 'chomp @array mutates elements'

test_run
