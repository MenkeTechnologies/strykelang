#!/usr/bin/env stryke

# Pinning batch Native-K (2026-05-10): Parity Deep Dive (from BUGS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Vec Lvalue ─────────────────────────────────────────────────────────────

my $s_v = ""
vec($s_v, 0, 8) = 65
$s_v |> aeq "A", "vec 8-bit lvalue"

# ── Overload ───────────────────────────────────────────────────────────────

package Box
# Use ->{ } for hashref access in strict mode
fn as_string = "Box(" . _0->{val} . ")"
fn add = bless({ val => _0->{val} + _1->{val} }, "Box")

use overload 
    '""' => "as_string",
    '+'  => "add"

package main
my $bx1 = bless({ val => 10 }, "Box")
my $bx2 = bless({ val => 20 }, "Box")
"$bx1" |> aeq "Box(10)", "overload stringify"
my $bx3 = $bx1 + $bx2
"$bx3" |> aeq "Box(30)", "overload +"

# Verify anonymous fn in overload behavior
package BoxAnon
use overload '""' => fn { "Anon(" . _0->{val} . ")" }
package main
my $ba = bless({ val => 99 }, "BoxAnon")
"$ba" |> aeq "Anon(99)", "overload anonymous fn"

# ── Caller ─────────────────────────────────────────────────────────────────

fn call_inner = (caller(0))[3]
fn call_outer = call_inner()
!defined(call_outer()) |> aok "caller(0)[3] is undef (pinned bug)"

# ── Bless Arrayref Tag ─────────────────────────────────────────────────────

my $o_bless = bless [1,2], "MyClass"
"$o_bless" =~ /MyClass=HASH/ |> aok "bless arrayref HASH (pinned bug)"

# ── Pipe Auto-deref ────────────────────────────────────────────────────────

[1:5] |> sum |> aeq 15, "pipe arrayref auto-derefs (FIXED): sum(1..5) = 15"

# ── Chomp Array ────────────────────────────────────────────────────────────

my @lines_chomp = ("a\n", "b\n")
chomp(@lines_chomp) |> aeq 2, "chomp @array returns element count"
join("|", @lines_chomp) |> aeq "a|b", "chomp @array mutates elements"

test_run
