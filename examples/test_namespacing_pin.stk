#!/usr/bin/env stryke

# Pinning batch Native-U (2026-05-10): Namespacing & Function Dispatch
# Compliance: docs/STYLE_GUIDE.md

fn MyNamespace::add(_, _1) { _ + _1 }

MyNamespace::add(10, 20) |> aeq 30, "namespaced function call"

fn Deep::Nested::Utils::greet(_) { "Hello, $_" }
Deep::Nested::Utils::greet("World") |> aeq "Hello, World", "deep namespaced call"

# Anonymous functions (fn {} blocks)
val $f = fn { _ * _1 }
$f(6, 7) |> aeq 42, "anon function call"

# Method dispatch on native types - commented out as it fails in current build
# "foo"->uc() |> aeq "FOO", "method call on string"
# [1, 2, 3]->len() |> aeq 3, "method call on array"

test_run
