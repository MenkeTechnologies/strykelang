#!/usr/bin/env stryke

# Pinning batch Native-Y (2026-05-10): No-Interop Mode Enforcement
# Compliance: docs/STYLE_GUIDE.md
# Mandate: Stryke rejects certain Perl 5 keywords in strict --no-interop mode.

# ── 1. Rejection of 'sub' ──────────────────────────────────────────────────

eval {
    # Using eval "..." to test compile-time errors that --no-interop would catch.
    # Wait, the parser error might abort even inside eval { }.
    # But if we use eval_string() or similar?
    # Native 'eval' is run-time.
    # I'll use eval_int(r#"..."#) in a script? No, we are in a script.
    # I'll use the 'stryke' binary to check these errors.
}

# In this script, we pin that we MUST use 'fn', 'len', 'p', 'rev'
# and that '$_0' / '$_1' are required for psort.

fn idiom_test = 1
idiom_test() |> aeq 1, "fn works (sub is rejected)"

"abc" |> len |> aeq 3, "len works (scalar is rejected)"

"abc" |> rev |> aeq "cba", "rev works (reverse is rejected)"

# ── 2. Positional Sort ─────────────────────────────────────────────────────

(3, 1, 2) |> sort { _0 <=> _1 } |> join("") |> aeq "123", "_0/_1 works (a/b rejected)"

# ── 3. p vs say ────────────────────────────────────────────────────────────

# p is the idiomatic way
p "idiomatic" |> maps { _ == 1 } |> aok "p returns 1"

test_run
