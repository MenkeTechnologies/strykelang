#!/usr/bin/env stryke
# Demo + regression test for BUG-028 / BUG-235 / BUG-091 / BUG-217 —
# hash and array slices used to silently drop their elements when the
# key/index operand was an array variable, arrayref deref, or curly-
# brace deref of a hashref.

val %h = (alice => 30, bob => 25, carol => 41, dave => 19)

# Literal-list form already worked; pin it as a control.
join(",", @h{("alice", "carol")})
    |> assert_eq("30,41", "@h{(\"a\",\"c\")} literal form")

# Array-variable keys — the original BUG-028 case.
var @ks = ("alice", "dave")
join(",", @h{@ks})
    |> assert_eq("30,19", "@h{@ks} via array variable")

# Arrayref deref keys.
val $kref = ["bob", "carol"]
join(",", @h{@$kref})
    |> assert_eq("25,41", "@h{@\$kref} via arrayref deref")

# `qw(...)` keys.
join(",", @h{qw(carol bob alice)})
    |> assert_eq("41,25,30", "@h{qw(...)} preserves order")

# Curly-brace deref of a hashref — BUG-091.
val $href = \%h
join(",", @{$href}{qw(alice bob)})
    |> assert_eq("30,25", "\@{\$href}{qw(a b)} works")
join(",", @{$href}{@ks})
    |> assert_eq("30,19", "\@{\$href}{@arrvar} works")

# Array slice via curly deref of an arrayref — BUG-217 cousin.
val $aref = [100, 200, 300, 400, 500]
join(",", @{$aref}[1, 3])
    |> assert_eq("200,400", "\@{\$aref}[1,3] array-slice deref")

# Mixed forms inside the slice.
val %h2 = (a => 1, b => 2, c => 3, d => 4, e => 5)
val @lit = ("a", "e")
join(",", @h2{@lit, qw(c)})
    |> assert_eq("1,5,3", "mixed array-var and qw inside one slice")

# Delete slice forms (BUG-042/043) interoperate with the same operand shapes.
val %h3 = (alice => 1, bob => 2, carol => 3, dave => 4)
delete @h3{@ks}    # @ks = (alice, dave)
join(",", sort keys %h3) |> assert_eq("bob,carol", "delete @h3{@ks} drops keys")

test_run
