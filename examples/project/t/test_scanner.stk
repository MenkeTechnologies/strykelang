#!/usr/bin/env stryke
# t/test_scanner.stk — scanner module tests

require "./lib/scanner.stk"

# System scan
val $sys = Project::Scanner::scan_system()
assert_ok $sys->{hostname}, "has hostname"
assert_ok $sys->{os}, "has os"
assert_gt $sys->{cpus}, 0, "has cpus"
assert_ok $sys->{ram}, "has ram"
assert_ok $sys->{uptime}, "has uptime"

# Disk scan
val @disks = Project::Scanner::scan_disks()
assert_gt len(@disks), 0, "has disks"
val $root = $disks[0]
assert_ok $root->{mount}, "disk has mount"
assert_gt $root->{total}, 0, "disk has total"
assert_ok $root->{free_h}, "disk has free_h"

# Network scan
val $net = Project::Scanner::scan_network()
assert_ok $net->{ipv4}, "has ipv4"
assert_ok $net->{mac}, "has mac"

# Interfaces
val @ifaces = Project::Scanner::scan_interfaces()
assert_gt len(@ifaces), 0, "has interfaces"

# Usage bar
val $bar = Project::Scanner::usage_bar(50, 10)
assert_ok $bar, "usage bar renders"
assert_contains $bar, "█", "bar has filled chars"

val $bar_full = Project::Scanner::usage_bar(100, 10)
assert_contains $bar_full, "█", "full bar"

val $bar_empty = Project::Scanner::usage_bar(0, 10)
assert_contains $bar_empty, "░", "empty bar"

# Process scan
val @procs = process_list()
assert_gt len(@procs), 0, "has processes"
assert_ok $procs[0]->{pid}, "process has pid"
assert_ok $procs[0]->{name}, "process has name"

test_run
