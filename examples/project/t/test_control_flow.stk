#!/usr/bin/env stryke
# t/test_control_flow.stk — tests for loops, conditionals, flow control

require "./lib/control_flow.stk"

# ── Basic if/elsif/else ────────────────────────────────────────────

assert_eq Project::ControlFlow::classify_number(5), "positive", "classify positive"
assert_eq Project::ControlFlow::classify_number(-3), "negative", "classify negative"
assert_eq Project::ControlFlow::classify_number(0), "zero", "classify zero"

assert_eq Project::ControlFlow::grade_score(95), "A", "grade A"
assert_eq Project::ControlFlow::grade_score(85), "B", "grade B"
assert_eq Project::ControlFlow::grade_score(75), "C", "grade C"
assert_eq Project::ControlFlow::grade_score(65), "D", "grade D"
assert_eq Project::ControlFlow::grade_score(55), "F", "grade F"

assert_eq Project::ControlFlow::unless_example(0), "was falsy", "unless falsy"
assert_eq Project::ControlFlow::unless_example(1), "default", "unless truthy"

# ── Ternary operator ───────────────────────────────────────────────

assert_eq Project::ControlFlow::ternary_simple(1), "yes", "ternary true"
assert_eq Project::ControlFlow::ternary_simple(0), "no", "ternary false"
assert_eq Project::ControlFlow::ternary_nested(5), "positive", "nested ternary pos"
assert_eq Project::ControlFlow::ternary_nested(-5), "negative", "nested ternary neg"
assert_eq Project::ControlFlow::ternary_nested(0), "zero", "nested ternary zero"
assert_eq Project::ControlFlow::ternary_expr(10, 3), 7, "ternary expr a>b"
assert_eq Project::ControlFlow::ternary_expr(3, 10), 7, "ternary expr a<b"

# ── Postfix conditionals ───────────────────────────────────────────

assert_eq Project::ControlFlow::postfix_if_true(), 42, "postfix if true"
assert_eq Project::ControlFlow::postfix_if_false(), 99, "postfix if false"
assert_eq Project::ControlFlow::postfix_unless_true(), 0, "postfix unless true"
assert_eq Project::ControlFlow::postfix_unless_false(), 42, "postfix unless false"

# ── For loops ──────────────────────────────────────────────────────

assert_eq Project::ControlFlow::sum_range(1, 10), 55, "sum 1:10"
assert_eq Project::ControlFlow::sum_range(5, 5), 5, "sum single"
assert_eq Project::ControlFlow::count_evens(1, 2, 3, 4, 5, 6), 3, "count evens"
assert_eq Project::ControlFlow::for_c_style_sum(10), 55, "c-style for"
assert_eq Project::ControlFlow::for_with_next(), 25, "for with next"
assert_eq Project::ControlFlow::for_with_last(), 55, "for with last"

# ── While loops ────────────────────────────────────────────────────

my @countdown = Project::ControlFlow::while_countdown(5)
assert_eq len(@countdown), 5, "countdown length"
assert_eq $countdown[0], 5, "countdown first"
assert_eq $countdown[4], 1, "countdown last"

assert_eq Project::ControlFlow::while_with_last(), 15, "while with last"
assert_eq Project::ControlFlow::while_with_next(), 25, "while with next"
assert_eq Project::ControlFlow::until_example(10), 10, "until example"

# ── Postfix loops ──────────────────────────────────────────────────

assert_eq Project::ControlFlow::postfix_for_sum(), 15, "postfix for sum"

my @post_count = Project::ControlFlow::postfix_while_countdown()
assert_eq len(@post_count), 5, "postfix while length"
assert_eq $post_count[0], 5, "postfix while first"

# ── Given/when (Perl 5.10+ switch) ─────────────────────────────────

assert_eq Project::ControlFlow::day_type_given("Saturday"), "weekend", "given Saturday"
assert_eq Project::ControlFlow::day_type_given("Sunday"), "weekend", "given Sunday"
assert_eq Project::ControlFlow::day_type_given("Monday"), "weekday", "given Monday"
assert_eq Project::ControlFlow::day_type_given("Friday"), "weekday", "given Friday"
assert_eq Project::ControlFlow::day_type_given("holiday"), "unknown", "given unknown"

assert_eq Project::ControlFlow::http_status_given(200), "OK", "given http 200"
assert_eq Project::ControlFlow::http_status_given(404), "Not Found", "given http 404"
assert_eq Project::ControlFlow::http_status_given(500), "Internal Server Error", "given http 500"
assert_eq Project::ControlFlow::http_status_given(999), "Unknown Status", "given http unknown"

assert_eq Project::ControlFlow::classify_char_given("5"), "digit", "given char digit"
assert_eq Project::ControlFlow::classify_char_given("a"), "lower", "given char lower"
assert_eq Project::ControlFlow::classify_char_given("Z"), "upper", "given char upper"
assert_eq Project::ControlFlow::classify_char_given(" "), "space", "given char space"
assert_eq Project::ControlFlow::classify_char_given("!"), "other", "given char other"

assert_eq Project::ControlFlow::nested_given(1, 1), "1-1", "nested given 1-1"
assert_eq Project::ControlFlow::nested_given(1, 2), "1-2", "nested given 1-2"
assert_eq Project::ControlFlow::nested_given(1, 9), "1-?", "nested given 1-?"
assert_eq Project::ControlFlow::nested_given(2, 1), "2-1", "nested given 2-1"
assert_eq Project::ControlFlow::nested_given(2, 9), "2-?", "nested given 2-?"
assert_eq Project::ControlFlow::nested_given(9, 9), "?-?", "nested given ?-?"

# ── Match expression (stryke native) ───────────────────────────────

assert_eq Project::ControlFlow::day_type("Saturday"), "weekend", "match Saturday"
assert_eq Project::ControlFlow::day_type("Sunday"), "weekend", "match Sunday"
assert_eq Project::ControlFlow::day_type("Monday"), "weekday", "match Monday"
assert_eq Project::ControlFlow::day_type("Wednesday"), "weekday", "match Wednesday"
assert_eq Project::ControlFlow::day_type("holiday"), "unknown", "match unknown"

assert_eq Project::ControlFlow::number_word(1), "one", "match 1"
assert_eq Project::ControlFlow::number_word(2), "two", "match 2"
assert_eq Project::ControlFlow::number_word(3), "three", "match 3"
assert_eq Project::ControlFlow::number_word(99), "many", "match default"

# ── Nested loops ───────────────────────────────────────────────────

assert_eq Project::ControlFlow::multiplication_table_sum(3), 36, "mult table 3x3"
assert_eq Project::ControlFlow::multiplication_table_sum(1), 1, "mult table 1x1"

my ($a, $b) = Project::ControlFlow::find_pair_sum(10, 1, 2, 3, 7, 8)
assert_eq $a + $b, 10, "find pair sum"

my @no_pair = Project::ControlFlow::find_pair_sum(100, 1, 2, 3)
assert_eq len(@no_pair), 0, "find pair no match"

# ── Return in various contexts ─────────────────────────────────────

assert_eq Project::ControlFlow::early_return(-5), "negative", "early return neg"
assert_eq Project::ControlFlow::early_return(0), "zero", "early return zero"
assert_eq Project::ControlFlow::early_return(5), "small", "early return small"
assert_eq Project::ControlFlow::early_return(100), "large", "early return large"

assert_eq Project::ControlFlow::return_from_loop(50, 75, 150, 200), 150, "return from loop found"
assert_eq Project::ControlFlow::return_from_loop(1, 2, 3), -1, "return from loop not found"

my @limited = Project::ControlFlow::return_list_from_loop(10)
assert_eq len(@limited), 5, "return list limited"
assert_eq $limited[0], 2, "return list first"

# ── Complex control flow ───────────────────────────────────────────

my @fb = fizzbuzz(15)
assert_eq len(@fb), 15, "fizzbuzz length"
assert_eq $fb[0], 1, "fizzbuzz 1"
assert_eq $fb[2], "Fizz", "fizzbuzz 3"
assert_eq $fb[4], "Buzz", "fizzbuzz 5"
assert_eq $fb[14], "FizzBuzz", "fizzbuzz 15"

assert_eq Project::ControlFlow::collatz_steps(1), 0, "collatz 1"
assert_eq Project::ControlFlow::collatz_steps(2), 1, "collatz 2"
assert_eq Project::ControlFlow::collatz_steps(6), 8, "collatz 6"

my @primes = Project::ControlFlow::find_primes(20)
assert_eq len(@primes), 8, "primes up to 20 count"
assert_eq $primes[0], 2, "first prime"
assert_eq $primes[7], 19, "eighth prime"

test_run
