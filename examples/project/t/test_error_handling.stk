# t/test_error_handling.stk — error handling, try/catch, const tests

require "./lib/error_handling.stk"

# ══════════════════════════════════════════════════════════════════════════════
# CONST VARIABLES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::get_pi(), 3.14159265358979, "const pi"
assert_eq Project::ErrorHandling::get_e(), 2.71828182845905, "const e"
assert_eq Project::ErrorHandling::get_golden_ratio(), 1.61803398874989, "const golden ratio"
assert_eq Project::ErrorHandling::get_max_retries(), 3, "const max retries"
assert_eq Project::ErrorHandling::get_timeout(), 30, "const timeout"
assert_eq Project::ErrorHandling::get_app_name(), "StrykeDemo", "const app name"
assert_eq Project::ErrorHandling::get_version(), "1.0.0", "const version"

val $area = Project::ErrorHandling::circle_area(2)
assert_eq int($area * 100) / 100, 12.56, "circle area"

val $circ = Project::ErrorHandling::circle_circumference(1)
assert_eq int($circ * 100) / 100, 6.28, "circle circumference"

val $growth = Project::ErrorHandling::exponential_growth(100, 0.1, 1)
assert_eq int($growth), 110, "exponential growth"

# ══════════════════════════════════════════════════════════════════════════════
# TRY/CATCH
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::try_catch_basic(), 42, "try catch basic"
assert_eq Project::ErrorHandling::try_catch_with_die(), 1, "try catch with die"
assert_eq Project::ErrorHandling::try_catch_error_message(), 1, "try catch error message"
assert_eq Project::ErrorHandling::try_catch_nested(), "caught-inner;caught-outer", "try catch nested"
assert_eq Project::ErrorHandling::try_catch_no_error(), 100, "try catch no error"

val $div_result = Project::ErrorHandling::safe_divide_try(10, 2)
assert_eq $div_result, 5, "safe divide try ok"

val $div_zero = Project::ErrorHandling::safe_divide_try(10, 0)
assert_eq defined($div_zero) ? 1 : 0, 0, "safe divide try zero"

assert_eq Project::ErrorHandling::try_catch_finally_pattern(), "try,catch,after", "try catch finally pattern"
assert_eq Project::ErrorHandling::try_catch_return_from_try(), "from-try", "try catch return from try"
assert_eq Project::ErrorHandling::try_catch_return_from_catch(), "from-catch", "try catch return from catch"
assert_eq Project::ErrorHandling::multiple_try_catch(), 12, "multiple try catch"

# ══════════════════════════════════════════════════════════════════════════════
# EVAL BLOCK
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::eval_success(), 42, "eval success"
assert_eq Project::ErrorHandling::eval_with_die(), "undef", "eval with die"
assert_eq Project::ErrorHandling::eval_captures_error(), 1, "eval captures error"
assert_eq Project::ErrorHandling::eval_clears_error(), 1, "eval clears error"
assert_eq Project::ErrorHandling::eval_nested(), "outer ok", "eval nested"

# ══════════════════════════════════════════════════════════════════════════════
# DIE AND WARN
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::die_in_eval(), 1, "die in eval"

# ══════════════════════════════════════════════════════════════════════════════
# ERROR HANDLING PATTERNS
# ══════════════════════════════════════════════════════════════════════════════

val $tc = Project::ErrorHandling::try_catch_pattern()
assert_eq $tc =~ /caught/ ? 1 : 0, 1, "try catch pattern"

assert_eq Project::ErrorHandling::safe_division(10, 2), 5, "safe division ok"
assert_eq defined(Project::ErrorHandling::safe_division(10, 0)) ? 1 : 0, 0, "safe division zero"

assert_eq Project::ErrorHandling::with_cleanup(), 1, "with cleanup"

# ══════════════════════════════════════════════════════════════════════════════
# ERROR PROPAGATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::outer_catches(), 1, "outer catches"
assert_eq Project::ErrorHandling::rethrow(), 1, "Project::ErrorHandling::rethrow"

# ══════════════════════════════════════════════════════════════════════════════
# CONDITIONAL ERRORS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::validate_positive(5), 5, "validate positive ok"

val $neg_result = eval { Project::ErrorHandling::validate_positive(-5) }
assert_eq defined($neg_result) ? 1 : 0, 0, "validate positive fail"

assert_eq Project::ErrorHandling::validate_in_range(5, 1, 10), 5, "validate range ok"

val $range_fail = eval { Project::ErrorHandling::validate_in_range(15, 1, 10) }
assert_eq $@ =~ /out of range/ ? 1 : 0, 1, "validate range fail"

assert_eq Project::ErrorHandling::validate_non_empty("hello"), "hello", "validate non-empty ok"

val $empty_fail = eval { Project::ErrorHandling::validate_non_empty("") }
assert_eq $@ =~ /must not be empty/ ? 1 : 0, 1, "validate non-empty fail"

# ══════════════════════════════════════════════════════════════════════════════
# RETURN VS DIE
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ErrorHandling::return_or_die(0), "returning", "return or die - return"

val $die_result = eval { Project::ErrorHandling::return_or_die(1) }
assert_eq $@ =~ /dying/ ? 1 : 0, 1, "return or die - die"

assert_eq Project::ErrorHandling::early_die(0), "reached end", "early die - no die"

val $early_result = eval { Project::ErrorHandling::early_die(1) }
assert_eq $@ =~ /early/ ? 1 : 0, 1, "early die - die"

# ══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL INLINE TESTS
# ══════════════════════════════════════════════════════════════════════════════

# Eval string (simplified)
val $eval_val = eval { 2 + 2 }
assert_eq $eval_val, 4, "eval simple expr"

# Multiple sequential errors
for val $i (1:3) {
    eval { die "error $i" }
    assert_eq $@ =~ /error $i/ ? 1 : 0, 1, "sequential error $i"
}

# Error in loop
var @errors
for val $n (1, 0, 2) {
    val $r = eval { 10 / $n }
    push @errors, defined($r) ? "ok" : "err"
}
assert_eq join(",", @errors), "ok,err,ok", "errors in loop"

# Nested eval
val $nested = eval {
    val $inner = eval { 5 + 5 }
    $inner * 2
}
assert_eq $nested, 20, "nested eval success"

# Die with newline
eval { die "message\n" }
assert_eq $@ eq "message\n", 1, "die with newline"

# Die without newline (adds location)
eval { die "message" }
assert_eq $@ =~ /message at/ ? 1 : 0, 1, "die without newline"

# $@ preservation
$@ = ""
val $prev_err = eval { die "test"; 1 }
val $captured = $@
assert_eq $captured =~ /test/ ? 1 : 0, 1, "error preserved"

# Successful eval clears $@
$@ = "previous error"
eval { 1 }
assert_eq $@ eq "", 1, "success clears error"

test_run
