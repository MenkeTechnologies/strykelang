#!/usr/bin/env stryke
# t/test_predicates.stk — type and value predicates

# Numeric predicates
assert_ok even(2), "2 is even"
assert_ok even(0), "0 is even"
assert_false even(3), "3 is not even"
assert_ok odd(3), "3 is odd"
assert_false odd(2), "2 is not odd"
assert_ok zero(0), "0 is zero"
assert_false zero(1), "1 is not zero"
assert_ok nonzero(1), "1 is nonzero"
assert_false nonzero(0), "0 is not nonzero"
assert_ok positive(5), "5 is positive"
assert_false positive(-5), "-5 is not positive"
assert_false positive(0), "0 is not positive"
assert_ok negative(-5), "-5 is negative"
assert_false negative(5), "5 is not negative"

# Sign and numeric transforms
assert_eq sign(5), 1, "sign of 5"
assert_eq sign(-5), -1, "sign of -5"
assert_eq sign(0), 0, "sign of 0"
assert_eq negate(5), -5, "negate 5"
assert_eq negate(-5), 5, "negate -5"
assert_eq double(7), 14, "double 7"
assert_eq triple(7), 21, "triple 7"
assert_eq half(10), 5, "half of 10"

# String predicates
assert_ok is_empty(""), "empty string is empty"
assert_false is_empty("hi"), "non-empty string is not empty"
assert_ok is_blank("   "), "whitespace is blank"
assert_ok is_blank(""), "empty string is blank"
assert_false is_blank("hi"), "non-whitespace is not blank"
assert_ok is_numeric("123"), "123 is numeric"
assert_ok is_numeric("-45.67"), "-45.67 is numeric"
assert_false is_numeric("abc"), "abc is not numeric"
assert_ok is_upper("ABC"), "ABC is upper"
assert_false is_upper("abc"), "abc is not upper"
assert_false is_upper("Abc"), "Abc is not all upper"
assert_ok is_lower("abc"), "abc is lower"
assert_false is_lower("ABC"), "ABC is not lower"
assert_ok is_alpha("abc"), "abc is alpha"
assert_false is_alpha("abc123"), "abc123 is not alpha"
assert_ok is_digit("123"), "123 is digit"
assert_false is_digit("12a"), "12a is not all digit"
assert_ok is_alnum("abc123"), "abc123 is alnum"
assert_false is_alnum("abc-123"), "abc-123 is not alnum"
assert_ok is_space("   "), "spaces is_space"
assert_ok is_space("\t\n"), "tab+newline is_space"
assert_false is_space("a b"), "a b is not all space"

# String matching predicates
assert_ok starts_with("hello", "hel"), "hello starts with hel"
assert_false starts_with("hello", "ell"), "hello doesn't start with ell"
assert_ok ends_with("hello", "llo"), "hello ends with llo"
assert_false ends_with("hello", "hel"), "hello doesn't end with hel"
assert_ok contains("hello", "ell"), "hello contains ell"
assert_false contains("hello", "xyz"), "hello doesn't contain xyz"

# Type predicates
assert_ok is_array([1, 2, 3]), "arrayref is array"
assert_false is_array({a => 1}), "hashref is not array"
assert_ok is_hash({a => 1}), "hashref is hash"
assert_false is_hash([1, 2]), "arrayref is not hash"
assert_ok is_code(fn { 1 }), "fn is code"
assert_false is_code(42), "number is not code"
assert_ok is_ref([1]), "arrayref is ref"
assert_ok is_ref({a => 1}), "hashref is ref"
assert_false is_ref(42), "scalar is not ref"
assert_ok is_undef(undef), "undef is undef"
assert_false is_undef(0), "0 is not undef"
assert_ok is_defined(0), "0 is defined"
assert_ok is_defined(""), "empty string is defined"
assert_false is_defined(undef), "undef is not defined"
assert_ok is_string("hello"), "string is string"
assert_ok is_int(42), "42 is int"
assert_false is_int(3.14), "3.14 is not int"
assert_ok is_float(3.14), "3.14 is float"

# Boolean predicates
assert_ok both(1, 1), "both true"
assert_false both(1, 0), "both with one false"
assert_false both(0, 0), "both false"
assert_ok either(1, 0), "either with one true"
assert_ok either(0, 1), "either with other true"
assert_false either(0, 0), "either both false"
assert_ok neither(0, 0), "neither both false"
assert_false neither(1, 0), "neither with one true"
assert_ok xor_bool(1, 0), "xor one true"
assert_ok xor_bool(0, 1), "xor other true"
assert_false xor_bool(1, 1), "xor both true"
assert_false xor_bool(0, 0), "xor both false"

test_run
