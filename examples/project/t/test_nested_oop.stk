#!/usr/bin/env stryke
# t/test_nested_oop.stk — tests for classes, structs, enums inside collections

require "./lib/nested_oop.stk"

# ══════════════════════════════════════════════════════════════════════════════
# STRUCTS IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

my @points = Project::NestedOop::points_in_array()
assert_eq len(@points), 3, "Project::NestedOop::points_in_array count"
assert_eq $points[0]->x, 1, "Project::NestedOop::points_in_array[0].x"
assert_eq $points[1]->y, 4, "Project::NestedOop::points_in_array[1].y"
assert_eq $points[2]->x, 5, "Project::NestedOop::points_in_array[2].x"

my $pts_ref = Project::NestedOop::points_in_arrayref()
assert_eq len(@$pts_ref), 3, "Project::NestedOop::points_in_arrayref count"
assert_eq $pts_ref->[0]->x, 10, "Project::NestedOop::points_in_arrayref->[0].x"
assert_eq $pts_ref->[2]->y, 60, "Project::NestedOop::points_in_arrayref->[2].y"

assert_eq Project::NestedOop::sum_point_coords(@points), 21, "Project::NestedOop::sum_point_coords"

my @distances = Project::NestedOop::map_points_to_distances(@points)
assert_near $distances[0], 2.236, 0.01, "distance point 0"
assert_near $distances[1], 5.0, 0.01, "distance point 1"

my @filtered = Project::NestedOop::filter_points_in_quadrant(@points)
assert_eq len(@filtered), 3, "filter quadrant 1"

my @sorted = Project::NestedOop::sort_points_by_x(@points)
assert_eq $sorted[0]->x, 1, "sort by x first"
assert_eq $sorted[2]->x, 5, "sort by x last"

my $tasks = Project::NestedOop::tasks_in_array()
assert_eq len(@$tasks), 4, "Project::NestedOop::tasks_in_array count"
assert_eq $tasks->[0]->title, "Setup", "task 0 title"
assert_eq $tasks->[3]->id, 4, "task 3 id"

# ══════════════════════════════════════════════════════════════════════════════
# STRUCTS IN HASHES
# ══════════════════════════════════════════════════════════════════════════════

my $pts_hash = Project::NestedOop::points_in_hash()
assert_eq $pts_hash->{origin}->x, 0, "points_hash origin.x"
assert_eq $pts_hash->{origin}->y, 0, "points_hash origin.y"
assert_eq $pts_hash->{north}->y, 1, "points_hash north.y"
assert_eq $pts_hash->{east}->x, 1, "points_hash east.x"

my $people = Project::NestedOop::person_lookup()
assert_eq $people->{alice}->name, "Alice", "Project::NestedOop::person_lookup alice.name"
assert_eq $people->{bob}->age, 25, "Project::NestedOop::person_lookup bob.age"
assert_eq Project::NestedOop::get_person_age($people, "carol"), 35, "Project::NestedOop::get_person_age carol"

my $task_reg = Project::NestedOop::task_registry()
assert_eq $task_reg->{"TASK-001"}->title, "Initialize", "Project::NestedOop::task_registry title"
assert_eq $task_reg->{"TASK-002"}->id, 2, "Project::NestedOop::task_registry id"

# ══════════════════════════════════════════════════════════════════════════════
# ENUMS IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

my $pq = Project::NestedOop::priority_queue()
assert_eq len(@$pq), 4, "Project::NestedOop::priority_queue count"

my $colors = Project::NestedOop::color_palette()
assert_eq len(@$colors), 3, "Project::NestedOop::color_palette count"

my $workflow = Project::NestedOop::status_workflow()
assert_eq len(@$workflow), 3, "Project::NestedOop::status_workflow count"

# ══════════════════════════════════════════════════════════════════════════════
# ENUMS IN HASHES
# ══════════════════════════════════════════════════════════════════════════════

my $priority_map = Project::NestedOop::priority_labels()
assert_eq len(keys %$priority_map), 4, "Project::NestedOop::priority_labels key count"

my $status_map = Project::NestedOop::status_by_id()
assert_eq len(keys %$status_map), 4, "Project::NestedOop::status_by_id key count"

my $color_map = Project::NestedOop::color_codes()
assert_eq len(keys %$color_map), 3, "Project::NestedOop::color_codes key count"

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

my $roster = Project::NestedOop::employee_roster()
assert_eq len(@$roster), 4, "Project::NestedOop::employee_roster count"
assert_eq $roster->[0]->name, "Alice", "roster[0].name"
assert_eq $roster->[1]->department, "Marketing", "roster[1].department"
assert_eq $roster->[2]->salary, 95000, "roster[2].salary"

my $catalog = Project::NestedOop::product_catalog()
assert_eq len(@$catalog), 3, "Project::NestedOop::product_catalog count"
assert_eq $catalog->[0]->sku, "SKU001", "catalog[0].sku"
assert_eq $catalog->[1]->price, 2999, "catalog[1].price"

my $eng_only = Project::NestedOop::filter_by_department($roster, "Engineering")
assert_eq len(@$eng_only), 2, "Project::NestedOop::filter_by_department Engineering"

assert_eq Project::NestedOop::total_salary($roster), 350000, "Project::NestedOop::total_salary"

my $discounted = Project::NestedOop::apply_discount_all($catalog, 10)
assert_eq $discounted->[0]->price, 1799, "discount 10% on widget"
assert_eq $discounted->[1]->price, 2699, "discount 10% on gadget"

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES IN HASHES
# ══════════════════════════════════════════════════════════════════════════════

my $dir = Project::NestedOop::employee_directory()
assert_eq len(keys %$dir), 3, "Project::NestedOop::employee_directory key count"
assert_eq $dir->{"emp001"}->name, "Alice", "directory emp001.name"
assert_eq $dir->{"emp002"}->department, "Mkt", "directory emp002.department"

assert_eq Project::NestedOop::get_employee_name($dir, "emp003"), "Carol", "Project::NestedOop::get_employee_name"

my $products = Project::NestedOop::product_by_sku()
assert_eq $products->{"SKU001"}->name, "Widget", "Project::NestedOop::product_by_sku Widget"
assert_eq $products->{"SKU002"}->price, 2999, "Project::NestedOop::product_by_sku Gadget price"

# ══════════════════════════════════════════════════════════════════════════════
# NESTED STRUCTS IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

my $tree = Project::NestedOop::tree_as_struct()
assert_eq $tree->value, 10, "tree root value"
assert_eq len(@{$tree->children}), 2, "tree root children count"
assert_eq $tree->children->[0]->value, 5, "tree left child"
assert_eq $tree->children->[1]->value, 15, "tree right child"

my $edges = Project::NestedOop::graph_edges()
assert_eq len(@$edges), 3, "Project::NestedOop::graph_edges count"
assert_eq $edges->[0]->weight, 10, "edge 0 weight"
assert_eq $edges->[0]->from->x, 0, "edge 0 from.x"
assert_eq $edges->[1]->to->x, 2, "edge 1 to.x"

my $grid = Project::NestedOop::nested_points()
assert_eq len(@$grid), 3, "Project::NestedOop::nested_points rows"
assert_eq len(@{$grid->[0]}), 3, "Project::NestedOop::nested_points cols"
assert_eq $grid->[1][1]->x, 1, "grid[1][1].x"
assert_eq $grid->[2][2]->y, 2, "grid[2][2].y"

assert_eq Project::NestedOop::sum_nested_points($grid), 18, "Project::NestedOop::sum_nested_points"

# ══════════════════════════════════════════════════════════════════════════════
# NESTED STRUCTS IN HASHES
# ══════════════════════════════════════════════════════════════════════════════

my $groups = Project::NestedOop::point_groups()
assert_eq len(@{$groups->{quadrant1}}), 3, "Project::NestedOop::point_groups q1 count"
assert_eq len(@{$groups->{quadrant2}}), 2, "Project::NestedOop::point_groups q2 count"
assert_eq $groups->{quadrant1}[0]->x, 1, "Project::NestedOop::point_groups q1[0].x"
assert_eq $groups->{quadrant3}[1]->y, -2, "Project::NestedOop::point_groups q3[1].y"

my $teams = Project::NestedOop::team_structure()
assert_eq len(@{$teams->{engineering}}), 2, "Project::NestedOop::team_structure eng count"
assert_eq len(@{$teams->{sales}}), 2, "Project::NestedOop::team_structure sales count"
assert_eq $teams->{marketing}[0]->name, "Carol", "Project::NestedOop::team_structure mkt[0].name"

assert_eq Project::NestedOop::count_team_members($teams), 5, "Project::NestedOop::count_team_members"

my $oldest_eng = Project::NestedOop::get_oldest_in_team($teams, "engineering")
assert_eq $oldest_eng->name, "Alice", "oldest in engineering"
assert_eq $oldest_eng->age, 30, "oldest in engineering age"

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES WITH COLLECTION FIELDS
# ══════════════════════════════════════════════════════════════════════════════

my $team = Team(name => "DevOps")
$team->add_member(Person("Alice", 30))
$team->add_member(Person("Bob", 25))
$team->add_member(Person("Carol", 35))

assert_eq $team->name, "DevOps", "team name"
assert_eq $team->size(), 3, "team size"
assert_eq $team->avg_age(), 30, "team avg_age"

my $graph = Graph()
$graph->add_node("a")
$graph->add_node("b")
$graph->add_node("c")
$graph->add_edge("a", "b")
$graph->add_edge("b", "c")

assert_eq $graph->node_count(), 3, "graph node_count"
my @a_neighbors = $graph->neighbors("a")
assert_eq len(@a_neighbors), 1, "graph neighbors(a) count"
my @b_neighbors = $graph->neighbors("b")
assert_eq len(@b_neighbors), 1, "graph neighbors(b) count"

my $queue = TaskQueue()
$queue->enqueue(Task(1, "First", Priority::Low))
$queue->enqueue(Task(2, "Second", Priority::High))
$queue->enqueue(Task(3, "Third", Priority::Medium))

assert_eq $queue->size(), 3, "queue size"
assert_false $queue->is_empty(), "queue not empty"
assert_eq $queue->peek()->id, 1, "queue peek"

my $dequeued = $queue->dequeue()
assert_eq $dequeued->id, 1, "queue dequeue"
assert_eq $queue->size(), 2, "queue size after dequeue"

# ══════════════════════════════════════════════════════════════════════════════
# BINARY TREE WITH CLASS NODES
# ══════════════════════════════════════════════════════════════════════════════

my $btree = Project::NestedOop::build_binary_tree()
assert_eq $btree->value, 10, "btree root value"
assert_eq $btree->left->value, 5, "btree left value"
assert_eq $btree->right->value, 15, "btree right value"
assert_eq $btree->left->left->value, 2, "btree left.left value"
assert_ok $btree->left->left->is_leaf(), "btree leaf check"

assert_eq Project::NestedOop::tree_sum($btree), 71, "Project::NestedOop::tree_sum"
assert_eq Project::NestedOop::tree_depth($btree), 3, "Project::NestedOop::tree_depth"

my @inorder = Project::NestedOop::tree_to_array($btree)
assert_eq len(@inorder), 7, "Project::NestedOop::tree_to_array count"
assert_eq $inorder[0], 2, "inorder first"
assert_eq $inorder[3], 10, "inorder middle"
assert_eq $inorder[6], 20, "inorder last"

# ══════════════════════════════════════════════════════════════════════════════
# COMPLEX NESTED STRUCTURES
# ══════════════════════════════════════════════════════════════════════════════

my $org = Project::NestedOop::organization_chart()
assert_eq $org->{ceo}->name, "Alice", "org ceo name"
assert_eq $org->{ceo}->salary, 500000, "org ceo salary"
assert_eq $org->{departments}{engineering}{lead}->name, "Bob", "org eng lead"
assert_eq len(@{$org->{departments}{engineering}{teams}}), 2, "org eng teams count"
assert_eq $org->{departments}{engineering}{teams}[0]->name, "Backend", "org eng team 0 name"

my $board = Project::NestedOop::project_board()
assert_eq len(@{$board->{todo}}), 2, "board todo count"
assert_eq len(@{$board->{in_progress}}), 1, "board in_progress count"
assert_eq len(@{$board->{done}}), 2, "board done count"
assert_eq $board->{todo}[0]->title, "Design API", "board todo[0] title"
assert_eq $board->{in_progress}[0]->id, 3, "board in_progress[0] id"

my $moved_board = Project::NestedOop::move_task($board, 1, "todo", "in_progress")
assert_eq len(@{$moved_board->{todo}}), 1, "after move todo count"
assert_eq len(@{$moved_board->{in_progress}}), 2, "after move in_progress count"

assert_eq Project::NestedOop::count_tasks_by_priority($board, Priority::Low), 2, "count low priority"
assert_eq Project::NestedOop::count_tasks_by_priority($board, Priority::High), 1, "count high priority"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY OF ARRAYS OF STRUCTS
# ══════════════════════════════════════════════════════════════════════════════

my $matrix = Project::NestedOop::matrix_of_points()
assert_eq len(@$matrix), 3, "matrix rows"
assert_eq len(@{$matrix->[0]}), 3, "matrix cols"
assert_eq $matrix->[0][0]->x, 0, "matrix[0][0].x"
assert_eq $matrix->[2][2]->x, 2, "matrix[2][2].x"
assert_eq $matrix->[1][2]->y, 2, "matrix[1][2].y"

my @flat = Project::NestedOop::flatten_point_matrix($matrix)
assert_eq len(@flat), 9, "Project::NestedOop::flatten_point_matrix count"
assert_eq $flat[0]->x, 0, "flat[0].x"
assert_eq $flat[8]->x, 2, "flat[8].x"

# ══════════════════════════════════════════════════════════════════════════════
# HASH OF HASHES OF CLASSES
# ══════════════════════════════════════════════════════════════════════════════

my $offices = Project::NestedOop::region_offices()
assert_eq $offices->{"us"}{"ny"}->name, "Alice", "offices us.ny.name"
assert_eq $offices->{"eu"}{"de"}->salary, 88000, "offices eu.de.salary"

my $carol = Project::NestedOop::get_regional_employee($offices, "eu", "uk")
assert_eq $carol->name, "Carol", "Project::NestedOop::get_regional_employee"

assert_eq Project::NestedOop::total_regional_salary($offices, "us"), 185000, "Project::NestedOop::total_regional_salary us"
assert_eq Project::NestedOop::total_regional_salary($offices, "eu"), 173000, "Project::NestedOop::total_regional_salary eu"

# ══════════════════════════════════════════════════════════════════════════════
# MIXED COLLECTIONS
# ══════════════════════════════════════════════════════════════════════════════

my $mixed = Project::NestedOop::mixed_struct_types()
assert_eq len(@$mixed), 3, "Project::NestedOop::mixed_struct_types count"
assert_eq $mixed->[0]{type}, "point", "mixed[0].type"
assert_eq $mixed->[1]{data}->name, "Alice", "mixed[1].data.name"
assert_eq $mixed->[2]{data}->id, 1, "mixed[2].data.id"

my @processed = Project::NestedOop::process_mixed($mixed)
assert_eq len(@processed), 3, "Project::NestedOop::process_mixed count"
assert_eq $processed[0], "Point(1,2)", "processed[0]"
assert_eq $processed[1], "Person:Alice", "processed[1]"
assert_eq $processed[2], "Task#1", "processed[2]"

# ══════════════════════════════════════════════════════════════════════════════
# TRANSFORMATION PIPELINES
# ══════════════════════════════════════════════════════════════════════════════

my @input_pts = (Point(1, 1), Point(2, 2), Point(3, 3))
my $transformed = Project::NestedOop::transform_points([@input_pts], 2, 10, 20)
assert_eq $transformed->[0]->x, 12, "transform x"
assert_eq $transformed->[0]->y, 22, "transform y"
assert_eq $transformed->[2]->x, 16, "transform[2].x"

my @people_list = (
    Person("Alice", 30),
    Person("Bob", 15),
    Person("Carol", 25),
    Person("Dave", 17),
)
my $adults = Project::NestedOop::filter_adults([@people_list])
assert_eq len(@$adults), 2, "Project::NestedOop::filter_adults count"

my $sorted_people = Project::NestedOop::sort_by_age([@people_list])
assert_eq $sorted_people->[0]->name, "Bob", "Project::NestedOop::sort_by_age first"
assert_eq $sorted_people->[3]->name, "Alice", "Project::NestedOop::sort_by_age last"

my $partitioned = Project::NestedOop::partition_by_age([@people_list], 20)
assert_eq len(@{$partitioned->{young}}), 2, "partition young"
assert_eq len(@{$partitioned->{old}}), 2, "partition old"

test_run
