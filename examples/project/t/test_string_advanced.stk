#!/usr/bin/env stryke
# t/test_string_advanced.stk — advanced string operations

# Word operations
assert_eq reverse_words("hello world"), "world hello", "reverse_words"
assert_eq reverse_words("one two three"), "three two one", "reverse_words 3"
assert_eq first_word("hello world"), "hello", "first_word"
assert_eq last_word("hello world"), "world", "last_word"
assert_eq first_word("  spaced  "), "spaced", "first_word trimmed"

# Character analysis
assert_eq count_vowels("hello"), 2, "count_vowels hello"
assert_eq count_vowels("aeiou"), 5, "count_vowels all"
assert_eq count_vowels("xyz"), 0, "count_vowels none"
assert_eq count_consonants("hello"), 3, "count_consonants hello"
assert_ok is_vowel("a"), "a is vowel"
assert_ok is_vowel("E"), "E is vowel"
assert_false is_vowel("b"), "b is not vowel"
assert_ok is_consonant("b"), "b is consonant"
assert_false is_consonant("a"), "a is not consonant"

# Substring extraction
assert_eq left_str("hello", 3), "hel", "left_str"
assert_eq right_str("hello", 3), "llo", "right_str"
assert_eq mid_str("hello", 1, 3), "ell", "mid_str"
assert_eq left_str("hi", 10), "hi", "left_str overflow"
assert_eq right_str("hi", 10), "hi", "right_str overflow"

# Case variants (from snake_case input)
assert_eq pascal_case("hello_world"), "HelloWorld", "pascal_case"
assert_eq constant_case("hello_world"), "HELLO_WORLD", "constant_case"
assert_eq dot_case("hello_world"), "hello.world", "dot_case"
assert_eq path_case("hello_world"), "hello/world", "path_case"

# Palindrome
assert_ok is_palindrome("racecar"), "racecar is palindrome"
assert_ok is_palindrome("level"), "level is palindrome"
assert_ok is_palindrome("a"), "single char is palindrome"
assert_ok is_palindrome(""), "empty is palindrome"
assert_false is_palindrome("hello"), "hello is not palindrome"

# String distance
assert_eq hamming_distance("karolin", "kathrin"), 3, "hamming karolin/kathrin"
assert_eq hamming_distance("abc", "abc"), 0, "hamming same"
assert_eq hamming_distance("abc", "abd"), 1, "hamming 1 diff"

# Longest common prefix
assert_eq longest_common_prefix("flower", "flow", "flight"), "fl", "lcp 3 strings"
assert_eq longest_common_prefix("abc", "abd"), "ab", "lcp 2 strings"
assert_eq longest_common_prefix("xyz", "abc"), "", "lcp no common"

# Character operations
assert_eq ascii_ord("A"), 65, "ord A"
assert_eq ascii_ord("a"), 97, "ord a"
assert_eq ascii_chr(65), "A", "chr 65"
assert_eq ascii_chr(97), "a", "chr 97"
assert_eq count_char("hello", "l"), 2, "count l in hello"
assert_eq count_char("aaa", "a"), 3, "count a in aaa"

# Replace operations
assert_eq replace_first("hello hello", "hello", "hi"), "hi hello", "replace_first"
assert_eq replace_all_str("hello hello", "hello", "hi"), "hi hi", "replace_all_str"

# Contains checks
assert_ok contains_any("hello", "x", "l", "z"), "contains_any finds l"
assert_false contains_any("hello", "x", "y", "z"), "contains_any none"
assert_ok contains_all("hello", "h", "e", "l"), "contains_all h,e,l"
assert_false contains_all("hello", "h", "x"), "contains_all missing x"

# Starts/ends with any
assert_ok starts_with_any("hello", "hi", "he", "ho"), "starts_with_any"
assert_false starts_with_any("hello", "ab", "cd"), "starts_with_any none"
assert_ok ends_with_any("hello", "lo", "la"), "ends_with_any"
assert_false ends_with_any("hello", "ab", "cd"), "ends_with_any none"

# Caesar cipher
assert_eq caesar_shift("abc", 1), "bcd", "caesar +1"
assert_eq caesar_shift("xyz", 1), "yza", "caesar wrap"
assert_eq caesar_shift("ABC", 1), "BCD", "caesar uppercase"

test_run
