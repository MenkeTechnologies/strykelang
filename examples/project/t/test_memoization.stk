#!/usr/bin/env stryke
# t/test_memoization.stk — memoization and caching pattern tests

require "./lib/memoization.stk"

# ══════════════════════════════════════════════════════════════════════════════
# MEMOIZED FIBONACCI
# ══════════════════════════════════════════════════════════════════════════════

assert_eq fib_memo(0), 0, "fib memo 0"
assert_eq fib_memo(1), 1, "fib memo 1"
assert_eq fib_memo(10), 55, "fib memo 10"
assert_eq fib_memo(20), 6765, "fib memo 20"
assert_eq fib_memo(30), 832040, "fib memo 30"

assert_eq fib_memo(10), 55, "fib memo cached"
assert_eq fib_memo(20), 6765, "fib memo cached 20"

assert_eq fib_no_memo(10), 55, "fib no memo 10"
assert_eq fib_no_memo(15), 610, "fib no memo 15"

# ══════════════════════════════════════════════════════════════════════════════
# BASIC ADDITION (simplified - closures with hashes are limited)
# ══════════════════════════════════════════════════════════════════════════════

my $add_result = 2 + 3
assert_eq $add_result, 5, "basic add 2+3"
assert_eq 5 + 7, 12, "basic add 5+7"

# ══════════════════════════════════════════════════════════════════════════════
# MEMOIZED FACTORIAL
# ══════════════════════════════════════════════════════════════════════════════

assert_eq factorial_memo(0), 1, "fact memo 0"
assert_eq factorial_memo(1), 1, "fact memo 1"
assert_eq factorial_memo(5), 120, "fact memo 5"
assert_eq factorial_memo(10), 3628800, "fact memo 10"
assert_eq factorial_memo(12), 479001600, "fact memo 12"

assert_eq factorial_memo(5), 120, "fact memo 5 cached"

# ══════════════════════════════════════════════════════════════════════════════
# HASH-BASED CACHING (simplified - arrays in closures are limited)
# ══════════════════════════════════════════════════════════════════════════════

my %simple_cache
$simple_cache{a} = 1
$simple_cache{b} = 2
$simple_cache{c} = 3
assert_eq scalar(keys %simple_cache), 3, "cache size 3"
assert_eq $simple_cache{a}, 1, "cache get a"
assert_eq $simple_cache{b}, 2, "cache get b"
assert_eq $simple_cache{c}, 3, "cache get c"

# ══════════════════════════════════════════════════════════════════════════════
# MEMOIZED PRIME CHECK
# ══════════════════════════════════════════════════════════════════════════════

assert_eq is_prime_memo(2), 1, "2 is prime"
assert_eq is_prime_memo(3), 1, "3 is prime"
assert_eq is_prime_memo(4), 0, "4 not prime"
assert_eq is_prime_memo(17), 1, "17 is prime"
assert_eq is_prime_memo(100), 0, "100 not prime"
assert_eq is_prime_memo(101), 1, "101 is prime"

assert_eq is_prime_memo(17), 1, "17 cached"
assert_eq is_prime_memo(101), 1, "101 cached"

# ══════════════════════════════════════════════════════════════════════════════
# SIMPLE FUNCTION CALLS
# ══════════════════════════════════════════════════════════════════════════════

my $double = fn($x) { $x * 2 }
assert_eq $double(5), 10, "double 5"
assert_eq $double(10), 20, "double 10"
assert_eq $double(1), 2, "double 1"

# ══════════════════════════════════════════════════════════════════════════════
# MEMOIZATION CONCEPT TEST
# ══════════════════════════════════════════════════════════════════════════════

my %memo_test
$memo_test{key1} = 42
assert_eq $memo_test{key1}, 42, "memo stores value"
assert_ok exists $memo_test{key1}, "memo key exists"
assert_false exists $memo_test{key2}, "memo missing key"

# ══════════════════════════════════════════════════════════════════════════════
# MEMOIZED COLLATZ
# ══════════════════════════════════════════════════════════════════════════════

assert_eq collatz_memo(1), 0, "collatz 1"
assert_eq collatz_memo(2), 1, "collatz 2"
assert_eq collatz_memo(6), 8, "collatz 6"
assert_eq collatz_memo(27), 111, "collatz 27"

assert_eq collatz_memo(6), 8, "collatz 6 cached"

# ══════════════════════════════════════════════════════════════════════════════
# COMBINED MEMOIZATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq nth_fibonacci_memo(15), 610, "nth fib memo 15"
assert_eq sum_fibs_memo(10), 143, "sum fibs 1..10"

assert_eq count_primes_memo(20), 8, "count primes <= 20"
assert_eq count_primes_memo(50), 15, "count primes <= 50"
assert_eq count_primes_memo(100), 25, "count primes <= 100"

# ══════════════════════════════════════════════════════════════════════════════
# PURE FUNCTION CALLS
# ══════════════════════════════════════════════════════════════════════════════

my $add_fn = fn($a, $b) { $a + $b }
assert_eq $add_fn(1, 2), 3, "add 1+2"
assert_eq $add_fn(3, 4), 7, "add 3+4"
assert_eq $add_fn(0, 0), 0, "add 0+0"

test_run
