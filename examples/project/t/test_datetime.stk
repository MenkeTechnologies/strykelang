#!/usr/bin/env stryke
# t/test_datetime.stk — date and time utilities

# Current time (just verify they return something reasonable)
my $now = time
assert_gt $now, 0, "time() returns positive"
my $now_ms = now_ms
assert_gt $now_ms, 0, "now_ms returns positive"
my $now_us = now_us
assert_gt $now_us, 0, "now_us returns positive"
my $epoch = unix_epoch
assert_gt $epoch, 1600000000, "epoch after 2020"

# Leap year detection
assert_ok is_leap_year 2000, "2000 is leap"
assert_ok is_leap_year 2024, "2024 is leap"
assert_false is_leap_year 1900, "1900 not leap"
assert_false is_leap_year 2023, "2023 not leap"

# Days in month (month, year order)
assert_eq days_in_month(2024, 1), 31, "jan has 31 days"
assert_eq days_in_month(2024, 2), 29, "feb 2024 leap has 29"
assert_eq days_in_month(2023, 2), 28, "feb 2023 has 28"
assert_eq days_in_month(2024, 4), 30, "apr has 30 days"

# Month names
assert_eq month_name(1), "January", "month 1 = January"
assert_eq month_name(12), "December", "month 12 = December"
assert_eq month_short(1), "Jan", "month 1 short = Jan"
assert_eq month_short(12), "Dec", "month 12 short = Dec"

# Weekday names
assert_eq weekday_name(0), "Sunday", "weekday 0 = Sunday"
assert_eq weekday_name(1), "Monday", "weekday 1 = Monday"
assert_eq weekday_name(6), "Saturday", "weekday 6 = Saturday"
assert_eq weekday_short(0), "Sun", "weekday 0 short = Sun"
assert_eq weekday_short(6), "Sat", "weekday 6 short = Sat"

# Quarter
assert_eq quarter_of(1), 1, "jan is Q1"
assert_eq quarter_of(3), 1, "mar is Q1"
assert_eq quarter_of(4), 2, "apr is Q2"
assert_eq quarter_of(7), 3, "jul is Q3"
assert_eq quarter_of(10), 4, "oct is Q4"
assert_eq quarter_of(12), 4, "dec is Q4"

test_run
