#!/usr/bin/env stryke
# t/test_array_advanced.stk — advanced array/list operations

# Sorting
my @nums = (3, 1, 4, 1, 5, 9, 2, 6)
my @sorted = sorted(@nums)
assert_eq join(",", @sorted), "1,1,2,3,4,5,6,9", "sorted"
my @sorted_desc = sorted_desc(@nums)
assert_eq join(",", @sorted_desc), "9,6,5,4,3,2,1,1", "sorted_desc"

# Sorting checks
assert_ok is_sorted(1, 2, 3, 4, 5), "1..5 is sorted"
assert_ok is_sorted(1, 1, 2, 2, 3), "with dupes is sorted"
assert_false is_sorted(1, 3, 2), "1,3,2 is not sorted"
assert_ok is_sorted_desc(5, 4, 3, 2, 1), "5..1 is sorted desc"
assert_false is_sorted_desc(1, 2, 3), "1,2,3 is not sorted desc"

# Search operations
assert_eq index_of(3, 1, 2, 3, 4, 3), 2, "index_of first 3"
assert_eq last_index_of(3, 1, 2, 3, 4, 3), 4, "last_index_of 3"
assert_eq index_of(9, 1, 2, 3), -1, "index_of not found"

my @positions = positions_of(3, 1, 3, 2, 3, 4, 3)
assert_eq scalar(@positions), 3, "positions_of count"
assert_eq $positions[0], 1, "positions_of first"
assert_eq $positions[2], 5, "positions_of last"

# Binary search (on sorted array)
assert_eq binary_search(5, 1, 2, 3, 4, 5, 6, 7), 4, "bsearch found"
assert_lt binary_search(99, 1, 2, 3, 4, 5), 0, "bsearch not found"

# First/last with value
assert_eq first_eq(2, 1, 2, 3, 2, 4), 2, "first_eq"
assert_eq last_eq(2, 1, 2, 3, 2, 4), 2, "last_eq"

# Length operations
assert_eq longest("a", "abc", "ab"), "abc", "longest string"
assert_eq shortest("abc", "a", "ab"), "a", "shortest string"

# Set operations
my @union = array_union([1, 2, 3], [3, 4, 5])
assert_eq scalar(@union), 5, "union count"
my @intersect = array_intersection([1, 2, 3, 4], [3, 4, 5, 6])
assert_eq join(",", sort(@intersect)), "3,4", "intersection"
my @diff = array_difference([1, 2, 3, 4], [3, 4, 5])
assert_eq join(",", sort(@diff)), "1,2", "difference"
my @sym_diff = symmetric_diff([1, 2, 3], [3, 4, 5])
assert_eq scalar(@sym_diff), 4, "symmetric_diff count"

# Subset/superset
assert_ok is_subset([1, 2], [1, 2, 3, 4]), "1,2 subset of 1,2,3,4"
assert_false is_subset([1, 5], [1, 2, 3, 4]), "1,5 not subset"
assert_ok is_superset([1, 2, 3, 4], [1, 2]), "superset"
assert_ok is_permutation([1, 2, 3], [3, 1, 2]), "is permutation"
assert_false is_permutation([1, 2, 3], [1, 2, 4]), "not permutation"

# Grouping and batching
my @batched = batch(2, 1, 2, 3, 4, 5)
assert_eq scalar(@batched), 3, "batch count"
assert_eq scalar(@{$batched[0]}), 2, "batch 0 size"
assert_eq scalar(@{$batched[2]}), 1, "batch 2 size (remainder)"

my @grouped = group_of_n(3, 1, 2, 3, 4, 5, 6, 7, 8, 9)
assert_eq scalar(@grouped), 3, "group_of_n count"
assert_eq join(",", @{$grouped[0]}), "1,2,3", "group 0"
assert_eq join(",", @{$grouped[2]}), "7,8,9", "group 2"

# Repeat/cycle
my @cycled = repeat_list(3, 1, 2)
assert_eq join(",", @cycled), "1,2,1,2,1,2", "repeat_list"

# Distinct count
assert_eq distinct_count(1, 2, 2, 3, 3, 3), 3, "distinct_count"

# Type checks
assert_ok is_pair([1, 2]), "2-element is pair"
assert_false is_pair([1]), "1-element not pair"
assert_ok is_triple([1, 2, 3]), "3-element is triple"
assert_false is_triple([1, 2]), "2-element not triple"
assert_ok is_empty_arr([]), "empty array"
assert_false is_empty_arr([1]), "non-empty array"

# Run-length encoding
my @rle = run_length_encode("a", "a", "a", "b", "b", "c")
assert_eq scalar(@rle), 3, "rle groups"
my @decoded = run_length_decode(@rle)
assert_eq join(",", @decoded), "a,a,a,b,b,c", "rle roundtrip"

# Sliding pairs
my @pairs = sliding_pairs(1, 2, 3, 4)
assert_eq scalar(@pairs), 3, "sliding_pairs count"
assert_eq join(",", @{$pairs[0]}), "1,2", "sliding pair 0"
assert_eq join(",", @{$pairs[2]}), "3,4", "sliding pair 2"

# Consecutive equal
assert_ok consecutive_eq(1, 1, 1), "all consecutive eq"
assert_false consecutive_eq(1, 2, 2), "not all consecutive eq"

test_run
