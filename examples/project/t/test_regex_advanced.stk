# t/test_regex_advanced.stk — advanced regex tests

require "./lib/regex_advanced.stk"

# ══════════════════════════════════════════════════════════════════════════════
# BASIC MATCHING
# ══════════════════════════════════════════════════════════════════════════════

assert_eq match_simple(), 1, "match simple"
assert_eq match_start(), 1, "match start"
assert_eq match_end(), 1, "match end"
assert_eq match_full(), 1, "match full"
assert_eq match_none(), 0, "match none"

assert_eq match_dot(), 1, "match dot"
assert_eq match_star(), 1, "match star"
assert_eq match_plus(), 1, "match plus"
assert_eq match_question(), 1, "match question"

# ══════════════════════════════════════════════════════════════════════════════
# CHARACTER CLASSES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq class_digit(), 1, "class digit"
assert_eq class_word(), 1, "class word"
assert_eq class_space(), 1, "class space"
assert_eq class_not_digit(), 1, "class not digit"
assert_eq class_not_word(), 1, "class not word"
assert_eq class_not_space(), 1, "class not space"

assert_eq class_range(), 1, "class range"
assert_eq class_negated(), 1, "class negated"
assert_eq class_multiple(), 1, "class multiple"

# ══════════════════════════════════════════════════════════════════════════════
# QUANTIFIERS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq quant_exact(), 1, "quant exact"
assert_eq quant_range(), 1, "quant range"
assert_eq quant_min(), 1, "quant min"
assert_eq quant_max(), 1, "quant max"

assert_eq quant_greedy(), 1, "quant greedy"
assert_eq quant_nongreedy(), 1, "quant nongreedy"

# ══════════════════════════════════════════════════════════════════════════════
# CAPTURES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq capture_simple(), 1, "capture simple"
assert_eq capture_second(), 1, "capture second"
assert_eq capture_nested(), 1, "capture nested"
assert_eq capture_in_subst(), 1, "capture in subst"
assert_eq capture_digit_backrefs(), 1, "capture digit backrefs"

# ══════════════════════════════════════════════════════════════════════════════
# FLAGS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq flag_case_insensitive(), 1, "flag case insensitive"
assert_eq flag_global_count(), 3, "flag global count"
assert_eq flag_multiline(), 1, "flag multiline"
assert_eq flag_dotall(), 1, "flag dotall"

# ══════════════════════════════════════════════════════════════════════════════
# SUBSTITUTION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq subst_simple(), "hello there", "subst simple"
assert_eq subst_global(), "bbb", "subst global"
assert_eq subst_case_insensitive(), "hi", "subst case insensitive"
assert_eq subst_empty(), "heo", "subst empty"
assert_eq subst_backrefs(), "[hello] [world]", "subst backrefs"
assert_eq subst_no_match(), 1, "subst no match"
assert_eq subst_returns_count(), 3, "subst returns count"

# ══════════════════════════════════════════════════════════════════════════════
# TRANSLITERATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq tr_simple(), "HELLO", "tr simple"
assert_eq tr_partial(), "hEllO", "tr partial"
assert_eq tr_count(), 2, "tr count"
# tr///s not fully implemented
# assert_eq tr_squeeze(), "helo", "tr squeeze"

# ══════════════════════════════════════════════════════════════════════════════
# SPLIT WITH REGEX
# ══════════════════════════════════════════════════════════════════════════════

assert_eq split_regex_ws(), 2, "split regex ws"
assert_eq split_regex_delim(), "a|b|c", "split regex delim"
assert_eq split_regex_limit(), 2, "split regex limit"
# capture in split returns captures too
assert_ok split_regex_capture() > 2, "split regex capture"

# ══════════════════════════════════════════════════════════════════════════════
# MATCH IN LIST CONTEXT
# ══════════════════════════════════════════════════════════════════════════════

assert_eq match_list_context(), 2, "match list context"
assert_eq match_list_first(), 1, "match list first"
assert_eq match_list_all(), "1,2,3", "match list all"

# ══════════════════════════════════════════════════════════════════════════════
# ALTERNATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq alt_simple(), 1, "alt simple"
assert_eq alt_second(), 1, "alt second"
assert_eq alt_none(), 0, "alt none"
assert_eq alt_grouped(), 1, "alt grouped"
assert_eq alt_multiple(), 1, "alt multiple"

# ══════════════════════════════════════════════════════════════════════════════
# WORD BOUNDARIES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq boundary_word_start(), 1, "boundary word start"
assert_eq boundary_word_end(), 1, "boundary word end"
assert_eq boundary_whole_word(), 1, "boundary whole word"
assert_eq boundary_not(), 1, "boundary not"

# ══════════════════════════════════════════════════════════════════════════════
# ANCHORS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq anchor_start(), 1, "anchor start"
assert_eq anchor_end(), 1, "anchor end"
assert_eq anchor_both(), 1, "anchor both"
assert_eq anchor_multiline_start(), 1, "anchor multiline start"
assert_eq anchor_multiline_end(), 1, "anchor multiline end"

# ══════════════════════════════════════════════════════════════════════════════
# ESCAPING
# ══════════════════════════════════════════════════════════════════════════════

assert_eq escape_dot(), 1, "escape dot"
assert_eq escape_star(), 1, "escape star"
assert_eq escape_plus(), 1, "escape plus"
assert_eq escape_question(), 1, "escape question"
assert_eq escape_paren(), 1, "escape paren"
assert_eq escape_bracket(), 1, "escape bracket"

# ══════════════════════════════════════════════════════════════════════════════
# COMMON PATTERNS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq pattern_number(), 1, "pattern number"
assert_eq pattern_float(), 1, "pattern float"
assert_eq pattern_hex(), 1, "pattern hex"
assert_eq pattern_word(), 1, "pattern word"
assert_eq pattern_email_simple(), 1, "pattern email simple"
assert_eq pattern_date(), 1, "pattern date"
assert_eq pattern_time(), 1, "pattern time"
assert_eq pattern_ip(), 1, "pattern ip"

# ══════════════════════════════════════════════════════════════════════════════
# REGEX CAPTURE RESULTS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq regex_capture_result(), 1, "regex capture result"
assert_eq regex_capture_values(), "hello-world", "regex capture values"
# $1 may remain from previous match - stryke doesn't reset
assert_eq regex_no_capture(), 1, "regex no capture"

# ══════════════════════════════════════════════════════════════════════════════
# EDGE CASES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq empty_pattern_match(), 1, "empty pattern match"
assert_eq empty_string_match(), 1, "empty string match"
assert_eq unicode_match(), 1, "unicode match"
assert_eq newline_match(), 1, "newline match"
assert_eq tab_match(), 1, "tab match"
assert_eq subst_preserves_original(), 1, "subst preserves original"

test_run
