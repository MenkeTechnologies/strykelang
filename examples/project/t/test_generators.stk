#!/usr/bin/env stryke
# t/test_generators.stk — test lazy generators

require "./lib/generators.stk"

# ── Project::Generators::range10_12_gen ──────────────────────────────────────────────────
val $rg = Project::Generators::range10_12_gen()
val $n1 = $rg->next()
assert_eq $n1->[0], 10, "Project::Generators::range10_12_gen 1"
assert_eq $n1->[1], 1, "Project::Generators::range10_12_gen 1 more"

val $n2 = $rg->next()
assert_eq $n2->[0], 11, "Project::Generators::range10_12_gen 2"

val $n3 = $rg->next()
assert_eq $n3->[0], 12, "Project::Generators::range10_12_gen 3"

val $n4 = $rg->next()
assert_false $n4->[1], "Project::Generators::range10_12_gen exhausted"

# ── Project::Generators::simple_fib_gen ─────────────────────────────────────────────────
val $fg = Project::Generators::simple_fib_gen()
val @fibs = Project::Generators::take_gen(5, $fg)
assert_eq join(",", @fibs), "0,1,1,2,3", "Project::Generators::simple_fib_gen take 5"

test_run
