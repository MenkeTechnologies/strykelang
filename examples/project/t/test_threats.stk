#!/usr/bin/env stryke
# t/test_threats.stk — threat analysis tests

require "./lib/threats.stk"

# Mock data: healthy system
val $sys = { hostname => "test", os => "linux", cpus => 8, ram => "16GB", ram_bytes => 16000000000, uptime => "1d", uptime_sec => 86400 }
val $net = { ipv4 => "192.168.1.100", mac => "aa:bb:cc:dd:ee:ff", gateway => "192.168.1.1", dns => "8.8.8.8" }
val @disks = ({ mount => "/", use_pct => 45, total => 500000000000, used => 225000000000, free_h => "275 GB free" })

val @threats = Project::Threats::analyze_threats($sys, $net, \@disks, 8000000000)
assert_eq $threats[0]->{level}, "OK", "healthy system is OK"

# Mock: disk almost full
val @bad_disks = ({ mount => "/", use_pct => 97, total => 500000000000, used => 485000000000, free_h => "15 GB free" })
val @disk_threats = Project::Threats::analyze_threats($sys, $net, \@bad_disks, 8000000000)
assert_eq $disk_threats[0]->{level}, "HIGH", "97% disk is HIGH"
assert_contains $disk_threats[0]->{message}, "critical", "critical message"

# Mock: no gateway
val $bad_net = { ipv4 => "192.168.1.100", mac => "aa:bb:cc:dd:ee:ff", gateway => "unknown", dns => "8.8.8.8" }
val @net_threats = Project::Threats::analyze_threats($sys, $bad_net, \@disks, 8000000000)
val @high = grep { _->{level} eq "HIGH" } @net_threats
assert_gt len(@high), 0, "no gateway is HIGH"

# Mock: long uptime
val $old_sys = { %$sys, uptime_sec => 60 * 86400 }
val @up_threats = Project::Threats::analyze_threats($old_sys, $net, \@disks, 8000000000)
val @warns = grep { _->{level} eq "WARN" } @up_threats
assert_gt len(@warns), 0, "60 day uptime is WARN"

test_run
