# t/test_file_ops.stk — file operation tests

require "./lib/file_ops.stk"

# ══════════════════════════════════════════════════════════════════════════════
# SLURP
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::slurp_self(), 1, "slurp self"
assert_eq Project::FileOps::slurp_has_content(), 1, "slurp has content"
assert_eq Project::FileOps::slurp_missing(), 1, "slurp missing"

# ══════════════════════════════════════════════════════════════════════════════
# SPEW
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::spew_and_read(), "hello world", "spew and read"
assert_eq Project::FileOps::spew_overwrite(), "second", "spew overwrite"
# Perl-correct: trailing empty stripped when LIMIT omitted, 3 lines.
assert_eq Project::FileOps::spew_multiline(), 3, "spew multiline"
assert_eq Project::FileOps::spew_empty(), 0, "spew empty"

# ══════════════════════════════════════════════════════════════════════════════
# FILE TEST OPERATORS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::file_exists_true(), 1, "file exists true"
assert_eq Project::FileOps::file_exists_false(), 0, "file exists false"
assert_eq Project::FileOps::file_is_file(), 1, "file is file"
assert_eq Project::FileOps::file_is_dir(), 1, "file is dir"
assert_eq Project::FileOps::file_is_readable(), 1, "file is readable"
assert_eq Project::FileOps::file_is_writable(), 1, "file is writable"
assert_eq Project::FileOps::test_file_has_size(), 1, "file size"
assert_eq Project::FileOps::dir_not_file(), 1, "dir not file"
assert_eq Project::FileOps::file_not_dir(), 1, "file not dir"

# ══════════════════════════════════════════════════════════════════════════════
# GLOB
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::glob_lib_files(), 1, "glob lib files"
assert_eq Project::FileOps::glob_test_files(), 1, "glob test files"
assert_eq Project::FileOps::glob_no_match(), 0, "glob no match"
assert_eq Project::FileOps::glob_single(), 1, "glob single"

# ══════════════════════════════════════════════════════════════════════════════
# STAT
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::stat_file(), 1, "stat file"
assert_eq Project::FileOps::stat_size(), 1, "stat size"
assert_eq Project::FileOps::stat_missing(), 0, "stat missing"

# ══════════════════════════════════════════════════════════════════════════════
# UNLINK
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::unlink_created(), 1, "unlink created"
assert_eq Project::FileOps::unlink_missing(), 1, "unlink missing"

# ══════════════════════════════════════════════════════════════════════════════
# MKDIR / RMDIR
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::mkdir_and_rmdir(), 1, "mkdir and rmdir"
assert_eq Project::FileOps::mkdir_exists(), 1, "mkdir exists"

# ══════════════════════════════════════════════════════════════════════════════
# CWD
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::cwd_defined(), 1, "cwd defined"
assert_eq Project::FileOps::cwd_not_empty(), 1, "cwd not empty"
assert_eq Project::FileOps::cwd_contains_project(), 1, "cwd contains project"

# ══════════════════════════════════════════════════════════════════════════════
# BASENAME / DIRNAME
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::basename_simple(), "baz.txt", "basename simple"
assert_eq Project::FileOps::basename_no_path(), "file.txt", "basename no path"
assert_eq Project::FileOps::basename_trailing_slash(), "bar", "basename trailing slash"

assert_eq Project::FileOps::dirname_simple(), "/foo/bar", "dirname simple"
assert_eq Project::FileOps::dirname_no_path(), ".", "dirname no path"
assert_eq Project::FileOps::dirname_root(), "/", "dirname root"

# ══════════════════════════════════════════════════════════════════════════════
# OPEN / CLOSE / READ / WRITE
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::open_read_close(), 1, "open read close"
assert_eq Project::FileOps::open_write_close(), 1, "open write close"
assert_eq Project::FileOps::open_append(), 1, "open append"

# ══════════════════════════════════════════════════════════════════════════════
# LINES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::lines_count(), 3, "lines count"
assert_eq Project::FileOps::lines_content(), 1, "lines content"
assert_eq Project::FileOps::lines_empty_file(), 0, "lines empty file"

# ══════════════════════════════════════════════════════════════════════════════
# TEMP FILE OPERATIONS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::temp_write_read(), 1, "temp write read"
assert_eq Project::FileOps::temp_binary_like(), 1, "temp binary like"

# ══════════════════════════════════════════════════════════════════════════════
# PATH OPERATIONS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::path_join_manual(), 1, "path join manual"
assert_eq Project::FileOps::path_cwd_is_absolute(), 1, "path cwd is absolute"
assert_eq Project::FileOps::path_basename_ext(), 1, "path basename ext"

# ══════════════════════════════════════════════════════════════════════════════
# RENAME / COPY
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::rename_file(), 1, "rename file"
assert_eq Project::FileOps::copy_file(), 1, "copy file"

# ══════════════════════════════════════════════════════════════════════════════
# FIND FILES
# ══════════════════════════════════════════════════════════════════

assert_eq Project::FileOps::find_lib_via_glob(), 1, "find lib via glob"
assert_eq Project::FileOps::find_test_via_glob(), 1, "find test via glob"

test_run
