# t/test_iterators.stk — iterator and loop tests

require "./lib/iterators.stk"

# ══════════════════════════════════════════════════════════════════════════════
# FOR LOOPS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::for_range_sum(), 15, "for range sum"
assert_eq Project::Iterators::for_array_sum(), 60, "for array sum"
assert_eq Project::Iterators::for_default_var(), 6, "for default var"
assert_eq Project::Iterators::for_nested(), 9, "for nested"
assert_eq Project::Iterators::for_with_last(), 15, "for with last"
assert_eq Project::Iterators::for_with_next(), 9, "for with next"

# ══════════════════════════════════════════════════════════════════════════════
# WHILE LOOPS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::while_count(), 5, "while count"
assert_eq Project::Iterators::while_with_last(), 5, "while with last"
assert_eq Project::Iterators::while_with_next(), 25, "while with next"
assert_eq Project::Iterators::while_decrement(), 5, "while decrement"

# ══════════════════════════════════════════════════════════════════════════════
# UNTIL LOOPS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::until_count(), 5, "until count"
assert_eq Project::Iterators::until_with_last(), 5, "until with last"

# ══════════════════════════════════════════════════════════════════════════════
# RANGE OPERATOR
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::range_ascending(), "1,2,3,4,5", "range ascending"
assert_eq Project::Iterators::range_single(), 1, "range single"
assert_eq Project::Iterators::range_empty(), 0, "range empty"
assert_eq Project::Iterators::range_negative(), "-2,-1,0,1,2", "range negative"
assert_eq Project::Iterators::range_in_for(), 10, "range in for"
assert_eq Project::Iterators::range_chars(), "abcde", "range chars"

# ══════════════════════════════════════════════════════════════════════════════
# KEYS/VALUES/EACH
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::keys_count(), 3, "keys count"
assert_eq Project::Iterators::keys_iterate(), 30, "keys iterate"
assert_eq Project::Iterators::values_count(), 3, "values count"
assert_eq Project::Iterators::values_sum(), 6, "values sum"
assert_eq Project::Iterators::test_keys_sorted(), "a,b,c", "keys sorted"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY ITERATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::array_for_each(), 15, "array for each"
assert_eq Project::Iterators::array_for_index(), 60, "array for index"
assert_eq Project::Iterators::array_postfix_for(), 6, "array postfix for"
assert_eq Project::Iterators::array_reverse_iter(), "3,2,1", "array reverse iter"

# ══════════════════════════════════════════════════════════════════════════════
# MAP AS ITERATOR
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::map_transform(), "2,4,6", "map transform"
assert_eq Project::Iterators::map_filter_combo(), "6,8,10", "map filter combo"
assert_eq Project::Iterators::map_with_index(), "a0,b1,c2", "map with index"
assert_eq Project::Iterators::map_flatten(), 6, "map flatten"

# ══════════════════════════════════════════════════════════════════════════════
# GREP AS ITERATOR
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::grep_filter(), "2,4,6", "grep filter"
assert_eq Project::Iterators::grep_regex(), "apple,banana,date", "grep regex"
assert_eq Project::Iterators::grep_defined(), 3, "grep defined"
assert_eq Project::Iterators::grep_first(), 5, "grep first"

# ══════════════════════════════════════════════════════════════════════════════
# SORT ITERATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::sort_numeric_iter(), "1,1,3,4,5", "sort numeric iter"
assert_eq Project::Iterators::sort_reverse_iter(), "3,2,1", "sort reverse iter"
assert_eq Project::Iterators::sort_string_iter(), "apple,banana,cherry", "sort string iter"
assert_eq Project::Iterators::sort_by_field(), 1, "sort by field"

# ══════════════════════════════════════════════════════════════════════════════
# LOOP CONTROL
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::last_immediate(), 1, "last immediate"
assert_eq Project::Iterators::next_skip_all(), 0, "next skip all"
# redo can cause issues, skip for now
# assert_eq Project::Iterators::redo_limited(), 5, "redo limited"
assert_eq Project::Iterators::labeled_last(), 1, "labeled last"
assert_eq Project::Iterators::labeled_next(), 3, "labeled next"

# ══════════════════════════════════════════════════════════════════════════════
# COMPLEX ITERATION
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::Iterators::nested_array_iter(), 21, "nested array iter"
assert_eq Project::Iterators::hash_of_arrays_iter(), 10, "hash of arrays iter"
assert_eq Project::Iterators::collect_matching(), "2,4,6,8,10", "collect matching"
assert_eq Project::Iterators::transform_in_place(), "2,4,6", "transform in place"

test_run
