#!/usr/bin/env stryke
# Demo + regression test for BUG-260 / BUG-261 — loop labels containing
# digits used to silently drop next/last/redo, and `redo if EXPR;`
# statement-modifier form used to fail to parse.

# BUG-260: digit-containing label routes `next` correctly.
fn Demo::Labels::next_with_digit_label() {
    var @hits
    LOOP1: for val $i (1:3) {
        for val $j (1:3) {
            next LOOP1 if $j == 2
            push @hits, "$i.$j"
        }
    }
    join(",", @hits)
}
Demo::Labels::next_with_digit_label() |> assert_eq("1.1,2.1,3.1", "next LOOP1 with digit")

# BUG-260: `last` with a digit label exits the outer loop.
fn Demo::Labels::last_with_digit_label() {
    var @hits
    A1: for val $i (1:5) {
        for val $j (1:5) {
            last A1 if $i == 2 && $j == 3
            push @hits, "$i.$j"
        }
    }
    join(",", @hits)
}
Demo::Labels::last_with_digit_label() |> assert_eq(
    "1.1,1.2,1.3,1.4,1.5,2.1,2.2",
    "last A1 stops at 2.3"
)

# Letter-only labels still work (control).
fn Demo::Labels::letter_label() {
    var @hits
    OUTER: for val $i (1:3) {
        for val $j (1:3) {
            next OUTER if $j == 2
            push @hits, "$i.$j"
        }
    }
    join(",", @hits)
}
Demo::Labels::letter_label() |> assert_eq("1.1,2.1,3.1", "next OUTER no-digit form")

# BUG-261: `redo if EXPR;` statement-modifier form parses and executes.
fn Demo::Redo::counted() {
    var $i = 0
    var @log
    for val $x (1:2) {
        $i++
        push @log, $i
        redo if $i < 4
    }
    join(",", @log)
}
Demo::Redo::counted() |> assert_eq("1,2,3,4,5", "redo if EXPR; runs body again")

# `redo unless` postfix form too.
fn Demo::Redo::counted_unless() {
    var $i = 0
    var @log
    for val $x (1:2) {
        $i++
        push @log, $i
        redo unless $i >= 4
    }
    join(",", @log)
}
Demo::Redo::counted_unless() |> assert_eq("1,2,3,4,5", "redo unless EXPR; works")

# Labelled redo with a digit label.
fn Demo::Redo::labelled() {
    var @hits
    var $n = 0
    INNER1: for val $i (1:3) {
        push @hits, $i
        $n++
        redo INNER1 if $n < 5
    }
    join(",", @hits)
}
Demo::Redo::labelled() |> assert_eq("1,1,1,1,1,2,3", "redo INNER1 with digit label")

test_run
