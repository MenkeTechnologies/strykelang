#!/usr/bin/env stryke
# t/test_strings_advanced_impl.stk — advanced string algorithms tests

require "./lib/strings_advanced_impl.stk"

# ── Project::StringsAdvancedImpl::adv_levenshtein ─────
assert_eq Project::StringsAdvancedImpl::adv_levenshtein("kitten", "sitting"), 3, "levenshtein(kitten, sitting)"
assert_eq Project::StringsAdvancedImpl::adv_levenshtein("flaw", "lawn"), 2, "levenshtein(flaw, lawn)"
assert_eq Project::StringsAdvancedImpl::adv_levenshtein("abc", "abc"), 0, "levenshtein(abc, abc)"
assert_eq Project::StringsAdvancedImpl::adv_levenshtein("", "abc"), 3, "levenshtein('', abc)"

# ── Project::StringsAdvancedImpl::adv_lcs ─────
assert_eq Project::StringsAdvancedImpl::adv_lcs("abcde", "ace"), 3, "lcs(abcde, ace)"
assert_eq Project::StringsAdvancedImpl::adv_lcs("abc", "def"), 0, "lcs(abc, def)"
assert_eq Project::StringsAdvancedImpl::adv_lcs("aggtab", "gxtxayb"), 4, "lcs(aggtab, gxtxayb)"

# ── Project::StringsAdvancedImpl::adv_is_anagram ─────
assert_ok Project::StringsAdvancedImpl::adv_is_anagram("Listen", "Silent"), "Listen/Silent is anagram"
assert_ok Project::StringsAdvancedImpl::adv_is_anagram("Dormitory", "Dirty Room"), "Dormitory/Dirty Room is anagram"
assert_false Project::StringsAdvancedImpl::adv_is_anagram("Hello", "World"), "Hello/World is not anagram"

# ── Project::StringsAdvancedImpl::adv_word_frequency ─────
val $f = Project::StringsAdvancedImpl::adv_word_frequency("Hello world, hello!")
assert_eq $f->{hello}, 2, "freq(hello)"
assert_eq $f->{world}, 1, "freq(world)"
assert_false defined($f->{missing}), "freq(missing)"

test_run
