# t/test_arrays_extended.stk — comprehensive array tests

require "./lib/arrays_extended.stk"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY CREATION
# ══════════════════════════════════════════════════════════════════════════════

val @list = Project::ArraysExtended::arr_from_list()
assert_eq len(@list), 5, "from list count"
assert_eq $list[0], 1, "from list first"
assert_eq $list[4], 5, "from list last"

val @range = Project::ArraysExtended::arr_from_range()
assert_eq len(@range), 10, "from range count"
assert_eq $range[0], 1, "from range first"
assert_eq $range[9], 10, "from range last"

val @qw = Project::ArraysExtended::arr_from_qw()
assert_eq len(@qw), 3, "from qw count"
assert_eq $qw[0], "one", "from qw first"

val @empty = Project::ArraysExtended::arr_empty()
assert_eq len(@empty), 0, "empty count"

val @single = Project::ArraysExtended::arr_single()
assert_eq len(@single), 1, "single count"
assert_eq $single[0], 42, "single value"

val @flat = Project::ArraysExtended::arr_nested_flatten()
assert_eq len(@flat), 4, "nested flatten count"

# ══════════════════════════════════════════════════════════════════════════════
# PUSH AND POP
# ══════════════════════════════════════════════════════════════════════════════

val @push1 = Project::ArraysExtended::arr_push_one()
assert_eq len(@push1), 4, "push one count"
assert_eq $push1[3], 4, "push one value"

val @push_many = Project::ArraysExtended::arr_push_many()
assert_eq len(@push_many), 5, "push many count"

val @push_arr = Project::ArraysExtended::arr_push_array()
assert_eq len(@push_arr), 4, "push array count"

val @pop_res = Project::ArraysExtended::arr_pop()
assert_eq $pop_res[0], 3, "pop value"
assert_eq $pop_res[1], 2, "pop remaining"

assert_eq Project::ArraysExtended::arr_pop_empty(), 0, "pop empty undef"

# ══════════════════════════════════════════════════════════════════════════════
# SHIFT AND UNSHIFT
# ══════════════════════════════════════════════════════════════════════════════

val @shift_res = Project::ArraysExtended::arr_shift()
assert_eq $shift_res[0], 1, "shift value"
assert_eq $shift_res[1], 2, "shift remaining"

assert_eq Project::ArraysExtended::arr_shift_empty(), 0, "shift empty undef"

val @unshift1 = Project::ArraysExtended::arr_unshift_one()
assert_eq len(@unshift1), 3, "unshift one count"
assert_eq $unshift1[0], 1, "unshift one first"

val @unshift_many = Project::ArraysExtended::arr_unshift_many()
assert_eq len(@unshift_many), 5, "unshift many count"
assert_eq $unshift_many[0], 1, "unshift many first"

# ══════════════════════════════════════════════════════════════════════════════
# SPLICE
# ══════════════════════════════════════════════════════════════════════════════

val @Project::ListOps::splice_remove = Project::ArraysExtended::arr_splice_remove()
assert_eq $Project::ListOps::splice_remove[0], "2,3", "splice remove removed"
assert_eq $Project::ListOps::splice_remove[1], "1,4,5", "splice remove remaining"

val @Project::ListOps::splice_insert = Project::ArraysExtended::arr_splice_insert()
assert_eq len(@Project::ListOps::splice_insert), 5, "splice insert count"
assert_eq join(",", @Project::ListOps::splice_insert), "1,2,3,4,5", "splice insert result"

val @Project::ListOps::splice_replace = Project::ArraysExtended::arr_splice_replace()
assert_eq join(",", @Project::ListOps::splice_replace), "1,a,b,5", "splice replace"

val @splice_end = Project::ArraysExtended::arr_splice_delete_to_end()
assert_eq $splice_end[0], "3,4,5", "splice end removed"
assert_eq $splice_end[1], "1,2", "splice end remaining"

# ══════════════════════════════════════════════════════════════════════════════
# SLICES
# ══════════════════════════════════════════════════════════════════════════════

val @slice_idx = Project::ArraysExtended::arr_slice_indices()
assert_eq join(",", @slice_idx), "20,40", "slice indices"

val @slice_range = Project::ArraysExtended::arr_slice_range()
assert_eq join(",", @slice_range), "2,3,4,5", "slice range"

val @slice_neg = Project::ArraysExtended::arr_slice_negative()
assert_eq join(",", @slice_neg), "4,5", "slice negative"

val @slice_assign = Project::ArraysExtended::arr_slice_assign()
assert_eq $slice_assign[1], 20, "slice assign 1"
assert_eq $slice_assign[3], 40, "slice assign 3"

# ══════════════════════════════════════════════════════════════════════════════
# SORT
# ══════════════════════════════════════════════════════════════════════════════

val @sort_def = Project::ArraysExtended::arr_sort_default()
assert_eq $sort_def[0], "apple", "sort default first"
assert_eq $sort_def[2], "cherry", "sort default last"

val @sort_num = Project::ArraysExtended::arr_sort_numeric()
assert_eq $sort_num[0], 1, "sort numeric first"
assert_eq $sort_num[7], 9, "sort numeric last"

val @sort_rev = Project::ArraysExtended::arr_sort_reverse_numeric()
assert_eq $sort_rev[0], 9, "sort reverse first"
assert_eq $sort_rev[7], 1, "sort reverse last"

val @sort_len = Project::ArraysExtended::arr_sort_by_length()
assert_eq $sort_len[0], "c", "sort by length first"
assert_eq $sort_len[3], "dddd", "sort by length last"

val @sort_ci = Project::ArraysExtended::arr_sort_case_insensitive()
assert_eq $sort_ci[0], "Apple", "sort ci first"

# ══════════════════════════════════════════════════════════════════════════════
# REVERSE
# ══════════════════════════════════════════════════════════════════════════════

val @rev = Project::ArraysExtended::arr_reverse()
assert_eq $rev[0], 5, "reverse first"
assert_eq $rev[4], 1, "reverse last"

val @rev_str = Project::ArraysExtended::arr_reverse_string()
assert_eq join(",", @rev_str), "c,b,a", "reverse string"

val @rev_place = Project::ArraysExtended::arr_reverse_in_place()
assert_eq join(",", @rev_place), "3,2,1", "reverse in place"

# ══════════════════════════════════════════════════════════════════════════════
# MAP AND GREP
# ══════════════════════════════════════════════════════════════════════════════

val @Project::ListOps::map_double = Project::ArraysExtended::arr_map_double()
assert_eq join(",", @Project::ListOps::map_double), "2,4,6,8,10", "map double"

val @map_uc = Project::ArraysExtended::arr_map_transform()
assert_eq join(",", @map_uc), "A,B,C", "map transform"

val @Project::ListOps::grep_even = Project::ArraysExtended::arr_grep_even()
assert_eq join(",", @Project::ListOps::grep_even), "2,4,6", "grep even"

val @grep_def = Project::ArraysExtended::arr_grep_defined()
assert_eq len(@grep_def), 3, "grep defined count"

val @grep_re = Project::ArraysExtended::arr_grep_regex()
assert_eq len(@grep_re), 2, "grep regex count"

assert_eq Project::ArraysExtended::arr_first_match(), 4, "first match"

# ══════════════════════════════════════════════════════════════════════════════
# JOIN AND SPLIT
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ArraysExtended::arr_join_comma(), "1,2,3", "join comma"
assert_eq Project::ArraysExtended::arr_join_empty(), "abc", "join empty"
assert_eq Project::ArraysExtended::arr_join_newline(), "line1\nline2\nline3", "join newline"

val @Project::ListOps::split_comma = Project::ArraysExtended::arr_split_comma()
assert_eq len(@Project::ListOps::split_comma), 3, "split comma count"

val @split_ws = Project::ArraysExtended::arr_split_ws()
assert_eq len(@split_ws), 3, "split ws count"

val @split_lim = Project::ArraysExtended::arr_split_limit()
assert_eq len(@split_lim), 2, "split limit count"
assert_eq $split_lim[1], "b,c,d", "split limit rest"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY FUNCTIONS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ArraysExtended::arr_length(), 5, "length"
assert_eq Project::ArraysExtended::arr_last_index(), 4, "last index"

val @ctx = Project::ArraysExtended::arr_wantarray_context()
assert_eq $ctx[0], 3, "wantarray scalar"

# ══════════════════════════════════════════════════════════════════════════════
# UNIQUE AND DEDUPE
# ══════════════════════════════════════════════════════════════════════════════

val @uniq = Project::ArraysExtended::arr_unique()
assert_eq len(@uniq), 4, "unique count"
assert_eq join(",", @uniq), "1,2,3,4", "unique values"

val @uniq_str = Project::ArraysExtended::arr_unique_strings()
assert_eq len(@uniq_str), 4, "unique strings count"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY UTILITIES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::ArraysExtended::arr_sum(), 15, "sum"
assert_eq Project::ArraysExtended::arr_min(), 1, "min"
assert_eq Project::ArraysExtended::arr_max(), 9, "max"
assert_eq Project::ArraysExtended::arr_any_match(), 1, "any match"
assert_eq Project::ArraysExtended::arr_all_match(), 1, "all match"
assert_eq Project::ArraysExtended::arr_index_of(), 2, "index of"

val @flatten = Project::ArraysExtended::arr_flatten()
assert_eq len(@flatten), 6, "flatten count"
assert_eq join(",", @flatten), "1,2,3,4,5,6", "flatten values"

val @zipped = Project::ArraysExtended::arr_zip()
assert_eq len(@zipped), 6, "zip count"
assert_eq join(",", @zipped), "1,a,2,b,3,c", "zip values"

# ══════════════════════════════════════════════════════════════════════════════
# ADDITIONAL EDGE CASES
# ══════════════════════════════════════════════════════════════════════════════

# Empty array operations
val @e = ()
assert_eq len(@e), 0, "empty scalar"
assert_eq join(",", @e), "", "empty join"

# Single element
val @s = (42)
assert_eq $s[0], 42, "single access"
assert_eq $s[-1], 42, "single neg access"

# Array in boolean
assert_eq @e ? 1 : 0, 0, "empty array false"
assert_eq @s ? 1 : 0, 1, "nonempty array true"

# Array assignment from scalar
val @from_scalar = (5)
assert_eq len(@from_scalar), 1, "from scalar count"

# Nested array flattening
val @n1 = (1, 2)
val @n2 = (@n1, 3, 4)
assert_eq len(@n2), 4, "nested flatten 2"

# Array copy
val @orig = (1, 2, 3)
var @copy = @orig
$copy[0] = 10
assert_eq $orig[0], 1, "copy independent"

# Range in array context
val @r = (1:5)
assert_eq len(@r), 5, "range context count"

test_run
