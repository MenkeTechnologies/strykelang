#!/usr/bin/env stryke
# t/test_parallel.stk — test parallel primitives

# pmap
my @sq = (1..10 |> pmap { $_ ** 2 })
assert_eq scalar(@sq), 10, "pmap count"
my $sq_sum = (@sq |> sum)
assert_eq $sq_sum, 385, "pmap sum of squares"

# pgrep
my @evens = (1..20 |> pgrep { $_ % 2 == 0 })
assert_eq scalar(@evens), 10, "pgrep even count"

# pmaps (streaming)
my @streamed = (range(1, 10) |> pmaps { $_ * 2 })
assert_eq scalar(@streamed), 10, "pmaps count"

# pgreps (streaming)
my @filtered = (range(1, 20) |> pgreps { $_ > 15 })
assert_eq scalar(@filtered), 5, "pgreps count"

# preduce
my $total = (1..100 |> preduce { $a + $b })
assert_eq $total, 5050, "preduce sum"

# pflat_map
my @flat = ((1, 2, 3) |> pflat_map { [$_, $_ * 10] })
assert_eq scalar(@flat), 6, "pflat_map count"

# Chained parallel pipeline
my @chain = (1..50 |> pgrep { $_ % 3 == 0 } |> pmap { $_ * $_ })
assert_eq scalar(@chain), 16, "chained pgrep+pmap count"
my $chain_min = (@chain |> min)
assert_eq $chain_min, 9, "chained min is 3^2"

# Thread pool info
assert_gt thread_count(), 0, "thread count > 0"
assert_gt num_cpus(), 0, "num cpus > 0"

test_run
