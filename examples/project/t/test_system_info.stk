#!/usr/bin/env stryke
# t/test_system_info.stk — system information builtins

# OS info
my $os = os_name()
assert_ok length($os) > 0, "os_name not empty"
assert_ok $os =~ /^(macos|linux|windows|freebsd|openbsd|netbsd)$/i, "os_name recognized"

my $arch = os_arch()
assert_ok length($arch) > 0, "os_arch not empty"
assert_ok $arch =~ /^(x86_64|aarch64|arm|i686|x86)$/i, "os_arch recognized"

# CPU count
my $cpus = num_cpus()
assert_gt $cpus, 0, "num_cpus > 0"

# Process info
my $pid = pid()
assert_gt $pid, 0, "pid > 0"

my $ppid = ppid()
assert_gt $ppid, 0, "ppid > 0"

# User info (may fail in some environments)
my $uid_val = uid()
assert_ge $uid_val, 0, "uid >= 0"

my $gid_val = gid()
assert_ge $gid_val, 0, "gid >= 0"

# Directories
my $home = home_dir()
assert_ok length($home) > 0, "home_dir not empty"
assert_ok -d $home, "home_dir exists"

my $tmp = temp_dir()
assert_ok length($tmp) > 0, "temp_dir not empty"
assert_ok -d $tmp, "temp_dir exists"

my $cwd = cwd()
assert_ok length($cwd) > 0, "cwd not empty"
assert_ok -d $cwd, "cwd exists"

# Memory info
my $mem_total = mem_total()
assert_gt $mem_total, 0, "mem_total > 0"

my $mem_free = mem_free()
assert_gt $mem_free, 0, "mem_free > 0"
assert_lt $mem_free, $mem_total, "mem_free < mem_total"

my $mem_used = mem_used()
assert_gt $mem_used, 0, "mem_used > 0"

# Hostname
my $host = gethostname()
assert_ok length($host) > 0, "hostname not empty"

test_run
