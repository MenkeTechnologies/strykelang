#!/usr/bin/env stryke
# t/test_functional_utils.stk — functional programming utilities

# Identity
assert_eq identity(42), 42, "identity number"
assert_eq identity("hello"), "hello", "identity string"

# Argument selectors
my $first = first_arg(1, 2, 3)
assert_eq $first, 1, "first_arg"
my $second = second_arg(1, 2, 3)
assert_eq $second, 2, "second_arg"
my $last = last_arg(1, 2, 3)
assert_eq $last, 3, "last_arg"

# Map, grep, reduce
my @doubled = map { $_ * 2 } 1..5
assert_eq join(",", @doubled), "2,4,6,8,10", "map double"

my @evens = grep { $_ % 2 == 0 } 1..10
assert_eq join(",", @evens), "2,4,6,8,10", "grep evens"

my $sum = reduce { $a + $b } 1..5
assert_eq $sum, 15, "reduce sum"

my $product = reduce { $a * $b } 1..5
assert_eq $product, 120, "reduce product"

# Pipeline operators
my $result = 1..10 |> grep { $_ % 2 == 0 } |> map { $_ * $_ } |> sum
assert_eq $result, 220, "pipeline grep map sum"

# Thread macro
my $threaded = (~> " hello " trim uc)
assert_eq $threaded, "HELLO", "thread trim uc"

# Range of values
my $range = range_of(3, 7, 1, 9, 4)
assert_eq $range, 8, "range_of (9-1)"

test_run
