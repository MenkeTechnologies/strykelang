# t/test_special_vars.stk — special variable tests

require "./lib/special_vars.stk"

# ══════════════════════════════════════════════════════════════════════════════
# $_ DEFAULT VARIABLE
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::default_in_for(), "1,2,3", "default in for"
assert_eq Project::SpecialVars::default_in_map(), "2,4,6", "default in map"
assert_eq Project::SpecialVars::default_in_grep(), 3, "default in grep"
assert_eq Project::SpecialVars::default_explicit_set(), "hello", "default explicit set"
assert_eq Project::SpecialVars::default_in_regex(), 1, "default in regex"
assert_eq Project::SpecialVars::default_in_subst(), "world", "default in subst"

# ══════════════════════════════════════════════════════════════════════════════
# @_ ARGUMENTS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::args_count(), 3, "args count"
assert_eq Project::SpecialVars::args_first(), "first", "args first"
assert_eq Project::SpecialVars::args_all(), "1,2,3", "args all"
assert_eq Project::SpecialVars::args_shift_style(), 30, "args shift style"
assert_eq Project::SpecialVars::args_modify(), 1, "args modify"

# ══════════════════════════════════════════════════════════════════════════════
# %ENV ENVIRONMENT
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::env_exists(), 1, "env exists"
assert_eq Project::SpecialVars::env_home(), 1, "env home"
assert_eq Project::SpecialVars::env_set_get(), 1, "env set get"
assert_eq Project::SpecialVars::test_env_keys(), 1, "env keys"

# ══════════════════════════════════════════════════════════════════════════════
# $0 PROGRAM NAME
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::prog_name_defined(), 1, "prog name defined"
assert_eq Project::SpecialVars::prog_name_not_empty(), 1, "prog name not empty"

# ══════════════════════════════════════════════════════════════════════════════
# $$ PROCESS ID
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::pid_positive(), 1, "pid positive"
assert_eq Project::SpecialVars::pid_numeric(), 1, "pid numeric"

# ══════════════════════════════════════════════════════════════════════════════
# $@ ERROR VARIABLE
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::error_after_eval_fail(), 1, "error after eval fail"
assert_eq Project::SpecialVars::error_after_eval_success(), 1, "error after eval success"
assert_eq Project::SpecialVars::error_cleared(), 1, "error cleared"

# ══════════════════════════════════════════════════════════════════════════════
# $! ERRNO
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::errno_after_bad_open(), 1, "errno after bad open"

# ══════════════════════════════════════════════════════════════════════════════
# $? CHILD STATUS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::child_status_after_system(), 1, "child status after system"

# ══════════════════════════════════════════════════════════════════════════════
# @ARGV COMMAND LINE ARGS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::argv_is_array(), 1, "argv is array"
assert_eq Project::SpecialVars::argv_count(), 1, "argv count"

# ══════════════════════════════════════════════════════════════════════════════
# CAPTURE GROUPS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::capture_1(), 1, "capture 1"
assert_eq Project::SpecialVars::capture_2(), 1, "capture 2"
assert_eq Project::SpecialVars::capture_multiple(), 1, "capture multiple"

# ══════════════════════════════════════════════════════════════════════════════
# SEPARATORS
# ══════════════════════════════════════════════════════════════════════════════

# local $" may not work - skip for now
# assert_eq Project::SpecialVars::list_separator(), 1, "list separator"

# ══════════════════════════════════════════════════════════════════════════════
# INPUT/OUTPUT SEPARATORS
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::input_sep_default(), 1, "input sep default"
assert_eq Project::SpecialVars::output_sep_default(), 1, "output sep default"

# ══════════════════════════════════════════════════════════════════════════════
# LINE/FILE
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::line_number(), 1, "line number"
assert_eq Project::SpecialVars::file_name(), 1, "file name"

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY LAST INDEX
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::array_last_index(), 1, "array last index"
# $#a = N may not work
# assert_eq Project::SpecialVars::array_last_index_modify(), 1, "array last index modify"

# ══════════════════════════════════════════════════════════════════════════════
# VERSION VARIABLES
# ══════════════════════════════════════════════════════════════════════════════

assert_eq Project::SpecialVars::perl_version(), 1, "perl version"
assert_eq Project::SpecialVars::test_os_name(), 1, "os name"

test_run
