#!/usr/bin/env stryke
# t/test_oop.stk — tests for classes, methods, structs, enums

require "./lib/oop.stk"

# ── Basic struct ───────────────────────────────────────────────────

my $p1 = make_point(3, 4)
assert_eq $p1->x, 3, "point x"
assert_eq $p1->y, 4, "point y"

my $p2 = make_point(0, 0)
assert_near calc_distance($p2, $p1), 5.0, 0.001, "point distance"

my $p3 = point_add($p1, make_point(1, 1))
assert_eq $p3->x, 4, "point add x"
assert_eq $p3->y, 5, "point add y"

my $p4 = point_scale($p1, 2)
assert_eq $p4->x, 6, "point scale x"
assert_eq $p4->y, 8, "point scale y"

# ── Struct with defaults ───────────────────────────────────────────

my $rect = make_rect(10, 5)
assert_eq $rect->width, 10, "rect width"
assert_eq $rect->height, 5, "rect height"
assert_eq rect_area($rect), 50, "rect area"
assert_eq rect_perimeter($rect), 30, "rect perimeter"
assert_false rect_is_square($rect), "rect not square"

my $square = make_rect(5, 5)
assert_ok rect_is_square($square), "rect is square"

# ── Nested structs ─────────────────────────────────────────────────

my $circle = make_circle(0, 0, 5)
assert_eq $circle->radius, 5, "circle radius"
assert_eq $circle->center->x, 0, "circle center x"

my $inside = make_point(2, 2)
my $outside = make_point(10, 10)
assert_ok circle_contains_point($circle, $inside), "point inside circle"
assert_false circle_contains_point($circle, $outside), "point outside circle"

assert_near circle_area($circle), 78.54, 0.01, "circle area"

# ── Struct with computed fields ────────────────────────────────────

my $person = make_person("Alice", 25)
assert_eq $person->name, "Alice", "person name"
assert_eq $person->age, 25, "person age"
assert_eq person_greet($person), "Hello, my name is Alice", "person greet"
assert_ok person_is_adult($person), "person is adult"

my $child = make_person("Bob", 10)
assert_false person_is_adult($child), "child not adult"

my $older = person_birthday($person)
assert_eq $older->age, 26, "person birthday"
assert_eq $older->name, "Alice", "birthday keeps name"

# ── Enum basics ────────────────────────────────────────────────────

my $red = Color::Red()
my $green = Color::Green()
my $blue = Color::Blue()

assert_eq color_name($red), "red", "color red"
assert_eq color_name($green), "green", "color green"
assert_eq color_name($blue), "blue", "color blue"

assert_ok is_primary($red), "red is primary"
assert_ok is_primary($green), "green is primary"

# ── Status enum ────────────────────────────────────────────────────

my $pending = Status::Pending()
my $running = Status::Running()
my $done = Status::Done()
my $failed = Status::Failed()

assert_eq status_name($pending), "pending", "status pending"
assert_eq status_name($running), "running", "status running"
assert_eq status_name($done), "done", "status done"
assert_eq status_name($failed), "failed", "status failed"

assert_false status_is_complete($pending), "pending not complete"
assert_false status_is_complete($running), "running not complete"
assert_ok status_is_complete($done), "done is complete"
assert_ok status_is_complete($failed), "failed is complete"

# ── Builder pattern ────────────────────────────────────────────────

my $builder = config_builder()
$builder = config_with_host($builder, "example.com")
$builder = config_with_port($builder, 3000)
my $config = config_build($builder)

assert_eq $config->host, "example.com", "config host"
assert_eq $config->port, 3000, "config port"
assert_eq $config->timeout, 30, "config timeout default"

# ── Complex struct operations ──────────────────────────────────────

my $v1 = vec3_new(1, 2, 3)
my $v2 = vec3_new(4, 5, 6)

assert_eq $v1->x, 1, "vec3 x"
assert_eq $v1->y, 2, "vec3 y"
assert_eq $v1->z, 3, "vec3 z"

my $sum = vec3_add($v1, $v2)
assert_eq $sum->x, 5, "vec3 add x"
assert_eq $sum->y, 7, "vec3 add y"
assert_eq $sum->z, 9, "vec3 add z"

assert_eq vec3_dot($v1, $v2), 32, "vec3 dot"

my $unit = vec3_new(1, 0, 0)
assert_near vec3_length($unit), 1.0, 0.001, "vec3 unit length"

my $norm = vec3_normalize(vec3_new(3, 0, 0))
assert_near $norm->x, 1.0, 0.001, "vec3 normalize x"
assert_near $norm->y, 0.0, 0.001, "vec3 normalize y"
