#!/usr/bin/env stryke
# t/test_collections_extended.stk — extended collection utility tests

require "./lib/collections_extended.stk"

# ── Project::CollectionsExtended::ext_flatten ─────
my @flat = Project::CollectionsExtended::ext_flatten(1, [2, [3, 4]], 5)
assert_eq join(",", @flat), "1,2,3,4,5", "Project::CollectionsExtended::ext_flatten"

# ── Project::CollectionsExtended::ext_zip ─────
my @a = (1, 2, 3)
my @b = ("a", "b", "c")
my @zipped = Project::CollectionsExtended::ext_zip(\@a, \@b)
assert_eq scalar(@zipped), 3, "zip count"
assert_eq $zipped[0][0], 1, "zip 0 a"
assert_eq $zipped[0][1], "a", "zip 0 b"
assert_eq $zipped[2][0], 3, "zip 2 a"
assert_eq $zipped[2][1], "c", "zip 2 b"

# ── Project::CollectionsExtended::ext_rotate ─────
my @r1 = Project::CollectionsExtended::ext_rotate(1, 1, 2, 3, 4)
assert_eq join(",", @r1), "4,1,2,3", "rotate 1"
my @r2 = Project::CollectionsExtended::ext_rotate(2, 1, 2, 3, 4)
assert_eq join(",", @r2), "3,4,1,2", "rotate 2"
my @r3 = Project::CollectionsExtended::ext_rotate(-1, 1, 2, 3, 4)
assert_eq join(",", @r3), "2,3,4,1", "rotate -1"

# ── Project::CollectionsExtended::ext_list_is_empty ─────
assert_false Project::CollectionsExtended::ext_list_is_empty(1), "Project::CollectionsExtended::ext_list_is_empty false"


# ── Project::CollectionsExtended::ext_is_empty_hash ─────
assert_ok Project::CollectionsExtended::ext_is_empty_hash({}), "Project::CollectionsExtended::ext_is_empty_hash true"
assert_false Project::CollectionsExtended::ext_is_empty_hash({a => 1}), "Project::CollectionsExtended::ext_is_empty_hash false"

# ── Project::CollectionsExtended::ext_first_where ─────
my $f = Project::CollectionsExtended::ext_first_where(fn { $_0 > 5 }, 1, 10, 2, 20)
assert_eq $f, 10, "Project::CollectionsExtended::ext_first_where"
my $f2 = Project::CollectionsExtended::ext_first_where(fn { $_0 > 100 }, 1, 10, 2, 20)
assert_false defined($f2), "Project::CollectionsExtended::ext_first_where not found"

# ── Project::CollectionsExtended::ext_last_where ─────
my $l = Project::CollectionsExtended::ext_last_where(fn { $_0 > 5 }, 1, 10, 2, 20)
assert_eq $l, 20, "Project::CollectionsExtended::ext_last_where"

test_run
