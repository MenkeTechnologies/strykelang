#!/usr/bin/env stryke
# t/test_git.stk — git builtin tests

my $root = undef
eval {
    $root = git_root()
}

if (!defined $root) {
    p "Not a git repo, skipping git tests."
    exit(0)
}

# ── Git Repository Info ───────────────────────────────────────────

assert_ok defined($root), "git_root is defined"
assert_ok -d $root, "git_root is a directory"

my @branches = git_branches()
assert_gt scalar(@branches), 0, "has branches"

my @head_branch = grep { _->{is_head} } @branches
assert_eq scalar(@head_branch), 1, "has exactly one HEAD branch"
assert_ok defined($head_branch[0]->{name}), "head branch has a name"

# ── Git Log and History ───────────────────────────────────────────

my @log = git_log(10)
assert_gt scalar(@log), 0, "has commit log"
if (scalar(@log) > 0) {
    assert_ok defined($log[0]->{sha}), "first commit has sha"
    assert_ok defined($log[0]->{author}), "first commit has author"
    assert_ok defined($log[0]->{message}), "first commit has message"
}

# ── Git Files ─────────────────────────────────────────────────────

my @files = git_files()
assert_gt scalar(@files), 0, "has tracked files"

# ── Git Authors ───────────────────────────────────────────────────

my @authors = git_authors()
assert_gt scalar(@authors), 0, "has authors"
if (scalar(@authors) > 0) {
    assert_ok defined($authors[0]->{name}), "first author has name"
    assert_gt $authors[0]->{commits}, 0, "first author has commit count"
}

test_run
