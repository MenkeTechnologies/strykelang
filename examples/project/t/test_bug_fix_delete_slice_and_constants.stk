#!/usr/bin/env stryke
# Demo + regression test for:
#  - BUG-042 / BUG-043: `delete @arr[indices]` / `delete @h{KEYS}` slice forms
#  - BUG-064: `PI` / `TAU` / `E` constants
#  - The open-FH parser carve-out so the new `E` constant doesn't
#    shadow Perl's `open E, ...` literal-filehandle idiom.

# BUG-042: delete array slice.
val @xa = (10, 20, 30, 40, 50)
val @gone = delete @xa[1, 3]
join(",", @gone) |> assert_eq("20,40", "delete @xa[1,3] returns removed")
# slots 1 and 3 are undef now; others intact.
join(",", map { defined($_) ? $_ : "U" } @xa)
    |> assert_eq("10,U,30,U,50", "delete leaves undef slots")

# Range form.
val @xb = (1..6)
delete @xb[1..3]
join(",", map { defined($_) ? $_ : "U" } @xb)
    |> assert_eq("1,U,U,U,5,6", "delete @xb[1..3] range")

# BUG-043: delete hash slice with literal keys.
val %h = (a => 1, b => 2, c => 3, d => 4)
val @removed = delete @h{qw(a c)}
join(",", sort @removed) |> assert_eq("1,3", "delete @h{qw(a c)} returns values")
join(",", sort keys %h) |> assert_eq("b,d", "remaining keys")

# Delete with array-var keys (interop with BUG-028).
val %h2 = (alice => 1, bob => 2, carol => 3, dave => 4)
val @drop = ("alice", "carol")
delete @h2{@drop}
join(",", sort keys %h2) |> assert_eq("bob,dave", "delete @h{@arr} drops keys")

# BUG-064: uppercase math constants.
(abs(PI() - 3.14159) < 0.01)  |> assert_ok("PI is ~3.14159")
(abs(TAU() - 6.28318) < 0.01) |> assert_ok("TAU is ~2*pi")
(abs(E() - 2.71828) < 0.01)   |> assert_ok("E is ~Euler")
(PI() * 2 == TAU())            |> assert_ok("TAU == 2*PI")

# Lowercase aliases continue to work.
(pi == PI)                 |> assert_ok("pi == PI")
(tau == TAU)               |> assert_ok("tau == TAU")
(euler_e == E)             |> assert_ok("euler_e == E")

# Open-FH parser carve-out: `open E, ...` uses the literal handle name,
# NOT the Euler constant.
val $tmp = "/tmp/stryke_bug_fix_open_E_demo.txt"
open E, ">", $tmp; print E "data\n"; close E
var $body = `cat $tmp`
chomp $body
$body |> assert_eq("data", "open E ... writes via handle, not constant 2.718...")
unlink $tmp

# Same protection for PI / TAU as filehandle names.
val $tmp2 = "/tmp/stryke_bug_fix_open_PI_demo.txt"
open PI, ">", $tmp2; print PI "via PI handle\n"; close PI
chomp(val $body2 = `cat $tmp2`)
$body2 |> assert_eq("via PI handle", "open PI ... also fine")
unlink $tmp2

# In expression position, the constants still resolve.
val $area = PI * 5 ** 2
sprintf("%.4f", $area) |> assert_eq("78.5398", "PI usable in math after open carve-out")

test_run
