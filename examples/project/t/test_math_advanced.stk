#!/usr/bin/env stryke
# t/test_math_advanced.stk — advanced math library tests

require "./lib/math_advanced.stk"

# ── adv_prime_factors ─────
my @pf12 = adv_prime_factors(12)
assert_eq join(",", @pf12), "2,2,3", "adv_prime_factors(12)"
my @pf28 = adv_prime_factors(28)
assert_eq join(",", @pf28), "2,2,7", "adv_prime_factors(28)"
my @pf13 = adv_prime_factors(13)
assert_eq join(",", @pf13), "13", "adv_prime_factors(13)"
my @pf1 = adv_prime_factors(1)
assert_eq scalar(@pf1), 0, "adv_prime_factors(1)"

# ── adv_is_perfect ─────
assert_ok adv_is_perfect(6), "6 is perfect"
assert_ok adv_is_perfect(28), "28 is perfect"
assert_false adv_is_perfect(10), "10 not perfect"
assert_false adv_is_perfect(1), "1 not perfect"

# ── adv_combinations ─────
assert_eq adv_combinations(5, 2), 10, "5C2"
assert_eq adv_combinations(10, 3), 120, "10C3"
assert_eq adv_combinations(5, 0), 1, "5C0"
assert_eq adv_combinations(5, 5), 1, "5C5"

# ── adv_permutations ─────
assert_eq adv_permutations(5, 2), 20, "5P2"
assert_eq adv_permutations(10, 3), 720, "10P3"
assert_eq adv_permutations(5, 0), 1, "5P0"
assert_eq adv_permutations(5, 5), 120, "5P5"

# ── adv_factorial ─────
assert_eq adv_factorial(0), 1, "0!"
assert_eq adv_factorial(5), 120, "5!"

# ── adv_gcd ─────
assert_eq adv_gcd(12, 18), 6, "gcd(12,18)"
assert_eq adv_gcd(13, 17), 1, "gcd(13,17)"

# ── adv_lcm ─────
assert_eq adv_lcm(12, 18), 36, "lcm(12,18)"
assert_eq adv_lcm(13, 17), 221, "lcm(13,17)"

# ── adv_gcd_many ─────
assert_eq adv_gcd_many(12, 18, 24), 6, "gcd_many(12,18,24)"
assert_eq adv_gcd_many(13, 17, 19), 1, "gcd_many(13,17,19)"

# ── adv_lcm_many ─────
assert_eq adv_lcm_many(2, 3, 4), 12, "lcm_many(2,3,4)"
assert_eq adv_lcm_many(5, 7, 11), 385, "lcm_many(5,7,11)"

# ── adv_prime_sieve ─────
my @sieve20 = adv_prime_sieve(20)
assert_eq join(",", @sieve20), "2,3,5,7,11,13,17,19", "prime_sieve(20)"

# ── adv_is_prime ─────
assert_ok adv_is_prime(2), "2 is prime"
assert_ok adv_is_prime(17), "17 is prime"
assert_false adv_is_prime(1), "1 not prime"
assert_false adv_is_prime(15), "15 not prime"

# ── Statistics ─────
my @stats_data = (2, 4, 4, 4, 5, 5, 7, 9)
assert_near adv_mean(@stats_data), 5.0, 0.001, "mean"
assert_near adv_median(@stats_data), 4.5, 0.001, "median"
assert_near adv_variance(@stats_data), 4.571, 0.001, "variance"
assert_near adv_stddev(@stats_data), 2.138, 0.001, "stddev"

# ── Linear Regression ─────
my $x_vals = [1, 2, 3, 4, 5]
my $y_vals = [2, 4, 5, 4, 5]
my $reg = adv_linear_regression($x_vals, $y_vals)
# m = (5*70 - 15*20) / (5*55 - 15*15) = (350 - 300) / (275 - 225) = 50 / 50 = 0.6
# b = (20 - 0.6*15) / 5 = (20 - 9) / 5 = 11 / 5 = 2.2
assert_near $reg->[0], 0.6, 0.001, "regression slope"
assert_near $reg->[1], 2.2, 0.001, "regression intercept"

# ── Weighted Mean ─────
my $vals = [10, 20, 30]
my $weights = [1, 2, 3]
# (10*1 + 20*2 + 30*3) / (1+2+3) = (10+40+90) / 6 = 140 / 6 = 23.333
assert_near adv_weighted_mean($vals, $weights), 23.333, 0.001, "weighted mean"

# ── Z-Score ─────
my @z_data = (10, 20, 30, 40, 50)
# mean=30, variance=((20^2 + 10^2 + 0 + 10^2 + 20^2) / 4) = (400+100+0+100+400)/4 = 1000/4 = 250
# stddev = sqrt(250) = 15.811
# z(50) = (50-30)/15.811 = 20/15.811 = 1.265
assert_near adv_z_score(50, @z_data), 1.265, 0.001, "z-score of 50"

test_run
