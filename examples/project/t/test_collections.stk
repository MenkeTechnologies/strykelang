#!/usr/bin/env stryke
# t/test_collections.stk — collection utility tests

require "./lib/collections.stk"

# ── Set operations ───────────────────────────────────────────────────

val @xa = (1, 2, 3, 4)
val @xb = (3, 4, 5, 6)

val @union = Project::Collections::union_sets(\@xa, \@xb)
assert_eq len(@union), 6, "set union size"

val @inter = Project::Collections::intersect_sets(\@xa, \@xb)
assert_eq len(@inter), 2, "set intersect size"

val @diff = Project::Collections::diff_sets(\@xa, \@xb)
assert_eq len(@diff), 2, "set diff size"

# Built-in set()
val @s = set(1, 1, 2, 2, 3, 3)
assert_eq len(@s), 3, "set dedup"

# ── Hash utilities ───────────────────────────────────────────────────

# Flip hash
val $inv = Project::Collections::flip_hash(red => "#ff0000", green => "#00ff00")
assert_eq $inv->{"#ff0000"}, "red", "Project::PipelineAdvanced::flip hash"

# Select keys
val $source = { a => 1, b => 2, c => 3, d => 4 }
val $picked = Project::Collections::extract_keys($source, "a", "c")
assert_eq $picked->{a}, 1, "select a"
assert_eq $picked->{c}, 3, "select c"
assert_false exists($picked->{b}), "select excludes b"

# Transform values
val $nums = { x => 1, y => 2, z => 3 }
val $doubled = Project::Collections::apply_to_values($nums, fn { _0 * 2 })
assert_eq $doubled->{x}, 2, "transform values x"
assert_eq $doubled->{z}, 6, "transform values z"

# ── Higher-order functions ───────────────────────────────────────────

# Compose
val $add1 = fn { _0 + 1 }
val $times3 = fn { _0 * 3 }
val $add1_then_times3 = Project::Collections::compose_fns($times3, $add1)
assert_eq $add1_then_times3(4), 15, "compose (4+1)*3=15"

# Apply pipeline
val $result = Project::Collections::apply_pipeline(2, fn { _0 + 3 }, fn { _0 * 4 }, fn { _0 - 1 })
assert_eq $result, 19, "Project::Collections::apply_pipeline (2+3)*4-1=19"

# Count occurrences
val $tallied = Project::Collections::count_occurrences(qw(a b a c a b))
assert_eq len(@$tallied), 3, "tally pair count"
# Find the 'a' entry
var $found_a = 0
for val $pair (@$tallied) {
    if ($pair->[0] eq "a") {
        $found_a = $pair->[1]
    }
}
assert_eq $found_a, 3, "tally a=3"

# Split chunks
val @chunks = Project::Collections::split_chunks(3, 1, 2, 3, 4, 5, 6, 7)
assert_eq len(@chunks), 3, "chunk count"
assert_eq len(@{$chunks[0]}), 3, "chunk first size"
assert_eq len(@{$chunks[2]}), 1, "chunk last size (remainder)"

test_run
