#!/usr/bin/env stryke
# t/test_collections.stk — collection utility tests

require "./lib/collections.stk"

# ── Set operations ───────────────────────────────────────────────────

my @a = (1, 2, 3, 4)
my @b = (3, 4, 5, 6)

my @union = union_sets(\@a, \@b)
assert_eq scalar(@union), 6, "set union size"

my @inter = intersect_sets(\@a, \@b)
assert_eq scalar(@inter), 2, "set intersect size"

my @diff = diff_sets(\@a, \@b)
assert_eq scalar(@diff), 2, "set diff size"

# Built-in set()
my @s = set(1, 1, 2, 2, 3, 3)
assert_eq scalar(@s), 3, "set dedup"

# ── Hash utilities ───────────────────────────────────────────────────

# Flip hash
my $inv = flip_hash(red => "#ff0000", green => "#00ff00")
assert_eq $inv->{"#ff0000"}, "red", "flip hash"

# Select keys
my $source = { a => 1, b => 2, c => 3, d => 4 }
my $picked = extract_keys($source, "a", "c")
assert_eq $picked->{a}, 1, "select a"
assert_eq $picked->{c}, 3, "select c"
assert_false exists($picked->{b}), "select excludes b"

# Transform values
my $nums = { x => 1, y => 2, z => 3 }
my $doubled = apply_to_values($nums, sub { $_[0] * 2 })
assert_eq $doubled->{x}, 2, "transform values x"
assert_eq $doubled->{z}, 6, "transform values z"

# ── Higher-order functions ───────────────────────────────────────────

# Compose
my $add1 = sub { $_[0] + 1 }
my $times3 = sub { $_[0] * 3 }
my $add1_then_times3 = compose_fns($times3, $add1)
assert_eq $add1_then_times3->(4), 15, "compose (4+1)*3=15"

# Apply pipeline
my $result = apply_pipeline(2, sub { $_[0] + 3 }, sub { $_[0] * 4 }, sub { $_[0] - 1 })
assert_eq $result, 19, "apply_pipeline (2+3)*4-1=19"

# Count occurrences
my $tallied = count_occurrences(qw(a b a c a b))
assert_eq scalar(@$tallied), 3, "tally pair count"
# Find the 'a' entry
my $found_a = 0
for my $pair (@$tallied) {
    if ($pair->[0] eq "a") {
        $found_a = $pair->[1]
    }
}
assert_eq $found_a, 3, "tally a=3"

# Split chunks
my @chunks = split_chunks(3, 1, 2, 3, 4, 5, 6, 7)
assert_eq scalar(@chunks), 3, "chunk count"
assert_eq scalar(@{$chunks[0]}), 3, "chunk first size"
assert_eq scalar(@{$chunks[2]}), 1, "chunk last size (remainder)"

test_run
