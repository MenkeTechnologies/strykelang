# lib/builtins_core.stk — core builtin function tests

# ══════════════════════════════════════════════════════════════════════════════
# DEFINED
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::defined_scalar_set { val $x = 1; defined($x) ? 1 : 0 }
fn Project::BuiltinsCore::defined_scalar_zero { val $x = 0; defined($x) ? 1 : 0 }
fn Project::BuiltinsCore::defined_scalar_empty { val $x = ""; defined($x) ? 1 : 0 }
fn Project::BuiltinsCore::defined_scalar_undef { val $x; defined($x) ? 1 : 0 }
fn Project::BuiltinsCore::defined_after_undef { var $x = 1; $x = undef; defined($x) ? 1 : 0 }

fn Project::BuiltinsCore::defined_array_elem_exists { val @xa = (1, 2, 3); defined($xa[1]) ? 1 : 0 }
fn Project::BuiltinsCore::defined_array_elem_missing { val @xa = (1, 2, 3); defined($xa[10]) ? 1 : 0 }
fn Project::BuiltinsCore::defined_array_elem_undef { val @xa = (1, undef, 3); defined($xa[1]) ? 1 : 0 }

fn Project::BuiltinsCore::defined_hash_key_exists { val %h = (a => 1); defined($h{a}) ? 1 : 0 }
fn Project::BuiltinsCore::defined_hash_key_missing { val %h = (a => 1); defined($h{z}) ? 1 : 0 }
fn Project::BuiltinsCore::defined_hash_key_undef { val %h = (a => undef); defined($h{a}) ? 1 : 0 }

fn Project::BuiltinsCore::defined_expr_result { defined(1 + 1) ? 1 : 0 }
fn Project::BuiltinsCore::defined_string_result { defined("hello") ? 1 : 0 }
fn Project::BuiltinsCore::defined_sub_result { defined(fn { 1 }) ? 1 : 0 }

# ══════════════════════════════════════════════════════════════════════════════
# REF
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::ref_scalar { val $x = 1; ref(\$x) }
fn Project::BuiltinsCore::ref_array { val @xa = (1, 2); ref(\@xa) }
fn Project::BuiltinsCore::ref_hash { val %h = (a => 1); ref(\%h) }
fn Project::BuiltinsCore::ref_code { val $f = fn { 1 }; ref($f) }
fn Project::BuiltinsCore::ref_anon_array { ref([1, 2, 3]) }
fn Project::BuiltinsCore::ref_anon_hash { ref({a => 1}) }

fn Project::BuiltinsCore::ref_not_ref { val $x = 1; ref($x) eq "" ? 1 : 0 }
fn Project::BuiltinsCore::ref_string { val $s = "hello"; ref($s) eq "" ? 1 : 0 }
fn Project::BuiltinsCore::ref_number { ref(42) eq "" ? 1 : 0 }

fn Project::BuiltinsCore::ref_nested_array { val $r = [[1, 2], [3, 4]]; ref($r->[0]) }
fn Project::BuiltinsCore::ref_nested_hash { val $r = {a => {b => 1}}; ref($r->{a}) }

# ══════════════════════════════════════════════════════════════════════════════
# LENGTH
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::length_empty { length("") }
fn Project::BuiltinsCore::length_one { length("a") }
fn Project::BuiltinsCore::length_multi { length("hello") }
fn Project::BuiltinsCore::length_spaces { length("  ") }
fn Project::BuiltinsCore::length_unicode { length("café") }
fn Project::BuiltinsCore::length_newline { length("a\nb") }
fn Project::BuiltinsCore::length_tab { length("a\tb") }

fn Project::BuiltinsCore::length_number { length(12345) }
fn Project::BuiltinsCore::length_float { length(3.14159) }
fn Project::BuiltinsCore::length_negative { length(-42) }

fn Project::BuiltinsCore::length_var {
    val $s = "test"
    length $s}

fn Project::BuiltinsCore::length_concat {
    val $va = "foo"
    val $vb = "bar"
    length($va . $vb)
}

# ══════════════════════════════════════════════════════════════════════════════
# SCALAR
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::scalar_array_count { val @xa = (1, 2, 3, 4, 5); len(@xa) }
fn Project::BuiltinsCore::scalar_array_empty { val @xa = (); len(@xa) }
fn Project::BuiltinsCore::scalar_array_one { val @xa = (42); len(@xa) }

fn Project::BuiltinsCore::scalar_hash_info { val %h = (a => 1, b => 2); len(keys %h) }

fn Project::BuiltinsCore::scalar_string { len("hello") }
fn Project::BuiltinsCore::scalar_number { len(42) }

fn Project::BuiltinsCore::scalar_reverse_str { len(rev("hello")) }
fn Project::BuiltinsCore::scalar_reverse_arr { val @xa = (1, 2, 3); val @r = rev(@xa); len(@r) }

fn Project::BuiltinsCore::scalar_force {
    val @xa = (1, 2, 3)
    val $count = @xa
    $count
}

# ══════════════════════════════════════════════════════════════════════════════
# WANTARRAY
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::returns_context {
    wantarray ? "list" : "scalar"
}

fn Project::BuiltinsCore::wantarray_in_scalar {
    val $x = Project::BuiltinsCore::returns_context()
    $x
}

fn Project::BuiltinsCore::wantarray_in_list {
    val @xa = Project::BuiltinsCore::returns_context()
    $xa[0]
}

fn Project::BuiltinsCore::wantarray_nested {
    val $inner = fn { wantarray ? "list" : "scalar" }
    val $result = $inner()
    $result
}

# ══════════════════════════════════════════════════════════════════════════════
# CALLER
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::caller_basic {
    val @c = caller()
    defined($c[0]) ? 1 : 0
}

fn Project::BuiltinsCore::caller_in_sub {
    val $inner = fn {
        val @c = caller()
        len(@c) > 0 ? 1 : 0
    }
    $inner()
}

# ══════════════════════════════════════════════════════════════════════════════
# EXISTS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::exists_hash_true { val %h = (a => 1, b => 2); exists $h{a} ? 1 : 0 }
fn Project::BuiltinsCore::exists_hash_false { val %h = (a => 1, b => 2); exists $h{z} ? 1 : 0 }
fn Project::BuiltinsCore::exists_hash_undef_val { val %h = (a => undef); exists $h{a} ? 1 : 0 }

fn Project::BuiltinsCore::exists_array_true { val @xa = (1, 2, 3); exists $xa[1] ? 1 : 0 }
fn Project::BuiltinsCore::exists_array_false { val @xa = (1, 2, 3); exists $xa[10] ? 1 : 0 }

fn Project::BuiltinsCore::exists_after_delete {
    var %h = (a => 1, b => 2)
    delete $h{a}
    exists $h{a} ? 1 : 0
}

fn Project::BuiltinsCore::exists_nested {
    val %h = (a => {b => 1})
    exists $h{a}{b} ? 1 : 0
}

# ══════════════════════════════════════════════════════════════════════════════
# DELETE
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::delete_hash_returns {
    var %h = (a => 1, b => 2, c => 3)
    delete $h{b}
}

fn Project::BuiltinsCore::delete_hash_removes {
    var %h = (a => 1, b => 2, c => 3)
    delete $h{b}
    len(keys %h)
}

fn Project::BuiltinsCore::delete_hash_missing {
    var %h = (a => 1)
    val $r = delete $h{z}
    defined($r) ? 1 : 0
}

fn Project::BuiltinsCore::delete_array_elem {
    var @xa = (1, 2, 3, 4, 5)
    val $r = delete $xa[2]
    $r
}

# ══════════════════════════════════════════════════════════════════════════════
# UNDEF
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::undef_returns { defined(undef) ? 1 : 0 }

fn Project::BuiltinsCore::undef_scalar {
    var $x = 42
    $x = undef
    defined($x) ? 1 : 0
}

fn Project::BuiltinsCore::undef_in_list {
    val @xa = (1, undef, 3)
    defined($xa[1]) ? 1 : 0
}

fn Project::BuiltinsCore::undef_comparison {
    val $x
    $x eq "" ? 1 : 0
}

# ══════════════════════════════════════════════════════════════════════════════
# BOOLEAN CONTEXT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::bool_zero { 0 ? 1 : 0 }
fn Project::BuiltinsCore::bool_one { 1 ? 1 : 0 }
fn Project::BuiltinsCore::bool_empty_str { "" ? 1 : 0 }
fn Project::BuiltinsCore::bool_zero_str { "0" ? 1 : 0 }
fn Project::BuiltinsCore::bool_space_str { " " ? 1 : 0 }
fn Project::BuiltinsCore::bool_text { "hello" ? 1 : 0 }
fn Project::BuiltinsCore::bool_undef { val $x; $x ? 1 : 0 }

fn Project::BuiltinsCore::bool_empty_array { val @xa = (); @xa ? 1 : 0 }
fn Project::BuiltinsCore::bool_nonempty_array { val @xa = (1); @xa ? 1 : 0 }

fn Project::BuiltinsCore::bool_negative { -1 ? 1 : 0 }
fn Project::BuiltinsCore::bool_float_zero { 0.0 ? 1 : 0 }
fn Project::BuiltinsCore::bool_float_nonzero { 0.1 ? 1 : 0 }

# ══════════════════════════════════════════════════════════════════════════════
# CHR AND ORD
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::chr_A { chr(65) }
fn Project::BuiltinsCore::chr_a { chr(97) }
fn Project::BuiltinsCore::chr_space { chr(32) }
fn Project::BuiltinsCore::chr_newline { chr(10) }
fn Project::BuiltinsCore::chr_zero { chr(48) }

fn Project::BuiltinsCore::ord_A { ord("A") }
fn Project::BuiltinsCore::ord_a { ord("a") }
fn Project::BuiltinsCore::ord_space { ord(" ") }
fn Project::BuiltinsCore::ord_zero { ord("0") }
fn Project::BuiltinsCore::ord_multi { ord("hello") }

fn Project::BuiltinsCore::chr_ord_roundtrip {
    val $c = "X"
    chr(ord($c)) eq $c ? 1 : 0
}

fn Project::BuiltinsCore::ord_chr_roundtrip {
    val $n = 72
    ord(chr($n)) == $n ? 1 : 0
}

# ══════════════════════════════════════════════════════════════════════════════
# HEX AND OCT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::hex_simple { hex("10") }
fn Project::BuiltinsCore::hex_ff { hex("ff") }
fn Project::BuiltinsCore::hex_FF { hex("FF") }
fn Project::BuiltinsCore::hex_0x { hex("0x10") }
fn Project::BuiltinsCore::hex_zero { hex("0") }

fn Project::BuiltinsCore::oct_simple { oct("10") }
fn Project::BuiltinsCore::oct_777 { oct("777") }
fn Project::BuiltinsCore::oct_zero { oct("0") }

