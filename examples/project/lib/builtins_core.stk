# UC/LC/UCFIRST/LCFIRST
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::uc_lower { uc("hello") }
fn Project::BuiltinsCore::uc_mixed { uc("HeLLo") }
fn Project::BuiltinsCore::uc_already { uc("HELLO") }

fn Project::BuiltinsCore::lc_upper { lc("HELLO") }
fn Project::BuiltinsCore::lc_mixed { lc("HeLLo") }
fn Project::BuiltinsCore::lc_already { lc("hello") }

fn Project::BuiltinsCore::ucfirst_lower { ucfirst("hello") }
fn Project::BuiltinsCore::ucfirst_upper { ucfirst("HELLO") }

fn Project::BuiltinsCore::lcfirst_upper { lcfirst("HELLO") }
fn Project::BuiltinsCore::lcfirst_lower { lcfirst("hello") }

# ══════════════════════════════════════════════════════════════════════════════
# REVERSE
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::reverse_string { rev("hello") }
fn Project::BuiltinsCore::reverse_empty { rev("") }
fn Project::BuiltinsCore::reverse_single { rev("x") }
fn Project::BuiltinsCore::reverse_palindrome { len(rev("radar")) }

fn Project::BuiltinsCore::reverse_array_count {
    val @xa = (1, 2, 3, 4, 5)
    val @r = rev(@xa)
    len @r}

fn Project::BuiltinsCore::reverse_array_first {
    val @xa = (1, 2, 3, 4, 5)
    val @r = rev(@xa)
    $r[0]
}

fn Project::BuiltinsCore::reverse_array_last {
    val @xa = (1, 2, 3, 4, 5)
    val @r = rev(@xa)
    $r[-1]
}

# ══════════════════════════════════════════════════════════════════════════════
# INDEX AND RINDEX
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::index_found { index("hello", "ll") }
fn Project::BuiltinsCore::index_not_found { index("hello", "x") }
fn Project::BuiltinsCore::index_start { index("hello", "h") }
fn Project::BuiltinsCore::index_end { index("hello", "o") }
fn Project::BuiltinsCore::index_empty { index("hello", "") }

fn Project::BuiltinsCore::index_from { index("hello hello", "hello", 1) }

fn Project::BuiltinsCore::rindex_found { rindex("hello hello", "hello") }
fn Project::BuiltinsCore::rindex_not_found { rindex("hello", "x") }
fn Project::BuiltinsCore::rindex_from { rindex("hello hello", "hello", 5) }

# ══════════════════════════════════════════════════════════════════════════════
# SUBSTR
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::substr_basic { substr("hello", 1, 3) }
fn Project::BuiltinsCore::substr_start { substr("hello", 0, 2) }
fn Project::BuiltinsCore::substr_to_end { substr("hello", 2) }
fn Project::BuiltinsCore::substr_negative { substr("hello", -2) }
fn Project::BuiltinsCore::substr_neg_len { substr("hello", 1, -1) }

fn Project::BuiltinsCore::substr_replace {
    var $s = "hello"
    substr($s, 1, 3, "XYZ")
    $s
}

fn Project::BuiltinsCore::substr_beyond { substr("hi", 0, 10) }
