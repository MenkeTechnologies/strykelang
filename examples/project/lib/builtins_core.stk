# INT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::int_positive { int(3.7) }
fn Project::BuiltinsCore::int_negative { int(-3.7) }
fn Project::BuiltinsCore::int_already { int(42) }
fn Project::BuiltinsCore::int_small { int(0.9) }
fn Project::BuiltinsCore::int_zero { int(0.0) }

fn Project::BuiltinsCore::int_string { int("3.14") }
fn Project::BuiltinsCore::int_string_neg { int("-2.9") }

# ══════════════════════════════════════════════════════════════════════════════
# ABS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::abs_positive { abs(42) }
fn Project::BuiltinsCore::abs_negative { abs(-42) }
fn Project::BuiltinsCore::abs_zero { abs(0) }
fn Project::BuiltinsCore::abs_float_pos { abs(3.14) }
fn Project::BuiltinsCore::abs_float_neg { abs(-3.14) }

# ══════════════════════════════════════════════════════════════════════════════
# SQRT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::sqrt_4 { sqrt(4) }
fn Project::BuiltinsCore::sqrt_9 { sqrt(9) }
fn Project::BuiltinsCore::sqrt_2 { int(sqrt(2) * 1000) }
fn Project::BuiltinsCore::sqrt_0 { sqrt(0) }
fn Project::BuiltinsCore::sqrt_1 { sqrt(1) }

# ══════════════════════════════════════════════════════════════════════════════
# PACK AND UNPACK
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::pack_char { pack("A3", "abc") }
fn Project::BuiltinsCore::pack_int { length(pack("N", 12345)) }

fn Project::BuiltinsCore::unpack_char {
    val $s = "hello"
    val @c = unpack("A5", $s)
    $c[0]
}

# ══════════════════════════════════════════════════════════════════════════════
# QUOTEMETA
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::quotemeta_special { quotemeta('a.b') =~ /\\\./ ? 1 : 0 }
fn Project::BuiltinsCore::quotemeta_plain { quotemeta("abc") }
fn Project::BuiltinsCore::quotemeta_star { quotemeta("a*b") =~ /\\\*/ ? 1 : 0 }

# ══════════════════════════════════════════════════════════════════════════════
# LVALUE OPERATIONS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::lvalue_substr {
    var $s = "hello world"
    substr($s, 0, 5, "hi")
    $s
}

fn Project::BuiltinsCore::lvalue_increment {
    var $x = 5
    $x++
    $x
}

fn Project::BuiltinsCore::lvalue_decrement {
    var $x = 5
    $x--
    $x
}

fn Project::BuiltinsCore::lvalue_add_assign {
    var $x = 10
    $x += 5
    $x
}

fn Project::BuiltinsCore::lvalue_concat_assign {
    var $s = "hello"
    $s .= " world"
    $s
}

# ══════════════════════════════════════════════════════════════════════════════
# CHOP AND CHOMP
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::chop_returns {
    var $s = "hello"
    chop $s}

fn Project::BuiltinsCore::chop_modifies {
    var $s = "hello"
    chop $s    $s
}

fn Project::BuiltinsCore::chomp_newline {
    var $s = "hello\n"
    chomp $s    $s
}

fn Project::BuiltinsCore::chomp_no_newline {
    var $s = "hello"
    chomp $s    $s
}

fn Project::BuiltinsCore::chomp_returns {
    var $s = "hello\n"
    chomp $s}

# ══════════════════════════════════════════════════════════════════════════════
# SPRINTF
# ══════════════════════════════════════════════════════════════════════════════

fn Project::BuiltinsCore::sprintf_d { sprintf("%d", 42) }
fn Project::BuiltinsCore::sprintf_s { sprintf("%s", "hello") }
fn Project::BuiltinsCore::sprintf_f { sprintf("%.2f", 3.14159) }
fn Project::BuiltinsCore::sprintf_x { sprintf("%x", 255) }
fn Project::BuiltinsCore::sprintf_X { sprintf("%X", 255) }
fn Project::BuiltinsCore::sprintf_o { sprintf("%o", 8) }
fn Project::BuiltinsCore::sprintf_b { sprintf("%b", 5) }

fn Project::BuiltinsCore::sprintf_padded { sprintf("%5d", 42) }
fn Project::BuiltinsCore::sprintf_zero_pad { sprintf("%05d", 42) }
fn Project::BuiltinsCore::sprintf_left_align { sprintf("%-5d", 42) }

fn Project::BuiltinsCore::sprintf_multi { sprintf("%s=%d", "x", 10) }
fn Project::BuiltinsCore::sprintf_percent { sprintf("%%") }

