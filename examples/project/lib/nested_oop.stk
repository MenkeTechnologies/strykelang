fn Project::NestedOop::team_structure {
    {
        engineering => [
            Person("Alice", 30),
            Person("Bob", 28),
        ],
        marketing => [
            Person("Carol", 35),
        ],
        sales => [
            Person("Dave", 40),
            Person("Eve", 32),
        ],
    }
}

fn Project::NestedOop::count_team_members($structure) {
    var $total = 0
    for val $team (keys %$structure) {
        $total += len(@{$structure->{$team}})
    }
    $total
}

fn Project::NestedOop::get_oldest_in_team($structure, $team) {
    val @members = @{$structure->{$team}}
    var $oldest = $members[0]
    for val $m (@members) {
        if ($m->age > $oldest->age) {
            $oldest = $m
        }
    }
    $oldest
}

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES WITH COLLECTION FIELDS
# ══════════════════════════════════════════════════════════════════════════════

class Team {
    name: Str
    members: Array = []

    fn add_member($person) {
        push @{$self->members}, $person
        $self
    }

    fn size { len(@{$self->members}) }

    fn avg_age {
        var $sum = 0
        for val $m (@{$self->members}) {
            $sum += $m->age
        }
        $sum / $self->size()
    }
}

class Graph {
    nodes: Array = []
    edges: Hash = {}

    fn add_node($id) {
        push @{$self->nodes}, $id
        var $e = $self->edges
        $e->{$id} = []
        $self
    }

    fn add_edge($from, $to) {
        val $e = $self->edges
        val $arr = $e->{$from}
        push @$arr, $to
        $self
    }

    fn neighbors($id) {
        val $e = $self->edges
        @{$e->{$id}}
    }

    fn node_count { len(@{$self->nodes}) }
}

class TaskQueue {
    items: Array = []

    fn enqueue($task) {
        push @{$self->items}, $task
        $self
    }

    fn dequeue {
        shift @{$self->items}
    }

    fn peek {
        $self->items->[0]
    }

    fn is_empty {
        len(@{$self->items}) == 0 ? 1 : 0
    }

    fn size { len(@{$self->items}) }
}

# ══════════════════════════════════════════════════════════════════════════════
# BINARY TREE WITH CLASS NODES
# ══════════════════════════════════════════════════════════════════════════════

fn Project::NestedOop::build_binary_tree {
    TreeNode(
        value => 10,
        left => TreeNode(
            value => 5,
            left => TreeNode(value => 2),
            right => TreeNode(value => 7),
        ),
        right => TreeNode(
            value => 15,
            left => TreeNode(value => 12),
            right => TreeNode(value => 20),
        ),
    )
}

fn Project::NestedOop::tree_sum($node) {
    if (!defined($node)) {
        return 0
    }
    $node->value + Project::NestedOop::tree_sum($node->left) + Project::NestedOop::tree_sum($node->right)
}

fn Project::NestedOop::tree_depth($node) {
    if (!defined($node)) {
        return 0
    }
    val $left_depth = Project::NestedOop::tree_depth($node->left)
    val $right_depth = Project::NestedOop::tree_depth($node->right)
    1 + ($left_depth > $right_depth ? $left_depth : $right_depth)
}

fn Project::NestedOop::tree_to_array($node) {
    if (!defined($node)) {
        return ()
    }
    (Project::NestedOop::tree_to_array($node->left), $node->value, Project::NestedOop::tree_to_array($node->right))
}

