# ENUMS IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

fn priority_queue {
    [Priority::Critical, Priority::High, Priority::Medium, Priority::Low]
}

fn color_palette {
    [Color::Red, Color::Green, Color::Blue]
}

fn status_workflow {
    [Status::Todo, Status::InProgress, Status::Done]
}

fn count_priority($tasks, $target) {
    my $count = 0
    for my $t (@$tasks) {
        my $matches = match ($t->priority) {
            Priority::Critical() => match ($target) { Priority::Critical() => 1, _ => 0 }
            Priority::High() => match ($target) { Priority::High() => 1, _ => 0 }
            Priority::Medium() => match ($target) { Priority::Medium() => 1, _ => 0 }
            Priority::Low() => match ($target) { Priority::Low() => 1, _ => 0 }
            _ => 0
        }
        $count += $matches
    }
    $count
}

