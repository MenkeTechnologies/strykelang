# ══════════════════════════════════════════════════════════════════════════════
# MIXED COLLECTIONS
# ══════════════════════════════════════════════════════════════════════════════

fn mixed_struct_types {
    [
        +{ type => "point", data => Point(1, 2) },
        +{ type => "person", data => Person("Alice", 30) },
        +{ type => "task", data => Task(1, "Test", Priority::High) },
    ]
}

fn process_mixed($items) {
    my @results
    for my $item (@$items) {
        my $result = match ($item->{type}) {
            "point" => "Point(" . $item->{data}->x . "," . $item->{data}->y . ")"
            "person" => "Person:" . $item->{data}->name
            "task" => "Task#" . $item->{data}->id
            _ => "unknown"
        }
        push @results, $result
    }
    @results
}

# ══════════════════════════════════════════════════════════════════════════════
# STRUCT/CLASS TRANSFORMATION PIPELINES
# ══════════════════════════════════════════════════════════════════════════════

fn transform_points($points, $scale, $offset_x, $offset_y) {
    [map {
        Point($_->x * $scale + $offset_x, $_->y * $scale + $offset_y)
    } @$points]
}

fn filter_adults($people) {
    [grep { $_->age >= 18 } @$people]
}

fn sort_by_age($people) {
    [sort { $a->age <=> $b->age } @$people]
}

fn partition_by_age($people, $threshold) {
    my @young
    my @old
    for my $p (@$people) {
        if ($p->age < $threshold) {
            push @young, $p
        } else {
            push @old, $p
        }
    }
    +{ young => [@young], old => [@old] }
}
