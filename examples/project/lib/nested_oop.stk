        ceo => Employee(name => "Alice", department => "Executive", salary => 500000),
        departments => +{
            engineering => +{
                lead => Employee(name => "Bob", department => "Engineering", salary => 200000),
                teams => [
                    Team(name => "Backend")->add_member(Person("Carol", 30))->add_member(Person("Dave", 28)),
                    Team(name => "Frontend")->add_member(Person("Eve", 32))->add_member(Person("Frank", 26)),
                ],
            },
            marketing => +{
                lead => Employee(name => "Grace", department => "Marketing", salary => 180000),
                teams => [
                    Team(name => "Brand")->add_member(Person("Hank", 35)),
                ],
