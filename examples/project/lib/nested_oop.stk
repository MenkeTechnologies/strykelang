fn team_structure {
    +{
        engineering => [
            Person("Alice", 30),
            Person("Bob", 28),
        ],
        marketing => [
            Person("Carol", 35),
        ],
        sales => [
            Person("Dave", 40),
            Person("Eve", 32),
        ],
    }
}

fn count_team_members($structure) {
    my $total = 0
    for my $team (keys %$structure) {
        $total += scalar(@{$structure->{$team}})
    }
    $total
}

fn get_oldest_in_team($structure, $team) {
    my @members = @{$structure->{$team}}
    my $oldest = $members[0]
    for my $m (@members) {
        if ($m->age > $oldest->age) {
            $oldest = $m
        }
    }
    $oldest
}

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES WITH COLLECTION FIELDS
# ══════════════════════════════════════════════════════════════════════════════

class Team {
    name: Str
    members: Array = []

    fn add_member($person) {
        push @{$self->members}, $person
        $self
    }

    fn size { scalar(@{$self->members}) }

    fn avg_age {
        my $sum = 0
        for my $m (@{$self->members}) {
            $sum += $m->age
        }
        $sum / $self->size()
    }
}

class Graph {
    nodes: Array = []
    edges: Hash = {}

    fn add_node($id) {
        push @{$self->nodes}, $id
        my $e = $self->edges
        $e->{$id} = []
        $self
    }

    fn add_edge($from, $to) {
        my $e = $self->edges
        my $arr = $e->{$from}
        push @$arr, $to
        $self
    }

    fn neighbors($id) {
        my $e = $self->edges
        @{$e->{$id}}
    }

    fn node_count { scalar(@{$self->nodes}) }
}

class TaskQueue {
    items: Array = []

    fn enqueue($task) {
        push @{$self->items}, $task
        $self
    }

    fn dequeue {
        shift @{$self->items}
    }

    fn peek {
        $self->items->[0]
    }

    fn is_empty {
        scalar(@{$self->items}) == 0 ? 1 : 0
    }

    fn size { scalar(@{$self->items}) }
}

# ══════════════════════════════════════════════════════════════════════════════
# BINARY TREE WITH CLASS NODES
# ══════════════════════════════════════════════════════════════════════════════

fn build_binary_tree {
    TreeNode(
        value => 10,
        left => TreeNode(
            value => 5,
            left => TreeNode(value => 2),
            right => TreeNode(value => 7),
        ),
        right => TreeNode(
            value => 15,
            left => TreeNode(value => 12),
            right => TreeNode(value => 20),
        ),
    )
}

fn tree_sum($node) {
    if (!defined($node)) {
        return 0
    }
    $node->value + tree_sum($node->left) + tree_sum($node->right)
}

fn tree_depth($node) {
    if (!defined($node)) {
        return 0
    }
    my $left_depth = tree_depth($node->left)
    my $right_depth = tree_depth($node->right)
    1 + ($left_depth > $right_depth ? $left_depth : $right_depth)
}

fn tree_to_array($node) {
    if (!defined($node)) {
        return ()
    }
    (tree_to_array($node->left), $node->value, tree_to_array($node->right))
}

