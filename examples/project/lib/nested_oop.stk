}

fn nested_points {
    [
        [Point(0, 0), Point(1, 0), Point(2, 0)],
        [Point(0, 1), Point(1, 1), Point(2, 1)],
        [Point(0, 2), Point(1, 2), Point(2, 2)],
    ]
}

fn sum_nested_points($grid) {
    my $sum = 0
    for my $row (@$grid) {
        for my $p (@$row) {
            $sum += $p->x + $p->y
        }
    }
    $sum
}

