# lib/nested_oop.stk — classes, structs, enums inside collections

# ══════════════════════════════════════════════════════════════════════════════
# STRUCTS
# ══════════════════════════════════════════════════════════════════════════════

struct Point { x, y }
struct Person { name, age }
struct Task { id, title, priority }
struct Node { value, children }
struct Edge { from, to, weight }

# ══════════════════════════════════════════════════════════════════════════════
# ENUMS
# ══════════════════════════════════════════════════════════════════════════════

enum Priority { Low, Medium, High, Critical }
enum Status { Todo, InProgress, Done, Blocked }
enum Color { Red, Green, Blue }

# ══════════════════════════════════════════════════════════════════════════════
# CLASSES
# ══════════════════════════════════════════════════════════════════════════════

class Employee {
    name: Str
    department: Str
    salary: Int = 0

    fn describe { $self->name . " (" . $self->department . ")" }
}

class Product {
    sku: Str
    name: Str
    price: Int

    fn discount($pct) { Product(sku => $self->sku, name => $self->name, price => int($self->price * (100 - $pct) / 100)) }
}

class TreeNode {
    value: Int
    left: TreeNode = undef
    right: TreeNode = undef

    fn is_leaf { !defined($self->left) && !defined($self->right) }
}

# ══════════════════════════════════════════════════════════════════════════════
# STRUCTS IN ARRAYS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::NestedOop::points_in_array {
    val @points = (
        Point(1, 2),
        Point(3, 4),
        Point(5, 6),
    )
    @points
}

fn Project::NestedOop::points_in_arrayref {
    [Point(10, 20), Point(30, 40), Point(50, 60)]
}

fn Project::NestedOop::sum_point_coords(@points) {
    var $sum = 0
    for val $p (@points) {
        $sum += $p->x + $p->y
    }
    $sum
}

fn Project::NestedOop::map_points_to_distances(@points) {
    map { sqrt(_->x * _->x + _->y * _->y) } @points
}

fn Project::NestedOop::filter_points_in_quadrant(@points) {
    grep { _->x > 0 && _->y > 0 } @points
}

fn Project::NestedOop::sort_points_by_x(@points) {
    sort { $a->x <=> $b->x } @points
}

fn Project::NestedOop::tasks_in_array {
    [
        Task(1, "Setup", Priority::High),
        Task(2, "Build", Priority::Medium),
        Task(3, "Test", Priority::Low),
        Task(4, "Deploy", Priority::Critical),
    ]
}

