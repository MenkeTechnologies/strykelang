fn Project::NestedOop::move_task($board, $task_id, $from_col, $to_col) {
    val @from_tasks = @{$board->{$from_col}}
    var @remaining
    var $moved_task
    for val $t (@from_tasks) {
        if ($t->id == $task_id) {
            $moved_task = $t
        } else {
            push @remaining, $t
        }
    }
    $board->{$from_col} = [@remaining]
    push @{$board->{$to_col}}, $moved_task if defined($moved_task)
    $board
}

fn Project::NestedOop::count_tasks_by_priority($board, $priority) {
    var $count = 0
    for val $col (keys %$board) {
        for val $t (@{$board->{$col}}) {
            val $matches = match ($t->priority) {
                Priority::Critical() => match ($priority) { Priority::Critical() => 1, _ => 0 }
                Priority::High() => match ($priority) { Priority::High() => 1, _ => 0 }
                Priority::Medium() => match ($priority) { Priority::Medium() => 1, _ => 0 }
                Priority::Low() => match ($priority) { Priority::Low() => 1, _ => 0 }
                _ => 0
            }
            $count += $matches
        }
    }
    $count
}

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY OF ARRAYS OF STRUCTS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::NestedOop::matrix_of_points {
    var @matrix
    for val $i (0:2) {
        var @row
        ~> 0:2 ep {
            push @row, Point($i, _)
        }
        push @matrix, [@row]
    }
    [@matrix]
}

fn Project::NestedOop::flatten_point_matrix($matrix) {
    var @flat
    for val $row (@$matrix) {
        ~> @$row ep {
            push @flat, _
        }
    }
    @flat
}

