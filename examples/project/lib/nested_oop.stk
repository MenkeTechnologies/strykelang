fn project_board {
    +{
        todo => [
            Task(1, "Design API", Priority::High),
            Task(2, "Write docs", Priority::Low),
        ],
        in_progress => [
            Task(3, "Implement auth", Priority::Critical),
        ],
        done => [
            Task(4, "Setup CI", Priority::Medium),
            Task(5, "Create repo", Priority::Low),
        ],
    }
}

fn move_task($board, $task_id, $from_col, $to_col) {
    my @from_tasks = @{$board->{$from_col}}
    my @remaining
    my $moved_task
    for my $t (@from_tasks) {
        if ($t->id == $task_id) {
            $moved_task = $t
        } else {
            push @remaining, $t
        }
    }
    $board->{$from_col} = [@remaining]
    push @{$board->{$to_col}}, $moved_task if defined($moved_task)
    $board
}

fn count_tasks_by_priority($board, $priority) {
    my $count = 0
    for my $col (keys %$board) {
        for my $t (@{$board->{$col}}) {
            my $matches = match ($t->priority) {
                Priority::Critical() => match ($priority) { Priority::Critical() => 1, _ => 0 }
                Priority::High() => match ($priority) { Priority::High() => 1, _ => 0 }
                Priority::Medium() => match ($priority) { Priority::Medium() => 1, _ => 0 }
                Priority::Low() => match ($priority) { Priority::Low() => 1, _ => 0 }
                _ => 0
            }
            $count += $matches
        }
    }
    $count
}

# ══════════════════════════════════════════════════════════════════════════════
# ARRAY OF ARRAYS OF STRUCTS
# ══════════════════════════════════════════════════════════════════════════════

fn matrix_of_points {
    my @matrix
    for my $i (0..2) {
        my @row
        for my $j (0..2) {
            push @row, Point($i, $j)
        }
        push @matrix, [@row]
    }
    [@matrix]
}

fn flatten_point_matrix($matrix) {
    my @flat
    for my $row (@$matrix) {
        for my $p (@$row) {
            push @flat, $p
        }
    }
    @flat
}

