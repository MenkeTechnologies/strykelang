# ══════════════════════════════════════════════════════════════════════════════
# MIXED COLLECTIONS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::NestedOop::mixed_struct_types {
    [
        { type => "point", data => Point(1, 2) },
        { type => "person", data => Person("Alice", 30) },
        { type => "task", data => Task(1, "Test", Priority::High) },
    ]
}

fn Project::NestedOop::process_mixed($items) {
    var @results
    for val $item (@$items) {
        val $result = match ($item->{type}) {
            "point" => "Point(" . $item->{data}->x . "," . $item->{data}->y . ")"
            "person" => "Person:" . $item->{data}->name
            "task" => "Task#" . $item->{data}->id
            _ => "unknown"
        }
        push @results, $result
    }
    @results
}

# ══════════════════════════════════════════════════════════════════════════════
# STRUCT/CLASS TRANSFORMATION PIPELINES
# ══════════════════════════════════════════════════════════════════════════════

fn Project::NestedOop::transform_points($points, $scale, $offset_x, $offset_y) {
    [map {
        Point(_->x * $scale + $offset_x, _->y * $scale + $offset_y)
    } @$points]
}

fn Project::NestedOop::filter_adults($people) {
    [grep { _->age >= 18 } @$people]
}

fn Project::NestedOop::sort_by_age($people) {
    [sort { $a->age <=> $b->age } @$people]
}

fn Project::NestedOop::partition_by_age($people, $threshold) {
    var @young
    var @old
    ~> @$people ep {
        if (_->age < $threshold) {
            push @young, _
        } else {
            push @old, _
        }
    }
    { young => [@young], old => [@old] }
}
