# ══════════════════════════════════════════════════════════════════════════════

fn pow_2_3 { 2 ** 3 }
fn pow_3_2 { 3 ** 2 }
fn pow_10_2 { 10 ** 2 }
fn pow_2_10 { 2 ** 10 }
fn pow_neg { (-2) ** 3 }
fn pow_zero_exp { 5 ** 0 }
fn pow_one_exp { 5 ** 1 }
fn pow_float { int((2.5 ** 2) * 100) }
fn pow_fractional { int((4 ** 0.5) * 1000) }

