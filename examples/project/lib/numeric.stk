# ══════════════════════════════════════════════════════════════════════════════
# RAND / SRAND
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::rand_bounded {
    val $r = rand()
    $r >= 0 && $r < 1 ? 1 : 0
}

fn Project::Numeric::rand_multiple_diff {
    val $r1 = rand()
    val $r2 = rand()
    val $r3 = rand()
    ($r1 != $r2 || $r2 != $r3) ? 1 : 0
}

fn Project::Numeric::rand_with_max {
    val $r = rand(100)
    $r >= 0 && $r < 100 ? 1 : 0
}

fn Project::Numeric::rand_int_range {
    val $r = int(rand(10))
    $r >= 0 && $r <= 9 ? 1 : 0
}

