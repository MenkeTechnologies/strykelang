fn log_10 { int(log(10) * 1000) }

fn exp_zero { int(exp(0) * 1000) }
fn exp_one { int(exp(1) * 1000) }
fn exp_two { int(exp(2) * 100) }

fn log_exp_roundtrip { int(log(exp(3)) * 1000) }
fn exp_log_roundtrip { int(exp(log(5)) * 1000) }

