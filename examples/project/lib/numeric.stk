# lib/numeric.stk — numeric operation tests

# ══════════════════════════════════════════════════════════════════════════════
# INT
# ══════════════════════════════════════════════════════════════════════════════

fn int_pos_floor { int(3.7) }
fn int_pos_exact { int(5.0) }
fn int_neg_toward_zero { int(-3.7) }
fn int_neg_exact { int(-5.0) }
fn int_zero { int(0.0) }
fn int_small_pos { int(0.1) }
fn int_small_neg { int(-0.1) }
fn int_large { int(1234567.89) }

fn int_string_pos { int("42.7") }
fn int_string_neg { int("-3.14") }
fn int_string_mixed { int("123abc") }

