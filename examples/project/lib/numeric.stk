fn Project::Numeric::ceil_pos { ceil(3.2) }
fn Project::Numeric::ceil_neg { ceil(-3.2) }
fn Project::Numeric::ceil_exact { ceil(5.0) }

fn Project::Numeric::round_up { round(3.6) }
fn Project::Numeric::round_down { round(3.4) }
fn Project::Numeric::round_half { round(3.5) }
fn Project::Numeric::round_neg { round(-3.6) }

# ══════════════════════════════════════════════════════════════════════════════
# NUMERIC COMPARISON
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::cmp_equal { 5 == 5 ? 1 : 0 }
fn Project::Numeric::cmp_not_equal { 5 != 3 ? 1 : 0 }
fn Project::Numeric::cmp_less { 3 < 5 ? 1 : 0 }
fn Project::Numeric::cmp_greater { 5 > 3 ? 1 : 0 }
fn Project::Numeric::cmp_less_eq { 5 <= 5 ? 1 : 0 }
fn Project::Numeric::cmp_greater_eq { 5 >= 3 ? 1 : 0 }

fn Project::Numeric::cmp_float_equal { 3.14 == 3.14 ? 1 : 0 }
fn Project::Numeric::cmp_float_not_equal { 3.14 != 2.71 ? 1 : 0 }

fn Project::Numeric::spaceship_less { 3 <=> 5 }
fn Project::Numeric::spaceship_equal { 5 <=> 5 }
fn Project::Numeric::spaceship_greater { 5 <=> 3 }

# ══════════════════════════════════════════════════════════════════════════════
# ARITHMETIC
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::add_int { 5 + 3 }
fn Project::Numeric::add_float { int((2.5 + 1.5) * 10) }
fn Project::Numeric::add_negative { 5 + (-3) }

fn Project::Numeric::sub_int { 5 - 3 }
fn Project::Numeric::sub_float { int((5.5 - 2.3) * 10) }
fn Project::Numeric::sub_negative { 5 - (-3) }

fn Project::Numeric::mul_int { 5 * 3 }
fn Project::Numeric::mul_float { int((2.5 * 2) * 10) }
fn Project::Numeric::mul_negative { 5 * (-3) }
fn Project::Numeric::mul_zero { 5 * 0 }

fn Project::Numeric::div_int { 10 / 2 }
fn Project::Numeric::div_float { int((7 / 2) * 10) }
fn Project::Numeric::div_negative { (-10) / 2 }

# ══════════════════════════════════════════════════════════════════════════════
# INCREMENT / DECREMENT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::inc_post {
    var $x = 5
    var $y = $x++
    $y
}

fn Project::Numeric::inc_post_after {
    var $x = 5
    $x++
    $x
}

fn Project::Numeric::inc_pre {
    var $x = 5
    val $y = ++$x
    $y
}

fn Project::Numeric::dec_post {
    var $x = 5
    var $y = $x--
    $y
}

fn Project::Numeric::dec_post_after {
    var $x = 5
    $x--
    $x
}

fn Project::Numeric::dec_pre {
    var $x = 5
    val $y = --$x
    $y
}

# ══════════════════════════════════════════════════════════════════════════════
# COMPOUND ASSIGNMENT
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::assign_add {
    var $x = 5
    $x += 3
    $x
}

fn Project::Numeric::assign_sub {
    var $x = 10
    $x -= 3
    $x
}

fn Project::Numeric::assign_mul {
    var $x = 4
    $x *= 3
    $x
}

fn Project::Numeric::assign_div {
    var $x = 12
    $x /= 3
    $x
}

fn Project::Numeric::assign_mod {
    var $x = 10
    $x %= 3
    $x
}

fn Project::Numeric::assign_pow {
    var $x = 2
    $x **= 3
    $x
}

# ══════════════════════════════════════════════════════════════════════════════
# BITWISE
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::test_bit_and { 12 & 10 }
fn Project::Numeric::test_bit_or { 12 | 10 }
fn Project::Numeric::test_bit_xor { 12 ^ 10 }
fn Project::Numeric::test_bit_not { ~0 }
fn Project::Numeric::bit_lshift { 1 << 4 }
fn Project::Numeric::bit_rshift { 16 >> 2 }

fn Project::Numeric::bit_assign_and {
    var $x = 12
    $x &= 10
    $x
}

fn Project::Numeric::bit_assign_or {
    var $x = 12
    $x |= 3
    $x
}

# ══════════════════════════════════════════════════════════════════════════════
# HEX / OCT / BIN
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::hex_simple { hex("ff") }
fn Project::Numeric::test_hex_upper { hex("FF") }
fn Project::Numeric::hex_prefix { hex("0xff") }
fn Project::Numeric::hex_zero { hex("0") }

fn Project::Numeric::oct_simple { oct("77") }
fn Project::Numeric::oct_zero { oct("0") }

fn Project::Numeric::sprintf_hex { sprintf("%x", 255) }
fn Project::Numeric::sprintf_oct { sprintf("%o", 64) }
fn Project::Numeric::sprintf_bin { sprintf("%b", 10) }

# ══════════════════════════════════════════════════════════════════════════════
# NUMERIC EDGE CASES
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::zero_div_protected {
    val $result = eval { 1 / 0 }
    $@ ? 1 : 0
}

fn Project::Numeric::large_number { 1000000 * 1000000 > 0 ? 1 : 0 }
fn Project::Numeric::small_fraction { 0.0001 > 0 ? 1 : 0 }

fn Project::Numeric::infinity_check {
    val $big = 1e308 * 10
    $big > 1e308 ? 1 : 0
}

fn Project::Numeric::negative_zero { -0 == 0 ? 1 : 0 }

fn Project::Numeric::precision_test {
    val $a = 0.1 + 0.2
    $a > 0.29 && $a < 0.31 ? 1 : 0
}

# ══════════════════════════════════════════════════════════════════════════════
# SUM / PRODUCT HELPERS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Numeric::sum_array {
    val @a = (1, 2, 3, 4, 5)
    var $sum = 0
    $sum += _ for @a
    $sum
}

fn Project::Numeric::product_array {
    val @a = (1, 2, 3, 4, 5)
    var $prod = 1
    $prod *= _ for @a
    $prod
}

fn Project::Numeric::average_array {
    val @a = (2, 4, 6, 8, 10)
    var $sum = 0
    $sum += _ for @a
    $sum / len(@a)
}
