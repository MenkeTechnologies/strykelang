# ══════════════════════════════════════════════════════════════════════════════

fn sin_zero { int(sin(0) * 1000) }
fn sin_pi_half { int(sin(3.14159265 / 2) * 1000) }
fn sin_pi { int(sin(3.14159265) * 1000) }

fn cos_zero { int(cos(0) * 1000) }
fn cos_pi_half { int(cos(3.14159265 / 2) * 1000) }
fn cos_pi { int(cos(3.14159265) * 1000) }

fn tan_zero { int(tan(0) * 1000) }
fn tan_pi_quarter { int(tan(3.14159265 / 4) * 1000) }

