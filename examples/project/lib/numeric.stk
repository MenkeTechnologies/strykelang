fn Project::Numeric::min_same { min(5, 5, 5) }
fn Project::Numeric::min_one { min(42) }

fn Project::Numeric::max_two { max(5, 3) }
fn Project::Numeric::max_many { max(5, 3, 8, 1, 9) }
fn Project::Numeric::max_negative { max(-5, -3, -8) }
fn Project::Numeric::max_same { max(5, 5, 5) }
fn Project::Numeric::max_one { max(42) }

