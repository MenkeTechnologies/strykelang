# lib/refs.stk — references and dereferencing

# ── Scalar references ──────────────────────────────────────────────

fn Project::Refs::make_scalar_ref($val) {
    \$val
}

fn Project::Refs::deref_scalar($ref) {
    $$ref
}

fn Project::Refs::modify_through_ref($ref, $new_val) {
    $$ref = $new_val
}

# ── Array references ───────────────────────────────────────────────

fn Project::Refs::make_array_ref {
    [1, 2, 3, 4, 5]
}

fn Project::Refs::array_ref_length($aref) {
    scalar @$aref
}

fn Project::Refs::array_ref_element($aref, $idx) {
    $aref->[$idx]
}

fn Project::Refs::array_ref_push($aref, $val) {
    push @$aref, $val
    $aref
}

fn Project::Refs::array_ref_pop($aref) {
    pop @$aref
}

fn Project::Refs::array_ref_slice($aref, $start, $end) {
    my @result = @{$aref}[$start:$end]
    \@result
}

# ── Hash references ────────────────────────────────────────────────

fn Project::Refs::make_hash_ref {
    { name => "test", value => 42, active => 1 }
}

fn Project::Refs::hash_ref_get($href, $key) {
    $href->{$key}
}

fn Project::Refs::hash_ref_set($href, $key, $val) {
    $href->{$key} = $val
    $href
}

fn Project::Refs::hash_ref_keys($href) {
    my @k = keys %$href
    @k
}

fn Project::Refs::hash_ref_values($href) {
    my @v = values %$href
    @v
}

fn Project::Refs::hash_ref_exists($href, $key) {
    exists $href->{$key} ? 1 : 0
}

fn Project::Refs::hash_ref_delete($href, $key) {
    delete $href->{$key}
}

# ── Nested references ──────────────────────────────────────────────

fn Project::Refs::make_nested_structure {
    {
        users => [
            { name => "Alice", age => 30 },
            { name => "Bob", age => 25 },
        ],
        config => {
            debug => 1,
            timeout => 60,
        },
    }
}

fn Project::Refs::nested_get_user($data, $idx) {
    $data->{users}->[$idx]
}

fn Project::Refs::nested_get_user_name($data, $idx) {
    $data->{users}->[$idx]->{name}
}

fn Project::Refs::nested_get_config($data, $key) {
    $data->{config}->{$key}
}

fn Project::Refs::nested_add_user($data, $name, $age) {
    push @{$data->{users}}, { name => $name, age => $age }
    $data
}

# ── Code references ────────────────────────────────────────────────

fn Project::Refs::make_code_ref {
    fn ($x) { $x * 2 }
}

fn Project::Refs::call_code_ref($cref, $arg) {
    $cref($arg)
}

fn Project::Refs::make_named_sub_ref {
    \&Project::Refs::array_ref_length
}

# ── Reference type checking ────────────────────────────────────────

fn Project::Refs::ref_type($ref) {
    ref $ref}

fn Project::Refs::is_array_ref($ref) {
    ref($ref) eq "ARRAY" ? 1 : 0
}

fn Project::Refs::is_hash_ref($ref) {
    ref($ref) eq "HASH" ? 1 : 0
}

fn Project::Refs::is_code_ref($ref) {
    ref($ref) eq "CODE" ? 1 : 0
}

fn Project::Refs::is_scalar_ref($ref) {
    ref($ref) eq "SCALAR" ? 1 : 0
}

# ── Autovivification ───────────────────────────────────────────────

fn Project::Refs::autoviv_array {
    my $data = { items => [] }
    $data->{items}->[0] = "first"
    $data->{items}->[1] = "second"
    $data
}

fn Project::Refs::autoviv_hash {
    my $data = { nested => { deep => {} } }
    $data->{nested}->{deep}->{value} = 42
    $data
}

# ── Reference counting / aliasing ──────────────────────────────────

fn Project::Refs::alias_test {
    my @arr = (1, 2, 3)
    my $ref1 = \@arr
    my $ref2 = $ref1
    push @$ref2, 4
    scalar @arr
}

fn Project::Refs::modify_alias {
    my %hash = (a => 1)
    my $ref = \%hash
    $ref->{b} = 2
    $hash{a} + $hash{b}
}

# ── Complex data structures ────────────────────────────────────────

fn Project::Refs::make_tree_node($val, $left, $right) {
    { value => $val, left => $left, right => $right }
}

fn Project::Refs::tree_sum($node) {
    if (!defined $node) { return 0 }
    my $v = $node->{value} // 0
    my $l = 0
    if (exists $node->{left} && defined $node->{left}) {
        $l = Project::Refs::tree_sum($node->{left})
    }
    my $r = 0
    if (exists $node->{right} && defined $node->{right}) {
        $r = Project::Refs::tree_sum($node->{right})
    }
    $v + $l + $r
}

fn Project::Refs::make_linked_list(@vals) {
    my $head = undef
    for my $v (rev @vals) {
        $head = { value => $v, next => $head }
    }
    $head
}

fn Project::Refs::list_length($head) {
    my $count = 0
    my $curr = $head
    while (defined $curr) {
        $count++
        $curr = $curr->{next}
    }
    $count
}

fn Project::Refs::list_to_array($head) {
    my @result
    my $curr = $head
    while (defined $curr) {
        push @result, $curr->{value}
        $curr = $curr->{next}
    }
    @result
}

# ── WeakRef-like patterns ──────────────────────────────────────────

fn Project::Refs::circular_safe {
    my $a = { name => "A" }
    my $b = { name => "B" }
    $a->{ref} = $b
    $a->{name} . "-" . $b->{name}
}
