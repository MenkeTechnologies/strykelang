# lib/benchmarks.stk — bench blocks and performance testing

# ══════════════════════════════════════════════════════════════════════════════
# BENCH BLOCKS (stryke native microbenchmarking)
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Benchmarks::bench_simple_addition {
    bench { 1 + 1 } 1000
}

fn Project::Benchmarks::bench_multiplication {
    bench { 7 * 13 } 1000
}

fn Project::Benchmarks::bench_string_concat {
    bench { "hello" . " " . "world" } 1000
}

fn Project::Benchmarks::bench_array_push {
    var @arr
    bench { push @arr, 42 } 100
    scalar @arr
}

fn Project::Benchmarks::bench_hash_insert {
    var %h
    var $i = 0
    bench { $h{$i++} = "value" } 100
    scalar keys %h
}

fn Project::Benchmarks::bench_function_call {
    fn add($a, $b) { $a + $b }
    bench { add(3, 4) } 1000
}

fn Project::Benchmarks::bench_regex_match {
    val $str = "hello world 12345"
    bench { $str =~ /\d+/ } 1000
}

fn Project::Benchmarks::bench_loop_sum {
    bench {
        var $sum = 0
        for val $i (1:10) { $sum += $i }
        $sum
    } 100
}

fn Project::Benchmarks::bench_map_transform {
    val @input = (1:10)
    bench { map { _ * 2 } @input } 100
}

fn Project::Benchmarks::bench_grep_filter {
    val @input = (1:20)
    bench { grep { _ % 2 == 0 } @input } 100
}

fn Project::Benchmarks::bench_sort_small {
    val @input = (5, 2, 8, 1, 9, 3, 7, 4, 6)
    bench { sort @input } 100
}

fn Project::Benchmarks::bench_hash_lookup {
    val %data = map { _ => _ * 2 } (1:100)
    bench { $data{50} } 1000
}

fn Project::Benchmarks::bench_array_access {
    val @data = (1:100)
    bench { $data[50] } 1000
}

fn Project::Benchmarks::bench_string_length {
    val $str = "a" x 1000
    bench { len($str) } 1000
}

fn Project::Benchmarks::bench_string_substr {
    val $str = "hello world this is a test string"
    bench { substr($str, 6, 5) } 1000
}

fn Project::Benchmarks::bench_sprintf {
    bench { sprintf("%d + %d = %d", 2, 3, 5) } 1000
}

fn Project::Benchmarks::bench_join {
    val @parts = qw(a b c d e)
    bench { join("-", @parts) } 1000
}

fn Project::Benchmarks::bench_split {
    val $str = "a-b-c-d-e"
    bench { split(/-/, $str) } 1000
}

fn Project::Benchmarks::bench_closure_call {
    val $fn = fn ($x) { $x * 2 }
    bench { $fn(42) } 1000
}

fn Project::Benchmarks::bench_nested_loops {
    bench {
        var $sum = 0
        for val $i (1:5) {
            for val $j (1:5) {
                $sum += $i * $j
            }
        }
        $sum
    } 100
}

fn Project::Benchmarks::bench_pipeline {
    bench {
        (1:10) |> map { _ * 2 } |> grep { _ > 5 } |> sum
    } 100
}

fn Project::Benchmarks::bench_threading {
    bench {
        ~> (1:10) map { _ ** 2 } sum
    } 100
}

# ══════════════════════════════════════════════════════════════════════════════
# COMPARATIVE BENCHMARKS
# ══════════════════════════════════════════════════════════════════════════════

fn Project::Benchmarks::compare_loop_vs_map {
    val @input = (1:100)
    
    val $loop_result = bench {
        var @out
        ~> @input ep { push @out, _ * 2 }
        @out
    } 50
    
    val $map_result = bench {
        map { _ * 2 } @input
    } 50
    
    "loop vs map comparison complete"
}

fn Project::Benchmarks::compare_hash_vs_array {
    val %hash = map { _ => 1 } (1:100)
    val @array = (1:100)
    
    bench { exists $hash{50} } 500
    bench { grep { _ == 50 } @array } 500
    
    "hash vs array lookup comparison"
}
