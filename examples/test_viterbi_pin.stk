#!/usr/bin/env stryke

package Viterbi

fn solve($obs, $states, $start_p, $trans_p, $emit_p) {
    val $t = len @$obs
    val $num_states = len @$states
    return [] if $t == 0

    val $v = []
    var $path = {}

    var $v_0 = {}
    val $obs_0 = $obs->[0]
    for val $y (@$states) {
        $v_0->{$y} = $start_p->{$y} * $emit_p->{$y}->{$obs_0}
        $path->{$y} = [$y]
    }
    push @$v, $v_0

    for val $i (1:$t-1) {
        val $obs_i = $obs->[$i]
        var $v_i = {}
        var $newpath = {}

        for val $y (@$states) {
            var $prob = -1.0
            var $state = ""
            for val $y0 (@$states) {
                val $prev_v = $v->[$i - 1]->{$y0}
                val $trans = $trans_p->{$y0}->{$y}
                val $emit = $emit_p->{$y}->{$obs_i}
                val $calc = $prev_v * $trans * $emit
                if ($calc > $prob) {
                    $prob = $calc
                    $state = $y0
                }
            }
            $v_i->{$y} = $prob
            val $prev_path = $path->{$state}
            var @next_path = @$prev_path
            push @next_path, $y
            $newpath->{$y} = \@next_path
        }
        push @$v, $v_i
        $path = $newpath
    }

    var $prob = -1.0
    var $state = ""
    val $v_last = $v->[$t - 1]
    for val $y (@$states) {
        val $val = $v_last->{$y}
        if ($val > $prob) {
            $prob = $val
            $state = $y
        }
    }

    { prob => $prob, path => $path->{$state} }
}

package main

val @obs = ("normal", "cold", "dizzy")
val @states = ("Healthy", "Fever")

val %start_p = ("Healthy" => 0.6, "Fever" => 0.4)
val %trans_p = (
    "Healthy" => { "Healthy" => 0.7, "Fever" => 0.3 },
    "Fever"   => { "Healthy" => 0.4, "Fever" => 0.6 }
)
val %emit_p = (
    "Healthy" => { "normal" => 0.5, "cold" => 0.4, "dizzy" => 0.1 },
    "Fever"   => { "normal" => 0.1, "cold" => 0.3, "dizzy" => 0.6 }
)

val $res = Viterbi::solve(\@obs, \@states, \%start_p, \%trans_p, \%emit_p)
val $path = join(",", @{$res->{path}})

$path |> aeq "Healthy,Healthy,Fever", "correct viterbi path"

test_run
