#!/usr/bin/env stryke

# Pinning batch: Tokenizer / expression lexer.
# Compliance: docs/STYLE_GUIDE.md

# Token = [type, value]
fn Tk::is_digit($c) = $c =~ /^[0-9]$/
fn Tk::is_alpha($c) = $c =~ /^[A-Za-z_]$/
fn Tk::is_alnum($c) = $c =~ /^[A-Za-z0-9_]$/
fn Tk::is_space($c) = $c =~ /^\s$/

fn Tk::lex($src) {
    my @toks = ()
    my @chars = split(//, $src)
    my $i = 0
    my $n = len @chars
    while ($i < $n) {
        my $c = $chars[$i]
        if (Tk::is_space($c)) {
            $i++
            next
        }
        if (Tk::is_digit($c)) {
            my $j = $i
            while ($j < $n && Tk::is_digit($chars[$j])) {
                $j++
            }
            if ($j < $n && $chars[$j] eq ".") {
                $j++
                while ($j < $n && Tk::is_digit($chars[$j])) {
                    $j++
                }
                push @toks, ["FLOAT", join("", @chars[$i:$j-1])]
            } else {
                push @toks, ["INT", join("", @chars[$i:$j-1])]
            }
            $i = $j
            next
        }
        if (Tk::is_alpha($c)) {
            my $j = $i
            while ($j < $n && Tk::is_alnum($chars[$j])) {
                $j++
            }
            my $word = join("", @chars[$i:$j-1])
            my $type = $word =~ /^(if|else|while|for|fn|return|true|false)$/ ? "KW" : "ID"
            push @toks, [$type, $word]
            $i = $j
            next
        }
        if ($c eq "\"") {
            my $j = $i + 1
            while ($j < $n && $chars[$j] ne "\"") {
                $j++
            }
            push @toks, ["STR", join("", @chars[$i+1:$j-1])]
            $i = $j + 1
            next
        }
        if ($c eq "+" || $c eq "-" || $c eq "*" || $c eq "/" || $c eq "%") {
            push @toks, ["OP", $c]
            $i++
            next
        }
        if ($c eq "(" || $c eq ")") {
            push @toks, ["PAREN", $c]
            $i++
            next
        }
        if ($c eq "=" || $c eq "<" || $c eq ">" || $c eq "!") {
            if ($i + 1 < $n && $chars[$i+1] eq "=") {
                push @toks, ["CMP", $c . "="]
                $i += 2
            } else {
                push @toks, ["OP", $c]
                $i++
            }
            next
        }
        if ($c eq ";" || $c eq "," || $c eq "{" || $c eq "}") {
            push @toks, ["PUNCT", $c]
            $i++
            next
        }
        push @toks, ["UNKNOWN", $c]
        $i++
    }
    \@toks
}

fn Tk::types($toks) = join(",", map { $_->[0] } @$toks)
fn Tk::vals($toks)  = join(",", map { $_->[1] } @$toks)

Tk::types(Tk::lex(""))         |> aeq "",        "empty"
Tk::types(Tk::lex("   "))      |> aeq "",        "whitespace only"
Tk::types(Tk::lex("42"))       |> aeq "INT",     "single int"
Tk::vals(Tk::lex("42"))        |> aeq "42",      "single int val"
Tk::types(Tk::lex("3.14"))     |> aeq "FLOAT",   "float"
Tk::vals(Tk::lex("3.14"))      |> aeq "3.14",    "float val"

my $t1 = Tk::lex("1 + 2")
Tk::types($t1) |> aeq "INT,OP,INT",  "1 + 2 types"
Tk::vals($t1)  |> aeq "1,+,2",       "1 + 2 vals"

my $t2 = Tk::lex("foo(1, 2)")
Tk::types($t2) |> aeq "ID,PAREN,INT,PUNCT,INT,PAREN", "call types"
Tk::vals($t2)  |> aeq "foo,(,1,,,2,)", "call vals"

my $t3 = Tk::lex("if x == 10")
Tk::types($t3) |> aeq "KW,ID,CMP,INT", "if-equal"
Tk::vals($t3)  |> aeq "if,x,==,10",    "if-equal vals"

my $t4 = Tk::lex("a >= b")
Tk::types($t4) |> aeq "ID,CMP,ID", "ge"
Tk::vals($t4)  |> aeq "a,>=,b",     "ge vals"

my $t5 = Tk::lex("\"hello world\"")
Tk::types($t5) |> aeq "STR",         "string"
Tk::vals($t5)  |> aeq "hello world", "string val"

my $t6 = Tk::lex("fn add(x, y) { return x + y }")
Tk::types($t6) |> aeq "KW,ID,PAREN,ID,PUNCT,ID,PAREN,PUNCT,KW,ID,OP,ID,PUNCT", "fn def"

my $t7 = Tk::lex("true || false && !x")
Tk::vals($t7) |> aeq "true,|,|,false,&,&,!,x", "logical chars"

my $t8 = Tk::lex("123 + 4.5 * x")
Tk::types($t8) |> aeq "INT,OP,FLOAT,OP,ID", "mixed types"

Tk::types(Tk::lex(";;,,{{}}")) |> aeq "PUNCT,PUNCT,PUNCT,PUNCT,PUNCT,PUNCT,PUNCT,PUNCT", "puncts"

# Stress: ignore extra whitespace
Tk::vals(Tk::lex("  1  +  \t 2  \n + 3 "))
    |> aeq "1,+,2,+,3", "whitespace tolerant"

# Counts
fn Tk::count($toks, $type) = len grep { $_->[0] eq $type } @$toks

my $big = Tk::lex("a + b * (c - d) / e + f - g")
Tk::count($big, "ID")    |> aeq 7, "7 ids"
Tk::count($big, "OP")    |> aeq 6, "6 ops"
Tk::count($big, "PAREN") |> aeq 2, "2 parens"

test_run
