#!/usr/bin/env stryke

package BronKerbosch

fn set_intersect($s1, $s2) {
    var %h
    for val $x (@$s2) { $h{$x} = 1 }
    val @res = ~> @$s1 grep { $h{_} }
    \@res
}

fn set_diff($s1, $s2) {
    var %h
    for val $x (@$s2) { $h{$x} = 1 }
    val @res = ~> @$s1 grep { !$h{_} }
    \@res
}

fn bk($r, $p, $x, $adj, $cliques) {
    val $p_len = len @$p; val $x_len = len @$x
    if ($p_len == 0 && $x_len == 0) { push @$cliques, $r; return undef }
    var $pivot = undef
    if ($p_len > 0) { $pivot = $p->[0] } elsif ($x_len > 0) { $pivot = $x->[0] }
    var $p_explore = $p
    if (defined $pivot) { val $ns = $adj->{$pivot} // []; $p_explore = BronKerbosch::set_diff($p, $ns) }
    var @p_copy = @$p; var @x_copy = @$x
    for val $v (@$p_explore) {
        var @new_r = @$r; push @new_r, $v
        val $ns = $adj->{$v} // []
        val $new_p = BronKerbosch::set_intersect(\@p_copy, $ns)
        val $new_x = BronKerbosch::set_intersect(\@x_copy, $ns)
        BronKerbosch::bk(\@new_r, $new_p, $new_x, $adj, $cliques)
        val $v_arr = [$v]; val $p_rem = BronKerbosch::set_diff(\@p_copy, $v_arr)
        @p_copy = @$p_rem; push @x_copy, $v
    }
}

fn solve($vertices, $adj) {
    val @cliques; val @r; val @x
    BronKerbosch::bk(\@r, $vertices, \@x, $adj, \@cliques)
    \@cliques
}

package main

val @v1 = ("1", "2", "3", "4", "5", "6")
val %adj1 = (
    "1" => ["2", "5"],
    "2" => ["1", "3", "5"],
    "3" => ["2", "4"],
    "4" => ["3", "5", "6"],
    "5" => ["1", "2", "4"],
    "6" => ["4"]
)
val $c1 = BronKerbosch::solve(\@v1, \%adj1)
~> len(@$c1) aeq(5, "5 maximal cliques")

test_run
