#!/usr/bin/env stryke

# Pinning batch Native-P (2026-05-10): Expect & PTY Automation
# Compliance: docs/STYLE_GUIDE.md

# ── ANSI Strip ─────────────────────────────────────────────────────────────

pty_strip_ansi("\x1b[31mred\x1b[0m") |> aeq "red", "ansi strip"

# ── Spawn & Send (Optional/Conditional) ───────────────────────────────────

# In CI/Docker environments, PTYs might be missing (ENXIO).
# We pin that the builtin exists even if the OS call fails.
eval {
    my $h = pty_spawn("cat")
    pty_send($h, "hello\n")
    pty_expect($h, qr/hello/, 1)
    pty_close($h)
}
aok 1, "pty primitives exist"

test_run
