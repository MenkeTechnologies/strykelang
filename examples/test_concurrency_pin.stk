#!/usr/bin/env stryke

# Pinning batch Native-G (2026-05-10): Concurrency & Channels
# Compliance: docs/STYLE_GUIDE.md

# ── Async / Await ──────────────────────────────────────────────────────────

async { sleep(0.1); 42 } |> await |> aeq 42, "async/await basic"
async { my $t = async { 10 }; (await $t) + 20 } |> await |> aeq 30, "nested async/await"

# ── Channels ───────────────────────────────────────────────────────────────

our ($tx, $rx) = pchannel(10)
$tx->send("hello")
$rx->recv() |> aeq "hello", "channel send/recv"

our ($tx2, $rx2) = pchannel(100)
fan 4 { $tx2->send(_) }
(1:4) |> map { $rx2->recv() } |> sum |> aeq 6, "channel from multiple producers"

# ── PSelect ────────────────────────────────────────────────────────────────

our ($tx_a, $rx_a) = pchannel(1)
our ($tx_b, $rx_b) = pchannel(1)
$tx_b->send("B")
pselect($rx_a, $rx_b)->[0] |> aeq "B", "pselect value B"

# ── Parallel Filesystem / IO ───────────────────────────────────────────────

my $tmp = tempdir()
spurt "$tmp/a.txt", "line1\nline2\n"

oursync $count = 0
par_lines("$tmp/a.txt", fn { $count++ })
$count |> aeq 2, "par_lines count"

oursync $walk_count = 0
# Use a broad pattern to ensure matches on absolute paths
par_walk($tmp, fn { $walk_count++ if _ =~ /\.txt$/ })
$walk_count |> maps { _ > 0 } |> aok "par_walk found at least 1 file"

par_sed(qr/line/g, "row", "$tmp/a.txt") |> aeq 1, "par_sed return value"
slurp("$tmp/a.txt") =~ /row1/ |> aok "par_sed content verified"

test_run
