#!/usr/bin/env stryke

package SV;

fn parse($s) {
    var $rest = $s
    val $plus = index($rest, "+")
    var $build = ""
    if ($plus >= 0) {
        $build = substr($rest, $plus + 1)
        $rest = substr($rest, 0, $plus)
    }
    val $dash = index($rest, "-")
    var $pre = ""
    if ($dash >= 0) {
        $pre = substr($rest, $dash + 1)
        $rest = substr($rest, 0, $dash)
    }
    var @nums = split(/\./, $rest)
    return undef if len(@nums) != 3
    for val $nn (@nums) {
        return undef if $nn !~ /^\d+$/
    }
    {
        major => $nums[0] + 0,
        minor => $nums[1] + 0,
        patch => $nums[2] + 0,
        pre => $pre,
        build => $build,
    }
}

fn format($v) {
    var $s = $v->{major} . "." . $v->{minor} . "." . $v->{patch}
    $s = $s . "-" . $v->{pre} if (len $v->{pre}) > 0
    $s = $s . "+" . $v->{build} if (len $v->{build}) > 0
    $s
}

fn _cmp_pre_id($x, $y) {
    val $xn = $x =~ /^\d+$/
    val $yn = $y =~ /^\d+$/
    if ($xn && $yn) {
        val $av = $x + 0
        val $bv = $y + 0
        return -1 if $av < $bv
        return 1 if $av > $bv
        return 0
    }
    return -1 if $xn && !$yn
    return 1 if !$xn && $yn
    return -1 if $x lt $y
    return 1 if $x gt $y
    0
}

fn compare($av, $bv) {
    return -1 if $av->{major} < $bv->{major}
    return 1 if $av->{major} > $bv->{major}
    return -1 if $av->{minor} < $bv->{minor}
    return 1 if $av->{minor} > $bv->{minor}
    return -1 if $av->{patch} < $bv->{patch}
    return 1 if $av->{patch} > $bv->{patch}
    val $ap = len $av->{pre}
    val $bp = len $bv->{pre}
    return 1 if $ap == 0 && $bp > 0
    return -1 if $ap > 0 && $bp == 0
    return 0 if $ap == 0 && $bp == 0
    val @ai = split(/\./, $av->{pre})
    val @bi = split(/\./, $bv->{pre})
    val $n = len(@ai) < len(@bi) ? len(@ai) : len(@bi)
    for val $i (0:$n-1) {
        val $c = SV::_cmp_pre_id($ai[$i], $bi[$i])
        return $c if $c != 0
    }
    return -1 if len(@ai) < len(@bi)
    return 1 if len(@ai) > len(@bi)
    0
}

fn satisfies_caret($v, $base) {
    return 0 if $v->{major} != $base->{major}
    if ($base->{major} > 0) {
        return SV::compare($v, $base) >= 0 ? 1 : 0
    }
    if ($base->{minor} > 0) {
        return 0 if $v->{minor} != $base->{minor}
        return SV::compare($v, $base) >= 0 ? 1 : 0
    }
    SV::compare($v, $base) == 0 ? 1 : 0
}

package main;

# --- parse simple ---
val $v1 = SV::parse("1.2.3")
$v1->{major} |> aeq 1, "parse major"
$v1->{minor} |> aeq 2, "parse minor"
$v1->{patch} |> aeq 3, "parse patch"
$v1->{pre}   |> aeq "", "parse no pre"
$v1->{build} |> aeq "", "parse no build"

val $v2 = SV::parse("0.0.0")
$v2->{major} |> aeq 0, "parse zero major"
$v2->{minor} |> aeq 0, "parse zero minor"
$v2->{patch} |> aeq 0, "parse zero patch"

val $v3 = SV::parse("10.20.30")
$v3->{major} |> aeq 10, "parse 10"
$v3->{minor} |> aeq 20, "parse 20"
$v3->{patch} |> aeq 30, "parse 30"

# --- parse pre-release / build ---
val $vp = SV::parse("1.0.0-alpha")
$vp->{pre} |> aeq "alpha", "parse pre alpha"

val $vp2 = SV::parse("1.0.0-rc.1")
$vp2->{pre} |> aeq "rc.1", "parse pre rc.1"

val $vb = SV::parse("2.0.0+build.42")
$vb->{build} |> aeq "build.42", "parse build"
$vb->{pre}   |> aeq "", "no pre when only build"

val $vpb = SV::parse("1.0.0-beta+exp.sha.5114f85")
$vpb->{pre}   |> aeq "beta", "pre with build"
$vpb->{build} |> aeq "exp.sha.5114f85", "build with pre"

# --- parse invalid ---
(defined SV::parse("1.2"))      |> aeq 0, "too few parts"
(defined SV::parse("1.2.3.4"))  |> aeq 0, "too many parts"
(defined SV::parse("a.b.c"))    |> aeq 0, "non-numeric"
(defined SV::parse(""))         |> aeq 0, "empty"
(defined SV::parse("1.x.3"))    |> aeq 0, "partial alpha"

# --- format / round-trip ---
SV::format($v1) |> aeq "1.2.3", "format basic"
SV::format($vp) |> aeq "1.0.0-alpha", "format pre"
SV::format($vb) |> aeq "2.0.0+build.42", "format build"
SV::format($vpb) |> aeq "1.0.0-beta+exp.sha.5114f85", "format pre+build"

for val $s ("0.0.0", "1.2.3", "10.20.30", "1.0.0-alpha", "1.0.0-rc.1",
           "2.0.0+build.42", "1.0.0-beta+meta") {
    val $parsed = SV::parse($s)
    SV::format($parsed) |> aeq $s, "round-trip: " . $s
}

# --- compare: major/minor/patch ---
val $va = SV::parse("1.0.0")
val $vb = SV::parse("2.0.0")
SV::compare($va, $vb) |> aeq -1, "1.0.0 < 2.0.0"
SV::compare($vb, $va) |> aeq 1, "2.0.0 > 1.0.0"
SV::compare($va, $va) |> aeq 0, "1.0.0 == 1.0.0"

val $c = SV::parse("1.2.0")
val $d = SV::parse("1.3.0")
SV::compare($c, $d) |> aeq -1, "minor less"

val $e = SV::parse("1.2.3")
val $f = SV::parse("1.2.4")
SV::compare($e, $f) |> aeq -1, "patch less"

# --- compare: pre-release rules ---
# pre-release < release
val $r = SV::parse("1.0.0")
val $rp = SV::parse("1.0.0-alpha")
SV::compare($rp, $r) |> aeq -1, "1.0.0-alpha < 1.0.0"
SV::compare($r, $rp) |> aeq 1, "1.0.0 > 1.0.0-alpha"

# pre-release lexical compare
SV::compare(SV::parse("1.0.0-alpha"), SV::parse("1.0.0-beta")) |> aeq -1, "alpha < beta"
SV::compare(SV::parse("1.0.0-alpha"), SV::parse("1.0.0-alpha.1")) |> aeq -1, "shorter < longer"
SV::compare(SV::parse("1.0.0-alpha.1"), SV::parse("1.0.0-alpha.beta")) |> aeq -1, "numeric < alpha id"
SV::compare(SV::parse("1.0.0-alpha.beta"), SV::parse("1.0.0-beta")) |> aeq -1, "alpha.beta < beta"
SV::compare(SV::parse("1.0.0-beta"), SV::parse("1.0.0-beta.2")) |> aeq -1, "beta < beta.2"
SV::compare(SV::parse("1.0.0-beta.2"), SV::parse("1.0.0-beta.11")) |> aeq -1, "beta.2 < beta.11 (numeric)"
SV::compare(SV::parse("1.0.0-beta.11"), SV::parse("1.0.0-rc.1")) |> aeq -1, "beta.11 < rc.1"
SV::compare(SV::parse("1.0.0-rc.1"), SV::parse("1.0.0")) |> aeq -1, "rc.1 < release"

# Equal pre-release
SV::compare(SV::parse("1.0.0-alpha"), SV::parse("1.0.0-alpha")) |> aeq 0, "equal pre"

# Build metadata ignored
SV::compare(SV::parse("1.0.0+a"), SV::parse("1.0.0+b")) |> aeq 0, "build ignored"
SV::compare(SV::parse("1.0.0"), SV::parse("1.0.0+xyz")) |> aeq 0, "build vs none ignored"

# --- satisfies_caret ---
val $base = SV::parse("1.2.3")
SV::satisfies_caret(SV::parse("1.2.3"), $base) |> aeq 1, "^1.2.3 = 1.2.3"
SV::satisfies_caret(SV::parse("1.2.4"), $base) |> aeq 1, "^1.2.3 = 1.2.4"
SV::satisfies_caret(SV::parse("1.9.0"), $base) |> aeq 1, "^1.2.3 = 1.9.0"
SV::satisfies_caret(SV::parse("1.2.2"), $base) |> aeq 0, "^1.2.3 not 1.2.2"
SV::satisfies_caret(SV::parse("2.0.0"), $base) |> aeq 0, "^1.2.3 not 2.0.0"
SV::satisfies_caret(SV::parse("0.9.0"), $base) |> aeq 0, "^1.2.3 not 0.9.0"

# Caret with 0.x.y: same minor required
val $bo = SV::parse("0.2.3")
SV::satisfies_caret(SV::parse("0.2.4"), $bo) |> aeq 1, "^0.2.3 = 0.2.4"
SV::satisfies_caret(SV::parse("0.2.3"), $bo) |> aeq 1, "^0.2.3 = 0.2.3"
SV::satisfies_caret(SV::parse("0.3.0"), $bo) |> aeq 0, "^0.2.3 not 0.3.0"
SV::satisfies_caret(SV::parse("0.2.2"), $bo) |> aeq 0, "^0.2.3 not 0.2.2"

# Caret with 0.0.z: exact only
val $bz = SV::parse("0.0.5")
SV::satisfies_caret(SV::parse("0.0.5"), $bz) |> aeq 1, "^0.0.5 = 0.0.5"
SV::satisfies_caret(SV::parse("0.0.6"), $bz) |> aeq 0, "^0.0.5 not 0.0.6"
SV::satisfies_caret(SV::parse("0.0.4"), $bz) |> aeq 0, "^0.0.5 not 0.0.4"

test_run
