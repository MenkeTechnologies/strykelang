#!/usr/bin/env stryke

# Closest pair of points — divide-and-conquer in O(n log n). Sort by
# x once, then recursively split: the closest pair is either in the
# left half, the right half, or straddles the dividing line. The
# "strip" trick — only candidate points within distance `d` of the
# divider, sorted by y — needs at most 7 comparisons per point
# regardless of n, dropping the bridge step to O(n) per level.
# Cross-validated against an O(n²) brute force on every input.
#
# Style-guide conformance (docs/STYLE_GUIDE.md):
#   * named-package fns (`Cp::`) under --no-interop (§18)
#   * `_0`/`_1` in sort comparator (§11)
#   * `:` ranges, `len` for sizes, `#{ }` interpolation (§4, §5, §1a)
#   * implicit return on tail, no trailing `;` (§3, §12b)
#
# Run: stryke --no-interop examples/closest_pair_no_interop.stk

# ── squared distance — avoids sqrt in hot loops ───────────────────

fn Cp::dist2($pa, $pb) {
    val $dx = $pa->[0] - $pb->[0]
    val $dy = $pa->[1] - $pb->[1]
    $dx * $dx + $dy * $dy
}

# ── recursive divide-and-conquer over [lo, hi] in Px (x-sorted) ───
# Returns +{ d2, pa, pb }. d2 is the squared distance.

fn Cp::rec($px, $lo, $hi) {
    val $n = $hi - $lo + 1
    if ($n <= 3) {
        var $best = 1_000_000_000_000_000
        var $bp_a
        var $bp_b
        for val $i ($lo:$hi) {
            for val $j ($i + 1:$hi) {
                val $d = Cp::dist2($px->[$i], $px->[$j])
                if ($d < $best) {
                    $best = $d
                    $bp_a = $px->[$i]
                    $bp_b = $px->[$j]
                }
            }
        }
        return +{ d2 => $best, pa => $bp_a, pb => $bp_b }
    }
    val $mid = int(($lo + $hi) / 2)
    val $mid_x = $px->[$mid]->[0]
    val $left = Cp::rec($px, $lo, $mid)
    val $right = Cp::rec($px, $mid + 1, $hi)
    var $best
    if ($left->{d2} < $right->{d2}) {
        $best = $left
    } else {
        $best = $right
    }
    var $d2 = $best->{d2}
    # Build the strip: points within sqrt(d2) of the divider x.
    var @strip
    for val $i ($lo:$hi) {
        val $dx = $px->[$i]->[0] - $mid_x
        push @strip, $px->[$i] if $dx * $dx < $d2
    }
    @strip = sort { _0->[1] <=> _1->[1] } @strip
    val $sn = len(@strip)
    for val $i (0:$sn - 1) {
        var $j = $i + 1
        while ($j < $sn && ($strip[$j]->[1] - $strip[$i]->[1]) * ($strip[$j]->[1] - $strip[$i]->[1]) < $d2) {
            val $d = Cp::dist2($strip[$i], $strip[$j])
            if ($d < $d2) {
                $d2 = $d
                $best = +{ d2 => $d, pa => $strip[$i], pb => $strip[$j] }
            }
            $j++
        }
    }
    $best
}

# ── entry point: sort by x, then recurse ─────────────────────────

fn Cp::closest($points) {
    val $n = len(@$points)
    die "need ≥ 2 points" if $n < 2
    val @px = sort { _0->[0] != _1->[0] ? _0->[0] <=> _1->[0] : _0->[1] <=> _1->[1] } @$points
    Cp::rec(\@px, 0, $n - 1)
}

# ── O(n²) brute force ────────────────────────────────────────────

fn Cp::brute($points) {
    val $n = len(@$points)
    var $best = 1_000_000_000_000_000
    var $bp_a
    var $bp_b
    for val $i (0:$n - 1) {
        for val $j ($i + 1:$n - 1) {
            val $d = Cp::dist2($points->[$i], $points->[$j])
            if ($d < $best) {
                $best = $d
                $bp_a = $points->[$i]
                $bp_b = $points->[$j]
            }
        }
    }
    +{ d2 => $best, pa => $bp_a, pb => $bp_b }
}

# ── primary cases ────────────────────────────────────────────────

val @cases = (
    +{
        name   => "2-point line",
        points => [[0, 0], [3, 4]],
        d2     => 25,
    },
    +{
        name   => "collinear cluster",
        points => [[0, 0], [10, 0], [20, 0], [11, 0], [9, 0]],
        d2     => 1,
    },
    +{
        name   => "grid 4×4",
        points => [
            [0, 0], [1, 0], [2, 0], [3, 0],
            [0, 1], [1, 1], [2, 1], [3, 1],
            [0, 2], [1, 2], [2, 2], [3, 2],
            [0, 3], [1, 3], [2, 3], [3, 3],
        ],
        d2     => 1,
    },
    +{
        name   => "diagonal closest",
        points => [[0, 0], [100, 100], [50, 50], [51, 51]],
        d2     => 2,
    },
    +{
        name   => "scattered 8 points",
        points => [
            [-5, -5], [10, 10], [-1, 3], [4, 7],
            [-1, 4], [8, -2], [3, 8], [9, -3],
        ],
        d2     => 1,
    },
    +{
        name   => "10-point cluster",
        points => [
            [10, 10], [10, 11], [11, 10], [50, 50],
            [50, 60], [60, 50], [-10, -10], [-10, 0],
            [100, 100], [200, 200],
        ],
        d2     => 1,
    },
    +{
        name   => "very close pair amid sparsity",
        points => [
            [0, 0], [1000, 0], [0, 1000], [1000, 1000],
            [500, 500], [501, 500],
        ],
        d2     => 1,
    },
)

p "── closest-pair-of-points demo ───────────────────────"
printf "  %-30s  %3s  %5s  %s\n", "case", "n", "d²", "pair"
printf "  %-30s  %3s  %5s  %s\n", "------------------------------", "---", "-----", "----"
for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    val $ok = $r->{d2} == $c->{d2}
    printf "  %-30s  %3d  %5d  (%d,%d)-(%d,%d)  %s\n",
        $c->{name}, len(@{$c->{points}}), $r->{d2},
        $r->{pa}->[0], $r->{pa}->[1], $r->{pb}->[0], $r->{pb}->[1],
        $ok ? "" : "FAIL want=#{$c->{d2}}"
}

# ── invariant 1: D&C result matches expected d² ───────────────────

for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    die "d² #{$r->{d2}} != expected #{$c->{d2}} on \"#{$c->{name}}\"" unless $r->{d2} == $c->{d2}
}

# ── invariant 2: D&C result matches brute force on every case ─────

for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    val $br = Cp::brute($c->{points})
    die "D&C d² #{$r->{d2}} != brute d² #{$br->{d2}} on \"#{$c->{name}}\"" unless $r->{d2} == $br->{d2}
}

# ── invariant 3: returned pair actually has the reported distance ─

for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    val $d_check = Cp::dist2($r->{pa}, $r->{pb})
    die "pair distance #{$d_check} != reported #{$r->{d2}} on \"#{$c->{name}}\"" unless $d_check == $r->{d2}
}

# ── invariant 4: both points are present in the input ─────────────

for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    var $found_a = 0
    var $found_b = 0
    for val $p (@{$c->{points}}) {
        $found_a = 1 if $p->[0] == $r->{pa}->[0] && $p->[1] == $r->{pa}->[1]
        $found_b = 1 if $p->[0] == $r->{pb}->[0] && $p->[1] == $r->{pb}->[1]
    }
    die "pa not in input on \"#{$c->{name}}\"" unless $found_a
    die "pb not in input on \"#{$c->{name}}\"" unless $found_b
}

# ── invariant 5: no pair in input has smaller distance ────────────

for val $c (@cases) {
    val $r = Cp::closest($c->{points})
    val $n = len(@{$c->{points}})
    for val $i (0:$n - 1) {
        for val $j ($i + 1:$n - 1) {
            val $d = Cp::dist2($c->{points}->[$i], $c->{points}->[$j])
            die "found closer pair (#{$d} < #{$r->{d2}}) on \"#{$c->{name}}\"" if $d < $r->{d2}
        }
    }
}

# ── invariant 6: 2-point input returns exactly that pair ──────────

val $two = Cp::closest([[7, 11], [19, 23]])
die "2-point d² mismatch" unless $two->{d2} == (12 * 12 + 12 * 12)

# ── invariant 7: a duplicated point yields d² = 0 ─────────────────

val $dup = Cp::closest([[1, 2], [3, 4], [1, 2], [5, 6]])
die "duplicate-point d² must be 0" unless $dup->{d2} == 0

p ""
p "── all seven invariants satisfied ────────────────────"
