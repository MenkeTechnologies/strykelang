#!/usr/bin/env stryke

# Pinning batch Native-I (2026-05-10): Perl Special Variables
# Compliance: docs/STYLE_GUIDE.md

# ── Process & Script ───────────────────────────────────────────────────────

$$ |> maps { _ > 0 } |> aok "PID $$ positive"
$0 |> maps { _ =~ /test_perl_special_vars_pin\.stk$/ } |> aok "Script name $0"
$^X |> maps { _ =~ /stryke$/ } |> aok "Executable path $^X"

# ── OS Errors ($! and $^E) ────────────────────────────────────────────────

eval { open(val $fh, "<", "/non/existent/path/999") }
$! |> maps { _ != 0 } |> aok "Errno $! non-zero"
"$!" |> maps { _ =~ /No such file/i } |> aok "Errno string"
$^E |> maps { _ =~ /No such file/i } |> aok "Extended error $^E"

# ── Eval Errors ($@) ──────────────────────────────────────────────────────

eval { die "boom" }
$@ |> maps { _ =~ /^boom at/ } |> aok "$@ contains location"

# ── Record Separators ($, and $\) ─────────────────────────────────────────

{
    local $, = "|"
    $, |> aeq "|", "$, assignable"
}

# ── Version ($] and $^V) ──────────────────────────────────────────────────

$] |> maps { _ =~ /^5\./ } |> aok "$] version"
$^V |> maps { _ =~ /^v\d+\.\d+/ } |> aok "$^V semver"

# ── Environment (%ENV) ────────────────────────────────────────────────────

$ENV{STRYKE_PIN_TEST} = "active"
$ENV{STRYKE_PIN_TEST} |> aeq "active", "%ENV writable"

# ── Match Offsets (@- and @+) ──────────────────────────────────────────────

"abc123def" =~ /(\d+)/
$-[0] |> aeq 3, "match start @-[0]"
$+[0] |> aeq 6, "match end @+[0]"

# ── Input Line Number ($.) ────────────────────────────────────────────────

val $tmp = tempdir()
spurt "$tmp/lines.txt", "a\nb\nc\n"
open(val $fh, "<", "$tmp/lines.txt")
<$fh>
$. |> aeq 1, "$. is 1"
<$fh>
$. |> aeq 2, "$. is 2"
close($fh)

# ── Caret Specials (${^PHASE}, etc) ───────────────────────────────────────

${^GLOBAL_PHASE} |> aeq "RUN", "Global phase RUN"

test_run
