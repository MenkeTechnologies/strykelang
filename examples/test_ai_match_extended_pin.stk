#!/usr/bin/env stryke

# Pinning batch Native-R (2026-05-10): Extended AI Match Tests
# Compliance: docs/STYLE_GUIDE.md
#
# `ai_match(item, criterion, ...)` is a SINGLE-ITEM binary matcher
# returning `1` if the LLM says the item matches the criterion, `0`
# otherwise. The prompt template is
#   Does this item match the criterion "<criterion>"? Reply ONLY with
#   `true` or `false`.
#   Item: <item>
# To match a list against a criterion, `pmap` / `grep` over `ai_match`.

# ── ai_match — single item, true verdict ────────────────────────────────────

ai_mock_install('(?is)Does this item match the criterion.*positive', "true")
ai_match(42, "is a positive number") |> aeq 1, "ai_match positive number"

# ── ai_match — single item, false verdict ───────────────────────────────────

ai_mock_install('(?is)Does this item match the criterion.*negative', "false")
ai_match(42, "is a negative number") |> aeq 0, "ai_match negative number"

# ── ai_match — robust to phrasing of "true" / "yes" ─────────────────────────

ai_mock_install('(?is)Does this item match the criterion.*fruit', "yes")
ai_match("apple", "is a fruit") |> aeq 1, "ai_match accepts 'yes' as true"

# ── ai_match — false verdicts also accepted ─────────────────────────────────

# Mock returns "false" — verifies the negative path through the
# response parser (matches /true/ when absent, /false/ presence wins).
ai_mock_install('(?is)criterion.*orange', "false")
ai_match("blueberry", "is an orange") |> aeq 0, "ai_match returns 0 on 'false'"

# ── ai_match — composes with pmap for parallel verdicts ─────────────────────

# `pmap` over ai_match produces a verdict-per-item array. With mocks
# the result is deterministic — each call routes to the same mock.
ai_mock_install('(?is)criterion.*even', "true")
my @verdicts = map { ai_match($_, "is even") } (2, 4, 6)
join(",", @verdicts) |> aeq "1,1,1", "ai_match via map yields verdict array"

test_run
