#!/usr/bin/env stryke

# Rabin-Karp substring search — find every occurrence of `pat` in
# `text` via rolling polynomial hash. Average O(n + m), worst O(nm)
# (only when hash collisions cascade). Used by grep-like tools and
# plagiarism detection. Parses clean under `--no-interop`.
#
# Idiomatic stryke per docs/STYLE_GUIDE.md:
#   * implicit return on tail (rule 7)
#   * `#{…}` interpolation (rule 1a)
#   * `:` ranges, `len` (rules 4, 5)
#   * `[N:M]` slice instead of `substr` for codepoint-safe extraction
#
# Namespaced UDFs `RK::*`.
#
# Run: stryke --no-interop examples/rabin_karp_no_interop.stk

# Hash a string with base/mod polynomial: h = c0*b^(n-1) + c1*b^(n-2) + ...
fn RK::hash($s, $base, $mod) {
    var $h = 0
    for val $i (0:len($s) - 1) {
        $h = ($h * $base + ord($s[$i])) % $mod
    }
    $h
}

# Find every occurrence of `pat` in `text`. Returns 0-indexed positions.
fn RK::find_all($text, $pat) {
    val $m = len $pat
    val $n = len $text
    return [] if $m == 0 || $m > $n

    val $base = 257
    val $mod  = 1000000007
    val $pat_h = RK::hash($pat, $base, $mod)

    # Compute b^(m-1) % mod for the rolling-window subtraction step.
    var $high = 1
    for (1:$m - 1) { $high = ($high * $base) % $mod }

    # Initial window hash.
    var $win_h = RK::hash($text[0:$m - 1], $base, $mod)
    var @hits
    if ($win_h == $pat_h && $text[0:$m - 1] eq $pat) {
        push @hits, 0
    }

    for val $i (1:$n - $m) {
        # Roll: drop char at i-1, add char at i+m-1.
        val $drop = ord($text[$i - 1])
        val $add  = ord($text[$i + $m - 1])
        $win_h = (($win_h - $drop * $high) * $base + $add) % $mod
        # Modular arithmetic may go negative — normalize.
        $win_h = ($win_h + $mod) % $mod
        if ($win_h == $pat_h && $text[$i:$i + $m - 1] eq $pat) {
            push @hits, $i
        }
    }
    \@hits
}

# Brute-force reference impl for cross-checking — O(n·m).
fn RK::find_brute($text, $pat) {
    val $m = len $pat
    val $n = len $text
    return [] if $m == 0 || $m > $n
    var @hits
    for val $i (0:$n - $m) {
        push @hits, $i if $text[$i:$i + $m - 1] eq $pat
    }
    \@hits
}

p "── Rabin-Karp demo ──"

val @cases = (
    +{ text => "abracadabra",     pat => "abra",   hits => [0, 7]    },
    +{ text => "abracadabra",     pat => "cad",    hits => [4]       },
    +{ text => "abracadabra",     pat => "z",      hits => []        },
    +{ text => "abracadabra",     pat => "a",      hits => [0, 3, 5, 7, 10] },
    +{ text => "aaaa",            pat => "aa",     hits => [0, 1, 2] },  # overlapping
    +{ text => "",                pat => "x",      hits => []        },
    +{ text => "x",               pat => "x",      hits => [0]       },
    +{ text => "x",               pat => "xx",     hits => []        },
    +{ text => "the the the",     pat => "the",    hits => [0, 4, 8] },
    +{ text => "the the the",     pat => "th",     hits => [0, 4, 8] },
)

var $fail = 0
for var $c (@cases) {
    val $rk    = RK::find_all($c->{text}, $c->{pat})
    val $brute = RK::find_brute($c->{text}, $c->{pat})
    val $rk_s    = join(",", @$rk)
    val $brute_s = join(",", @$brute)
    val $want    = join(",", @{$c->{hits}})
    val $ok      = $rk_s eq $want && $brute_s eq $want
    $fail++ unless $ok
    p "  RK(\"$c->{text}\", \"$c->{pat}\") = [$rk_s]  expect [$want]  #{$ok ? \"\" : \"FAIL\"}"
}
die "$fail / #{len @cases} RK cases failed" if $fail > 0

# Universal invariants:
#   * RK results == brute-force results (full cross-check)
#   * Every hit position `i` actually has the pattern at text[i:i+m-1]
#   * No hits when pattern longer than text
for val $c (@cases) {
    val $hits = RK::find_all($c->{text}, $c->{pat})
    val $m    = len $c->{pat}
    val $tx   = $c->{text}
    for val $i (@$hits) {
        die "false hit at $i" unless $tx[$i:$i + $m - 1] eq $c->{pat}
    }
}

# Stress: random text of length 1000, pattern "abc" → verify against brute.
srand(42)
val $alphabet = "abcde"
var @text_chars
push @text_chars, $alphabet[int(rand 5)] for 1:1000
val $rand_text = join("", @text_chars)
val $rk_hits    = RK::find_all($rand_text, "abc")
val $brute_hits = RK::find_brute($rand_text, "abc")
die "stress disagreement" unless join(",", @$rk_hits) eq join(",", @$brute_hits)
p "  1000-char stress: RK and brute-force agree on #{len(@$rk_hits)} hits  OK"

p ""
p "  ALL PASS (10 cases + position-correctness + 1000-char stress vs brute)"
