#!/usr/bin/env stryke

fn AVL::height($n) { defined $n ? $n->{h} : 0 }

fn AVL::node($v) {
    +{ val => $v, left => undef, right => undef, h => 1 }
}

fn AVL::_update_h($n) {
    val $lh = AVL::height($n->{left})
    val $rh = AVL::height($n->{right})
    $n->{h} = 1 + ($lh > $rh ? $lh : $rh)
}

fn AVL::_balance($n) {
    AVL::height($n->{left}) - AVL::height($n->{right})
}

fn AVL::_rot_right($y) {
    var $x  = $y->{left}
    val $t2 = $x->{right}
    $x->{right} = $y
    $y->{left}  = $t2
    AVL::_update_h($y)
    AVL::_update_h($x)
    $x
}

fn AVL::_rot_left($x) {
    var $y  = $x->{right}
    val $t2 = $y->{left}
    $y->{left}  = $x
    $x->{right} = $t2
    AVL::_update_h($x)
    AVL::_update_h($y)
    $y
}

fn AVL::insert($n, $v) {
    return AVL::node($v) unless defined $n
    if ($v < $n->{val}) {
        $n->{left} = AVL::insert($n->{left}, $v)
    } elsif ($v > $n->{val}) {
        $n->{right} = AVL::insert($n->{right}, $v)
    } else {
        return $n
    }
    AVL::_update_h($n)
    val $bf = AVL::_balance($n)
    if ($bf > 1 && $v < $n->{left}->{val})  { return AVL::_rot_right($n) }
    if ($bf < -1 && $v > $n->{right}->{val}) { return AVL::_rot_left($n) }
    if ($bf > 1 && $v > $n->{left}->{val}) {
        $n->{left} = AVL::_rot_left($n->{left})
        return AVL::_rot_right($n)
    }
    if ($bf < -1 && $v < $n->{right}->{val}) {
        $n->{right} = AVL::_rot_right($n->{right})
        return AVL::_rot_left($n)
    }
    $n
}

fn AVL::contains($n, $v) {
    return 0 unless defined $n
    return 1 if $n->{val} == $v
    $v < $n->{val} ? AVL::contains($n->{left}, $v) : AVL::contains($n->{right}, $v)
}

fn AVL::inorder($n) {
    var @out = ()
    return \@out unless defined $n
    for val $x (@{AVL::inorder($n->{left})})  { push @out, $x }
    push @out, $n->{val}
    for val $x (@{AVL::inorder($n->{right})}) { push @out, $x }
    \@out
}

fn AVL::balanced($n) {
    return 1 unless defined $n
    val $bf = AVL::_balance($n)
    return 0 if $bf < -1 || $bf > 1
    AVL::balanced($n->{left}) && AVL::balanced($n->{right})
}

# Empty
AVL::height(undef)   |> aeq 0, "empty height"
AVL::balanced(undef) |> aeq 1, "empty balanced"
AVL::contains(undef, 5) |> aeq 0, "empty contains"
len(@{AVL::inorder(undef)}) |> aeq 0, "empty inorder"

# Single
val $r1 = AVL::insert(undef, 42)
AVL::height($r1)   |> aeq 1, "single height"
AVL::balanced($r1) |> aeq 1, "single balanced"
AVL::contains($r1, 42) |> aeq 1, "contains 42"
AVL::contains($r1, 1)  |> aeq 0, "no 1"
join(",", @{AVL::inorder($r1)}) |> aeq "42", "single inorder"

# Duplicate insert no-op
val $r2 = AVL::insert($r1, 42)
join(",", @{AVL::inorder($r2)}) |> aeq "42", "duplicate inorder"

# Right-right (LL) rotation case
var $rr = undef
for val $v (1, 2, 3) { $rr = AVL::insert($rr, $v) }
AVL::balanced($rr) |> aeq 1, "LL balanced"
AVL::height($rr)   |> aeq 2, "LL height 2"
$rr->{val} |> aeq 2, "LL root is 2"

# Left-left (RR rotation case)
var $ll = undef
for val $v (3, 2, 1) { $ll = AVL::insert($ll, $v) }
AVL::balanced($ll) |> aeq 1, "RR balanced"
$ll->{val} |> aeq 2, "RR root is 2"

# Right-left rotation
var $rl = undef
for val $v (1, 3, 2) { $rl = AVL::insert($rl, $v) }
$rl->{val} |> aeq 2, "RL root is 2"
AVL::balanced($rl) |> aeq 1, "RL balanced"

# Left-right rotation
var $lr = undef
for val $v (3, 1, 2) { $lr = AVL::insert($lr, $v) }
$lr->{val} |> aeq 2, "LR root is 2"
AVL::balanced($lr) |> aeq 1, "LR balanced"

# Inorder is sorted for arbitrary insertion order
var $rand = undef
for val $v (5, 3, 8, 1, 9, 4, 7, 2, 6) { $rand = AVL::insert($rand, $v) }
join(",", @{AVL::inorder($rand)}) |> aeq "1,2,3,4,5,6,7,8,9", "rand inorder sorted"
AVL::balanced($rand) |> aeq 1, "rand balanced"

# Ascending 1..32 stays balanced and height log-ish
var $asc = undef
for val $v (1:32) { $asc = AVL::insert($asc, $v) }
AVL::balanced($asc) |> aeq 1, "ascending balanced"
(AVL::height($asc) <= 7 ? 1 : 0) |> aeq 1, "height stays small"
len(@{AVL::inorder($asc)}) |> aeq 32, "32 elems"

# Descending 32..1 stays balanced
var $dsc = undef
for val $v (1:32) { $dsc = AVL::insert($dsc, 33 - $v) }
AVL::balanced($dsc) |> aeq 1, "descending balanced"
(AVL::height($dsc) <= 7 ? 1 : 0) |> aeq 1, "desc height small"
join(",", @{AVL::inorder($dsc)}->[0:4]) |> aeq "1,2,3,4,5", "desc sorted (first 5)"

# Mixed contains
for val $v (1, 5, 10, 16, 32) {
    AVL::contains($asc, $v) |> aeq 1, "asc contains $v"
}
AVL::contains($asc, 0)  |> aeq 0, "no 0"
AVL::contains($asc, 33) |> aeq 0, "no 33"

# Larger stress: 100 random-ish insertions stay balanced
var $big = undef
var $seed = 12345
for val $i (1:100) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    $big = AVL::insert($big, $seed % 1000)
}
AVL::balanced($big) |> aeq 1, "100 stress balanced"

test_run
