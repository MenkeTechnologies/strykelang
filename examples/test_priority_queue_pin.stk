#!/usr/bin/env stryke

# Binary heap–based priority queue (min-heap).

fn Pq::new() { +{ heap => [] } }

fn Pq::size($q) { len(@{$q->{heap}}) }

fn Pq::_swap($h, $i, $j) {
    my $t = $h->[$i]
    $h->[$i] = $h->[$j]
    $h->[$j] = $t
}

fn Pq::push($q, $val) {
    my $h = $q->{heap}
    push @$h, $val
    my $i = len(@$h) - 1
    while ($i > 0) {
        my $parent = int(($i - 1) / 2)
        last if $h->[$parent] <= $h->[$i]
        Pq::_swap($h, $i, $parent)
        $i = $parent
    }
}

fn Pq::peek($q) { $q->{heap}[0] }

fn Pq::pop($q) {
    my $h = $q->{heap}
    return undef if len(@$h) == 0
    my $top = $h->[0]
    my $last = pop @$h
    if (len(@$h) > 0) {
        $h->[0] = $last
        my $i = 0
        my $n = len(@$h)
        while (1) {
            my $l = 2 * $i + 1
            my $r = 2 * $i + 2
            my $sm = $i
            $sm = $l if $l < $n && $h->[$l] < $h->[$sm]
            $sm = $r if $r < $n && $h->[$r] < $h->[$sm]
            last if $sm == $i
            Pq::_swap($h, $i, $sm)
            $i = $sm
        }
    }
    $top
}

fn Pq::drain($q) {
    my @out
    push @out, Pq::pop($q) while Pq::size($q) > 0
    \@out
}

my $q = Pq::new()
Pq::size($q) |> aeq 0, "empty size"

Pq::push($q, 5)
Pq::push($q, 1)
Pq::push($q, 9)
Pq::push($q, 3)
Pq::push($q, 7)
Pq::push($q, 0)

Pq::size($q) |> aeq 6, "size after pushes"
Pq::peek($q) |> aeq 0, "peek min"

Pq::pop($q) |> aeq 0, "pop 0"
Pq::pop($q) |> aeq 1, "pop 1"
Pq::pop($q) |> aeq 3, "pop 3"
Pq::size($q) |> aeq 3, "size after 3 pops"

# Drain remainder
my $rest = Pq::drain($q)
join(",", @$rest) |> aeq "5,7,9", "drain rest sorted"

# Heap-sort: push everything, drain into sorted array
my $q2 = Pq::new()
Pq::push($q2, _) for 42, 17, 8, 99, 23, 5, 61, 30, 1, 88
my $sorted = Pq::drain($q2)
join(",", @$sorted) |> aeq "1,5,8,17,23,30,42,61,88,99", "heap sort"

# Stress: insert 100 ints, drain, ensure ascending
my $q3 = Pq::new()
Pq::push($q3, int(rand() * 1000)) for 1:100
my $out = Pq::drain($q3)
len(@$out) |> aeq 100, "stress size"
my $ascending = 1
for my $i (1:99) {
    $ascending = 0 if $out->[$i] < $out->[$i - 1]
}
$ascending |> aok "stress ascending"

# Empty pop returns undef
my $q4 = Pq::new()
!defined(Pq::pop($q4)) |> aok "pop empty undef"

test_run
