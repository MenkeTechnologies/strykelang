#!/usr/bin/env stryke

# Pinning batch Native-T (2026-05-10): Advanced Math & Physics
# Compliance: docs/STYLE_GUIDE.md

# ── Bessel & Special Functions ─────────────────────────────────────────────

bessel_j0(0) |> maps { abs(_ - 1.0) < 1e-8 } |> aok "bessel_j0(0) near 1"
bessel_j1(0) |> aeq 0, "bessel_j1(0)"
bessel_i(0, 0) |> aeq 1, "bessel_i(0, 0)"
bessel_k(0, 1) |> maps { _ > 0.4 && _ < 0.5 } |> aok "bessel_k(0, 1)"

airy_ai(0) |> maps { abs(_ - 0.3550) < 0.001 } |> aok "airy_ai(0)"
airy_bi(0) |> maps { abs(_ - 0.6149) < 0.001 } |> aok "airy_bi(0)"

# ── Hypergeometric & Polylog ───────────────────────────────────────────────

log_integral(2) |> maps { abs(_ - 1.045) < 0.01 } |> aok "log_integral(2)"
polylog(2, 0.5) |> maps { abs(_ - 0.582) < 0.01 } |> aok "polylog(2, 0.5)"

# ── Quantum Primitives ─────────────────────────────────────────────────────

# pauli_x returns a matrix that stringifies as '0110' (len 4) but serializes as an array
pauli_x() |> len |> aeq 4, "pauli_x flat length"
# bell_state(0) returns coefficient 1/sqrt(2)
bell_state(0) |> maps { abs(_ - 0.707) < 0.001 } |> aok "bell_state(0) coeff"

# ── String Similarity (Extended) ───────────────────────────────────────────

jaro_winkler("martha", "marhta") |> maps { _ > 0.9 } |> aok "jaro_winkler high"
hamming_distance("101", "100") |> aeq 1, "hamming_distance"
sorensen_dice("context", "contact") |> maps { _ > 0.5 && _ < 0.6 } |> aok "sorensen_dice"

# ── Audio & DSP ────────────────────────────────────────────────────────────

a_weighting_factor(1000) |> maps { abs(_ - 1.0) < 1e-4 } |> aok "a_weighting_factor(1000Hz) near 1.0"

test_run
