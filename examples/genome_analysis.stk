#!/usr/bin/env stryke

# DNA sequence analysis demo. Patterns:
#   * GC content (% G + C nucleotides)
#   * codon frequency (consecutive 3-bases)
#   * reverse complement
#   * ORF (open reading frame) detection between start/stop codons
#   * t-digest for per-codon scan latency
#   * sketch (TopK) for most-frequent codons

# ── sample DNA sequence (synthetic) ────────────────────────────────

val $dna = "ATGAAACCTGCAGGCCCTGGGTAAGTCATGGCTCCTGAATAGTTTAAACCG" .
          "ATGGCCATTGGCAAGTTGCATGCTAGCTGAACGCATGAGCAACGTCCATAA" .
          "CGTGCTACGACGCATAGCCTAGCATGCAGCGTAGACGCATCAGTGCATGTC"

printf "── DNA sequence: %d bases ───────────────────────────\n",
    len $dna

# ── GC content ──────────────────────────────────────────────────────

var $ng = 0
var $nc = 0
var $na = 0
var $nt = 0
var $other = 0
for val $i (0:len($dna) - 1) {
    val $ch = substr($dna, $i, 1)
    if    ($ch eq "G") { $ng++ }
    elsif ($ch eq "C") { $nc++ }
    elsif ($ch eq "A") { $na++ }
    elsif ($ch eq "T") { $nt++ }
    else               { $other++ }
}

val $total = $na + $nc + $ng + $nt
val $gc_pct = 100.0 * ($ng + $nc) / $total

p ""
p "── nucleotide composition ───────────────────────────"
printf "  A : %4d (%.1f%%)\n", $na, 100.0 * $na / $total
printf "  C : %4d (%.1f%%)\n", $nc, 100.0 * $nc / $total
printf "  G : %4d (%.1f%%)\n", $ng, 100.0 * $ng / $total
printf "  T : %4d (%.1f%%)\n", $nt, 100.0 * $nt / $total
printf "  GC content : %.1f%%\n", $gc_pct

# ── codon frequency ─────────────────────────────────────────────────

var %codon_count
val $td_scan = t_digest(100)
val $tk_codons = topk(5)

var $i = 0
while ($i + 3 <= len($dna)) {
    val $t0 = now_ns()
    val $codon = substr($dna, $i, 3)
    $codon_count{$codon} = ($codon_count{$codon} // 0) + 1
    topk_add($tk_codons, $codon)
    td_add($td_scan, (now_ns() - $t0) / 1000.0)
    $i = $i + 3
}

p ""
printf "── codon frequencies (top 10 of %d distinct) ──────────\n",
    len(keys %codon_count)
val @sorted_codons = sort { $codon_count{_1} <=> $codon_count{_} } keys %codon_count
var $shown = 0
for val $codon (@sorted_codons) {
    last if $shown >= 10
    printf "  %s : %d\n", $codon, $codon_count{$codon}
    $shown++
}

# ── reverse complement ──────────────────────────────────────────────

val %complement = (A => "T", T => "A", G => "C", C => "G")

fn Demo::Genome::reverse_complement($seq) {
    var $rc = ""
    for val $i (rev(0:len($seq) - 1)) {
        val $ch = substr($seq, $i, 1)
        $rc .= ($complement{$ch} // "N")
    }
    $rc
}

val $rc = Demo::Genome::reverse_complement($dna)
p ""
p "── reverse complement (first 60 bases) ──────────────"
printf "  orig : %s\n", substr($dna, 0, 60)
printf "  rc   : %s\n", substr($rc, 0, 60)
printf "  rc length : %d (must match input)\n", len $rc

# ── ORF detection (between ATG start and TAA/TAG/TGA stop) ─────────

p ""
p "── open reading frames (ATG..STOP) ───────────────────"
var @orfs
for val $frame (0:2) {
    var $j = $frame
    while ($j + 3 <= len($dna)) {
        val $codon = substr($dna, $j, 3)
        if ($codon eq "ATG") {
            # Look for stop codon.
            var $k = $j + 3
            while ($k + 3 <= len($dna)) {
                val $next = substr($dna, $k, 3)
                if ($next eq "TAA" || $next eq "TAG" || $next eq "TGA") {
                    val $orf_len = $k + 3 - $j
                    if ($orf_len >= 30) {   # minimum length filter
                        push @orfs, +{
                            frame => $frame,
                            start => $j,
                            end   => $k + 3,
                            length => $orf_len,
                            stop_codon => $next,
                        }
                    }
                    last
                }
                $k = $k + 3
            }
        }
        $j = $j + 3
    }
}

@orfs = sort { _1->{length} <=> _->{length} } @orfs
printf "  found %d ORFs (≥30 bases)\n", len @orfs
var $orf_shown = 0
for val $orf (@orfs) {
    last if $orf_shown >= 5
    printf "  frame=%d start=%-3d end=%-3d length=%-3d stop=%s\n",
        $orf->{frame}, $orf->{start}, $orf->{end},
        $orf->{length}, $orf->{stop_codon}
    $orf_shown++
}

# ── distinct codons (HLL) ──────────────────────────────────────────

p ""
p "── HLL distinct codons ──────────────────────────────"
val $hll = hll(14)
for val $codon (keys %codon_count) {
    hll_add($hll, $codon)
}
printf "  HLL distinct codons : %d\n", hll_count($hll)
printf "  exact               : %d (max 64)\n", len(keys %codon_count)

# ── TopK most-frequent codons (sketch) ─────────────────────────────

p ""
p "── TopK most-frequent codons ────────────────────────"
val @hits = topk_top($tk_codons)
for val $h (@hits) {
    printf "  %s : %d hits\n", $h->[0], $h->[1]
}

# ── latency ─────────────────────────────────────────────────────────

p ""
p "── per-codon scan latency (t-digest) ────────────────"
printf "  p50  : %.1f µs\n", td_quantile($td_scan, 0.50)
printf "  p99  : %.1f µs\n", td_quantile($td_scan, 0.99)
