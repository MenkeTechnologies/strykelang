#!/usr/bin/env stryke

fn MT::hash($s) {
    var $h = 0
    val $n = len $s
    for val $i (0:$n-1) {
        val $c = ord(substr($s, $i, 1))
        $h = (($h * 31) + $c) % 1000000007
    }
    sprintf("%08x", $h)
}

fn MT::combine($aa, $bb) {
    MT::hash("(" . $aa . "|" . $bb . ")")
}

fn MT::build($leaves) {
    var @first = ()
    for val $x (@$leaves) { push @first, MT::hash($x) }
    var @levels = ()
    val @copy0 = @first
    push @levels, \@copy0
    var @level = @first
    while (len(@level) > 1) {
        var @next = ()
        var $i = 0
        val $n = len(@level)
        while ($i < $n) {
            val $left  = $level[$i]
            val $right = ($i + 1 < $n) ? $level[$i + 1] : $left
            push @next, MT::combine($left, $right)
            $i = $i + 2
        }
        val @copy = @next
        push @levels, \@copy
        @level = @next
    }
    +{ levels => \@levels, root => $level[0] }
}

fn MT::proof($tree, $idx) {
    var @proof = ()
    val $levels = $tree->{levels}
    val $depth = len(@$levels) - 1
    for val $d (0:$depth-1) {
        val $level = $levels->[$d]
        var $sib   = ($idx % 2 == 0) ? $idx + 1 : $idx - 1
        if ($sib >= len(@$level)) { $sib = $idx }
        val $side  = ($idx % 2 == 0) ? "right" : "left"
        push @proof, +{ hash => $level->[$sib], side => $side }
        $idx = int($idx / 2)
    }
    \@proof
}

fn MT::verify($leaf, $proof, $root) {
    var $h = MT::hash($leaf)
    for val $step (@$proof) {
        if ($step->{side} eq "right") {
            $h = MT::combine($h, $step->{hash})
        } else {
            $h = MT::combine($step->{hash}, $h)
        }
    }
    $h eq $root ? 1 : 0
}

# Determinism
MT::hash("a") |> aeq MT::hash("a"), "hash deterministic"
(MT::hash("a") eq MT::hash("b") ? 1 : 0) |> aeq 0, "different inputs differ"

# Build 4 leaves
val @l4 = ("a","b","c","d")
val $t4 = MT::build(\@l4)
len(@{$t4->{levels}}) |> aeq 3, "depth 3 for 4 leaves"
len(@{$t4->{levels}->[0]}) |> aeq 4, "L0 has 4"
len(@{$t4->{levels}->[1]}) |> aeq 2, "L1 has 2"
len(@{$t4->{levels}->[2]}) |> aeq 1, "L2 root"

# Verify all 4 inclusion proofs
MT::verify("a", MT::proof($t4, 0), $t4->{root}) |> aeq 1, "verify a"
MT::verify("b", MT::proof($t4, 1), $t4->{root}) |> aeq 1, "verify b"
MT::verify("c", MT::proof($t4, 2), $t4->{root}) |> aeq 1, "verify c"
MT::verify("d", MT::proof($t4, 3), $t4->{root}) |> aeq 1, "verify d"

# Wrong leaf fails
MT::verify("X", MT::proof($t4, 0), $t4->{root}) |> aeq 0, "wrong leaf fails"
MT::verify("a", MT::proof($t4, 1), $t4->{root}) |> aeq 0, "wrong proof fails"
MT::verify("a", MT::proof($t4, 0), "00000000")  |> aeq 0, "wrong root fails"

# Single leaf tree
val @l1 = ("only")
val $t1 = MT::build(\@l1)
$t1->{root} |> aeq MT::hash("only"), "single-leaf root"
len(@{MT::proof($t1, 0)}) |> aeq 0, "no proof needed"
MT::verify("only", MT::proof($t1, 0), $t1->{root}) |> aeq 1, "single verify"

# Odd leaves (duplication)
val @l3 = ("x","y","z")
val $t3 = MT::build(\@l3)
MT::verify("x", MT::proof($t3, 0), $t3->{root}) |> aeq 1, "odd verify 0"
MT::verify("y", MT::proof($t3, 1), $t3->{root}) |> aeq 1, "odd verify 1"
MT::verify("z", MT::proof($t3, 2), $t3->{root}) |> aeq 1, "odd verify 2"

# 8 leaves
val @l8 = ("a","b","c","d","e","f","g","h")
val $t8 = MT::build(\@l8)
len(@{$t8->{levels}}) |> aeq 4, "4 levels for 8 leaves"
for val $i (0:7) {
    MT::verify($l8[$i], MT::proof($t8, $i), $t8->{root}) |> aeq 1, "8-leaf verify $i"
}

# Different leaf sets give different roots
val @other = ("a","b","c","e")
val $to = MT::build(\@other)
(($to->{root} eq $t4->{root}) ? 1 : 0) |> aeq 0, "different roots"

test_run
