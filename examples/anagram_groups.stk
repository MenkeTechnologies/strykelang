#!/usr/bin/env stryke

# Anagram grouping demo: take a word list, group by sorted-character
# key (canonical form), find the largest groups, sketch-based hot-key
# detection. Showcases:
#   * split + sort on characters via split //
#   * hash-of-arrayref grouping (no autoviv: explicit init per BUG-216)
#   * pipe-forward composition
#   * TopK sketch for top anagram families
#   * t-digest for canonicalize() latency

# ── word list ───────────────────────────────────────────────────────

var @words = (
    "eat", "tea", "tan", "ate", "nat", "bat",
    "listen", "silent", "enlist", "tinsel",
    "evil", "vile", "live", "veil", "levi",
    "stop", "tops", "spot", "pots", "opts",
    "rat", "tar", "art",
    "race", "care", "acre",
    "hello", "world",
    "post", "spot",       # duplicate "spot"
    "tar", "rat",         # duplicates
    "dusty", "study",
    "night", "thing",
)

printf "── input: %d words ────────────────────────────────────\n",
    len @words

# ── canonical key: sorted characters ────────────────────────────────

val $td_lat = t_digest(100)

fn Demo::Anagram::canonical($word) {
    val $t0 = now_ns()
    val @chars = split //, lc $word
    val @sorted = sort { _ cmp _1 } @chars
    val $r = join("", @sorted)
    td_add($td_lat, (now_ns() - $t0) / 1000.0)
    $r
}

# ── group words by canonical key ────────────────────────────────────

var %groups
for val $w (@words) {
    val $k = Demo::Anagram::canonical($w)
    $groups{$k} = [] unless exists $groups{$k}
    push @{$groups{$k}}, $w
}

printf "  %d distinct canonical forms\n", len(keys %groups)

# ── report groups with 2+ members ───────────────────────────────────

p ""
p "── groups with 2+ members ────────────────────────────"
var @keep
for val $k (keys %groups) {
    next if len(@{$groups{$k}}) < 2
    push @keep, $k
}
@keep = sort { len(@{$groups{_1}}) <=> len(@{$groups{_}}) } @keep
for val $k (@keep) {
    val $members = $groups{$k}
    val @uniq_mems = sort { _ cmp _1 } uniq(@$members)
    printf "  '%s' (%d words): %s\n", $k, len(@uniq_mems), join(", ", @uniq_mems)
}

# ── singletons (no anagram partners) ────────────────────────────────

p ""
p "── singletons (no anagram partners in input) ────────"
var @singletons
for val $k (keys %groups) {
    push @singletons, $groups{$k}->[0] if len(uniq(@{$groups{$k}})) == 1
}
@singletons = sort { _ cmp _1 } @singletons
printf "  %d singletons: %s\n", len(@singletons), join(", ", @singletons)

# ── largest group ───────────────────────────────────────────────────

p ""
val @sorted_groups = sort { len(@{$groups{_1}}) <=> len(@{$groups{_}}) } keys %groups
val $largest_key = $sorted_groups[0]
printf "── largest anagram family ────────────────────────────\n"
printf "  canonical: '%s' (%d occurrences)\n",
    $largest_key, len(@{$groups{$largest_key}})
val @members = uniq(@{$groups{$largest_key}})
printf "  distinct members: %s\n", join(", ", sort { _ cmp _1 } @members)

# ── sketch-based "hot keys" using TopK ──────────────────────────────

p ""
p "── TopK hottest anagram families (sketch) ────────────"
val $tk = topk(5)
topk_add($tk, Demo::Anagram::canonical(_)) for @words
var @hits = topk_top($tk)
for val $h (@hits) {
    printf "  '%s' : %d hits\n", $h->[0], $h->[1]
}

# ── HLL: distinct canonical forms ───────────────────────────────────

p ""
p "── distinct canonical-key cardinality (HLL) ──────────"
val $hll = hll(14)
hll_add($hll, Demo::Anagram::canonical(_)) for @words
printf "  HLL distinct keys : %d\n", hll_count($hll)
printf "  exact (hash keys) : %d\n", len(keys %groups)

# ── pipe-forward composition: distinct canonical forms via uniq ─────

p ""
p "── pipe-forward composition ──────────────────────────"
val @all_canonical = map {Demo::Anagram::canonical} @words
val @distinct_keys = sort { _ cmp _1 } uniq(@all_canonical)
printf "  distinct canonical forms (composed): %d\n", len @distinct_keys
printf "  alphabetically first: %s\n", $distinct_keys[0]
printf "  alphabetically last : %s\n", $distinct_keys[-1]

# ── canonicalize latency ────────────────────────────────────────────

p ""
p "── canonicalize() latency (t-digest) ─────────────────"
printf "  p50  : %.1f µs\n", td_quantile($td_lat, 0.50)
printf "  p99  : %.1f µs\n", td_quantile($td_lat, 0.99)
