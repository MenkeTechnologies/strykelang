#!/usr/bin/env stryke

# Pinning batch System-Resources (2026-05-10): Resource Introspection
# Compliance: docs/STYLE_GUIDE.md

# ── 1. CPU & Memory ───────────────────────────────────────────────────────

cpu_count() |> maps { _ > 0 } |> aok "cpu_count is positive"
mem_total() |> maps { _ > 0 } |> aok "mem_total is positive"

# ── 2. High-precision Time ────────────────────────────────────────────────

val $t1 = now_ns()
sleep 0.01
val $t2 = now_ns()
($t2 > $t1) |> aok "now_ns is monotonic"

# ── 3. Temp Assets ────────────────────────────────────────────────────────

val $tmp_dir = tempdir()
$tmp_dir |> maps { -d _ } |> aok "tempdir creates directory"

val $tmp_file = tempfile()
$tmp_file |> maps { -f _ } |> aok "tempfile creates file"

# ── 4. Slurp & Spurt ───────────────────────────────────────────────────────

val $data = "stryke pinning test"
spurt $tmp_file, $data
slurp($tmp_file) |> aeq $data, "spurt/slurp roundtrip"

test_run
