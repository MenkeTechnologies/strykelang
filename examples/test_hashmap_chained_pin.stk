#!/usr/bin/env stryke

fn HM::_hash($s) {
    var $h = 2166136261
    val $n = len $s
    for val $i (0:$n-1) {
        val $c = ord(substr($s, $i, 1))
        $h = ($h ^ $c)
        $h = ($h * 16777619) % 4294967296
    }
    $h
}

fn HM::new() {
    var @b = ()
    for val $i (1:8) { push @b, [] }
    +{ buckets => \@b, size => 0, cap => 8 }
}

fn HM::_bucket($hm, $k) {
    val $h = HM::_hash($k)
    $hm->{buckets}->[$h % $hm->{cap}]
}

fn HM::get($hm, $k) {
    val $bk = HM::_bucket($hm, $k)
    for val $p (@$bk) {
        return $p->[1] if $p->[0] eq $k
    }
    undef
}

fn HM::has($hm, $k) {
    val $bk = HM::_bucket($hm, $k)
    for val $p (@$bk) {
        return 1 if $p->[0] eq $k
    }
    0
}

fn HM::_resize($hm) {
    val $newcap = $hm->{cap} * 2
    var @nb = ()
    for val $i (1:$newcap) { push @nb, [] }
    for val $bucket (@{$hm->{buckets}}) {
        for val $p (@$bucket) {
            val $h = HM::_hash($p->[0])
            push @{$nb[$h % $newcap]}, $p
        }
    }
    $hm->{buckets} = \@nb
    $hm->{cap}     = $newcap
}

fn HM::put($hm, $k, $v) {
    val $bk = HM::_bucket($hm, $k)
    for var $p (@$bk) {
        if ($p->[0] eq $k) {
            $p->[1] = $v
            return
        }
    }
    push @$bk, [$k, $v]
    $hm->{size} = $hm->{size} + 1
    if ($hm->{size} * 4 > $hm->{cap} * 3) {
        HM::_resize($hm)
    }
}

fn HM::delete($hm, $k) {
    val $bk = HM::_bucket($hm, $k)
    var @kept = ()
    var $removed = 0
    for val $p (@$bk) {
        if ($p->[0] eq $k && !$removed) {
            $removed = 1
        } else {
            push @kept, $p
        }
    }
    if ($removed) {
        $hm->{size} = $hm->{size} - 1
        val $idx = HM::_hash($k) % $hm->{cap}
        $hm->{buckets}->[$idx] = \@kept
    }
    $removed
}

fn HM::keys($hm) {
    var @out = ()
    for val $bk (@{$hm->{buckets}}) {
        for val $p (@$bk) { push @out, $p->[0] }
    }
    val @s = sort @out
    \@s
}

fn HM::size($hm) { $hm->{size} }
fn HM::cap($hm)  { $hm->{cap} }

# Empty
val $e = HM::new()
HM::size($e) |> aeq 0, "empty size"
HM::cap($e)  |> aeq 8, "init cap"
(defined HM::get($e, "x") ? 1 : 0) |> aeq 0, "miss undef"
HM::has($e, "x") |> aeq 0, "no has"
len(@{HM::keys($e)}) |> aeq 0, "no keys"

# Put/get
val $hm = HM::new()
HM::put($hm, "a", 1)
HM::put($hm, "b", 2)
HM::put($hm, "c", 3)
HM::size($hm) |> aeq 3, "3 entries"
HM::get($hm, "a") |> aeq 1, "get a"
HM::get($hm, "b") |> aeq 2, "get b"
HM::get($hm, "c") |> aeq 3, "get c"
HM::has($hm, "a") |> aeq 1, "has a"
HM::has($hm, "ghost") |> aeq 0, "no ghost"

# Update existing
HM::put($hm, "a", 100)
HM::get($hm, "a") |> aeq 100, "updated value"
HM::size($hm) |> aeq 3, "size unchanged"

# Delete
HM::delete($hm, "b") |> aeq 1, "deleted returns 1"
HM::has($hm, "b")    |> aeq 0, "b gone"
HM::size($hm)        |> aeq 2, "size 2"
HM::delete($hm, "b") |> aeq 0, "delete absent returns 0"
HM::delete($hm, "missing") |> aeq 0, "delete missing"

# Keys
join(",", @{HM::keys($hm)}) |> aeq "a,c", "keys sorted"

# Auto resize triggers
val $big = HM::new()
for val $i (1:20) { HM::put($big, "k" . $i, $i * 10) }
HM::size($big) |> aeq 20, "20 entries"
(HM::cap($big) > 8 ? 1 : 0) |> aeq 1, "cap grew"
# Spot check survival
HM::get($big, "k1")  |> aeq 10,  "k1 after resize"
HM::get($big, "k10") |> aeq 100, "k10 after resize"
HM::get($big, "k20") |> aeq 200, "k20 after resize"

# Mass delete halves
for val $i (1:10) { HM::delete($big, "k" . $i) }
HM::size($big) |> aeq 10, "10 left"
HM::has($big, "k5")  |> aeq 0, "k5 gone"
HM::has($big, "k15") |> aeq 1, "k15 kept"

# Empty string key
val $es = HM::new()
HM::put($es, "", "empty-val")
HM::get($es, "") |> aeq "empty-val", "empty key"
HM::has($es, "") |> aeq 1, "has empty"

# Mixed value types
val $mt = HM::new()
HM::put($mt, "int",  42)
HM::put($mt, "str",  "hi")
HM::put($mt, "arr",  [1,2,3])
HM::put($mt, "hash", +{ k => 1 })
HM::get($mt, "int") |> aeq 42, "int val"
HM::get($mt, "str") |> aeq "hi", "str val"
ref(HM::get($mt, "arr"))  |> aeq "ARRAY", "arr val ref"
ref(HM::get($mt, "hash")) |> aeq "HASH",  "hash val ref"

test_run
