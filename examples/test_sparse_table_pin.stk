#!/usr/bin/env stryke

package ST;

fn ilog2($n) {
    my $k = 0
    my $v = $n
    while ($v > 1) {
        $v = $v >> 1
        $k = $k + 1
    }
    $k
}

fn build_min($arr) {
    my $n = len(@$arr)
    my $logn = ilog2($n) + 1
    my @table = ()
    my @row0 = ()
    for my $i (0:$n-1) { push @row0, $arr->[$i] }
    push @table, \@row0
    for my $k (1:$logn-1) {
        my $half = 1 << ($k - 1)
        my $span = 1 << $k
        my @row = ()
        my $last = $n - $span
        if ($last < 0) {
            for my $i (0:$n-1) { push @row, $table[$k-1]->[$i] }
        } else {
            for my $i (0:$last) {
                my $va = $table[$k-1]->[$i]
                my $vb = $table[$k-1]->[$i + $half]
                push @row, ($va <= $vb ? $va : $vb)
            }
        }
        push @table, \@row
    }
    { table => \@table, n => $n, logn => $logn }
}

fn build_max($arr) {
    my $n = len(@$arr)
    my $logn = ilog2($n) + 1
    my @table = ()
    my @row0 = ()
    for my $i (0:$n-1) { push @row0, $arr->[$i] }
    push @table, \@row0
    for my $k (1:$logn-1) {
        my $half = 1 << ($k - 1)
        my $span = 1 << $k
        my @row = ()
        my $last = $n - $span
        if ($last < 0) {
            for my $i (0:$n-1) { push @row, $table[$k-1]->[$i] }
        } else {
            for my $i (0:$last) {
                my $va = $table[$k-1]->[$i]
                my $vb = $table[$k-1]->[$i + $half]
                push @row, ($va >= $vb ? $va : $vb)
            }
        }
        push @table, \@row
    }
    { table => \@table, n => $n, logn => $logn }
}

fn query_min($s, $l, $r) {
    return undef if $l > $r || $l < 0 || $r >= $s->{n}
    my $k = ilog2($r - $l + 1)
    my $span = 1 << $k
    my $va = $s->{table}->[$k]->[$l]
    my $vb = $s->{table}->[$k]->[$r - $span + 1]
    $va <= $vb ? $va : $vb
}

fn query_max($s, $l, $r) {
    return undef if $l > $r || $l < 0 || $r >= $s->{n}
    my $k = ilog2($r - $l + 1)
    my $span = 1 << $k
    my $va = $s->{table}->[$k]->[$l]
    my $vb = $s->{table}->[$k]->[$r - $span + 1]
    $va >= $vb ? $va : $vb
}

fn brute_min($arr, $l, $r) {
    my $m = $arr->[$l]
    for my $i ($l:$r) {
        $m = $arr->[$i] if $arr->[$i] < $m
    }
    $m
}

fn brute_max($arr, $l, $r) {
    my $m = $arr->[$l]
    for my $i ($l:$r) {
        $m = $arr->[$i] if $arr->[$i] > $m
    }
    $m
}

package main;

# --- ilog2 sanity ---
ST::ilog2(1)  |> aeq 0, "ilog2(1)"
ST::ilog2(2)  |> aeq 1, "ilog2(2)"
ST::ilog2(3)  |> aeq 1, "ilog2(3)"
ST::ilog2(4)  |> aeq 2, "ilog2(4)"
ST::ilog2(7)  |> aeq 2, "ilog2(7)"
ST::ilog2(8)  |> aeq 3, "ilog2(8)"
ST::ilog2(31) |> aeq 4, "ilog2(31)"
ST::ilog2(32) |> aeq 5, "ilog2(32)"

# --- Single element ---
my $s1 = ST::build_min([42])
ST::query_min($s1, 0, 0) |> aeq 42, "single min"
my $s1x = ST::build_max([42])
ST::query_max($s1x, 0, 0) |> aeq 42, "single max"

# --- Two elements ---
my $s2 = ST::build_min([5, 3])
ST::query_min($s2, 0, 0) |> aeq 5, "two min[0..0]"
ST::query_min($s2, 1, 1) |> aeq 3, "two min[1..1]"
ST::query_min($s2, 0, 1) |> aeq 3, "two min[0..1]"

# --- Canonical ---
my $arr = [7, 2, 3, 0, 5, 10, 3, 12, 18, 6]
my $smin = ST::build_min($arr)
my $smax = ST::build_max($arr)
ST::query_min($smin, 0, 9) |> aeq 0, "canon full min"
ST::query_max($smax, 0, 9) |> aeq 18, "canon full max"
ST::query_min($smin, 4, 9) |> aeq 3, "canon min[4..9]"
ST::query_max($smax, 4, 9) |> aeq 18, "canon max[4..9]"
ST::query_min($smin, 7, 9) |> aeq 6, "canon min[7..9]"
ST::query_max($smax, 0, 4) |> aeq 7, "canon max[0..4]"
ST::query_min($smin, 5, 5) |> aeq 10, "canon min[5..5]"

# --- Out-of-bounds returns undef ---
(defined ST::query_min($smin, -1, 3)) |> aeq 0, "oob l<0"
(defined ST::query_min($smin, 0, 10)) |> aeq 0, "oob r>=n"
(defined ST::query_min($smin, 5, 4)) |> aeq 0, "oob l>r"

# --- Constant array ---
my $sc = ST::build_min([9, 9, 9, 9, 9, 9])
for my $l (0:5) {
    for my $r ($l:5) {
        ST::query_min($sc, $l, $r) |> aeq 9, "const min[$l..$r]"
    }
}

# --- Negative values ---
my $sn = ST::build_min([-3, -1, -5, 0, -2, -4])
ST::query_min($sn, 0, 5) |> aeq -5, "neg min full"
ST::query_min($sn, 3, 5) |> aeq -4, "neg min[3..5]"
my $snx = ST::build_max([-3, -1, -5, 0, -2, -4])
ST::query_max($snx, 0, 5) |> aeq 0, "neg max full"

# --- Power-of-two-sized array exercises every row ---
my @p16 = ()
for my $i (1:16) { push @p16, ($i * 7) % 50 }
my $sp = ST::build_min(\@p16)
my $spm = ST::build_max(\@p16)
my $ok16 = 1
for my $l (0:15) {
    for my $r ($l:15) {
        $ok16 = 0 if ST::query_min($sp, $l, $r) != ST::brute_min(\@p16, $l, $r)
        $ok16 = 0 if ST::query_max($spm, $l, $r) != ST::brute_max(\@p16, $l, $r)
    }
}
$ok16 |> aeq 1, "p16 all ranges match brute"

# --- Stress: random array, all O(n^2) ranges vs brute ---
my $seed = 13371337
my @rand = ()
for my $i (1:50) {
    $seed = ($seed * 1103515245 + 12345) % 2147483648
    push @rand, ($seed % 2000) - 1000
}
my $sr_min = ST::build_min(\@rand)
my $sr_max = ST::build_max(\@rand)
my $all = 1
for my $l (0:49) {
    for my $r ($l:49) {
        $all = 0 if ST::query_min($sr_min, $l, $r) != ST::brute_min(\@rand, $l, $r)
        $all = 0 if ST::query_max($sr_max, $l, $r) != ST::brute_max(\@rand, $l, $r)
    }
}
$all |> aeq 1, "stress: all min/max ranges match brute"

# --- Idempotent: querying a single index returns arr[i] ---
my $self_ok = 1
for my $i (0:49) {
    $self_ok = 0 if ST::query_min($sr_min, $i, $i) != $rand[$i]
    $self_ok = 0 if ST::query_max($sr_max, $i, $i) != $rand[$i]
}
$self_ok |> aeq 1, "stress: single-index identity"

test_run
