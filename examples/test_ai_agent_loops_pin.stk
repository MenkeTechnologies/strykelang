#!/usr/bin/env stryke

# AI Agent Loops & Advanced Primitives (2026-05-15)
# Testing Tool Use, Sessions, Extraction, and Vector Memory.
# Compliance: docs/STYLE_GUIDE.md
# Mode: --no-interop
#
# Run with STRYKE_AI_MODE=mock-only in the environment to avoid hitting
# the network. Mocks below install the deterministic responses each
# assertion expects.

# ── 1. AI Sessions (Multi-turn) ─────────────────────────────────────────────

# Mocks use the FIRST regex that matches; later prompts (extraction
# schema, weather, etc.) include the word `name` and the substring `hi`
# in their bodies. Anchor each mock with phrases unique to the
# specific user message so they don't fire on unrelated downstream
# prompts.
ai_mock_install("(?i)\\bhi\\b", "Hello! How can I help?")
ai_mock_install("(?i)what is your name", "My name is StrykeAgent.")

my $sess_obj = ai_session_new(system => "You are a helpful assistant")
ai_session_send($sess_obj, "hi") |> aeq "Hello! How can I help?", "Session turn 1"
ai_session_send($sess_obj, "what is your name?") |> aeq "My name is StrykeAgent.", "Session turn 2"
my @sess_hist = ai_session_history($sess_obj)
@sess_hist |> len |> { _ >= 4 } |> aok "Session history length (system + 2 turns)"
$sess_hist[1]->{content} |> aeq "hi", "Session history first user message"
ai_session_reset($sess_obj)
ai_session_history($sess_obj) |> len |> aeq 1, "Session history after reset (system only)"
ai_session_close($sess_obj)

# ── 2. AI Extraction with Schema ────────────────────────────────────────────

# Per `ai_extract` docs: one positional arg (the prompt) + opts. The
# task description goes inside the prompt itself; previously this test
# tried to pass it as a second positional which got eaten as an opt
# key by `parse_opts`.
ai_mock_install("(?i)extract user", '{"name":"Alice","age":30}')
my $u_schema = +{ name => "string", age => "int" }
my $u_obj = ai_extract("Alice is 30 years old. Task: extract user", schema => $u_schema)
$u_obj->{name} |> aeq "Alice", "ai_extract name"
$u_obj->{age}  |> aeq 30, "ai_extract age"

# ── 3. Tool Function Mocking ────────────────────────────────────────────────

tool fn get_temp($city: string) "Get current temperature" {
    $city eq "San Francisco" ? 65 : 75
}

ai_mock_install("(?i)weather.*SF", '{"tool_calls":[{"name":"get_temp","args":{"city":"San Francisco"}}]}')
ai_mock_install("(?i)65 degrees", "The weather in San Francisco is 65 degrees.")

my $r_loop = ai "What is the weather in SF?"
$r_loop |> { /65/ } |> aok "Agent used get_temp via mock"

# ── 4. AI Vector Memory (Mock Mode) ─────────────────────────────────────────

ai_memory_clear()
ai_memory_save("doc1", "Stryke is a fast language", +{ category => "tech" })
ai_memory_save("doc2", "Apples are delicious", +{ category => "food" })

ai_memory_count() |> aeq 2, "ai_memory_count after save"
# Mock embeddings (SHA256-based, see `mock_embedding` in ai.rs) have no
# semantic ordering — they're hash-deterministic noise. Pull top_k=2 and
# assert both expected ids are present rather than asserting on rank.
my @m_results = ai_memory_recall("Stryke", top_k => 2)
@m_results |> len |> aeq 2, "ai_memory_recall count"
my @ids = sort map { $_->{id} } @m_results
($ids[0] eq "doc1" && $ids[1] eq "doc2") |> aok "ai_memory_recall returns both docs"
my ($doc1_row) = grep { $_->{id} eq "doc1" } @m_results
$doc1_row->{metadata}->{category} |> aeq "tech", "ai_memory_recall metadata"
ai_memory_forget("doc1")
ai_memory_count() |> aeq 1, "ai_memory_count after forget"
ai_memory_clear()
ai_memory_count() |> aeq 0, "ai_memory_count after clear"

# ── 5. AI Budget and Cost ───────────────────────────────────────────────────

# `ai_budget` requires a coderef body it runs under the cap; calling it
# without one is invalid. Demonstrate the proper shape, then check
# `ai_cost()` returns a numeric usd field afterwards.
ai_budget(10.0, fn { 1 })
ai_cost()->{usd} |> { _ >= 0 } |> aok "ai_cost is numeric"

# ── 6. MCP (Model Context Protocol) ─────────────────────────────────────────

# NOTE: invoking `mcp_server "name" { ... }` here would call
# `mcp_server_start`, which runs a blocking stdio JSON-RPC loop and
# deadlocks under `s t`'s pool runner (the worker child's stdin is a
# pipe from the parent). The behavior-pin test for `mcp_server` syntax
# is in `tests/suite/behavior_pin_2026_05_t.rs` and intercepts
# `mcp_server_start` via AOP — see that file for the pattern.
# Here we just verify the MCP-client builtin is present.
exists $all{mcp_connect} |> aok "mcp_connect exists"
test_run
