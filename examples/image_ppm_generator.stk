#!/usr/bin/env stryke

# basic PPM Image Generator
#
# Demonstrates:
#   * File writing with `spurt`.
#   * Procedural pixel generation.
#   * Math builtins (sin, cos, sqrt).
#
# Run: stryke --no-interop examples/image_ppm_generator.stk

p "--- PPM Image Generator ---"

my $width = 256
my $height = 256
my $max_color = 255

# 1. Start building the PPM header (P3 = ASCII color)
my $ppm_data = "P3\n$width $height\n$max_color\n"

# 2. Generate pixels (Gradient effect)
p "Generating #{ $width * $height } pixels..."
for my $y (0 : $height - 1) {
    for my $x (0 : $width - 1) {
        my $r = $x % 256
        my $g = $y % 256
        my $bl = ($x + $y) % 256
        $ppm_data .= "$r $g $bl  "
    }
    $ppm_data .= "\n"
}

# 3. Save to file
my $filename = "#{ temp_dir() }stryke_gradient.ppm"
spurt $filename, $ppm_data
p "Saved to $filename"

# ── 4. Tests ───────────────────────────────────────────────────────

(-f $filename) |> aok "file exists"

my $content = c"$filename"
($content[0:1] eq "P3") |> aok "PPM header check"

unlink $filename

test_run
