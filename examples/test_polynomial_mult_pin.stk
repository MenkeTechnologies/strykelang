#!/usr/bin/env stryke

fn PM::trim($p) {
    var @r = @$p
    while (len(@r) > 1 && $r[len(@r) - 1] == 0) {
        pop @r
    }
    \@r
}

fn PM::add($pa, $pb) {
    val $n = len(@$pa)
    val $m = len(@$pb)
    val $k = $n > $m ? $n : $m
    var @r = ()
    for val $i (0:$k-1) {
        val $av = $i < $n ? $pa->[$i] : 0
        val $bv = $i < $m ? $pb->[$i] : 0
        push @r, $av + $bv
    }
    PM::trim(\@r)
}

fn PM::scale($p, $c) {
    var @r = ()
    for val $x (@$p) { push @r, $x * $c }
    PM::trim(\@r)
}

fn PM::mul($pa, $pb) {
    val $n = len(@$pa)
    val $m = len(@$pb)
    var @r = ()
    for val $i (0:$n+$m-2) { push @r, 0 }
    for val $i (0:$n-1) {
        for val $j (0:$m-1) {
            $r[$i + $j] = $r[$i + $j] + $pa->[$i] * $pb->[$j]
        }
    }
    PM::trim(\@r)
}

fn PM::evalp($p, $x) {
    var $i = len(@$p) - 1
    var $acc = 0
    while ($i >= 0) {
        $acc = $acc * $x + $p->[$i]
        $i = $i - 1
    }
    $acc
}

fn PM::deriv($p) {
    val $n = len(@$p)
    return [0] if $n <= 1
    var @r = ()
    for val $i (1:$n-1) { push @r, $p->[$i] * $i }
    PM::trim(\@r)
}

fn eqp($p, $expected_csv) {
    join(",", @$p)
}

# --- trim ---
join(",", @{PM::trim([1, 2, 3])}) |> aeq "1,2,3", "trim no-op"
join(",", @{PM::trim([1, 2, 0, 0])}) |> aeq "1,2", "trim trailing zeros"
join(",", @{PM::trim([0])}) |> aeq "0", "trim all zero keeps one"
join(",", @{PM::trim([0, 0, 0])}) |> aeq "0", "trim collapse zeros"

# --- add ---
join(",", @{PM::add([1, 2], [3, 4])}) |> aeq "4,6", "add same len"
join(",", @{PM::add([1, 2, 3], [10])}) |> aeq "11,2,3", "add diff len"
join(",", @{PM::add([1, 2], [-1, -2])}) |> aeq "0", "add to zero polynomial"
join(",", @{PM::add([], [1, 2])}) |> aeq "1,2", "add empty"

# --- scale ---
join(",", @{PM::scale([1, 2, 3], 2)}) |> aeq "2,4,6", "scale by 2"
join(",", @{PM::scale([1, 2, 3], 0)}) |> aeq "0", "scale by 0"
join(",", @{PM::scale([1, 2, 3], -1)}) |> aeq "-1,-2,-3", "scale by -1"

# --- mul ---
# (1 + 2x + 3x^2)(4 + 5x) = 4 + 13x + 22x^2 + 15x^3
val $m1 = PM::mul([1, 2, 3], [4, 5])
join(",", @$m1) |> aeq "4,13,22,15", "mul classic"
# (x + 1)(x - 1) = x^2 - 1
val $m2 = PM::mul([1, 1], [-1, 1])
join(",", @$m2) |> aeq "-1,0,1", "mul difference of squares"
# (x + 1)^2 = x^2 + 2x + 1
val $m3 = PM::mul([1, 1], [1, 1])
join(",", @$m3) |> aeq "1,2,1", "mul perfect square"
# (2)(3x + 1) = 6x + 2
val $m4 = PM::mul([2], [1, 3])
join(",", @$m4) |> aeq "2,6", "mul by const"

# --- evalp (Horner) ---
PM::evalp([1, 2, 3], 0) |> aeq 1, "eval at 0"
PM::evalp([1, 2, 3], 1) |> aeq 6, "eval at 1"
PM::evalp([1, 2, 3], 2) |> aeq 17, "eval at 2 (1+4+12)"
PM::evalp([1, 2, 3], -1) |> aeq 2, "eval at -1"
PM::evalp([5], 100) |> aeq 5, "eval constant"
PM::evalp([0, 1], 7) |> aeq 7, "eval identity"

# --- deriv ---
# d/dx (1 + 2x + 3x^2) = 2 + 6x
join(",", @{PM::deriv([1, 2, 3])}) |> aeq "2,6", "deriv quadratic"
# d/dx (c) = 0
join(",", @{PM::deriv([5])}) |> aeq "0", "deriv constant"
# d/dx (x^3) = 3x^2
join(",", @{PM::deriv([0, 0, 0, 1])}) |> aeq "0,0,3", "deriv x^3"

# --- algebraic identities via composition ---
# (a + b)*c = a*c + b*c
val $aa = [1, 2, 3]
val $bb = [4, 5]
val $cc = [0, 1, 1]
val $ab = PM::add($aa, $bb)
val $lhs = PM::mul($ab, $cc)
val $ac = PM::mul($aa, $cc)
val $bc = PM::mul($bb, $cc)
val $rhs = PM::add($ac, $bc)
join(",", @$lhs) |> aeq join(",", @$rhs), "distributive law"

# (x^2 - 1) = (x - 1)(x + 1)
val $factored = PM::mul([-1, 1], [1, 1])
join(",", @$factored) |> aeq "-1,0,1", "factoring identity"

# Evaluate product equals product of evaluations
val $prod = PM::mul($aa, $bb)
val $expected = PM::evalp($aa, 3) * PM::evalp($bb, 3)
PM::evalp($prod, 3) |> aeq $expected, "eval distributes over mul"

# Derivative of product: (fg)' = f'g + fg'
val $f = [1, 0, 1]   # 1 + x^2
val $g = [0, 1]      # x
val $fg = PM::mul($f, $g)
val $dfg = PM::deriv($fg)
val $df = PM::deriv($f)
val $dg = PM::deriv($g)
val $fprimeg = PM::mul($df, $g)
val $fgprime = PM::mul($f, $dg)
val $sumd = PM::add($fprimeg, $fgprime)
join(",", @$dfg) |> aeq join(",", @$sumd), "product rule"

test_run
