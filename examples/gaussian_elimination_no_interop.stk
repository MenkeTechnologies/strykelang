#!/usr/bin/env stryke

# Gaussian elimination — solve Ax = b for square A via partial-pivot
# row reduction in O(n³). Also computes |det A| by tracking pivot
# signs and the product of pivots. Matrix inversion follows by
# augmenting `[A | I]` and reducing to `[I | A⁻¹]`.
#
# Style-guide conformance (docs/STYLE_GUIDE.md):
#   * named-package fns (`Gauss::`) under --no-interop (§18)
#   * `:` ranges, `len` for sizes, `#{ }` interpolation (§4, §5, §1a)
#   * `_0`/`_1` would go here in sort blocks (§11)
#   * implicit return on tail, no trailing `;` (§3, §12b)
#
# Run: stryke --no-interop examples/gaussian_elimination_no_interop.stk

# ── deep-copy a 2D matrix (matrices are arrayref-of-arrayref) ─────

fn Gauss::clone($A) {
    var @out
    for val $row (@$A) {
        val @r = @$row
        push @out, \@r
    }
    \@out
}

# ── solve A x = b via partial-pivot Gaussian elimination ──────────
# Returns +{ ok => 0/1, x => [...], det => scalar }.

fn Gauss::solve($A_in, $b_in) {
    val $n = len(@$A_in)
    var $A = Gauss::clone($A_in)
    var @bv = @$b_in
    var $det = 1.0
    for val $k (0:$n - 1) {
        var $pivot = $k
        var $max = abs($A->[$k]->[$k])
        for val $i ($k + 1:$n - 1) {
            val $v = abs($A->[$i]->[$k])
            if ($v > $max) {
                $max = $v
                $pivot = $i
            }
        }
        if ($max == 0) {
            return +{ ok => 0, x => [], det => 0 }
        }
        if ($pivot != $k) {
            val $tmp = $A->[$k]
            $A->[$k] = $A->[$pivot]
            $A->[$pivot] = $tmp
            val $tb = $bv[$k]
            $bv[$k] = $bv[$pivot]
            $bv[$pivot] = $tb
            $det = -$det
        }
        val $pv = $A->[$k]->[$k]
        $det = $det * $pv
        for val $i ($k + 1:$n - 1) {
            val $factor = $A->[$i]->[$k] / $pv
            for val $j ($k:$n - 1) {
                $A->[$i]->[$j] = $A->[$i]->[$j] - $factor * $A->[$k]->[$j]
            }
            $bv[$i] = $bv[$i] - $factor * $bv[$k]
        }
    }
    var @x = (0) x $n
    for val $i (0:$n - 1) {
        val $row = $n - 1 - $i
        var $s = $bv[$row]
        for val $j ($row + 1:$n - 1) {
            $s = $s - $A->[$row]->[$j] * $x[$j]
        }
        $x[$row] = $s / $A->[$row]->[$row]
    }
    +{ ok => 1, x => \@x, det => $det }
}

# ── invert an n×n matrix by reducing [A | I] to [I | A⁻¹] ─────────

fn Gauss::invert($A_in) {
    val $n = len(@$A_in)
    var @aug
    for val $i (0:$n - 1) {
        var @row
        for val $j (0:$n - 1) {
            push @row, $A_in->[$i]->[$j]
        }
        for val $j (0:$n - 1) {
            push @row, $i == $j ? 1.0 : 0.0
        }
        push @aug, \@row
    }
    for val $k (0:$n - 1) {
        var $pivot = $k
        var $max = abs($aug[$k]->[$k])
        for val $i ($k + 1:$n - 1) {
            val $v = abs($aug[$i]->[$k])
            if ($v > $max) {
                $max = $v
                $pivot = $i
            }
        }
        return +{ ok => 0, inv => [] } if $max == 0
        if ($pivot != $k) {
            val $tmp = $aug[$k]
            $aug[$k] = $aug[$pivot]
            $aug[$pivot] = $tmp
        }
        val $pv = $aug[$k]->[$k]
        for val $j (0:2 * $n - 1) {
            $aug[$k]->[$j] = $aug[$k]->[$j] / $pv
        }
        for val $i (0:$n - 1) {
            next if $i == $k
            val $factor = $aug[$i]->[$k]
            for val $j (0:2 * $n - 1) {
                $aug[$i]->[$j] = $aug[$i]->[$j] - $factor * $aug[$k]->[$j]
            }
        }
    }
    var @inv
    for val $i (0:$n - 1) {
        var @row
        for val $j (0:$n - 1) {
            push @row, $aug[$i]->[$n + $j]
        }
        push @inv, \@row
    }
    +{ ok => 1, inv => \@inv }
}

# ── matrix-vector product ─────────────────────────────────────────

fn Gauss::matvec($A, $x) {
    val $n = len(@$A)
    var @out
    for val $i (0:$n - 1) {
        var $s = 0
        val $m = len(@{$A->[$i]})
        for val $j (0:$m - 1) {
            $s = $s + $A->[$i]->[$j] * $x->[$j]
        }
        push @out, $s
    }
    \@out
}

# ── matrix × matrix ───────────────────────────────────────────────

fn Gauss::matmul($A, $B) {
    val $n = len(@$A)
    val $m = len(@{$B->[0]})
    val $k = len(@{$A->[0]})
    var @out
    for val $i (0:$n - 1) {
        var @row = (0) x $m
        for val $j (0:$m - 1) {
            var $s = 0
            for val $kk (0:$k - 1) {
                $s = $s + $A->[$i]->[$kk] * $B->[$kk]->[$j]
            }
            $row[$j] = $s
        }
        push @out, \@row
    }
    \@out
}

# ── primary cases with known solutions ────────────────────────────

val @cases = (
    +{
        name => "2x2 trivial",
        A    => [[2, 1], [1, 3]],
        b    => [4, 5],
        x    => [1.4, 1.2],
        det  => 5,
    },
    +{
        name => "3x3 textbook",
        A    => [
            [ 2,  1, -1],
            [-3, -1,  2],
            [-2,  1,  2],
        ],
        b    => [8, -11, -3],
        x    => [2, 3, -1],
        det  => -1,
    },
    +{
        name => "3x3 needs-pivot",   # zero diagonal at start
        A    => [
            [0, 2, 1],
            [1, 0, 3],
            [4, 5, 6],
        ],
        b    => [3, 4, 15],
        x    => [1, 1, 1],
        det  => 17,
    },
    +{
        name => "4x4 identity-ish",
        A    => [
            [1, 0, 0, 0],
            [0, 2, 0, 0],
            [0, 0, 3, 0],
            [0, 0, 0, 4],
        ],
        b    => [1, 4, 9, 16],
        x    => [1, 2, 3, 4],
        det  => 24,
    },
)

# ── approximate float equality ────────────────────────────────────

fn Gauss::approx($got, $want, $eps) {
    var $d = $got - $want
    $d = -$d if $d < 0
    $d < $eps
}

p "── Gaussian elimination demo ────────────────────────"
printf "  %-22s  %5s  %s\n", "case", "det", "solution"
printf "  %-22s  %5s  %s\n", "----------------------", "-----", "--------"
for val $c (@cases) {
    val $r = Gauss::solve($c->{A}, $c->{b})
    die "no solution on \"#{$c->{name}}\"" unless $r->{ok}
    var @rounded
    for val $v (@{$r->{x}}) {
        push @rounded, sprintf("%.4f", $v)
    }
    printf "  %-22s  %5.2f  [%s]\n", $c->{name}, $r->{det}, join(", ", @rounded)
}

# ── invariant 1: solution matches expected within 1e-6 ────────────

for val $c (@cases) {
    val $r = Gauss::solve($c->{A}, $c->{b})
    val $n = len(@{$c->{x}})
    for val $i (0:$n - 1) {
        die "x[#{$i}] mismatch on \"#{$c->{name}}\": got #{$r->{x}->[$i]} want #{$c->{x}->[$i]}" unless Gauss::approx($r->{x}->[$i], $c->{x}->[$i], 1e-6)
    }
}

# ── invariant 2: det matches expected within 1e-6 ─────────────────

for val $c (@cases) {
    val $r = Gauss::solve($c->{A}, $c->{b})
    die "det mismatch on \"#{$c->{name}}\": got #{$r->{det}} want #{$c->{det}}" unless Gauss::approx($r->{det}, $c->{det}, 1e-6)
}

# ── invariant 3: A · x = b (residual check) ───────────────────────

for val $c (@cases) {
    val $r = Gauss::solve($c->{A}, $c->{b})
    val $bv = Gauss::matvec($c->{A}, $r->{x})
    val $n = len(@$bv)
    for val $i (0:$n - 1) {
        die "residual on \"#{$c->{name}}\" row #{$i}: A·x = #{$bv->[$i]} != b = #{$c->{b}->[$i]}" unless Gauss::approx($bv->[$i], $c->{b}->[$i], 1e-6)
    }
}

# ── invariant 4: singular matrices report ok=0 ────────────────────

val $sing = Gauss::solve(
    [
        [1, 2, 3],
        [2, 4, 6],
        [1, 1, 1],
    ],
    [6, 12, 3],
)
die "singular matrix must return ok=0" unless $sing->{ok} == 0

# ── invariant 5: inversion produces a true inverse (A · A⁻¹ = I) ──

p ""
p "── matrix inversion demo ────────────────────────────"
for val $c (@cases) {
    val $iv = Gauss::invert($c->{A})
    die "inversion failed on \"#{$c->{name}}\"" unless $iv->{ok}
    val $prod = Gauss::matmul($c->{A}, $iv->{inv})
    val $n = len(@$prod)
    for val $i (0:$n - 1) {
        for val $j (0:$n - 1) {
            val $want = $i == $j ? 1.0 : 0.0
            die "A · A⁻¹ off identity at (#{$i}, #{$j}) on \"#{$c->{name}}\": got #{$prod->[$i]->[$j]}" unless Gauss::approx($prod->[$i]->[$j], $want, 1e-6)
        }
    }
    printf "  %-22s  inv·A = I (within 1e-6)\n", $c->{name}
}

# ── invariant 6: 1×1 inverse is the reciprocal ────────────────────

val $solo = Gauss::invert([[7.0]])
die "1x1 inverse must succeed" unless $solo->{ok}
die "1x1 inverse must be 1/7" unless Gauss::approx($solo->{inv}->[0]->[0], 1.0 / 7.0, 1e-9)

# ── invariant 7: 2×2 inverse formula sanity ───────────────────────
# For [[a,b],[c,d]], inv = 1/(ad-bc) * [[d,-b],[-c,a]].

val $two = Gauss::invert([[4.0, 7.0], [2.0, 6.0]])
val $det2 = 4.0 * 6.0 - 7.0 * 2.0   # = 10
val @want2 = ([6.0 / $det2, -7.0 / $det2], [-2.0 / $det2, 4.0 / $det2])
for val $i (0:1) {
    for val $j (0:1) {
        die "2x2 inv[#{$i}][#{$j}] mismatch" unless Gauss::approx($two->{inv}->[$i]->[$j], $want2[$i][$j], 1e-9)
    }
}

p ""
p "── all seven invariants satisfied ────────────────────"
