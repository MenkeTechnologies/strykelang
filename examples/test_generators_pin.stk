#!/usr/bin/env stryke

# Pinning batch: Generators and yield — finite generators, collect helpers,
# and lazy range pipelines.
# Compliance: docs/STYLE_GUIDE.md

# ── Finite generator ───────────────────────────────────────────────────────

my $steps = gen { yield "init"; yield "run"; yield "done" }
$steps->next->[0] |> aeq "init", "finite gen: step 1"
$steps->next->[0] |> aeq "run",  "finite gen: step 2"
$steps->next->[0] |> aeq "done", "finite gen: step 3"
$steps->next->[1] |> aeq 0,      "finite gen: exhausted active=0"

# ── Collect helper ─────────────────────────────────────────────────────────

fn gen_collect($g) {
    my @out = ()
    while (1) {
        my $r = $g->next
        last unless $r->[1]
        push @out, $r->[0]
    }
    \@out
}

my $abc = gen { yield "a"; yield "b"; yield "c" }
join(",", @{gen_collect($abc)}) |> aeq "a,b,c", "collect: abc"

my $nums = gen { yield 10; yield 20; yield 30; yield 40 }
join(",", @{gen_collect($nums)}) |> aeq "10,20,30,40", "collect: nums"

# Empty generator
my $empty = gen { 0 }
gen_collect($empty) |> { len(@{_}) } |> aeq 0, "collect: empty gen"

# ── Generator yielding from a loop body ─────────────────────────────────────
# NOTE: gen { for ... { yield } } not supported in tree interpreter; use
# explicit yield statements instead.

my $loop_gen = gen {
    yield 10; yield 20; yield 30; yield 40; yield 50
}
join(",", @{gen_collect($loop_gen)}) |> aeq "10,20,30,40,50", "loop gen: 5 yields"

# ── Two finite generators interleaved ─────────────────────────────────────

my $g1 = gen { yield "A"; yield "B"; yield "C" }
my $g2 = gen { yield 1; yield 2; yield 3 }
my @zipped = ()
for (1:3) {
    push @zipped, $g1->next->[0] . $g2->next->[0]
}
join(",", @zipped) |> aeq "A1,B2,C3", "interleaved generators"

# ── Generator with yielded expression ──────────────────────────────────────

my $exprs = gen {
    yield 2 + 3
    yield 4 * 5
    yield 10 - 7
}
join(",", @{gen_collect($exprs)}) |> aeq "5,20,3", "yielded expressions"

# ── Lazy streaming via range-based pipeline ────────────────────────────────

my @lazy1 = (1:200)
    |> maps { _ * _ }
    |> greps { _ % 4 == 0 }
    |> take(5)
    |> collect
join(",", @lazy1) |> aeq "4,16,36,64,100", "lazy: squares div by 4, first 5"

my @lazy2 = (1:100)
    |> greps { _ % 7 == 0 }
    |> take(4)
    |> collect
join(",", @lazy2) |> aeq "7,14,21,28", "lazy: multiples of 7, first 4"

my @lazy3 = (1:50)
    |> maps { _ * 3 }
    |> take(6)
    |> collect
join(",", @lazy3) |> aeq "3,6,9,12,15,18", "lazy: multiples of 3, first 6"

# ── Counter-style generator using explicit yields ────────────────────────

my $evens = gen { yield 0; yield 2; yield 4; yield 6; yield 8 }
join(",", @{gen_collect($evens)}) |> aeq "0,2,4,6,8", "counter: evens"

my $by3 = gen { yield 3; yield 6; yield 9; yield 12; yield 15 }
join(",", @{gen_collect($by3)}) |> aeq "3,6,9,12,15", "counter: multiples of 3"

# ── Squares generator (explicit) ──────────────────────────────────────────

my $sq = gen { yield 1; yield 4; yield 9; yield 16; yield 25; yield 36 }
join(",", @{gen_collect($sq)}) |> aeq "1,4,9,16,25,36", "squares: first 6"

# ── Powers of 2 (explicit) ────────────────────────────────────────────────

my $pow2 = gen { yield 1; yield 2; yield 4; yield 8; yield 16; yield 32; yield 64; yield 128 }
join(",", @{gen_collect($pow2)}) |> aeq "1,2,4,8,16,32,64,128", "powers of 2: first 8"

test_run
