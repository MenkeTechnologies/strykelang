#!/usr/bin/env stryke

package CYK

fn parse($words, $rules, $start_symbol) {
    val $n = len @$words
    return 0 if $n == 0
    val $dp = []
    for val $i (0:$n-1) {
        val $row = []
        for val $j (0:$n) { push @$row, {} }
        push @$dp, $row
    }
    for val $i (0:$n-1) {
        val $word = $words->[$i]
        for val $rule (@$rules) {
            if ((len @$rule) == 2) {
                val $lhs = $rule->[0]; val $rhs = $rule->[1]
                if ($rhs eq $word) { $dp->[$i]->[1]->{$lhs} = 1 }
            }
        }
    }
    for val $l (2:$n) {
        for val $s (0:$n-$l) {
            for val $p (1:$l-1) {
                for val $rule (@$rules) {
                    if ((len @$rule) == 3) {
                        val $lhs = $rule->[0]; val $rhs1 = $rule->[1]; val $rhs2 = $rule->[2]
                        if ($dp->[$s]->[$p]->{$rhs1} && $dp->[$s+$p]->[$l-$p]->{$rhs2}) {
                            $dp->[$s]->[$l]->{$lhs} = 1
                        }
                    }
                }
            }
        }
    }
    $dp->[0]->[$n]->{$start_symbol} // 0
}

package main

val @rules = (
    ["S", "NP", "VP"],
    ["VP", "VP", "PP"],
    ["VP", "V", "NP"],
    ["VP", "eats"],
    ["PP", "P", "NP"],
    ["NP", "Det", "N"],
    ["NP", "she"],
    ["V", "eats"],
    ["P", "with"],
    ["N", "fish"],
    ["N", "fork"],
    ["Det", "a"]
)

val @words1 = ("she", "eats", "a", "fish", "with", "a", "fork")
CYK::parse(\@words1, \@rules, "S") |> aeq 1, "valid sentence"

val @words2 = ("she", "eats", "fork")
CYK::parse(\@words2, \@rules, "S") |> aeq 0, "invalid sentence"

test_run
