#!/usr/bin/env stryke

package CYK

fn parse($words, $rules, $start_symbol) {
    my $n = len @$words
    return 0 if $n == 0
    my $dp = []
    for my $i (0:$n-1) {
        my $row = []
        for my $j (0:$n) { push @$row, {} }
        push @$dp, $row
    }
    for my $i (0:$n-1) {
        my $word = $words->[$i]
        for my $rule (@$rules) {
            if ((len @$rule) == 2) {
                my $lhs = $rule->[0]; my $rhs = $rule->[1]
                if ($rhs eq $word) { $dp->[$i]->[1]->{$lhs} = 1 }
            }
        }
    }
    for my $l (2:$n) {
        for my $s (0:$n-$l) {
            for my $p (1:$l-1) {
                for my $rule (@$rules) {
                    if ((len @$rule) == 3) {
                        my $lhs = $rule->[0]; my $rhs1 = $rule->[1]; my $rhs2 = $rule->[2]
                        if ($dp->[$s]->[$p]->{$rhs1} && $dp->[$s+$p]->[$l-$p]->{$rhs2}) {
                            $dp->[$s]->[$l]->{$lhs} = 1
                        }
                    }
                }
            }
        }
    }
    $dp->[0]->[$n]->{$start_symbol} // 0
}

package main

my @rules = (
    ["S", "NP", "VP"],
    ["VP", "VP", "PP"],
    ["VP", "V", "NP"],
    ["VP", "eats"],
    ["PP", "P", "NP"],
    ["NP", "Det", "N"],
    ["NP", "she"],
    ["V", "eats"],
    ["P", "with"],
    ["N", "fish"],
    ["N", "fork"],
    ["Det", "a"]
)

my @words1 = ("she", "eats", "a", "fish", "with", "a", "fork")
CYK::parse(\@words1, \@rules, "S") |> aeq 1, "valid sentence"

my @words2 = ("she", "eats", "fork")
CYK::parse(\@words2, \@rules, "S") |> aeq 0, "invalid sentence"

test_run
