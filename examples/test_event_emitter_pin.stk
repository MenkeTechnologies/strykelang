#!/usr/bin/env stryke

fn EE::new() {
    +{ listeners => +{}, once => +{}, next_id => 1 }
}

fn EE::on($ee, $event, $cb) {
    my $id = $ee->{next_id}
    $ee->{next_id} = $id + 1
    $ee->{listeners}->{$event} = [] unless exists $ee->{listeners}->{$event}
    push @{$ee->{listeners}->{$event}}, +{ id => $id, cb => $cb }
    $id
}

fn EE::once($ee, $event, $cb) {
    my $id = EE::on($ee, $event, $cb)
    $ee->{once}->{$id} = 1
    $id
}

fn EE::off($ee, $event, $id) {
    return unless exists $ee->{listeners}->{$event}
    my @kept = ()
    for my $l (@{$ee->{listeners}->{$event}}) {
        push @kept, $l unless $l->{id} == $id
    }
    $ee->{listeners}->{$event} = \@kept
    delete $ee->{once}->{$id}
}

fn EE::emit($ee, $event, $payload) {
    return 0 unless exists $ee->{listeners}->{$event}
    my @ls = @{$ee->{listeners}->{$event}}
    my $count = 0
    my @kept = ()
    for my $l (@ls) {
        $l->{cb}($payload)
        $count = $count + 1
        if (exists $ee->{once}->{$l->{id}}) {
            delete $ee->{once}->{$l->{id}}
        } else {
            push @kept, $l
        }
    }
    $ee->{listeners}->{$event} = \@kept
    $count
}

fn EE::count($ee, $event) {
    return 0 unless exists $ee->{listeners}->{$event}
    len @{$ee->{listeners}->{$event}}
}

# Empty emit
my $b0 = EE::new()
EE::emit($b0, "x", 1)  |> aeq 0, "emit no listeners"
EE::count($b0, "x")    |> aeq 0, "count zero"

# Single listener
my $b1 = EE::new()
mysync @l1 = ()
EE::on($b1, "data", fn ($x) { push @l1, $x })
EE::emit($b1, "data", 42) |> aeq 1, "one fired"
join(",", @l1) |> aeq "42", "got payload"
EE::emit($b1, "data", 7)  |> aeq 1, "one fired again"
join(",", @l1) |> aeq "42,7", "two payloads"

# Multiple listeners
my $b2 = EE::new()
mysync @l2 = ()
EE::on($b2, "ev", fn ($x) { push @l2, "A:" . $x })
EE::on($b2, "ev", fn ($x) { push @l2, "B:" . $x })
EE::on($b2, "ev", fn ($x) { push @l2, "C:" . $x })
EE::count($b2, "ev") |> aeq 3, "three listeners"
EE::emit($b2, "ev", 5) |> aeq 3, "three fired"
join(",", @l2) |> aeq "A:5,B:5,C:5", "all three"

# once() fires only once
my $b3 = EE::new()
mysync @l3 = ()
EE::once($b3, "o", fn ($x) { push @l3, "once:" . $x })
EE::on($b3, "o",   fn ($x) { push @l3, "perm:" . $x })
EE::emit($b3, "o", 1)
EE::emit($b3, "o", 2)
join(",", @l3) |> aeq "once:1,perm:1,perm:2", "once only fires first"
EE::count($b3, "o") |> aeq 1, "once removed"

# off removes listener
my $b4 = EE::new()
mysync @l4 = ()
my $id = EE::on($b4, "z", fn ($x) { push @l4, "1:" . $x })
EE::on($b4, "z",          fn ($x) { push @l4, "2:" . $x })
EE::emit($b4, "z", "a")
EE::off($b4, "z", $id)
EE::emit($b4, "z", "b")
join(",", @l4) |> aeq "1:a,2:a,2:b", "after off"
EE::count($b4, "z") |> aeq 1, "one remains"

# Unrelated events isolated
my $b5 = EE::new()
mysync @lx = ()
mysync @ly = ()
EE::on($b5, "x", fn ($v) { push @lx, $v })
EE::on($b5, "y", fn ($v) { push @ly, $v })
EE::emit($b5, "x", 1)
EE::emit($b5, "y", 2)
EE::emit($b5, "x", 3)
join(",", @lx) |> aeq "1,3", "x channel"
join(",", @ly) |> aeq "2",   "y channel"

# off non-existent id is safe
my $b6 = EE::new()
EE::on($b6, "a", fn ($x) {})
EE::off($b6, "a", 9999)
EE::count($b6, "a") |> aeq 1, "off bad id no-op"
EE::off($b6, "missing-event", 1)
EE::count($b6, "missing-event") |> aeq 0, "off missing event no-op"

test_run
