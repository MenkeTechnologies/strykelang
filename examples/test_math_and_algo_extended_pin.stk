#!/usr/bin/env stryke

# Math and Algorithms Extended Pinning (2026-05-15)
# Testing Number Theory, Geometry, Text, Statistics, and Matrix builtins.
# Compliance: docs/STYLE_GUIDE.md
# Mode: --no-interop

# ── 1. Number Theory ────────────────────────────────────────────────────────

is_prime(7)  |> aeq 1, "is_prime(7)"
is_prime(10) |> { _ == 0 } |> aok "is_prime(10) false"

prime_factors(60) |> join(",") |> aeq "2,2,3,5", "prime_factors(60)"

divisors(12) |> sort { _ <=> _1 } |> join(",") |> aeq "1,2,3,4,6,12", "divisors(12)"

next_prime(10) |> aeq 11, "next_prime(10)"

factorial(5) |> aeq 120, "factorial(5)"

gcd(48, 18) |> aeq 6, "gcd(48, 18)"
lcm(48, 18) |> aeq 144, "lcm(48, 18)"

# ── 2. Geometry ─────────────────────────────────────────────────────────────

euclidean_distance([0, 0], [3, 4]) |> aeq 5, "euclidean_distance"
manhattan_distance([0, 0], [3, 4]) |> aeq 7, "manhattan_distance"

slope(1, 1, 3, 3) |> aeq 1, "slope"
midpoint(0, 0, 4, 6) |> join(",") |> aeq "2,3", "midpoint"

# ── 3. Text Algorithms ──────────────────────────────────────────────────────

levenshtein("kitten", "sitting") |> aeq 3, "levenshtein"
jaro_winkler("dwayne", "duane") |> { 0.8 <= _ <= 0.9 } |> aok "jaro_winkler"

soundex("Stryke") |> aeq "S362", "soundex"

# ── 4. Statistics ───────────────────────────────────────────────────────────

my @data = (10, 20, 30, 40, 50)
mean(@data)   |> aeq 30, "mean"
median(@data) |> aeq 30, "median"
variance(@data) |> aeq 200, "variance"
stddev(@data) |> { 14.1 <= _ <= 14.2 } |> aok "stddev"

# ── 5. Matrix Operations ────────────────────────────────────────────────────

my $m2 = [[1, 2], [3, 4]]
matrix_det($m2) |> aeq -2, "matrix_det 2x2"

my $m3 = [[1, 2, 3], [0, 1, 4], [5, 6, 0]]
matrix_det($m3) |> aeq 1, "matrix_det 3x3"

my $inv = matrix_inverse($m2)
$inv->[0][0] |> aeq -2, "matrix_inverse [0][0]"
$inv->[0][1] |> aeq 1, "matrix_inverse [0][1]"

# ── 6. Combinatorics ────────────────────────────────────────────────────────

permutations([1, 2]) |> len |> aeq 2, "permutations len"
combinations(2, [1, 2, 3]) |> len |> aeq 3, "combinations len"

# ── 7. Validation ───────────────────────────────────────────────────────────

is_url("https://google.com") |> aok "is_url valid"
is_ipv4("192.168.1.1")       |> aok "is_ipv4 valid"
is_ipv6("::1")               |> aok "is_ipv6 valid"

test_run
