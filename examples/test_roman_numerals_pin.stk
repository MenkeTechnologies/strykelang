#!/usr/bin/env stryke

# Roman numeral encode/decode.

fn Roman::encode($n) {
    var @table = (
        [1000, "M"],  [900, "CM"], [500, "D"], [400, "CD"],
        [100,  "C"],  [90,  "XC"], [50,  "L"], [40,  "XL"],
        [10,   "X"],  [9,   "IX"], [5,   "V"], [4,   "IV"],
        [1,    "I"],
    )
    var $out = ""
    for val $row (@table) {
        val ($v, $sym) = @$row
        while ($n >= $v) {
            $out .= $sym
            $n -= $v
        }
    }
    $out
}

fn Roman::decode($s) {
    val %v = (I => 1, V => 5, X => 10, L => 50, C => 100, D => 500, M => 1000)
    val @chars = split(//, $s)
    val $n = len(@chars)
    var $total = 0
    for val $i (0:$n - 1) {
        val $cur = $v{$chars[$i]}
        val $nxt = $i + 1 < $n ? $v{$chars[$i + 1]} : 0
        if ($cur < $nxt) {
            $total -= $cur
        } else {
            $total += $cur
        }
    }
    $total
}

# Known values
Roman::encode(1)    |> aeq "I",     "encode 1"
Roman::encode(4)    |> aeq "IV",    "encode 4"
Roman::encode(9)    |> aeq "IX",    "encode 9"
Roman::encode(40)   |> aeq "XL",    "encode 40"
Roman::encode(90)   |> aeq "XC",    "encode 90"
Roman::encode(400)  |> aeq "CD",    "encode 400"
Roman::encode(900)  |> aeq "CM",    "encode 900"
Roman::encode(1994) |> aeq "MCMXCIV", "encode 1994"
Roman::encode(2024) |> aeq "MMXXIV", "encode 2024"
Roman::encode(3999) |> aeq "MMMCMXCIX", "encode 3999 (max standard)"
Roman::encode(58)   |> aeq "LVIII", "encode 58"
Roman::encode(444)  |> aeq "CDXLIV", "encode 444"

Roman::decode("I")          |> aeq 1,    "decode I"
Roman::decode("IV")         |> aeq 4,    "decode IV"
Roman::decode("IX")         |> aeq 9,    "decode IX"
Roman::decode("XL")         |> aeq 40,   "decode XL"
Roman::decode("XC")         |> aeq 90,   "decode XC"
Roman::decode("CD")         |> aeq 400,  "decode CD"
Roman::decode("CM")         |> aeq 900,  "decode CM"
Roman::decode("MCMXCIV")    |> aeq 1994, "decode MCMXCIV"
Roman::decode("MMXXIV")     |> aeq 2024, "decode MMXXIV"
Roman::decode("LVIII")      |> aeq 58,   "decode LVIII"
Roman::decode("CDXLIV")     |> aeq 444,  "decode CDXLIV"
Roman::decode("MMMCMXCIX")  |> aeq 3999, "decode MMMCMXCIX"

# Roundtrips
for val $n (1, 3, 7, 14, 49, 88, 100, 247, 555, 999, 1000, 1492, 1888, 2024, 3500) {
    Roman::decode(Roman::encode($n)) |> aeq $n, "roundtrip $n"
}

# Length monotonicity sanity
val @lens = map { len(Roman::encode(_)) } 1, 10, 100, 1000
$lens[3] >= $lens[2] |> aok "len 1000 >= len 100"
$lens[2] >= $lens[1] |> aok "len 100 >= len 10"

# Sum the digits of decoded representations as a pipeline
val @vals = map { Roman::decode(_) } qw(I II III IV V VI VII VIII IX X)
sum(@vals) |> aeq 55, "sum I..X = 55"

test_run
