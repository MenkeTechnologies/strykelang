#!/usr/bin/env stryke

package FFT

fn c_add($u, $v) { [ $u->[0] + $v->[0], $u->[1] + $v->[1] ] }
fn c_sub($u, $v) { [ $u->[0] - $v->[0], $u->[1] - $v->[1] ] }
fn c_mul($u, $v) {
    val $r = $u->[0] * $v->[0] - $u->[1] * $v->[1]
    val $i = $u->[0] * $v->[1] + $u->[1] * $v->[0]
    [ $r, $i ]
}
fn c_exp($theta) { [ cos($theta), sin($theta) ] }

fn transform($x) {
    val $n = len @$x
    return $x if $n <= 1
    var @even; var @odd
    for (var $i = 0; $i < $n; $i += 2) {
        push @even, $x->[$i]; push @odd, $x->[$i + 1]
    }
    val $even_fft = FFT::transform(\@even)
    val $odd_fft  = FFT::transform(\@odd)
    var @res
    for (var $i = 0; $i < $n; $i++) { push @res, [0.0, 0.0] }
    val $half = int($n / 2)
    val $pi = 3.14159265358979323846
    for (var $k = 0; $k < $half; $k++) {
        val $theta = -2.0 * $pi * $k / $n
        val $t = FFT::c_exp($theta)
        val $term = FFT::c_mul($t, $odd_fft->[$k])
        $res[$k] = FFT::c_add($even_fft->[$k], $term)
        $res[$k + $half] = FFT::c_sub($even_fft->[$k], $term)
    }
    \@res
}

fn inverse_transform($x) {
    val $n = len @$x; var @conj
    for val $c (@$x) { push @conj, [ $c->[0], -$c->[1] ] }
    val $t_res = FFT::transform(\@conj); var @res
    for val $c (@$t_res) { push @res, [ $c->[0] / $n, -$c->[1] / $n ] }
    \@res
}

package main

# --- Basic E2E ---
val @poly = ( [1.0, 0.0], [2.0, 0.0], [3.0, 0.0], [4.0, 0.0] )
val $fft_res = FFT::transform(\@poly)
val $ifft_res = FFT::inverse_transform($fft_res)

# Validate roundtrip
var $ok = 1
for val $i (0 : 3) {
    val $orig = $poly[$i]->[0]
    val $inv = $ifft_res->[$i]->[0]
    if (abs($orig - $inv) > 1e-6) { $ok = 0 }
}
$ok |> aeq 1, "FFT roundtrip matches original"

test_run
