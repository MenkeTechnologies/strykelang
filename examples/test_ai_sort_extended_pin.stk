#!/usr/bin/env stryke

# Pinning batch Native-R (2026-05-10): Extended AI Sort Tests
# Compliance: docs/STYLE_GUIDE.md

# ── AI Sort: Reverse Alphabetical ───────────────────────────────────────

ai_mock_install("(?s)Sort these items by: reverse alphabetical", '[0, 1, 2]');

val @items_alpha = ("zebra", "mongoose", "aardvark");
val $sorted_alpha = ai_sort(\@items_alpha, "reverse alphabetical");

join(",", @{$sorted_alpha}) |> aeq "zebra,mongoose,aardvark", "ai_sort reverse alphabetical";

# ── AI Sort: Numerical Ascending ────────────────────────────────────────

ai_mock_install("(?s)Sort these items by: ascending numerical order", '[1, 2, 0]');

val @items_numeric = (100, 2, 87);
val $sorted_numeric = ai_sort(\@items_numeric, "ascending numerical order");

join(",", @{$sorted_numeric}) |> aeq "2,87,100", "ai_sort numerical ascending";

# ── AI Sort: By Hash Key ──────────────────────────────────────────────────

ai_mock_install("(?s)Sort these items by: age, youngest first", '[1, 0, 2]');

val @items_hash = (
    +{ name => "Alice", age => 30 },
    +{ name => "Bob", age => 25 },
    +{ name => "Charlie", age => 35 }
);
val $sorted_hash = ai_sort(\@items_hash, "age, youngest first");

val @sorted_names = map { $_->{name} } @{$sorted_hash};
join(",", @sorted_names) |> aeq "Bob,Alice,Charlie", "ai_sort by hash key";

# ── AI Sort: By Multiple Hash Keys ────────────────────────────────────────

ai_mock_install("(?s)Sort these items by: age ascending, then name alphabetically", '[2, 1, 0]');

val @items_multi_hash = (
    +{ name => "Charlie", age => 30 },
    +{ name => "Alice", age => 30 },
    +{ name => "Bob", age => 25 }
);
val $sorted_multi_hash = ai_sort(\@items_multi_hash, "age ascending, then name alphabetically");

val @sorted_multi_names = map { $_->{name} } @{$sorted_multi_hash};
join(",", @sorted_multi_names) |> aeq "Bob,Alice,Charlie", "ai_sort by multiple hash keys";

# ── AI Sort: Complex Criterion ───────────────────────────────────────────

ai_mock_install("(?s)Sort these version strings from oldest to newest", '[1, 2, 0]');

val @versions = ("1.10.2", "1.2.1", "1.9.0");
val $sorted_versions = ai_sort(\@versions, "Sort these version strings from oldest to newest");

join(",", @{$sorted_versions}) |> aeq "1.2.1,1.9.0,1.10.2", "ai_sort by complex criterion";


test_run
