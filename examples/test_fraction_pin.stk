#!/usr/bin/env stryke

# Pinning batch: Fraction / rational arithmetic in lowest terms.
# Compliance: docs/STYLE_GUIDE.md

fn Fr::gcd($x, $y) {
    while ($y != 0) {
        ($x, $y) = ($y, $x % $y)
    }
    $x < 0 ? -$x : $x
}

fn Fr::new($n, $d) {
    val $g = Fr::gcd($n, $d)
    val $s = $d < 0 ? -1 : 1
    [$s * $n / $g, $s * $d / $g]
}

fn Fr::num($x) = $x->[0]
fn Fr::den($x) = $x->[1]

fn Fr::add($x, $y) = Fr::new($x->[0] * $y->[1] + $y->[0] * $x->[1], $x->[1] * $y->[1])
fn Fr::sub($x, $y) = Fr::new($x->[0] * $y->[1] - $y->[0] * $x->[1], $x->[1] * $y->[1])
fn Fr::mul($x, $y) = Fr::new($x->[0] * $y->[0], $x->[1] * $y->[1])
fn Fr::div($x, $y) = Fr::new($x->[0] * $y->[1], $x->[1] * $y->[0])
fn Fr::neg($x)     = [-$x->[0], $x->[1]]
fn Fr::equals($x, $y)  = $x->[0] == $y->[0] && $x->[1] == $y->[1]
fn Fr::less($x, $y)  = $x->[0] * $y->[1] < $y->[0] * $x->[1]
fn Fr::to_f($x)    = $x->[0] / $x->[1]
fn Fr::show($x)    = "#{$x->[0]}/#{$x->[1]}"

val $half  = Fr::new(1, 2)
val $third = Fr::new(1, 3)
val $two   = Fr::new(2, 1)

Fr::show($half)  |> aeq "1/2", "1/2"
Fr::show($third) |> aeq "1/3", "1/3"
Fr::show(Fr::new(2, 4))   |> aeq "1/2", "2/4 → 1/2"
Fr::show(Fr::new(6, 9))   |> aeq "2/3", "6/9 → 2/3"
Fr::show(Fr::new(-2, 4))  |> aeq "-1/2", "neg num"
Fr::show(Fr::new(2, -4))  |> aeq "-1/2", "neg den normalized"
Fr::show(Fr::new(-2, -4)) |> aeq "1/2",  "double neg"

Fr::show(Fr::add($half, $third)) |> aeq "5/6",  "1/2 + 1/3"
Fr::show(Fr::sub($half, $third)) |> aeq "1/6",  "1/2 - 1/3"
Fr::show(Fr::mul($half, $third)) |> aeq "1/6",  "1/2 * 1/3"
Fr::show(Fr::div($half, $third)) |> aeq "3/2",  "1/2 / 1/3"
Fr::show(Fr::neg($half))         |> aeq "-1/2", "-1/2"
Fr::show(Fr::add($half, $half))  |> aeq "1/1",  "1/2 + 1/2"

Fr::equals($half, Fr::new(2, 4))    |> aeq 1, "1/2 == 2/4"
Fr::equals($half, $third)           |> aeq 0, "1/2 != 1/3"
Fr::less($third, $half)           |> aeq 1, "1/3 < 1/2"
Fr::less($half, $third)           |> aeq 0, "1/2 ≮ 1/3"

abs(Fr::to_f($half) - 0.5)         < 1e-12 |> aeq 1, "to_f 1/2"
abs(Fr::to_f($third) - 1/3)        < 1e-12 |> aeq 1, "to_f 1/3"

# Egyptian / harmonic-like sum: 1 + 1/2 + 1/3 + ... + 1/n
fn Fr::harmonic($n) {
    var $acc = Fr::new(0, 1)
    for val $k (1:$n) {
        $acc = Fr::add($acc, Fr::new(1, $k))
    }
    $acc
}

Fr::show(Fr::harmonic(1)) |> aeq "1/1",  "H1"
Fr::show(Fr::harmonic(2)) |> aeq "3/2",  "H2"
Fr::show(Fr::harmonic(3)) |> aeq "11/6", "H3"
Fr::show(Fr::harmonic(4)) |> aeq "25/12","H4"
Fr::show(Fr::harmonic(5)) |> aeq "137/60","H5"

# Geometric: r + r² + ... + rⁿ in fractions; r = 1/2
fn Fr::geom($r, $n) {
    var $acc  = Fr::new(0, 1)
    mysync $pow = Fr::new(1, 1)
    for val $k (1:$n) {
        $pow = Fr::mul($pow, $r)
        $acc = Fr::add($acc, $pow)
    }
    $acc
}

Fr::show(Fr::geom($half, 3)) |> aeq "7/8",   "1/2+1/4+1/8"
Fr::show(Fr::geom($half, 4)) |> aeq "15/16", "→ 15/16"
Fr::show(Fr::geom($half, 5)) |> aeq "31/32", "→ 31/32"

# Continued-fraction approximation of φ: [1;1,1,1,...]
fn Fr::phi_cf($n) {
    var $acc = Fr::new(1, 1)
    for (1:$n) {
        $acc = Fr::add(Fr::new(1, 1), Fr::div(Fr::new(1, 1), $acc))
    }
    $acc
}

Fr::show(Fr::phi_cf(1)) |> aeq "2/1", "phi 1"
Fr::show(Fr::phi_cf(2)) |> aeq "3/2", "phi 2"
Fr::show(Fr::phi_cf(3)) |> aeq "5/3", "phi 3"
Fr::show(Fr::phi_cf(4)) |> aeq "8/5", "phi 4"
Fr::show(Fr::phi_cf(5)) |> aeq "13/8","phi 5"
Fr::show(Fr::phi_cf(6)) |> aeq "21/13","phi 6"

abs(Fr::to_f(Fr::phi_cf(20)) - (1 + sqrt(5)) / 2) < 1e-6 |> aeq 1, "phi converges"

test_run
