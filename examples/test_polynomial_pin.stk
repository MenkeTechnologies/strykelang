#!/usr/bin/env stryke

# Pinning batch: Polynomial arithmetic, evaluation, derivative, integral, roots.
# Polynomials are coefficient arrays low-degree first: [c0, c1, c2] = c0 + c1·x + c2·x²
# Compliance: docs/STYLE_GUIDE.md

fn Pl::deg($p)  = (len $p) - 1
fn Pl::evalp($p, $x) {
    var $acc = 0
    for val $c (rev @$p) {
        $acc = $acc * $x + $c
    }
    $acc
}

fn Pl::add($p, $q) {
    val $n = (len $p) > (len $q) ? (len $p) : (len $q)
    [map { ($p->[$_] // 0) + ($q->[$_] // 0) } 0:$n-1]
}

fn Pl::sub($p, $q) {
    val $n = (len $p) > (len $q) ? (len $p) : (len $q)
    [map { ($p->[$_] // 0) - ($q->[$_] // 0) } 0:$n-1]
}

fn Pl::scale($p, $k) = [map { $_ * $k } @$p]

fn Pl::mul($p, $q) {
    var @r = (0) x (len $p + (len $q) - 1)
    for val $i (0:(len $p)-1) {
        for val $j (0:(len $q)-1) {
            $r[$i + $j] += $p->[$i] * $q->[$j]
        }
    }
    \@r
}

fn Pl::deriv($p) {
    return [0] if (len $p) <= 1
    [map { $_ * $p->[$_] } 1:(len $p)-1]
}

fn Pl::integ($p) {
    var @r = (0)
    for val $i (0:(len $p)-1) {
        push @r, $p->[$i] / ($i + 1)
    }
    \@r
}

fn Pl::trim($p) {
    var @r = @$p
    pop @r while (len @r) > 1 && $r[-1] == 0
    \@r
}

# p(x) = 2 + 3x + x²
val $p = [2, 3, 1]
# q(x) = 1 - x
val $q = [1, -1]

Pl::deg($p)        |> aeq 2,  "deg p"
Pl::deg($q)        |> aeq 1,  "deg q"
Pl::evalp($p, 0)    |> aeq 2,  "p(0)"
Pl::evalp($p, 1)    |> aeq 6,  "p(1)"
Pl::evalp($p, 2)    |> aeq 12, "p(2)"
Pl::evalp($p, -1)   |> aeq 0,  "p(-1) is a root"
Pl::evalp($q, 5)    |> aeq -4, "q(5)"

join(",", @{Pl::add($p, $q)})   |> aeq "3,2,1",  "p + q"
join(",", @{Pl::sub($p, $q)})   |> aeq "1,4,1",  "p - q"
join(",", @{Pl::scale($p, 3)})  |> aeq "6,9,3",  "3p"
join(",", @{Pl::mul($p, $q)})   |> aeq "2,1,-2,-1", "p*q"
join(",", @{Pl::deriv($p)})     |> aeq "3,2",    "p'"
join(",", @{Pl::deriv($q)})     |> aeq "-1",     "q'"
join(",", @{Pl::integ($q)})     |> aeq "0,1,-0.5","∫q dx"

# Power: pⁿ via repeated mul
fn Pl::pow($p, $n) {
    varsync $r = [1]
    for (1:$n) {
        $r = Pl::mul($r, $p)
    }
    $r
}

# (x + 1)⁴ = 1 + 4x + 6x² + 4x³ + x⁴
val $bp = Pl::pow([1, 1], 4)
join(",", @$bp) |> aeq "1,4,6,4,1", "(1+x)^4 binomial"

# (x - 1)³ = -1 + 3x - 3x² + x³
val $bm = Pl::pow([-1, 1], 3)
join(",", @$bm) |> aeq "-1,3,-3,1", "(x-1)^3"

# Lagrange interpolation: find polynomial through points
fn Pl::lagrange(@pts) {
    val @xs = map { $_->[0] } @pts
    val @ys = map { $_->[1] } @pts
    val $n  = (len @pts)
    varsync $sum = [0]
    for val $i (0:$n-1) {
        varsync $term = [$ys[$i]]
        for val $j (0:$n-1) {
            next if $j == $i
            val $denom = $xs[$i] - $xs[$j]
            $term = Pl::mul($term, [-$xs[$j] / $denom, 1 / $denom])
        }
        $sum = Pl::add($sum, $term)
    }
    $sum
}

val $lp = Pl::lagrange([0, 1], [1, 2], [2, 5])
# Through (0,1),(1,2),(2,5): p(x) = x² + 1? eval check
Pl::evalp($lp, 0) |> aeq 1, "lagrange p(0)=1"
Pl::evalp($lp, 1) |> aeq 2, "lagrange p(1)=2"
Pl::evalp($lp, 2) |> aeq 5, "lagrange p(2)=5"
abs(Pl::evalp($lp, 3) - 10) < 1e-9 |> aeq 1, "lagrange p(3)=10"

# Newton's method: find root of p starting at x0
fn Pl::root($p, $x0, $iters) {
    val $dp = Pl::deriv($p)
    var $x  = $x0
    for (1:$iters) {
        val $fx = Pl::evalp($p, $x)
        val $df = Pl::evalp($dp, $x)
        $x = $x - $fx / $df
    }
    $x
}

# p(x) = x² - 2 → √2
val $rt = Pl::root([-2, 0, 1], 1.0, 30)
abs($rt - sqrt(2)) < 1e-9 |> aeq 1, "newton √2"

# p(x) = x³ - x - 2 → ~1.5214
val $rt2 = Pl::root([-2, -1, 0, 1], 1.5, 50)
abs(Pl::evalp([-2, -1, 0, 1], $rt2)) < 1e-9 |> aeq 1, "newton cubic root"

# Horner check
fn Pl::horner($p, $x) {
    var $acc = 0
    $acc = $acc * $x + $_ for rev @$p
    $acc
}

Pl::horner($p, 3)  |> aeq 20, "horner p(3)"
Pl::horner($p, 10) |> aeq 132, "horner p(10)"

test_run
