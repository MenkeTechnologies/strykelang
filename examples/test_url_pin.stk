#!/usr/bin/env stryke

# URL parsing, percent encode/decode, query strings, URL join.

fn Url::parse($u) {
    my %out = (scheme => "", host => "", path => "/", query => "", fragment => "")
    my @c = ($u =~ m{^([a-z]+)://([^/?#]+)(/[^?#]*)?(\?[^#]*)?(\#.*)?$})
    if (len(@c) > 0) {
        $out{scheme}   = $c[0]
        $out{host}     = $c[1]
        $out{path}     = defined $c[2] && $c[2] ne "" ? $c[2] : "/"
        my $qr = defined $c[3] ? $c[3] : ""
        my $fr = defined $c[4] ? $c[4] : ""
        $qr =~ s/^\?//
        $fr =~ s/^\#//
        $out{query}    = $qr
        $out{fragment} = $fr
    }
    \%out
}

my $u = Url::parse("https://example.com/path/to/page?x=1&y=two#section")
$u->{scheme}   |> aeq "https",         "scheme"
$u->{host}     |> aeq "example.com",   "host"
$u->{path}     |> aeq "/path/to/page", "path"
$u->{query}    |> aeq "x=1&y=two",     "query"
$u->{fragment} |> aeq "section",       "fragment"

my $u2 = Url::parse("http://localhost")
$u2->{scheme} |> aeq "http",      "scheme http"
$u2->{host}   |> aeq "localhost", "host localhost"
$u2->{path}   |> aeq "/",         "default path"
$u2->{query}  |> aeq "",          "empty query"

# Query string parse
fn Qs::parse($q) {
    my %out = ()
    return \%out if $q eq ""
    for my $pair (split /&/, $q) {
        my ($k, $v) = split /=/, $pair, 2
        $out{$k} = defined $v ? $v : ""
    }
    \%out
}

my $qs = Qs::parse("foo=1&bar=two&baz=")
$qs->{foo} |> aeq "1",   "qs foo"
$qs->{bar} |> aeq "two", "qs bar"
$qs->{baz} |> aeq "",    "qs baz empty"

# Query string build (sorted keys for stable output)
fn Qs::build($h) {
    join "&", maps { "#{_}=#{$h->{_}}" } sort keys %$h
}

Qs::build({ a => 1, b => 2, c => 3 }) |> aeq "a=1&b=2&c=3", "qs build"

# Percent-encode
fn Url::pct_encode($s) {
    my $out = ""
    for my $ch (split //, $s) {
        $out .= $ch =~ /[A-Za-z0-9\-_.~]/
            ? $ch
            : sprintf("%%%02X", ord $ch)
    }
    $out
}

Url::pct_encode("hello world")   |> aeq "hello%20world", "encode space"
Url::pct_encode("a=b&c")          |> aeq "a%3Db%26c",     "encode = and &"
Url::pct_encode("abc-XYZ_123.~")  |> aeq "abc-XYZ_123.~", "encode safe"
Url::pct_encode("a/b/c")          |> aeq "a%2Fb%2Fc",     "encode slashes"

# Percent-decode
fn Url::pct_decode($s) {
    my $t = $s
    $t =~ s/%([0-9A-Fa-f]{2})/chr(hex($1))/ge
    $t
}

Url::pct_decode("hello%20world") |> aeq "hello world", "decode space"
Url::pct_decode("a%3Db%26c")      |> aeq "a=b&c",       "decode = and &"
Url::pct_decode("no-percents")    |> aeq "no-percents", "decode passthrough"

# Roundtrip ASCII
Url::pct_decode(Url::pct_encode("Hello, World!"))
  |> aeq "Hello, World!", "encode/decode roundtrip"

# Join URL
fn Url::join($base, $path) {
    return $path if $path =~ m{^[a-z]+://}
    if ($path =~ m{^/}) {
        my @c = ($base =~ m{^([a-z]+://[^/]+)})
        return "#{$c[0]}#{$path}" if len(@c) > 0
    }
    return "#{$base}#{$path}" if $base =~ m{/$}
    my $rest = $base
    $rest =~ s{[^/]*$}{}
    "#{$rest}#{$path}"
}

Url::join("http://example.com/foo/bar", "baz")        |> aeq "http://example.com/foo/baz", "join relative"
Url::join("http://example.com/foo/", "baz")            |> aeq "http://example.com/foo/baz", "join trailing slash"
Url::join("http://example.com/foo/bar", "/x")           |> aeq "http://example.com/x",       "join absolute path"
Url::join("http://example.com/foo", "https://y.com/z") |> aeq "https://y.com/z",            "join absolute url"

# Registrable suffix (toy: last two labels)
fn Url::registrable($host) {
    my @parts = split /\./, $host
    return $host if len(@parts) < 2
    join(".", @parts[-2:-1])
}

Url::registrable("www.example.com")     |> aeq "example.com", "regd ex"
Url::registrable("a.b.c.d.example.org") |> aeq "example.org", "regd deep"
Url::registrable("localhost")           |> aeq "localhost",   "regd short"

test_run
