#!/usr/bin/env stryke

# Pinning batch Native-U (2026-05-10): Ultra-Specialized & Scientific
# Compliance: docs/STYLE_GUIDE.md

# ── 1. Inequality Measures ────────────────────────────────────────────────

# gini(1,1,1,1) -> 0
gini(1, 1, 1, 1) |> aeq 0, "Gini perfect equality"
# gini(0,0,0,100) -> 0.75
gini(0, 0, 0, 100) |> maps { abs(_ - 0.75) < 0.01 } |> aok "Gini high inequality"

# ── 2. Sequence Alignment (Bioinformatics) ─────────────────────────────────

smith_waterman("TGTTAC", "GGTTAC") |> aeq 10, "Smith-Waterman best local score"

# ── 3. Linear Programming ──────────────────────────────────────────────────

# max x + y s.t. x <= 1, y <= 1 -> [1, 1], 2
my $lp_res = simplex_lp([1, 1], [[1, 0], [0, 1]], [1, 1])
$lp_res->[1] |> aeq 2, "Simplex LP optimal value"
tj($lp_res->[0]) |> aeq "[1,1]", "Simplex LP solution vector"

# ── 4. Game Theory ─────────────────────────────────────────────────────────

# Pure Nash for Prisoners Dilemma
my $p1 = [[-1, -3], [0, -2]]
my $p2 = [[-1, 0], [-3, -2]]
nash_eq_2x2($p1, $p2) |> maps { _->[0][0] == 1 && _->[0][1] == 1 } |> aok "Nash 2x2"

# ── 5. Linear Algebra (Numeric) ────────────────────────────────────────────

# lu_decompose returns three pieces: L (lower-triangular 2x2), U
# (upper-triangular 2x2), and P (permutation vector). `len` is the
# outer triple count = 3 (not a fictional flattened number). Probe
# inner shape via index navigation rather than `ref` since stryke's
# ref-of-nested-array doesn't return "ARRAY".
my @lu = lu_decompose([[1, 2], [3, 4]])
len(@lu) |> aeq 3, "lu_decompose returns [L, U, P]"
$lu[0]->[0]->[0] |> aeq 1, "L[0][0] = 1 (unit lower diagonal)"
$lu[1]->[0]->[0] |> aeq 3, "U[0][0] = 3 (top-left pivot)"

# ── 6. CAS-Lite (Quadratic Factor) ─────────────────────────────────────────

factor_quadratic(1, -5, 6) |> join(",") |> aeq "2,3", "factor_quadratic roots"

# ── 7. Population Genetics ─────────────────────────────────────────────────

hardy_weinberg(0.3) |> maps { abs(_->[0] - 0.09) < 0.001 } |> aok "Hardy-Weinberg p^2"

test_run
