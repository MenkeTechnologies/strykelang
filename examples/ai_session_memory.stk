#!/usr/bin/env stryke

# Stryke AI sessions + vector memory — multi-turn chat with persistent
# semantic retrieval. Runs entirely in mock mode (no network calls)
# but exercises the full save/recall/history surface.
#
# Run with:  STRYKE_AI_MODE=mock-only s examples/ai_session_memory.stk

# ── Mocks ───────────────────────────────────────────────────────────────
# Word-boundary anchors so mock regex doesn't substring-match into later
# prompts. Without `\b`, `(?i)hi` would also fire on words like
# `matching` / `this` in unrelated prompt bodies.
#
# `embed:probe` is the sentinel mock that flips `mock_embed_active` →
# true for the rest of the script, so `ai_memory_save`/`recall` use
# the deterministic SHA-based mock embedding instead of trying to
# call out to a paid embedding provider. Required whenever AI memory
# is exercised without a real API key.
ai_mock_install("embed:probe",             "")
ai_mock_install('(?i)\bhi\b',              "Hello! I'm StrykeAgent.")
ai_mock_install('(?i)what is your name',   "My name is StrykeAgent.")
ai_mock_install('(?i)stryke',              "Stryke is a parallel Perl 5 interpreter in Rust.")

# ── Sessions ────────────────────────────────────────────────────────────

p "── multi-turn chat session ────────────────────────────";
my $sess = ai_session_new(system => "You are a helpful assistant.")
my $r1 = ai_session_send($sess, "hi")
my $r2 = ai_session_send($sess, "what is your name?")
p "  user: hi"
p "  asst: $r1"
p "  user: what is your name?"
p "  asst: $r2"

p "";
p "── history: system row + alternating user/assistant ───";
my @hist = ai_session_history($sess)
printf "  %d rows total:\n", len(@hist)
for my $i (0:len(@hist)-1) {
    printf "    [%d] %-9s : %s\n", $i, $hist[$i]->{role}, $hist[$i]->{content}
}

p "";
p "── reset: drop turns but keep system prompt ───────────";
ai_session_reset($sess)
my @after = ai_session_history($sess)
printf "  after reset: %d row(s) — role=%s\n", len(@after), $after[0]->{role}

ai_session_close($sess)

# ── Vector memory ──────────────────────────────────────────────────────

p "";
p "── persistent vector memory ───────────────────────────";
ai_memory_clear()

ai_memory_save("doc:stryke",   "Stryke is a parallel Perl 5 interpreter in Rust", +{
    category => "lang",
    tags     => "rust,perl,jit",
    priority => 1,
})
ai_memory_save("doc:nushell",  "Nushell is a structured-data shell written in Rust", +{
    category => "shell",
    tags     => "rust,shell",
    priority => 2,
})
ai_memory_save("doc:cooking",  "Apples poached with cinnamon are delicious", +{
    category => "recipe",
    priority => 3,
})

printf "  saved %d docs\n", ai_memory_count()

p "";
p "── recall returns FLAT array of hashref hits ──────────";
my @hits = ai_memory_recall("Rust scripting", top_k => 3)
printf "  recall yielded %d row(s) (top_k=3):\n", len(@hits)
for my $h (@hits) {
    my $meta = $h->{metadata}
    printf "    %-14s [%-7s] priority=%d  '%s'\n",
        $h->{id}, $meta->{category}, $meta->{priority}, $h->{content}
}

p "";
p "── metadata round-trips as a navigable hashref ────────";
my $first = $hits[0]
p "  first->{id}                      : ", $first->{id}
p "  first->{metadata}->{category}    : ", $first->{metadata}->{category}
p "  first->{metadata}->{priority}    : ", $first->{metadata}->{priority}

p "";
p "── forget one + clear ─────────────────────────────────";
ai_memory_forget("doc:cooking")
printf "  after forget(doc:cooking)  : %d remaining\n", ai_memory_count()
ai_memory_clear()
printf "  after clear                : %d remaining\n", ai_memory_count()
