#!/usr/bin/env stryke

# Extended Feature Pinning (2026-05-15)
# Testing Sketch Algebra, KV Store, Advanced OOP, and more functional helpers.
# Compliance: docs/STYLE_GUIDE.md
# Mode: --no-interop

# ── 1. Sketch Algebra (+ | & ^ -) ───────────────────────────────────────────

# Bloom union via +
my $b1 = bloom_filter(100, 0.01)
my $b2 = bloom_filter(100, 0.01)
bloom_add($b1, "a")
bloom_add($b2, "b")
my $b3 = $b1 + $b2
bloom_contains($b3, "a") |> aok "Bloom union contains 'a'"
bloom_contains($b3, "b") |> aok "Bloom union contains 'b'"
bloom_contains($b1, "b") |> { _ == 0 } |> aok "Original bloom unchanged"

# HLL union via +
my $h1 = hll(10)
my $h2 = hll(10)
hll_add($h1, "x")
hll_add($h2, "y")
my $h3 = $h1 + $h2
hll_count($h3) |> { _ >= 2 } |> aok "HLL union count >= 2"

# Roaring set algebra
my $r1 = roaring()
my $r2 = roaring()
rb_add($r1, 1)
rb_add($r1, 2)
rb_add($r2, 2)
rb_add($r2, 3)

rb_len($r1 | $r2) |> aeq 3, "Roaring union |"
rb_len($r1 & $r2) |> aeq 1, "Roaring intersection &"
rb_len($r1 ^ $r2) |> aeq 2, "Roaring sym.diff ^"
rb_len($r1 - $r2) |> aeq 1, "Roaring difference -"

# t-digest centroid merge via +
my $td1 = t_digest(10)
my $td2 = t_digest(10)
td_add($td1, 10)
td_add($td2, 20)
my $td3 = $td1 + $td2
td_quantile($td3, 0.5) |> { 10 <= _ <= 20 } |> aok "t-digest merge p50 in range"

# TopK merge via +
my $tk1 = topk(5)
my $tk2 = topk(5)
topk_add($tk1, "apple")
topk_add($tk2, "banana")
my $tk3 = $tk1 + $tk2
topk_heavies($tk3) |> len |> aeq 2, "TopK merge count"

# ── 2. rkyv KV Store ────────────────────────────────────────────────────────

my $kv_path = "/tmp/test_kv.rkyv"
unlink($kv_path)
my $db = kv_open($kv_path)
kv_put($db, "k1", "v1")
kv_put($db, "k2", +{ a => 1 })
kv_get($db, "k1") |> aeq "v1", "KV get string"
kv_get($db, "k2")->{a} |> aeq 1, "KV get hashref"
kv_exists($db, "k1") |> aok "KV exists true"
kv_exists($db, "k3") |> { _ == 0 } |> aok "KV exists false"
kv_len($db) |> aeq 2, "KV len"
kv_keys($db) |> join(",") |> aeq "k1,k2", "KV keys"
kv_del($db, "k1")
kv_len($db) |> aeq 1, "KV len after del"
kv_commit($db)
kv_close($db)

my $db2 = kv_open($kv_path)
kv_len($db2) |> aeq 1, "KV reopen len"
kv_get($db2, "k2")->{a} |> aeq 1, "KV reopen get"
kv_close($db2)
unlink($kv_path)

# ── 3. Advanced OOP ─────────────────────────────────────────────────────────

# Traits and default methods
trait Greetable {
    fn greeting { "Hello" }
    fn name
}

class Person impl Greetable {
    n : Str
    fn name { $self->n }
}

class FormalPerson impl Greetable {
    n : Str
    fn name { $self->n }
    fn greeting { "Good day" }
}

my $p1 = Person(n => "Alice")
$p1->greeting() |> aeq "Hello", "Trait default method"
$p1->does("Greetable") |> aok "does(Trait) works"

my $p2 = FormalPerson(n => "Bob")
$p2->greeting() |> aeq "Good day", "Trait method override"

# Abstract classes
abstract class Shape {
    fn area
}

class Circle extends Shape {
    radius : Float
    fn area { 3.14159 * $self->radius * $self->radius }
}

my $c = Circle(radius => 10)
$c->area() |> { 314.1 <= _ <= 314.2 } |> aok "Circle area from abstract Shape"

# Operator Overloading
class Vec2 {
    x : Float; y : Float
    fn op_add($other) {
        Vec2(x => $self->x + $other->x, y => $self->y + $other->y)
    }
    fn stringify { "(" . $self->x . "," . $self->y . ")" }
}

my $v1 = Vec2(x => 1, y => 2)
my $v2 = Vec2(x => 10, y => 20)
my $v3 = $v1 + $v2
$v3->stringify() |> aeq "(11,22)", "Operator overloading op_add"

# ── 4. Deep Utilities ───────────────────────────────────────────────────────

my $orig = { a => [1, 2], b => { c => 3 } }
my $cloned = deep_clone($orig)
$cloned->{a}[0] = 99
$orig->{a}[0] |> aeq 1, "deep_clone is deep"

deep_equal($orig, { a => [1, 2], b => { c => 3 } }) |> aok "deep_equal true"
deep_equal($orig, $cloned) |> { _ == 0 } |> aok "deep_equal false"

my $m1 = { a => 1, b => { x => 10 } }
my $m2 = { c => 2, b => { y => 20 } }
my $merged = deep_merge($m1, $m2)
$merged->{b}{x} |> aeq 10, "deep_merge b.x"
$merged->{b}{y} |> aeq 20, "deep_merge b.y"
$merged->{c} |> aeq 2, "deep_merge c"

# ── 5. Functional Builtins ──────────────────────────────────────────────────

zip_with { _ + _1 } [1, 2, 3], [10, 20, 30] |> join(",") |> aeq "11,22,33", "zip_with"

my ($even, $odd) = partition { _ % 2 == 0 } 1:10
$even |> len |> aeq 5, "partition even count"
$odd  |> len |> aeq 5, "partition odd count"

interleave [1, 2, 3], ["a", "b", "c"] |> join(",") |> aeq "1,a,2,b,3,c", "interleave"

"a b a c" |> words |> frequencies |> { _->{a} } |> aeq 2, "frequencies"

1:20 |> map { _ % 3 == 0 ? "mod3" : "other" } |> frequencies |> { _->{mod3} } |> aeq 6, "count_by_manual"

# ── 6. Pipeline Regex ───────────────────────────────────────────────────────

"hello world" |> s/world/stryke/ |> aeq "hello stryke", "Pipe s///"
"abc" |> tr/a-z/A-Z/ |> aeq "ABC", "Pipe tr///"
"foo123bar456" |> /\d+/g |> join(",") |> aeq "123,456", "Pipe m//g"

# ── 7. Glob ─────────────────────────────────────────────────────────────────

my $tdir = tempdir()
spurt($tdir . "/f1.txt", "hi")
mkdir($tdir . "/subdir")
spurt($tdir . "/subdir/f2.log", "bye")

glob($tdir . "/**/*") |> len |> { _ >= 3 } |> aok "Glob basic"

unlink($tdir . "/f1.txt")
unlink($tdir . "/subdir/f2.log")
rmdir($tdir . "/subdir")
rmdir($tdir)

test_run
