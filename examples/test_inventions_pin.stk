#!/usr/bin/env stryke

# Pinning batch Native-V (2026-05-10): Inventions & Architectural Highlights
# Compliance: docs/STYLE_GUIDE.md

# ── 1. Streaming Thread Macros (~s>) ───────────────────────────────────────

# ~s> runs each stage as a worker thread. 
# Side-effects on non-sync variables are thread-local or lost.
oursync @stream_results = ()
~s> range(1, 5) map { _ * 10 } tap { push @stream_results, _ } |> collect
len(@stream_results) |> aeq 5, "streaming macro tap count"
join(",", sort(@stream_results)) |> aeq "10,20,30,40,50", "streaming macro content"

# ── 2. Parallel Chunk Stages (par / par_reduce) ───────────────────────────

# par { } flattens chunk outputs
~> "hello world" par { letters } |> join("") |> aeq "helloworld", "par letters flattening"

# par_reduce { } auto-merges
# Number -> sum
~> (1:100) par_reduce { sum } |> aeq 5050, "par_reduce numeric sum"
# Hash<num> -> key-wise add
my $merged_h = ~> "aaabbc" par_reduce { letters |> freq }
$merged_h->{a} |> aeq 3, "par_reduce hash merge"

# ── 3. Indexed Outer Topics (_<N) ──────────────────────────────────────────

my $invention_depth = 0
range(1, 1) |> e {
    range(2, 2) |> e {
        range(3, 3) |> e {
            $invention_depth = _ + _<1 + _<2
        }
    }
}
$invention_depth |> aeq 6, "indexed depth topics _<N"

# ── 4. Block Param Alignment (|p| -> _) ───────────────────────────────────

(10, 20) |> map { |$x| _ } |> join(",") |> aeq "10,20", "named param $x maps to _"
(10, 20) |> map { |$x| _0 } |> join(",") |> aeq "10,20", "named param $x maps to _0"

# ── 5. Multi-line Comma Regex (s,,) ───────────────────────────────────────

my $re_val = "foo,bar"
$re_val =~ s,foo,baz,
$re_val |> aeq "baz,bar", "s,,, comma delimiter"

# ── 6. Range Inferences (Extreme) ──────────────────────────────────────────

# Dateseq requires explicit step today
dateseq("2026-05-10", "2026-05-12", "1d") |> join(",") |> aeq "2026-05-10,2026-05-11,2026-05-12", "iso date sequence"

test_run
