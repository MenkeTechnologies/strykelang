#!/usr/bin/env stryke

# Collection / array / hash operations.

fn Coll::partition($pred, @xs) {
    val @t = grep { $pred(_) } @xs
    val @f = grep { !$pred(_) } @xs
    (\@t, \@f)
}

fn Coll::chunk($n, @xs) {
    var @out
    var $i = 0
    while ($i < len(@xs)) {
        var @slice
        var $j = $i
        while ($j < $i + $n && $j < len(@xs)) {
            push @slice, $xs[$j]
            $j++
        }
        push @out, \@slice
        $i += $n
    }
    \@out
}

fn Coll::zip($r1, $r2) {
    var @out
    val $n = len(@$r1) < len(@$r2) ? len(@$r1) : len(@$r2)
    for val $i (0:$n - 1) {
        push @out, [$r1->[$i], $r2->[$i]]
    }
    \@out
}

fn Coll::flatten($ref) {
    var @out
    for var $e (@$ref) {
        if (ref($e) eq "ARRAY") {
            push @out, @{Coll::flatten($e)}
        } else {
            push @out, $e
        }
    }
    \@out
}

fn Coll::group_by($keyfn, @xs) {
    var %g
    for val $x (@xs) {
        val $k = $keyfn($x)
        $g{$k} ||= []
        push @{$g{$k}}, $x
    }
    \%g
}

fn Coll::count_if($pred, @xs) {
    var $n = 0
    $pred(_) && $n++ for @xs
    $n
}

# partition
val ($evens, $odds) = Coll::partition(fn ($n) { $n % 2 == 0 }, 1, 2, 3, 4, 5, 6)
join(",", @$evens) |> aeq "2,4,6", "partition evens"
join(",", @$odds)  |> aeq "1,3,5", "partition odds"

# chunk
val $chunks = Coll::chunk(3, 1, 2, 3, 4, 5, 6, 7)
len(@$chunks)              |> aeq 3, "chunk count"
join(",", @{$chunks->[0]}) |> aeq "1,2,3", "chunk 0"
join(",", @{$chunks->[2]}) |> aeq "7", "chunk last tail"

# zip
val $z = Coll::zip([1, 2, 3], ["a", "b", "c"])
$z->[1][0] |> aeq 2, "zip val"
$z->[2][1] |> aeq "c", "zip key"
len(@$z)   |> aeq 3, "zip len"

# flatten (nested)
val $flat = Coll::flatten([1, [2, [3, [4, 5]], 6], 7])
join(",", @$flat) |> aeq "1,2,3,4,5,6,7", "flatten deep"

# group_by
val $g = Coll::group_by(fn ($x) { $x % 3 }, 1, 2, 3, 4, 5, 6, 7, 8, 9)
len(@{$g->{0}}) |> aeq 3, "group_by 0"
len(@{$g->{1}}) |> aeq 3, "group_by 1"
len(@{$g->{2}}) |> aeq 3, "group_by 2"

# count_if
Coll::count_if(fn ($n) { $n > 3 }, 1, 2, 3, 4, 5, 6) |> aeq 3, "count_if"

# Stdlib pipelines on collections
(1:10) |> grep { _ % 2 == 0 } |> map { _ * _ } |> sum |> aeq 220, "even squares sum"
~> (3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5) uniq |> sort |> join(",") |> aeq "1,2,3,4,5,6,9", "uniq sort"

# hash inversion
val %h = (a => 1, b => 2, c => 3)
val %inv = map { ($h{_}, _) } keys %h
$inv{2} |> aeq "b", "hash inversion"

test_run
