#!/usr/bin/env stryke

# Pinning batch Native-E (2026-05-10): Advanced Types & Const (from BUGS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Const and Frozen with Types ───────────────────────────────────────────

const val $x : Int = 42
$x |> aeq 42, "const my with type annotation"

# ── Class Instances and Dereferencing ─────────────────────────────────────

class Point {
    x : Int
    y : Int
}

val $p = Point->new(x => 10, y => 20)
ref($p) |> aeq "Point", "ref() on class instance"

val %fields = %$p
keys(%fields) |> sort { _ cmp _1 } |> join(",") |> aeq "x,y", "deref class instance keys"
$fields{x} |> aeq 10, "deref class instance value x"

# ── Recursive Serialization ───────────────────────────────────────────────

class Node {
    name : Str
    child : Node
}

val $root = Node->new(
    name => "parent",
    child => Node->new(name => "child")
)

tj($root) |> maps { _ =~ /"name":"parent"/ } |> aok "recursive JSON"

test_run
