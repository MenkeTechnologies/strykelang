#!/usr/bin/env stryke

package NeedlemanWunsch

fn solve($seq1, $seq2, $match_score, $mismatch_penalty, $gap_penalty) {
    val $n = len $seq1; val $m = len $seq2
    val $dp = []
    for val $i (0 : $n) {
        val $row = []
        for val $j (0 : $m) { push @$row, 0 }
        push @$dp, $row
    }
    for val $i (0 : $n) { $dp->[$i]->[0] = $i * $gap_penalty }
    for val $j (0 : $m) { $dp->[0]->[$j] = $j * $gap_penalty }
    for val $i (1 : $n) {
        for val $j (1 : $m) {
            val $match = $dp->[$i - 1]->[$j - 1] + ($seq1[$i - 1] eq $seq2[$j - 1] ? $match_score : $mismatch_penalty)
            val $delete = $dp->[$i - 1]->[$j] + $gap_penalty
            val $insert = $dp->[$i]->[$j - 1] + $gap_penalty
            var $max_val = $match
            $max_val = $delete if $delete > $max_val
            $max_val = $insert if $insert > $max_val
            $dp->[$i]->[$j] = $max_val
        }
    }
    var $align1 = ""; var $align2 = ""; var $i = $n; var $j = $m
    while ($i > 0 || $j > 0) {
        if ($i > 0 && $j > 0 && $dp->[$i]->[$j] == $dp->[$i - 1]->[$j - 1] + ($seq1[$i - 1] eq $seq2[$j - 1] ? $match_score : $mismatch_penalty)) {
            $align1 = $seq1[$i - 1] . $align1; $align2 = $seq2[$j - 1] . $align2; $i--; $j--
        } elsif ($i > 0 && $dp->[$i]->[$j] == $dp->[$i - 1]->[$j] + $gap_penalty) {
            $align1 = $seq1[$i - 1] . $align1; $align2 = "-" . $align2; $i--
        } else {
            $align1 = "-" . $align1; $align2 = $seq2[$j - 1] . $align2; $j--
        }
    }
    { score => $dp->[$n]->[$m], align1 => $align1, align2 => $align2 }
}

package main

# --- Basic E2E ---
val $res1 = NeedlemanWunsch::solve("GATTACA", "GCATGCU", 1, -1, -2)
$res1->{score} |> aeq -1, "GATTACA vs GCATGCU score"

val $res2 = NeedlemanWunsch::solve("AAAA", "A", 1, -1, -1)
$res2->{score} |> aeq -2, "AAAA vs A score"
$res2->{align1} |> aeq "AAAA", "AAAA vs A align1"
$res2->{align2} |> aeq "---A", "AAAA vs A align2" # Alternative optimal alignments exist but this is standard

test_run
