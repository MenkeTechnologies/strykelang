#!/usr/bin/env stryke

package BK;

fn lev($s1, $s2) {
    val $n = len $s1
    val $m = len $s2
    return $m if $n == 0
    return $n if $m == 0
    var @prev = ()
    for val $j (0:$m) { push @prev, $j }
    for val $i (1:$n) {
        var @cur = ($i)
        for val $j (1:$m) {
            val $cost = substr($s1, $i - 1, 1) eq substr($s2, $j - 1, 1) ? 0 : 1
            val $del = $prev[$j] + 1
            val $ins = $cur[$j - 1] + 1
            val $sub = $prev[$j - 1] + $cost
            var $mn = $del
            $mn = $ins if $ins < $mn
            $mn = $sub if $sub < $mn
            push @cur, $mn
        }
        @prev = @cur
    }
    $prev[$m]
}

fn new() { { root => undef } }

fn _node($w) { { word => $w, ch => {} } }

fn add($t, $w) {
    if (!defined $t->{root}) {
        $t->{root} = BK::_node($w)
        return
    }
    var $node = $t->{root}
    while (1) {
        val $d = BK::lev($w, $node->{word})
        return if $d == 0
        if (exists $node->{ch}->{$d}) {
            $node = $node->{ch}->{$d}
        } else {
            $node->{ch}->{$d} = BK::_node($w)
            return
        }
    }
}

fn _search($node, $w, $k, $out) {
    return if !defined $node
    val $d = BK::lev($w, $node->{word})
    push @$out, $node->{word} if $d <= $k
    val $lo = $d - $k
    val $hi = $d + $k
    val @keys = sort keys %{$node->{ch}}
    for val $dk (@keys) {
        if ($dk >= $lo && $dk <= $hi) {
            BK::_search($node->{ch}->{$dk}, $w, $k, $out)
        }
    }
}

fn search($t, $w, $k) {
    var @out = ()
    BK::_search($t->{root}, $w, $k, \@out)
    @out = sort @out
    \@out
}

package main;

# --- Levenshtein basics ---
BK::lev("", "")          |> aeq 0, "lev empty"
BK::lev("a", "")         |> aeq 1, "lev a empty"
BK::lev("", "abc")       |> aeq 3, "lev empty abc"
BK::lev("abc", "abc")    |> aeq 0, "lev equal"
BK::lev("abc", "abd")    |> aeq 1, "lev 1 sub"
BK::lev("abc", "axc")    |> aeq 1, "lev 1 sub middle"
BK::lev("abc", "ab")     |> aeq 1, "lev 1 del"
BK::lev("abc", "abcd")   |> aeq 1, "lev 1 ins"
BK::lev("kitten", "sitting") |> aeq 3, "lev classic"
BK::lev("flaw", "lawn")  |> aeq 2, "lev flaw lawn"
BK::lev("hello", "world") |> aeq 4, "lev hello world"

# Symmetry
BK::lev("foo", "bar") |> aeq BK::lev("bar", "foo"), "lev symmetric"
BK::lev("kitten", "sitting") |> aeq BK::lev("sitting", "kitten"), "lev symmetric 2"

# --- Empty tree ---
val $te = BK::new()
len(@{BK::search($te, "any", 5)}) |> aeq 0, "empty search no matches"
(defined $te->{root}) |> aeq 0, "empty root undef"

# --- Single word ---
val $t1 = BK::new()
BK::add($t1, "hello")
join(",", @{BK::search($t1, "hello", 0)}) |> aeq "hello", "single exact"
join(",", @{BK::search($t1, "helxo", 1)}) |> aeq "hello", "single within 1"
len(@{BK::search($t1, "world", 1)}) |> aeq 0, "single far away"
len(@{BK::search($t1, "world", 4)}) |> aeq 1, "single within 4"
join(",", @{BK::search($t1, "world", 4)}) |> aeq "hello", "single via dist 4"

# --- Duplicate add is no-op ---
val $td = BK::new()
BK::add($td, "foo")
BK::add($td, "foo")
BK::add($td, "foo")
join(",", @{BK::search($td, "foo", 0)}) |> aeq "foo", "dup add: only one"
len(@{BK::search($td, "fox", 1)}) |> aeq 1, "dup add still one"

# --- Multiple words ---
val $t = BK::new()
for val $w ("book", "books", "boo", "boon", "cook", "cake", "cape", "cart") {
    BK::add($t, $w)
}

# Exact match
join(",", @{BK::search($t, "book", 0)}) |> aeq "book", "exact book"

# Within edit distance 1
join(",", @{BK::search($t, "book", 1)}) |> aeq "boo,book,books,boon,cook", "k=1 of book"

# Within edit distance 1 of 'caqe'
join(",", @{BK::search($t, "caqe", 1)}) |> aeq "cake,cape", "k=1 of caqe"

# Within edit distance 2 of 'boook'
join(",", @{BK::search($t, "boook", 2)}) |> aeq "boo,book,books,boon,cook", "k=2 of boook"

# Nothing within k=0 of unknown
len(@{BK::search($t, "zebra", 0)}) |> aeq 0, "no zebra"

# Big k returns everything
val $all = BK::search($t, "x", 20)
len(@$all) |> aeq 8, "k=20 returns all 8"

# Search returns sorted output
val $sr = BK::search($t, "book", 2)
var $sorted = 1
for val $i (0:len(@$sr)-2) {
    $sorted = 0 if $sr->[$i] gt $sr->[$i + 1]
}
$sorted |> aeq 1, "results sorted"

# --- Equivalence with brute force on a small dictionary ---
val $tb = BK::new()
val @words = ("apple", "apply", "ample", "amplep", "snake", "snare", "stare", "spare", "spark")
for val $w (@words) { BK::add($tb, $w) }

# Brute force: for each query / k, compute true matches
for val $q ("apple", "snake", "spare", "amplx") {
    for val $k (0, 1, 2) {
        var @expected = ()
        for val $w (@words) {
            push @expected, $w if BK::lev($q, $w) <= $k
        }
        @expected = sort @expected
        val $got = BK::search($tb, $q, $k)
        join(",", @$got) |> aeq join(",", @expected), "match brute: " . $q . " k=" . $k
    }
}

# --- Numeric/short strings ---
val $tn = BK::new()
for val $w ("1", "12", "123", "1234", "21") { BK::add($tn, $w) }
join(",", @{BK::search($tn, "12", 1)}) |> aeq "1,12,123", "numeric strings k=1"

test_run
