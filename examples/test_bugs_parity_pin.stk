#!/usr/bin/env stryke

# Pinning batch Native-C (2026-05-10): Bugs & Parity (from BUGS.md)
# Compliance: docs/STYLE_GUIDE.md

# ── Magic String Increment ───────────────────────────────────────────────

fn Pin::BugsParity::my_inc($s) { $s++; $s }
Pin::BugsParity::my_inc("z") |> aeq "aa", "magic inc z -> aa"
Pin::BugsParity::my_inc("Az") |> aeq "Ba", "magic inc Az -> Ba"
Pin::BugsParity::my_inc("") |> aeq "1", "magic inc empty -> 1"

# ── Vec Lvalue ─────────────────────────────────────────────────────────────

var $bits = ""
vec($bits, 0, 8) = 65
$bits |> aeq "A", "vec lvalue assignment"

# ── Inf / NaN Numification ────────────────────────────────────────────────

"Inf" + 0 |> tj |> aeq "inf", "Inf numification"
sqrt(-1) |> tj |> aeq "NaN", "NaN stringification"

# ── For In-place Mutation ─────────────────────────────────────────────────

val @list = (1, 2, 3)
for (@list) { _ *= 10 }
join(",", @list) |> aeq "10,20,30", "for loop in-place mutation"

# ── Tail Binding ──────────────────────────────────────────────────────────

val ($head, @tail) = (10, 20, 30, 40)
$head |> aeq 10, "head binding"
join(",", @tail) |> aeq "20,30,40", "tail binding"

# ── PSort with _, _1 ────────────────────────────────────────────────────

(5, 2, 8, 1) |> psort { _ <=> _1 } |> join(",") |> aeq "1,2,5,8", "psort with _, _1"

# ── Dijkstra Deterministic Order ─────────────────────────────────────────

val $graph = +{
    A => [["B", 1], ["C", 4]],
    B => [["C", 2]],
    C => []
}
dijkstra($graph, "A") |> tj |> aeq '["A",0,"B",1,"C",3]', "dijkstra deterministic JSON"

test_run
