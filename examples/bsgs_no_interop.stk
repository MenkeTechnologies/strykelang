#!/usr/bin/env stryke

# Baby-step / giant-step вҖ” discrete logarithm in cyclic groups: find
# the smallest non-negative `x` with `g^x вүЎ h (mod p)`, given a
# generator `g`, target `h`, and prime modulus `p`. Splits the search
# `x = iВ·m вҲ’ j` (where m = вҢҲвҲҡ(pвҲ’1)вҢү) into m "baby" steps `g^j` cached
# in a hash, and m "giant" steps `h В· (g^m)^i` probed against the
# hash. O(вҲҡp) time + O(вҲҡp) memory. Cross-validated by recomputing
# `g^x mod p` and comparing against `h`.
#
# Style-guide conformance (docs/STYLE_GUIDE.md):
#   * named-package fns (`Bsgs::`) under --no-interop (В§18)
#   * `:` ranges, `len` for sizes, `#{ }` interpolation (В§4, В§5, В§1a)
#   * implicit return on tail, no trailing `;` (В§3, В§12b)
#
# Run: stryke --no-interop examples/bsgs_no_interop.stk

# в”Җв”Җ modular exponentiation a^e mod m в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn Bsgs::pow_mod($base, $exp, $m) {
    return 0 if $m == 1
    var $result = 1
    var $bx = $base % $m
    var $e = $exp
    while ($e > 0) {
        if ($e & 1) {
            $result = ($result * $bx) % $m
        }
        $e = int($e / 2)
        $bx = ($bx * $bx) % $m
    }
    $result
}

# в”Җв”Җ extended Euclidean вҶ’ modular inverse в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn Bsgs::ext_gcd($ax, $bx) {
    return +{ g => $ax, x => 1, y => 0 } if $bx == 0
    val $q = int($ax / $bx)
    val $r = $ax - $q * $bx
    val $sub = Bsgs::ext_gcd($bx, $r)
    +{
        g => $sub->{g},
        x => $sub->{y},
        y => $sub->{x} - $q * $sub->{y},
    }
}

fn Bsgs::mod_inverse($ax, $m) {
    val $r = Bsgs::ext_gcd($ax, $m)
    die "no inverse: gcd(#{$ax}, #{$m}) = #{$r->{g}}" unless $r->{g} == 1
    var $inv = $r->{x} % $m
    $inv += $m if $inv < 0
    $inv
}

# в”Җв”Җ integer ceiling of вҲҡn в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn Bsgs::isqrt_ceil($n) {
    return 0 if $n <= 0
    var $r = int(sqrt($n))
    while ($r * $r < $n) {
        $r++
    }
    $r
}

# в”Җв”Җ core BSGS вҖ” returns +{ ok => 0/1, x => smallest non-neg } в”Җв”Җв”Җв”Җ

fn Bsgs::dlog($g, $h, $p) {
    val $gg = $g % $p
    val $hh = $h % $p
    if ($hh == 1) {
        return +{ ok => 1, x => 0 }
    }
    val $m = Bsgs::isqrt_ceil($p - 1)
    # Baby steps: tab[g^j] = j for j = 0..m-1.
    var %tab
    var $cur = 1
    for val $j (0:$m - 1) {
        if (!exists $tab{$cur}) {
            $tab{$cur} = $j
        }
        $cur = ($cur * $gg) % $p
    }
    # Giant step factor: (g^m)^{-1} mod p, applied each iteration to h.
    val $gm = Bsgs::pow_mod($gg, $m, $p)
    val $gm_inv = Bsgs::mod_inverse($gm, $p)
    var $gamma = $hh
    for val $i (0:$m - 1) {
        if (exists $tab{$gamma}) {
            val $j = $tab{$gamma}
            val $x = $i * $m + $j
            return +{ ok => 1, x => $x }
        }
        $gamma = ($gamma * $gm_inv) % $p
    }
    +{ ok => 0, x => -1 }
}

# в”Җв”Җ O(p) brute force discrete log for cross-validation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn Bsgs::brute_dlog($g, $h, $p) {
    val $gg = $g % $p
    val $hh = $h % $p
    var $cur = 1
    for val $x (0:$p - 2) {
        if ($cur == $hh) {
            return +{ ok => 1, x => $x }
        }
        $cur = ($cur * $gg) % $p
    }
    +{ ok => 0, x => -1 }
}

# в”Җв”Җ primary cases в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

var @cases = (
    +{ g => 2,  h => 5,   p => 23  },   # 2^4 = 16, 2^16 = 5 mod 23
    +{ g => 2,  h => 1,   p => 23  },   # x = 0
    +{ g => 5,  h => 3,   p => 41  },
    +{ g => 3,  h => 13,  p => 17  },
    +{ g => 7,  h => 8,   p => 23  },
    +{ g => 3,  h => 23,  p => 113 },
    +{ g => 2,  h => 263, p => 491 },
    +{ g => 5,  h => 1000, p => 1009 },
)

p "в”Җв”Җ baby-step / giant-step discrete-log demo в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
printf "  %5s  %6s  %6s  %6s\n", "g", "h", "p", "x"
printf "  %5s  %6s  %6s  %6s\n", "-----", "------", "------", "------"
for val $c (@cases) {
    val $r = Bsgs::dlog($c->{g}, $c->{h}, $c->{p})
    if ($r->{ok}) {
        printf "  %5d  %6d  %6d  %6d\n", $c->{g}, $c->{h}, $c->{p}, $r->{x}
    } else {
        printf "  %5d  %6d  %6d  %6s\n", $c->{g}, $c->{h}, $c->{p}, "вҖ”"
    }
}

# в”Җв”Җ invariant 1: g^x mod p equals h on every reported solution в”Җв”Җв”Җв”Җ

for val $c (@cases) {
    val $r = Bsgs::dlog($c->{g}, $c->{h}, $c->{p})
    next unless $r->{ok}
    val $check = Bsgs::pow_mod($c->{g}, $r->{x}, $c->{p})
    die "g^x check failed on (g=#{$c->{g}}, h=#{$c->{h}}, p=#{$c->{p}}): #{$check} != #{$c->{h}}" unless $check == $c->{h} % $c->{p}
}

# в”Җв”Җ invariant 2: x is in [0, p-1) for every solution в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

for val $c (@cases) {
    val $r = Bsgs::dlog($c->{g}, $c->{h}, $c->{p})
    next unless $r->{ok}
    die "x #{$r->{x}} out of [0, #{$c->{p} - 1}) on (g=#{$c->{g}}, h=#{$c->{h}}, p=#{$c->{p}})" unless $r->{x} >= 0 && $r->{x} < $c->{p} - 1
}

# в”Җв”Җ invariant 3: BSGS agrees with brute force (small p) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

for val $c (@cases) {
    next if $c->{p} > 200
    val $bs = Bsgs::dlog($c->{g}, $c->{h}, $c->{p})
    val $br = Bsgs::brute_dlog($c->{g}, $c->{h}, $c->{p})
    die "ok mismatch on (g=#{$c->{g}}, h=#{$c->{h}}, p=#{$c->{p}}): bsgs=#{$bs->{ok}} brute=#{$br->{ok}}" unless $bs->{ok} == $br->{ok}
    next unless $bs->{ok}
    # Both should refer to the same element; allow x's that differ
    # by a multiple of group order вҖ” verify by g^x вүЎ h instead.
    val $check_bs = Bsgs::pow_mod($c->{g}, $bs->{x}, $c->{p})
    val $check_br = Bsgs::pow_mod($c->{g}, $br->{x}, $c->{p})
    die "bsgs check failed for (g=#{$c->{g}}, h=#{$c->{h}}, p=#{$c->{p}}): #{$check_bs} != h" unless $check_bs == $c->{h}
    die "brute check failed for (g=#{$c->{g}}, h=#{$c->{h}}, p=#{$c->{p}}): #{$check_br} != h" unless $check_br == $c->{h}
}

# в”Җв”Җ invariant 4: h = 1 always returns x = 0 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

for val $p (7, 11, 13, 17, 23, 31, 41, 101, 113, 257) {
    val $r = Bsgs::dlog(3, 1, $p)
    die "dlog(3, 1, #{$p}) must be ok with x=0" unless $r->{ok} && $r->{x} == 0
}

# в”Җв”Җ invariant 5: h = g returns x = 1 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

for val $p (7, 11, 13, 23, 41, 101) {
    for val $g (2, 3, 5) {
        next if $g >= $p
        val $r = Bsgs::dlog($g, $g, $p)
        die "dlog(#{$g}, #{$g}, #{$p}) must yield x вүҘ 1" unless $r->{ok} && $r->{x} >= 1
        # Verify it's a real solution (x might be 1 or > 1 for any subgroup).
        val $check = Bsgs::pow_mod($g, $r->{x}, $p)
        die "g^x != g for dlog(#{$g}, #{$g}, #{$p}): got #{$check}" unless $check == $g
    }
}

# в”Җв”Җ invariant 6: mod_inverse round-trip: a В· aвҒ»В№ вүЎ 1 (mod p) в”Җв”Җв”Җв”Җв”Җв”Җ

for val $pair ([5, 23], [7, 41], [3, 113], [11, 1009], [17, 257]) {
    val $inv = Bsgs::mod_inverse($pair->[0], $pair->[1])
    val $prod = ($pair->[0] * $inv) % $pair->[1]
    die "inverse round-trip failed on (#{$pair->[0]}, #{$pair->[1]})" unless $prod == 1
}

# в”Җв”Җ invariant 7: dlog round-trip вҖ” for every y in [0, p-2], в”Җв”Җв”Җв”Җв”Җв”Җ
# dlog(g, g^y mod p, p) recovers some x with g^x вүЎ g^y (mod p).

for val $p (23, 41, 113) {
    val $g = 2
    for val $y (0:$p - 2) {
        val $h = Bsgs::pow_mod($g, $y, $p)
        val $r = Bsgs::dlog($g, $h, $p)
        die "dlog roundtrip ok=0 on (g=#{$g}, y=#{$y}, p=#{$p})" unless $r->{ok}
        val $check = Bsgs::pow_mod($g, $r->{x}, $p)
        die "round-trip h mismatch on (g=#{$g}, y=#{$y}, p=#{$p}): #{$check} != #{$h}" unless $check == $h
    }
}

p ""
p "в”Җв”Җ all seven invariants satisfied в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
