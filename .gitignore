/target

# CPAN local-lib from parity/cpan_topn/install_deps.sh (reproducible via MODULES.txt + cpanm).
/parity/cpan_topn/local/

# cargo-fuzz build + run artifacts. Seed corpus under `fuzz/corpus/` stays tracked
# (it's the regression suite for `tests/fuzz_smoke.rs`); generated mutations and
# crash reproducers do not.
/fuzz/target/
/fuzz/artifacts/
/fuzz/coverage/
/fuzz/Cargo.lock

# Per-run parity failure log — truncated on each `bash parity/run_parity.sh`.
# Noisy diff content; upload as CI artifact instead of committing.
# `parity_summary.json` stays tracked — it feeds the docs badge.
/parity/parity_failures.log

# Downloaded fonts for scripts/reference_pdf.sh
docs/.fonts/

# Paid products — companion book + reference manual/PDF + their build pipeline —
# live in the private menke-books repo. Never track them here. The free docs
# landing page (docs/index.html) and the public gen-docs binary stay tracked;
# docs/reference.html is a local gen-docs artifact and is intentionally ignored.
docs/book.md
docs/book.tex
docs/book.pdf
docs/reference.html
docs/reference.tex
docs/reference.pdf
scripts/book_pdf.sh
scripts/reference_pdf.sh
scripts/pdf_theme_lib.sh
scripts/reference_pdf_theme.tex
